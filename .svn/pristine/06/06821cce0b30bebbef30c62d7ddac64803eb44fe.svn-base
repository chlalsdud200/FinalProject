(function () {
    'use strict';

    function getCtxPath() {
        const meta = document.querySelector('meta[name="ctx-path"]');
        return meta ? meta.getAttribute('content') : '';
    }

    function getCsrf() {
        const token = document.querySelector('meta[name="_csrf"]')?.content;
        const header = document.querySelector('meta[name="_csrf_header"]')?.content;

        return { token, header };
    }

    function setText(id, text) {
        const el = document.getElementById(id);
        if (el) {
            el.textContent = text;
        }
    }

    function setHtml(id, html) {
        const el = document.getElementById(id);
        if (el) {
            el.innerHTML = html;
        }
    }

    window.handleFreightCertFiles = function (input) {
        setFreightCertFileName(input);
        renderFreightCertTable(input);
        resetFreightCertCompareResult();
    };

    function setFreightCertFileName(input) {
        const target = document.getElementById('freightCertFileName');

        if (!target || !input || !input.files) {
            return;
        }

        if (input.files.length === 0) {
            target.textContent = 'PDF · JPG · PNG — 최대 20MB';
            return;
        }

        target.textContent = input.files[0].name;
    }

    function renderFreightCertTable(input) {
        const tbody = document.getElementById('freightCertUploadTbody');

        if (!tbody || !input || !input.files) {
            return;
        }

        tbody.innerHTML = '';

        if (input.files.length === 0) {
            tbody.innerHTML =
                '<tr class="empty-row">' +
                '   <td colspan="4" style="text-align:center;color:#94a3b8;padding:18px;">' +
                '       첨부된 신고필증이 없습니다.' +
                '   </td>' +
                '</tr>';
            return;
        }

        const file = input.files[0];

        tbody.innerHTML =
            '<tr class="new-file-row">' +
            '   <td><span class="doc-type-pill">신고필증</span></td>' +
            '   <td class="td-id"><span class="doc-file-name">' + escapeHtml(file.name) + '</span></td>' +
            '   <td><span class="doc-status wait">대조대기</span></td>' +
            '   <td class="doc-actions">' +
            '       <button type="button" class="mini mini-reject" onclick="clearFreightCertFile()">삭제</button>' +
            '   </td>' +
            '</tr>';
    }

    window.clearFreightCertFile = function () {
        const input = document.getElementById('freightCertFile');

        if (input) {
            input.value = '';
        }

        setText('freightCertFileName', 'PDF · JPG · PNG — 최대 20MB');

        const tbody = document.getElementById('freightCertUploadTbody');

        if (tbody) {
            tbody.innerHTML =
                '<tr class="empty-row">' +
                '   <td colspan="4" style="text-align:center;color:#94a3b8;padding:18px;">' +
                '       첨부된 신고필증이 없습니다.' +
                '   </td>' +
                '</tr>';
        }

        resetFreightCertCompareResult();
    };

    function resetFreightCertCompareResult() {
        setText('certExtractedBlNo', '파일 업로드 후 자동 판독');
        setText('certMatchResult', '대조 전');

        const certMatchYn = document.getElementById('certMatchYn');
        const extractedBlNo = document.getElementById('extractedBlNo');
        const matchMethodCd = document.getElementById('matchMethodCd');
        const submitBtn = document.getElementById('freightCertSubmitBtn');

        if (certMatchYn) certMatchYn.value = 'N';
        if (extractedBlNo) extractedBlNo.value = '';
        if (matchMethodCd) matchMethodCd.value = '';
        if (submitBtn) submitBtn.disabled = true;

        setHtml(
            'certAiMessage',
            '<span class="material-symbols-outlined">smart_toy</span>' +
            '신고필증 파일을 선택한 뒤 AI 대조를 실행하세요.'
        );
    }

    window.compareFreightCertFile = async function () {
        const form = document.getElementById('freightCertUploadForm');
        const fileInput = document.getElementById('freightCertFile');
        const submitBtn = document.getElementById('freightCertSubmitBtn');

        if (!form) {
            alert('신고필증 업로드 폼을 찾을 수 없습니다.');
            return;
        }

        if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
            alert('대조할 신고필증 파일을 선택하세요.');
            return;
        }

        const file = fileInput.files[0];
        const valid = validateFreightCertFile(file);

        if (!valid) {
            return;
        }

        const formData = new FormData();
        formData.append('tcsNo', form.querySelector('input[name="tcsNo"]').value);
        formData.append('trcNo', form.querySelector('input[name="trcNo"]').value);
        formData.append('certFile', file);

        const csrf = getCsrf();

        try {
            if (submitBtn) {
                submitBtn.disabled = true;
            }

            setText('certMatchResult', '대조 중...');
            setHtml(
                'certAiMessage',
                '<span class="material-symbols-outlined">hourglass_top</span>' +
                'PDF 텍스트 분석 및 OCR 판독 중입니다.'
            );

            const headers = {};

            if (csrf.token && csrf.header) {
                headers[csrf.header] = csrf.token;
            }

            const response = await fetch(getCtxPath() + '/owner/transport/freight/cert/compare.do', {
                method: 'POST',
                body: formData,
                headers: headers,
                credentials: 'same-origin'
            });

            if (!response.ok) {
                throw new Error('요청 실패: ' + response.status);
            }

            const data = await response.json();

            if (data.result !== 'OK') {
                setText('certMatchResult', '대조 실패');
                setHtml(
                    'certAiMessage',
                    '<span class="material-symbols-outlined">error</span>' +
                    (data.message || '신고필증 대조에 실패했습니다.')
                );
                return;
            }

            const certMatchYn = document.getElementById('certMatchYn');
            const extractedBlNo = document.getElementById('extractedBlNo');
            const matchMethodCd = document.getElementById('matchMethodCd');

            if (certMatchYn) certMatchYn.value = data.matchYn || 'N';
            if (extractedBlNo) extractedBlNo.value = data.matchedBlNo || '';
            if (matchMethodCd) matchMethodCd.value = data.matchMethodCd || '';

            if (data.matchYn === 'Y') {
                setText('certExtractedBlNo', data.matchedBlNo || '-');
                setHtml('certMatchResult', '<span class="doc-status ok">일치</span>');
                setHtml(
                    'certAiMessage',
                    '<span class="material-symbols-outlined">check_circle</span>' +
                    (data.message || 'B/L 번호가 일치합니다.') +
                    ' 대조방식: ' + (data.matchMethodCd || '-')
                );

                if (submitBtn) {
                    submitBtn.disabled = false;
                }

                updateFreightCertRowStatus('대조완료', 'ok');
            } else {
                setText('certExtractedBlNo', data.matchedBlNo || '-');
                setHtml('certMatchResult', '<span class="doc-status delete">불일치</span>');
                setHtml(
                    'certAiMessage',
                    '<span class="material-symbols-outlined">warning</span>' +
                    (data.message || 'B/L 번호가 일치하지 않습니다.')
                );

                if (submitBtn) {
                    submitBtn.disabled = true;
                }

                updateFreightCertRowStatus('대조실패', 'delete');
            }

        } catch (e) {
            console.error(e);

            setText('certMatchResult', '대조 오류');
            setHtml(
                'certAiMessage',
                '<span class="material-symbols-outlined">error</span>' +
                '신고필증 대조 중 오류가 발생했습니다.'
            );

            if (submitBtn) {
                submitBtn.disabled = true;
            }
        }
    };

    window.validateFreightCertUploadForm = function () {
        const fileInput = document.getElementById('freightCertFile');
        const certMatchYn = document.getElementById('certMatchYn');

        if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
            alert('전달할 신고필증 파일을 선택하세요.');
            return false;
        }

        const file = fileInput.files[0];

        if (!validateFreightCertFile(file)) {
            return false;
        }

        if (!certMatchYn || certMatchYn.value !== 'Y') {
            alert('AI 대조가 완료된 뒤 전달할 수 있습니다.');
            return false;
        }

        return confirm('신고필증을 운송업체에게 전달하시겠습니까?');
    };

    function validateFreightCertFile(file) {
        const allowedExt = ['pdf', 'jpg', 'jpeg', 'png'];
        const maxSize = 20 * 1024 * 1024;

        const fileName = file.name || '';
        const ext = fileName.includes('.') ? fileName.split('.').pop().toLowerCase() : '';

        if (!allowedExt.includes(ext)) {
            alert('신고필증은 PDF, JPG, PNG 파일만 업로드할 수 있습니다.');
            return false;
        }

        if (file.size > maxSize) {
            alert('파일 용량은 20MB를 초과할 수 없습니다.');
            return false;
        }

        return true;
    }

    function updateFreightCertRowStatus(text, statusClass) {
        const status = document.querySelector('#freightCertUploadTbody .doc-status');

        if (!status) {
            return;
        }

        status.className = 'doc-status ' + statusClass;
        status.textContent = text;
    }

    function escapeHtml(str) {
        return String(str || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

})();