<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fn" uri="http://java.sun.com/jsp/jstl/functions" %>

<main class="ml-72 pt-16 min-h-screen bg-surface">
  <c:set var="initialGroup" value="${transportInitialGroup}" />
  <c:set var="initialItem" value="${transportInitialItem}" />
  <c:set var="showInitialDetail" value="${not empty initialGroup and initialGroup ne 'dashboard'}" />
  <c:set var="exportCount" value="${fn:length(exportRequestList)}" />
  <c:set var="importCount" value="${fn:length(importRequestList)}" />
  <c:set var="importArrivalCount" value="${fn:length(importArrivalTrackingList)}" />
  <c:set var="importReleaseCount" value="${fn:length(importReleaseList)}" />

  <section id="dashboard-view" class="p-8 space-y-8 ${showInitialDetail ? 'hidden' : ''}">
    <section class="bg-primary-container flex items-center justify-between">
      <div>
        <h2>수출·수입운송 운영 현황</h2>
        <p>DB 조회 기준 · 수출/수입 운송의뢰 접수와 진행 현황을 확인합니다.</p>
      </div>
      <div class="flex gap-8 text-right text-xs font-bold text-slate-600">
        <div>
          <div class="mb-2">오늘 수출 의뢰</div>
          <div class="text-base text-slate-700">${exportCount}건</div>
        </div>
        <div>
          <div class="mb-2">오늘 수입 의뢰</div>
          <div class="text-base text-slate-700">${importCount}건</div>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      <button type="button" class="kpi text-left" onclick="if(typeof openDetail==='function'){openDetail('export','TACS-FW-001');}else{location.href='${pageContext.request.contextPath}/transport/export.do?page=TACS-FW-001';}">
        <span class="block text-xs font-black text-slate-700 mb-3">수출 운송 의뢰접수</span>
        <strong class="block text-5xl font-black text-slate-900 leading-none">${exportCount}</strong>
      </button>
      <button type="button" class="kpi text-left" onclick="if(typeof openDetail==='function'){openDetail('import','TACS-FW-015');}else{location.href='${pageContext.request.contextPath}/transport/import.do?page=TACS-FW-015';}">
        <span class="block text-xs font-black text-slate-700 mb-3">수입운송 의뢰접수</span>
        <strong class="block text-5xl font-black text-slate-900 leading-none">${importCount}</strong>
      </button>
      <button type="button" class="kpi text-left" onclick="if(typeof openDetail==='function'){openDetail('import','TACS-FW-020');}else{location.href='${pageContext.request.contextPath}/transport/import.do?page=TACS-FW-020';}">
        <span class="block text-xs font-black text-slate-700 mb-3">도착예정 및 입항추적</span>
        <strong class="block text-5xl font-black text-slate-900 leading-none">${importArrivalCount}</strong>
      </button>
      <button type="button" class="kpi text-left" onclick="if(typeof openDetail==='function'){openDetail('import','TACS-FW-033');}else{location.href='${pageContext.request.contextPath}/transport/import.do?page=TACS-FW-033';}">
        <span class="block text-xs font-black text-slate-700 mb-3">보세구역 반출요청</span>
        <strong class="block text-5xl font-black text-slate-900 leading-none">${importReleaseCount}</strong>
      </button>
    </section>

    <section class="section-card overflow-hidden bg-surface-container-low">
      <div class="bg-slate-700 px-6 py-4">
        <h3 class="text-base font-black text-white">수출·수입 의뢰접수 현황</h3>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-2 gap-8 p-6">
        <article class="bg-surface-container-lowest border-2">
          <h4 class="text-base font-black text-slate-900 mb-5">수출 운송 의뢰접수</h4>
          <div class="overflow-x-auto">
            <table class="w-full tbl">
              <thead>
              <tr>
                <th>의뢰번호</th>
                <th>화주</th>
                <th>요청일시</th>
                <th>요청사항</th>
              </tr>
              </thead>
              <tbody>
              <c:forEach var="req" items="${exportRequestList}" end="2">
                <tr>
                  <td>${req.trcNo}</td>
                  <td>${req.ownerNm}</td>
                  <td>${req.requestDt}</td>
                  <td><span class="status-chip">${empty req.requestCn ? req.statusNm : req.requestCn}</span></td>
                </tr>
              </c:forEach>
              <c:if test="${empty exportRequestList}">
                <tr><td colspan="4" class="text-center text-slate-500 py-6">표시할 수출 운송의뢰가 없습니다.</td></tr>
              </c:if>
              </tbody>
            </table>
          </div>
        </article>

        <article class="bg-surface-container-lowest border-2">
          <h4 class="text-base font-black text-slate-900 mb-5">수입운송 의뢰접수</h4>
          <div class="overflow-x-auto">
            <table class="w-full tbl">
              <thead>
              <tr>
                <th>의뢰번호</th>
                <th>화주</th>
                <th>요청일시</th>
                <th>요청사항</th>
              </tr>
              </thead>
              <tbody>
              <c:forEach var="req" items="${importRequestList}" end="2">
                <tr>
                  <td>${req.trcNo}</td>
                  <td>${req.ownerNm}</td>
                  <td>${req.requestDt}</td>
                  <td><span class="status-chip">${empty req.requestCn ? req.statusNm : req.requestCn}</span></td>
                </tr>
              </c:forEach>
              <c:if test="${empty importRequestList}">
                <tr><td colspan="4" class="text-center text-slate-500 py-6">표시할 수입 운송의뢰가 없습니다.</td></tr>
              </c:if>
              </tbody>
            </table>
          </div>
        </article>
      </div>
    </section>
  </section>

  <section id="detail-view" class="${showInitialDetail ? '' : 'hidden'}">
    <div class="p-8" id="detail-body">
      <c:if test="${initialGroup eq 'docs'}">
        <c:set var="docsRole" value="TRANSPORT_MANAGER" scope="request" />
        <c:choose>
          <c:when test="${initialItem eq 'TACS-DC-002'}">
            <jsp:include page="/WEB-INF/views/common/trashContent.jsp" />
          </c:when>
          <c:otherwise>
            <jsp:include page="/WEB-INF/views/common/docsContent.jsp" />
          </c:otherwise>
        </c:choose>
      </c:if>
    </div>
  </section>
</main>
