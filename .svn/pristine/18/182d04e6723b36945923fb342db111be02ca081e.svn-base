package kr.or.tacs.broker.status.controller;

import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestMapping;

/**
 * 처리현황 페이지 컨트롤러
 *  - URL : /status/search, /status/tax, /status/cert
 *  - View: pages/status.jsp
 */
@Controller
@RequestMapping("/broker/status")
public class StatusController {

    @GetMapping("/search.do")
    public String search(Model model) {
        model.addAttribute("activeMenu", "status");
        model.addAttribute("activeSub", "search");
        return "broker/pages/status";
    }

    @GetMapping("/tax.do")
    public String tax(Model model) {
        model.addAttribute("activeMenu", "status");
        model.addAttribute("activeSub", "tax");
        return "broker/pages/status";
    }

    @GetMapping("/cert.do")
    public String cert(Model model) {
        model.addAttribute("activeMenu", "status");
        model.addAttribute("activeSub", "cert");
        return "broker/pages/status";
    }
}
