<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<c:set var="ctx" value="${pageContext.request.contextPath}" />
<!DOCTYPE html>
<html lang="ko">
<head>
    <%@ include file="/WEB-INF/views/broker/common/meta.jsp" %>
    <link rel="stylesheet" href="${ctx}/resources/css/broker/common.css">
    <link rel="stylesheet" href="${ctx}/resources/css/broker/pages/dash.css">
    <title>대시보드 | TACS</title>
</head>
<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/broker/common/sidebar.jsp" %>
    <div class="main-wrap">
        <%@ include file="/WEB-INF/views/broker/common/header.jsp" %>
        <div class="content">
<%-- 대시보드 페이지 --%>
      <div class="page active" id="pg-dash">
        <div class="banner">
          <div class="banner-left">
            <h2>오늘의 업무 현황</h2>
            <div class="meta">2024-05-20 14:32:01 (KST) · 담당 화주 18개사</div>
          </div>
          <div class="banner-right">
            <div class="banner-stat">
              <div class="label">오늘 접수</div>
              <div class="val">7 <span class="unit">건</span></div>
            </div>
          </div>
        </div>

       <div class="stats-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
		  <a class="stat-card" href="${ctx}/clients" style="text-decoration:none;color:inherit">
		    <div class="s-label">화주 신규 요청</div>
		    <div class="s-row"><span class="s-num">7</span></div>
		  </a>
		  <a class="stat-card c2" href="${ctx}/clients" style="text-decoration:none;color:inherit">
		    <div class="s-label">서류 보완 대기</div>
		    <div class="s-row"><span class="s-num">4</span></div>
		  </a>
		  <a class="stat-card c4" href="${ctx}/status/search" style="text-decoration:none;color:inherit">
		    <div class="s-label">금일 처리 완료</div>
		    <div class="s-row"><span class="s-num">23</span></div>
		  </a>
		</div>

        <div class="grid-2col">
          <div class="card-section">
			  <div class="card-header">
			    <h3>화주 신규 요청</h3><button onclick="location.href='${ctx}/clients'">전체 보기 →</button>
			  </div>

			  <div class="req-item new-item">
			    <div class="req-left">
			      <div class="req-title">삼성전자(주) — 수입신고 의뢰 <span class="badge badge-new">NEW</span></div>
			      <div class="req-sub">정밀 의료기기 외 2건 · B/L: MSKU1234567 · 10분 전</div>
			    </div>
			    <div class="req-right">
			      <button class="mini mini-view" onclick="openDocDetail('samsung-imp')">상세</button>
			    </div>
			  </div>

			  <div class="req-item new-item">
			    <div class="req-left">
			      <div class="req-title">LG화학(주) — 환급신청 의뢰 <span class="badge badge-new">NEW</span></div>
			      <div class="req-sub">수입원재료 환급 · 환급예상액 ₩12,450,000 · 32분 전</div>
			    </div>
			    <div class="req-right">
			      <button class="mini mini-view">상세</button>
			    </div>
			  </div>

			  <div class="req-item">
			    <div class="req-left">
			      <div class="req-title">현대모비스(주) — 수출신고 의뢰</div>
			      <div class="req-sub">자동차 부품 조립체 · FOB $128,500 · 1시간 전</div>
			    </div>
			    <div class="req-right">
			      <button class="mini mini-view">상세</button>
			    </div>
			  </div>

			  <div class="req-item">
			    <div class="req-left">
			      <div class="req-title">SK하이닉스(주) — 서류 제출</div>
			      <div class="req-sub">원산지증명서 보완 제출 · 기한: 오늘 18:00</div>
			    </div>
			    <div class="req-right">
			      <button class="mini mini-view">상세</button>
			    </div>
			  </div>

			  <div class="req-item">
			    <div class="req-left">
			      <div class="req-title">포스코(주) — 수입신고 의뢰</div>
			      <div class="req-sub">철강 원재료 · CIF $892,000 · 3시간 전</div>
			    </div>
			    <div class="req-right">
			      <button class="mini mini-view">상세</button>
			    </div>
			  </div>
			</div>

          <div style="display:flex;flex-direction:column;gap:20px">
            <div class="side-card">
              <h3>서류 보완 현황</h3>
              <div class="client-row" onclick="showModal('supplement')">
                <div class="client-info">
                  <div class="client-avatar">SK</div>
                  <div>
                    <div class="client-name">SK하이닉스</div>
                    <div class="client-detail">검사성적서 미제출 · <b style="color:#9f403d">D-0</b></div>
                  </div>
                </div>
                <button class="mini mini-sup" onclick="event.stopPropagation();showModal('supplement')">보완요청</button>
              </div>
              <div class="client-row">
                <div class="client-info">
                  <div class="client-avatar">한</div>
                  <div>
                    <div class="client-name">한화솔루션</div>
                    <div class="client-detail">포장명세서 미비 · <b style="color:#d97706">D-2</b></div>
                  </div>
                </div>
                <button class="mini mini-sup" onclick="showModal('supplement')">보완요청</button>
              </div>
              <div class="client-row">
                <div class="client-info">
                  <div class="client-avatar">CJ</div>
                  <div>
                    <div class="client-name">CJ대한통운</div>
                    <div class="client-detail">B/L 원본 대조 · <b style="color:#1d6b4f">D-5</b></div>
                  </div>
                </div>
                <button class="mini mini-sup" onclick="showModal('supplement')">보완요청</button>
              </div>
              <div class="client-row">
                <div class="client-info">
                  <div class="client-avatar">두</div>
                  <div>
                    <div class="client-name">두산에너빌리티</div>
                    <div class="client-detail">가격신고서 · <b style="color:#1d6b4f">D-7</b></div>
                  </div>
                </div>
                <button class="mini mini-sup" onclick="showModal('supplement')">보완요청</button>
              </div>
            </div>

            <div class="side-card" style="background:#fff;border:2px solid #d0e5fa">
              <h3>담당 화주 TOP 5</h3>
              <div class="client-row" onclick="alert('삼성전자 상세:\n\n진행중 3건 / 금월 완료 12건\n통관고유부호: ABCD1234')">
                <div class="client-info">
                  <div class="client-avatar">삼</div>
                  <div>
                    <div class="client-name">삼성전자(주)</div>
                    <div class="client-detail">진행중 3건</div>
                  </div>
                </div>
                <div class="client-count">금월 12건</div>
              </div>
              <div class="client-row">
                <div class="client-info">
                  <div class="client-avatar">LG</div>
                  <div>
                    <div class="client-name">LG화학(주)</div>
                    <div class="client-detail">진행중 2건</div>
                  </div>
                </div>
                <div class="client-count">금월 8건</div>
              </div>
              <div class="client-row">
                <div class="client-info">
                  <div class="client-avatar">현</div>
                  <div>
                    <div class="client-name">현대모비스(주)</div>
                    <div class="client-detail">진행중 1건</div>
                  </div>
                </div>
                <div class="client-count">금월 6건</div>
              </div>
              <div class="client-row">
                <div class="client-info">
                  <div class="client-avatar">SK</div>
                  <div>
                    <div class="client-name">SK하이닉스(주)</div>
                    <div class="client-detail">진행중 2건</div>
                  </div>
                </div>
                <div class="client-count">금월 5건</div>
              </div>
              <div class="client-row">
                <div class="client-info">
                  <div class="client-avatar">포</div>
                  <div>
                    <div class="client-name">포스코(주)</div>
                    <div class="client-detail">진행중 1건</div>
                  </div>
                </div>
                <div class="client-count">금월 4건</div>
              </div>
            </div>
          </div>
        </div>

        <div class="bottom-grid">
          <div class="data-block">
            <h3>금월 실적 요약</h3>
            <div class="data-grid">
              <div class="d-item">
                <div class="d-label">수입신고 처리</div>
                <div class="d-val">148<span class="d-unit">건</span></div>
              </div>
              <div class="d-item">
                <div class="d-label">수출신고 처리</div>
                <div class="d-val">89<span class="d-unit">건</span></div>
              </div>
              <div class="d-item">
                <div class="d-label">환급 처리액</div>
                <div class="d-val primary">2.4B<span class="d-unit">원</span></div>
              </div>
              <div class="d-item">
                <div class="d-label">반려/보완 건수</div>
                <div class="d-val error">7<span class="d-unit">건</span></div>
              </div>
            </div>
          </div>
          <div class="deadline-block">
            <h3>다가오는 기한</h3>
            <div class="dl-item">
              <div class="dl-left">SK하이닉스 — 서류보완 기한<span>IMP-20240520-001</span></div>
              <div class="dl-right dday">D-0 (오늘)</div>
            </div>
            <div class="dl-item">
              <div class="dl-left">한화솔루션 — 보완서류 제출<span>IMP-20240518-012</span></div>
              <div class="dl-right dday">D-2</div>
            </div>
            <div class="dl-item">
              <div class="dl-left">삼성전자 — 수입신고 기한<span>의뢰 접수 대기</span></div>
              <div class="dl-right safe">D-5</div>
            </div>
            <div class="dl-item">
              <div class="dl-left">LG화학 — 환급신청 기한<span>의뢰 접수 대기</span></div>
              <div class="dl-right safe">D-14</div>
            </div>
          </div>
        </div>
      </div>
        </div>
        <%@ include file="/WEB-INF/views/broker/common/footer.jsp" %>
    </div>
</div>
<%@ include file="/WEB-INF/views/broker/common/modals.jsp" %>
<script>window.contextPath = '${ctx}';</script>
<script src="${ctx}/resources/js/broker/common.js"></script>
<script src="${ctx}/resources/js/broker/pages/dash.js"></script>
<script src="${ctx}/resources/js/broker/pages/clients.js"></script>
</body>
</html>
