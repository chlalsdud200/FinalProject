// loadedCargoList.js - 적재화물목록 / 혼재화물 적하목록 조회 전용
(function () {

  function text(value) {
    return value && String(value).trim() ? String(value).trim() : '-';
  }

  function setText(id, value) {
    var el = document.getElementById(id);
    if (el) el.textContent = text(value);
  }

  function getActiveTabKey() {
    var active = document.querySelector('[data-tab-group="cargo-list-type"].active');
    return active ? active.getAttribute('data-tab-key') || 'loading-list' : 'loading-list';
  }

  function getMemoKey(row) {
    var type = row.dataset.type || getActiveTabKey();
    var listNo = row.dataset.listNo || row.dataset.blNo || row.dataset.mblNo || row.dataset.reqNo || row.rowIndex;
    return 'loadedCargoMemo:' + type + ':' + listNo;
  }

  function setCargoListTab(key, btn) {
    document.querySelectorAll('[data-tab-group="cargo-list-type"]').forEach(function (b) {
      b.classList.remove('active');
    });
    btn.classList.add('active');
    btn.setAttribute('data-tab-key', key);

    document.querySelectorAll('[data-panel-group="cargo-list-type"]').forEach(function (p) {
      p.style.display = p.dataset.panelKey === key ? 'block' : 'none';
    });

    hideDetail();
  }

  function hideDetail() {
    document.querySelectorAll('.detail-panel, [id$="-detail-panel"]').forEach(function (p) {
      p.style.display = 'none';
    });
    document.querySelectorAll('.cargo-click-row').forEach(function (r) {
      r.classList.remove('row-selected');
    });
  }

  function openCargoDetail(row) {
    var panel = document.getElementById('cargo-list-detail-panel');
    if (!panel || !row) return;

    document.querySelectorAll('.cargo-click-row').forEach(function (r) {
      r.classList.remove('row-selected');
    });
    row.classList.add('row-selected');

    var type = row.dataset.type;
    var isHouse = type === 'house';

    setText('detailType', isHouse ? '혼재화물 적하목록' : '적재화물목록');
    setText('detailMainNoLabel', isHouse ? 'MBL / HBL' : 'B/L번호');
    setText('detailMainNo', isHouse ? ((row.dataset.mblNo || '-') + ' / ' + (row.dataset.hblNo || '-')) : row.dataset.blNo);
    setText('detailReqNo', row.dataset.reqNo);
    setText('detailListNo', row.dataset.listNo);
    setText('detailGoodsGroupNo', row.dataset.goodsGroupNo);
    setText('detailOwnerName', row.dataset.ownerName);
    setText('detailItemName', row.dataset.itemName);
    setText('detailVesselName', isHouse ? '-' : row.dataset.vesselName);
    setText('detailSubmitStatus', isHouse ? row.dataset.declareStatus : row.dataset.submitStatus);
    setText('detailSubmitDate', row.dataset.submitDate);
    setText('detailRemark', row.dataset.remark);

    var memo = document.getElementById('cargoMemo');
    if (memo) {
      memo.value = localStorage.getItem(getMemoKey(row)) || '';
      memo.dataset.memoKey = getMemoKey(row);
    }

    panel.style.display = 'block';
    panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function bindRows() {
    document.querySelectorAll('.cargo-click-row').forEach(function (row) {
      row.addEventListener('click', function (e) {
        if (e.target.closest('a, input, select, textarea, label')) return;

        var detailButton = e.target.closest('.btn-cargo-detail');
        if (detailButton) {
          e.preventDefault();
          openCargoDetail(row);
          return;
        }

        if (e.target.closest('button')) return;
        openCargoDetail(row);
      });
    });
  }

  function bindMemoSave() {
    var btn = document.getElementById('btnSaveCargoMemo');
    var memo = document.getElementById('cargoMemo');
    var saved = document.getElementById('cargoMemoSavedText');

    if (!btn || !memo) return;

    btn.addEventListener('click', function () {
      var key = memo.dataset.memoKey;
      if (!key) return;
      localStorage.setItem(key, memo.value || '');
      if (saved) {
        saved.textContent = '메모가 저장되었습니다.';
        setTimeout(function () { saved.textContent = ''; }, 1800);
      }
    });
  }

  function bindSearchButtons() {
    var resetBtn = document.getElementById('btnResetLoadedCargoSearch');
    if (resetBtn) {
      resetBtn.addEventListener('click', function () {
        window.location.href = (window.location.pathname || '/officer/loadedCargoList.do');
      });
    }

    var recentBtn = document.getElementById('btnRecentWeek');
    if (recentBtn) {
      recentBtn.addEventListener('click', function () {
        var end = new Date();
        var start = new Date();
        start.setDate(end.getDate() - 7);

        function format(d) {
          var y = d.getFullYear();
          var m = String(d.getMonth() + 1).padStart(2, '0');
          var day = String(d.getDate()).padStart(2, '0');
          return y + '-' + m + '-' + day;
        }

        var startEl = document.getElementById('startDate');
        var endEl = document.getElementById('endDate');
        if (startEl) startEl.value = format(start);
        if (endEl) endEl.value = format(end);
      });
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    bindRows();
    bindMemoSave();
    bindSearchButtons();
  });

  window.setCargoListTab = setCargoListTab;
  window.openCargoDetailFromRow = openCargoDetail;

})();
