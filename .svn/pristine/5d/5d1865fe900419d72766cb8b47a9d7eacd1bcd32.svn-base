package kr.or.tacs.officer.fulfillmentandexport.controller;

import java.util.Collections;
import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;

import kr.or.tacs.dto.officer.LoadedCargoListDTO;
import kr.or.tacs.dto.officer.WarehouseCargoTrackingDTO;
import kr.or.tacs.officer.fulfillmentandexport.service.ILoadedCargoListService;
import kr.or.tacs.officer.fulfillmentandexport.service.IWarehouseCargoTrackingService;

/*
 * 행정공무원 - 이행 반출 및 화물 조회
 * - 반출 및 이행 관리, 적재화물목록/혼재화물 적하 목록 조회, 창고(보세구역) 화물 조회 처리를 위한 컨트롤러
 */
@Controller
@RequestMapping("/officer")
public class OfficerFulfillmentReleaseAndCargoTrackingController {

    @Autowired
    IWarehouseCargoTrackingService service;

    @Autowired
    ILoadedCargoListService loadedCargoListService;

    // 반출 및 이행 관리 페이지 요청
    @GetMapping("/exportAndFulfillment.do")
    public String exportAndFulfillment(Model model) {
        model.addAttribute("menuKey", "exportAndFulfillment");
        return "officer/exportAndFulfillment";
    }

    // 적재화물목록, 혼재화물 적하목록 조회 페이지 요청
    @GetMapping("/loadedCargoList.do")
    public String loadedCargoList(
            @RequestParam(required = false) String reqNo,
            @RequestParam(required = false, defaultValue = "ALL") String submitStatusCd,
            @RequestParam(required = false, defaultValue = "ALL") String declareType,
            @RequestParam(required = false) String startDate,
            @RequestParam(required = false) String endDate,
            @RequestParam(required = false) String keyword,
            Model model) {

        List<LoadedCargoListDTO> loadedCargoList = Collections.emptyList();
        List<LoadedCargoListDTO> mixedCargoList = Collections.emptyList();

        if (!"IMPORT".equals(declareType)) {
            loadedCargoList = loadedCargoListService.selectLoadedCargoList(
                    reqNo, submitStatusCd, startDate, endDate, keyword);
        }

        if (!"EXPORT".equals(declareType)) {
            mixedCargoList = loadedCargoListService.selectMixedCargoList(
                    reqNo, submitStatusCd, startDate, endDate, keyword);
        }

        model.addAttribute("loadedCargoList", loadedCargoList);
        model.addAttribute("mixedCargoList", mixedCargoList);
        model.addAttribute("loadedCargoCount", loadedCargoList == null ? 0 : loadedCargoList.size());
        model.addAttribute("mixedCargoCount", mixedCargoList == null ? 0 : mixedCargoList.size());

        model.addAttribute("reqNo", reqNo);
        model.addAttribute("submitStatusCd", submitStatusCd);
        model.addAttribute("declareType", declareType);
        model.addAttribute("startDate", startDate);
        model.addAttribute("endDate", endDate);
        model.addAttribute("keyword", keyword);
        model.addAttribute("menuKey", "loadedCargoList");

        return "officer/loadedCargoList";
    }

    // 창고(보세구역) 화물 조회 페이지 요청
    @GetMapping("/warehouseCargoTracking.do")
    public String warehouseCargoTracking(
            @RequestParam(required = false) String startDate,
            @RequestParam(required = false) String endDate,
            @RequestParam(required = false) String reqNo,
            @RequestParam(required = false, defaultValue = "ALL") String declareType,
            @RequestParam(required = false) String warehouseName,
            @RequestParam(required = false, defaultValue = "ALL") String cargoStatusCd,
            Model model) {

        List<WarehouseCargoTrackingDTO> cargoList =
                service.selectWarehouseCargoList(
                        startDate,
                        endDate,
                        reqNo,
                        declareType,
                        warehouseName,
                        cargoStatusCd
                );

        model.addAttribute("cargoList", cargoList);
        model.addAttribute("cargoCount", cargoList == null ? 0 : cargoList.size());

        model.addAttribute("startDate", startDate);
        model.addAttribute("endDate", endDate);
        model.addAttribute("reqNo", reqNo);
        model.addAttribute("declareType", declareType);
        model.addAttribute("warehouseName", warehouseName);
        model.addAttribute("cargoStatusCd", cargoStatusCd);

        return "officer/warehouseCargoTracking";
    }

}
