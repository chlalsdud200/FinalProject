<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ include file="/WEB-INF/views/officer/common/taglibs.jsp" %>
<%@ taglib uri="http://www.springframework.org/security/tags" prefix="sec" %>

<c:set var="ctx" value="${pageContext.request.contextPath}" />
<c:set var="activeMenu" value="cargo" />
<c:set var="activeSub" value="warehouseCargoTracking" />


<!DOCTYPE html>
<html lang="ko">
    <head>
        <%@ include file="/WEB-INF/views/officer/header/head.jsp" %>
        <title>TACS · 창고(보세구역) 화물 조회</title>
        <link rel="stylesheet" href="${ctx}/resources/css/officer/pages/warehouseCargoTracking.css">
    </head>

    <body>
        <%@ include file="/WEB-INF/views/officer/header/sidebar.jsp" %>
        <%@ include file="/WEB-INF/views/officer/header/header.jsp" %>

        <main class="officer-main">
            <div class="page-content warehouseCargoTracking-page">
                <div class="page-content">
                    <div class="section-head">
                        <div class="breadcrumb-bar">
                            <span class="breadcrumb-text">이행·반출 및 화물 조회</span>
                            <span class="breadcrumb-sep">›</span>
                            <span class="breadcrumb-tag">TACS-AD-019</span>
                        </div>
                        <h2 class="page-heading">창고(보세구역) 화물 조회</h2>
                    </div>
                    <div class="inline-screen-host">
                        <div class="inline-screen-header">
                            <h3 class="screen-title">창고(보세구역) 화물 조회</h3>
                            <p class="screen-desc">TACS-AD-019 · 창고/보세구역별 보관 화물과 검사대기·반출완료 상태를 조회합니다.</p>
                        </div>
                        <div class="inline-screen-body">

                            &lt;%-- 검색 조건 --%&gt;
                            <div class="receipt-search-panel white-bg">
                                <p class="section-title receipt-search-title">검색 조건</p>
                                <div class="receipt-search-row">
                                    <div class="receipt-search-label">신고번호</div>
                                    <div class="receipt-search-field receipt-search-field-wide">
                                        <input class="receipt-search-input" placeholder="신고번호 입력" type="text"/>
                                    </div>
                                </div>
                                <div class="receipt-search-row">
                                    <div class="receipt-search-label">처리 상태</div>
                                    <div class="receipt-search-field receipt-search-field-md">
                                        <select class="receipt-search-select">
                                            <option>전체</option>
                                            <option>접수대기</option>
                                            <option>심사중</option>
                                            <option>처리대기</option>
                                            <option>완료</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="receipt-search-row">
                                    <div class="receipt-search-label">구분</div>
                                    <div class="receipt-search-radio-group">
                                        <label class="receipt-check-item"><input checked="" type="checkbox"/> 전체</label>
                                        <label class="receipt-check-item"><input type="checkbox"/> 수입</label>
                                        <label class="receipt-check-item"><input type="checkbox"/> 수출</label>
                                    </div>
                                </div>
                                <div class="receipt-search-row">
                                    <div class="receipt-search-label">신고 일자</div>
                                    <div class="receipt-search-date-wrap">
                                        <input class="receipt-search-date" type="date" value="2026-04-01"/>
                                        <span class="receipt-search-date-sep">~</span>
                                        <input class="receipt-search-date" type="date" value="2026-04-14"/>
                                        <button class="receipt-inline-btn" type="button">최근 1주일</button>
                                    </div>
                                </div>
                                <div class="receipt-search-row receipt-search-row-last">
                                    <div class="receipt-search-label">통합 검색</div>
                                    <div class="receipt-search-bottom">
                                        <input class="receipt-search-input" placeholder="신고번호 또는 업체명 입력" type="text"/>
                                        <button class="btn-primary receipt-action-btn" type="button">
                                            <span class="material-symbols-outlined">search</span>조회
                                            </button>
                                            <button class="btn-secondary receipt-action-btn" type="button">초기화</button>
                                        </div>
                                    </div>
                                </div>

                                &lt;%-- 결과 목록 --%&gt;
                                <div class="result-bar">
                                    <div class="result-title">창고별 화물 목록 <span class="result-count">4건</span></div>
                                </div>
                                <div class="table-wrap">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>No.</th>
                                                <th>창고명</th>
                                                <th>보세구역코드</th>
                                                <th>품명</th>
                                                <th>수량/중량</th>
                                                <th>상태</th>
                                                <th>반입일</th>
                                                <th>상세</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            &lt;%-- 행 1 --%&gt;
                                            <tr>
                                                <td>1</td>
                                                <td class="td-bold">부산 냉동창고</td>
                                                <td>WH-BUS-001</td>
                                                <td>냉동식품</td>
                                                <td>120 CT / 2,400KG</td>
                                                <td>검사대기</td>
                                                <td>2026-04-12</td>
                                                <td>
                                                    <button class="btn-secondary btn-sm" onclick="toggleSimpleDetail(this,'warehouse-detail-row')" type="button">상세</button>
                                                </td>
                                            </tr>
                                            <tr class="warehouse-detail-row" style="display:none;">
                                                <td class="p-zero" colspan="8">
                                                    <div class="detail-content">
                                                        <div class="grid-3 grid-sm">
                                                            <div class="info-card">
                                                                <p class="section-title">화물정보</p>
                                                                <table class="data-table">
                                                                    <tbody>
                                                                        <tr><td class="td-bold">화물관리번호</td><td>CARGO-2026-0412-014</td></tr>
                                                                        <tr><td class="td-bold">품명</td><td>냉동식품</td></tr>
                                                                        <tr><td class="td-bold">수량/중량</td><td>120 CT / 2,400KG</td></tr>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                            <div class="info-card">
                                                                <p class="section-title">위치정보</p>
                                                                <table class="data-table">
                                                                    <tbody>
                                                                        <tr><td class="td-bold">창고</td><td>부산 냉동창고</td></tr>
                                                                        <tr><td class="td-bold">보관위치</td><td>B-03-12</td></tr>
                                                                        <tr><td class="td-bold">보관상태</td><td>검사대기</td></tr>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                            <div class="info-card">
                                                                <p class="section-title">이력</p>
                                                                <table class="data-table">
                                                                    <tbody>
                                                                        <tr><td class="td-bold">반입일</td><td>2026-04-12</td></tr>
                                                                        <tr><td class="td-bold">검사여부</td><td>대기</td></tr>
                                                                        <tr><td class="td-bold">반출일</td><td>-</td></tr>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                        <div class="btn-row">
                                                            <button class="btn-secondary" type="button">검사관리로 이동</button>
                                                            <button class="btn-primary" type="button">화물 위치 확인완료</button>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>

                                            &lt;%-- 행 2 --%&gt;
                                            <tr>
                                                <td>2</td>
                                                <td class="td-bold">인천항 CY</td>
                                                <td>WH-INC-002</td>
                                                <td>전자부품</td>
                                                <td>22 PLT / 1,180KG</td>
                                                <td>반출대기</td>
                                                <td>2026-04-17</td>
                                                <td>
                                                    <button class="btn-secondary btn-sm" onclick="toggleSimpleDetail(this,'warehouse-detail-row')" type="button">상세</button>
                                                </td>
                                            </tr>
                                            <tr class="warehouse-detail-row" style="display:none;">
                                                <td class="p-zero" colspan="8">
                                                    <div class="detail-content">
                                                        <p class="section-title">화물 상세</p>
                                                        <table class="data-table">
                                                            <tbody>
                                                                <tr><td class="td-bold">화물관리번호</td><td>CARGO-2026-0417-021</td></tr>
                                                                <tr><td class="td-bold">보관위치</td><td>CY-A-11</td></tr>
                                                                <tr><td class="td-bold">상태</td><td>반출대기</td></tr>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>

            <%@ include file="/WEB-INF/views/officer/footer/footer.jsp" %>
            <%@ include file="/WEB-INF/views/officer/footer/scripts.jsp" %>

            <script defer src="${ctx}/resources/js/officer/pages/warehouseCargoTracking.js"></script>
        </body>
    </html>
