<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>보세창고 통합현황 - TACS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet"/>
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/base.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/sidebar.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/topbar.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/dashboard.css">
</head>
<body>
<div class="app" id="app">
    <!-- Sidebar -->
    <jsp:include page="/WEB-INF/views/warehouse/common/sidebar.jsp" />
    
    <!-- Main Wrapper -->
    <div class="main-wrap">
        <!-- Header -->
        <jsp:include page="/WEB-INF/views/warehouse/common/header.jsp" />
        
        <!-- Content -->
        <div class="content">
            <div class="page-title-row">
                <h2>보세창고 통합현황</h2>
                <div class="btn-row" style="align-items: center;">
                    <c:set var="today" value="<%= new java.util.Date() %>"/>
                    <span class="date-label">
                        <fmt:formatDate value="${today}" pattern="yyyy-MM-dd (E)"/>
                    </span>
                </div>
            </div>

            <!-- ── KPI 요약 ── -->
            <div class="metric-strip">

                <!-- 입고 승인 대기 -->
				<div class="metric-box" onclick="location.href='${pageContext.request.contextPath}/warehouse/inbound.do'">
				    <span class="material-symbols-outlined">archive</span>
				    <div class="k">입고 승인 대기</div>
				    <div class="v">${dashboard.wirWaitCnt}</div>
				    <div class="s">입고 승인 또는 보완요청 필요</div>
				</div>

                <!-- 보완 제출 확인 -->
                <div class="metric-box" onclick="location.href='${pageContext.request.contextPath}/warehouse/inbound.do'" style="border-left-color: #9f403d;">
                    <span class="material-symbols-outlined">assignment_late</span>
                    <div class="k">보완 제출 확인</div>
                    <div class="v">${dashboard.wirReqSentCnt}</div>
                    <div class="s">운송업체 보완제출 확인 필요</div>
                </div>

               <!-- 반출 요청 대기 -->
				<div class="metric-box" onclick="location.href='${pageContext.request.contextPath}/warehouse/outbound.do'" style="border-left-color: #3b82f6;">
				    <span class="material-symbols-outlined">unarchive</span>
				    <div class="k">반출 요청 대기</div>
				    <div class="v">${dashboard.crrWaitCnt}</div>
				    <div class="s">반출 승인 처리 필요</div>
				</div>

                <!-- 현재 보관 재고 -->
				<div class="metric-box" onclick="location.href='${pageContext.request.contextPath}/warehouse/inventory.do'" style="border-left-color: #7c3aed;">
				    <span class="material-symbols-outlined">warehouse</span>
				    <div class="k">현재 보관 재고</div>
				    <div class="v">${dashboard.wirStoredCnt}</div>
				    <div class="s">창고 내 현재 보관 물품</div>
				</div>
            </div>

            <!-- ── 대시보드 메인 그리드 ── -->
            <div style="display:grid; grid-template-columns:minmax(0, 1.55fr) minmax(360px, 0.95fr); gap:20px; align-items:start;">

                <!-- 왼쪽: 오늘 처리 업무 -->
				<div class="flex-col" style="gap:20px">
				    <div class="card-section" style="margin-bottom:0">
				        <div class="card-header">
				            <h3>오늘 처리 업무</h3>
				            <button onclick="location.href='${pageContext.request.contextPath}/warehouse/inbound.do'">전체</button>
				        </div>
				
				        <table class="data-table">
				            <thead>
				                <tr>
				                    <th>구분</th>
				                    <th>요청번호</th>
				                    <th>화주</th>
				                    <th>품목</th>
				                    <th>상태</th>
				                    <th>기준일시</th>
				                </tr>
				            </thead>
				            <tbody>
				                <c:choose>
				                    <c:when test="${empty dashboard.recentFlowList}">
				                        <tr>
				                            <td colspan="6" style="text-align:center; padding:40px 0; color:#94a3b8;">
				                                오늘 표시할 입출고 업무가 없습니다.
				                            </td>
				                        </tr>
				                    </c:when>
				
				                    <c:otherwise>
				                        <c:forEach var="flow" items="${dashboard.recentFlowList}">
				                            <tr>
				                                <!-- 구분 -->
				                                <td>
				                                    <c:choose>
				                                        <c:when test="${not empty flow.wirNo}">
				                                            <span class="badge badge-new">입고</span>
				                                        </c:when>
				                                        <c:otherwise>
				                                            <span class="badge badge-ok">반출</span>
				                                        </c:otherwise>
				                                    </c:choose>
				                                </td>
				
				                                <!-- 요청번호 -->
				                                <td style="font-weight:700">
				                                    <c:choose>
				                                        <c:when test="${not empty flow.wirNo}">
				                                            ${flow.wirNo}
				                                        </c:when>
				                                        <c:otherwise>
				                                            ${flow.crrNo}
				                                        </c:otherwise>
				                                    </c:choose>
				                                </td>
				
				                                <!-- 화주 -->
				                                <td>${flow.wirOwrNm}</td>
				
				                                <!-- 품목 -->
				                                <td>
				                                    <c:choose>
				                                        <c:when test="${not empty flow.goodsSummary}">
				                                            ${flow.goodsSummary}
				                                        </c:when>
				                                        <c:otherwise>
				                                            -
				                                        </c:otherwise>
				                                    </c:choose>
				                                </td>
				
				                                <!-- 상태 -->
				                                <td>
				                                    <c:choose>
				                                        <c:when test="${not empty flow.wirNo}">
				                                            <c:choose>
				                                                <c:when test="${flow.wirStatusCd eq 'WAIT'}">
				                                                    <span class="doc-status wait">${flow.wirStatusNm}</span>
				                                                </c:when>
				                                                <c:when test="${flow.wirStatusCd eq 'REQ_SENT'}">
				                                                    <span class="doc-status req">${flow.wirStatusNm}</span>
				                                                </c:when>
				                                                <c:when test="${flow.wirStatusCd eq 'IN_DONE'}">
				                                                    <span class="doc-status ok">${flow.wirStatusNm}</span>
				                                                </c:when>
				                                                <c:otherwise>
				                                                    <span class="doc-status none">${flow.wirStatusNm}</span>
				                                                </c:otherwise>
				                                            </c:choose>
				                                        </c:when>
				
				                                        <c:otherwise>
				                                            <c:choose>
				                                                <c:when test="${flow.crrStatusCd eq 'REL_WAIT'}">
				                                                    <span class="doc-status wait">${flow.crrStatusNm}</span>
				                                                </c:when>
				                                                <c:when test="${flow.crrStatusCd eq 'REQ_SENT'}">
				                                                    <span class="doc-status req">${flow.crrStatusNm}</span>
				                                                </c:when>
				                                                <c:when test="${flow.crrStatusCd eq 'REL_DONE'}">
				                                                    <span class="doc-status ok">${flow.crrStatusNm}</span>
				                                                </c:when>
				                                                <c:otherwise>
				                                                    <span class="doc-status none">${flow.crrStatusNm}</span>
				                                                </c:otherwise>
				                                            </c:choose>
				                                        </c:otherwise>
				                                    </c:choose>
				                                </td>
				
				                                <!-- 기준일시 -->
				                                <td style="color:#94a3b8;font-size:11px">
				                                    <c:choose>
				                                        <c:when test="${not empty flow.wirNo}">
				                                            ${flow.wirDt}
				                                        </c:when>
				                                        <c:otherwise>
				                                            ${flow.crrDt}
				                                        </c:otherwise>
				                                    </c:choose>
				                                </td>
				                            </tr>
				                        </c:forEach>
				                    </c:otherwise>
				                </c:choose>
				            </tbody>
				        </table>
				    </div>
				</div>

                <!-- 오른쪽: 업무 알림 + 창고별 적재 현황 -->
                <div class="flex-col" style="gap:20px">

                    <!-- 오른쪽 상단: 업무 알림 -->
                    <div class="card-section" style="margin-bottom:0">
                        <div class="card-header">
                            <h3>업무 알림</h3>
                            <button type="button">전체</button>
                        </div>

                        <!-- 실시간 업무 알림 기능 연동 예정 영역 -->
                        <div style="padding: 32px 20px; text-align:center; color:#94a3b8; font-size:12px;">
                            수신된 업무 알림이 없습니다.
                        </div>
                    </div>

                    <!-- 오른쪽 하단: 창고별 적재 현황 그래프 -->
                    <div class="card-section" style="margin-bottom:0">
                        <div class="card-header">
                            <h3>창고별 적재 현황</h3>
                            <button onclick="location.href='${pageContext.request.contextPath}/warehouse/inventory.do'">전체</button>
                        </div>

                        <div style="padding: 20px;">
                            <c:choose>
                                <c:when test="${empty dashboard.zoneStatusList}">
                                    <div style="text-align:center; padding:40px 0; color:#94a3b8;">
                                        창고 구역별 적재 현황이 없습니다.
                                    </div>
                                </c:when>

                                <c:otherwise>
                                    <c:forEach var="zone" items="${dashboard.zoneStatusList}" varStatus="stat">
                                        <div style="margin-bottom: 20px;">
                                            <div class="flex-sb" style="margin-bottom: 8px;">
                                                <span style="font-size: 12px; font-weight: 700;">
											        ${zone.wzNm}
											    </span>
                                                <span style="font-size: 11px; color: #565e74; font-weight: 800;">
                                                    ${zone.wzUseRt}%
                                                </span>
                                            </div>

                                            <div style="height: 8px; background: #f1f5f9; border-radius: 4px; overflow: hidden;">
                                                <div style="width: ${zone.wzUseRt}%; height: 100%; background: #565e74;"></div>
                                            </div>

                                            <div class="flex-sb" style="margin-top: 6px;">
                                                <span style="font-size: 11px; color:#94a3b8;">
                                                    ${zone.wzNo}
                                                </span>
                                                <span style="font-size: 11px; color:#94a3b8;">
                                                    <fmt:formatNumber value="${zone.wzUseCapa}" pattern="#,##0" />
												     /
												    <fmt:formatNumber value="${zone.wzTtlCapa}" pattern="#,##0" />칸
                                                </span>
                                            </div>
                                        </div>
                                    </c:forEach>
                                </c:otherwise>
                            </c:choose>
                        </div>
                    </div>

                </div>
            </div>
        </div>
        <!-- Footer -->
        <jsp:include page="/WEB-INF/views/warehouse/common/footer.jsp" />
    </div>
</div>

<script src="${pageContext.request.contextPath}/resources/js/warehouse/common.js"></script>
<script src="${pageContext.request.contextPath}/resources/js/warehouse/navigation.js"></script>
<script src="${pageContext.request.contextPath}/resources/js/warehouse/dashboard.js"></script>
</body>
</html>