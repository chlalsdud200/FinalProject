    @Override
    @Transactional
    public String modifyImpUnloadingInDelivered(String trcNo,
                                                 String wirNo,
                                                 String wmId,
                                                 String wzNo,
                                                 String inPlanDt,
                                                 String cargoMgmtNo,
                                                 String invoiceNo,
                                                 String incoTermsCd,
                                                 String remark,
                                                 List<TransportRequestVO> goodsList) {
        int updated = importTransportMapper.updateImpUnloadingInDelivered(
                wirNo,
                trcNo,
                wmId,
                wzNo,
                inPlanDt,
                cargoMgmtNo,
                invoiceNo,
                incoTermsCd,
                remark
        );

        // 최초 발송 전에는 화면/파라미터에 WIR_NO가 비어 있을 수 있다.
        // DB INSERT/UPDATE 이후 실제 생성된 입고신청번호를 다시 찾아서 품목 저장과 화면 갱신에 사용한다.
        String savedWirNo = importTransportMapper.selectImpUnloadingInWirNoByTrcNo(trcNo);
        if (savedWirNo == null || savedWirNo.isBlank()) {
            savedWirNo = wirNo;
        }
        saveImpUnloadingInGoods(savedWirNo, goodsList);

        // 최초 입고요청 발송은 WH_IN_RPT만 WAIT/WAIT으로 변경한다.
        // PL/SQL 블록은 JDBC 드라이버에 따라 update count가 -1로 올 수 있으므로 0만 실패로 본다.
        // 보완제출완료(REQ_SENT)는 창고가 보완요청(REQ_FIX/REQ)을 보낸 뒤
        // 운송담당자가 보완제출 버튼을 눌렀을 때 modifyImpUnloadingInSupplement()에서만 처리한다.
        return updated == 0 ? null : savedWirNo;
    }

