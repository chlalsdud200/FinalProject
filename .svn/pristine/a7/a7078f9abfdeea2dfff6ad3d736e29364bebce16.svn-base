/* Dashboard specific styles */
.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
  margin-bottom: 24px;
}

.dashboard-card {
  background: #fff;
  border: 1px solid #e2e8f0;
  padding: 20px;
  border-radius: 8px;
}

.dashboard-card h3 {
  font-size: 14px;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12px;
}

.dashboard-card p {
  font-size: 13px;
  color: #64748b;
  line-height: 1.6;
}
