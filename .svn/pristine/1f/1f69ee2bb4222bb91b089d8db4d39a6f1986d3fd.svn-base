document.addEventListener('DOMContentLoaded', function () {
  bindRowClick();
  bindResetButton();
});

function bindRowClick() {
  document.querySelectorAll('.clickable-row').forEach(function (row) {
    row.addEventListener('click', function () {
      var url = row.dataset.url;
      if (url) {
        location.href = url;
      }
    });
  });

  document.querySelectorAll('.clickable-row a, .clickable-row button').forEach(function (el) {
    el.addEventListener('click', function (e) {
      e.stopPropagation();
    });
  });
}

function bindResetButton() {
  var btnReset = document.getElementById('btnReset');
  if (!btnReset) return;
  btnReset.addEventListener('click', function () {
    location.href = (window.contextPath || '') + '/officer/basicScreenList.do';
  });
}

/* =========================================================
   현재 검색 조건을 form에서 읽어 URLSearchParams로 조립한다.
   페이징 버튼과 건수 변경이 모두 form 바깥에 있기 때문에
   form.submit() 대신 URL을 직접 조립해 이동해야 검색조건이 유지된다.
   ========================================================= */

/**
 * form의 현재 입력값을 읽어 URLSearchParams로 반환한다.
 * hidden page / size 는 제외하고 순수 검색 조건만 수집한다.
 */
function collectSearchParams() {
  var form = document.getElementById('basicSearchForm');
  if (!form) return new URLSearchParams();

  var params = new URLSearchParams();
  var excludeNames = ['page', 'size'];

  // 텍스트 / select 입력값 수집
  form.querySelectorAll('input[name], select[name]').forEach(function (el) {
    if (excludeNames.indexOf(el.name) !== -1) return;

    // radio / checkbox 는 checked 된 것만
    if (el.type === 'radio' || el.type === 'checkbox') {
      if (el.checked && el.value !== '') {
        params.set(el.name, el.value);
      }
      return;
    }

    if (el.value !== '') {
      params.set(el.name, el.value);
    }
  });

  return params;
}

/**
 * 특정 페이지로 이동.
 * 현재 검색 form의 모든 조건을 그대로 유지하고 page 값만 교체하여 이동한다.
 */
function goPage(page) {
  var params = collectSearchParams();
  params.set('page', page);

  // 현재 size 유지 (pageSizeSelect 가 form 바깥에 있으므로 별도로 읽음)
  var sizeSelect = document.getElementById('pageSizeSelect');
  params.set('size', sizeSelect ? sizeSelect.value : 10);

  var ctx = window.contextPath || '';
  location.href = ctx + '/officer/basicScreenList.do?' + params.toString();
}

/**
 * 페이지당 건수 변경.
 * size를 바꾸면 1페이지부터 다시 조회한다.
 */
function changePageSize(size) {
  var params = collectSearchParams();
  params.set('page', 1);
  params.set('size', size);

  var ctx = window.contextPath || '';
  location.href = ctx + '/officer/basicScreenList.do?' + params.toString();
}