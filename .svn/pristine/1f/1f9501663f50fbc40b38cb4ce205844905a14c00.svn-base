<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%
    request.setAttribute("activeMenu", "refund");
    request.setAttribute("activeGroup", "refund");
    request.setAttribute("activeSub", "duty");
%>
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="ctx-path" content="${pageContext.request.contextPath}">
  <title>TACS 관세 납부</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet">
  <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/owner.css">
</head>
<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/owner/sidebar.jsp" %>

  <div class="main-wrap">
    <%@ include file="/WEB-INF/views/common/header.jsp" %>

    <main class="content">
<div class="page active" id="pg-refund">
<div class="page-title-row">
<h2>관세</h2>
</div>
<!-- ① 관세 납부 탭 -->
<div id="refund-duty">
<!-- 일괄 결제 액션 바 -->
<div id="duty-action-bar" style="display:none;background:#eff6ff;border:1px solid #bfdbfe;padding:10px 16px;margin-bottom:12px;display:none;align-items:center;justify-content:space-between">
<div style="font-size:13px;font-weight:700;color:#1d4ed8"><span id="duty-selected-count">0</span>건 선택 · 합계 <span id="duty-selected-total">₩0</span></div>
<button class="btn btn-primary" onclick="openBulkDutyPayment()" style="font-size:12px;padding:8px 18px">선택 건 일괄 납부</button>
</div>
<!-- 납부 대상 현황 -->
<div style="font-size:12px;font-weight:700;color:#475569;margin-bottom:10px">납부 대상 현황</div>
<table class="data-table" style="margin-bottom:24px">
<thead>
<tr>
<th style="width:36px"><input id="dutyCheckAll" onchange="toggleAllDuty(this)" style="accent-color:#3b82f6;width:14px;height:14px" type="checkbox"/></th>
<th>의뢰번호</th><th>수입품명</th><th>관세</th><th>부가세</th><th>납부총액</th><th>납부기한</th><th>상태</th><th></th>
</tr>
</thead>
<tbody>
<tr>
<td><input class="duty-chk" data-amount="3144864" onchange="updateDutySelection()" style="accent-color:#3b82f6;width:14px;height:14px" type="checkbox"/></td>
<td><span style="background:#dcfce7;color:#15803d;font-size:10px;font-weight:700;padding:2px 6px;margin-right:4px">수입</span><strong>IMP-004</strong></td>
<td>스마트센서 모듈</td>
<td>₩1,338,240</td>
<td>₩1,806,624</td>
<td style="font-weight:800;color:#dc2626">₩3,144,864</td>
<td style="color:#dc2626;font-weight:700">2026-04-22</td>
<td><span class="doc-status wait" onclick="openDutyPaymentModal('IMP-004', '3,144,864')" style="cursor:pointer">납부전</span></td>
<td><button class="mini mini-sup" onclick="openDutyPaymentModal('IMP-004', '3,144,864')">납부</button></td>
</tr>
<tr>
<td><input class="duty-chk" data-amount="2093000" onchange="updateDutySelection()" style="accent-color:#3b82f6;width:14px;height:14px" type="checkbox"/></td>
<td><span style="background:#dcfce7;color:#15803d;font-size:10px;font-weight:700;padding:2px 6px;margin-right:4px">수입</span><strong>IMP-006</strong></td>
<td>산업용 제어보드 (신규)</td>
<td>₩890,000</td>
<td>₩1,203,000</td>
<td style="font-weight:800;color:#dc2626">₩2,093,000</td>
<td style="color:#d97706;font-weight:700">2026-04-28</td>
<td><span class="doc-status wait" onclick="openDutyPaymentModal('IMP-006', '2,093,000')" style="cursor:pointer">납부전</span></td>
<td><button class="mini mini-sup" onclick="openDutyPaymentModal('IMP-006', '2,093,000')">납부</button></td>
</tr>
<tr style="opacity:.5">
<td><input disabled="" style="width:14px;height:14px" type="checkbox"/></td>
<td><span style="background:#dcfce7;color:#15803d;font-size:10px;font-weight:700;padding:2px 6px;margin-right:4px">수입</span><strong>IMP-002</strong></td>
<td>산업용 제어보드</td>
<td>₩890,000</td>
<td>₩1,203,000</td>
<td style="font-weight:800">₩2,093,000</td>
<td style="color:#94a3b8;font-size:11px">2026-05-03</td>
<td><span class="doc-status ok">납부완료</span></td>
<td><button class="mini mini-view">영수증</button></td>
</tr>
</tbody>
</table>
</div>

    <button type="button"
            class="btn btn-dark btn-toss-pay"
            data-claim-no="${bcNo}"
            data-record-ty="BROKER">
        결제하기
    </button>
</div>
    </main>

    <%@ include file="/WEB-INF/views/common/ownerModals.jsp" %>
    <%@ include file="/WEB-INF/views/common/footer.jsp" %>
  </div>
</div>

<%@ include file="/WEB-INF/views/common/ownerScripts.jsp" %>

<script>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof switchRefundTab === 'function') switchRefundTab('duty');
});
</script>
</body>
</html>
