<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<style>
.noti-bell-wrap {
    position: relative;
    display: inline-block;
}
/* 외부에 tb-btn 등 헤더 버튼 스타일이 있으면 cascade로 덮어쓰여 기존 9차 A 동작 보존.
   Tailwind 등 다른 헤더에서는 이 기본 스타일이 적용되어 깔끔히 동작. */
.noti-bell-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
    border-radius: 8px;
    transition: background-color 0.15s ease;
}
.noti-bell-btn:hover {
    background-color: rgba(0, 0, 0, 0.06);
}
.noti-bell-btn:focus {
    outline: none;
}
/* 기존 tb-btn 스타일 상속 가정, .noti-bell-btn 자체에 특별한 스타일은 기존 tb-btn을 씀 */
.noti-bell-badge {
    position: absolute;
    top: 2px;
    right: 2px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    background: #ef4444;
    color: #fff;
    border-radius: 9px;
    font-size: 11px;
    line-height: 18px;
    text-align: center;
    font-weight: 700;
    pointer-events: none;
    box-sizing: border-box;
}
.noti-bell-panel {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 8px;
    width: 360px;
    max-height: 480px;
    overflow-y: auto;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    box-shadow: 0 12px 28px rgba(0,0,0,.18);
    z-index: 1000;
    text-align: left;
}
.noti-bell-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid #f3f4f6;
    font-weight: 700;
    color: #111827;
}
.noti-bell-actions {
    display: flex;
    align-items: center;
    gap: 10px;
}
.noti-bell-read-all, .noti-bell-clear-all {
    border: none;
    background: transparent;
    color: #2563eb;
    cursor: pointer;
    font-size: 13px;
    padding: 0;
}
.noti-bell-clear-all {
    color: #dc2626;
}
.noti-bell-list {
    margin: 0;
    padding: 0;
    list-style: none;
}
.noti-bell-item {
    padding: 12px 16px;
    border-bottom: 1px solid #f3f4f6;
    cursor: pointer;
}
.noti-bell-item:hover {
    background: #f9fafb;
}
.noti-bell-item.is-unread {
    background: #eff6ff;
}
.noti-bell-item .noti-title {
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 4px;
    color: #111827;
}
.noti-bell-item .noti-body {
    font-size: 13px;
    color: #4b5563;
    line-height: 1.4;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.noti-bell-item .noti-meta {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: #6b7280;
}
.noti-delete-btn {
    border: none;
    background: transparent;
    color: #dc2626;
    cursor: pointer;
    font-size: 11px;
    padding: 0;
}
.noti-delete-btn:hover {
    text-decoration: underline;
}
.noti-bell-empty, .noti-bell-loading {
    padding: 32px 16px;
    text-align: center;
    color: #9ca3af;
    font-size: 13px;
}
</style>

<div class="noti-bell-wrap" id="notiBellWrap">
    <button class="tb-btn noti-bell-btn" id="notiBellBtn" aria-label="알림">
        <span class="material-symbols-outlined">notifications</span>
        <span class="noti-bell-badge" id="notiBellBadge" hidden></span>
    </button>
    <div class="noti-bell-panel" id="notiBellPanel" hidden>
        <div class="noti-bell-header"><span>알림</span><div class="noti-bell-actions"><button class="noti-bell-read-all" id="notiBellReadAll">모두 읽음</button><button class="noti-bell-clear-all" id="notiBellClearAll">일괄 비우기</button></div></div>
        <ul class="noti-bell-list" id="notiBellList"></ul>
    </div>
</div>

<script>
(function () {
    const API_BASE = '${pageContext.request.contextPath}/api/notifications';
    const POLL_INTERVAL_MS = 30000;
    const PANEL_LIMIT = 10;
    const CONTEXT_PATH = '${pageContext.request.contextPath}';

    let pollTimer = null;

    function init() {
        const btn = document.getElementById('notiBellBtn');
        const panel = document.getElementById('notiBellPanel');
        const readAll = document.getElementById('notiBellReadAll');
        const clearAll = document.getElementById('notiBellClearAll');
        if (!btn || !panel || !readAll || !clearAll) return;

        btn.addEventListener('click', togglePanel);
        readAll.addEventListener('click', handleReadAll);
        clearAll.addEventListener('click', handleClearAll);
        document.addEventListener('click', handleOutsideClick);

        refreshCount();
        pollTimer = setInterval(refreshCount, POLL_INTERVAL_MS);
    }

    async function refreshCount() {
        try {
            const res = await fetch(API_BASE + '/unread-count', { credentials: 'same-origin' });
            if (!res.ok) return;  // 401 등은 조용히 무시 (세션 만료 시 다른 가드가 처리)
            const data = await res.json();
            updateBadge(data.count || 0);
        } catch (e) {
            // 네트워크 일시 오류는 다음 폴링에서 복구
        }
    }

    function updateBadge(count) {
        const badge = document.getElementById('notiBellBadge');
        if (!count) {
            badge.hidden = true;
            badge.textContent = '';
        } else {
            badge.hidden = false;
            badge.textContent = count > 99 ? '99+' : String(count);
        }
    }

    async function togglePanel(event) {
        event.stopPropagation();
        const panel = document.getElementById('notiBellPanel');
        const willOpen = panel.hidden;
        panel.hidden = !willOpen;
        if (willOpen) {
            await loadList();
        }
    }

    async function loadList() {
        const list = document.getElementById('notiBellList');
        list.innerHTML = '<li class="noti-bell-loading">불러오는 중...</li>';
        try {
            const res = await fetch(API_BASE + '?limit=' + PANEL_LIMIT, { credentials: 'same-origin' });
            if (!res.ok) {
                list.innerHTML = '<li class="noti-bell-empty">알림을 불러올 수 없습니다.</li>';
                return;
            }
            const items = await res.json();
            renderList(items);
        } catch (e) {
            list.innerHTML = '<li class="noti-bell-empty">알림을 불러올 수 없습니다.</li>';
        }
    }

    function renderList(items) {
        const list = document.getElementById('notiBellList');
        if (!items || items.length === 0) {
            list.innerHTML = '<li class="noti-bell-empty">새 알림이 없습니다</li>';
            return;
        }
        list.innerHTML = items.map(function (item) {
            const unread = item.notiReadYn === 'N' ? ' is-unread' : '';
            const biz = escape(item.npBizNm || item.notiEventCd || '');
            const title = escape(item.notiTitle || '');
            const body = escape(item.notiBody || '');
            const time = relativeTime(item.notiSendDt);
            const absTime = escape(item.notiSendDt || '');
            return '<li class="noti-bell-item' + unread + '" data-no="' + item.notiNo + '" data-link="' + escape(item.notiLinkUrl || '') + '">' +
                   '<div class="noti-title">' + title + '</div>' +
                   '<div class="noti-body">' + body + '</div>' +
                   '<div class="noti-meta"><span>' + biz + '</span><span title="' + absTime + '">' + time + '</span><button type="button" class="noti-delete-btn" data-no="' + item.notiNo + '">삭제</button></div>' +
                   '</li>';
        }).join('');
        list.querySelectorAll('.noti-bell-item').forEach(function (li) {
            li.addEventListener('click', function () { handleItemClick(li); });
        });
        list.querySelectorAll('.noti-delete-btn').forEach(function (btn) {
            btn.addEventListener('click', function (event) { handleDeleteItem(event, btn); });
        });
    }

    async function handleItemClick(li) {
        const notiNo = li.dataset.no;
        const link = li.dataset.link;
        try {
            await fetch(API_BASE + '/' + encodeURIComponent(notiNo) + '/read', {
                method: 'PUT',
                credentials: 'same-origin'
            });
        } catch (e) {
            // 읽음 처리 실패해도 이동은 진행
        }
        if (link) {
            // /로 시작하는 절대 경로면 contextPath 자동 부착
            const url = link.startsWith('/') ? CONTEXT_PATH + link : link;
            window.location.href = url;
        }
    }

    async function handleDeleteItem(event, button) {
        event.stopPropagation();
        const notiNo = button.dataset.no;
        if (!notiNo) return;
        button.disabled = true;
        try {
            await fetch(API_BASE + '/' + encodeURIComponent(notiNo), {
                method: 'DELETE',
                credentials: 'same-origin'
            });
            await refreshCount();
            await loadList();
        } catch (e) {
            button.disabled = false;
        }
    }

    async function handleClearAll(event) {
        event.stopPropagation();
        if (!confirm('모든 알림을 비울까요?')) return;
        try {
            await fetch(API_BASE, { method: 'DELETE', credentials: 'same-origin' });
            await refreshCount();
            await loadList();
        } catch (e) {
            // 무시
        }
    }

    async function handleReadAll() {
        try {
            await fetch(API_BASE + '/read-all', { method: 'PUT', credentials: 'same-origin' });
            await refreshCount();
            await loadList();
        } catch (e) {
            // 무시
        }
    }

    function handleOutsideClick(event) {
        const wrap = document.getElementById('notiBellWrap');
        const panel = document.getElementById('notiBellPanel');
        if (!wrap || !panel) return;
        if (!wrap.contains(event.target)) {
            panel.hidden = true;
        }
    }

    function relativeTime(dateStr) {
        if (!dateStr) return '';
        // 'yyyy-MM-dd HH:mm:ss' → 'yyyy-MM-ddTHH:mm:ss' 로 변환 후 파싱
        const iso = dateStr.replace(' ', 'T');
        const date = new Date(iso);
        if (isNaN(date.getTime())) return dateStr;
        const diffMs = Date.now() - date.getTime();
        const m = Math.floor(diffMs / 60000);
        if (m < 1) return '방금 전';
        if (m < 60) return m + '분 전';
        const h = Math.floor(m / 60);
        if (h < 24) return h + '시간 전';
        const d = Math.floor(h / 24);
        if (d < 7) return d + '일 전';
        return dateStr.split(' ')[0];
    }

    function escape(s) {
        if (s == null) return '';
        return String(s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
