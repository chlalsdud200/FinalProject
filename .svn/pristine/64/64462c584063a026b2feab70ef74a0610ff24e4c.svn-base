/* =========================================================
   TACS 검역기관 검역 합격 증명서 발급 전용 스타일
   - 발급 대상 목록 검색 조건
   - 발급 대상 목록 테이블
   - 증명서 상세 화면
   - 검역 결과 정보
   - 증명서 미리보기
   - 처리 이력
========================================================= */

/* ===== 검역증명서 발급 대상 목록 검색 조건 ===== */
#cert-list-view .cert-search-panel {
  border: 1px solid #d9eafc;
  background: #fff;
  padding: 20px 22px 18px;
  margin-bottom: 22px;
}

#cert-list-view .cert-search-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 15px;
  font-weight: 900;
  color: #203444;
  margin-bottom: 18px;
}

#cert-list-view .cert-search-title span {
  width: 4px;
  height: 16px;
  background: #565e74;
  display: inline-block;
}

#cert-list-view .cert-search-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
  gap: 14px 24px !important;
  margin-bottom: 16px !important;
}

#cert-list-view .cert-search-grid .form-item {
  min-width: 0;
}

#cert-list-view .cert-search-grid .form-item label {
  font-size: 11px;
  font-weight: 800;
  color: #4d6172;
  margin-bottom: 6px;
}

#cert-list-view .cert-search-grid input,
#cert-list-view .cert-search-grid select {
  width: 100%;
  min-width: 0;
  height: 36px;
  border: 1px solid #a0b4c8;
  background: #fff;
  font-size: 13px;
}

#cert-list-view .cert-search-grid input::placeholder {
  color: #94a3b8;
}

#cert-list-view .cert-search-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
}

#cert-list-view .cert-search-actions .btn {
  height: 36px;
}

#cert-list-view .cert-search-actions .material-symbols-outlined {
  font-size: 17px;
}

/* ===== 발급 대상 목록 테이블 ===== */
#cert-list-view table.data-table tbody tr {
  cursor: pointer;
}

#cert-list-view table.data-table tbody tr:hover {
  background: #f0f7ff;
}

/* ===== 검역증명서 상세 상단 카드 ===== */
#cert-detail-view .cert-summary-grid,
#cert-detail-view .detail-summary {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16px;
  margin-bottom: 20px;
}

#cert-detail-view .cert-summary-item,
#cert-detail-view .detail-summary-item {
  background: #ecf4ff;
  border-left: 4px solid #565e74;
  padding: 16px;
}

#cert-detail-view .cert-summary-item .label,
#cert-detail-view .detail-summary-item .label {
  font-size: 10px;
  font-weight: 800;
  color: #4d6172;
  text-transform: uppercase;
  letter-spacing: .5px;
  margin-bottom: 6px;
}

#cert-detail-view .cert-summary-item .value,
#cert-detail-view .detail-summary-item .value {
  font-size: 16px;
  font-weight: 900;
  color: #203444;
  word-break: keep-all;
}

/* ===== 상세 섹션 제목 ===== */
#cert-detail-view h4 {
  font-size: 12px;
  font-weight: 700;
  color: #4d6172;
  margin: 18px 0 10px;
  border-left: 3px solid #565e74;
  padding-left: 8px;
}

/* ===== 검역증명서 상세 3열 폼 ===== */
#cert-detail-view .form-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px 24px;
  margin-bottom: 18px;
}

#cert-detail-view .form-item {
  min-width: 0;
}

#cert-detail-view .form-item.full {
  grid-column: 1 / -1;
}

#cert-detail-view .form-item input,
#cert-detail-view .form-item select,
#cert-detail-view .form-item textarea {
  width: 100%;
}

/* ===== 읽기전용 입력값 ===== */
#cert-detail-view input[readonly],
#cert-detail-view textarea[readonly] {
  background: #f8fafc;
  color: #475569;
}

/* ===== 검사 결과 요약 / 판정 사유 ===== */
#cert-detail-view textarea {
  min-height: 76px;
  resize: vertical;
  line-height: 1.5;
}

/* ===== 증명서 미리보기 영역 ===== */
.cert-preview,
.food-preview,
#cert-detail-view .preview-box {
  background: #fff;
  border: 1px solid #dbe5ef;
  padding: 24px;
  margin-top: 16px;
  margin-bottom: 20px;
}

.cert-preview-header,
.food-preview-header,
#cert-detail-view .preview-header {
  border-bottom: 2px solid #0f172a;
  padding-bottom: 14px;
  margin-bottom: 18px;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
}

.cert-preview-title,
.food-preview-title,
#foodPreviewTitle {
  font-size: 18px;
  font-weight: 900;
  color: #0f172a;
}

.cert-preview-no,
.food-preview-no,
#foodPreviewNo {
  font-size: 12px;
  font-weight: 700;
  color: #565e74;
}

.cert-preview-body,
.food-preview-body {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px 24px;
}

.cert-preview-row,
.food-preview-row {
  display: flex;
  gap: 8px;
  font-size: 13px;
  color: #334155;
}

.cert-preview-row .label,
.food-preview-row .label {
  min-width: 90px;
  font-weight: 800;
  color: #4d6172;
}

.cert-preview-row .value,
.food-preview-row .value {
  flex: 1;
  font-weight: 600;
  color: #203444;
}

/* ===== 증명서 발급 상태 뱃지 ===== */
.cert-status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 64px;
  padding: 4px 10px;
  font-size: 11px;
  font-weight: 800;
  background: #ecf4ff;
  color: #565e74;
}

.cert-status-badge.wait {
  background: #fef3c7;
  color: #92400e;
}

.cert-status-badge.approve {
  background: #d1fae5;
  color: #065f46;
}

.cert-status-badge.done {
  background: #565e74;
  color: #fff;
}

/* ===== 처리 이력 테이블 ===== */
#cert-detail-view .cert-history-wrap {
  margin-top: 18px;
}

#cert-detail-view #certHistoryBody td {
  vertical-align: middle;
}

/* ===== 상세 하단 버튼 ===== */
#cert-detail-view .btn-row {
  justify-content: flex-end;
  margin-top: 20px;
}

/* ===== 출력 / 제출 버튼 강조 ===== */
#cert-detail-view .btn-primary .material-symbols-outlined,
#cert-detail-view .btn-success .material-symbols-outlined,
#cert-detail-view .btn-secondary .material-symbols-outlined {
  font-size: 14px;
}

/* ===== 반응형 ===== */
@media (max-width: 1400px) {
	#cert-list-view .cert-search-grid {
	  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
	}

	#cert-detail-view .cert-summary-grid,
	#cert-detail-view .detail-summary {
	  grid-template-columns: repeat(2, minmax(0, 1fr));
	}
	
	#cert-detail-view .form-grid {
	  grid-template-columns: repeat(2, minmax(0, 1fr));
	}
	
	.cert-preview-body,
	.food-preview-body {
	  grid-template-columns: 1fr;
	}
}

@media (max-width: 900px) {
	#cert-list-view .cert-search-grid {
	  grid-template-columns: 1fr !important;
	}
	
	#cert-list-view .cert-search-actions {
	  justify-content: flex-start;
	  flex-wrap: wrap;
	}

  #cert-detail-view .cert-summary-grid,
  #cert-detail-view .detail-summary {
    grid-template-columns: 1fr;
  }

  #cert-detail-view .form-grid {
    grid-template-columns: 1fr;
  }

  #cert-detail-view .btn-row {
    justify-content: flex-start;
  }

  .cert-preview-header,
  .food-preview-header,
  #cert-detail-view .preview-header {
    flex-direction: column;
  }
}

/* ===== 검역 합격 증명서 미리보기 모달 ===== */
.cert-preview-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, .55);
  z-index: 9999;
  align-items: center;
  justify-content: center;
  padding: 32px;
}

.cert-preview-modal.open {
  display: flex;
}

.cert-preview-modal-panel {
  width: 760px;
  max-height: 90vh;
  overflow-y: auto;
  background: #fff;
  border: 1px solid #cbd5e1;
  box-shadow: 0 20px 40px rgba(15, 23, 42, .25);
}

.cert-preview-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: #373f54;
  color: #fff;
}

.cert-preview-modal-title {
  font-size: 14px;
  font-weight: 800;
  display: flex;
  align-items: center;
  gap: 8px;
}

.cert-preview-modal-close {
  background: none;
  border: none;
  color: #fff;
  font-size: 22px;
  cursor: pointer;
  line-height: 1;
}

.cert-preview-print-area {
  padding: 36px 42px;
  background: #fff;
  color: #203444;
}

.cert-preview-doc-title {
  text-align: center;
  border-bottom: 2px solid #0f172a;
  padding-bottom: 20px;
  margin-bottom: 24px;
}

.cert-preview-doc-title .ko {
  font-size: 24px;
  font-weight: 900;
  letter-spacing: 2px;
  margin-bottom: 8px;
}

.cert-preview-doc-title .en {
  font-size: 12px;
  color: #64748b;
}

.cert-preview-print-area table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
  margin-bottom: 22px;
}

.cert-preview-print-area th {
  width: 24%;
  text-align: left;
  background: #ecf4ff;
  border: 1px solid #cbd5e1;
  padding: 10px;
}

.cert-preview-print-area td {
  border: 1px solid #cbd5e1;
  padding: 10px;
}

.cert-preview-print-area h4 {
  font-size: 13px;
  font-weight: 800;
  margin: 20px 0 8px;
  border-left: 3px solid #565e74;
  padding-left: 8px;
}

.cert-preview-modal-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 20px;
  border-top: 1px solid #e2e8f0;
  background: #f8fbff;
}


/* ===== 최종 판정 영역 ===== */
.judge-final-box {
  margin-top: 24px;
  padding: 22px 24px;
  border: 2px solid #cbd5e1;
  background: #f8fafc;
}

.judge-final-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18px;
}

.judge-final-title {
  font-size: 20px;
  font-weight: 900;
  color: #203444;
}

.judge-final-sub {
  margin-top: 4px;
  font-size: 12px;
  color: #64748b;
  font-weight: 600;
}

.judge-final-icon {
  font-size: 36px;
  color: #565e74;
}

.judge-final-body {
  display: grid;
  grid-template-columns: 1fr 240px;
  gap: 20px;
  align-items: end;
}

.judge-final-select-wrap label,
.judge-final-result-label {
  display: block;
  margin-bottom: 8px;
  font-size: 12px;
  font-weight: 800;
  color: #4d6172;
}

.judge-final-select-wrap select {
  width: 100%;
  height: 48px;
  border: 1px solid #94a3b8;
  padding: 0 12px;
  font-size: 16px;
  font-weight: 700;
  background: #fff;
}

.judge-final-result {
  background: #fff;
  border: 1px solid #cbd5e1;
  padding: 12px 14px;
  min-height: 48px;
}

.judge-final-result-value {
  font-size: 28px;
  font-weight: 900;
  color: #203444;
  line-height: 1.2;
}

.judge-final-message {
  margin-top: 16px;
  padding: 12px 14px;
  background: #eef2f7;
  border-left: 4px solid #565e74;
  font-size: 13px;
  font-weight: 700;
  color: #334155;
}

/* 합격 상태 */
.judge-final-box.pass {
  border-color: #1d6b4f;
  background: #f0fdf4;
}

.judge-final-box.pass .judge-final-icon,
.judge-final-box.pass .judge-final-result-value {
  color: #1d6b4f;
}

.judge-final-box.pass .judge-final-message {
  background: #dcfce7;
  border-left-color: #1d6b4f;
  color: #166534;
}

/* 불합격 상태 */
.judge-final-box.fail {
  border-color: #9f403d;
  background: #fff1f2;
}

.judge-final-box.fail .judge-final-icon,
.judge-final-box.fail .judge-final-result-value {
  color: #9f403d;
}

.judge-final-box.fail .judge-final-message {
  background: #ffe4e6;
  border-left-color: #9f403d;
  color: #9f1239;
}

/* ===== 최종 판정 및 발급 적격성 확인 ===== */
.cert-final-decision-box {
  margin-top: 24px;
  padding: 22px 24px;
  border: 1px solid #cbd5e1;
  border-top: 4px solid #373f54;
  background: #f8fbff;
}

.cert-final-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20px;
  margin-bottom: 18px;
}

.cert-final-title {
  font-size: 18px;
  font-weight: 900;
  color: #203444;
  margin-bottom: 5px;
}

.cert-final-desc {
  font-size: 12px;
  font-weight: 600;
  color: #64748b;
}

.cert-final-status {
  min-width: 110px;
  padding: 9px 14px;
  text-align: center;
  font-size: 12px;
  font-weight: 900;
  border: 1px solid #cbd5e1;
  background: #fff;
  color: #334155;
}

.cert-final-options {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.cert-final-option {
  min-width: 0;
}

.cert-final-option {
  position: relative;
  display: block;
  padding: 18px 18px 16px;
  border: 1px solid #cbd5e1;
  background: #fff;
  cursor: pointer;
  transition: all .12s ease;
}

.cert-final-option input {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 18px;
  height: 18px;
  accent-color: #373f54;
}

.cert-final-option .option-top {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

.cert-final-option .option-top .material-symbols-outlined {
  font-size: 28px;
  color: #565e74;
}

.cert-final-option strong {
  font-size: 20px;
  font-weight: 900;
  color: #203444;
}

.cert-final-option p {
  font-size: 12px;
  font-weight: 600;
  color: #64748b;
  line-height: 1.6;
}

.cert-final-option.selected {
  border-width: 2px;
  padding: 17px 17px 15px;
}

.cert-final-option.pass.selected {
  border-color: #1d6b4f;
  background: #f0fdf4;
}

.cert-final-option.pass.selected .material-symbols-outlined,
.cert-final-option.pass.selected strong {
  color: #1d6b4f;
}

.cert-final-option.fail.selected {
  border-color: #9f403d;
  background: #fff1f2;
}

.cert-final-option.fail.selected .material-symbols-outlined,
.cert-final-option.fail.selected strong {
  color: #9f403d;
}

.cert-final-result-line {
  margin-top: 14px;
  padding: 12px 14px;
  border-left: 4px solid #565e74;
  background: #eef2f7;
  font-size: 12px;
  font-weight: 800;
  color: #334155;
}

.cert-final-decision-box.pass {
  border-top-color: #1d6b4f;
}

.cert-final-decision-box.pass .cert-final-status {
  background: #dcfce7;
  color: #166534;
  border-color: #86efac;
}

.cert-final-decision-box.fail {
  border-top-color: #9f403d;
}

.cert-final-decision-box.fail .cert-final-status {
  background: #ffe4e6;
  color: #9f1239;
  border-color: #fda4af;
}


/* ===== 검역 합격 증명서 목록 페이지네이션 ===== */
#cert-list-view .pagination-area {
  display: flex !important;
  justify-content: center !important;
  align-items: center;
  width: 100%;
  margin-top: 16px;
}

#cert-list-view .pagination-area ul.pagination {
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 4px;
  list-style: none !important;
  margin: 0 !important;
  padding: 0 !important;
}

#cert-list-view .pagination-area ul.pagination li {
  list-style: none !important;
  margin: 0;
  padding: 0;
}

#cert-list-view .pagination-area .page-link {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 30px;
  height: 30px;
  padding: 0 10px;
  border: 1px solid #b8c7d9;
  background: #fff;
  color: #203444;
  font-size: 12px;
  font-weight: 700;
  text-decoration: none;
  box-sizing: border-box;
}

#cert-list-view .pagination-area .page-item.active .page-link,
#cert-list-view .pagination-area .page-item.active span.page-link {
  background: #565e74;
  border-color: #565e74;
  color: #fff;
}

#cert-list-view .pagination-area .page-link:hover {
  background: #eef4fb;
}


/* ===== TOAST UI Grid 상세 버튼 ===== */
.grid-detail-btn {
  height: 28px;
  padding: 0 12px;
  border: 1px solid #4b5563;
  background: #ffffff;
  color: #1f2937;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
}

.grid-detail-btn:hover {
  background: #1f2937;
  color: #ffffff;
}

#certsGrid .tui-grid-cell {
  cursor: pointer;
}


/* =========================================================
   보완요청 진행 현황
   ========================================================= */

.supp-progress-card {
    margin-top: 22px;
    padding: 20px;
    border: 1px solid #d8e0ea;
    background: #ffffff;
}

.supp-progress-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid #e2e8f0;
}

.supp-progress-head h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 800;
    color: #203444;
}

.supp-progress-head p {
    margin: 4px 0 0;
    font-size: 12px;
    color: #64748b;
}

.supp-status-badge {
    display: inline-flex;
    align-items: center;
    height: 28px;
    padding: 0 12px;
    font-size: 12px;
    font-weight: 800;
    border: 1px solid #cbd5e1;
    background: #f8fafc;
    color: #334155;
}

.supp-status-badge.wait {
    border-color: #f3d19e;
    background: #fff7ed;
    color: #9a3412;
}

.supp-status-badge.submit {
    border-color: #93c5fd;
    background: #eff6ff;
    color: #1d4ed8;
}

.supp-status-badge.done {
    border-color: #86efac;
    background: #f0fdf4;
    color: #166534;
}

.supp-block {
    margin-top: 16px;
    padding: 16px;
    border: 1px solid #e2e8f0;
    background: #f8fbff;
}

.supp-block-title {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
    font-size: 13px;
    font-weight: 800;
    color: #334155;
}

.supp-block-title .material-symbols-outlined {
    font-size: 18px;
    color: #565e74;
}

.supp-info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 12px;
}

.supp-info-item {
    padding: 10px 12px;
    border: 1px solid #e2e8f0;
    background: #ffffff;
}

.supp-info-item span {
    display: block;
    margin-bottom: 4px;
    font-size: 11px;
    color: #64748b;
    font-weight: 700;
}

.supp-info-item strong {
    font-size: 13px;
    color: #111827;
    font-weight: 800;
}

.supp-content-box {
    border: 1px solid #d8e0ea;
    background: #ffffff;
}

.supp-content-label {
    padding: 9px 12px;
    border-bottom: 1px solid #e2e8f0;
    background: #f1f5f9;
    font-size: 12px;
    font-weight: 800;
    color: #334155;
}

.supp-content-text {
    min-height: 72px;
    padding: 12px;
    font-size: 13px;
    line-height: 1.7;
    color: #1f2937;
    white-space: pre-wrap;
}

.supp-empty-submit {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 16px;
    padding: 14px 16px;
    border: 1px dashed #cbd5e1;
    background: #f8fafc;
    color: #475569;
}

.supp-empty-submit .material-symbols-outlined {
    font-size: 24px;
    color: #64748b;
}

.supp-empty-submit strong {
    display: block;
    font-size: 13px;
    color: #334155;
}

.supp-empty-submit p {
    margin: 3px 0 0;
    font-size: 12px;
    color: #64748b;
}

.submit-block {
    background: #fbfdff;
}

.supp-action-row {
    display: flex;
    justify-content: flex-end;
    margin-top: 14px;
}