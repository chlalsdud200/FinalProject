<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%
    request.setAttribute("activeMenu", "transport");
    request.setAttribute("activeGroup", "transport");
    request.setAttribute("activeSub", "forwarder");
    request.setAttribute("transportTab", "forwarder");
%>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="ctx-path" content="${pageContext.request.contextPath}">
    <title>TACS 운송업체 선택</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
          rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
          rel="stylesheet">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/owner.css">
</head>
<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/owner/sidebar.jsp" %>

    <div class="main-wrap">
        <%@ include file="/WEB-INF/views/common/header.jsp" %>

        <main class="content">
            <div class="page active" id="pg-transport">
                <div class="page-title-row">
                    <h2>운송</h2>
                </div>
                <%@ include file="/WEB-INF/views/owner/transport/fragments/transportTabs.jsp" %>
                <div id="trans-fwd-list-view">
                    <div class="filter-bar" style="margin-bottom: 20px; border-left:3px solid #565e74;">
                        <div class="search-wrap" style="flex:1">
                            <span class="material-symbols-outlined">search</span>
                            <input id="trans-fwd-search" oninput="renderTransFwdList()"
                                   placeholder="운송업체명, 담당자, 전문구간 검색..." style="width:100%"/>
                        </div>
                        <select id="trans-fwd-type-filter" onchange="renderTransFwdList()" style="min-width:120px">
                            <option value="">전체 유형</option>
                            <option value="해상">해상</option>
                            <option value="항공">항공</option>
                            <option value="복합">복합</option>
                        </select>
                        <select id="trans-fwd-status-filter" onchange="renderTransFwdList()" style="min-width:120px">
                            <option value="">전체 상태</option>
                            <option value="이용중">이용중</option>
                            <option value="계약종료">계약종료</option>
                        </select>
                        <input id="trans-fwd-date-from" onchange="renderTransFwdList()"
                               style="padding:6px 8px;border:1px solid #e2e8f0;font-size:12px" type="date"/>
                        <span style="font-size:11px;color:#94a3b8">~</span>
                        <input id="trans-fwd-date-to" onchange="renderTransFwdList()"
                               style="padding:6px 8px;border:1px solid #e2e8f0;font-size:12px" type="date"/>
                        <button class="btn btn-dark" onclick="renderTransFwdList()">조회</button>
                        <a class="btn btn-primary"
                           href="${pageContext.request.contextPath}/owner/transport/contract/form.do"
                           style="text-decoration:none">
                            <span class="material-symbols-outlined"
                                  style="font-size:14px;vertical-align:middle;margin-right:4px">handshake</span>운송업체 계약
                        </a>
                    </div>
                    <div style="font-size:12px;font-weight:700;color:#475569;margin-bottom:10px">운송업체 목록</div>
                    <div class="card-section">
                        <table class="data-table">
                            <thead>
                            <tr>
                                <th>운송업체명</th>
                                <th>담당자 / 연락처</th>
                                <th>전문구간</th>
                                <th>운송유형</th>
                                <th>평점/실적</th>
                                <th>상태</th>
                                <th style="width:160px">관리</th>
                            </tr>
                            </thead>
                            <tbody id="trans-fwd-list-tbody">
                            <!-- JS에서 동적 렌더링 -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>

        <%@ include file="/WEB-INF/views/common/ownerModals.jsp" %>
        <%@ include file="/WEB-INF/views/common/footer.jsp" %>
    </div>
</div>

<%@ include file="/WEB-INF/views/common/ownerScripts.jsp" %>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (typeof renderTransFwdList === 'function') renderTransFwdList();
    });

    // JSP 분리 후 계약/상세는 같은 화면 div 표시가 아니라 URL 이동으로 처리한다.
    function openFwdContractForm(idx) {
        var url = '${pageContext.request.contextPath}/owner/transport/contract/form.do';
        if (typeof idx === 'number' && window.fwdData && fwdData[idx]) {
            url += '?frwrId=' + encodeURIComponent(fwdData[idx].name);
        }
        location.href = url;
    }

    function openFwdCompanyDetail(idx) {
        var id = (typeof idx === 'number' && window.fwdData && fwdData[idx]) ? encodeURIComponent(fwdData[idx].name) : '';
        location.href = '${pageContext.request.contextPath}/owner/transport/forwarder/detail.do/' + id;
    }
</script>

</body>
</html>
