<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ include file="/WEB-INF/views/officer/common/taglibs.jsp" %>
<%@ taglib uri="http://www.springframework.org/security/tags" prefix="sec" %>

<c:set var="ctx" value="${pageContext.request.contextPath}" />
<c:set var="activeMenu" value="cargo" />
<c:set var="activeSub" value="loadedCargoList" />

<!DOCTYPE html>
<html lang="ko">
    <head>
        <%@ include file="/WEB-INF/views/officer/header/head.jsp" %>
        <title>TACS · 적재화물목록 / 혼재화물 적하목록 조회</title>
        <link rel="stylesheet" href="${ctx}/resources/css/officer/pages/loadedCargoList.css">
    </head>

    <body>
        <%@ include file="/WEB-INF/views/officer/header/sidebar.jsp" %>
        <%@ include file="/WEB-INF/views/officer/header/header.jsp" %>

        <main class="officer-main">
            <div class="page-content loadedCargoList-page">
                <div class="mb-5">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="text-[10px] font-black text-on-surface-variant">이행·반출 및 화물 조회</span>
                        <span class="text-on-surface-variant">›</span>
                        <span class="bg-primary text-on-primary text-[10px] font-black px-2 py-0.5">TACS-AD-017</span>
                    </div>
                    <h2 class="text-xl font-black text-slate-900">적재화물목록 / 혼재화물 적하목록 조회</h2>
                </div>

                <div class="inline-screen-host active" id="screen-host-TACS-AD-017">
                    <div class="inline-screen-header">
                        <h3 class="font-black text-base">적재화물목록 / 혼재화물 적하목록 조회</h3>
                        <p class="text-[10px] text-primary-fixed mt-0.5">TACS-AD-017 · 신고값과 실제 물류목록을 비교하여 선적·혼재화물 이상 여부를 확인합니다.</p>
                    </div>
                    <div class="inline-screen-body">
                        <div class="line-tabs" style="margin-bottom:16px;">
                            <button class="line-tab active" data-tab-group="cargo-list-type" onclick="setCommonTab('cargo-list-type','loading-list',this)">적재화물목록</button>
                            <button class="line-tab" data-tab-group="cargo-list-type" onclick="setCommonTab('cargo-list-type','house-list',this)">혼재화물 적하목록</button>
                        </div>
                        <div class="receipt-search-panel white-bg">
                            <p class="section-title receipt-search-title">검색 조건</p>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">신고번호</div>
                                <div class="receipt-search-field receipt-search-field-wide">
                                    <input class="receipt-search-input" placeholder="신고번호 입력" style="width:100%;" type="text"/>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">처리 상태</div>
                                <div class="receipt-search-field receipt-search-field-md">
                                    <select class="receipt-search-select w-full">
                                        <option>전체</option>
                                        <option>접수대기</option>
                                        <option>심사중</option>
                                        <option>처리대기</option>
                                        <option>완료</option>
                                    </select>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">구분</div>
                                <div class="receipt-search-radio-group">
                                    <label class="receipt-check-item"><input checked="" type="checkbox"/> 전체</label>
                                    <label class="receipt-check-item"><input type="checkbox"/> 수입</label>
                                    <label class="receipt-check-item"><input type="checkbox"/> 수출</label>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">신고 일자</div>
                                <div class="receipt-search-date-wrap">
                                    <input class="receipt-search-date" type="date" value="2026-04-01"/>
                                    <span class="receipt-search-date-sep">~</span>
                                    <input class="receipt-search-date" type="date" value="2026-04-14"/>
                                    <button class="receipt-inline-btn">최근 1주일</button>
                                </div>
                            </div>
                            <div class="receipt-search-row receipt-search-row-last">
                                <div class="receipt-search-label">통합 검색</div>
                                <div class="receipt-search-bottom">
                                    <input class="receipt-search-input" placeholder="신고번호 또는 업체명 입력" type="text"/>
                                    <button class="btn-primary receipt-action-btn"><span class="material-symbols-outlined text-[16px]">search</span>조회</button>
                                    <button class="btn-secondary receipt-action-btn">초기화</button>
                                </div>
                            </div>
                        </div> <div data-panel-group="cargo-list-type" data-panel-key="loading-list" style="display:block;">
                        <div class="flex items-center justify-between mb-3"><div class="text-[15px] font-bold text-slate-800">적재화물목록 검증 대상 <span class="text-blue-600 ml-2">3건</span></div></div>
                        <div class="bg-white border border-slate-200 mb-4">
                            <table class="data-table">
                                <thead><tr><th>No.</th><th>B/L번호</th><th>신고번호</th><th>선박/항차</th><th>업체명</th><th>품명</th><th>신고↔목록</th><th>검증상태</th><th>상세</th></tr></thead>
                                <tbody>
                                    <tr><td>1</td><td class="font-bold text-blue-600">MBL-KR26041801</td><td>EXP-2026-0418-007</td><td>HMM OCEAN / 0418E</td><td>미래로지스</td><td>자동차부품</td><td>일치</td><td><span class="badge-done">정상</span></td><td><button class="btn-secondary btn-sm" onclick="toggleCargoDetail(this)">상세</button></td></tr>
                                    <tr><td>2</td><td class="font-bold text-blue-600">MBL-KR26041711</td><td>EXP-2026-0417-011</td><td>MSC GRACE / 2526E</td><td>서해테크</td><td>산업기기</td><td>중량 차이</td><td><span class="badge-wait">확인필요</span></td><td><button class="btn-secondary btn-sm" onclick="toggleCargoDetail(this)">상세</button></td></tr>
                                    <tr><td>3</td><td class="font-bold text-blue-600">MBL-KR26041209</td><td>EXP-2026-0412-022</td><td>KMTC BUSAN / 119W</td><td>코오롱</td><td>화학제품</td><td>컨테이너 불일치</td><td><span class="badge-fail">불일치</span></td><td><button class="btn-secondary btn-sm" onclick="toggleCargoDetail(this)">상세</button></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div data-panel-group="cargo-list-type" data-panel-key="house-list" style="display:none;">
                        <div class="flex items-center justify-between mb-3"><div class="text-[15px] font-bold text-slate-800">혼재화물 적하목록 검증 대상 <span class="text-blue-600 ml-2">3건</span></div></div>
                        <div class="bg-white border border-slate-200 mb-4">
                            <table class="data-table">
                                <thead><tr><th>No.</th><th>MB/L</th><th>HB/L</th><th>신고번호</th><th>화주명</th><th>품명</th><th>혼재 검증</th><th>검증상태</th><th>상세</th></tr></thead>
                                <tbody>
                                    <tr><td>1</td><td class="font-bold text-blue-600">MBL-KR26041801</td><td>HBL-260418-031</td><td>IMP-2026-0418-031</td><td>정다운무역</td><td>냉동망고</td><td>화주·수량 일치</td><td><span class="badge-done">정상</span></td><td><button class="btn-secondary btn-sm" onclick="toggleCargoDetail(this)">상세</button></td></tr>
                                    <tr><td>2</td><td class="font-bold text-blue-600">MBL-KR26041801</td><td>HBL-260418-044</td><td>IMP-2026-0418-044</td><td>동해전자</td><td>전자부품</td><td>품명 확인필요</td><td><span class="badge-wait">확인중</span></td><td><button class="btn-secondary btn-sm" onclick="toggleCargoDetail(this)">상세</button></td></tr>
                                    <tr><td>3</td><td class="font-bold text-blue-600">MBL-KR26041718</td><td>HBL-260417-009</td><td>IMP-2026-0417-009</td><td>세림푸드</td><td>가공식품</td><td>HB/L 누락 의심</td><td><span class="badge-fail">불일치</span></td><td><button class="btn-secondary btn-sm" onclick="toggleCargoDetail(this)">상세</button></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div id="cargo-list-detail-panel" style="display:none;">
                        <div class="info-card mb-0">
                            <p class="section-title">운송 기본정보</p>
                            <div class="grid grid-cols-4 gap-3 mb-4">
                                <div><label class="form-label">B/L번호</label><input class="form-input" readonly="" type="text" value="MBL-KR26041711 / HBL-260417-009"/></div>
                                <div><label class="form-label">신고번호</label><input class="form-input" readonly="" type="text" value="EXP-2026-0417-011"/></div>
                                <div><label class="form-label">선박/항차</label><input class="form-input" readonly="" type="text" value="MSC GRACE / 2526E"/></div>
                                <div><label class="form-label">출항예정일</label><input class="form-input" readonly="" type="text" value="2026-04-21"/></div>
                                <div><label class="form-label">출발항</label><input class="form-input" readonly="" type="text" value="부산항"/></div>
                                <div><label class="form-label">도착항</label><input class="form-input" readonly="" type="text" value="LA/LONG BEACH"/></div>
                                <div><label class="form-label">컨테이너번호</label><input class="form-input" readonly="" type="text" value="MSCU-2401123"/></div>
                                <div><label class="form-label">검증상태</label><input class="form-input" readonly="" type="text" value="중량 차이 확인필요"/></div>
                            </div>
                            <p class="section-title">신고정보 ↔ 적재/적하목록 비교</p>
                            <table class="data-table mb-4">
                                <thead><tr><th>비교항목</th><th>신고서 DB값</th><th>물류목록 값</th><th>확인결과</th></tr></thead>
                                <tbody>
                                    <tr><td class="font-bold">품명</td><td>산업기기 부품</td><td>산업기기 부품</td><td><span class="badge-done">일치</span></td></tr>
                                    <tr><td class="font-bold">수량</td><td>22 PLT</td><td>22 PLT</td><td><span class="badge-done">일치</span></td></tr>
                                    <tr><td class="font-bold">중량</td><td>1,180 KG</td><td>1,240 KG</td><td><span class="badge-wait">차이 60 KG</span></td></tr>
                                    <tr><td class="font-bold">컨테이너번호</td><td>MSCU-2401123</td><td>MSCU-2401123</td><td><span class="badge-done">일치</span></td></tr>
                                    <tr><td class="font-bold">화주명</td><td>서해테크</td><td>서해테크</td><td><span class="badge-done">일치</span></td></tr>
                                </tbody>
                            </table>
                            <p class="section-title">불일치 항목 및 처리</p>
                            <table class="data-table mb-4">
                                <tbody>
                                    <tr><td class="font-bold">불일치 항목</td><td>신고 중량과 적재화물목록 중량이 60 KG 차이</td></tr>
                                    <tr><td class="font-bold">확인 필요 자료</td><td>Packing List, 계량증명서, 운송사 정정자료</td></tr>
                                    <tr><td class="font-bold">처리 기준</td><td>단순 오기 확인 시 정상 확인, 증빙 부족 시 보완요청 또는 검사 요청</td></tr>
                                </tbody>
                            </table>
                            <div class="flex gap-2 flex-wrap">
                                <button class="btn-primary">정상 확인</button>
                                <button class="btn-secondary">보완요청</button>
                                <button class="btn-secondary" onclick="showPage('cat4')">검사 요청</button>
                                <button class="btn-danger">적재 보류</button>
                            </div>
                        </div>
                    </div></div>
                </div>
            </div>
        </main>

        <%@ include file="/WEB-INF/views/officer/footer/footer.jsp" %>
        <%@ include file="/WEB-INF/views/officer/footer/scripts.jsp" %>

        <script defer src="${ctx}/resources/js/officer/pages/loadedCargoList.js"></script>
    </body>
</html>
