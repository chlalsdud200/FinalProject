/* 이 파일에는 사이드바/헤더 CSS를 넣지 않는다. */
.warehouseCargoTracking-page {
  padding: 24px 28px;
}

.warehouseCargoTracking-page * {
  box-sizing: border-box;
}

.warehouseCargoTracking-page .page-content {
  padding: 0;
}

.warehouseCargoTracking-page .section-head {
  margin-bottom: 20px;
}

.warehouseCargoTracking-page .breadcrumb-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
  color: #64748b;
  font-size: 11px;
}

.warehouseCargoTracking-page .breadcrumb-text {
  color: #64748b;
  font-size: 11px;
  font-weight: 700;
}

.warehouseCargoTracking-page .breadcrumb-sep {
  color: #94a3b8;
}

.warehouseCargoTracking-page .breadcrumb-tag {
  background: #1e3054;
  color: #fff;
  padding: 2px 8px;
  font-size: 10px;
  font-weight: 900;
}

.warehouseCargoTracking-page .page-heading {
  margin: 0 0 14px;
  color: #0f172a;
  font-size: 20px;
  font-weight: 900;
}

.warehouseCargoTracking-page .inline-screen-host {
  background: #fff;
  border: 1px solid #dde4ef;
}

.warehouseCargoTracking-page .inline-screen-header {
  padding: 14px 18px;
  border-bottom: 1px solid #dde4ef;
}

.warehouseCargoTracking-page .screen-title {
  margin: 0 0 3px;
  color: #0f172a;
  font-size: 14px;
  font-weight: 900;
}

.warehouseCargoTracking-page .screen-desc {
  margin: 0;
  color: #64748b;
  font-size: 10px;
}

.warehouseCargoTracking-page .inline-screen-body {
  padding: 18px;
}

/* 검색 조건 */
.warehouseCargoTracking-page .receipt-search-panel {
  margin-bottom: 18px;
  background: #fff;
  border: 1px solid #dde4ef;
}

.warehouseCargoTracking-page .receipt-search-title,
.warehouseCargoTracking-page .section-title {
  position: relative;
  margin: 0;
  padding: 10px 16px 10px 20px;
  border-bottom: 1px solid #dde4ef;
  color: #111827;
  font-size: 12px;
  font-weight: 900;
}

.warehouseCargoTracking-page .receipt-search-title::before,
.warehouseCargoTracking-page .section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 4px;
  height: 100%;
  background: #536178;
}

.warehouseCargoTracking-page .receipt-search-row {
  display: flex;
  align-items: center;
  min-height: 44px;
  padding: 6px 16px;
  border-bottom: 1px solid #f1f5f9;
  gap: 14px;
}

.warehouseCargoTracking-page .receipt-search-row-last {
  border-bottom: 0;
}

.warehouseCargoTracking-page .receipt-search-label {
  width: 90px;
  flex: 0 0 90px;
  color: #374151;
  font-size: 12px;
  font-weight: 700;
}

.warehouseCargoTracking-page .receipt-search-field,
.warehouseCargoTracking-page .receipt-search-bottom,
.warehouseCargoTracking-page .receipt-search-date-wrap,
.warehouseCargoTracking-page .receipt-search-radio-group {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
}

.warehouseCargoTracking-page .receipt-search-input,
.warehouseCargoTracking-page .receipt-search-select,
.warehouseCargoTracking-page .receipt-search-date {
  height: 33px;
  padding: 0 10px;
  border: 1px solid #d1d9e6;
  background: #fff;
  color: #0f172a;
  font-size: 12px;
  outline: none;
}

.warehouseCargoTracking-page .receipt-search-input:focus,
.warehouseCargoTracking-page .receipt-search-select:focus,
.warehouseCargoTracking-page .receipt-search-date:focus {
  border-color: #3b5bdb;
}

.warehouseCargoTracking-page .receipt-search-field-md { max-width: 260px; }
.warehouseCargoTracking-page .receipt-search-field-wide { max-width: 420px; }
.warehouseCargoTracking-page .receipt-search-date { width: 130px; }
.warehouseCargoTracking-page .receipt-search-date-sep { color: #94a3b8; }

.warehouseCargoTracking-page .receipt-check-item {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  margin-right: 12px;
  color: #374151;
  font-size: 12px;
  font-weight: 600;
}

/* 버튼 */
.warehouseCargoTracking-page .btn-primary,
.warehouseCargoTracking-page .btn-secondary,
.warehouseCargoTracking-page .btn-danger,
.warehouseCargoTracking-page .receipt-action-btn,
.warehouseCargoTracking-page .receipt-inline-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 33px;
  padding: 0 14px;
  border: 1px solid transparent;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  white-space: nowrap;
}

.warehouseCargoTracking-page .btn-primary {
  background: #1e3054;
  border-color: #1e3054;
  color: #fff;
}

.warehouseCargoTracking-page .btn-primary:hover { background: #152540; }

.warehouseCargoTracking-page .btn-secondary,
.warehouseCargoTracking-page .receipt-inline-btn {
  background: #fff;
  border-color: #cbd8e8;
  color: #334155;
}

.warehouseCargoTracking-page .btn-secondary:hover,
.warehouseCargoTracking-page .receipt-inline-btn:hover { background: #f1f5f9; }

.warehouseCargoTracking-page .btn-danger {
  background: #fef2f2;
  border-color: #fca5a5;
  color: #991b1b;
}

.warehouseCargoTracking-page .btn-sm {
  height: 28px;
  padding: 0 10px;
  font-size: 11px;
}

/* 결과/테이블 */
.warehouseCargoTracking-page .result-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.warehouseCargoTracking-page .result-title {
  color: #1e293b;
  font-size: 15px;
  font-weight: 700;
}

.warehouseCargoTracking-page .result-count {
  margin-left: 6px;
  color: #2563eb;
}

.warehouseCargoTracking-page .table-wrap,
.warehouseCargoTracking-page .info-card {
  background: #fff;
  border: 1px solid #d9eafc;
}

.warehouseCargoTracking-page .table-wrap {
  margin-bottom: 16px;
  overflow-x: auto;
}

.warehouseCargoTracking-page .data-table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
}

.warehouseCargoTracking-page .data-table th {
  padding: 10px 14px;
  background: #ecf4ff;
  border-bottom: 1px solid #d9eafc;
  color: #4d6172;
  font-size: 10px;
  font-weight: 800;
  text-align: center;
  white-space: nowrap;
}

.warehouseCargoTracking-page .data-table td {
  padding: 11px 14px;
  border-bottom: 1px solid #d9eafc;
  color: #203444;
  font-size: 12px;
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
}

.warehouseCargoTracking-page .data-table tbody tr:hover td {
  background: #f8fbff;
}

.warehouseCargoTracking-page .td-bold {
  font-weight: 700;
  color: #0f2537;
}

/* 상세 행 */
.warehouseCargoTracking-page .p-zero {
  padding: 0 !important;
}

.warehouseCargoTracking-page .detail-content {
  background: #fff;
  border-top: 1px solid #e2e8f0;
  padding: 18px;
}

.warehouseCargoTracking-page .grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.warehouseCargoTracking-page .grid-sm {
  margin-bottom: 16px;
}

.warehouseCargoTracking-page .info-card {
  overflow: hidden;
}

.warehouseCargoTracking-page .btn-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

@media (max-width: 1200px) {
  .warehouseCargoTracking-page .grid-3 {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .warehouseCargoTracking-page {
    padding: 16px;
  }

  .warehouseCargoTracking-page .receipt-search-row {
    align-items: flex-start;
    flex-direction: column;
  }
}
