<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="jakarta.tags.fmt" %>
<c:set var="ctx" value="${pageContext.request.contextPath}" />
<!DOCTYPE html>
<html lang="ko">
<head>
    <%@ include file="/WEB-INF/views/broker/common/meta.jsp" %>
    <link rel="stylesheet" href="${ctx}/resources/css/broker/common.css">
    <link rel="stylesheet" href="${ctx}/resources/css/broker/pages/status.css">
    <title>처리현황 | TACS</title>
</head>
<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/broker/common/sidebar.jsp" %>
    <div class="main-wrap">
        <%@ include file="/WEB-INF/views/broker/common/header.jsp" %>
        <div class="content">
<%-- 처리현황 페이지 --%>
      <div class="page active" id="pg-status">
       <div class="sub-page">
          <div class="sub-tabs" id="tabs-st">
            <a class="sub-tab ${activeSub eq 'search' ? 'active' : ''}" href="${ctx}/broker/status/search.do">통합 조회</a>
			<a class="sub-tab ${activeSub eq 'tax' ? 'active' : ''}" href="${ctx}/broker/status/tax.do">세금납부 관리</a>
			<a class="sub-tab ${activeSub eq 'cert' ? 'active' : ''}" href="${ctx}/broker/status/cert.do">신고필증 관리</a>
          </div>

        	<c:if test="${activeSub eq 'search' and mode ne 'detail' and mode ne 'suppForm'}">

  <form method="get" action="${ctx}/broker/status/search.do">
    <input type="hidden" name="page" value="1">

    <div class="form-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
      <div class="form-item">
        <label>검색구분</label>
        <select name="searchType">
          <option value="" ${empty pageDTO.searchType ? 'selected' : ''}>전체</option>
          <option value="irNo" ${pageDTO.searchType eq 'irNo' ? 'selected' : ''}>통관의뢰번호</option>
          <option value="owner" ${pageDTO.searchType eq 'owner' ? 'selected' : ''}>화주/수입자</option>
          <option value="item" ${pageDTO.searchType eq 'item' ? 'selected' : ''}>품목/HS코드</option>
        </select>
      </div>

      <div class="form-item">
        <label>검색어</label>
        <input name="keyword" value="${pageDTO.keyword}" placeholder="검색어 입력">
      </div>

      <div class="form-item">
        <label>신고서 상태</label>
        <select name="statusCd">
          <option value="" ${empty pageDTO.statusCd ? 'selected' : ''}>전체</option>
          <option value="TEMP" ${pageDTO.statusCd eq 'TEMP' ? 'selected' : ''}>임시저장</option>
          <option value="SUBMIT" ${pageDTO.statusCd eq 'SUBMIT' ? 'selected' : ''}>신고제출</option>
          <option value="CSTM_INPRG" ${pageDTO.statusCd eq 'CSTM_INPRG' ? 'selected' : ''}>세관심사중</option>
          <option value="CSTM_ACPT" ${pageDTO.statusCd eq 'CSTM_ACPT' ? 'selected' : ''}>수리</option>
          <option value="CSTM_REJ" ${pageDTO.statusCd eq 'CSTM_REJ' ? 'selected' : ''}>반려</option>
        </select>
      </div>

      <div class="form-item">
        <label>페이지당 건수</label>
        <select name="size">
          <option value="10" ${pageDTO.size eq 10 ? 'selected' : ''}>10개</option>
          <option value="20" ${pageDTO.size eq 20 ? 'selected' : ''}>20개</option>
          <option value="50" ${pageDTO.size eq 50 ? 'selected' : ''}>50개</option>
        </select>
      </div>

      <div class="form-item">
        <label>신고 시작일</label>
        <input type="date" name="startDate" value="${pageDTO.startDate}">
      </div>

      <div class="form-item">
        <label>신고 종료일</label>
        <input type="date" name="endDate" value="${pageDTO.endDate}">
      </div>

      <div class="form-item" style="justify-content: flex-end;">
        <label>&nbsp;</label>
        <div class="btn-row">
          <button type="submit" class="btn btn-primary">조회</button>
          <a href="${ctx}/broker/status/search.do" class="btn btn-secondary">초기화</a>
        </div>
      </div>
    </div>
  </form>

  <table class="data-table">
    <thead>
      <tr>
        <th>통관의뢰번호</th>
        <th>화주</th>
        <th>유형</th>
        <th>품목</th>
        <th>신고일</th>
        <th>상태</th>
        <th>세관</th>
        <th>처리</th>
      </tr>
    </thead>

    <tbody>
      <c:choose>
        <c:when test="${empty declareList}">
          <tr>
            <td colspan="8" style="text-align:center;padding:30px;color:#94a3b8;">
              조회된 수입신고서가 없습니다.
            </td>
          </tr>
        </c:when>

        <c:otherwise>
          <c:forEach var="row" items="${declareList}">
            <tr>
              <td class="td-id">${row.IDIRNO}</td>
              <td>${row.IDIMPRNM}</td>
              <td>수입신고</td>
              <td>
                ${row.MAINITEMNM}
                <c:if test="${row.ITEMCNT gt 1}">
                  외 ${row.ITEMCNT - 1}건
                </c:if>
              </td>
              <td class="td-muted">${row.IDDCLRDTSTR}</td>
              <td>
                <span class="badge badge-rev">${row.IDSTATUSNM}</span>
              </td>
              <td>${row.ARRVPORTNM}</td>
              <td>
                <a class="mini mini-view"
                   href="${ctx}/broker/status/detail.do?idIrNo=${row.IDIRNO}&page=${pageDTO.page}&size=${pageDTO.size}&keyword=${pageDTO.keyword}&searchType=${pageDTO.searchType}&statusCd=${pageDTO.statusCd}&startDate=${pageDTO.startDate}&endDate=${pageDTO.endDate}">
                  상세
                </a>
              </td>
            </tr>
          </c:forEach>
        </c:otherwise>
      </c:choose>
    </tbody>
  </table>

  <!-- 통합조회 페이지네이션 -->
  <div class="pagination">
    <c:url var="firstUrl" value="/broker/status/search.do">
      <c:param name="page" value="1"/>
      <c:param name="size" value="${pageDTO.size}"/>
      <c:param name="keyword" value="${pageDTO.keyword}"/>
      <c:param name="searchType" value="${pageDTO.searchType}"/>
      <c:param name="statusCd" value="${pageDTO.statusCd}"/>
      <c:param name="startDate" value="${pageDTO.startDate}"/>
      <c:param name="endDate" value="${pageDTO.endDate}"/>
    </c:url>

    <c:url var="prevUrl" value="/broker/status/search.do">
      <c:param name="page" value="${pageDTO.startPage - 1}"/>
      <c:param name="size" value="${pageDTO.size}"/>
      <c:param name="keyword" value="${pageDTO.keyword}"/>
      <c:param name="searchType" value="${pageDTO.searchType}"/>
      <c:param name="statusCd" value="${pageDTO.statusCd}"/>
      <c:param name="startDate" value="${pageDTO.startDate}"/>
      <c:param name="endDate" value="${pageDTO.endDate}"/>
    </c:url>

    <c:choose>
      <c:when test="${pageDTO.prev}">
        <a class="page-btn" title="처음" href="${firstUrl}">«</a>
        <a class="page-btn" title="이전" href="${prevUrl}">‹</a>
      </c:when>
      <c:otherwise>
        <span class="page-btn disabled" title="처음">«</span>
        <span class="page-btn disabled" title="이전">‹</span>
      </c:otherwise>
    </c:choose>

    <c:forEach var="p" begin="${pageDTO.startPage}" end="${pageDTO.endPage}">
      <c:url var="pageUrl" value="/broker/status/search.do">
        <c:param name="page" value="${p}"/>
        <c:param name="size" value="${pageDTO.size}"/>
        <c:param name="keyword" value="${pageDTO.keyword}"/>
        <c:param name="searchType" value="${pageDTO.searchType}"/>
        <c:param name="statusCd" value="${pageDTO.statusCd}"/>
        <c:param name="startDate" value="${pageDTO.startDate}"/>
        <c:param name="endDate" value="${pageDTO.endDate}"/>
      </c:url>

      <c:choose>
        <c:when test="${p eq pageDTO.page}">
          <span class="page-btn active">${p}</span>
        </c:when>
        <c:otherwise>
          <a class="page-btn" href="${pageUrl}">${p}</a>
        </c:otherwise>
      </c:choose>
    </c:forEach>

    <c:url var="nextUrl" value="/broker/status/search.do">
      <c:param name="page" value="${pageDTO.endPage + 1}"/>
      <c:param name="size" value="${pageDTO.size}"/>
      <c:param name="keyword" value="${pageDTO.keyword}"/>
      <c:param name="searchType" value="${pageDTO.searchType}"/>
      <c:param name="statusCd" value="${pageDTO.statusCd}"/>
      <c:param name="startDate" value="${pageDTO.startDate}"/>
      <c:param name="endDate" value="${pageDTO.endDate}"/>
    </c:url>

    <c:url var="lastUrl" value="/broker/status/search.do">
      <c:param name="page" value="${pageDTO.totalPage}"/>
      <c:param name="size" value="${pageDTO.size}"/>
      <c:param name="keyword" value="${pageDTO.keyword}"/>
      <c:param name="searchType" value="${pageDTO.searchType}"/>
      <c:param name="statusCd" value="${pageDTO.statusCd}"/>
      <c:param name="startDate" value="${pageDTO.startDate}"/>
      <c:param name="endDate" value="${pageDTO.endDate}"/>
    </c:url>

    <c:choose>
      <c:when test="${pageDTO.next}">
        <a class="page-btn" title="다음" href="${nextUrl}">›</a>
        <a class="page-btn" title="마지막" href="${lastUrl}">»</a>
      </c:when>
      <c:otherwise>
        <span class="page-btn disabled" title="다음">›</span>
        <span class="page-btn disabled" title="마지막">»</span>
      </c:otherwise>
    </c:choose>

    <span class="page-info">
      ${pageDTO.page} / ${pageDTO.totalPage} 페이지 · 총 ${pageDTO.totalCount}건
    </span>
  </div>

</c:if>
            
            
			<c:if test="${activeSub eq 'search' and mode eq 'detail'}">
			  <div id="st-detail-db" style="margin-top:24px;border-top:2px solid #cbd5e1;padding-top:20px">
			
			    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding:12px 16px;background:linear-gradient(135deg,#ecf4ff,#dae2fd);border-left:4px solid #565e74">
			      <div>
			        <div style="font-size:10px;font-weight:800;color:#565e74;letter-spacing:1px">
			          IMPORT DECLARATION DETAIL
			        </div>
			        <div style="display:flex;gap:12px;align-items:center;margin-top:4px">
			          <h3 style="font-size:16px;font-weight:900;color:#203444;margin:0">수입신고서 상세</h3>
			          <span style="font-size:11px;color:#697d8f;font-family:monospace">${detail.IDIRNO}</span>
			        </div>
			      </div>
			
			      <a class="btn btn-outline" style="padding:6px 10px;font-size:11px"
			         href="${ctx}/broker/status/search.do?page=${pageDTO.page}&size=${pageDTO.size}&keyword=${pageDTO.keyword}&searchType=${pageDTO.searchType}&statusCd=${pageDTO.statusCd}&startDate=${pageDTO.startDate}&endDate=${pageDTO.endDate}">
			        목록
			      </a>
			    </div>
			
			    <!-- 기본 신고 정보 -->
			    <div style="border-left:3px solid #565e74;padding-left:12px;margin-bottom:16px">
			      <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:10px">■ 기본 신고 정보</h4>
			
			      <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr">
			        <div class="form-item">
			          <label>통관의뢰번호</label>
			          <input type="text" value="${detail.IDIRNO}" readonly style="background:#f8fafc">
			        </div>
			
			        <div class="form-item">
			          <label>신고서 상태</label>
			          <input type="text" value="${detail.IDSTATUSCD}" readonly style="background:#f8fafc">
			        </div>
			
			        <div class="form-item">
			          <label>신고일시</label>
			          <input type="text" value="${detail.IDDCLRDTSTR}" readonly style="background:#f8fafc">
			        </div>
			
			        <div class="form-item">
			          <label>수입자</label>
			          <input type="text" value="${detail.IDIMPRNM}" readonly style="background:#f8fafc">
			        </div>
			
			        <div class="form-item">
			          <label>통관고유부호</label>
			          <input type="text" value="${detail.IDIMPRCLNCCD}" readonly style="background:#f8fafc">
			        </div>
			
			        <div class="form-item">
			          <label>B/L 번호</label>
			          <input type="text" value="${detail.IRBLAWBNO}" readonly style="background:#f8fafc">
			        </div>
			
			        <div class="form-item">
			          <label>도착항</label>
			          <input type="text" value="${detail.ARRVPORTNM}" readonly style="background:#f8fafc">
			        </div>
			
			        <div class="form-item">
			          <label>총중량</label>
			          <input type="text" value="${detail.IDTOTWT}" readonly style="background:#f8fafc">
			        </div>
			
			        <div class="form-item">
			          <label>총세액</label>
			          <input type="text" value="${detail.IDTOTTAXAMT}" readonly style="background:#f8fafc">
			        </div>
			      </div>
			    </div>
			
			    <!-- 란사항 정보 -->
			    <div style="border-left:3px solid #506076;padding-left:12px;margin-bottom:16px">
			      <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:10px">■ 란사항별 진행상태</h4>
			
			      <table class="data-table">
			        <thead>
			          <tr>
			            <th>란번호</th>
			            <th>HS코드</th>
			            <th>신고품명</th>
			            <th>거래품명</th>
			            <th>수량</th>
			            <th>과세가격</th>
			            <th>란상태</th>
			            <th>처리</th>
			          </tr>
			        </thead>
			
			        <tbody>
			          <c:choose>
			            <c:when test="${empty items}">
			              <tr>
			                <td colspan="8" style="text-align:center;padding:24px;color:#94a3b8;">
			                  등록된 란사항이 없습니다.
			                </td>
			              </tr>
			            </c:when>
			
			            <c:otherwise>
			              <c:forEach var="item" items="${items}">
			                <tr>
			                  <td class="td-id">${item.IDISN}</td>
			                  <td>${item.IDIHSCD}</td>
			                  <td>${item.IDIDCLRGDSNM}</td>
			                  <td>${item.IDITRDNGGDSNM}</td>
			                  <td>${item.IDIQTY} ${item.IDIQTYUNITCD}</td>
			                  <td>${item.IDITAXTPRCKRW}</td>
			                  <td>
			                    <c:choose>
								  <c:when test="${item.IDISTATUSCD eq 'ITEM_DCLR'}">
								    <span class="item-status-badge item-dclr">품목 신고</span>
								  </c:when>
								  <c:when test="${item.IDISTATUSCD eq 'ITEM_REVIEW'}">
								    <span class="item-status-badge item-review">심사중</span>
								  </c:when>
								  <c:when test="${item.IDISTATUSCD eq 'ITEM_SUPP_REQ'}">
								    <span class="item-status-badge item-supp-req">보완요청</span>
								  </c:when>
								  <c:when test="${item.IDISTATUSCD eq 'ITEM_SUPP_SUB'}">
								    <span class="item-status-badge item-supp-sub">보완제출</span>
								  </c:when>
								  <c:when test="${item.IDISTATUSCD eq 'ITEM_ACPT'}">
								    <span class="item-status-badge item-acpt">수리</span>
								  </c:when>
								  <c:when test="${item.IDISTATUSCD eq 'ITEM_REJ'}">
								    <span class="item-status-badge item-rej">반려</span>
								  </c:when>
								  <c:otherwise>
								    <span class="item-status-badge item-unknown">${item.IDISTATUSCD}</span>
								  </c:otherwise>
								</c:choose>
			                  </td>
			
			                  <!-- 여기 들어간 게 네가 말한 12번 버튼 위치 -->
			                  <td>
			                    <c:choose>
			                      <c:when test="${item.IDISTATUSCD eq 'ITEM_DCLR'}">
									  <span class="action-muted">버튼 없음</span>
									</c:when>
			
			                      <c:when test="${item.IDISTATUSCD eq 'ITEM_REVIEW'}">
									  <span class="action-muted">심사중</span>
									</c:when>
			
			                      <c:when test="${item.IDISTATUSCD eq 'ITEM_SUPP_REQ'}">
			                        <a class="item-action-btn"
									   href="${ctx}/broker/status/item/suppForm.do?idIrNo=${item.IDIIRNO}&idiSn=${item.IDISN}&page=${pageDTO.page}&size=${pageDTO.size}&keyword=${pageDTO.keyword}&searchType=${pageDTO.searchType}&statusCd=${pageDTO.statusCd}&startDate=${pageDTO.startDate}&endDate=${pageDTO.endDate}">
									  보완수정
									</a>
			                      </c:when>
			
			                      <c:when test="${item.IDISTATUSCD eq 'ITEM_SUPP_SUB'}">
									  <span class="action-muted">보완제출 완료</span>
									</c:when>
												
			                      <c:when test="${item.IDISTATUSCD eq 'ITEM_ACPT'}">
									  <span class="action-muted">수리 완료</span>
									</c:when>
			
			                     <c:when test="${item.IDISTATUSCD eq 'ITEM_REJ'}">
								  <span class="action-muted action-reject">반려</span>
								</c:when>	
			
			                      <c:otherwise>
			                        <span class="td-muted">-</span>
			                      </c:otherwise>
			                    </c:choose>
			                  </td>
			                </tr>
			              </c:forEach>
			            </c:otherwise>
			          </c:choose>
			        </tbody>
			      </table>
			    </div>
			
			    <!-- 모델/규격 정보 -->
			    <div style="border-left:3px solid #9f403d;padding-left:12px;margin-bottom:16px">
			      <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:10px">■ 모델/규격 정보</h4>
			
			      <table class="data-table">
			        <thead>
			          <tr>
			            <th>소속 란번호</th>
			            <th>규격번호</th>
			            <th>모델/규격명</th>
			            <th>수량</th>
			            <th>단가</th>
			            <th>금액</th>
			          </tr>
			        </thead>
			
			        <tbody>
			          <c:choose>
			            <c:when test="${empty mdlspecs}">
			              <tr>
			                <td colspan="6" style="text-align:center;padding:24px;color:#94a3b8;">
			                  등록된 모델/규격 정보가 없습니다.
			                </td>
			              </tr>
			            </c:when>
			
			            <c:otherwise>
			              <c:forEach var="m" items="${mdlspecs}">
			                <tr>
			                  <td class="td-id">${m.IDIMSN}</td>
			                  <td>${m.IDIMMDLSPECNO}</td>
			                  <td>${m.IDIMMDLSPECNM}</td>
			                  <td>${m.IDIMQTY1} ${m.IDIMQTY1UNITCD}</td>
			                  <td>${m.IDIMUNITPRC}</td>
			                  <td>${m.IDIMAMT}</td>
			                </tr>
			              </c:forEach>
			            </c:otherwise>
			          </c:choose>
			        </tbody>
			      </table>
			    </div>
			  </div>
			</c:if>

			<c:if test="${activeSub eq 'search' and mode eq 'suppForm'}">
			  <div id="st-supp-form" style="margin-top:24px;border-top:2px solid #cbd5e1;padding-top:20px">
			
			    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding:12px 16px;background:linear-gradient(135deg,#fff7ed,#ffedd5);border-left:4px solid #f97316">
			      <div>
			        <div style="font-size:10px;font-weight:800;color:#c2410c;letter-spacing:1px">
			          SUPPLEMENT EDIT
			        </div>
			        <div style="display:flex;gap:12px;align-items:center;margin-top:4px">
			          <h3 style="font-size:16px;font-weight:900;color:#203444;margin:0">란사항 보완수정</h3>
			          <span style="font-size:11px;color:#697d8f;font-family:monospace">
			            ${suppItem.IDIIRNO} / 란번호 ${suppItem.IDISN}
			          </span>
			        </div>
			      </div>
			
			      <a class="btn btn-outline" style="padding:6px 10px;font-size:11px"
			         href="${ctx}/broker/status/detail.do?idIrNo=${suppItem.IDIIRNO}&page=${pageDTO.page}&size=${pageDTO.size}&keyword=${pageDTO.keyword}&searchType=${pageDTO.searchType}&statusCd=${pageDTO.statusCd}&startDate=${pageDTO.startDate}&endDate=${pageDTO.endDate}">
			        뒤로
			      </a>
			    </div>
			
			    <form method="post" action="${ctx}/broker/status/item/suppSubmit.do">
			    <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}">
			    
			      <input type="hidden" name="idIrNo" value="${suppItem.IDIIRNO}">
			      <input type="hidden" name="idiSn" value="${suppItem.IDISN}">
			
			      <!-- 란사항 수정 -->
			      <div style="border-left:3px solid #f97316;padding-left:12px;margin-bottom:18px">
			        <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:10px">■ 란사항 수정</h4>
			
			        <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr">
									
			          <div class="form-item">
			            <label>HS코드</label>
			            <input name="idiHsCd" value="${suppItem.IDIHSCD}" placeholder="HS코드">
			          </div>
			
			          <div class="form-item">
			            <label>신고품명</label>
			            <input name="idiDclrGdsnm" value="${suppItem.IDIDCLRGDSNM}" placeholder="신고품명">
			          </div>
			
			          <div class="form-item">
			            <label>거래품명</label>
			            <input name="idiTrdngGdsnm" value="${suppItem.IDITRDNGGDSNM}" placeholder="거래품명">
			          </div>
			
			          <div class="form-item">
			            <label>상표명</label>
			            <input name="idiTrdmkNm" value="${suppItem.IDITRDMKNM}" placeholder="상표명">
			          </div>
			
			          <div class="form-item">
			            <label>수량</label>
			            <input name="idiQty" value="${suppItem.IDIQTY}" placeholder="수량">
			          </div>
			
			          <div class="form-item">
			            <label>수량단위</label>
			            <input name="idiQtyUnitCd" value="${suppItem.IDIQTYUNITCD}" placeholder="EA, KG 등">
			          </div>
			
			          <div class="form-item">
			            <label>순중량</label>
			            <input name="idiNetWt" value="${suppItem.IDINETWT}" placeholder="순중량">
			          </div>
			
			          <div class="form-item">
			            <label>과세가격 KRW</label>
			            <input name="idiTaxtPrcKrw" value="${suppItem.IDITAXTPRCKRW}" placeholder="과세가격">
			          </div>
			
			          <div class="form-item">
			            <label>원산지국</label>
			            <input name="idiOrgnCntryCd" value="${suppItem.IDIORGNCNTRYCD}" placeholder="KR, US 등">
			          </div>
			        </div>
			      </div>
			
			      <!-- 모델/규격 수정 -->
			      <div style="border-left:3px solid #9f403d;padding-left:12px;margin-bottom:18px">
			        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
			          <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin:0">■ 모델/규격 수정</h4>
			          <button type="button" class="mini mini-accept" onclick="addSuppMdlspecRow()">모델 추가</button>
			        </div>
			
			        <table class="data-table" id="supp-mdlspec-table">
			          <thead>
			            <tr>
			              <th>규격번호</th>
			              <th>모델/규격명</th>
			              <th>수량</th>
			              <th>단위</th>
			              <th>단가</th>
			              <th>금액</th>
			              <th>삭제</th>
			            </tr>
			          </thead>
			
			          <tbody id="supp-mdlspec-body">
			            <c:choose>
			              <c:when test="${empty suppMdlspecs}">
			                <tr>
			                  <td><input name="idimMdlspecNo" placeholder="규격번호"></td>
			                  <td><input name="idimMdlspecNm" placeholder="모델/규격명"></td>
			                  <td><input name="idimQty1" placeholder="수량"></td>
			                  <td><input name="idimQty1UnitCd" placeholder="EA"></td>
			                  <td><input name="idimUnitPrc" placeholder="단가"></td>
			                  <td><input name="idimAmt" placeholder="금액"></td>
			                  <td><button type="button" class="mini mini-reject" onclick="removeSuppMdlspecRow(this)">삭제</button></td>
			                </tr>
			              </c:when>
			
			              <c:otherwise>
			                <c:forEach var="m" items="${suppMdlspecs}">
			                  <tr>
			                    <td><input name="idimMdlspecNo" value="${m.IDIMMDLSPECNO}" placeholder="규격번호"></td>
			                    <td><input name="idimMdlspecNm" value="${m.IDIMMDLSPECNM}" placeholder="모델/규격명"></td>
			                    <td><input name="idimQty1" value="${m.IDIMQTY1}" placeholder="수량"></td>
			                    <td><input name="idimQty1UnitCd" value="${m.IDIMQTY1UNITCD}" placeholder="EA"></td>
			                    <td><input name="idimUnitPrc" value="${m.IDIMUNITPRC}" placeholder="단가"></td>
			                    <td><input name="idimAmt" value="${m.IDIMAMT}" placeholder="금액"></td>
			                    <td><button type="button" class="mini mini-reject" onclick="removeSuppMdlspecRow(this)">삭제</button></td>
			                  </tr>
			                </c:forEach>
			              </c:otherwise>
			            </c:choose>
			          </tbody>
			        </table>
			      </div>
			
			      <div class="btn-row" style="justify-content:flex-end;margin-top:16px">
			        <a class="btn btn-secondary"
						   href="${ctx}/broker/status/detail.do?idIrNo=${suppItem.IDIIRNO}&page=${pageDTO.page}&size=${pageDTO.size}&keyword=${pageDTO.keyword}&searchType=${pageDTO.searchType}&statusCd=${pageDTO.statusCd}&startDate=${pageDTO.startDate}&endDate=${pageDTO.endDate}">
						  취소
						</a>
			        <button type="submit" class="btn btn-primary"
			                onclick="return confirm('보완수정 내용을 제출하시겠습니까? 제출 후 상태가 보완제출로 변경됩니다.');">
			          보완제출
			        </button>
			      </div>
			    </form>
			  </div>
			</c:if>

          
          
          
          
          
          <!-- ===== 세금납부/화주청구 관리 ===== -->
			<div id="st-tax" style="display:${activeSub eq 'tax' ? 'block' : 'none'}">
			    <h2><span class="material-symbols-outlined">payments</span> 세금납부 · 화주청구 관리</h2>
			
			    <c:if test="${not empty msg}">
			        <div style="margin:10px 0;padding:10px 12px;background:#ecfdf5;border:1px solid #bbf7d0;color:#166534;font-size:12px;font-weight:700">
			            ${msg}
			        </div>
			    </c:if>
			
			    <form method="get" action="${ctx}/broker/status/tax.do">
				  <div class="form-grid" style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px 12px;align-items:end">
				      <div class="form-item">
				          <label>통관의뢰번호</label>
				          <input type="text" name="keyword" value="${pageDTO.keyword}" placeholder="번호 입력">
				      </div>
				
				      <div class="form-item">
				          <label>화주</label>
				          <input type="text" placeholder="화주명">
				      </div>
				
				      <div class="form-item">
				          <label>세금납부상태</label>
				          <select disabled>
				              <option>전체</option>
				              <option>세금납부대기</option>
				              <option>세금납부완료</option>
				          </select>
				      </div>
				
				      <div class="form-item">
				          <label>화주청구상태</label>
				          <select name="statusCd">
				              <option value="" <c:if test="${empty pageDTO.statusCd}">selected</c:if>>전체</option>
				              <option value="UNBILLED" <c:if test="${pageDTO.statusCd eq 'UNBILLED'}">selected</c:if>>미청구</option>
				              <option value="CSTM_TAX_REQ" <c:if test="${pageDTO.statusCd eq 'CSTM_TAX_REQ'}">selected</c:if>>청구완료</option>
				              <option value="CSTM_TAX_PAID" <c:if test="${pageDTO.statusCd eq 'CSTM_TAX_PAID'}">selected</c:if>>결제완료</option>
				              <option value="CSTM_DONE" <c:if test="${pageDTO.statusCd eq 'CSTM_DONE'}">selected</c:if>>완료</option>
				          </select>
				      </div>
				
				      <div class="form-item">
				          <label>&nbsp;</label>
				          <div class="btn-row">
				              <button class="btn btn-primary" type="submit">조회</button>
				              <a class="btn btn-secondary" href="${ctx}/broker/status/tax.do">초기화</a>
				          </div>
				      </div>
				  </div>
				</form>
			
			    <table class="data-table">
			        <thead>
			        <tr>
			            <th>수입통관의뢰번호</th>
			            <th>화주</th>
			            <th>대표품목</th>
			            <th>신고금액</th>
			            <th>세금합계</th>
			            <th>관세사 수수료</th>
			            <th>수수료 부가세</th>
			            <th>최종청구금액</th>
			            <th>세금상태</th>
			            <th>청구상태</th>
			            <th>처리</th>
			        </tr>
			        </thead>
			        <tbody>
			        <c:choose>
			            <c:when test="${empty taxChargeList}">
			                <tr>
			                    <td colspan="11" style="text-align:center;padding:34px;color:#94a3b8">
			                        조회된 세금/청구 대상 건이 없습니다.
			                    </td>
			                </tr>
			            </c:when>
			
			            <c:otherwise>
			                <c:forEach var="row" items="${taxChargeList}">
			                    <tr>
			                        <td class="td-id">${row.IRNO}</td>
			
			                        <td>
			                            <c:choose>
			                                <c:when test="${not empty row.OWRNM}">
			                                    ${row.OWRNM}
			                                </c:when>
			                                <c:otherwise>
			                                    ${row.OWRID}
			                                </c:otherwise>
			                            </c:choose>
			                        </td>
			
			                        <td>${row.REPRITEMNM}</td>
			
			                        <td>
			                            <fmt:formatNumber value="${row.DCLRAMT}" pattern="#,##0"/>원
			                        </td>
			
			                        <td style="font-weight:800;color:#9f403d">
			                            <fmt:formatNumber value="${row.TAXAMT}" pattern="#,##0"/>원
			                        </td>
			
			                       <td>
									  <c:choose>
									    <c:when test="${empty row.BCNO}">
									      -
									    </c:when>
									    <c:otherwise>
									      <fmt:formatNumber value="${row.BROKERFEEAMT}" pattern="#,##0"/>원
									    </c:otherwise>
									  </c:choose>
									</td>
			
			                        <td>
			                            <c:choose>
			                                <c:when test="${empty row.BCNO}">
			                                    -
			                                </c:when>
			                                <c:otherwise>
			                                    <fmt:formatNumber value="${row.FEEVATAMT}" pattern="#,##0"/>원
			                                </c:otherwise>
			                            </c:choose>
			                        </td>
			
			                        <td style="font-weight:800">
			                            <c:choose>
			                                <c:when test="${empty row.BCNO}">
			                                    -
			                                </c:when>
			                                <c:otherwise>
			                                    <fmt:formatNumber value="${row.TOTALAMT}" pattern="#,##0"/>원
			                                </c:otherwise>
			                            </c:choose>
			                        </td>
			
			                        <td>
			                            <c:choose>
			                                <c:when test="${row.TAXPAYSTATUSCD eq 'TAX_PAID' or row.TAXPAYDONEYN eq 'Y'}">
			                                    <span class="pay-badge paid">
			                                        <span class="material-symbols-outlined">check_circle</span>세금납부완료
			                                    </span>
			                                </c:when>
			                                <c:when test="${row.TAXPAYSTATUSCD eq 'TAX_OVERDUE'}">
			                                    <span class="pay-badge urgent">
			                                        <span class="material-symbols-outlined">warning</span>기한초과
			                                    </span>
			                                </c:when>
			                                <c:otherwise>
			                                    <span class="pay-badge unpaid">세금납부대기</span>
			                                </c:otherwise>
			                            </c:choose>
			                        </td>
			
			                        <td>
									  <c:choose>
									    <c:when test="${row.CHARGESTATUSNM eq '미청구'}">
									      <span class="charge-state-pill charge-state-unbilled">
									        <span class="material-symbols-outlined">pending</span>
									        미청구
									      </span>
									    </c:when>
									
									    <c:when test="${row.CHARGESTATUSNM eq '청구완료'}">
									      <span class="charge-state-pill charge-state-billed">
									        <span class="material-symbols-outlined">request_quote</span>
									        청구완료
									      </span>
									    </c:when>
									
									    <c:when test="${row.CHARGESTATUSNM eq '결제완료'}">
									      <span class="charge-state-pill charge-state-paid">
									        <span class="material-symbols-outlined">paid</span>
									        결제완료
									      </span>
									    </c:when>
									
									    <c:when test="${row.CHARGESTATUSNM eq '완료'}">
									      <span class="charge-state-pill charge-state-done">
									        <span class="material-symbols-outlined">done_all</span>
									        완료
									      </span>
									    </c:when>
									
									    <c:otherwise>
									      <span class="charge-state-pill charge-state-cancel">
									        ${row.CHARGESTATUSNM}
									      </span>
									    </c:otherwise>
									  </c:choose>
									</td>
			
			                        <td>
			                            <c:choose>
			                                <c:when test="${empty row.BCNO}">
			                                    <form method="post" action="${ctx}/broker/status/charge/create.do" style="display:inline">
			                                        <c:if test="${not empty _csrf}">
			                                            <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}">
			                                        </c:if>
			                                        <input type="hidden" name="irNo" value="${row.IRNO}">
			                                        <input type="hidden" name="ctNo" value="${row.CTNO}">
			                                        <button type="submit"
			                                                class="mini"
			                                                style="background:#565e74;color:#fff"
			                                                onclick="return confirm('화주에게 세금과 관세사 수수료를 청구하시겠습니까?')">
			                                            화주 청구 생성
			                                        </button>
			                                    </form>
			                                </c:when>
			
			                                <c:otherwise>
			                                    <button class="mini mini-view"
												        type="button"
												        data-bc-no="${row.BCNO}"
												        data-ir-no="${row.IRNO}"
												        data-ir-status-cd="${row.IRSTATUSCD}"
												        data-owr-nm="${row.OWRNM}"
												        data-repr-item-nm="${row.REPRITEMNM}"
												        data-policy-nm="${row.BFPPOLICYNM}"
												        data-dclr-amt="${row.DCLRAMT}"
												        data-tax-amt="${row.TAXAMT}"
												        data-base-fee="${row.BFPBASEFEEAMT}"
												        data-rate="${row.BFPRATE}"
												        data-min-fee="${row.BFPMINFEEAMT}"
												        data-max-fee="${row.BFPMAXFEEAMT}"
												        data-broker-fee="${row.BROKERFEEAMT}"
												        data-fee-vat="${row.FEEVATAMT}"
												        data-total-amt="${row.TOTALAMT}"
												        onclick="openChargeCalcModal(this)">
												    계산상세
												</button>
			                                </c:otherwise>
			                            </c:choose>
			                        </td>
			                    </tr>
			                </c:forEach>
			            </c:otherwise>
			        </c:choose>
			        </tbody>
			    </table>
			
			    <div class="pagination">
			        <button class="page-btn" title="처음" disabled>«</button>
			        <button class="page-btn" title="이전" disabled>‹</button>
			        <button class="page-btn active">1</button>
			        <button class="page-btn" title="다음" disabled>›</button>
			        <button class="page-btn" title="마지막" disabled>»</button>
			    </div>
			</div>
<!-- ===== 화주 청구 수수료 계산 상세 모달 ===== -->
		<!-- ===== 화주 청구 수수료 계산 상세 모달 ===== -->
<div id="modal-charge-calc" class="modal-bg">
  <div class="modal-box charge-calc-modal">
    <button type="button" class="modal-close" onclick="hideModal('charge-calc')">×</button>

    <h3>
      <span class="material-symbols-outlined">calculate</span>
      수수료 계산 상세
    </h3>

    <div class="charge-calc-body">
      <div class="charge-calc-summary">
        <div>
          <span class="calc-label">청구번호</span>
          <strong id="ccm-bc-no">-</strong>
        </div>
        <div>
          <span class="calc-label">통관의뢰번호</span>
          <strong id="ccm-ir-no">-</strong>
        </div>
        <div>
          <span class="calc-label">화주</span>
          <strong id="ccm-owr-nm">-</strong>
        </div>
        <div>
          <span class="calc-label">대표품목</span>
          <strong id="ccm-item-nm">-</strong>
        </div>
      </div>

      <div class="charge-calc-section">
        <h4>적용 수수료 정책</h4>
        <table class="calc-table">
          <tbody>
            <tr>
              <th>정책명</th>
              <td id="ccm-policy-nm">-</td>
            </tr>
            <tr>
              <th>신고금액 구간</th>
              <td id="ccm-policy-range">-</td>
            </tr>
            <tr>
              <th>기본수수료</th>
              <td id="ccm-base-fee">-</td>
            </tr>
            <tr>
              <th>수수료율</th>
              <td id="ccm-rate">-</td>
            </tr>
            <tr>
              <th>최소/최대 수수료</th>
              <td id="ccm-min-max-fee">-</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="charge-calc-section">
        <h4>계산 결과</h4>
        <table class="calc-table result">
          <tbody>
            <tr>
              <th>신고금액</th>
              <td id="ccm-dclr-amt">-</td>
            </tr>
            <tr>
              <th>세금합계</th>
              <td id="ccm-tax-amt">-</td>
            </tr>
            <tr>
              <th>관세사 수수료</th>
              <td id="ccm-broker-fee">-</td>
            </tr>
            <tr>
              <th>수수료 부가세</th>
              <td id="ccm-fee-vat">-</td>
            </tr>
            <tr class="total-row">
              <th>최종 청구금액</th>
              <td id="ccm-total-amt">-</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="charge-calc-formula">
        계산식: 최종 청구금액 = 세금합계 + 관세사 수수료 + 수수료 부가세
      </div>
    </div>

    <div class="charge-calc-footer">
      <button type="button" class="btn btn-secondary" onclick="hideModal('charge-calc')">닫기</button>
      

      <form method="post" action="${ctx}/broker/status/charge/confirmDone.do" style="display:inline-flex;margin:0;">
        <c:if test="${not empty _csrf}">
          <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}">
        </c:if>
        <input type="hidden" name="irNo" id="ccm-ir-no-hidden">
        <button type="submit"
                class="btn btn-primary"
                id="ccm-done-btn"
                style="display:none"
                onclick="return confirm('결제완료 건을 최종 완료 처리하시겠습니까?');">
          확인
        </button>
      </form>
    </div>
  </div>
</div>

		

            <!-- ===== 신고필증 관리 ===== -->
            <div id="st-cert" style="display:${activeSub eq 'cert' ? 'block' : 'none'}">
            	  <h2><span class="material-symbols-outlined">verified</span> 신고필증 관리</h2>
            	<form method="get" action="${ctx}/broker/status/cert.do">
		  <div class="form-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px 12px;align-items:end">
		
		    <div class="form-item">
		      <label>검색어</label>
		      <input type="text"
		             name="keyword"
		             value="${keyword}"
		             placeholder="필증번호 / 신고번호 / 화주 / 품목">
		    </div>
		
		    <div class="form-item">
		      <label>구분</label>
		      <select name="type">
		        <option value="ALL" ${empty type or type eq 'ALL' ? 'selected' : ''}>전체</option>
		        <option value="IMPORT" ${type eq 'IMPORT' ? 'selected' : ''}>수입</option>
		        <option value="EXPORT" ${type eq 'EXPORT' ? 'selected' : ''}>수출</option>
		      </select>
		    </div>
		
		    <div class="form-item">
		      <label>필증상태</label>
		      <select name="status">
		        <option value="ALL" ${empty status or status eq 'ALL' ? 'selected' : ''}>전체</option>
		        <option value="ISSUED" ${status eq 'ISSUED' ? 'selected' : ''}>발급완료</option>
		        <option value="REISSUED" ${status eq 'REISSUED' ? 'selected' : ''}>재발급</option>
		        <option value="CANCELLED" ${status eq 'CANCELLED' ? 'selected' : ''}>취소</option>
		      </select>
		    </div>
		
		    <div class="form-item" style="justify-content:flex-end">
		      <label>&nbsp;</label>
		      <div class="btn-row">
		        <button type="submit" class="btn btn-primary">조회</button>
		        <a class="btn btn-secondary" href="${ctx}/broker/status/cert.do">초기화</a>
		      </div>
		    </div>
		
		  </div>
		</form>
				
              <table class="data-table">
               <thead>
			  <tr>
			    <th>필증번호</th>
			    <th>신고번호</th>
			    <th>구분</th>
			    <th>화주</th>
			    <th>품목</th>
			    <th>발급일자</th>
			    <th>납부상태</th>
			    <th>필증상태</th>
			    <th>처리</th>
			  </tr>
			</thead>
              <tbody>
  <c:choose>
    <c:when test="${empty certList}">
      <tr>
        <td colspan="9" style="text-align:center;padding:30px;color:#94a3b8;">
          조회된 신고필증 정보가 없습니다.
        </td>
      </tr>
    </c:when>

    <c:otherwise>
      <c:forEach var="cert" items="${certList}">
  <tr>
    <td class="td-id">${cert.CINO}</td>
    <td class="td-id">${cert.CIDCLRNO}</td>
    <td>${cert.CIDCLRTYPENM}</td>
    <td>${cert.IDIMPRNM}</td>
    <td>${cert.MAINITEMNM}</td>
    <td class="td-muted">${cert.CIISSUEDTSTR}</td>

    <td>
      <c:choose>
        <c:when test="${cert.CTPAYSTATUSNM eq '납부완료'}">
          <span class="cert-state-pill cert-state-paid">납부완료</span>
        </c:when>
        <c:when test="${cert.CTPAYSTATUSNM eq '분납중'}">
          <span class="cert-state-pill cert-state-partial">분납중</span>
        </c:when>
        <c:when test="${cert.CTPAYSTATUSNM eq '미납'}">
          <span class="cert-state-pill cert-state-unpaid">미납</span>
        </c:when>
        <c:otherwise>
          <span class="cert-state-pill cert-state-check">${cert.CTPAYSTATUSNM}</span>
        </c:otherwise>
      </c:choose>
    </td>

    <td>
      <c:choose>
        <c:when test="${cert.CISTATUSNM eq '발급완료'}">
          <span class="cert-state-pill cert-state-issued">발급완료</span>
        </c:when>
        <c:when test="${cert.CISTATUSNM eq '재발급'}">
          <span class="cert-state-pill cert-state-partial">재발급</span>
        </c:when>
        <c:when test="${cert.CISTATUSNM eq '취소'}">
          <span class="cert-state-pill cert-state-cancel">취소</span>
        </c:when>
        <c:otherwise>
          <span class="cert-state-pill cert-state-check">${cert.CISTATUSNM}</span>
        </c:otherwise>
      </c:choose>
    </td>

    <td>
      <button type="button"
              class="mini mini-view"
              onclick="openCertDetail('${cert.CINO}')">
        상세
      </button>

      <a class="mini"
         href="${ctx}/broker/status/detail.do?idIrNo=${cert.CIDCLRNO}">
        신고서
      </a>
    </td>
  </tr>
</c:forEach> 
    </c:otherwise>
  </c:choose>
</tbody>
                
                
              </table>
              
                          </div>

          


          </div>     <!-- closes st-cert sub-tab content -->
      </div>         <!-- closes pg-status -->
        </div>
        <%@ include file="/WEB-INF/views/broker/common/footer.jsp" %>
    </div>
</div>
<%@ include file="/WEB-INF/views/broker/common/modals.jsp" %>

<script>window.contextPath = '${ctx}';</script>
<script src="${ctx}/resources/js/broker/common.js"></script>
<script src="${ctx}/resources/js/broker/pages/status.js"></script>
</body>
</html>
