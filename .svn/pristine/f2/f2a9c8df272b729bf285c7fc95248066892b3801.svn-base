<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ include file="/WEB-INF/views/officer/common/taglibs.jsp" %>
<%@ taglib uri="http://www.springframework.org/security/tags" prefix="sec" %>

<c:set var="ctx" value="${pageContext.request.contextPath}" />
<c:set var="activeMenu" value="basic" />
<c:set var="activeSub" value="basicScreenList" />

<!DOCTYPE html>
<html lang="ko">
    <head>
        <%@ include file="/WEB-INF/views/officer/header/head.jsp" %>
        <title>TACS · 기본심사목록</title>
        <link rel="stylesheet" href="${ctx}/resources/css/officer/pages/basicScreenList.css">
    </head>

    <body>
        <%@ include file="/WEB-INF/views/officer/header/sidebar.jsp" %>
        <%@ include file="/WEB-INF/views/officer/header/header.jsp" %>

        <main class="main-content basic-screen-main">
            <section class="page-inner">
                <div class="breadcrumb">
                    <span>신고 접수 및 기본심사</span>
                    <span>›</span>
                    <strong>TACS-AD-002</strong>
                </div>

                <h2 class="page-title">기본심사목록</h2>

                <div class="page-banner">
                    <h3>기본심사목록</h3>
                    <p>접수 완료된 신고건의 기본정보, 답변상태, AI위험도를 확인하고 기본심사를 처리합니다.</p>
                </div>

                <form class="search-panel" id="basicSearchForm" method="get" action="${ctx}/officer/basicScreenList.do">
                    <div class="search-title">검색 조건</div>

                    <div class="search-row">
                        <label class="search-label" for="reqNo">신고번호</label>
                        <div class="search-field">
                            <input id="reqNo" name="reqNo" class="form-input input-md" type="text" placeholder="신고번호 입력">
                        </div>
                    </div>

              
                    <div class="search-row">
                        <label class="search-label" for="answerStatus">답변상태</label>
                        <div class="search-field">
                            <select id="answerStatus" name="answerStatus" class="form-select select-sm">
                                <option value="">전체</option>
                                <option value="WAIT">답변대기</option>
                                <option value="ARRIVED">답변도착</option>
                                <option value="DONE">검토완료</option>
                            </select>
                        </div>
                    </div>

                    <div class="search-row">
                        <span class="search-label">신고구분</span>
                        <div class="search-field radio-group">
                            <label><input type="radio" name="declareType" value="" checked> 전체</label>
                            <label><input type="radio" name="declareType" value="IMPORT"> 수입</label>
                            <label><input type="radio" name="declareType" value="EXPORT"> 수출</label>
                        </div>
                    </div>

                    <div class="search-row last-row">
                        <label class="search-label" for="officerName">담당자명</label>
                        <div class="search-field">
                            <%-- 로그인 유저 이름은 서버에서 model로 내려주거나 Security 태그로 표시 --%>
                            <input id="officerName" name="officerName" class="form-input input-sm" type="text"
                                   value="<sec:authentication property='principal.username' />">
                            <button type="submit" class="btn-primary">조회</button>
                            <button type="button" class="btn-secondary" id="btnReset">초기화</button>
                        </div>
                    </div>
                </form>

                <div class="result-header">
                    <div class="result-count">
                        조회목록 <span><c:out value="${totalCount}" default="0" />건</span>
                    </div>
                    <div class="result-actions">
                        <button type="button" class="btn-secondary">엑셀 다운로드</button>
                    </div>
                </div>

                <div class="table-card">
                    <table class="basic-table">
                        <thead>
                            <tr>
                                <th>NO.</th>
                                <th>신고번호</th>
                                <th>수입자명</th>
                                <th>담당자명</th>
                                <th>현재상태</th>
                                <th>답변상태</th>
                                <th>AI위험도</th>
                                <th>상세</th>
                            </tr>
                        </thead>
                        <tbody>
                            <c:choose>
                                <c:when test="${empty list}">
                                    <tr>
                                        <td colspan="8" class="empty-row">조회된 기본심사 건이 없습니다.</td>
                                    </tr>
                                </c:when>

                                <c:otherwise>
                                  <c:forEach var="item" items="${list}">
									    <c:set var="isMine" value="${item.officerId eq loginOfficerId}" />
									
									    <c:choose>
									        <c:when test="${isMine and item.statusCd ne 'DCLR_DONE'}">
									            <c:set var="detailUrl"
									                   value="${ctx}/officer/basicScreenDetail.do?reqNo=${item.reqNo}&mode=edit"/>
									        </c:when>
									
									        <c:otherwise>
									            <c:set var="detailUrl"
									                   value="${ctx}/officer/basicScreenDetail.do?reqNo=${item.reqNo}&mode=readonly"/>
									        </c:otherwise>
									    </c:choose>
									
									    <tr class="clickable-row ${isMine ? 'row-mine' : 'row-others'}"
									        data-url="${detailUrl}">

                                            <%-- NO. --%>
                                            <td>${item.no}</td>

                                            <%-- 신고번호 --%>
                                           <td>
											    <a href="${detailUrl}" class="req-link">
											        <strong>${item.reqNo}</strong>
											    </a>
											</td>

                                            <%-- 수입자(업체)명 --%>
                                            <td>${item.companyName}</td>

                                            <%-- 담당자명 : officerName이 있으면 표시, 없으면 미배정 --%>
                                            <td>
                                                <c:choose>
                                                    <c:when test="${not empty item.officerName}">
                                                        <c:out value="${item.officerName}" />
                                                        <c:if test="${isMine}">
                                                        </c:if>
                                                    </c:when>
                                                    <c:otherwise>
                                                        <span class="done-text">미배정</span>
                                                    </c:otherwise>
                                                </c:choose>
                                            </td>

                                            <%-- 현재상태 --%>
                                            <td>
                                                <c:choose>
                                                    <c:when test="${item.statusCd eq 'DCLR_WAIT'}">
                                                        <span class="status-text status-wait">DCLR_WAIT</span>
                                                    </c:when>
                                                    <c:when test="${item.statusCd eq 'DCLR_REVIEW'}">
                                                        <span class="status-text status-process">DCLR_REVIEW</span>
                                                    </c:when>
                                                    <c:when test="${item.statusCd eq 'DCLR_DONE'}">
                                                        <span class="status-text status-approved">DCLR_DONE</span>
                                                    </c:when>
                                                    <c:otherwise>
                                                        <span class="status-text">${item.statusCd}</span>
                                                    </c:otherwise>
                                                </c:choose>
                                            </td>

                                            <%-- 답변상태 --%>
                                            <td>
                                                <span class="done-text">—</span>
                                            </td>

                                            <%-- AI위험도 --%>
                                            <td>
											    <c:choose>
											
											        <c:when test="${item.riskStatusCd eq 'DONE'}">
											
											            <c:choose>
											
											                <c:when test="${item.riskGradeCd eq 'HIGH'}">
											                    <span class="risk-text high">
											                        ● 고위험 ${item.riskScore}점
											                    </span>
											                </c:when>
											
											                <c:when test="${item.riskGradeCd eq 'MIDDLE'}">
											                    <span class="risk-text middle">
											                        ● 중위험 ${item.riskScore}점
											                    </span>
											                </c:when>
											
											                <c:otherwise>
											                    <span class="risk-text low">
											                        ● 저위험 ${item.riskScore}점
											                    </span>
											                </c:otherwise>
											
											            </c:choose>
											
											        </c:when>
											
											        <c:when test="${item.riskStatusCd eq 'READY'}">
											            <span class="risk-text low">● 분석대기</span>
											        </c:when>
											
											        <c:otherwise>
											            <span class="risk-text low">● 미분석</span>
											        </c:otherwise>
											
											    </c:choose>
											</td>

                                            <%-- 버튼
                                                 - 본인 건 + 미승인  → [검토] edit 모드
                                                 - 본인 건 + 승인완료 → [상세] readonly 모드
                                                 - 타인 건           → [상세] readonly 모드 --%>
                                            <td class="td-detail-action" onclick="event.stopPropagation()">
                                                <c:choose>
                                                    <%-- 타인 건: 상세만 --%>
                                                    <c:when test="${!isMine}">
                                                        <a class="btn-secondary btn-sm"
                                                           href="${ctx}/officer/basicScreenDetail.do?reqNo=${item.reqNo}&mode=readonly">
                                                            상세
                                                        </a>
                                                    </c:when>
                                                    <%-- 본인 건 + 완료: 상세만 --%>
                                                    <c:when test="${isMine and item.statusCd eq 'CSTM_DONE'}">
                                                        <a class="btn-secondary btn-sm"
                                                           href="${ctx}/officer/basicScreenDetail.do?reqNo=${item.reqNo}&mode=readonly">
                                                            상세
                                                        </a>
                                                    </c:when>
                                                    <%-- 본인 건 + 미승인: 검토 --%>
                                                    <c:otherwise>
                                                        <a class="btn-primary btn-sm"
                                                           href="${ctx}/officer/basicScreenDetail.do?reqNo=${item.reqNo}&mode=edit">
                                                            검토
                                                        </a>
                                                    </c:otherwise>
                                                </c:choose>
                                            </td>
                                        </tr>
                                    </c:forEach>
                                </c:otherwise>
                            </c:choose>
                        </tbody>
                    </table>
                </div>           
            </section>
        </main>

        <%@ include file="/WEB-INF/views/officer/footer/footer.jsp" %>
        <%@ include file="/WEB-INF/views/officer/footer/scripts.jsp" %>

        <script defer src="${ctx}/resources/js/officer/pages/basicScreenList.js"></script>
    </body>
</html>
