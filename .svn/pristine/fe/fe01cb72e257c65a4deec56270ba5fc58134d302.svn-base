// loadedCargoList.js - 화물 현황 조회 전용
// 탭/상세 클릭이 다른 스크립트나 DOM 이동 영향으로 죽지 않도록 이벤트 위임 방식으로만 처리한다.
(function () {
  'use strict';

  function text(value) {
    return value !== undefined && value !== null && String(value).trim() ? String(value).trim() : '-';
  }

  function setText(id, value) {
    var el = document.getElementById(id);
    if (el) el.textContent = text(value);
  }

  function escapeHtml(value) {
    return text(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function closest(el, selector) {
    while (el && el.nodeType === 1) {
      if (el.matches && el.matches(selector)) return el;
      el = el.parentElement;
    }
    return null;
  }

  function normalizeType(row) {
    return row.getAttribute('data-cargo-type') || (row.getAttribute('data-type') === 'house' ? '혼재화물' : '적재화물');
  }

  function declareTypeText(row) {
    var v = row.getAttribute('data-declare-type');
    if (v === 'IMPORT') return '수입';
    if (v === 'EXPORT') return '수출';
    return '-';
  }

  function rowData(row, key) {
    return row ? row.getAttribute('data-' + key) : '';
  }

  function mainNoValue(row) {
    if (rowData(row, 'type') === 'house') {
      return rowData(row, 'hbl-no') || rowData(row, 'mbl-no') || rowData(row, 'bl-no');
    }
    return rowData(row, 'bl-no') || rowData(row, 'mbl-no') || rowData(row, 'hbl-no');
  }

  function submitStatusValue(row) {
    var submit = text(rowData(row, 'submit-status'));
    var declare = text(rowData(row, 'declare-status'));
    if (submit !== '-' && declare !== '-') return submit + ' / ' + declare;
    if (submit !== '-') return submit;
    return declare;
  }

  function getMemoKey(row) {
    var type = rowData(row, 'type') || 'loading';
    var keyNo = rowData(row, 'req-no') || rowData(row, 'list-no') || rowData(row, 'bl-no') || rowData(row, 'mbl-no') || row.rowIndex;
    return 'loadedCargoMemo:' + type + ':' + keyNo;
  }

  function getActiveColspan(row) {
    var table = row ? row.closest('table') : null;
    if (!table) return row ? row.children.length || 1 : 1;
    var thCount = table.querySelectorAll('thead th').length;
    return thCount || row.children.length || 1;
  }

  function getPanelHome() {
    return document.querySelector('.loadedCargoList-page .inline-screen-body') || document.body;
  }

  function removeDetailRow() {
    var detailRow = document.getElementById('cargo-detail-inline-row');
    if (detailRow && detailRow.parentNode) detailRow.parentNode.removeChild(detailRow);
  }

  function hideDetail() {
    var panel = document.getElementById('cargo-list-detail-panel');
    if (panel) {
      panel.style.display = 'none';
      getPanelHome().appendChild(panel);
    }

    removeDetailRow();

    document.querySelectorAll('.cargo-click-row').forEach(function (r) {
      r.classList.remove('row-selected');
    });
  }

  function setCargoListTab(key, btn) {
    key = key || 'all-list';

    document.querySelectorAll('[data-tab-group="cargo-list-type"]').forEach(function (b) {
      b.classList.remove('active');
    });

    if (!btn) {
      btn = document.querySelector('[data-tab-group="cargo-list-type"][data-tab-key="' + key + '"]');
    }
    if (btn) btn.classList.add('active');

    document.querySelectorAll('[data-panel-group="cargo-list-type"]').forEach(function (p) {
      p.style.display = p.getAttribute('data-panel-key') === key ? 'block' : 'none';
    });

    hideDetail();
  }

  function createInlineDetailRow(row, panel) {
    removeDetailRow();

    var detailRow = document.createElement('tr');
    detailRow.id = 'cargo-detail-inline-row';
    detailRow.className = 'cargo-detail-inline-row';

    var detailCell = document.createElement('td');
    detailCell.colSpan = getActiveColspan(row);
    detailCell.className = 'cargo-detail-inline-cell';

    detailCell.appendChild(panel);
    detailRow.appendChild(detailCell);
    row.parentNode.insertBefore(detailRow, row.nextSibling);
  }

  function compareResult(left, right) {
    var l = text(left);
    var r = text(right);
    if (l === '-' || r === '-') return '확인필요';
    return l === r ? '일치' : '확인필요';
  }

  function renderCompareRows(row) {
    var body = document.getElementById('cargoCompareBody');
    if (!body) return;

    var rows = [
      { name: '신고번호', declareValue: rowData(row, 'req-no'), listValue: rowData(row, 'req-no') },
      { name: '화주명', declareValue: rowData(row, 'owner-name'), listValue: rowData(row, 'owner-name') },
      { name: '품명', declareValue: rowData(row, 'item-name'), listValue: rowData(row, 'item-name') },
      { name: 'B/L 번호', declareValue: mainNoValue(row), listValue: mainNoValue(row) },
      { name: '물품그룹번호', declareValue: rowData(row, 'goods-group-no'), listValue: rowData(row, 'goods-group-no') },
      { name: '창고 정보', declareValue: '물류 조회값', listValue: rowData(row, 'warehouse-name') }
    ];

    body.innerHTML = rows.map(function (item) {
      var result = compareResult(item.declareValue, item.listValue);
      return '<tr>'
        + '<td>' + escapeHtml(item.name) + '</td>'
        + '<td>' + escapeHtml(item.declareValue) + '</td>'
        + '<td>' + escapeHtml(item.listValue) + '</td>'
        + '<td><span class="compare-result ' + (result === '일치' ? 'is-match' : 'is-check') + '">' + result + '</span></td>'
        + '</tr>';
    }).join('');
  }

  function openCargoDetail(row) {
    var panel = document.getElementById('cargo-list-detail-panel');
    if (!panel || !row) return;

    if (row.classList.contains('row-selected')) {
      hideDetail();
      return;
    }

    document.querySelectorAll('.cargo-click-row').forEach(function (r) {
      r.classList.remove('row-selected');
    });
    row.classList.add('row-selected');

    createInlineDetailRow(row, panel);

    setText('detailType', normalizeType(row));
    setText('detailDeclareType', declareTypeText(row));
    setText('detailReqNo', rowData(row, 'req-no'));
    setText('detailGoodsGroupNo', rowData(row, 'goods-group-no'));
    setText('detailOwnerName', rowData(row, 'owner-name'));
    setText('detailItemName', rowData(row, 'item-name'));
    setText('detailSubmitStatus', submitStatusValue(row));
    setText('detailSubmitDate', rowData(row, 'submit-date'));

    setText('detailMainNo', mainNoValue(row));
    setText('detailMblNo', rowData(row, 'mbl-no'));
    setText('detailHblNo', rowData(row, 'hbl-no'));
    setText('detailBlStatus', rowData(row, 'bl-status'));
    setText('detailListNo', rowData(row, 'list-no'));
    setText('detailTraderName', rowData(row, 'trader-name'));

    setText('detailTransportNo', rowData(row, 'transport-no'));
    setText('detailDeparturePort', rowData(row, 'departure-port'));
    setText('detailArrivalPort', rowData(row, 'arrival-port'));
    setText('detailTransportStatus', rowData(row, 'transport-status'));

    setText('detailWarehouseName', rowData(row, 'warehouse-name'));
    setText('detailWarehouseZoneName', rowData(row, 'warehouse-zone-name'));
    setText('detailWarehouseStatus', rowData(row, 'warehouse-status'));
    setText('detailWarehouseItemStatus', rowData(row, 'warehouse-item-status'));
    setText('detailSealNo', rowData(row, 'seal-no'));
    setText('detailRemark', rowData(row, 'remark'));

    renderCompareRows(row);

    var memo = document.getElementById('cargoMemo');
    if (memo) {
      memo.value = localStorage.getItem(getMemoKey(row)) || '';
      memo.setAttribute('data-memo-key', getMemoKey(row));
    }

    var saved = document.getElementById('cargoMemoSavedText');
    if (saved) saved.textContent = '';

    panel.style.display = 'block';
  }

  function handleDocumentClick(e) {
    var tab = closest(e.target, '[data-tab-group="cargo-list-type"]');
    if (tab) {
      e.preventDefault();
      e.stopPropagation();
      setCargoListTab(tab.getAttribute('data-tab-key') || 'all-list', tab);
      return;
    }

    var detailBtn = closest(e.target, '.btn-cargo-detail');
    var row = detailBtn ? closest(detailBtn, '.cargo-click-row') : closest(e.target, '.cargo-click-row');

    if (!row) return;
    if (closest(e.target, 'a, input, select, textarea, label')) return;

    e.preventDefault();
    e.stopPropagation();
    openCargoDetail(row);
  }

  function bindMemoSave() {
    var btn = document.getElementById('btnSaveCargoMemo');
    var memo = document.getElementById('cargoMemo');
    var saved = document.getElementById('cargoMemoSavedText');
    if (!btn || !memo) return;

    btn.onclick = function () {
      var key = memo.getAttribute('data-memo-key');
      if (!key) return;

      localStorage.setItem(key, memo.value || '');
      if (saved) {
        saved.textContent = '메모가 저장되었습니다.';
        setTimeout(function () { saved.textContent = ''; }, 1800);
      }
    };
  }

  function bindSearchButtons() {
    var resetBtn = document.getElementById('btnResetLoadedCargoSearch');
    if (resetBtn) {
      resetBtn.onclick = function () {
        window.location.href = window.location.pathname;
      };
    }

    var recentBtn = document.getElementById('btnRecentWeek');
    if (recentBtn) {
      recentBtn.onclick = function () {
        var end = new Date();
        var start = new Date();
        start.setDate(end.getDate() - 7);

        function fmt(d) {
          return d.getFullYear() + '-'
            + String(d.getMonth() + 1).padStart(2, '0') + '-'
            + String(d.getDate()).padStart(2, '0');
        }

        var s = document.getElementById('startDate');
        var e = document.getElementById('endDate');
        if (s) s.value = fmt(start);
        if (e) e.value = fmt(end);
      };
    }
  }

  function initLoadedCargoList() {
    if (window.__loadedCargoListBound) return;
    window.__loadedCargoListBound = true;

    document.addEventListener('click', handleDocumentClick, true);
    bindMemoSave();
    bindSearchButtons();
    setCargoListTab('all-list');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLoadedCargoList);
  } else {
    initLoadedCargoList();
  }

  window.setCargoListTab = setCargoListTab;
  window.openCargoDetail = openCargoDetail;
})();
