					      <span class="material-symbols-outlined" style="font-size:14px">search</span>
					    </button>
					  </div>
					</div>
                  <div class="form-item"><div class="form-item">
					  <label>*전화번호</label>
					  <input id="imp-taxpyr-tel" name="idTaxpyrTelno">
					</div></div>
                  <div class="form-item"><label>*식별부호</label>
                    <div style="display:flex;gap:4px"><select id="imp-taxpyr-idnt-se" style="width:110px">
                        <option value="">- 선택 -</option>
                        <option value="사업자등록번호">사업자등록번호</option>
                        <option value="주민등록번호">주민등록번호</option>
                        <option value="여권번호">여권번호</option>
                      </select><input id="imp-taxpyr-idnt-no" style="flex:1"></div>
                  </div>
                <div class="form-item" style="grid-column:1/-1"><label>*주소</label>
				  <div style="display:flex;gap:4px">
				    <input id="imp-taxpyr-zip"
				           style="width:120px"
				           placeholder="우편번호"
				           maxlength="5"
				           inputmode="numeric">
				
				    <button type="button"
				            class="btn btn-secondary"
				            style="padding:6px 8px;font-size:10px"
				            onclick="openImpTaxpayerPostcode()">
				      <span class="material-symbols-outlined" style="font-size:14px">search</span>
				    </button>
				
				    <input id="imp-taxpyr-addr"
				           style="flex:1"
				           placeholder="도로명주소">
				
				    <input id="imp-taxpyr-dtl-addr"
				           style="flex:1"
				           placeholder="상세주소">
				  </div>
				</div>
                </div>
              </div>


             <!-- 해외공급자 -->
				<div style="border-left:3px solid #506076;padding-left:12px;margin-bottom:16px">
				  <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">해외공급자</h4>
				
				  <div class="form-grid" style="grid-template-columns:1fr 1fr">
				    <div class="form-item">
				      <label>상호</label>
