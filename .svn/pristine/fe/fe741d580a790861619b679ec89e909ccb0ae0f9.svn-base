                  </div> -->

                  <div class="form-item"><label>*입항일자</label>
                    <div style="display:flex;gap:4px"><input id="imp-arvl-ymd" type="date" style="flex:1"></div>
                  </div>

                  <div class="form-item">
					  <label>*적출국</label>
					  <div style="display:flex;gap:4px">
					 <input id="imp-shipout-cntry-cd"
				       name="idShipoutCntryCd"
				       style="width:60px"
				       maxlength="2"
				       placeholder="2자리"
				       onblur="resolveCountryByCodeOrOpenModal('imp-shipout-cntry-cd', 'imp-shipout-cntry-nm')">
					
					    <button type="button"
					            class="btn btn-secondary"
					            style="padding:6px 8px;font-size:10px"
					            onclick="openCountryModal('imp-shipout-cntry-cd', 'imp-shipout-cntry-nm')">
					      <span class="material-symbols-outlined" style="font-size:14px">search</span>
