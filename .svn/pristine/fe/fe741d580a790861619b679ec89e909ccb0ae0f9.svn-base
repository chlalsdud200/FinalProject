					  <input type="hidden" id="imp-impr-se-cd" name="idImprSeCd" value="A">
					  <input type="text" value="A - 실수요자" readonly style="width:100%;">
					</div>
                </div>
              </div>

              <!-- 납세의무자 -->
              <div style="border-left:3px solid #565e74;padding-left:12px;margin-bottom:16px">
