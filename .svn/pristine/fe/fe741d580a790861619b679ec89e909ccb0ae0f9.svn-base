<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<c:set var="ctx" value="${pageContext.request.contextPath}" />
<!DOCTYPE html>
<html lang="ko">
<head>
    <%@ include file="/WEB-INF/views/broker/common/meta.jsp" %>
    <link rel="stylesheet" href="${ctx}/resources/css/broker/common.css">
    <link rel="stylesheet" href="${ctx}/resources/css/broker/pages/declare.css">
    <title>신고서 작성 | TACS</title>
</head>
<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/broker/common/sidebar.jsp" %>
    <div class="main-wrap">
        <%@ include file="/WEB-INF/views/broker/common/header.jsp" %>
        <div class="content">
<%-- 신고서 작성 페이지 --%>
      <div class="page active" id="pg-declare">
      
        <div class="sub-page">
          <h2><span class="material-symbols-outlined">edit_note</span> 신고서 작성</h2>
          <div class="selector-bar">
            <label>업무 구분</label>
            <select id="declareType" onchange="switchDeclare(this.value)">
              <option value="">— 업무를 선택하세요 —</option>
              <optgroup label="수입통관">
                <option value="imp-general">수입신고서</option>
              </optgroup>
              <optgroup label="수출통관">
                <option value="exp-general">수출신고서</option>
              </optgroup>
            </select>
          </div>

          <div id="declare-empty" style="text-align:center;padding:60px 0;color:#a0b4c8">
            <span class="material-symbols-outlined"
              style="font-size:48px;display:block;margin-bottom:12px">description</span>
            <p style="font-size:14px;font-weight:600;color:#697d8f">준비중 입니다</p>
            <p style="font-size:12px;color:#a0b4c8;margin-top:6px">수입통관 · 수출통관이 통합되어 있습니다</p>
          </div>

          <div id="declare-form" style="display:none">
            <div class="alert-bar info"><span class="material-symbols-outlined" style="font-size:18px">info</span> <span
                id="declare-form-title">수출신고서</span> 작성 화면입니다.</div>

          <div class="sub-tabs" id="tabs-df">
			  <button class="sub-tab active" onclick="cTab('df','c1')">공통사항1</button>
			  <button class="sub-tab" onclick="cTab('df','c2')">공통사항2</button>
			  <button class="sub-tab" onclick="cTab('df','items')">란사항</button>
			  <button class="sub-tab" onclick="cTab('df','attach')">첨부파일</button>
			</div>
            
            <!-- ========== 공통사항1 ========== -->
            <div id="df-c1">
              <div style="margin-bottom:16px;padding:10px 12px;background:#f0f7ff;border:1px solid #d0e5fa">
                <div style="display:flex;gap:8px;align-items:center;margin-bottom:10px">
                  <label style="font-size:11px;font-weight:700;color:#4d6172;white-space:nowrap">기존 신고서 조회</label>
                  <input id="exp-declare-input" placeholder="화주명 또는 통관의뢰번호"
                    style="width:240px;padding:6px 8px;border:1px solid #a0b4c8;font-size:13px">
                  <button class="btn btn-secondary" style="padding:6px 8px;font-size:10px"
                    onclick="openDeclareSearch('exp')" title="통관의뢰번호 검색"><span class="material-symbols-outlined"
                      style="font-size:14px">search</span></button>
                         <button class="btn btn-secondary" style="padding:6px 10px;font-size:10px"
  								onclick="loadDeclareByNo('exp')">조회</button>
                </div>
              </div>

              <!-- 신고인 -->
              <div style="border-left:3px solid #565e74;padding-left:12px;margin-bottom:16px">
                <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">신고인</h4>
                <div class="form-grid">
                  <div class="form-item"><label>*신고인부호</label>
                    <div style="display:flex;gap:4px"><input placeholder="" style="flex:1"><select style="width:50px">
                        <option></option>
                      </select></div>
                  </div>
                  <div class="form-item"><label>*상호/대표자성명</label>
                    <div style="display:flex;gap:4px"><input placeholder="상호" style="flex:1"><button
                        class="btn btn-secondary" style="padding:6px 8px;font-size:10px"><span
                          class="material-symbols-outlined" style="font-size:14px">search</span></button></div>
                  </div>
                </div>
              </div>

              <!-- 수출대행자 -->
              <div style="border-left:3px solid #506076;padding-left:12px;margin-bottom:16px">
                <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">수출대행자</h4>
                <div class="form-grid">
                  <div class="form-item"><label>*상호</label>
                    <div style="display:flex;gap:4px"><input placeholder="" style="flex:1"><button
                        class="btn btn-secondary" style="padding:6px 8px;font-size:10px"><span
                          class="material-symbols-outlined" style="font-size:14px">search</span></button></div>
                  </div>
                  <div class="form-item"><label>*수출자구분</label><select>
                      <option>선택</option>
                      <option>A-수출대행자=제조자</option>
                      <option>B-수출대행만</option>
                      <option>C-완제품공급수출</option>
                      <option>D-본지사관계</option>
                    </select></div>
                  <div class="form-item"><label>통관고유부호</label>
                    <div style="display:flex;gap:4px"><input placeholder="" style="flex:1"><button
                        class="btn btn-secondary" style="padding:6px 8px;font-size:10px"><span
                          class="material-symbols-outlined" style="font-size:14px">search</span></button></div>
                  </div>
                  <div class="form-item"><label>사업장일련번호</label><input placeholder=""></div>
                </div>
              </div>

              <!-- 수출화주 -->
              <div style="border-left:3px solid #506076;padding-left:12px;margin-bottom:16px">
                <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">수출화주</h4>
                <div class="form-grid">
                  <div class="form-item"><label>상호</label>
                    <div style="display:flex;gap:4px"><input placeholder="" style="flex:1"><button
                        class="btn btn-secondary" style="padding:6px 8px;font-size:10px"><span
                          class="material-symbols-outlined" style="font-size:14px">search</span></button></div>
                  </div>
                  <div class="form-item"><label>*대표자명</label><input placeholder=""></div>
                  <div class="form-item"><label>*식별부호구분</label><select>
                      <option>선택</option>
                      <option>사업자등록번호</option>
                      <option>주민등록번호</option>
                      <option>개인통관고유부호</option>
                      <option>여권번호(외국인)</option>
                      <option>외국인등록번호</option>
                    </select></div>
                  <div class="form-item"><label>*식별번호</label><input placeholder=""></div>
                  <div class="form-item"><label>통관고유부호</label>
                    <div style="display:flex;gap:4px"><input placeholder="" style="flex:1"><button
                        class="btn btn-secondary" style="padding:6px 8px;font-size:10px"><span
                          class="material-symbols-outlined" style="font-size:14px">search</span></button></div>
                  </div>
                  <div class="form-item"><label>사업장일련번호</label><input placeholder=""></div>
                  <div class="form-item full"><label>*소재지주소</label>
                    <div style="display:flex;gap:4px"><input placeholder="우편번호" style="width:80px"><button
                        class="btn btn-secondary" style="padding:6px 8px;font-size:10px"><span
                          class="material-symbols-outlined" style="font-size:14px">search</span></button><input
                        placeholder="도로명주소" style="flex:1"></div>
                  </div>
                </div>
              </div>


              <!-- 기본신고사항 -->
              <div style="border-left:3px solid #565e74;padding-left:12px;margin-bottom:16px">
                <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">기본신고사항</h4>
                <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr">
                  <div class="form-item"><label>*거래구분</label><select>
                      <option>선택</option>
                      <option>11-일반형태수출</option>
                      <option>21-무상수출</option>
                      <option>23-위탁판매수출</option>
                      <option>31-외화획득용원료</option>
                      <option>41-개인간거래</option>
                      <option>72-재수출</option>
                    </select></div>
                  <div class="form-item"><label>인도조건</label><select>
                      <option>선택</option>
                      <option>FOB</option>
                      <option>CIF</option>
                      <option>CFR</option>
                      <option>EXW</option>
                      <option>FCA</option>
                      <option>DAP</option>
                      <option>DDP</option>
                    </select></div>
                  <div class="form-item"><label>*목적국</label>
                    <div style="display:flex;gap:4px"><input placeholder="국가부호" style="flex:1"><button
                        class="btn btn-secondary" style="padding:6px 8px;font-size:10px"><span
                          class="material-symbols-outlined" style="font-size:14px">search</span></button></div>
                  </div>
                  <div class="form-item"><label>*적재항</label>
                    <div style="display:flex;gap:4px"><input placeholder="항구/공항 부호" style="flex:1"><button
                        class="btn btn-secondary" style="padding:6px 8px;font-size:10px"><span
                          class="material-symbols-outlined" style="font-size:14px">search</span></button></div>
                  </div>
                  <div class="form-item"><label>운송수단</label><select>
                      <option>선택</option>
                      <option>10-선박</option>
                      <option>20-철도</option>
                      <option>30-차량</option>
                      <option>40-항공기</option>
                      <option>90-기타</option>
                    </select></div>
                  <div class="form-item"><label>검사희망일</label>
                    <div style="display:flex;gap:4px"><input type="date"><input placeholder="" style="width:40px"></div>
                  </div>
                  <div class="form-item"><label>보세구역부호</label><input placeholder="최대 8자리"></div>
                  <div class="form-item"><label>환급신청인</label><select>
                      <option>선택</option>
                      <option>1-수출대행자/수출화주</option>
                      <option>2-제조자</option>
                    </select></div>
                </div>
              </div>
            </div>

            <!-- ========== 공통사항2 ========== -->
            <div id="df-c2" style="display:none">
              <div style="border-left:3px solid #565e74;padding-left:12px;margin-bottom:16px">
                <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">금액 및 중량 정보</h4>
                <div class="form-grid">
                  <div class="form-item"><label>적용환율</label>
                    <div style="display:flex;gap:4px;align-items:center"><input placeholder="" style="width:80px"><span
                        style="font-size:11px;color:#697d8f">USD</span></div>
                  </div>
                  <div class="form-item"><label>*총중량</label>
                    <div style="display:flex;gap:4px;align-items:center"><input placeholder="0" style="flex:1"><span
                        style="font-size:11px;color:#697d8f">KG</span></div>
                  </div>
                  <div class="form-item"><label>*전체포장개수</label>
                    <div style="display:flex;gap:4px"><input placeholder="" style="flex:1"><select style="width:70px">
                        <option>선택</option>
                        <option>CT</option>
                        <option>BX</option>
                        <option>PK</option>
                      </select></div>
                  </div>
                  <div class="form-item"><label>*통화코드</label>
                    <div style="display:flex;gap:4px;align-items:center"><select style="width:70px">
                        <option>USD</option>
                        <option>EUR</option>
                        <option>JPY</option>
                        <option>CNY</option>
                        <option>GBP</option>
                      </select><button class="btn btn-secondary"
                        style="padding:4px 8px;font-size:10px">환율조회</button><input placeholder="0" style="width:60px">
                    </div>
                  </div>
                  <div class="form-item"><label>*결제금액</label><input placeholder="0"></div>
                  <div class="form-item"><label>*신고총액 (USD)</label><input placeholder="0" disabled
                      style="background:#ecf4ff"></div>
                  <div class="form-item"><label>*신고총액 (KRW)</label>
                    <div style="display:flex;gap:4px"><input placeholder="0" disabled
                        style="background:#ecf4ff;flex:1"><button class="btn btn-primary"
                        style="padding:4px 10px;font-size:10px"
                        onclick="alert('수출신고금액이 계산되었습니다.\n\nFOB: $45,230\n원화환산: ₩58,799,000')">수출신고금액계산</button></div>
                  </div>
                </div>
              </div>



              <div style="border-left:3px solid #506076;padding-left:12px;margin-bottom:16px">
                <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">컨테이너 정보</h4>
                <div class="form-grid">
                  <div class="form-item"><label>컨테이너적입여부</label><select>
                      <option>N</option>
                      <option>Y</option>
                    </select></div>
                  <div class="form-item"><label>화물번호전송구분</label><select>
                      <option>선택</option>
                    </select></div>
                  <div class="form-item"><label>화물관리번호</label><input placeholder=""></div>
                  <div class="form-item"><label>화물식별번호(UCR번호)</label><input placeholder=""></div>
                </div>
                <div style="margin-top:12px">
                  <button class="btn btn-secondary" style="margin-bottom:8px">컨테이너번호등록</button>
                  <div style="display:flex;gap:6px;justify-content:flex-end;margin-bottom:6px">
                    <button class="btn btn-secondary" style="padding:4px 10px;font-size:10px">＋ 행추가</button>
                    <button class="btn btn-danger" style="padding:4px 10px;font-size:10px">－ 행삭제</button>
                  </div>
                  <table class="data-table">
                    <thead>
                      <tr>
                        <th style="width:30px"><input type="checkbox"></th>
                        <th style="width:40px">NO</th>
                        <th>컨테이너번호</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td><input type="checkbox"></td>
                        <td>1</td>
                        <td><input placeholder="" style="width:100%;padding:4px;font-size:11px"></td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>

              <div style="border-left:3px solid #605c78;padding-left:12px;margin-bottom:16px">
                <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">보세운송신고</h4>
                <div class="form-item" style="margin-bottom:10px"><label>보세운송신고인구분</label>
                  <div style="display:flex;gap:12px;align-items:center;font-size:12px;margin-top:4px">
                    <label><input type="radio" name="bose" style="margin-right:3px">x</label>
                    <label><input type="radio" name="bose" style="margin-right:3px">신고</label>
                    <label><input type="radio" name="bose" style="margin-right:3px">수출</label>
                    <label><input type="radio" name="bose" style="margin-right:3px">제조</label>
                    <label><input type="radio" name="bose" style="margin-right:3px">보세운송</label>
                  </div>
                </div>
                <div class="form-grid">
                  <div class="form-item"><label>보세운송신고인</label>
                    <div style="display:flex;gap:4px"><input placeholder="" style="flex:1"><button
                        class="btn btn-secondary" style="padding:6px 8px;font-size:10px"><span
                          class="material-symbols-outlined" style="font-size:14px">search</span></button></div>
                  </div>
                  <div class="form-item"><label>보세운송신고기간</label>
                    <div style="display:flex;gap:4px"><input type="date" style="flex:1"><span
                        style="color:#697d8f;align-self:center">~</span><input type="date" style="flex:1"></div>
                  </div>
                  <div class="form-item"><label>선박회사(항공사)</label>
                    <div style="display:flex;gap:4px"><input placeholder="" style="flex:1"><button
                        class="btn btn-secondary" style="padding:6px 8px;font-size:10px"><span
                          class="material-symbols-outlined" style="font-size:14px">search</span></button></div>
                  </div>
                  <div class="form-item"><label>선박명(편명)</label><input placeholder=""></div>
                  <div class="form-item"><label>출항예정일자</label>
                    <div style="display:flex;gap:4px"><input type="date" style="flex:1"><input placeholder=""
                        style="width:40px"></div>
                  </div>
                  <div class="form-item"><label>적재예정보세구역</label><input placeholder=""></div>
                </div>
                <div class="form-item" style="margin-top:8px"><label>신고인기재란</label><textarea rows="2" placeholder=""
                    style="width:100%"></textarea></div>
              </div>
             </div>
		

              <!-- ========== 란사항 ========== -->
               <div id="df-items" style="display:none">
              <div style="border-left:3px solid #565e74;padding-left:12px;margin-bottom:16px">
                <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">란사항 입력</h4>
                <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr 1fr">
                  <div class="form-item"><label>*HS부호</label>
                    <div style="display:flex;gap:4px"><input placeholder="HS카드조회" style="flex:1"><span
                        style="font-size:10px;color:#565e74;align-self:center;cursor:pointer;text-decoration:underline"
                        onclick="alert('HS카드 조회 팝업이 열립니다.')">HS카드조회</span></div>
                  </div>
                  <div class="form-item"><label>란번호</label>
                    <div style="display:flex;gap:4px;align-items:center"><input placeholder="001"
                        style="width:50px"><span style="font-size:11px;color:#697d8f">/</span><span
                        style="font-size:11px;color:#697d8f">품목수</span><input placeholder="" style="width:40px"></div>
                  </div>
                  <div class="form-item"><label>자동선적여부</label><select>
                      <option>선택</option>
                      <option>Y</option>
                      <option>N</option>
                    </select></div>
                </div>
                <div class="form-grid" style="grid-template-columns:1fr 1fr;margin-top:8px">
                  <div class="form-item"><label>*수출물품명</label><input placeholder="품명(영문)"></div>
                  <div class="form-item"><label>자격증명코드</label><input placeholder=""></div>
                  <div class="form-item"><label>*거래품명</label><input placeholder="거래품명"></div>
                  <div class="form-item"><label>실적</label><input placeholder=""></div>
                </div>
                <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr 1fr;margin-top:8px">
                  <div class="form-item"><label>*순중량/단위</label>
                    <div style="display:flex;gap:4px"><input placeholder="" style="flex:1"><span
                        style="font-size:11px;color:#697d8f;align-self:center">(KG/GT)</span></div>
                  </div>
                  <div class="form-item"><label>*신고가격</label>
                    <div style="display:flex;gap:4px;align-items:center"><input placeholder="0" style="flex:1"><span
                        style="font-size:11px;color:#697d8f">KRW</span></div>
                  </div>
                  <div class="form-item"><label>포장개수</label><select>
                      <option>선택</option>
                    </select></div>
                  <div class="form-item"><label>신고수량</label><input placeholder=""></div>
                </div>
              </div>
              
             <!-- 모델 및 규격 -->
				<div style="border-left:3px solid #605c78;padding-left:12px;margin-bottom:16px">
				
				  <!-- 제목 + 현재 란 표시 -->
				  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
				    <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin:0">
				      모델 및 규격
				    </h4>
				
				   <span id="exp-mdlspec-current-item-label"
				          style="font-size:11px;color:#475569;background:#eef4ff;padding:4px 8px;border:1px solid #d7e0ea">
				      신규 란
				    </span>
				  </div>
				
				  <!-- 행 추가 버튼 -->
				  <div style="display:flex;gap:6px;justify-content:flex-end;margin-bottom:6px">
				    <button type="button"
				            class="btn btn-secondary"
				            style="padding:4px 8px;font-size:9px"
				            onclick="alert('수출 모델/규격은 추후 구현 예정입니다.')">
				      ＋ 행추가
				    </button>
				  </div>
				
				  <table class="data-table" style="font-size:11px">
				    <thead>
				      <tr>
				        <th style="width:55px">규격번호</th>
				        <th>규격</th>
				        <th style="width:90px">수량</th>
				        <th style="width:70px">단위</th>
				        <th style="width:90px">단가</th>
				        <th style="width:90px">금액</th>
				        <th style="width:55px">삭제</th>
				      </tr>
				    </thead>
				
				    <tbody id="exp-mdlspec-tbody">
				      <tr class="mdlspec-row">
				        <td>
				          <input class="mdlspec-mdlspec-no"
				                 value="01"
				                 style="width:100%;padding:3px;font-size:11px">
				        </td>
				
				        <td>
				          <textarea class="mdlspec-mdlspec-nm"
				                    style="width:100%;font-size:11px;resize:vertical;min-height:40px"></textarea>
				        </td>
				
				        <td>
				          <input class="mdlspec-qty1"
				                 style="width:100%;padding:3px;font-size:11px">
				        </td>
				
				        <td>
				          <input class="mdlspec-qty1-unit-cd"
				                 style="width:100%;padding:3px;font-size:11px"
				                 placeholder="KG">
				        </td>
				
				        <td>
				          <input class="mdlspec-unit-prc"
				                 style="width:100%;padding:3px;font-size:11px">
				        </td>
				
				        <td>
				          <input class="mdlspec-amt"
				                 style="width:100%;padding:3px;font-size:11px">
				        </td>
				
				        <td style="text-align:center">
				          <button type="button"
				                  class="btn btn-danger"
				                  style="padding:2px 6px;font-size:9px"
				                  onclick="alert('수출 모델/규격은 추후 구현 예정입니다.')">
				            삭제
				          </button>
				        </td>
				      </tr>
				    </tbody>
				  </table>
				</div>
				
				  <!-- 란 목록 -->
				  <div style="margin-top:16px;padding:12px;background:#f0f7ff;border:1px solid #d0e5fa">
				    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
				      <h4 style="font-size:12px;font-weight:700;color:#4d6172">란 목록</h4>
				      <div style="display:flex;gap:4px">
				        <button class="btn btn-primary" style="padding:4px 10px;font-size:10px">추가</button>
				        <button class="btn btn-secondary" style="padding:4px 10px;font-size:10px">수정</button>
				        <button class="btn btn-danger" style="padding:4px 10px;font-size:10px">삭제</button>
				        <button class="btn btn-secondary" style="padding:4px 10px;font-size:10px">초기화</button>
				      </div>
				    </div>
				    <table class="data-table">
				      <thead>
				        <tr>
				          <th style="width:24px"><input type="checkbox"></th>
				          <thead>
							  <tr style="background:#f5f7fa">
							    <th style="width:50px">선택</th>
							    <th style="width:60px">란번호</th>
							    <th style="width:120px">HS부호</th>
							    <th>신고품명</th>
							    <th>거래품명</th>
							    <th style="width:70px">세율</th>
							    <th style="width:100px">수량/단위</th>
							    <th style="width:130px">과세가격(KRW)</th>
							    <th style="width:90px">규격수</th>
							  </tr>
							</thead>
				          <th style="width:140px">세번부호</th>
				          <th>신고품명</th>
				        </tr>
				      </thead>
				      <tbody>
				        <tr style="color:#a0b4c8;text-align:center">
				          <td colspan="4" style="padding:20px;font-size:12px">란사항을 입력 후 [추가] 버튼을 클릭하세요</td>
				        </tr>
				      </tbody>
				    </table>
				  </div>
				</div>




            <!-- ========== 첨부파일 ========== -->
            <div id="df-attach" style="display:none">
              <div style="display:flex;gap:6px;justify-content:flex-end;margin-bottom:10px">
                <button class="btn btn-secondary" onclick="alert('첨부파일 행이 추가되었습니다.')"><span
                    class="material-symbols-outlined" style="font-size:14px">add</span> 행추가</button>
                <button class="btn btn-danger"><span class="material-symbols-outlined"
                    style="font-size:14px">remove</span> 행삭제</button>
              </div>
              <table class="data-table">
                <thead>
                  <tr>
                    <th style="width:24px"><input type="checkbox"></th>
                    <th style="width:40px">NO</th>
                    <th style="width:180px">문서코드</th>
                    <th>첨부파일</th>
                    <th style="width:180px">업무참조번호<br><span
                        style="font-size:8px;font-weight:400;color:#a0b4c8">(통관의뢰번호/제품번호)</span></th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><input type="checkbox"></td>
                    <td>1</td>
                    <td><select style="font-size:11px;padding:4px;width:100%">
                        <option>선택</option>
                        <option>송품장(INVOICE)</option>
                        <option>포장명세서(P/L)</option>
                        <option>B/L 사본</option>
                        <option>원산지증명서</option>
                        <option>검사성적서</option>
                        <option>수출승인서</option>
                        <option>가격신고서</option>
                        <option>위임장</option>
                        <option>기타</option>
                      </select></td>
                    <td>
                      <div style="display:flex;gap:4px;align-items:center"><span
                          style="font-size:11px;color:#697d8f">파일명 :</span><input type="file"
                          style="font-size:10px;flex:1"></div>
                    </td>
                    <td><input placeholder="" style="width:100%;padding:4px;font-size:11px"></td>
                  </tr>
          </tbody>
              </table>
            </div>

            <!-- 하단 버튼 영역 -->
            <div
              style="margin-top:20px;padding-top:16px;border-top:2px solid #e2e8f0;display:flex;justify-content:space-between">
              <div class="btn-row">
                <button class="btn btn-outline" onclick="location.href='${ctx}/broker/dashboard.do'"><span class="material-symbols-outlined"
                    style="font-size:14px">arrow_back</span> 목록</button>
                <button class="btn btn-secondary" onclick="alert('미리보기')"><span class="material-symbols-outlined"
                    style="font-size:14px">preview</span> 미리보기</button>
              </div>
              <div class="btn-row">
                <button class="btn btn-secondary" onclick="alert('임시저장 완료\n임시문서함에서 조회 가능합니다.')"><span
                    class="material-symbols-outlined" style="font-size:14px">save</span> 임시저장</button>
               <button class="btn btn-primary" onclick="alert('항목 검증 완료\n일괄전송 가능 상태로 저장되었습니다.')">일괄전송저장</button>
                <button class="btn btn-dark"
                  onclick="if(confirm('신고서를 전송하시겠습니까?\n전송 후 수정이 제한됩니다.'))alert('✅ 전송 완료')"><span
                    class="material-symbols-outlined" style="font-size:14px">send</span> 전송</button>
              </div>
            </div>
          </div>
          <!-- ↑ 위 3개로 [btn-row 행 → 하단 버튼 컨테이너 → declare-form] 닫음 -->




          <!-- ========== 수입신고서 시작 ========== -->
          <div id="declare-form-imp" style="display:none">
            <div class="alert-bar info"><span class="material-symbols-outlined" style="font-size:18px">info</span> 수입신고서
              작성 화면입니다.</div>

            <div class="sub-tabs" id="tabs-imp">
              <button class="sub-tab active" onclick="impTab('c1')">공통사항1</button>
              <button class="sub-tab" onclick="impTab('c2')">공통사항2</button>
              <button class="sub-tab" onclick="impTab('items')">란사항</button>
              <button class="sub-tab" onclick="impTab('attach')">첨부파일</button>
            </div>

            <!-- ========== [수입] 공통사항1 ========== -->
            <div id="imp-c1">

              <div style="margin-bottom:16px;padding:10px 12px;background:#f0f7ff;border:1px solid #d0e5fa">
                <div style="display:flex;gap:8px;align-items:center;margin-bottom:10px">
                  <label style="font-size:11px;font-weight:700;color:#4d6172;white-space:nowrap">기존 신고서 조회</label>
                  <input id="imp-declare-input" placeholder="화주명 또는 통관의뢰번호"
                    style="width:240px;padding:6px 8px;border:1px solid #a0b4c8;font-size:13px">
                  <button class="btn btn-secondary" style="padding:6px 8px;font-size:10px"
                    onclick="openDeclareSearch('imp')" title="화주명으로 통관의뢰번호 검색"><span class="material-symbols-outlined"
                      style="font-size:14px">search</span></button>
                  <button class="btn btn-secondary" style="padding:6px 10px;font-size:10px"
  						onclick="loadDeclareByNo('imp')">조회</button>
                  <button class="btn btn-primary" style="padding:6px 10px;font-size:10px;background:#6d28d9"
                        onclick="aiParseFromPdf('imp')" title="첨부 PDF 들을 AI 가 종합 파싱해서 폼 자동 채움">
                    <span class="material-symbols-outlined" style="font-size:14px">auto_awesome</span> AI 자동 채움
                  </button>
                </div>
              </div>

              <!-- 신고인 -->
              <div style="border-left:3px solid #565e74;padding-left:12px;margin-bottom:16px">
                <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">신고인</h4>
                <div class="form-grid" style="grid-template-columns:1fr 1fr">
                  <div class="form-item"><label>*상호/성명</label><input id="imp-dclrnt-nm" placeholder="로그인 정보에서 자동 입력"></div>
                  <div class="form-item"><label>*이메일</label>
                    <div style="display:flex;gap:4px;align-items:center"><input id="imp-dclrnt-eml-local" style="flex:1"><span>@</span><input
                        id="imp-dclrnt-eml-domain" style="flex:1"><select id="imp-dclrnt-eml-select"
						        style="width:80px"
						        onchange="syncDclrntEmailDomainFromSelect()">
						  <option value="">- 선택 -</option>
						  <option value="naver.com">naver.com</option>
						  <option value="gmail.com">gmail.com</option>
						</select></div>
                  </div>
                  <div class="form-item"><label>*전화번호</label>
                    <div style="display:flex;gap:4px"><input id="imp-dclrnt-tel" style="flex:1"><span
                        style="align-self:center"></span></div>
                  </div>
                </div>
              </div>

              <!-- 수입자 -->
              <div style="border-left:3px solid #565e74;padding-left:12px;margin-bottom:16px">
                <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">수입자</h4>
                <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr">
                  <div class="form-item"><label>*상호</label>
                    <div style="display:flex;gap:4px">
                    <input id="imp-impr-nm" name="idImprNm" style="flex:1">
					<button type="button"
					        class="btn btn-secondary"
					        style="padding:6px 8px;font-size:10px"
					        onclick="openOwnerModal('imp', document.getElementById('imp-impr-nm').value)">
					  <span class="material-symbols-outlined" style="font-size:14px">search</span>
					</button>
                          </div>
                  </div>
                  <div class="form-item"><label>통관고유부호</label>
                    <div style="display:flex;gap:4px">
                    <input id="imp-impr-clnc-cd" name="idImprClncCd" style="flex:1">
					<button type="button"
					        class="btn btn-secondary"
					        style="padding:6px 8px;font-size:10px"
					        onclick="openOwnerModal('imp', document.getElementById('imp-impr-clnc-cd').value)">
					  <span class="material-symbols-outlined" style="font-size:14px">search</span>
					</button>
                     </div>
                  </div>
