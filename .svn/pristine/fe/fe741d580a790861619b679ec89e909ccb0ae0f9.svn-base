              <!-- 기본신고사항 -->
              <div style="border-left:3px solid #565e74;padding-left:12px;margin-bottom:16px">
                <h4 style="font-size:12px;font-weight:700;color:#4d6172;margin-bottom:8px">기본신고사항</h4>
                <div class="form-grid" style="grid-template-columns:1fr 1fr">

                <div class="form-item">
