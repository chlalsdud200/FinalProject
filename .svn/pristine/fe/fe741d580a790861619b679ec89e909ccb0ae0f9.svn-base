                <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr">
               		 <div class="form-item">
					  <label>*상호</label>
					  <div style="display:flex;gap:4px">
					    <input id="imp-taxpyr-nm" name="idTaxpyrNm" style="flex:1">
					
					    <button type="button"
					            class="btn btn-secondary"
					            style="padding:6px 8px;font-size:10px"
					            onclick="openOwnerModal('taxpyr', document.getElementById('imp-taxpyr-nm').value)">
					      <span class="material-symbols-outlined" style="font-size:14px">search</span>
					    </button>
					  </div>
					</div>
                 <div class="form-item">
					  <label>통관고유부호</label>
