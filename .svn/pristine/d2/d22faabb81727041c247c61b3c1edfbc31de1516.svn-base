/* =========================================================
   TACS 검역기관 대시보드 전용 스타일
   - 상단 현황 배너
   - 통계 카드
   - 최근 요청 목록
   - 처리율 / 마감 일정 영역
========================================================= */

/* ===== 대시보드 상단 배너 ===== */
.banner {
  padding: 16px 24px;
  background: #dae2fd;
  border-left: 8px solid #565e74;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.banner-left h2 {
  font-size: 16px;
  font-weight: 700;
  color: #4a5167;
}

.banner-left h2 span {
  font-weight: 900;
  color: #565e74;
  text-transform: uppercase;
}

.banner-left .meta {
  font-size: 10px;
  color: #4a5167;
  opacity: .7;
  margin-top: 2px;
}

.banner-right {
  display: flex;
  gap: 32px;
}

.banner-stat {
  text-align: right;
}

.banner-stat .label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  opacity: .6;
  color: #4a5167;
}

.banner-stat .val {
  font-size: 20px;
  font-weight: 900;
  color: #4a5167;
}

.banner-stat .unit {
  font-size: 11px;
  font-weight: 400;
}

/* ===== 대시보드 통계 카드 ===== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 28px;
}

.stat-card {
  background: #fff;
  padding: 20px 24px;
  border-bottom: 4px solid #565e74;
  cursor: pointer;
  transition: transform .1s;
}

.stat-card:hover {
  transform: translateY(-2px);
}

.stat-card.c2 {
  border-color: #d97706;
}

.stat-card.c3 {
  border-color: #605c78;
}

.stat-card.c4 {
  border-color: #1d6b4f;
}

.stat-card .s-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: -.3px;
  color: #4d6172;
  margin-bottom: 8px;
}

.stat-card .s-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.stat-card .s-num {
  font-size: 36px;
  font-weight: 900;
  letter-spacing: -2px;
  color: #203444;
}

.stat-card .s-sub {
  font-size: 11px;
  font-weight: 700;
  margin-bottom: 6px;
}

/* ===== 대시보드 2열 영역 ===== */
.grid-2col {
  display: grid;
  grid-template-columns: 7fr 5fr;
  gap: 24px;
  margin-bottom: 28px;
}

.card-section {
  background: #fff;
  overflow: hidden;
}

.card-header {
  background: #373f54;
  padding: 12px 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-header h3 {
  color: #f7f7ff;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: -.3px;
}

.card-header button {
  background: none;
  border: none;
  color: #dae2fd;
  font-size: 10px;
  font-weight: 700;
  cursor: pointer;
}

.card-header button:hover {
  text-decoration: underline;
}

/* ===== 최근 검역 요청 목록 ===== */
.req-item {
  padding: 14px 20px;
  border-bottom: 1px solid #ecf4ff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background .12s;
}

.req-item:hover {
  background: #f8faff;
}

.req-item.new-item {
  border-left: 4px solid #565e74;
}

.req-item.urgent {
  border-left: 4px solid #9f403d;
}

.req-left {
  flex: 1;
  min-width: 0;
}

.req-title {
  font-size: 13px;
  font-weight: 700;
  color: #203444;
  display: flex;
  align-items: center;
  gap: 6px;
}

.req-title .badge {
  font-size: 9px;
  font-weight: 900;
  padding: 2px 8px;
  display: inline-block;
}

.req-sub {
  font-size: 10px;
  color: #697d8f;
  margin-top: 3px;
}

.req-right {
  display: flex;
  gap: 6px;
  flex-shrink: 0;
}

/* ===== 우측 요약 카드 ===== */
.side-card {
  background: #ecf4ff;
  padding: 20px;
}

.side-card h3 {
  font-size: 11px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #4d6172;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.side-card h3::before {
  content: '';
  width: 3px;
  height: 16px;
  background: #565e74;
  display: inline-block;
}

/* ===== 최근 대상 업체 / 기관 목록 ===== */
.client-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px;
  background: #fff;
  margin-bottom: 6px;
  border-bottom: 2px solid #e2e8f0;
  transition: all .12s;
  cursor: pointer;
}

.client-row:hover {
  background: #dae2fd;
}

.client-info {
  display: flex;
  align-items: center;
  gap: 10px;
}

.client-avatar {
  width: 28px;
  height: 28px;
  background: #565e74;
  color: #f7f7ff;
  font-size: 10px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.client-name {
  font-size: 12px;
  font-weight: 700;
  color: #203444;
}

.client-detail {
  font-size: 9px;
  color: #697d8f;
}

.client-count {
  font-size: 10px;
  font-weight: 700;
  color: #565e74;
}

/* ===== 하단 대시보드 영역 ===== */
.bottom-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}

.data-block {
  background: #ecf4ff;
  padding: 24px;
}

.data-block h3 {
  font-size: 12px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 1px;
  border-bottom: 1px solid rgba(32, 52, 68, .1);
  padding-bottom: 8px;
  margin-bottom: 20px;
}

.data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px 40px;
}

.d-item .d-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: #4d6172;
  margin-bottom: 4px;
}

.d-item .d-val {
  font-size: 22px;
  font-weight: 900;
  color: #203444;
}

.d-item .d-val.primary {
  color: #565e74;
}

.d-item .d-val.error {
  color: #9f403d;
}

.d-item .d-val .d-unit {
  font-size: 12px;
  font-weight: 400;
  margin-left: 4px;
}

/* ===== 마감 일정 영역 ===== */
.deadline-block {
  background: #d0e5fa;
  padding: 24px;
}

.deadline-block h3 {
  font-size: 12px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 16px;
}

.dl-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid rgba(32, 52, 68, .1);
}

.dl-item:last-child {
  border-bottom: none;
}

.dl-left {
  font-size: 12px;
  font-weight: 600;
  color: #203444;
}

.dl-left span {
  font-size: 10px;
  color: #697d8f;
  display: block;
  margin-top: 1px;
}

.dl-right {
  font-size: 11px;
  font-weight: 800;
}

.dl-right.dday {
  color: #9f403d;
}

.dl-right.safe {
  color: #1d6b4f;
}

/* ===== 반응형 ===== */
@media (max-width: 1280px) {
  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .grid-2col,
  .bottom-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 900px) {
  .banner {
    align-items: flex-start;
    flex-direction: column;
    gap: 16px;
  }

  .banner-right {
    width: 100%;
    justify-content: space-between;
    gap: 16px;
  }

  .banner-stat {
    text-align: left;
  }

  .stats-grid {
    grid-template-columns: 1fr;
  }

  .data-grid {
    grid-template-columns: 1fr;
  }

  .req-item {
    align-items: flex-start;
    flex-direction: column;
    gap: 10px;
  }

  .req-right {
    width: 100%;
    justify-content: flex-end;
  }
}