<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.common.notification.mapper.INotificationMapper">

    <resultMap id="notificationPolicyMap"
               type="kr.or.tacs.vo.common.notification.NotificationPolicyVO">
        <result property="npEventCd" column="np_event_cd"/>
        <result property="npBizNm" column="np_biz_nm"/>
        <result property="npReceiverUserType" column="np_receiver_user_type"/>
        <result property="npTitleTpl" column="np_title_tpl"/>
        <result property="npBodyTpl" column="np_body_tpl"/>
        <result property="npLinkTpl" column="np_link_tpl"/>
        <result property="npUseYn" column="np_use_yn"/>
        <result property="npRegDt" column="np_reg_dt"/>
    </resultMap>

    <select id="selectNotificationPolicy"
            resultMap="notificationPolicyMap">
        SELECT
            np_event_cd
          , np_biz_nm
          , np_receiver_user_type
          , np_title_tpl
          , np_body_tpl
          , np_link_tpl
          , np_use_yn
          , np_reg_dt
        FROM noti_policy
        WHERE np_event_cd = #{eventCd}
    </select>

    <select id="selectOwnerIdByIrNo"
            resultType="string">
        SELECT
            ir_owr_id
        FROM imp_rqst
        WHERE ir_no     = #{irNo}
          AND ir_use_yn = 'Y'
    </select>

    <select id="selectBrokerIdByIrNo"
            resultType="string">
        SELECT
            ir_broker_id
        FROM imp_rqst
        WHERE ir_no     = #{irNo}
          AND ir_use_yn = 'Y'
    </select>

    <select id="selectOfficerIdByIrNo"
            resultType="string">
        SELECT
            id_officer_id
        FROM imp_dclr
        WHERE id_ir_no = #{irNo}
    </select>

    <select id="selectWarehouseManagerIdByIrNo"
            resultType="string">
        SELECT
            wir_wm_id
        FROM (
            SELECT
                w.wir_wm_id
            FROM tran_rcp t
            INNER JOIN wh_in_rpt w
                ON w.wir_gg_no = t.trc_tfg_no
            WHERE (
                    t.trc_no = #{irNo}
                 OR t.trc_no = 'TRC-' || #{irNo}
                 OR REPLACE(t.trc_no, 'TRC-', '') = #{irNo}
            )
              AND w.wir_wm_id IS NOT NULL
            ORDER BY w.wir_in_plan_dt DESC NULLS LAST, w.wir_no DESC
        )
        WHERE ROWNUM = 1
    </select>

    <select id="selectTransportManagerIdByIrNo"
            resultType="string">
        SELECT
            tm_id
        FROM (
            SELECT
                tm.tm_id
            FROM tran_rcp t
            INNER JOIN transport_manager tm
                ON tm.tm_no = t.trc_tm_no
            WHERE (
                    t.trc_no = #{irNo}
                 OR t.trc_no = 'TRC-' || #{irNo}
                 OR REPLACE(t.trc_no, 'TRC-', '') = #{irNo}
            )
              AND tm.tm_id IS NOT NULL
              AND tm.tm_use_yn = 'Y'
            ORDER BY t.trc_rcept_dt DESC NULLS LAST, t.trc_no DESC
        )
        WHERE ROWNUM = 1
    </select>

    <select id="selectOwnerIdByWirNo"
            resultType="string">
        SELECT
            trc_owr_id
        FROM (
            SELECT
                t.trc_owr_id
            FROM wh_in_rpt w
            INNER JOIN tran_rcp t
                ON (
                      T.TRC_SE_CD = W.WIR_IO_SE_CD
                   OR (T.TRC_SE_CD = 'IMPORT' AND W.WIR_IO_SE_CD = 'IMP')
                   OR (T.TRC_SE_CD = 'EXPORT' AND W.WIR_IO_SE_CD = 'EXP')
                   OR (T.TRC_SE_CD = 'IMP'    AND W.WIR_IO_SE_CD = 'IMPORT')
                   OR (T.TRC_SE_CD = 'EXP'    AND W.WIR_IO_SE_CD = 'EXPORT')
                )
               AND (
                      t.trc_no = w.wir_no
                   OR t.trc_no = 'TRC-' || w.wir_no
                   OR REPLACE(t.trc_no, 'TRC-', '') = w.wir_no
                   OR t.trc_tfg_no = w.wir_gg_no
                )
            WHERE w.wir_no = #{wirNo}
              AND t.trc_owr_id IS NOT NULL
            ORDER BY t.trc_rcept_dt DESC NULLS LAST, t.trc_no DESC
        )
        WHERE ROWNUM = 1
    </select>

    <select id="selectTransportManagerIdByWirNo"
            resultType="string">
        SELECT
            tm_id
        FROM (
            SELECT
                tm.tm_id
            FROM wh_in_rpt w
            INNER JOIN tran_rcp t
                ON (
                      T.TRC_SE_CD = W.WIR_IO_SE_CD
                   OR (T.TRC_SE_CD = 'IMPORT' AND W.WIR_IO_SE_CD = 'IMP')
                   OR (T.TRC_SE_CD = 'EXPORT' AND W.WIR_IO_SE_CD = 'EXP')
                   OR (T.TRC_SE_CD = 'IMP'    AND W.WIR_IO_SE_CD = 'IMPORT')
                   OR (T.TRC_SE_CD = 'EXP'    AND W.WIR_IO_SE_CD = 'EXPORT')
                )
               AND (
                      t.trc_no = w.wir_no
                   OR t.trc_no = 'TRC-' || w.wir_no
                   OR REPLACE(t.trc_no, 'TRC-', '') = w.wir_no
                   OR t.trc_tfg_no = w.wir_gg_no
                )
            INNER JOIN transport_manager tm
                ON tm.tm_no = t.trc_tm_no
            WHERE w.wir_no = #{wirNo}
              AND tm.tm_id IS NOT NULL
              AND tm.tm_use_yn = 'Y'
            ORDER BY t.trc_rcept_dt DESC NULLS LAST, t.trc_no DESC
        )
        WHERE ROWNUM = 1
    </select>

    <select id="selectTransportManagerIdByCrrNo"
            resultType="string">
        SELECT
            tm_id
        FROM (
            SELECT
                tm.tm_id
            FROM cargo_release_req crr
            INNER JOIN tran_rcp t
                ON t.trc_no = crr.crr_tre_id
            INNER JOIN transport_manager tm
                ON tm.tm_no = t.trc_tm_no
            WHERE crr.crr_no = #{crrNo}
              AND tm.tm_id IS NOT NULL
              AND tm.tm_use_yn = 'Y'
            ORDER BY t.trc_rcept_dt DESC NULLS LAST, t.trc_no DESC
        )
        WHERE ROWNUM = 1
    </select>

    <select id="selectTransportManagerIdByTrcNo"
            resultType="string">
        SELECT
            tm_id
        FROM (
            SELECT
                tm.tm_id
            FROM tran_rcp t
            INNER JOIN transport_manager tm
                ON tm.tm_no = t.trc_tm_no
            WHERE t.trc_no = #{trcNo}
              AND tm.tm_id IS NOT NULL
              AND tm.tm_use_yn = 'Y'
            ORDER BY t.trc_rcept_dt DESC NULLS LAST, t.trc_no DESC
        )
        WHERE ROWNUM = 1
    </select>

    <select id="selectWarehouseManagerIdByWirNo"
            resultType="string">
        SELECT
            wir_wm_id
        FROM (
            SELECT
                w.wir_wm_id
            FROM wh_in_rpt w
            WHERE w.wir_no = #{wirNo}
              AND w.wir_wm_id IS NOT NULL
            ORDER BY w.wir_in_plan_dt DESC NULLS LAST, w.wir_no DESC
        )
        WHERE ROWNUM = 1
    </select>

    <select id="selectWarehouseManagerIdByCrrNo"
            resultType="string">
        SELECT
            wm_id
        FROM (
            SELECT
                w.wir_wm_id AS wm_id
            FROM cargo_release_req crr
            INNER JOIN wh_in_rpt w
                ON w.wir_gg_no = crr.crr_gg_no
            WHERE crr.crr_no = #{crrNo}
              AND w.wir_wm_id IS NOT NULL
            ORDER BY w.wir_in_plan_dt DESC NULLS LAST, w.wir_no DESC
        )
        WHERE ROWNUM = 1
    </select>

    <insert id="insertNotification"
            parameterType="kr.or.tacs.vo.common.notification.NotificationVO">
        INSERT INTO notification (
            noti_no
          , noti_event_cd
          , noti_ref_key
          , noti_receiver_id
          , noti_sender_id
          , noti_title
          , noti_body
          , noti_link_url
          , noti_read_yn
          , noti_read_dt
          , noti_send_status
          , noti_retry_count
          , noti_last_error
          , noti_send_dt
        ) VALUES (
            seq_notification.NEXTVAL
          , #{notiEventCd}
          , #{notiRefKey}
          , #{notiReceiverId}
          , #{notiSenderId}
          , #{notiTitle}
          , #{notiBody}
          , #{notiLinkUrl}
          , 'N'
          , NULL
          , #{notiSendStatus}
          , 0
          , NULL
          , SYSDATE
        )
    </insert>

</mapper>
