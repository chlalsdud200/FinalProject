<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.warehouse.inventory.mapper.Inventory3DMapper">

	<!--
    로그인한 창고관리자의 담당 창고 1건 조회

    목적:
    - React 3D 허브 화면에서 창고를 하드코딩하지 않기 위함
    - 창고관리자 1명 = 창고 1개 구조이므로 wmId 기준으로 WAREHOUSE 1건을 조회한다.

    기준:
    - WAREHOUSE.WM_ID = 로그인 창고관리자 ID
    - 사용 중인 활성 창고만 조회한다.
	-->
	<select id="selectMyWarehouse"
	        resultType="kr.or.tacs.dto.warehouse.WarehouseZoneDTO">
	
	    SELECT
	        WH.WH_NO AS "whNo",
	        WH.WH_NM AS "whNm",
	        WH.WM_ID AS "wmId"
	    FROM WAREHOUSE WH
	    WHERE WH.WM_ID = #{wmId}
	      AND WH.WH_USE_YN = 'Y'
	      AND WH.WH_STATUS_CD = 'ACTIVE'
	
	</select>

    <select id="selectInventory3DList"
            resultType="kr.or.tacs.dto.warehouse.WarehouseInventory3DDTO">

        SELECT
            /*
                입고의뢰번호
                WAREHOUSE_ITEM.WI_WIR_NO와 WH_IN_RPT.WIR_NO를 조인해서 가져온다.
                보세재고조회 화면 첫 번째 컬럼에 표시할 값이다.
            */
            WIR.WIR_NO AS "wirNo",

            /*
                창고물품 기본 정보
            */
            WI.WI_GG_NO AS "wiGgNo",
            WI.WIL_CL_NO AS "wilClNo",
            WI.WI_CG_NO AS "wiCgNo",
            WI.WI_STATUS_CD AS "wiStatusCd",
            CC_STATUS.CC_NM AS "wiStatusNm",

            /*
                위치 정보
            */
            WIL.WIL_NO AS "locationCode",
            WIL.WIL_WH_ZONE_NO AS "wilWhZoneNo",
            WIL.WIL_DESC_CN AS "wilDescCn",
            TO_CHAR(WIL.WIL_IN_DT, 'YYYY-MM-DD HH24:MI') AS "wilInDt",
            TO_CHAR(WIL.WIL_OUT_DT, 'YYYY-MM-DD HH24:MI') AS "wilOutDt",

            /*
                창고 구역 정보
            */
            WZ.WZ_NM AS "wzNm",

            CASE
                WHEN WZ.WZ_NM LIKE 'A%' THEN 'A'
                WHEN WZ.WZ_NM LIKE 'B%' THEN 'B'
                WHEN WZ.WZ_NM LIKE 'C%' THEN 'C'
                ELSE 'Z'
            END AS "zone",

            /*
                물품명
            */
            GD.GOODS_NAME AS "goodsName",

            /*
                수입 / 수출 유형
            */
            WIR.WIR_IO_SE_CD AS "wirIoSeCd",

            CASE
                WHEN WIR.WIR_IO_SE_CD = 'IMP' THEN '수입'
                WHEN WIR.WIR_IO_SE_CD = 'EXP' THEN '수출'
                ELSE WIR.WIR_IO_SE_CD
            END AS "wirIoSeNm"

        FROM WAREHOUSE_ITEM WI

        /*
            현재 물품 위치 조인
            WAREHOUSE_ITEM.WIL_CL_NO = WAREHOUSE_ITEM_LOCATION.WIL_NO
        */
        JOIN WAREHOUSE_ITEM_LOCATION WIL
          ON WI.WIL_CL_NO = WIL.WIL_NO

        /*
            창고 구역 조인
        */
        JOIN WAREHOUSE_ZONE WZ
          ON WIL.WIL_WH_ZONE_NO = WZ.WZ_NO

        /*
            통관물품 조인
            WI_CG_NO와 WI_GG_NO를 같이 맞춰서 정확한 물품을 찾는다.
        */
        LEFT JOIN CUSTOMS_GOODS CG
          ON WI.WI_CG_NO = CG.CG_NO
         AND WI.WI_GG_NO = CG.GG_NO

        /*
            실제 물품명 조인
        */
        LEFT JOIN GOODS GD
          ON CG.GOODS_NO = GD.GOODS_NO

        /*
            입고의뢰 조인
            기존에는 WI_GG_NO = WIR_GG_NO로 조인해서 중복이 발생했다.
            이제는 WAREHOUSE_ITEM.WI_WIR_NO = WH_IN_RPT.WIR_NO로 정확히 조인한다.
        */
        LEFT JOIN WH_IN_RPT WIR
          ON WI.WI_WIR_NO = WIR.WIR_NO

        /*
            창고물품 상태명 조인
            예: IN_DONE → 입고완료
        */
        LEFT JOIN COM_CODE CC_STATUS
          ON WI.WI_STATUS_CD = CC_STATUS.CC_CD
         AND CC_STATUS.CC_CCG_ID = 'WH_IN_STATUS'

        WHERE WI.WI_USE_YN = 'Y'
          AND WIL.WIL_NO IS NOT NULL
          AND WZ.WM_ID = #{wmId}

        ORDER BY WIL.WIL_NO

    </select>
    
    <select id="selectZoneStatusList"
            resultType="kr.or.tacs.dto.warehouse.WarehouseZoneDTO">

        SELECT
            WZ.WZ_NO AS "wzNo",
            WZ.WZ_WH_NO AS "wzWhNo",
            WZ.WM_ID AS "wmId",
            WZ.WZ_NM AS "wzNm",
            WZ.WZ_TY_CD AS "wzTyCd",
            WZ.WZ_STATUS_CD AS "wzStatusCd",
            WZ.WZ_LOAD_PSBL_YN AS "wzLoadPsblYn",

            /*
                전체 적재 가능 칸 수.
                이 값은 WAREHOUSE_ZONE에 세팅해둔 기준값을 그대로 사용한다.
                예: A구역 448칸, B구역 189칸, C구역 336칸
            */
            WZ.WZ_TTL_CAPA AS "wzTtlCapa",

            /*
                현재 사용 중인 칸 수.
                WAREHOUSE_ZONE.WZ_USE_CAPA 저장값을 믿는 게 아니라,
                실제 WAREHOUSE_ITEM_LOCATION에 현재 반출되지 않은 위치 개수를 센다.
            */
            (
                SELECT COUNT(DISTINCT WI.WIL_CL_NO)
				FROM WAREHOUSE_ITEM WI
				INNER JOIN WAREHOUSE_ITEM_LOCATION WIL
				   ON WIL.WIL_NO = WI.WIL_CL_NO
				WHERE WIL.WIL_WH_ZONE_NO = WZ.WZ_NO
				  AND NVL(WI.WI_USE_YN, 'Y') = 'Y'
				  AND WI.WIL_CL_NO IS NOT NULL
            ) AS "wzUseCapa",

            /*
                현재 적재율.
                현재 사용 칸 수 / 전체 칸 수 * 100
                NULLIF는 전체 칸 수가 0일 때 0으로 나누는 오류를 막기 위한 처리다.
            */
            ROUND(
                (
                    (
                        SELECT COUNT(DISTINCT WI.WIL_CL_NO)
						FROM WAREHOUSE_ITEM WI
						INNER JOIN WAREHOUSE_ITEM_LOCATION WIL
						   ON WIL.WIL_NO = WI.WIL_CL_NO
						WHERE WIL.WIL_WH_ZONE_NO = WZ.WZ_NO
						  AND NVL(WI.WI_USE_YN, 'Y') = 'Y'
						  AND WI.WIL_CL_NO IS NOT NULL
                    ) / NULLIF(WZ.WZ_TTL_CAPA, 0)
                ) * 100,
                2
            ) AS "wzUseRt",

            WZ.WZ_DESC_CN AS "wzDescCn",
            WZ.WZ_USE_YN AS "wzUseYn",
            WZ.WZ_REGIST_DT AS "wzRegistDt",
            WZ.WZ_UPDT_DT AS "wzUpdtDt"

        FROM WAREHOUSE_ZONE WZ

        WHERE WZ.WZ_USE_YN = 'Y'
          AND WZ.WZ_STATUS_CD = 'ACTIVE'
          AND WZ.WM_ID = #{wmId}

        ORDER BY WZ.WZ_NO

    </select>

    <select id="selectInventoryCount" resultType="int">

        SELECT COUNT(*)
        FROM (
            /*
                1. 현재 보관 중인 재고
                - 현재 재고 여부는 WAREHOUSE_ITEM.WI_USE_YN = 'Y' 기준
                - 위치반입일시는 물품 row 생성일시인 WI_REGIST_DT 기준
            */
            SELECT
                WI.WI_NO AS ITEM_NO
            FROM WAREHOUSE_ITEM WI

            JOIN WAREHOUSE_ITEM_LOCATION WIL
              ON WI.WIL_CL_NO = WIL.WIL_NO

            JOIN WAREHOUSE_ZONE WZ
              ON WIL.WIL_WH_ZONE_NO = WZ.WZ_NO

            LEFT JOIN CUSTOMS_GOODS CG
              ON WI.WI_CG_NO = CG.CG_NO
             AND WI.WI_GG_NO = CG.GG_NO

            LEFT JOIN GOODS GD
              ON CG.GOODS_NO = GD.GOODS_NO

            LEFT JOIN WH_IN_RPT WIR
              ON WI.WI_WIR_NO = WIR.WIR_NO

            WHERE NVL(WI.WI_USE_YN, 'Y') = 'Y'
              AND WIL.WIL_NO IS NOT NULL
              AND WZ.WM_ID = #{wmId}

            <if test="searchDTO.zone != null and searchDTO.zone != ''">
                AND WIL.WIL_WH_ZONE_NO = #{searchDTO.zone}
            </if>

            <!-- 수입/수출 유형 검색 -->
            <if test="searchDTO.wirIoSeCd != null and searchDTO.wirIoSeCd != ''">
                AND WIR.WIR_IO_SE_CD = #{searchDTO.wirIoSeCd}
            </if>

            <!-- 상태 검색
                 현재 보관 중인 재고는 입고완료(IN_DONE) 영역이다.
                 상태가 REL_DONE이면 이 SELECT는 제외된다. -->
            <if test="searchDTO.statusCd != null and searchDTO.statusCd != ''">
                AND #{searchDTO.statusCd} = 'IN_DONE'
            </if>

            <if test="searchDTO.startDate != null and searchDTO.startDate != ''">
                AND TRUNC(WI.WI_REGIST_DT) &gt;= TO_DATE(#{searchDTO.startDate}, 'YYYY-MM-DD')
            </if>

            <if test="searchDTO.endDate != null and searchDTO.endDate != ''">
                AND TRUNC(WI.WI_REGIST_DT) &lt;= TO_DATE(#{searchDTO.endDate}, 'YYYY-MM-DD')
            </if>

            <if test="searchDTO.keyword != null and searchDTO.keyword != ''">
                AND (
                       WIR.WIR_NO LIKE '%' || #{searchDTO.keyword} || '%'
                    OR WIR.WIR_OWR_NM LIKE '%' || #{searchDTO.keyword} || '%'
                    OR GD.GOODS_NAME LIKE '%' || #{searchDTO.keyword} || '%'
                    OR WZ.WZ_NM LIKE '%' || #{searchDTO.keyword} || '%'
                    OR WIL.WIL_WH_ZONE_NO LIKE '%' || #{searchDTO.keyword} || '%'
                    OR WIL.WIL_NO LIKE '%' || #{searchDTO.keyword} || '%'
                )
            </if>

            UNION ALL

            /*
                2. 반출완료 이력
                - 반출완료 건은 WH_OUT_HIS 기준
                - 반출일시는 WOH_OUT_DT 기준
            */
            SELECT
                WOH.WOH_WI_NO AS ITEM_NO
            FROM WH_OUT_HIS WOH

            LEFT JOIN WAREHOUSE_ITEM WI
              ON WI.WI_NO = WOH.WOH_WI_NO

            LEFT JOIN WH_IN_RPT WIR
              ON WI.WI_WIR_NO = WIR.WIR_NO

            WHERE WOH.WOH_WM_ID = #{wmId}

            <if test="searchDTO.zone != null and searchDTO.zone != ''">
                AND WOH.WOH_WZ_NO = #{searchDTO.zone}
            </if>

            <!-- 수입/수출 유형 검색 -->
            <if test="searchDTO.wirIoSeCd != null and searchDTO.wirIoSeCd != ''">
                AND WIR.WIR_IO_SE_CD = #{searchDTO.wirIoSeCd}
            </if>

            <!-- 상태 검색
                 반출완료 이력은 REL_DONE 영역이다.
                 상태가 IN_DONE이면 이 SELECT는 제외된다. -->
            <if test="searchDTO.statusCd != null and searchDTO.statusCd != ''">
                AND #{searchDTO.statusCd} = 'REL_DONE'
            </if>

            <if test="searchDTO.startDate != null and searchDTO.startDate != ''">
                AND TRUNC(WI.WI_REGIST_DT) &gt;= TO_DATE(#{searchDTO.startDate}, 'YYYY-MM-DD')
            </if>

            <if test="searchDTO.endDate != null and searchDTO.endDate != ''">
                AND TRUNC(WI.WI_REGIST_DT) &lt;= TO_DATE(#{searchDTO.endDate}, 'YYYY-MM-DD')
            </if>

            <if test="searchDTO.keyword != null and searchDTO.keyword != ''">
                AND (
                       WIR.WIR_NO LIKE '%' || #{searchDTO.keyword} || '%'
                    OR WOH.WOH_OWR_NM LIKE '%' || #{searchDTO.keyword} || '%'
                    OR WOH.WOH_GOODS_NM LIKE '%' || #{searchDTO.keyword} || '%'
                    OR WOH.WOH_WZ_NM LIKE '%' || #{searchDTO.keyword} || '%'
                    OR WOH.WOH_WZ_NO LIKE '%' || #{searchDTO.keyword} || '%'
                    OR WOH.WOH_LOCATION_CD LIKE '%' || #{searchDTO.keyword} || '%'
                    OR TO_CHAR(WOH.WOH_CRR_NO) LIKE '%' || #{searchDTO.keyword} || '%'
                )
            </if>
        )

    </select>


    <!--
        보세재고 목록 페이징 조회

        기존 selectInventory3DList와 같은 컬럼을 내려주되,
        검색조건과 ROWNUM 페이징을 추가한다.
    -->
    <select id="selectInventoryList"
            resultType="kr.or.tacs.dto.warehouse.WarehouseInventory3DDTO">

        SELECT *
        FROM (
            SELECT ROWNUM AS rnum, B.*
            FROM (
                /*
                    1. 현재 보관 중인 재고

                    - 기준 테이블: WAREHOUSE_ITEM
                    - 현재 재고 여부: WI_USE_YN = 'Y'
                    - 위치반입일시: WI_REGIST_DT
                      → 이 물품이 창고 재고 row로 등록된 시점
                    - 위치반출일시: NULL
                      → 아직 반출되지 않았으므로 비워둔다.
                */
                SELECT
                    WIR.WIR_NO AS "wirNo",
                    WIR.WIR_OWR_NM AS "wirOwrNm",
                    WI.WI_GG_NO AS "wiGgNo",
                    WI.WIL_CL_NO AS "wilClNo",
                    WI.WI_CG_NO AS "wiCgNo",
                    WI.WI_STATUS_CD AS "wiStatusCd",
                    CC_STATUS.CC_NM AS "wiStatusNm",

                    WI.WIL_CL_NO AS "locationCode",
                    WIL.WIL_WH_ZONE_NO AS "wilWhZoneNo",
                    WIL.WIL_DESC_CN AS "wilDescCn",

                    TO_CHAR(WI.WI_REGIST_DT, 'YYYY-MM-DD HH24:MI') AS "wilInDt",
                    NULL AS "wilOutDt",

                    WZ.WZ_NM AS "wzNm",

                    CASE
                        WHEN WZ.WZ_NM LIKE 'A%' THEN 'A'
                        WHEN WZ.WZ_NM LIKE 'B%' THEN 'B'
                        WHEN WZ.WZ_NM LIKE 'C%' THEN 'C'
                        ELSE 'Z'
                    END AS "zone",

                    GD.GOODS_NAME AS "goodsName",

                    WIR.WIR_IO_SE_CD AS "wirIoSeCd",

                    CASE
                        WHEN WIR.WIR_IO_SE_CD = 'IMP' THEN '수입'
                        WHEN WIR.WIR_IO_SE_CD = 'EXP' THEN '수출'
                        WHEN WIR.WIR_IO_SE_CD = 'IMPORT' THEN '수입'
                        WHEN WIR.WIR_IO_SE_CD = 'EXPORT' THEN '수출'
                        ELSE WIR.WIR_IO_SE_CD
                    END AS "wirIoSeNm",

                    WI.WI_REGIST_DT AS sortDt,
                    WIR.WIR_NO AS sortNo

                FROM WAREHOUSE_ITEM WI

                JOIN WAREHOUSE_ITEM_LOCATION WIL
                  ON WI.WIL_CL_NO = WIL.WIL_NO

                JOIN WAREHOUSE_ZONE WZ
                  ON WIL.WIL_WH_ZONE_NO = WZ.WZ_NO

                LEFT JOIN CUSTOMS_GOODS CG
                  ON WI.WI_CG_NO = CG.CG_NO
                 AND WI.WI_GG_NO = CG.GG_NO

                LEFT JOIN GOODS GD
                  ON CG.GOODS_NO = GD.GOODS_NO

                LEFT JOIN WH_IN_RPT WIR
                  ON WI.WI_WIR_NO = WIR.WIR_NO

                LEFT JOIN COM_CODE CC_STATUS
                  ON WI.WI_STATUS_CD = CC_STATUS.CC_CD
                 AND CC_STATUS.CC_CCG_ID = 'WH_IN_STATUS'

                WHERE NVL(WI.WI_USE_YN, 'Y') = 'Y'
                  AND WIL.WIL_NO IS NOT NULL
                  AND WZ.WM_ID = #{wmId}

                <!-- 보관 구역 검색 -->
                <if test="searchDTO.zone != null and searchDTO.zone != ''">
                    AND WIL.WIL_WH_ZONE_NO = #{searchDTO.zone}
                </if>

                <!-- 수입/수출 유형 검색 -->
                <if test="searchDTO.wirIoSeCd != null and searchDTO.wirIoSeCd != ''">
                    AND WIR.WIR_IO_SE_CD = #{searchDTO.wirIoSeCd}
                </if>

                <!-- 상태 검색
                     현재 보관 중인 재고는 입고완료(IN_DONE) 영역이다.
                     상태가 REL_DONE이면 이 SELECT는 제외된다. -->
                <if test="searchDTO.statusCd != null and searchDTO.statusCd != ''">
                    AND #{searchDTO.statusCd} = 'IN_DONE'
                </if>

                <!-- 위치반입 시작일 검색 -->
                <if test="searchDTO.startDate != null and searchDTO.startDate != ''">
                    AND TRUNC(WI.WI_REGIST_DT) &gt;= TO_DATE(#{searchDTO.startDate}, 'YYYY-MM-DD')
                </if>

                <!-- 위치반입 종료일 검색 -->
                <if test="searchDTO.endDate != null and searchDTO.endDate != ''">
                    AND TRUNC(WI.WI_REGIST_DT) &lt;= TO_DATE(#{searchDTO.endDate}, 'YYYY-MM-DD')
                </if>

                <!-- 검색어 검색 -->
                <if test="searchDTO.keyword != null and searchDTO.keyword != ''">
                    AND (
                           WIR.WIR_NO LIKE '%' || #{searchDTO.keyword} || '%'
                        OR WIR.WIR_OWR_NM LIKE '%' || #{searchDTO.keyword} || '%'
                        OR GD.GOODS_NAME LIKE '%' || #{searchDTO.keyword} || '%'
                        OR WZ.WZ_NM LIKE '%' || #{searchDTO.keyword} || '%'
                        OR WIL.WIL_WH_ZONE_NO LIKE '%' || #{searchDTO.keyword} || '%'
                        OR WIL.WIL_NO LIKE '%' || #{searchDTO.keyword} || '%'
                    )
                </if>

                UNION ALL

                /*
                    2. 반출완료 이력

                    - 기준 테이블: WH_OUT_HIS
                    - 위치반입일시: WAREHOUSE_ITEM.WI_REGIST_DT
                      → 해당 물품이 창고 재고로 등록된 시점
                    - 위치반출일시: WH_OUT_HIS.WOH_OUT_DT
                      → 반출승인 당시 저장된 반출 이력 시점
                    - WAREHOUSE_ITEM_LOCATION.WIL_OUT_DT를 쓰지 않는 이유:
                      같은 위치를 여러 물품이 재사용하면 위치 최신 일시로 덮여서
                      과거 물품들이 전부 같은 일시로 보이기 때문.
                */
                SELECT
                    WIR.WIR_NO AS "wirNo",
                    WOH.WOH_OWR_NM AS "wirOwrNm",
                    WOH.WOH_GG_NO AS "wiGgNo",
                    WOH.WOH_LOCATION_CD AS "wilClNo",
                    WI.WI_CG_NO AS "wiCgNo",
                    'REL_DONE' AS "wiStatusCd",
                    '반출완료' AS "wiStatusNm",

                    WOH.WOH_LOCATION_CD AS "locationCode",
                    WOH.WOH_WZ_NO AS "wilWhZoneNo",
                    WOH.WOH_WZ_NM AS "wilDescCn",

                    TO_CHAR(WI.WI_REGIST_DT, 'YYYY-MM-DD HH24:MI') AS "wilInDt",
                    TO_CHAR(WOH.WOH_OUT_DT, 'YYYY-MM-DD HH24:MI') AS "wilOutDt",

                    WOH.WOH_WZ_NM AS "wzNm",

                    CASE
                        WHEN WOH.WOH_WZ_NM LIKE 'A%' THEN 'A'
                        WHEN WOH.WOH_WZ_NM LIKE 'B%' THEN 'B'
                        WHEN WOH.WOH_WZ_NM LIKE 'C%' THEN 'C'
                        ELSE 'Z'
                    END AS "zone",

                    WOH.WOH_GOODS_NM AS "goodsName",

                    WIR.WIR_IO_SE_CD AS "wirIoSeCd",

                    CASE
                        WHEN WIR.WIR_IO_SE_CD = 'IMP' THEN '수입'
                        WHEN WIR.WIR_IO_SE_CD = 'EXP' THEN '수출'
                        WHEN WIR.WIR_IO_SE_CD = 'IMPORT' THEN '수입'
                        WHEN WIR.WIR_IO_SE_CD = 'EXPORT' THEN '수출'
                        ELSE WIR.WIR_IO_SE_CD
                    END AS "wirIoSeNm",

                    WOH.WOH_OUT_DT AS sortDt,
                    WIR.WIR_NO AS sortNo

                FROM WH_OUT_HIS WOH

                LEFT JOIN WAREHOUSE_ITEM WI
                  ON WI.WI_NO = WOH.WOH_WI_NO

                LEFT JOIN WH_IN_RPT WIR
                  ON WI.WI_WIR_NO = WIR.WIR_NO

                WHERE WOH.WOH_WM_ID = #{wmId}

                <!-- 보관 구역 검색 -->
                <if test="searchDTO.zone != null and searchDTO.zone != ''">
                    AND WOH.WOH_WZ_NO = #{searchDTO.zone}
                </if>

                <!-- 수입/수출 유형 검색 -->
                <if test="searchDTO.wirIoSeCd != null and searchDTO.wirIoSeCd != ''">
                    AND WIR.WIR_IO_SE_CD = #{searchDTO.wirIoSeCd}
                </if>

                <!-- 상태 검색
                     반출완료 이력은 REL_DONE 영역이다.
                     상태가 IN_DONE이면 이 SELECT는 제외된다. -->
                <if test="searchDTO.statusCd != null and searchDTO.statusCd != ''">
                    AND #{searchDTO.statusCd} = 'REL_DONE'
                </if>

                <!-- 위치반입 시작일 검색 -->
                <if test="searchDTO.startDate != null and searchDTO.startDate != ''">
                    AND TRUNC(WI.WI_REGIST_DT) &gt;= TO_DATE(#{searchDTO.startDate}, 'YYYY-MM-DD')
                </if>

                <!-- 위치반입 종료일 검색 -->
                <if test="searchDTO.endDate != null and searchDTO.endDate != ''">
                    AND TRUNC(WI.WI_REGIST_DT) &lt;= TO_DATE(#{searchDTO.endDate}, 'YYYY-MM-DD')
                </if>

                <!-- 검색어 검색 -->
                <if test="searchDTO.keyword != null and searchDTO.keyword != ''">
                    AND (
                           WIR.WIR_NO LIKE '%' || #{searchDTO.keyword} || '%'
                        OR WOH.WOH_OWR_NM LIKE '%' || #{searchDTO.keyword} || '%'
                        OR WOH.WOH_GOODS_NM LIKE '%' || #{searchDTO.keyword} || '%'
                        OR WOH.WOH_WZ_NM LIKE '%' || #{searchDTO.keyword} || '%'
                        OR WOH.WOH_WZ_NO LIKE '%' || #{searchDTO.keyword} || '%'
                        OR WOH.WOH_LOCATION_CD LIKE '%' || #{searchDTO.keyword} || '%'
                        OR TO_CHAR(WOH.WOH_CRR_NO) LIKE '%' || #{searchDTO.keyword} || '%'
                    )
                </if>

                ORDER BY sortDt DESC, sortNo DESC

            ) B
            WHERE ROWNUM &lt;= #{searchDTO.endRow}
        )
        WHERE rnum &gt;= #{searchDTO.startRow}

    </select>
    
    <!--
    3D 재고 검색 목록 조회

    기존 selectInventory3DList는 전체 현재재고 조회용으로 유지한다.
    이 쿼리는 React 3D 검색창에서 zone, q 조건을 보낼 때 사용한다.

    조회 기준:
    - 현재 창고 안에 있는 물품만 조회
    - WI_USE_YN = 'Y'
    - 로그인한 창고관리자 wmId의 창고 구역만 조회
    - 반출완료 이력 WH_OUT_HIS는 3D에 표시하지 않는다.
-->
<select id="selectInventory3DSearchList"
        resultType="kr.or.tacs.dto.warehouse.WarehouseInventory3DDTO">

    SELECT
        /*
            입고의뢰번호
        */
        WIR.WIR_NO AS "wirNo",

        /*
            화주명
            3D 검색에서 화주명으로도 찾을 수 있게 내려준다.
        */
        WIR.WIR_OWR_NM AS "wirOwrNm",

        /*
            창고물품 기본 정보
        */
        WI.WI_GG_NO AS "wiGgNo",
        WI.WIL_CL_NO AS "wilClNo",
        WI.WI_CG_NO AS "wiCgNo",
        WI.WI_STATUS_CD AS "wiStatusCd",
        CC_STATUS.CC_NM AS "wiStatusNm",

        /*
            위치 정보
        */
        WIL.WIL_NO AS "locationCode",
        WIL.WIL_WH_ZONE_NO AS "wilWhZoneNo",
        WIL.WIL_DESC_CN AS "wilDescCn",
        TO_CHAR(WIL.WIL_IN_DT, 'YYYY-MM-DD HH24:MI') AS "wilInDt",
        TO_CHAR(WIL.WIL_OUT_DT, 'YYYY-MM-DD HH24:MI') AS "wilOutDt",

        /*
            창고 구역 정보
        */
        WZ.WZ_NM AS "wzNm",

        CASE
            WHEN WZ.WZ_NM LIKE 'A%' THEN 'A'
            WHEN WZ.WZ_NM LIKE 'B%' THEN 'B'
            WHEN WZ.WZ_NM LIKE 'C%' THEN 'C'
            ELSE 'Z'
        END AS "zone",

        /*
            물품명
        */
        GD.GOODS_NAME AS "goodsName",

        /*
            수입 / 수출 유형
        */
        WIR.WIR_IO_SE_CD AS "wirIoSeCd",

        CASE
            WHEN WIR.WIR_IO_SE_CD = 'IMP' THEN '수입'
            WHEN WIR.WIR_IO_SE_CD = 'EXP' THEN '수출'
            ELSE WIR.WIR_IO_SE_CD
        END AS "wirIoSeNm"

    FROM WAREHOUSE_ITEM WI

    JOIN WAREHOUSE_ITEM_LOCATION WIL
      ON WI.WIL_CL_NO = WIL.WIL_NO

    JOIN WAREHOUSE_ZONE WZ
      ON WIL.WIL_WH_ZONE_NO = WZ.WZ_NO

    LEFT JOIN CUSTOMS_GOODS CG
      ON WI.WI_CG_NO = CG.CG_NO
     AND WI.WI_GG_NO = CG.GG_NO

    LEFT JOIN GOODS GD
      ON CG.GOODS_NO = GD.GOODS_NO

    LEFT JOIN WH_IN_RPT WIR
      ON WI.WI_WIR_NO = WIR.WIR_NO

    LEFT JOIN COM_CODE CC_STATUS
      ON WI.WI_STATUS_CD = CC_STATUS.CC_CD
     AND CC_STATUS.CC_CCG_ID = 'WH_IN_STATUS'

    WHERE WI.WI_USE_YN = 'Y'
	  AND WIL.WIL_NO IS NOT NULL
	  AND WZ.WM_ID = #{wmId}

    <!-- 3D 구역 검색
         React에서 A/B/C로 보내도 되고,
         나중에 WZ-001 같은 구역번호로 보내도 검색되게 둘 다 허용한다. -->
    <if test="searchDTO.zone != null and searchDTO.zone != ''">
        AND (
               WIL.WIL_WH_ZONE_NO = #{searchDTO.zone}
            OR (
                CASE
                    WHEN WZ.WZ_NM LIKE 'A%' THEN 'A'
                    WHEN WZ.WZ_NM LIKE 'B%' THEN 'B'
                    WHEN WZ.WZ_NM LIKE 'C%' THEN 'C'
                    ELSE 'Z'
                END
            ) = #{searchDTO.zone}
        )
    </if>

    <!-- 3D 검색어 검색
         입고의뢰번호, 화주명, 물품명, 구역명, 위치코드 기준으로 검색한다. -->
    <if test="searchDTO.keyword != null and searchDTO.keyword != ''">
        AND (
               WIR.WIR_NO LIKE '%' || #{searchDTO.keyword} || '%'
            OR WIR.WIR_OWR_NM LIKE '%' || #{searchDTO.keyword} || '%'
            OR GD.GOODS_NAME LIKE '%' || #{searchDTO.keyword} || '%'
            OR WZ.WZ_NM LIKE '%' || #{searchDTO.keyword} || '%'
            OR WIL.WIL_WH_ZONE_NO LIKE '%' || #{searchDTO.keyword} || '%'
            OR WIL.WIL_NO LIKE '%' || #{searchDTO.keyword} || '%'
        )
    </if>

    ORDER BY WIL.WIL_NO

</select>


</mapper>