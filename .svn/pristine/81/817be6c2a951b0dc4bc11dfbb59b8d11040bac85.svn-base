package kr.or.tacs.vo.systemadmin.stats;

import lombok.Data;

/**
 * 관리자 통계 대시보드 조회 조건.
 * 기간 필터(startDate ~ endDate)는 신고/운송/알림 등 일자 기반 통계에 적용된다.
 * 값이 없으면 전체 기간을 대상으로 한다.
 */
@Data
public class AdminStatsSearchVO {

    /** 조회 시작일 (YYYY-MM-DD). null/빈값이면 미적용. */
    private String startDate;

    /** 조회 종료일 (YYYY-MM-DD). null/빈값이면 미적용. */
    private String endDate;

    /** 랭킹/분포 항목 노출 개수 (기본 10). */
    private Integer topN;
}
