@charset "UTF-8";

 /* =========================
   검색 영역
========================= */
.inventory-search-panel {
  padding: 18px 20px;
  background: #fff;
  border-bottom: 1px solid #e2e8f0;
}

.search-row {
  display: grid;
  grid-template-columns: 180px 320px minmax(0, 1fr) 120px;
  align-items: end;
  gap: 14px;
}

/* 공통 form */
.search-row .form-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
  min-width: 0;
}

.search-row .form-item label {
  font-size: 12px;
  font-weight: 800;
  color: #334155;
}

/* select, input 공통 */
.search-row select,
.search-row input {
  height: 38px;
  border: 1px solid #cbd5e1;
  background: #fff;
  color: #0f172a;
  font-size: 13px;
  font-weight: 600;
  outline: none;
  box-sizing: border-box;
}

.search-row select {
  width: 100%;
  padding: 0 12px;
}

.search-row input {
  width: 100%;
}

/* =========================
   날짜 범위
========================= */
.date-range {
  display: grid;
  grid-template-columns: 1fr 18px 1fr;
  align-items: center;
  gap: 6px;
  min-width: 0;
}

.date-range input {
  padding: 0 12px;
}

.date-range span {
  text-align: center;
  color: #64748b;
  font-size: 13px;
  font-weight: 800;
}

/* =========================
   검색창
========================= */
.search-item {
  min-width: 0;
}

.search-wrap {
  position: relative;
  width: 100%;
  min-width: 0;
}

.search-icon {
  position: absolute;
  left: 11px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 18px;
  color: #64748b;
  pointer-events: none;
}

.keyword-input {
  width: 100%;
  height: 38px;
  padding: 0 12px 0 38px !important;
  border: 1px solid #cbd5e1;
  background: #fff;
  color: #0f172a;
  font-size: 13px;
  font-weight: 600;
  box-sizing: border-box;
}

.keyword-input::placeholder {
  color: #94a3b8;
  font-weight: 600;
}

/* 검색 버튼 */
.inventory-search-btn {
  height: 38px;
  padding: 0 18px;
  justify-content: center;
  white-space: nowrap;
}

/* =========================
   테이블 영역
========================= */
.inventory-table-wrap {
  width: 100%;
  overflow-x: auto;
  background: #fff;
}

.inventory-table {
  width: 100%;
  min-width: 1040px;
  border-collapse: collapse;
  table-layout: fixed;
}

.inventory-table thead th {
  height: 48px;
  padding: 0 16px;
  background: #f8fafc;
  border-bottom: 1px solid #e2e8f0;
  color: #475569;
  font-size: 12px;
  font-weight: 800;
  text-align: left;
  white-space: nowrap;
}

.inventory-table tbody td {
  height: 46px;
  padding: 0 16px;
  border-bottom: 1px solid #f1f5f9;
  color: #0f172a;
  font-size: 12px;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.empty-table-result {
  height: 150px !important;
  text-align: center !important;
  vertical-align: middle !important;
  color: #94a3b8 !important;
  font-size: 14px !important;
  font-weight: 700 !important;
  background: #fff !important;
  border-bottom: 1px solid #e2e8f0 !important;
}

/* =========================
   3D 영역
========================= */
#inventory-3d-view {
  display: none;
  height: 650px;
  overflow: hidden;
}

.wh3d-wrap {
  position: relative;
  width: 100%;
  height: calc(100% - 54px);
}

#wh3d-frame {
  display: block;
  width: 100%;
  height: 100%;
  border: none;
  background: #0b1220;
}

#wh3d-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18px;
  background: rgba(2, 6, 23, 0.55);
  backdrop-filter: blur(2px);
}

.wh3d-message-box {
  max-width: 720px;
  width: 100%;
  background: #fff;
  border: 1px solid #e2e8f0;
  padding: 18px 20px;
}

.wh3d-title {
  font-size: 13px;
  font-weight: 900;
  color: #0f172a;
  margin-bottom: 8px;
}

.wh3d-status {
  font-size: 12px;
  color: #64748b;
  line-height: 1.7;
}

.wh3d-btn-row {
  margin-top: 12px;
  display: flex;
  gap: 8px;
}

#wh3d-overlay button {
  height: 36px;
  padding: 0 14px;
  font-size: 12px;
  font-weight: 800;
}

/* =========================
   구역별 적재 현황 카드
========================= */
.zone-status-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
  margin-bottom: 20px;
}

.zone-status-card {
  background: #fff;
  border: 1px solid #e2e8f0;
  padding: 18px 20px;
  box-shadow: 0 4px 14px rgba(15, 23, 42, 0.04);
}

.zone-status-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 14px;
}

.zone-status-name {
  font-size: 15px;
  font-weight: 900;
  color: #0f172a;
}

.zone-status-no {
  margin-top: 4px;
  font-size: 12px;
  font-weight: 700;
  color: #64748b;
}

.zone-status-rate {
  font-size: 24px;
  font-weight: 900;
  color: #0f172a;
  white-space: nowrap;
}

.zone-progress {
  width: 100%;
  height: 8px;
  background: #e2e8f0;
  overflow: hidden;
  margin-bottom: 12px;
}

.zone-progress-bar {
  height: 100%;
  background: #2563eb;
  transition: width 0.25s ease;
}

.zone-status-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  font-size: 12px;
  font-weight: 800;
  color: #475569;
}

.zone-status-empty {
  grid-column: 1 / -1;
  height: 90px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 1px solid #e2e8f0;
  color: #94a3b8;
  font-size: 13px;
  font-weight: 800;
}

/* =========================
   뱃지 스타일
========================= */

/* 공통 뱃지 */
.inventory-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 48px;
  height: 22px;
  padding: 0 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
}

/* 수입 */
.type-import {
  color: #047857;
  background: #d1fae5;
}

/* 수출 */
.type-export {
  color: #334155;
  background: #e2e8f0;
}

/* 입고완료 */
.status-in-done {
  color: #047857;
  background: #d1fae5;
}

/* 입고요청완료 / 대기 계열 */
.status-wait,
.status-sent {
  color: #334155;
  background: #e2e8f0;
}

/* 반려 / 오류 / 반출 계열 */
/* 반려 */
.status-reject {
  color: #b91c1c;
  background: #fee2e2;
}

/* 반출완료 */
.status-out,
.status-out-done {
  color: #1d4ed8;
  background: #dbeafe;
}

/* =========================
   반응형
========================= */
@media (max-width: 1200px) {
  .search-row {
    grid-template-columns: 1fr 1fr;
    row-gap: 12px;
  }

  .search-item {
    grid-column: 1 / -1;
  }

  .inventory-search-btn {
    grid-column: 1 / -1;
    width: 140px;
    justify-self: end;
  }

  .zone-status-grid {
    grid-template-columns: 1fr;
  }
}

/* =========================
   보세재고 목록 NO 컬럼
========================= */
.inventory-table .col-no,
.inventory-table .td-no {
  width: 55px;
  min-width: 55px;
  max-width: 55px;
  text-align: left !important;
  font-weight: 700;
}

/* =========================
   보세재고 목록 페이지네이션
========================= */
.inventory-pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 6px;

  padding: 16px 0;
  background: #fff;
  border-top: 1px solid #eef2f7;
}

.inventory-pagination .page-btn {
  min-width: 32px;
  height: 32px;
  padding: 0 10px;

  border: 1px solid #cbd5e1;
  background: #fff;
  color: #334155;

  font-size: 13px;
  font-weight: 800;
  line-height: 30px;
  text-align: center;

  cursor: pointer;
  border-radius: 4px;
}

.inventory-pagination .page-btn.active {
  background: #334155;
  border-color: #334155;
  color: #fff;
}

.inventory-pagination .page-btn.disabled,
.inventory-pagination .page-btn:disabled {
  background: #f8fafc;
  color: #94a3b8;
  border-color: #e2e8f0;
  cursor: not-allowed;
}

.inventory-pagination .page-btn:not(.active):not(:disabled):hover {
  background: #f8fafc;
  border-color: #94a3b8;
}