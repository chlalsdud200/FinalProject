    @PostMapping({"/import/unloading-in/supplement.do", "/import/unloading-in/supplement"})
    @ResponseBody
    public Map<String, Object> modifyImpUnloadingInSupplement(
            @RequestParam String wirNo,
            @RequestParam(required = false) String receiverId,
            @RequestParam(required = false) String wmId,
            @RequestParam(required = false) String wzNo,
            @RequestParam(required = false) String inPlanDt,
            @RequestParam(required = false) String cargoMgmtNo,
            @RequestParam(required = false) String invoiceNo,
            @RequestParam(required = false) String incoTermsCd,
            @RequestParam(required = false) String remark,
            @RequestParam(required = false) String goodsJson,
            Authentication authentication
    ) {
        List<TransportRequestVO> goodsList = parseTransportGoodsList(goodsJson);
        boolean success = importTransportService.modifyImpUnloadingInSupplement(
                wirNo,
                receiverId,
                wmId,
                wzNo,
                inPlanDt,
                cargoMgmtNo,
                invoiceNo,
                incoTermsCd,
                remark,
                goodsList,
                resolveActorId(authentication, receiverId)

        );
        return Map.of(
                "success", success,
                "message", success ? "보세구역 입고신청 보완제출이 완료되었습니다." : "보완제출 대상이 없습니다."
        );
    }

    private List<TransportRequestVO> parseTransportGoodsList(String goodsJson) {
        if (goodsJson == null || goodsJson.isBlank()) {
            return List.of();
        }
        try {
            return objectMapper.readValue(goodsJson, new TypeReference<List<TransportRequestVO>>() {});
        } catch (JsonProcessingException e) {
            return List.of();
        }
    }

