    @GetMapping({"/import/manifest/packing-text", "/import/manifest/packing-text.do"})
    @ResponseBody
    public Map<String, Object> retriveImpPackingListText(@RequestParam Long fileNo) {
        FileInfoDTO fileInfo = fileService.getFileInfo(fileNo);
        if (fileInfo == null || fileInfo.getDfiDriveFileId() == null || fileInfo.getDfiDriveFileId().isBlank()) {
            return Map.of("success", false, "text", "", "message", "포장명세서 파일 정보가 없습니다.");
        }

        try (PDDocument document = Loader.loadPDF(googleDriveService.downloadFile(fileInfo.getDfiDriveFileId()))) {
            String text = new PDFTextStripper().getText(document);
            return Map.of("success", true, "text", text == null ? "" : text);
        } catch (Exception e) {
            return Map.of("success", false, "text", "", "message", "포장명세서 PDF 텍스트 추출에 실패했습니다.");
        }
    }

    /**
     * 업로드한 포장명세서 PDF 텍스트 추출
     *
     * DB에 저장하지 않고, 적하목록 조회 화면에서 임시 업로드한 PDF를
     * PDFBox로 텍스트 추출하여 화면 대조용으로만 사용한다.
     */
    @PostMapping({"/import/manifest/upload-packing-text", "/import/manifest/upload-packing-text.do"})
    @ResponseBody
    public Map<String, Object> retriveUploadedImpPackingListText(@RequestParam("file") MultipartFile file) {
        if (file == null || file.isEmpty()) {
            return Map.of("success", false, "text", "", "message", "업로드된 PDF 파일이 없습니다.");
        }

        try (PDDocument document = Loader.loadPDF(file.getBytes())) {
            String text = new PDFTextStripper().getText(document);
            return Map.of(
                    "success", true,
                    "text", text == null ? "" : text,
                    "fileName", file.getOriginalFilename() == null ? "" : file.getOriginalFilename()
            );
        } catch (Exception e) {
            return Map.of("success", false, "text", "", "message", "업로드한 포장명세서 PDF 텍스트 추출에 실패했습니다.");
        }
    }

