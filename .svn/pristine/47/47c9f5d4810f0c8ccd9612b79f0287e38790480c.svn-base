    @PostMapping({"/import/release-request/supplement.do", "/import/release-request/supplement"})
    @ResponseBody
    public Map<String, Object> registImpReleaseSupplement(
            @RequestParam(required = false) String releaseReqNo,
            @RequestParam(required = false) String trcNo,
            @RequestParam(required = false) String receiverId,
            @RequestParam(required = false) String wmId,
            @RequestParam(required = false) String wzNo,
            @RequestParam(required = false) String releaseReqDt,
            @RequestParam(required = false) String itemNm,
            @RequestParam(required = false) String remark,
            @RequestParam(required = false) String goodsJson,
            @RequestParam(required = false) String suppTypeCd,
            @RequestParam(required = false) String suppReqCn,
            Authentication authentication
    ) {
        List<TransportRequestVO> goodsList = parseTransportGoodsList(goodsJson);
        boolean success = importTransportService.modifyImpReleaseSupplement(
                releaseReqNo,
                trcNo,
                receiverId,
                wmId,
                wzNo,
                releaseReqDt,
                itemNm,
                remark,
                goodsList,
                suppTypeCd,
                suppReqCn,
                resolveActorId(authentication, receiverId)
        );
        return Map.of(
                "success", success,
                "message", success ? "보세구역 반출요청 보완요청이 등록되었습니다." : "보완요청 등록 대상이 없습니다."
        );
    }

    @GetMapping("/import/inland-dispatch/list.do")
    @ResponseBody
    public List<TransportRequestVO> retriveImpInlandDispatchList() {
        return importTransportService.retriveImpInlandDispatchList();
    }

    @GetMapping("/import/inland-dispatch/cars.do")
    @ResponseBody
    public List<TransportRequestVO> retriveImpAvailableCarList() {
        return importTransportService.retriveImpAvailableCarList();
    }

    @PostMapping("/import/inland-dispatch/assign.do")
    @ResponseBody
    public Map<String, Object> modifyImpInlandDispatch(@RequestParam("trcNo") String trcNo,
                                                       @RequestParam(value = "carNo", required = false) Integer carNo,
                                                       @RequestParam(value = "destinationAdres", required = false) String destinationAdres,
                                                       @RequestParam(value = "pickupDt", required = false) String pickupDt) {
        TransportRequestVO vo = new TransportRequestVO();
        vo.setTrcNo(trcNo);
        vo.setCarNo(carNo);
        vo.setDestinationAdres(destinationAdres);
        vo.setPickupDt(pickupDt);

        int cnt = importTransportService.modifyImpInlandDispatch(vo);
        if (cnt > 0) {
            return Map.of("success", true, "message", "배차가 완료되었습니다.");
        }
        return Map.of("success", false, "message", "배차 처리 대상이 없습니다.");
    }

}
