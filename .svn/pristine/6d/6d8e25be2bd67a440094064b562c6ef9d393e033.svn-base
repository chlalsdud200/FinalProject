function buildShippingSupplementRequestPanel() {
  const selectedDocLabel = selectedShippingDoc ? `${selectedShippingDoc.requestNo} / ${selectedShippingDoc.docName}` : '선적서류 수신 화면에서 선택된 서류 없음';
  const senderLabel = selectedShippingDoc ? `${selectedShippingDoc.sender} / ${selectedShippingDoc.owner}` : '';

  return `
    <div class="section-card border border-slate-300">
      <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
        <h4 class="text-sm font-bold text-slate-900">선적 서류 검토 및 보완요청</h4>
      </div>
      <div class="p-6 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label class="field-label">검토대상 서류</label>
            <input class="field-input bg-slate-50" type="text" value="${selectedDocLabel}" readonly />
          </div>
          <div>
            <label class="field-label">요청 대상</label>
            <input class="field-input bg-slate-50" type="text" value="${senderLabel}" placeholder="요청 대상 자동 반영" readonly />
          </div>
          <div>
            <label class="field-label">보완기한</label>
            <input class="field-input" type="datetime-local" />
          </div>
          <div>
            <label class="field-label">요청명</label>
            <input class="field-input" type="text" placeholder="보완 요청 제목을 입력하세요." value="" />
          </div>
          <div class="md:col-span-2">
            <label class="field-label">요청내용</label>
            <textarea class="field-textarea h-32" placeholder="보완 요청 내용을 입력하세요."></textarea>
          </div>
        </div>
      </div>
      <div class="section-card-action-footer flex justify-end gap-2 px-6 py-4 border-t border-slate-200">
        <button id="shippingSupplementProcessBtn" class="px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">처리</button>
      </div>
    </div>
  `;
}

function bindReceiveListActions(groupKey, itemId) {
  if (!['TACS-FW-005','TACS-FW-019'].includes(itemId)) return;

  function applyRowState(row, status) {
    if (!row) return;
    const statusCell = row.querySelector('.receive-status-cell');
    const actionCell = row.lastElementChild;
    const normalizedStatus = status || '미확인';

    if (statusCell) statusCell.innerHTML = buildStatusChip(normalizedStatus);

    if (actionCell) {
      if (normalizedStatus === '미확인') {
        actionCell.innerHTML = `<div class="flex gap-2"><button class="receive-doc-confirm-btn px-3 py-1 bg-slate-800 text-white text-xs font-bold">확인</button><button class="receive-doc-reject-btn px-3 py-1 border border-slate-300 bg-white text-slate-700 text-xs font-bold">반려</button></div>`;
      } else {
        actionCell.innerHTML = buildStatusChip(normalizedStatus);
      }
    }
  }

  function hydrateRowButtons(row) {
    if (!row) return;
    const rejectBtn = row.querySelector('.receive-doc-reject-btn');
    const confirmBtn = row.querySelector('.receive-doc-confirm-btn');
    const key = rejectBtn ? getShippingDocKey(groupKey, rejectBtn.dataset.requestNo, rejectBtn.dataset.docName) : '';
    const saved = key ? shippingDocStatusOverrides[key] : null;

    if (saved && saved.status) {
      applyRowState(row, saved.status);
      return;
    }

    const statusCell = row.querySelector('.receive-status-cell');
    if (statusCell) {
      const value = (statusCell.textContent || '').trim() || '미확인';
      statusCell.innerHTML = buildStatusChip(value);
    }

    if (confirmBtn) {
      confirmBtn.addEventListener('click', function() {
        const currentRow = this.closest('tr');
        const rejectRef = currentRow ? currentRow.querySelector('.receive-doc-reject-btn') : null;
        const requestNo = rejectRef ? rejectRef.dataset.requestNo : '';
        const docName = rejectRef ? rejectRef.dataset.docName : '';
        const overrideKey = getShippingDocKey(groupKey, requestNo, docName);
        shippingDocStatusOverrides[overrideKey] = { status: '확인완료' };
        applyRowState(currentRow, '확인완료');
      });
    }

    if (rejectBtn) {
      rejectBtn.addEventListener('click', function() {
        selectedShippingDoc = {
          groupKey,
          requestNo: this.dataset.requestNo,
          owner: this.dataset.owner,
          docName: this.dataset.docName,
          receivedAt: this.dataset.receivedAt,
          sender: this.dataset.sender,
          receiveStatus: this.dataset.receiveStatus,
          key: getShippingDocKey(groupKey, this.dataset.requestNo, this.dataset.docName)
        };
        if (typeof window.openShippingDocRejectModal === 'function') {
          window.openShippingDocRejectModal(this, groupKey);
        } else {
          alert('반려 모달을 불러오는 중입니다. 다시 시도해주세요.');
        }
      });
    }
  }

  detailBody.querySelectorAll('tbody tr').forEach(hydrateRowButtons);
}

function bindShippingSupplementRequestActions(groupKey, itemId) {
  if (!['TACS-FW-006', 'TACS-FW-019R'].includes(itemId)) return;

  const processBtn = detailBody.querySelector('#shippingSupplementProcessBtn');
  if (!processBtn) return;

  processBtn.addEventListener('click', function() {
    const sourceGroupKey = selectedShippingDoc?.groupKey || groupKey;
    const returnItemId = sourceGroupKey === 'import' ? 'TACS-FW-019' : 'TACS-FW-005';
    const docKey = selectedShippingDoc?.key || getShippingDocKey(sourceGroupKey, selectedShippingDoc?.requestNo, selectedShippingDoc?.docName);

    if (docKey) {
      shippingDocStatusOverrides[docKey] = {
        status: '반려',
        sentTo: selectedShippingDoc?.owner || '화주'
      };
    }

    alert(`${selectedShippingDoc?.owner || '화주'}에게 보완 요청이 발송되었습니다.`);
    openDetail(sourceGroupKey, returnItemId);
  });
}



function buildDraftBLReviewPanel() {
  return `
    <div class="section-card border border-slate-300">
      <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
        <h4 class="text-sm font-bold text-slate-900">House B/L 발행 및 전달</h4>
        <button class="house-bl-issue-open-btn px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">발행</button>
      </div>
      <div class="p-6 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
          <div><label class="field-label">House B/L 번호</label><input class="field-input" type="text" placeholder="House B/L 번호 검색" /></div>
          <div><label class="field-label">화주명</label><input class="field-input" type="text" placeholder="화주명 검색" /></div>
          <div><label class="field-label">바이어</label><input class="field-input" type="text" placeholder="바이어 검색" /></div>
          <div><label class="field-label">발행상태</label><select class="field-select"><option>전체</option><option>발행대기</option><option>발행완료</option><option>전달대기</option><option>전달완료</option></select></div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full tbl">
            <thead>
              <tr>
                <th>House B/L 번호</th>
                <th>화주명</th>
                <th>바이어</th>
                <th>발행예정일</th>
                <th>발행상태</th>
                <th>전달상태</th>
                <th>상태</th>
              </tr>
            </thead>
            <tbody class="text-sm text-slate-700">
              <tr><td colspan="7" class="text-center text-slate-500 py-6">조회된 B/L 발행 대상이 없습니다.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  `;
}

function buildBLCorrectionRequestPanel() {
  const draftNo = selectedDraftBL ? selectedDraftBL.draftNo : '';
  const owner = selectedDraftBL ? (selectedDraftBL.owner || '') : '';
  const product = selectedDraftBL ? (selectedDraftBL.product || '') : '';
  const beforeValue = selectedDraftBL ? (selectedDraftBL.beforeValue || '') : '';
  const afterValue = selectedDraftBL ? (selectedDraftBL.afterValue || '') : '';
  const reason = selectedDraftBL ? (selectedDraftBL.reason || '') : '';

  return `
    <div class="section-card border border-slate-300">
      <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
        <h4 class="text-sm font-bold text-slate-900">B/L 정정요청 수신</h4>
      </div>
      <div class="p-6">
        <div class="overflow-x-auto border border-slate-200">
          <table class="w-full tbl">
            <thead>
              <tr><th class="w-48">항목명</th><th>설명</th></tr>
            </thead>
            <tbody class="text-sm text-slate-700">
              <tr>
                <td class="font-bold">House B/L 번호</td>
                <td><input id="blCorrectionNo" class="field-input bg-slate-50" type="text" value="${draftNo}" readonly /></td>
              </tr>
              <tr>
                <td class="font-bold">정정대상</td>
                <td><input id="blCorrectionTarget" class="field-input bg-slate-50" type="text" value="화주명: ${owner} / 품목: ${product}" readonly /></td>
              </tr>
              <tr>
                <td class="font-bold">변경 전</td>
                <td><input id="blCorrectionBefore" class="field-input bg-slate-50" type="text" value="${beforeValue}" readonly /></td>
              </tr>
              <tr>
                <td class="font-bold">변경 후</td>
                <td><input id="blCorrectionAfter" class="field-input" type="text" value="${afterValue}" placeholder="변경 후 데이터 입력" /></td>
              </tr>
              <tr>
                <td class="font-bold">사유</td>
                <td><input id="blCorrectionReason" class="field-input" type="text" value="${reason}" placeholder="사유 입력" /></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="section-card-action-footer flex justify-end gap-2 px-6 py-4 border-t border-slate-200">
        <button class="px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">처리</button>
      </div>
    </div>
  `;
}

function buildOriginalBLDeliveryPanel() {
  const selectedLabel = selectedOriginalBL ? `${selectedOriginalBL.docNo} / ${selectedOriginalBL.owner}` : '전달할 Original House B/L을 선택하세요.';
  return `
    <div class="section-card border border-slate-300">
      <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
        <h4 class="text-sm font-bold text-slate-900">Original House B/L 수령 및 전달</h4>
      </div>
      <div class="p-6 space-y-6">
        <div class="overflow-x-auto">
          <table class="w-full tbl">
            <thead>
              <tr>
                <th>서류번호</th>
                <th>화주명</th>
                <th>문서구분</th>
                <th>수령일시</th>
                <th>상태</th>
                <th>상태</th>
              </tr>
            </thead>
            <tbody class="text-sm text-slate-700">
              <tr><td colspan="6" class="text-center text-slate-500 py-6">조회된 Original B/L 전달 대상이 없습니다.</td></tr>
            </tbody>
          </table>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div><label class="field-label">선택 서류</label><input class="field-input bg-slate-50" type="text" value="${selectedLabel}" readonly /></div>
          <div><label class="field-label">수령일</label><input class="field-input" type="datetime-local" value="" /></div>
          <div><label class="field-label">전달대상</label><input class="field-input" type="text" value="${selectedOriginalBL ? selectedOriginalBL.owner + ' 담당자' : ''}" placeholder="전달받는 사람 입력" /></div>
          <div><label class="field-label">전달방법</label><select class="field-select"><option>선택</option><option>직접 전달</option><option>퀵 발송</option><option>우편 발송</option><option>전자문서 전달</option></select></div>
          <div><label class="field-label">전달일</label><input class="field-input" type="datetime-local" /></div>
          <div><label class="field-label">확인여부</label><select class="field-select"><option>선택</option><option>여</option><option>부</option></select></div>
          <div class="md:col-span-2"><label class="field-label">전달 메모</label><textarea class="field-textarea h-28" placeholder="전달 관련 특이사항 입력">${selectedOriginalBL ? selectedOriginalBL.docType + ' 전달 예정' : ''}</textarea></div>
        </div>
      </div>
      <div class="section-card-action-footer flex justify-end gap-2 px-6 py-4 border-t border-slate-200">
        <button class="px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">처리</button>
      </div>
    </div>
  `;
}

function bindDraftBLActions(groupKey, itemId) {
  if (itemId !== 'TACS-FW-012') return;

  detailBody.querySelectorAll('.draft-bl-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      selectedDraftBL = {
        draftNo: this.dataset.draftNo,
        owner: this.dataset.owner,
        carrier: this.dataset.carrier,
        receivedAt: this.dataset.receivedAt,
        errorYn: this.dataset.errorYn,
        errorItems: this.dataset.errorItems,
        reviewStatus: this.dataset.reviewStatus
      };
      openDetail(groupKey, 'TACS-FW-013');
    });
  });
}

function bindOriginalBLActions(groupKey, itemId) {
  if (itemId !== 'TACS-FW-014') return;

  detailBody.querySelectorAll('.original-bl-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      selectedOriginalBL = {
        docNo: this.dataset.docNo,
        owner: this.dataset.owner,
        docType: this.dataset.docType,
        receivedAt: this.dataset.receivedAt
      };
      openDetail(groupKey, 'TACS-FW-014');
    });
  });
}
