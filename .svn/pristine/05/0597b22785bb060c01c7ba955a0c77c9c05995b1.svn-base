<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.tacs.transport.importp.mapper.ImportTransportMapper">
      <!-- 수입운송 D/O 탭에서 정산, D/O 발급, 파일 상태를 관리한다. -->

      <select id="retriveImpDoList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">

            SELECT
            T.TRC_NO                                  AS trcNo
            , T.TRC_OWR_ID                            AS ownerId
            , NVL(O.OWR_NM, T.TRC_OWR_ID)             AS ownerNm

            , W.WIR_NO                                AS wirNo
            , W.WIR_STATUS_CD                         AS warehouseInStatusCd
            , W.WIR_WH_REPLY_STATUS_CD                AS warehouseReplyStatusCd
            , CASE
            WHEN W.WIR_STATUS_CD = 'IN_DONE' AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN 'IN_DONE'
            WHEN W.WIR_STATUS_CD = 'REQ_FIX' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN 'REQ_FIX'
            WHEN W.WIR_STATUS_CD = 'REQ_SENT' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN 'REQ_SENT'
            WHEN W.WIR_STATUS_CD IN ('REJECT', 'REJECTED') OR W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED') THEN 'REJECT'
            WHEN W.WIR_STATUS_CD = 'WAIT' OR W.WIR_WH_REPLY_STATUS_CD = 'WAIT' THEN 'WAIT'
            WHEN W.WIR_STATUS_CD IS NULL AND W.WIR_WH_REPLY_STATUS_CD IS NULL THEN NULL
            ELSE 'WAIT'
            END                                      AS warehouseInStatusNm
            , CASE
            WHEN W.WIR_STATUS_CD = 'IN_DONE' AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN 'Y'
            ELSE 'N'
            END                                      AS warehouseInDoneYn

            , CASE
            WHEN W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            THEN DI.DI_DO_NO
            ELSE NULL
            END                                      AS doNo

            , CASE
            WHEN W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            THEN NVL(DI.DI_STATUS_CD, 'TRC_DO_READY')
            ELSE NULL
            END                                      AS doStatusCd

            , CASE
            WHEN W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            THEN NVL(DO_CODE.CC_NM, CASE NVL(DI.DI_STATUS_CD, 'TRC_DO_READY')
            WHEN 'TRC_DO_READY' THEN 'TRC_DO_READY'
            WHEN 'TRC_DO_ISSUED' THEN 'TRC_DO_ISSUED'
            WHEN 'TRC_DO_REQ' THEN 'TRC_DO_REQ'
            ELSE DI.DI_STATUS_CD
            END)
            ELSE NULL
            END                                      AS doStatusNm

            , DI.DI_HBL_PRESENT_YN                    AS hblPresentYn
            , DI.DI_DO_FEE                            AS doFee
            , TO_CHAR(DI.DI_REQ_DT, 'YYYY-MM-DD')     AS doReqDt
            , TO_CHAR(DI.DI_RECEIVE_DT, 'YYYY-MM-DD') AS doReceiveDt
            , NVL(DI.DI_DLVRY_OWR_NM, NVL(O.OWR_NM, T.TRC_OWR_ID)) AS deliveryTargetNm
            , TO_CHAR(DI.DI_DLVRY_DT, 'YYYY-MM-DD')   AS deliveryDt
            , DI.DI_DLVRY_MTHD_CD                     AS deliveryMethodCd
            , DI.DI_ISSUER_NM                         AS doIssuerNm
            , NVL(DI.DI_ISSU_OWR_NM, NVL(WM.WM_NM, W.WIR_WM_ID)) AS issueTargetNm
            , DI.DI_TFG_NO                            AS doTfgNo
            , NVL(T.TRC_CERT_TFG_NO, DI.DI_TFG_NO)  AS doCertTfgNo
            , DO_PDF_FILE.DFI_FILE_NO                 AS doPdfFileNo
            , DO_PDF_FILE.DFI_ORG_NM                  AS doPdfFile
            , NVL(DO_CERT_FILE_DI.DFI_FILE_NO, DO_CERT_FILE_TRC.DFI_FILE_NO) AS doCertFileNo
            , CASE
                WHEN DO_CERT_FILE_DI.DFI_ORG_NM IS NOT NULL AND DO_CERT_FILE_TRC.DFI_ORG_NM IS NOT NULL THEN DO_CERT_FILE_DI.DFI_ORG_NM || ', ' || DO_CERT_FILE_TRC.DFI_ORG_NM
                ELSE NVL(DO_CERT_FILE_DI.DFI_ORG_NM, DO_CERT_FILE_TRC.DFI_ORG_NM)
              END                                  AS doCertFile
            , CASE
                WHEN DO_CERT_FILE_DI.DFI_FILE_NO IS NOT NULL OR DO_CERT_FILE_TRC.DFI_FILE_NO IS NOT NULL THEN 'Y'
                ELSE NVL(T.TRC_CERT_YN, 'N')
              END                                  AS certYn
            , CASE
                WHEN DO_CERT_FILE_DI.DFI_FILE_NO IS NOT NULL OR DO_CERT_FILE_TRC.DFI_FILE_NO IS NOT NULL THEN '수신완료'
                ELSE '미수신'
              END                                  AS certStatusNm
            , NVL(DO_CERT_FILE_DI.DFI_FILE_NO, DO_CERT_FILE_TRC.DFI_FILE_NO) AS customsCertFileNo
            , CASE
                WHEN DO_CERT_FILE_DI.DFI_ORG_NM IS NOT NULL AND DO_CERT_FILE_TRC.DFI_ORG_NM IS NOT NULL THEN DO_CERT_FILE_DI.DFI_ORG_NM || ', ' || DO_CERT_FILE_TRC.DFI_ORG_NM
                ELSE NVL(DO_CERT_FILE_DI.DFI_ORG_NM, DO_CERT_FILE_TRC.DFI_ORG_NM)
              END                                  AS customsCertFile
            , NVL(DO_CERT_FILE_DI.DFI_FILE_NO, DO_CERT_FILE_TRC.DFI_FILE_NO) AS importDeclCertFileNo
            , CASE
                WHEN DO_CERT_FILE_DI.DFI_ORG_NM IS NOT NULL AND DO_CERT_FILE_TRC.DFI_ORG_NM IS NOT NULL THEN DO_CERT_FILE_DI.DFI_ORG_NM || ', ' || DO_CERT_FILE_TRC.DFI_ORG_NM
                ELSE NVL(DO_CERT_FILE_DI.DFI_ORG_NM, DO_CERT_FILE_TRC.DFI_ORG_NM)
              END                                  AS importDeclCertFile

            , TCS.TCS_NO                              AS tcsNo
            , COALESCE(M.ICM_MBL_NO, BI.BI_MBL_NO, TCS.TCS_MBL_NO, (SELECT MAX(IR.IR_BL_AWB_NO)
            FROM IMP_RQST IR
            WHERE (IR.IR_NO = T.TRC_NO OR IR.IR_NO = REPLACE(T.TRC_NO, 'TRC-', '') OR IR.IR_OWR_ID = T.TRC_OWR_ID)
            AND IR.IR_BL_AWB_NO IS NOT NULL)) AS mblNo
            , COALESCE(M.ICM_HBL_NO, BI.BI_HBL_NO, TCS.TCS_HBL_NO, TCS.TCS_MBL_NO, (SELECT MAX(IR.IR_BL_AWB_NO)
            FROM IMP_RQST IR
            WHERE (IR.IR_NO = T.TRC_NO OR IR.IR_NO = REPLACE(T.TRC_NO, 'TRC-', '') OR IR.IR_OWR_ID = T.TRC_OWR_ID)
            AND IR.IR_BL_AWB_NO IS NOT NULL), TO_CHAR(T.TRC_BI_NO)) AS hblNo

            , NVL(TCS.TCS_FRGT_AMT, 0)                AS freightAmt
            , NVL(TCS.TCS_FRGT_AMT, 0)                AS importFreightCost
            , NVL(TCS.TCS_FRGT_AMT, 0)                AS freightCost
            , NVL(TCS.TCS_FRGT_AMT, 0)                AS importFreightAmt
            , NVL(TCS.TCS_FRGT_AMT, 0)                AS tcsFrgtAmt
            , NVL(TCS.TCS_FRGT_AMT, 0)                AS tcsFrgtCost
            , NVL(TCS.TCS_WH_AMT, 0)                  AS warehouseAmt
            , NVL(TCS.TCS_WH_AMT, 0)                  AS warehouseCost
            , NVL(TCS.TCS_WH_AMT, 0)                  AS whCost
            , NVL(TCS.TCS_WH_AMT, 0)                  AS warehouseFee
            , NVL(TCS.TCS_WH_AMT, 0)                  AS tcsWhAmt
            , NVL(TCS.TCS_WH_AMT, 0)                  AS tcsWhCost
            , NVL(TCS.TCS_TOT_BILL_AMT, 0)            AS totalBillAmt
            , NVL(TCS.TCS_TOT_BILL_AMT, 0)            AS totalCost
            , NVL(TCS.TCS_TOT_BILL_AMT, 0)            AS billTotalCost
            , NVL(TCS.TCS_TOT_BILL_AMT, 0)            AS totalAmt
            , NVL(TCS.TCS_TOT_BILL_AMT, 0)            AS tcsTotBillAmt
            , NVL(TCS.TCS_TOT_BILL_AMT, 0)            AS tcsTotalCost
            , NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID')    AS settlementStatusCd
            , NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID')    AS tcsStlStatusCd
            , CASE NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID')
            WHEN 'TRC_STL_UNPAID' THEN '미정산'
            WHEN 'UNPAID'         THEN '미정산'
            WHEN 'TRC_STL_REQ'    THEN '정산요청'
            WHEN 'REQ'            THEN '정산요청'
            WHEN 'REQUEST'        THEN '정산요청'
            WHEN 'REQUESTED'      THEN '정산요청'
            WHEN 'TRC_STL_PAID'   THEN '정산완료'
            WHEN 'PAID'           THEN '정산완료'
            ELSE TCS.TCS_STL_STATUS_CD
            END                                      AS settlementStatusNm
            , CASE NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID')
            WHEN 'TRC_STL_UNPAID' THEN '미정산'
            WHEN 'UNPAID'         THEN '미정산'
            WHEN 'TRC_STL_REQ'    THEN '정산요청'
            WHEN 'REQ'            THEN '정산요청'
            WHEN 'REQUEST'        THEN '정산요청'
            WHEN 'REQUESTED'      THEN '정산요청'
            WHEN 'TRC_STL_PAID'   THEN '정산완료'
            WHEN 'PAID'           THEN '정산완료'
            ELSE TCS.TCS_STL_STATUS_CD
            END                                      AS tcsStlStatusNm
            , CASE WHEN NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID') IN ('TRC_STL_REQ', 'REQ', 'REQUEST', 'REQUESTED') THEN 'Y' ELSE 'N' END AS settlementRequestedYn
            , CASE WHEN NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID') IN ('TRC_STL_PAID', 'PAID') THEN 'Y' ELSE 'N' END AS settlementPaidYn
            , CASE WHEN NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID') IN ('TRC_STL_REQ', 'REQ', 'REQUEST', 'REQUESTED', 'TRC_STL_PAID', 'PAID') THEN 'Y' ELSE 'N' END AS settlementReadonlyYn
            , TCS.TCS_STL_EXPLN                       AS settlementExpln
            , TCS.TCS_STL_EXPLN                       AS settlementDesc
            , TCS.TCS_STL_EXPLN                       AS tcsStlExpln
            , TO_CHAR(T.TRC_RQST_DT, 'YYYY-MM-DD')    AS requestDt

            FROM TRAN_RCP T
            LEFT JOIN OWNER O
            ON O.OWR_ID = T.TRC_OWR_ID

            LEFT JOIN (
            SELECT *
            FROM (
            SELECT
            W0.*
            , ROW_NUMBER() OVER (
            PARTITION BY W0.WIR_GG_NO
            ORDER BY
            CASE
            WHEN W0.WIR_STATUS_CD = 'IN_DONE' OR W0.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN 1
            WHEN W0.WIR_STATUS_CD = 'REQ_SENT' OR W0.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN 2
            WHEN W0.WIR_STATUS_CD = 'REQ_FIX' OR W0.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN 3
            ELSE 4
            END,
            W0.WIR_IN_PLAN_DT DESC NULLS LAST,
            W0.WIR_NO DESC
            ) AS RN
            FROM WH_IN_RPT W0
            WHERE W0.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            )
            WHERE RN = 1
            ) W
            ON W.WIR_GG_NO = T.TRC_TFG_NO

            LEFT JOIN WAREHOUSE_MANAGER WM
            ON WM.WM_ID = W.WIR_WM_ID

            LEFT JOIN DO_ISSUANCE DI
            ON DI.DI_TRC_NO = T.TRC_NO
            AND NVL(DI.DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')

            LEFT JOIN COM_CODE DO_CODE
            ON DO_CODE.CC_CCG_ID = 'DO_STATUS'
            AND DO_CODE.CC_CD = DI.DI_STATUS_CD
            AND NVL(DO_CODE.CC_USE_YN, 'Y') = 'Y'

            LEFT JOIN (
            SELECT
            FM.TFM_TFG_NO
            , LISTAGG(TO_CHAR(FD.DFI_FILE_NO), ', ') WITHIN GROUP (ORDER BY FM.TFM_NO) AS DFI_FILE_NO
            , LISTAGG(FD.DFI_ORG_NM, ', ') WITHIN GROUP (ORDER BY FM.TFM_NO) AS DFI_ORG_NM
            FROM TACS_FILE_MAP FM
            INNER JOIN DOCS_FILE_DATA FD
            ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
            AND FD.DFI_DEL_YN = 'N'
            WHERE (
            NVL(FM.TFM_DOC_TY_CD, 'IMP_DO') = 'IMP_DO'
            OR FD.DFI_BIZ_TY_CD = 'IMP_DO'
            OR LOWER(FD.DFI_ORG_NM) LIKE '%do%'
            OR LOWER(FD.DFI_ORG_NM) LIKE '%d/o%'
            OR LOWER(FD.DFI_ORG_NM) LIKE '%d_o%'
            OR LOWER(FD.DFI_ORG_NM) LIKE '%delivery%'
            )
            AND NOT (
            UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN ('CUSTOMS_CERT', 'IMP_DO_CERT')
            OR FD.DFI_BIZ_TY_CD = 'IMP_DO_CERT'
            OR LOWER(FD.DFI_ORG_NM) LIKE '%cert%'
            OR LOWER(FD.DFI_ORG_NM) LIKE '%declaration%'
            OR FD.DFI_ORG_NM LIKE '%신고%'
            OR FD.DFI_ORG_NM LIKE '%필증%'
            )
            GROUP BY FM.TFM_TFG_NO
            ) DO_PDF_FILE
            ON DO_PDF_FILE.TFM_TFG_NO = DI.DI_TFG_NO

        LEFT JOIN (
            SELECT
                FM.TFM_TFG_NO
                , MAX(FD.DFI_FILE_NO) KEEP (DENSE_RANK LAST ORDER BY FM.TFM_NO, FD.DFI_FILE_NO) AS DFI_FILE_NO
                , LISTAGG(FD.DFI_ORG_NM, ', ') WITHIN GROUP (ORDER BY FM.TFM_NO) AS DFI_ORG_NM
            FROM TACS_FILE_MAP FM
            JOIN DOCS_FILE_DATA FD
              ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
             AND NVL(FD.DFI_DEL_YN, 'N') = 'N'
             AND NVL(FD.DFI_UPLOAD_STTS_CD, 'DONE') = 'DONE'
            WHERE (
                    UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN (
                        'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
                        'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
                    )
                 OR UPPER(NVL(FD.DFI_BIZ_TY_CD, 'X')) IN (
                        'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
                        'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
                    )
                 OR FD.DFI_ORG_NM LIKE '%수입신고필증%'
                 OR FD.DFI_ORG_NM LIKE '%수입신고%'
                 OR FD.DFI_ORG_NM LIKE '%신고필증%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%import%declar%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%declaration%cert%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%certificate%'
            )
            AND NOT (
                    UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN (
                        'IMP_INVOICE', 'INVOICE', 'INV', 'IMP_PACKING_LIST', 'PACKING_LIST', 'PACKING', 'PL'
                    )
                 OR UPPER(NVL(FD.DFI_BIZ_TY_CD, 'X')) IN (
                        'IMP_INVOICE', 'INVOICE', 'INV', 'IMP_PACKING_LIST', 'PACKING_LIST', 'PACKING', 'PL'
                    )
                 OR FD.DFI_ORG_NM LIKE '%송장%'
                 OR FD.DFI_ORG_NM LIKE '%포장%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%invoice%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%packing%'
            )
            GROUP BY FM.TFM_TFG_NO
        ) DO_CERT_FILE_DI
          ON DO_CERT_FILE_DI.TFM_TFG_NO = DI.DI_TFG_NO
        LEFT JOIN (
            SELECT
                FM.TFM_TFG_NO
                , MAX(FD.DFI_FILE_NO) KEEP (DENSE_RANK LAST ORDER BY FM.TFM_NO, FD.DFI_FILE_NO) AS DFI_FILE_NO
                , LISTAGG(FD.DFI_ORG_NM, ', ') WITHIN GROUP (ORDER BY FM.TFM_NO) AS DFI_ORG_NM
            FROM TACS_FILE_MAP FM
            JOIN DOCS_FILE_DATA FD
              ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
             AND NVL(FD.DFI_DEL_YN, 'N') = 'N'
             AND NVL(FD.DFI_UPLOAD_STTS_CD, 'DONE') = 'DONE'
            WHERE (
                    UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN (
                        'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
                        'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
                    )
                 OR UPPER(NVL(FD.DFI_BIZ_TY_CD, 'X')) IN (
                        'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
                        'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
                    )
                 OR FD.DFI_ORG_NM LIKE '%수입신고필증%'
                 OR FD.DFI_ORG_NM LIKE '%수입신고%'
                 OR FD.DFI_ORG_NM LIKE '%신고필증%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%import%declar%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%declaration%cert%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%certificate%'
            )
            AND NOT (
                    UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN (
                        'IMP_INVOICE', 'INVOICE', 'INV', 'IMP_PACKING_LIST', 'PACKING_LIST', 'PACKING', 'PL'
                    )
                 OR UPPER(NVL(FD.DFI_BIZ_TY_CD, 'X')) IN (
                        'IMP_INVOICE', 'INVOICE', 'INV', 'IMP_PACKING_LIST', 'PACKING_LIST', 'PACKING', 'PL'
                    )
                 OR FD.DFI_ORG_NM LIKE '%송장%'
                 OR FD.DFI_ORG_NM LIKE '%포장%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%invoice%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%packing%'
            )
            GROUP BY FM.TFM_TFG_NO
        ) DO_CERT_FILE_TRC
          ON DO_CERT_FILE_TRC.TFM_TFG_NO = NVL(T.TRC_CERT_TFG_NO, T.TRC_TFG_NO)
         AND NVL(DI.DI_TFG_NO, -1) &lt;&gt; NVL(T.TRC_CERT_TFG_NO, T.TRC_TFG_NO)

            LEFT JOIN (
            SELECT *
            FROM (
            SELECT X.*,
            ROW_NUMBER() OVER (
            PARTITION BY X.TCS_TRC_NO
            ORDER BY
            CASE
            WHEN NVL(X.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID') IN ('TRC_STL_PAID', 'PAID', 'TRC_STL_REQ', 'REQ', 'REQUEST', 'REQUESTED') THEN 0
            ELSE 1
            END,
            CASE
            WHEN NVL(X.TCS_FRGT_AMT, 0) > 0
            OR NVL(X.TCS_WH_AMT, 0) > 0
            OR NVL(X.TCS_TOT_BILL_AMT, 0) > 0
            THEN 0
            ELSE 1
            END,
            X.TCS_NO DESC
            ) AS RN
            FROM TRAN_COST_STL X
            )
            WHERE RN = 1
            ) TCS
            ON TCS.TCS_TRC_NO = T.TRC_NO

            LEFT JOIN BL_ISSU BI
            ON BI.BI_TRE_ID = T.TRC_NO

            LEFT JOIN (
            SELECT
            ICM_GG_NO
            , ICM_MBL_NO
            , ICM_HBL_NO
            FROM (
            SELECT
            ICM_GG_NO
            , ICM_MBL_NO
            , ICM_HBL_NO
            , ROW_NUMBER() OVER (PARTITION BY ICM_GG_NO ORDER BY ICM_SBMSN_DT DESC NULLS LAST, ICM_NO DESC) AS RN
            FROM IMP_CARGO_MANIFEST
            )
            WHERE RN = 1
            ) M
            ON M.ICM_GG_NO = T.TRC_TFG_NO

            WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
            <if test="tmId != null and tmId != ''">
                  AND T.TRC_TM_NO = (
                  SELECT TM.TM_NO
                  FROM TRANSPORT_MANAGER TM
                  WHERE TM.TM_ID = #{tmId}
                  )
            </if>
            AND (
            T.TRC_STATUS_CD = 'TRC_DONE'
            OR TCS.TCS_STL_STATUS_CD IN ('TRC_STL_REQ', 'TRC_STL_PAID', 'REQ', 'PAID')
            )

            ORDER BY T.TRC_RQST_DT DESC NULLS LAST, T.TRC_NO DESC
      </select>

      <!--
            화주가 수입 운임비/창고비를 납부해서 TRAN_COST_STL이 정산완료가 되면
            운송담당자가 D/O 번호를 손으로 입력하지 않아도 서비스 계층에서 D/O 발급대기 행을 자동 준비한다.
            - 기존 DO_ISSUANCE가 있고 DI_DO_NO만 비어 있으면 번호만 채운다.
            - 기존 DO_ISSUANCE가 없으면 TRC_DO_READY 상태로 새 행을 만든다.
            - D/O 번호는 DO-YYYYMMDD-### 패턴으로 당일 최대 번호 다음 값을 사용한다.
      -->
      <update id="ensureImpDoReadyForPaidSettlement">
            DECLARE
                  V_BASE_DO_SN   NUMBER;
                  V_BASE_TRAN_NO NUMBER;
            BEGIN
                  SELECT NVL(MAX(TO_NUMBER(SUBSTR(DI_DO_NO, -3))), 0)
                  INTO V_BASE_DO_SN
                  FROM DO_ISSUANCE
                  WHERE DI_DO_NO LIKE 'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
                  AND REGEXP_LIKE(SUBSTR(DI_DO_NO, -3), '^[0-9]{3}$');

                  MERGE INTO DO_ISSUANCE D
                  USING (
                        SELECT
                              RID
                              , 'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' ||
                                LPAD(V_BASE_DO_SN + ROW_NUMBER() OVER (ORDER BY TRC_NO), 3, '0') AS NEW_DO_NO
                        FROM (
                              SELECT
                                    D0.ROWID AS RID
                                    , T.TRC_NO
                              FROM DO_ISSUANCE D0
                              INNER JOIN TRAN_RCP T
                              ON T.TRC_NO = D0.DI_TRC_NO
                              INNER JOIN TRAN_COST_STL TCS
                              ON TCS.TCS_TRC_NO = T.TRC_NO
                              INNER JOIN WH_IN_RPT W
                              ON W.WIR_GG_NO = T.TRC_TFG_NO
                              AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
                              AND W.WIR_STATUS_CD = 'IN_DONE'
                              AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
                              WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
                              AND T.TRC_STATUS_CD = 'TRC_DONE'
                              AND NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID') IN ('TRC_STL_PAID', 'PAID')
                              AND NVL(D0.DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')
                              AND D0.DI_DO_NO IS NULL
                              <if test="trcNo != null and trcNo != ''">
                                    AND T.TRC_NO = #{trcNo}
                              </if>
                              <if test="tmId != null and tmId != ''">
                                    AND T.TRC_TM_NO = (
                                          SELECT TM.TM_NO
                                          FROM TRANSPORT_MANAGER TM
                                          WHERE TM.TM_ID = #{tmId}
                                    )
                              </if>
                              GROUP BY D0.ROWID, T.TRC_NO
                        )
                  ) S
                  ON (D.ROWID = S.RID)
                  WHEN MATCHED THEN UPDATE SET
                        D.DI_DO_NO       = S.NEW_DO_NO
                        , D.DI_STATUS_CD = NVL(D.DI_STATUS_CD, 'TRC_DO_READY')
                        , D.DI_TRDE_SE_CD = 'IMP'
                        , D.DI_REQ_DT    = NVL(D.DI_REQ_DT, SYSDATE);

                  SELECT NVL(MAX(TO_NUMBER(SUBSTR(DI_DO_NO, -3))), 0)
                  INTO V_BASE_DO_SN
                  FROM DO_ISSUANCE
                  WHERE DI_DO_NO LIKE 'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
                  AND REGEXP_LIKE(SUBSTR(DI_DO_NO, -3), '^[0-9]{3}$');

                  SELECT NVL(MAX(DI_TRAN_NO), 0)
                  INTO V_BASE_TRAN_NO
                  FROM DO_ISSUANCE;

                  INSERT INTO DO_ISSUANCE (
                        DI_TRAN_NO
                        , DI_TRC_NO
                        , DI_DO_NO
                        , DI_STATUS_CD
                        , DI_REQ_DT
                        , DI_DLVRY_OWR_NM
                        , DI_ISSU_OWR_NM
                        , DI_HBL_PRESENT_YN
                        , DI_DO_FEE
                        , DI_TRDE_SE_CD
                  )
                  SELECT
                        V_BASE_TRAN_NO + RN
                        , TRC_NO
                        , 'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' || LPAD(V_BASE_DO_SN + RN, 3, '0')
                        , 'TRC_DO_READY'
                        , SYSDATE
                        , OWNER_NM
                        , ISSUE_TARGET_NM
                        , 'Y'
                        , 0
                        , 'IMP'
                  FROM (
                        SELECT
                              T.TRC_NO
                              , NVL(O.OWR_NM, T.TRC_OWR_ID) AS OWNER_NM
                              , NVL(WM.WM_NM, W.WIR_WM_ID) AS ISSUE_TARGET_NM
                              , ROW_NUMBER() OVER (ORDER BY T.TRC_NO) AS RN
                        FROM TRAN_RCP T
                        INNER JOIN TRAN_COST_STL TCS
                        ON TCS.TCS_TRC_NO = T.TRC_NO
                        INNER JOIN WH_IN_RPT W
                        ON W.WIR_GG_NO = T.TRC_TFG_NO
                        AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
                        AND W.WIR_STATUS_CD = 'IN_DONE'
                        AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
                        LEFT JOIN OWNER O
                        ON O.OWR_ID = T.TRC_OWR_ID
                        LEFT JOIN WAREHOUSE_MANAGER WM
                        ON WM.WM_ID = W.WIR_WM_ID
                        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
                        AND T.TRC_STATUS_CD = 'TRC_DONE'
                        AND NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID') IN ('TRC_STL_PAID', 'PAID')
                        <if test="trcNo != null and trcNo != ''">
                              AND T.TRC_NO = #{trcNo}
                        </if>
                        <if test="tmId != null and tmId != ''">
                              AND T.TRC_TM_NO = (
                                    SELECT TM.TM_NO
                                    FROM TRANSPORT_MANAGER TM
                                    WHERE TM.TM_ID = #{tmId}
                              )
                        </if>
                        AND NOT EXISTS (
                              SELECT 1
                              FROM DO_ISSUANCE DI
                              WHERE DI.DI_TRC_NO = T.TRC_NO
                              AND NVL(DI.DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')
                        )
                  );
            END;
      </update>

      <update id="updateImpDoDelivered">
            UPDATE DO_ISSUANCE
            SET
            DI_STATUS_CD      = 'TRC_DO_REQ'
            , DI_TRDE_SE_CD   = 'IMP'
            , DI_DLVRY_DT     = TO_DATE(#{deliveryDt}, 'YYYY-MM-DD')
            , DI_DLVRY_OWR_NM = COALESCE(
            NULLIF(#{deliveryTargetNm}, ''),
            (
            SELECT NVL(O.OWR_NM, T.TRC_OWR_ID)
            FROM TRAN_RCP T
            LEFT JOIN OWNER O
            ON O.OWR_ID = T.TRC_OWR_ID
            WHERE T.TRC_NO = #{trcNo}
            ),
            DI_DLVRY_OWR_NM
            )
            , DI_DLVRY_MTHD_CD = COALESCE(
            NULLIF(#{deliveryMethodCd}, ''),
            (
            SELECT W.WIR_WZ_NO
            FROM TRAN_RCP T
            JOIN WH_IN_RPT W
            ON W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            WHERE T.TRC_NO = #{trcNo}
            ORDER BY W.WIR_NO DESC
            FETCH FIRST 1 ROW ONLY
            ),
            DI_DLVRY_MTHD_CD
            )
            WHERE DI_TRC_NO = #{trcNo}
            AND NVL(DI_TRDE_SE_CD, 'IMP') = 'IMP'
            AND EXISTS (
            SELECT 1
            FROM TRAN_RCP T
            JOIN WH_IN_RPT W
            ON W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            AND W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            WHERE T.TRC_NO = #{trcNo}
            AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
            AND T.TRC_STATUS_CD = 'TRC_DONE'
            )
      </update>
      <update id="updateImpDoIssued">

            BEGIN
            UPDATE DO_ISSUANCE D
            SET D.DI_DO_NO = COALESCE(NULLIF(#{doNo,jdbcType=VARCHAR}, ''), D.DI_DO_NO,
            'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' ||
            LPAD((
            SELECT NVL(MAX(TO_NUMBER(SUBSTR(DI_DO_NO, -3))), 0) + 1
            FROM DO_ISSUANCE
            WHERE DI_DO_NO LIKE 'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
            ), 3, '0'))
            , D.DI_STATUS_CD = 'TRC_DO_ISSUED'
            , D.DI_REQ_DT = NVL(D.DI_REQ_DT, SYSDATE)
            , D.DI_RECEIVE_DT = TO_DATE(NVL(#{receiveDt}, TO_CHAR(SYSDATE, 'YYYY-MM-DD')), 'YYYY-MM-DD')
            , D.DI_TFG_NO = NVL(#{doTfgNo,jdbcType=NUMERIC}, D.DI_TFG_NO)
            , D.DI_ISSU_OWR_NM = NVL(D.DI_ISSU_OWR_NM, (
            SELECT NVL(WM.WM_NM, W.WIR_WM_ID)
            FROM TRAN_RCP T
            JOIN WH_IN_RPT W
            ON W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            AND W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            LEFT JOIN WAREHOUSE_MANAGER WM
            ON WM.WM_ID = W.WIR_WM_ID
            WHERE T.TRC_NO = #{trcNo}
            AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
            AND T.TRC_STATUS_CD = 'TRC_DONE'
            FETCH FIRST 1 ROW ONLY
            ))
            WHERE D.DI_TRC_NO = #{trcNo}
            AND NVL(D.DI_TRDE_SE_CD, 'IMP') = 'IMP'
            AND NVL(D.DI_STATUS_CD, 'TRC_DO_READY') = 'TRC_DO_READY'
            AND EXISTS (
            SELECT 1
            FROM TRAN_RCP T
            JOIN WH_IN_RPT W
            ON W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            AND W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            WHERE T.TRC_NO = #{trcNo}
            AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
            AND T.TRC_STATUS_CD = 'TRC_DONE'
            AND EXISTS (
            SELECT 1
            FROM TRAN_COST_STL TCS
            WHERE TCS.TCS_TRC_NO = T.TRC_NO
            AND TCS.TCS_STL_STATUS_CD IN ('TRC_STL_PAID', 'PAID')
            )
            );

            IF SQL%ROWCOUNT = 0 THEN
            INSERT INTO DO_ISSUANCE (
            DI_DO_NO,
            DI_TRAN_NO,
            DI_TRC_NO,
            DI_TRDE_SE_CD,
            DI_STATUS_CD,
            DI_HBL_PRESENT_YN,
            DI_REQ_DT,
            DI_RECEIVE_DT,
            DI_TFG_NO,
            DI_ISSU_OWR_NM
            )
            SELECT
            COALESCE(NULLIF(#{doNo,jdbcType=VARCHAR}, ''), 'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' ||
            LPAD((
            SELECT NVL(MAX(TO_NUMBER(SUBSTR(DI_DO_NO, -3))), 0) + 1
            FROM DO_ISSUANCE
            WHERE DI_DO_NO LIKE 'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
            ), 3, '0')),
            (SELECT NVL(MAX(DI_TRAN_NO), 0) + 1 FROM DO_ISSUANCE),
            T.TRC_NO,
            'IMP',
            'TRC_DO_ISSUED',
            'Y',
            SYSDATE,
            TO_DATE(NVL(#{receiveDt}, TO_CHAR(SYSDATE, 'YYYY-MM-DD')), 'YYYY-MM-DD'),
            #{doTfgNo,jdbcType=NUMERIC},
            (
            SELECT NVL(WM.WM_NM, W.WIR_WM_ID)
            FROM WH_IN_RPT W
            LEFT JOIN WAREHOUSE_MANAGER WM
            ON WM.WM_ID = W.WIR_WM_ID
            WHERE W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            AND W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            FETCH FIRST 1 ROW ONLY
            )
            FROM TRAN_RCP T
            WHERE T.TRC_NO = #{trcNo}
            AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
            AND T.TRC_STATUS_CD = 'TRC_DONE'
            AND EXISTS (
            SELECT 1
            FROM WH_IN_RPT W
            WHERE W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            AND W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            )
            AND EXISTS (
            SELECT 1
            FROM TRAN_COST_STL TCS
            WHERE TCS.TCS_TRC_NO = T.TRC_NO
            AND TCS.TCS_STL_STATUS_CD IN ('TRC_STL_PAID', 'PAID')
            )
            AND NOT EXISTS (
            SELECT 1
            FROM DO_ISSUANCE D
            WHERE D.DI_TRC_NO = T.TRC_NO
            AND NVL(D.DI_TRDE_SE_CD, 'IMP') = 'IMP'
            );
            END IF;
            END;
      </update>
      <update id="updateImpDoUploadedFiles">

            BEGIN
            UPDATE DO_ISSUANCE D
            SET
            D.DI_TFG_NO = #{doTfgNo,jdbcType=NUMERIC}
            , D.DI_TRDE_SE_CD = 'IMP'
            , D.DI_STATUS_CD = NVL(D.DI_STATUS_CD, 'TRC_DO_READY')
            WHERE D.DI_TRC_NO = #{trcNo}
            AND NVL(D.DI_TRDE_SE_CD, 'IMP') = 'IMP'
            AND NVL(D.DI_STATUS_CD, 'TRC_DO_READY') IN ('TRC_DO_READY', 'TRC_DO_ISSUED', 'TRC_DO_REQ')
            AND EXISTS (
            SELECT 1
            FROM TRAN_RCP T
            JOIN WH_IN_RPT W
            ON W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            AND W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            JOIN TRAN_COST_STL TCS
            ON TCS.TCS_TRC_NO = T.TRC_NO
            AND TCS.TCS_STL_STATUS_CD IN ('TRC_STL_PAID', 'PAID')
            WHERE T.TRC_NO = #{trcNo}
            AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
            AND T.TRC_STATUS_CD = 'TRC_DONE'
            );

            IF SQL%ROWCOUNT = 0 THEN
            INSERT INTO DO_ISSUANCE (
            DI_DO_NO,
            DI_TRAN_NO,
            DI_TRC_NO,
            DI_TRDE_SE_CD,
            DI_STATUS_CD,
            DI_HBL_PRESENT_YN,
            DI_TFG_NO
            )
            SELECT
            'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' ||
            LPAD((
            SELECT NVL(MAX(TO_NUMBER(SUBSTR(DI_DO_NO, -3))), 0) + 1
            FROM DO_ISSUANCE
            WHERE DI_DO_NO LIKE 'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
            ), 3, '0'),
            (SELECT NVL(MAX(DI_TRAN_NO), 0) + 1 FROM DO_ISSUANCE),
            T.TRC_NO,
            'IMP',
            'TRC_DO_READY',
            'Y',
            #{doTfgNo,jdbcType=NUMERIC}
            FROM TRAN_RCP T
            WHERE T.TRC_NO = #{trcNo}
            AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
            AND T.TRC_STATUS_CD = 'TRC_DONE'
            AND EXISTS (
            SELECT 1
            FROM WH_IN_RPT W
            WHERE W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            AND W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            )
            AND EXISTS (
            SELECT 1
            FROM TRAN_COST_STL TCS
            WHERE TCS.TCS_TRC_NO = T.TRC_NO
            AND TCS.TCS_STL_STATUS_CD IN ('TRC_STL_PAID', 'PAID')
            )
            AND NOT EXISTS (
            SELECT 1
            FROM DO_ISSUANCE D
            WHERE D.DI_TRC_NO = T.TRC_NO
            AND NVL(D.DI_TRDE_SE_CD, 'IMP') = 'IMP'
            );
            END IF;
            END;
      </update>
      <update id="updateImpDoFileDocTypes">
            UPDATE TACS_FILE_MAP FM
            SET FM.TFM_DOC_TY_CD = CASE
            WHEN EXISTS (
            SELECT 1
            FROM DOCS_FILE_DATA FD
            WHERE FD.DFI_FILE_NO = FM.TFM_DFI_NO
            AND (
            UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN (
            'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
            'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
            )
            OR UPPER(NVL(FD.DFI_BIZ_TY_CD, 'X')) IN (
            'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
            'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
            )
            OR FD.DFI_ORG_NM LIKE '%수입신고필증%'
            OR FD.DFI_ORG_NM LIKE '%수입신고%'
            OR FD.DFI_ORG_NM LIKE '%신고필증%'
            OR FD.DFI_ORG_NM LIKE '%필증%'
            OR LOWER(NVL(FD.DFI_ORG_NM, '')) LIKE '%customs%cert%'
            OR LOWER(NVL(FD.DFI_ORG_NM, '')) LIKE '%declaration%cert%'
            OR LOWER(NVL(FD.DFI_ORG_NM, '')) LIKE '%certificate%'
            )
            AND NOT (
            UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN (
            'IMP_INVOICE', 'INVOICE', 'INV', 'IMP_PACKING_LIST', 'PACKING_LIST', 'PACKING', 'PL'
            )
            OR UPPER(NVL(FD.DFI_BIZ_TY_CD, 'X')) IN (
            'IMP_INVOICE', 'INVOICE', 'INV', 'IMP_PACKING_LIST', 'PACKING_LIST', 'PACKING', 'PL'
            )
            OR FD.DFI_ORG_NM LIKE '%송장%'
            OR FD.DFI_ORG_NM LIKE '%포장%'
            OR LOWER(NVL(FD.DFI_ORG_NM, '')) LIKE '%invoice%'
            OR LOWER(NVL(FD.DFI_ORG_NM, '')) LIKE '%packing%'
            )
            )
            THEN 'IMP_DO_CERT'
            ELSE 'IMP_DO'
            END
            WHERE FM.TFM_TFG_NO = #{doTfgNo}
      </update>
      <update id="updateImpDoCertFile">
            UPDATE DO_ISSUANCE
            SET
            DI_TFG_NO = #{doTfgNo,jdbcType=NUMERIC}
            WHERE DI_TRC_NO = #{trcNo}
            AND NVL(DI_TRDE_SE_CD, 'IMP') = 'IMP'
            AND DI_STATUS_CD IN ('TRC_DO_ISSUED', 'TRC_DO_REQ')
            AND EXISTS (
            SELECT 1
            FROM TRAN_RCP T
            JOIN WH_IN_RPT W
            ON W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            AND W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            WHERE T.TRC_NO = #{trcNo}
            AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
            AND T.TRC_STATUS_CD = 'TRC_DONE'
            )
      </update>
      <select id="selectIssuedImpDoNo" resultType="String">
            SELECT DI_DO_NO
            FROM DO_ISSUANCE
            WHERE DI_TRC_NO = #{trcNo}
            AND NVL(DI_TRDE_SE_CD, 'IMP') = 'IMP'
            AND DI_STATUS_CD IN ('TRC_DO_ISSUED', 'TRC_DO_REQ')
            ORDER BY DI_RECEIVE_DT DESC NULLS LAST, DI_DO_NO DESC
            FETCH FIRST 1 ROW ONLY
      </select>
      <select id="selectImpDoTfgNo" resultType="java.lang.Long">
            SELECT DI_TFG_NO
            FROM DO_ISSUANCE
            WHERE DI_TRC_NO = #{trcNo}
            AND NVL(DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')
            ORDER BY DI_RECEIVE_DT DESC NULLS LAST, DI_DO_NO DESC
            FETCH FIRST 1 ROW ONLY
      </select>
      <select id="selectImpDoPdfDetail" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
            SELECT
                  T.TRC_NO AS trcNo
                  , T.TRC_OWR_ID AS ownerId
                  , NVL(O.OWR_NM, T.TRC_OWR_ID) AS ownerNm
                  , COALESCE(T.TRC_TRDR_NM, ID.ID_OVRSS_NM) AS buyerNm
                  , COALESCE(T.TRC_TRDR_COUNTRY_CD, TD.TRDR_COUNTRY_CD, ID.ID_OVRSS_CNTRY_CD, ID.ID_SHIPOUT_CNTRY_CD) AS buyerCountryCd
                  , COALESCE(T.TRC_TRAN_MN_CD, ID.ID_TRNSP_MN_CD) AS transportMeanCd
                  , CASE COALESCE(T.TRC_TRAN_MN_CD, ID.ID_TRNSP_MN_CD)
                        WHEN 'SEA' THEN '해상'
                        WHEN 'AIR' THEN '항공'
                        WHEN '10' THEN '선박'
                        WHEN '20' THEN '철도'
                        WHEN '30' THEN '차량'
                        WHEN '40' THEN '항공기'
                        WHEN '90' THEN '기타'
                        ELSE COALESCE(T.TRC_TRAN_MN_CD, ID.ID_TRNSP_MN_CD)
                    END AS transportMeanNm
                  , COALESCE(T.TRC_TRAN_TY_CD, ID.ID_CNTNR_SE_CD) AS transportTypeCd
                  , COALESCE(T.TRC_INCO_TERMS_CD, ID.ID_DLVR_CNDTN_CD) AS incoTermsCd
                  , COALESCE(T.TRC_DEPT_PORT_CD, T.TRC_PORT_CD) AS deptPortCd
                  , NVL(DP.PORT_NM, COALESCE(T.TRC_DEPT_PORT_CD, T.TRC_PORT_CD)) AS deptPortNm
                  , COALESCE(T.TRC_ARVL_PORT_CD, IR.IR_ARRV_PORT_CD) AS arvlPortCd
                  , NVL(AP.PORT_NM, COALESCE(T.TRC_ARVL_PORT_CD, IR.IR_ARRV_PORT_CD)) AS arvlPortNm
                  , T.TRC_ITEM_CTGRY_NM AS itemCategory
                  , COALESCE(T.TRC_RQST_CN, IR.IR_CN, IR.IR_COMMENT) AS requestCn
                  , T.TRC_STATUS_CD AS statusCd
                  , CASE T.TRC_STATUS_CD
                        WHEN 'TRC_WAIT' THEN '접수대기'
                        WHEN 'TRC_DONE' THEN '접수완료'
                        WHEN 'TRC_REJECT' THEN '접수반려'
                        WHEN 'TRC_COMPLETE' THEN '최종완료'
                        ELSE T.TRC_STATUS_CD
                    END AS statusNm
                  , TO_CHAR(T.TRC_RQST_DT, 'YYYY-MM-DD HH24:MI') AS requestDt
                  , W.WIR_NO AS wirNo
                  , W.WIR_WM_ID AS wmId
                  , NVL(WM.WM_NM, W.WIR_WM_ID) AS warehouseManagerNm
                  , TO_CHAR(W.WIR_WZ_NO) AS wzNo
                  , WH.WH_NM AS warehouseNm
                  , NVL(WZ.WZ_NM, TO_CHAR(W.WIR_WZ_NO)) AS warehouseZoneNm
                  , W.WIR_STATUS_CD AS warehouseInStatusCd
                  , W.WIR_WH_REPLY_STATUS_CD AS warehouseReplyStatusCd
                  , CASE
                        WHEN W.WIR_STATUS_CD = 'IN_DONE' AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN '입고완료'
                        WHEN W.WIR_STATUS_CD = 'REQ_FIX' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN '보완요청'
                        WHEN W.WIR_STATUS_CD = 'REQ_SENT' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN '보완제출완료'
                        WHEN W.WIR_STATUS_CD IN ('REJECT', 'REJECTED') OR W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED') THEN '반려'
                        WHEN W.WIR_STATUS_CD = 'WAIT' OR W.WIR_WH_REPLY_STATUS_CD = 'WAIT' THEN '입고대기'
                        ELSE W.WIR_STATUS_CD
                    END AS warehouseInStatusNm
                  , TO_CHAR(W.WIR_IN_PLAN_DT, 'YYYY-MM-DD HH24:MI') AS inPlanDt
                  , W.WIR_CARGO_MGMT_NO AS cargoMgmtNo
                  , W.WIR_INVOICE_NO AS invoiceNo
                  , DI.DI_DO_NO AS doNo
                  , DI.DI_STATUS_CD AS doStatusCd
                  , CASE DI.DI_STATUS_CD
                        WHEN 'TRC_DO_READY' THEN 'D/O발급대기'
                        WHEN 'TRC_DO_ISSUED' THEN 'D/O발급완료'
                        WHEN 'TRC_DO_REQ' THEN 'D/O전달완료'
                        ELSE DI.DI_STATUS_CD
                    END AS doStatusNm
                  , TO_CHAR(DI.DI_RECEIVE_DT, 'YYYY-MM-DD') AS doReceiveDt
                  , DI.DI_TFG_NO AS doTfgNo
                  , DI.DI_ISSU_OWR_NM AS issueTargetNm
                  , DI.DI_DLVRY_OWR_NM AS deliveryTargetNm
                  , TO_CHAR(DI.DI_DLVRY_DT, 'YYYY-MM-DD') AS deliveryDt
                  , DI.DI_DLVRY_MTHD_CD AS deliveryMethodCd
                  , COALESCE(M.ICM_MBL_NO, BI.BI_MBL_NO, TCS.TCS_MBL_NO, ID.ID_MBL_NO, IR.IR_BL_AWB_NO) AS mblNo
                  , COALESCE(M.ICM_HBL_NO, BI.BI_HBL_NO, TCS.TCS_HBL_NO, TCS.TCS_MBL_NO, BI.BI_MBL_NO, ID.ID_MBL_NO, IR.IR_BL_AWB_NO) AS hblNo
                  , COALESCE(M.ICM_HBL_NO, BI.BI_HBL_NO, TCS.TCS_HBL_NO, M.ICM_MBL_NO, BI.BI_MBL_NO, TCS.TCS_MBL_NO, ID.ID_MBL_NO, IR.IR_BL_AWB_NO) AS blNo
                  , TCS.TCS_MBL_NO AS tcsMblNo
                  , TCS.TCS_HBL_NO AS tcsHblNo
                  , NVL(TCS.TCS_FRGT_AMT, 0) AS freightAmt
                  , NVL(TCS.TCS_WH_AMT, 0) AS warehouseAmt
                  , NVL(TCS.TCS_TOT_BILL_AMT, 0) AS totalBillAmt
                  , NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID') AS tcsStlStatusCd
                  , CASE NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID')
                        WHEN 'TRC_STL_UNPAID' THEN '미정산'
                        WHEN 'UNPAID' THEN '미정산'
                        WHEN 'TRC_STL_REQ' THEN '정산요청'
                        WHEN 'REQ' THEN '정산요청'
                        WHEN 'TRC_STL_PAID' THEN '정산완료'
                        WHEN 'PAID' THEN '정산완료'
                        ELSE TCS.TCS_STL_STATUS_CD
                    END AS tcsStlStatusNm
                  , TCS.TCS_STL_EXPLN AS settlementExpln
                  , GDS.GOODS_NAME AS goodsName
                  , GDS.GOODS_NAME AS itemNm
                  , GDS.CG_QTY AS qty
                  , GDS.CG_WEIGHT AS weight
                  , CERT_FILE.DFI_ORG_NM AS doCertFile
            FROM TRAN_RCP T
            LEFT JOIN OWNER O
              ON O.OWR_ID = T.TRC_OWR_ID
            LEFT JOIN DO_ISSUANCE DI
              ON DI.DI_TRC_NO = T.TRC_NO
             AND NVL(DI.DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')
            LEFT JOIN BL_ISSU BI
              ON BI.BI_TRE_ID = T.TRC_NO
              OR (T.TRC_TFG_NO IS NOT NULL AND BI.BI_GG_NO = T.TRC_TFG_NO)
            LEFT JOIN (
                  SELECT
                        ICM_GG_NO
                        , ICM_OWR_ID
                        , ICM_MBL_NO
                        , ICM_HBL_NO
                  FROM (
                        SELECT
                              M0.*
                              , ROW_NUMBER() OVER (
                                    PARTITION BY M0.ICM_GG_NO, M0.ICM_OWR_ID
                                    ORDER BY M0.ICM_SBMSN_DT DESC NULLS LAST, M0.ICM_NO DESC
                                ) AS RN
                        FROM IMP_CARGO_MANIFEST M0
                  )
                  WHERE RN = 1
            ) M
              ON M.ICM_GG_NO = T.TRC_TFG_NO
             AND M.ICM_OWR_ID = T.TRC_OWR_ID
            LEFT JOIN (
                  SELECT
                        TCS0.*
                        , ROW_NUMBER() OVER (
                              PARTITION BY TCS0.TCS_TRC_NO
                              ORDER BY TCS0.TCS_NO DESC
                          ) AS RN
                  FROM TRAN_COST_STL TCS0
            ) TCS
              ON TCS.TCS_TRC_NO = T.TRC_NO
             AND TCS.RN = 1
            LEFT JOIN (
                  SELECT *
                  FROM (
                        SELECT
                              IR0.*
                              , ROW_NUMBER() OVER (
                                    PARTITION BY IR0.IR_OWR_ID, NVL(IR0.IR_BL_AWB_NO, IR0.IR_NO)
                                    ORDER BY IR0.IR_REGIST_DT DESC NULLS LAST, IR0.IR_NO DESC
                                ) AS RN
                        FROM IMP_RQST IR0
                        WHERE NVL(IR0.IR_USE_YN, 'Y') = 'Y'
                  )
                  WHERE RN = 1
            ) IR
              ON IR.IR_OWR_ID = T.TRC_OWR_ID
             AND (
                    IR.IR_NO = T.TRC_NO
                 OR IR.IR_NO = REPLACE(T.TRC_NO, 'TRC-', '')
                 OR IR.IR_BL_AWB_NO = BI.BI_MBL_NO
                 OR IR.IR_BL_AWB_NO = M.ICM_MBL_NO
                 OR IR.IR_BL_AWB_NO = TCS.TCS_MBL_NO
                 OR IR.IR_BL_AWB_NO = TO_CHAR(T.TRC_BI_NO)
             )
            LEFT JOIN (
                  SELECT *
                  FROM (
                        SELECT
                              ID0.*
                              , ROW_NUMBER() OVER (
                                    PARTITION BY ID0.ID_IR_NO
                                    ORDER BY ID0.ID_UPDT_DT DESC NULLS LAST, ID0.ID_REGIST_DT DESC NULLS LAST
                                ) AS RN
                        FROM IMP_DCLR ID0
                  )
                  WHERE RN = 1
            ) ID
              ON ID.ID_IR_NO = IR.IR_NO
              OR ID.ID_MBL_NO = BI.BI_MBL_NO
              OR ID.ID_MBL_NO = M.ICM_MBL_NO
              OR ID.ID_MBL_NO = TCS.TCS_MBL_NO
            LEFT JOIN TRDR TD
              ON TD.TRDR_NM = T.TRC_TRDR_NM
              OR TD.TRDR_NM = ID.ID_OVRSS_NM
            LEFT JOIN PORT DP
              ON DP.PORT_CD = COALESCE(T.TRC_DEPT_PORT_CD, T.TRC_PORT_CD)
            LEFT JOIN PORT AP
              ON AP.PORT_CD = COALESCE(T.TRC_ARVL_PORT_CD, IR.IR_ARRV_PORT_CD)
            LEFT JOIN (
                  SELECT *
                  FROM (
                        SELECT
                              W0.*
                              , ROW_NUMBER() OVER (
                                    PARTITION BY W0.WIR_GG_NO
                                    ORDER BY W0.WIR_IN_PLAN_DT DESC NULLS LAST, W0.WIR_NO DESC
                                ) AS RN
                        FROM WH_IN_RPT W0
                        WHERE W0.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
                  )
                  WHERE RN = 1
            ) W
              ON W.WIR_GG_NO = T.TRC_TFG_NO
            LEFT JOIN WAREHOUSE_MANAGER WM
              ON WM.WM_ID = W.WIR_WM_ID
            LEFT JOIN WAREHOUSE_ZONE WZ
              ON WZ.WZ_NO = W.WIR_WZ_NO
            LEFT JOIN WAREHOUSE WH
              ON WH.WH_NO = WZ.WZ_WH_NO
            LEFT JOIN (
                  SELECT
                        CG.GG_NO
                        , CASE
                              WHEN COUNT(*) > 1 THEN MIN(G.GOODS_NAME) KEEP (DENSE_RANK FIRST ORDER BY CG.CG_NO) || ' 외 ' || (COUNT(*) - 1) || '건'
                              ELSE MIN(G.GOODS_NAME) KEEP (DENSE_RANK FIRST ORDER BY CG.CG_NO)
                          END AS GOODS_NAME
                        , NVL(SUM(CG.CG_QTY), 0) AS CG_QTY
                        , NVL(SUM(CG.CG_WEIGHT), 0) AS CG_WEIGHT
                  FROM CUSTOMS_GOODS CG
                  LEFT JOIN GOODS G
                    ON G.GOODS_NO = CG.GOODS_NO
                  GROUP BY CG.GG_NO
            ) GDS
              ON GDS.GG_NO = T.TRC_TFG_NO
            LEFT JOIN (
                  SELECT
                        FM.TFM_TFG_NO
                        , LISTAGG(FD.DFI_ORG_NM, ', ') WITHIN GROUP (ORDER BY FM.TFM_NO) AS DFI_ORG_NM
                  FROM TACS_FILE_MAP FM
                  JOIN DOCS_FILE_DATA FD
                    ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
                   AND NVL(FD.DFI_DEL_YN, 'N') = 'N'
                  WHERE UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN ('CUSTOMS_CERT', 'IMP_DO_CERT')
                     OR FD.DFI_ORG_NM LIKE '%수입신고%'
                     OR FD.DFI_ORG_NM LIKE '%필증%'
                  GROUP BY FM.TFM_TFG_NO
            ) CERT_FILE
              ON CERT_FILE.TFM_TFG_NO = DI.DI_TFG_NO
            WHERE T.TRC_NO = #{trcNo}
            AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
            ORDER BY DI.DI_RECEIVE_DT DESC NULLS LAST, DI.DI_DO_NO DESC
            FETCH FIRST 1 ROW ONLY
      </select>
      <update id="updateImpDoSettlementPaid">
            MERGE INTO TRAN_COST_STL TCS
            USING (
                  SELECT
                        TR.TRC_NO,
                        TR.TRC_OWR_ID,
                        TR.TRC_TFG_NO,
                        COALESCE(
                              NULLIF(TRIM(M.ICM_MBL_NO), ''),
                              NULLIF(TRIM(BI.BI_MBL_NO), ''),
                              NULLIF(TRIM((
                                    SELECT MAX(IR.IR_BL_AWB_NO)
                                    FROM IMP_RQST IR
                                    WHERE (
                                                IR.IR_NO = TR.TRC_NO
                                             OR IR.IR_NO = REPLACE(TR.TRC_NO, 'TRC-', '')
                                             OR IR.IR_OWR_ID = TR.TRC_OWR_ID
                                          )
                                      AND IR.IR_BL_AWB_NO IS NOT NULL
                              )), ''),
                              NULLIF(TRIM(TO_CHAR(TR.TRC_BI_NO)), '')
                        ) AS SRC_MBL_NO,
                        COALESCE(
                              NULLIF(TRIM(M.ICM_HBL_NO), ''),
                              NULLIF(TRIM(BI.BI_HBL_NO), ''),
                              NULLIF(TRIM((
                                    SELECT MAX(IR.IR_BL_AWB_NO)
                                    FROM IMP_RQST IR
                                    WHERE (
                                                IR.IR_NO = TR.TRC_NO
                                             OR IR.IR_NO = REPLACE(TR.TRC_NO, 'TRC-', '')
                                             OR IR.IR_OWR_ID = TR.TRC_OWR_ID
                                          )
                                      AND IR.IR_BL_AWB_NO IS NOT NULL
                              )), ''),
                              NULLIF(TRIM(TO_CHAR(TR.TRC_BI_NO)), '')
                        ) AS SRC_HBL_NO
                  FROM TRAN_RCP TR
                  LEFT JOIN (
                        SELECT
                              BI_TRE_ID,
                              MAX(NULLIF(TRIM(BI_MBL_NO), '')) AS BI_MBL_NO,
                              MAX(NULLIF(TRIM(BI_HBL_NO), '')) AS BI_HBL_NO
                        FROM BL_ISSU
                        GROUP BY BI_TRE_ID
                  ) BI
                    ON BI.BI_TRE_ID = TR.TRC_NO
                  LEFT JOIN (
                        SELECT ICM_GG_NO, ICM_OWR_ID, ICM_MBL_NO, ICM_HBL_NO
                        FROM (
                              SELECT M0.*,
                                     ROW_NUMBER() OVER (
                                           PARTITION BY M0.ICM_GG_NO, M0.ICM_OWR_ID
                                           ORDER BY M0.ICM_SBMSN_DT DESC NULLS LAST, M0.ICM_NO DESC
                                     ) AS RN
                              FROM IMP_CARGO_MANIFEST M0
                        )
                        WHERE RN = 1
                  ) M
                    ON M.ICM_GG_NO = TR.TRC_TFG_NO
                   AND M.ICM_OWR_ID = TR.TRC_OWR_ID
                  WHERE TR.TRC_NO = #{trcNo}
                    AND TR.TRC_SE_CD IN ('IMP', 'IMPORT')
            ) SRC
            ON (TCS.TCS_TRC_NO = SRC.TRC_NO)
            WHEN MATCHED THEN
                  UPDATE SET
                        TCS.TCS_OWR_ID = NVL(TCS.TCS_OWR_ID, SRC.TRC_OWR_ID),
                        TCS.TCS_GG_NO = NVL(TCS.TCS_GG_NO, SRC.TRC_TFG_NO),
                        TCS.TCS_MBL_NO = COALESCE(SRC.SRC_MBL_NO, NULLIF(TRIM(TCS.TCS_MBL_NO), '')),
                        TCS.TCS_HBL_NO = COALESCE(SRC.SRC_HBL_NO, NULLIF(TRIM(TCS.TCS_HBL_NO), ''), SRC.SRC_MBL_NO, NULLIF(TRIM(TCS.TCS_MBL_NO), '')),
                        TCS.TCS_STL_STATUS_CD = 'TRC_STL_REQ',
                        TCS.TCS_FRGT_AMT = CASE
                              WHEN NVL(#{freightAmt}, 0) > 0 THEN NVL(#{freightAmt}, 0)
                              ELSE NVL(TCS.TCS_FRGT_AMT, 0)
                        END,
                        TCS.TCS_WH_AMT = CASE
                              WHEN NVL(#{warehouseAmt}, 0) > 0 THEN NVL(#{warehouseAmt}, 0)
                              ELSE NVL(TCS.TCS_WH_AMT, 0)
                        END,
                        TCS.TCS_TOT_BILL_AMT = CASE
                              WHEN NVL(#{totalBillAmt}, 0) > 0 THEN NVL(#{totalBillAmt}, 0)
                              WHEN NVL(#{freightAmt}, 0) > 0 OR NVL(#{warehouseAmt}, 0) > 0 THEN
                                    (CASE WHEN NVL(#{freightAmt}, 0) > 0 THEN NVL(#{freightAmt}, 0) ELSE NVL(TCS.TCS_FRGT_AMT, 0) END)
                                  + (CASE WHEN NVL(#{warehouseAmt}, 0) > 0 THEN NVL(#{warehouseAmt}, 0) ELSE NVL(TCS.TCS_WH_AMT, 0) END)
                              ELSE NVL(TCS.TCS_TOT_BILL_AMT, NVL(TCS.TCS_FRGT_AMT, 0) + NVL(TCS.TCS_WH_AMT, 0))
                        END,
                        TCS.TCS_STL_EXPLN = COALESCE(NULLIF(TRIM(#{settlementExpln}), ''), TCS.TCS_STL_EXPLN)
            WHEN NOT MATCHED THEN
                  INSERT (
                        TCS_NO,
                        TCS_TRC_NO,
                        TCS_OWR_ID,
                        TCS_GG_NO,
                        TCS_MBL_NO,
                        TCS_HBL_NO,
                        TCS_STL_STATUS_CD,
                        TCS_FRGT_AMT,
                        TCS_WH_AMT,
                        TCS_TOT_BILL_AMT,
                        TCS_STL_EXPLN
                  )
                  VALUES (
                        'TCS-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' ||
                        LPAD((
                              SELECT NVL(MAX(TO_NUMBER(REGEXP_SUBSTR(X.TCS_NO, '[0-9]+$'))), 0) + 1
                              FROM TRAN_COST_STL X
                              WHERE X.TCS_NO LIKE 'TCS-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
                        ), 3, '0'),
                        SRC.TRC_NO,
                        SRC.TRC_OWR_ID,
                        SRC.TRC_TFG_NO,
                        SRC.SRC_MBL_NO,
                        COALESCE(SRC.SRC_HBL_NO, SRC.SRC_MBL_NO),
                        'TRC_STL_REQ',
                        NVL(#{freightAmt}, 0),
                        NVL(#{warehouseAmt}, 0),
                        NVL(#{totalBillAmt}, NVL(#{freightAmt}, 0) + NVL(#{warehouseAmt}, 0)),
                        #{settlementExpln}
                  )
      </update>
      <select id="countImpDoSettlementPaid" resultType="int">

            SELECT COUNT(1)
            FROM TRAN_COST_STL TCS
            WHERE TCS.TCS_TRC_NO = #{trcNo}
            AND TCS.TCS_STL_STATUS_CD IN ('TRC_STL_REQ', 'TRC_STL_PAID', 'REQ', 'PAID')
            AND EXISTS (
            SELECT 1
            FROM TRAN_RCP T
            LEFT JOIN WH_IN_RPT W
            ON W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            WHERE T.TRC_NO = TCS.TCS_TRC_NO
            AND T.TRC_NO = #{trcNo}
            AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
            AND W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            )
      </select>
      <select id="selectTcsNoByTrcNo" resultType="string">
            SELECT TCS_NO
            FROM (
                SELECT TCS_NO
                FROM TRAN_COST_STL
                WHERE TCS_TRC_NO = #{trcNo}
                ORDER BY TCS_NO DESC
            )
            WHERE ROWNUM = 1
      </select>
      <select id="selectCrrNoByTrcNo" resultType="string">
            SELECT CRR_NO
            FROM (
                SELECT CRR_NO
                FROM CARGO_RELEASE_REQ
                WHERE CRR_TRE_ID = #{trcNo}
                ORDER BY CRR_NO DESC
            )
            WHERE ROWNUM = 1
      </select>
      <select id="countImpDoAnyPdfFile" resultType="int">
            SELECT COUNT(1)
            FROM DO_ISSUANCE DI
            JOIN TACS_FILE_MAP FM
            ON FM.TFM_TFG_NO = DI.DI_TFG_NO
            JOIN DOCS_FILE_DATA FD
            ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
            AND NVL(FD.DFI_DEL_YN, 'N') = 'N'
            WHERE DI.DI_TRC_NO = #{trcNo}
            AND NVL(DI.DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')
            AND (
            LOWER(NVL(FD.DFI_ORG_NM, '')) LIKE '%.pdf'
            OR LOWER(NVL(FD.DFI_EXT, '')) = 'pdf'
            OR LOWER(NVL(FD.DFI_MIME_TY, '')) LIKE '%pdf%'
            )
      </select>
      <select id="countImpDoPdfFile" resultType="int">
            SELECT COUNT(1)
            FROM DO_ISSUANCE DI
            JOIN TACS_FILE_MAP FM
            ON FM.TFM_TFG_NO = DI.DI_TFG_NO
            JOIN DOCS_FILE_DATA FD
            ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
            AND NVL(FD.DFI_DEL_YN, 'N') = 'N'
            WHERE DI.DI_TRC_NO = #{trcNo}
            AND NVL(DI.DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')
            AND (
            NVL(FM.TFM_DOC_TY_CD, 'IMP_DO') = 'IMP_DO'
            OR LOWER(FD.DFI_ORG_NM) LIKE '%do%'
            OR LOWER(FD.DFI_ORG_NM) LIKE '%d/o%'
            OR LOWER(FD.DFI_ORG_NM) LIKE '%d_o%'
            OR LOWER(FD.DFI_ORG_NM) LIKE '%delivery%'
            )
            AND NOT (
            UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN ('CUSTOMS_CERT', 'IMP_DO_CERT')
            OR LOWER(FD.DFI_ORG_NM) LIKE '%cert%'
            OR LOWER(FD.DFI_ORG_NM) LIKE '%declaration%'
            OR FD.DFI_ORG_NM LIKE '%신고%'
            OR FD.DFI_ORG_NM LIKE '%필증%'
            )
      </select>
      <select id="countImpDoCertFile" resultType="int">
        SELECT COUNT(1)
        FROM DO_ISSUANCE DI
        JOIN TACS_FILE_MAP FM
          ON FM.TFM_TFG_NO = DI.DI_TFG_NO
        JOIN DOCS_FILE_DATA FD
          ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
         AND NVL(FD.DFI_DEL_YN, 'N') = 'N'
         AND NVL(FD.DFI_UPLOAD_STTS_CD, 'DONE') = 'DONE'
        WHERE DI.DI_TRC_NO = #{trcNo}
          AND (
                UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN (
                    'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
                    'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
                )
             OR UPPER(NVL(FD.DFI_BIZ_TY_CD, 'X')) IN (
                    'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
                    'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
                )
             OR FD.DFI_ORG_NM LIKE '%수입신고필증%'
             OR FD.DFI_ORG_NM LIKE '%수입신고%'
             OR FD.DFI_ORG_NM LIKE '%신고필증%'
             OR LOWER(FD.DFI_ORG_NM) LIKE '%import%declar%'
             OR LOWER(FD.DFI_ORG_NM) LIKE '%declaration%cert%'
             OR LOWER(FD.DFI_ORG_NM) LIKE '%certificate%'
          )
          AND NOT (
                UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN (
                    'IMP_INVOICE', 'INVOICE', 'INV', 'IMP_PACKING_LIST', 'PACKING_LIST', 'PACKING', 'PL'
                )
             OR UPPER(NVL(FD.DFI_BIZ_TY_CD, 'X')) IN (
                    'IMP_INVOICE', 'INVOICE', 'INV', 'IMP_PACKING_LIST', 'PACKING_LIST', 'PACKING', 'PL'
                )
             OR FD.DFI_ORG_NM LIKE '%송장%'
             OR FD.DFI_ORG_NM LIKE '%포장%'
             OR LOWER(FD.DFI_ORG_NM) LIKE '%invoice%'
             OR LOWER(FD.DFI_ORG_NM) LIKE '%packing%'
          )
      </select>


      <select id="selectLatestUnmappedImpCustomsCertFileNo" resultType="long">
        SELECT DFI_FILE_NO
        FROM (
            SELECT
                FD.DFI_FILE_NO,
                CASE
                    WHEN FM.TFM_TFG_NO = T.TRC_CERT_TFG_NO THEN 0
                    WHEN FM.TFM_TFG_NO = T.TRC_TFG_NO THEN 1
                    ELSE 2
                END AS SORT_NO
            FROM DO_ISSUANCE DI
            JOIN TRAN_RCP T
              ON T.TRC_NO = DI.DI_TRC_NO
            JOIN TACS_FILE_MAP FM
              ON FM.TFM_TFG_NO IN (T.TRC_CERT_TFG_NO, T.TRC_TFG_NO)
            JOIN DOCS_FILE_DATA FD
              ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
             AND NVL(FD.DFI_DEL_YN, 'N') = 'N'
             AND NVL(FD.DFI_UPLOAD_STTS_CD, 'DONE') = 'DONE'
            LEFT JOIN TACS_FILE_MAP DO_FM
              ON DO_FM.TFM_TFG_NO = DI.DI_TFG_NO
             AND DO_FM.TFM_DFI_NO = FD.DFI_FILE_NO
            WHERE DI.DI_TRC_NO = #{trcNo}
              AND NVL(DI.DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')
              AND DI.DI_TFG_NO IS NOT NULL
              AND DO_FM.TFM_DFI_NO IS NULL
              AND (
                    UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN (
                        'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
                        'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
                    )
                 OR UPPER(NVL(FD.DFI_BIZ_TY_CD, 'X')) IN (
                        'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
                        'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
                    )
                 OR FD.DFI_ORG_NM LIKE '%수입신고필증%'
                 OR FD.DFI_ORG_NM LIKE '%수입신고%'
                 OR FD.DFI_ORG_NM LIKE '%신고필증%'
                 OR FD.DFI_ORG_NM LIKE '%필증%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%customs%cert%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%declaration%cert%'
                 OR LOWER(FD.DFI_ORG_NM) LIKE '%certificate%'
              )
              AND (
                    LOWER(NVL(FD.DFI_ORG_NM, '')) LIKE '%.pdf'
                 OR LOWER(NVL(FD.DFI_EXT, '')) = 'pdf'
                 OR LOWER(NVL(FD.DFI_MIME_TY, '')) LIKE '%pdf%'
              )
            ORDER BY SORT_NO, FD.DFI_FILE_NO DESC
        )
        WHERE ROWNUM = 1
      </select>

      <select id="countImpCustomsCertFileCandidate" resultType="int">
        SELECT COUNT(1)
        FROM DOCS_FILE_DATA FD
        LEFT JOIN TACS_FILE_MAP FM
          ON FM.TFM_DFI_NO = FD.DFI_FILE_NO
        WHERE FD.DFI_FILE_NO = #{fileNo}
          AND NVL(FD.DFI_DEL_YN, 'N') = 'N'
          AND NVL(FD.DFI_UPLOAD_STTS_CD, 'DONE') = 'DONE'
          AND (
                UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) IN (
                    'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
                    'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
                )
             OR UPPER(NVL(FD.DFI_BIZ_TY_CD, 'X')) IN (
                    'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
                    'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
                )
             OR FD.DFI_ORG_NM LIKE '%수입신고필증%'
             OR FD.DFI_ORG_NM LIKE '%수입신고%'
             OR FD.DFI_ORG_NM LIKE '%신고필증%'
             OR FD.DFI_ORG_NM LIKE '%필증%'
             OR LOWER(FD.DFI_ORG_NM) LIKE '%customs%cert%'
             OR LOWER(FD.DFI_ORG_NM) LIKE '%declaration%cert%'
             OR LOWER(FD.DFI_ORG_NM) LIKE '%certificate%'
          )
          AND (
                LOWER(NVL(FD.DFI_ORG_NM, '')) LIKE '%.pdf'
             OR LOWER(NVL(FD.DFI_EXT, '')) = 'pdf'
             OR LOWER(NVL(FD.DFI_MIME_TY, '')) LIKE '%pdf%'
          )
      </select>

      <insert id="insertImpCustomsCertFileMap">
        MERGE INTO TACS_FILE_MAP FM
        USING (
            SELECT
                MAX(DI.DI_TFG_NO) AS TARGET_TFG_NO,
                #{fileNo} AS TARGET_FILE_NO
            FROM DO_ISSUANCE DI
            WHERE DI.DI_TRC_NO = #{trcNo}
              AND NVL(DI.DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')
              AND DI.DI_TFG_NO IS NOT NULL
            HAVING MAX(DI.DI_TFG_NO) IS NOT NULL
        ) SRC
        ON (
            FM.TFM_TFG_NO = SRC.TARGET_TFG_NO
            AND FM.TFM_DFI_NO = SRC.TARGET_FILE_NO
        )
        WHEN MATCHED THEN
            UPDATE SET
                FM.TFM_DOC_TY_CD = 'IMP_DO_CERT'
            WHERE UPPER(NVL(FM.TFM_DOC_TY_CD, 'X')) NOT IN (
                'CUSTOMS_CERT', 'IMP_DO_CERT', 'IMP_DECL_CERT', 'IMP_DECLARATION_CERT',
                'IMPORT_DECL_CERT', 'IMPORT_DECLARATION_CERT', 'IMPORT_DECLARE_CERT'
            )
        WHEN NOT MATCHED THEN
            INSERT (
                TFM_NO,
                TFM_TFG_NO,
                TFM_DFI_NO,
                TFM_DOC_TY_CD
            )
            VALUES (
                NVL((SELECT MAX(FM0.TFM_NO) + 1 FROM TACS_FILE_MAP FM0), 1),
                SRC.TARGET_TFG_NO,
                SRC.TARGET_FILE_NO,
                'IMP_DO_CERT'
            )
      </insert>

      <update id="updateImpTransportCertYn">
        UPDATE TRAN_RCP
        SET TRC_CERT_YN = #{certYn}
        WHERE TRC_NO = #{trcNo}
      </update>

</mapper>
