/* Community specific styles */
.cs-category {
  display: inline-block;
  padding: 6px 14px;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  border: 1px solid #cbd5e1;
  background: #fff;
  color: #697d8f;
  margin-right: 4px;
  margin-bottom: 8px;
}

.cs-category.active {
  background: #565e74;
  color: #fff;
  border-color: #565e74;
}

.faq-item {
  border-bottom: 1px solid #e2e8f0;
}

.faq-q {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 700;
  color: #203444;
}

.faq-q:hover {
  background: #f6f9ff;
}

.faq-a {
  display: none;
  padding: 0 16px 16px;
  font-size: 13px;
  color: #4d6172;
  line-height: 1.7;
  background: #f8fafc;
}

.faq-a.open {
  display: block;
}

.iq-status {
  font-size: 11px;
  font-weight: 700;
  padding: 4px 10px;
  display: inline-block;
}

.iq-status.waiting {
  background: #fef3c7;
  color: #92400e;
}

.iq-status.answered {
  background: #d1fae5;
  color: #065f46;
}

.iq-status.closed {
  background: #e2e8f0;
  color: #64748b;
}

.inquiry-detail {
  background: #fff;
  padding: 24px;
}

.iq-thread {
  margin-top: 20px;
}

.iq-msg {
  padding: 16px;
  margin-bottom: 12px;
}

.iq-msg.user {
  background: #ecf4ff;
  border-left: 4px solid #565e74;
}

.iq-msg.admin {
  background: #f0fdf4;
  border-left: 4px solid #1d6b4f;
}

.iq-msg-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
  font-size: 12px;
}

.iq-msg-author {
  font-weight: 700;
  color: #203444;
}

.iq-msg-date {
  color: #697d8f;
}

.iq-msg-body {
  font-size: 13px;
  line-height: 1.7;
  color: #334155;
}

.notice-detail {
  background: #fff;
  padding: 32px;
}

.nd-header {
  border-bottom: 2px solid #0f172a;
  padding-bottom: 16px;
  margin-bottom: 24px;
}

.nd-title {
  font-size: 18px;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 8px;
}

.nd-meta {
  display: flex;
  gap: 20px;
  font-size: 12px;
  color: #697d8f;
}

.nd-body {
  font-size: 14px;
  line-height: 1.9;
  color: #334155;
  min-height: 200px;
  padding: 20px 0;
}

.inquiry-form {
  background: #fff;
  padding: 24px;
}

.inquiry-form h4 {
  font-size: 14px;
  font-weight: 700;
  color: #1e293b;
  border-bottom: 1px solid #e2e8f0;
  padding-bottom: 10px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.inquiry-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid #e2e8f0;
  cursor: pointer;
}

.inquiry-row:hover {
  background: #f6f9ff;
}
