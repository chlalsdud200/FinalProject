<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%
    request.setAttribute("activeMenu", "import");
    request.setAttribute("activeGroup", "");
    request.setAttribute("activeSub", "");
%>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="ctx-path" content="${pageContext.request.contextPath}">
    <title>TACS 수입통관 의뢰 작성</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/owner.css">
</head>
<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/owner/sidebar.jsp" %>

    <div class="main-wrap">
        <%@ include file="/WEB-INF/views/common/header.jsp" %>

        <main class="content">
            <div class="page active">
                <div class="page-title-row">
                    <div>
                        <div style="font-size:11px;color:#94a3b8;font-weight:600;letter-spacing:.5px;margin-bottom:4px;text-transform:uppercase">
                            통관관리
                        </div>
                        <h2>수입통관 의뢰 작성</h2>
                    </div>

                    <div>
                        <button type="button"
                                class="btn btn-outline"
                                onclick="location.href='/owner/import/list.do'">
                            <span class="material-symbols-outlined" style="font-size:16px">arrow_back</span>
                            목록으로
                        </button>
                    </div>
                </div>

                <form id="importRequestForm"
                      class="form-doc"
                      action="/owner/import/form.do"
                      method="post"
                      enctype="multipart/form-data"
                      style="border-top:2px solid #0f172a;">
                    <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}">

                    <div class="form-doc-head">
                        <div class="form-doc-head-left">
                            <div class="form-doc-type">TACS · Import Customs</div>
                            <div class="form-doc-title">수입통관 의뢰서</div>
                        </div>
                    </div>

                    <div class="form-doc-body">
                        <%@ include file="/WEB-INF/views/owner/import/fragments/importFormFields.jsp" %>

                        <div class="form-doc-divider"></div>

                        <div class="alert-bar info">
                            <span class="material-symbols-outlined">info</span>
                            품목·수량·중량 정보는 첨부된 송장, 패킹리스트, B/L 등 문서를 기준으로 담당자가 확인 후 전산 등록합니다.
                        </div>

                        <%@ include file="/WEB-INF/views/owner/import/fragments/importDocUpload.jsp" %>
                    </div>

                    <div class="btn-row" style="padding:20px 28px;border-top:1px solid #f1f5f9;">
                        <button type="submit" class="btn btn-primary">수입통관 의뢰 등록</button>
                        <button type="button" class="btn btn-secondary" onclick="saveImportDraft()">임시저장</button>
                        <button type="button"
                                class="btn btn-outline"
                                onclick="location.href='/owner/import/list.do'">
                            취소
                        </button>
                    </div>
                </form>
            </div>
        </main>

        <%@ include file="/WEB-INF/views/common/ownerModals.jsp" %>
        <%@ include file="/WEB-INF/views/common/footer.jsp" %>
    </div>
</div>

<div id="importUploadLoadingOverlay"
     style="display:none;
            position:fixed;
            inset:0;
            background:rgba(15,23,42,.45);
            z-index:9999;
            align-items:center;
            justify-content:center;">
    <div style="background:#fff;
                padding:24px 32px;
                font-weight:700;
                color:#203444;
                border:1px solid #e2e8f0;">
        수입 의뢰 등록 중입니다...
    </div>
</div>

<%@ include file="/WEB-INF/views/common/ownerScripts.jsp" %>
<script src="${pageContext.request.contextPath}/resources/js/owner/import-request.js"></script>
</body>
</html>
