<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%
    request.setAttribute("activeMenu", "transport");
    request.setAttribute("activeGroup", "transport");
    request.setAttribute("activeSub", "freight");
%>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="ctx-path" content="${pageContext.request.contextPath}">
    <title>TACS 운임 정산</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/owner.css">
</head>
<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/owner/sidebar.jsp" %>

    <div class="main-wrap">
        <%@ include file="/WEB-INF/views/common/header.jsp" %>

        <main class="content">
            <div class="page active" id="pg-transport">
                <div class="page-title-row">
                    <h2>운송</h2>
                </div>
                <%@ include file="/WEB-INF/views/owner/transport/fragments/transportTabs.jsp" %>
                <div id="trans-freight">
                    <div class="filter-bar" style="margin-bottom:20px; border-left:3px solid #565e74;">
                        <div class="search-wrap" style="flex:1">
                            <span class="material-symbols-outlined">search</span>
                            <input placeholder="청구번호 · 운송업체 · B/L 번호 검색" style="width:100%"/>
                        </div>
                        <select style="min-width:120px">
                            <option>전체 상태</option>
                            <option>납부완료</option>
                            <option>확인 대기</option>
                            <option>청구서 검토</option>
                        </select>
                        <input style="padding:6px 8px;border:1px solid #e2e8f0;font-size:12px" type="date"/>
                        <span style="font-size:11px;color:#94a3b8">~</span>
                        <input style="padding:6px 8px;border:1px solid #e2e8f0;font-size:12px" type="date"/>
                        <button class="btn btn-dark">조회</button>
                    </div>
                    <div style="font-size:12px;font-weight:700;color:#475569;margin-bottom:10px">운임 청구 / 정산 목록</div>
                    <div class="card-section">
                        <table class="data-table">
                            <thead>
                            <tr>
                                <th>청구번호</th>
                                <th>운송업체</th>
                                <th>B/L 번호</th>
                                <th>청구금액</th>
                                <th>청구일</th>
                                <th>상태</th>
                                <th></th>
                            </tr>
                            </thead>
                            <tbody>
                            <tr>
                                <td style="font-weight:600">INV-2026-0089</td>
                                <td>대한포워딩</td>
                                <td>SZXA2404169901</td>
                                <td style="font-weight:700">USD 1,850</td>
                                <td style="color:#94a3b8;font-size:11px">2026-04-14</td>
                                <td><span class="doc-status ok">납부완료</span></td>
                                <td>
                                    <button class="mini mini-view">영수증</button>
                                </td>
                            </tr>
                            <tr>
                                <td style="font-weight:600">INV-2026-0101</td>
                                <td>대한포워딩</td>
                                <td>KRPT2404089902</td>
                                <td style="font-weight:700">USD 2,300</td>
                                <td style="color:#94a3b8;font-size:11px">2026-04-16</td>
                                <td><span class="doc-status wait">확인 대기</span></td>
                                <td>
                                    <button class="mini mini-sup" onclick="payFreight('INV-2026-0101','USD 2,300')">
                                        납부하기
                                    </button>
                                </td>
                            </tr>
                            <tr>
                                <td style="font-weight:600">INV-2026-0112</td>
                                <td>글로벌로지스</td>
                                <td>KRINC2404109903</td>
                                <td style="font-weight:700">EUR 1,420</td>
                                <td style="color:#94a3b8;font-size:11px">2026-04-16</td>
                                <td><span class="doc-status none">청구서 검토</span></td>
                                <td>
                                    <button class="mini mini-view">확인</button>
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                    <div style="margin-top:16px;padding:14px 16px;background:#f8fafc;border:1px solid #e2e8f0;font-size:12px;color:#64748b">
                        운임 납부 전 반드시 청구 내역(해상운임·부대비용·세금)을 확인하세요. 이의 제기는 청구일로부터 7일 이내 가능합니다.
                    </div>
                </div>
            </div>
        </main>

        <%@ include file="/WEB-INF/views/common/ownerModals.jsp" %>
        <%@ include file="/WEB-INF/views/common/footer.jsp" %>
    </div>
</div>

<%@ include file="/WEB-INF/views/common/ownerScripts.jsp" %>

</body>
</html>
