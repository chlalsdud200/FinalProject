<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.common.docs.mapper.DocsMapper">

    <!-- DOCS_FOLDER PK 생성 -->
    <select id="selectDocsFolderNo" resultType="long">
        SELECT
            seq_docs_folder.NEXTVAL
        FROM dual
    </select>

    <!-- DOCS_FILE_DATA PK 생성 -->
    <select id="selectDocsFileNo" resultType="long">
        SELECT
            seq_docs_file_data.NEXTVAL
        FROM dual
    </select>

    <!-- DOCS_BOX_FILE PK 생성 -->
    <select id="selectDocsBoxFileNo" resultType="long">
        SELECT
            seq_docs_box_file.NEXTVAL
        FROM dual
    </select>

    <!-- 사용자별 ROOT 폴더 조회 -->
    <select id="selectRootFolderNo" resultType="long">
        SELECT
            df_folder_no
        FROM docs_folder
        WHERE df_actor_id = #{actorId}
          AND df_actor_type = #{actorType}
          AND df_ty_cd = 'ROOT'
          AND df_del_yn = 'N'
          AND ROWNUM = 1
    </select>

    <!-- 사용자별 ROOT 폴더 생성 -->
    <insert id="insertRootFolder">
        INSERT INTO docs_folder (
            df_folder_no
          , df_parent_no
          , df_actor_id
          , df_actor_type
          , df_nm
          , df_ty_cd
          , df_del_yn
          , df_regist_dt
        ) VALUES (
            #{folderNo}
          , NULL
          , #{actorId}
          , #{actorType}
          , 'ROOT'
          , 'ROOT'
          , 'N'
          , SYSDATE
        )
    </insert>

    <!-- 현재 폴더가 로그인 사용자의 폴더인지 확인 -->
    <select id="countFolderOwner" resultType="int">
        SELECT
            COUNT(1)
        FROM docs_folder
        WHERE df_folder_no = #{folderNo}
          AND df_actor_id = #{actorId}
          AND df_actor_type = #{actorType}
          AND df_del_yn = 'N'
    </select>

    <!-- 현재 폴더 하위 폴더 목록 조회 -->
    <select id="selectFolderItems" resultType="kr.or.tacs.dto.common.docs.DocsItemDTO">
        SELECT
            df_folder_no AS "id"
          , 'folder' AS "type"
          , df_nm AS "name"
          , 0 AS "size"
          , TO_CHAR(df_regist_dt, 'YYYY-MM-DD HH24:MI:SS') AS "createdAt"
          , TO_CHAR(df_regist_dt, 'YYYY-MM-DD HH24:MI:SS') AS "updatedAt"
        FROM docs_folder
        WHERE df_parent_no = #{folderNo}
          AND df_actor_id = #{actorId}
          AND df_actor_type = #{actorType}
          AND df_ty_cd = 'GENERAL'
          AND df_del_yn = 'N'
        ORDER BY df_nm
    </select>

    <!-- 현재 폴더 파일 목록 조회 -->
    <select id="selectFileItems" resultType="kr.or.tacs.dto.common.docs.DocsItemDTO">
        SELECT
            B.dbf_no AS "id"
          , 'file' AS "type"
          , B.dbf_disp_nm AS "name"
          , F.dfi_size AS "size"
          , TO_CHAR(B.dbf_regist_dt, 'YYYY-MM-DD HH24:MI:SS') AS "createdAt"
          , TO_CHAR(B.dbf_regist_dt, 'YYYY-MM-DD HH24:MI:SS') AS "updatedAt"
        FROM docs_box_file B
        INNER JOIN docs_file_data F
                ON F.dfi_file_no = B.dbf_dfi_no
        WHERE B.dbf_dfd_no = #{folderNo}
          AND NVL(B.dbf_trash_yn, 'N') = 'N'
          AND F.dfi_actor_id = #{actorId}
          AND F.dfi_actor_type = #{actorType}
          AND F.dfi_biz_ty_cd = 'CLOUD'
          AND NVL(F.dfi_del_yn, 'N') = 'N'
        ORDER BY B.dbf_disp_nm
    </select>

    <!-- 현재 위치 경로 조회 -->
    <select id="selectBreadcrumb" resultType="kr.or.tacs.dto.common.docs.DocsFolderDTO">
        SELECT
            df_folder_no AS "id"
          , df_nm AS "name"
        FROM docs_folder
        WHERE df_actor_id = #{actorId}
          AND df_actor_type = #{actorType}
          AND df_del_yn = 'N'
        START WITH df_folder_no = #{folderNo}
        CONNECT BY PRIOR df_parent_no = df_folder_no
        ORDER BY LEVEL DESC
    </select>

    <!-- 사용자 저장공간 조회 -->
    <select id="selectStorage" resultType="kr.or.tacs.dto.common.docs.DocsStorageDTO">
        SELECT
            ds_max_capa AS "maxCapa"
          , ds_used_capa AS "usedCapa"
          , CASE
                WHEN ds_max_capa = 0 THEN 0
                ELSE ROUND((ds_used_capa / ds_max_capa) * 100, 2)
            END AS "usedPct"
        FROM docs_storage
        WHERE ds_actor_id = #{actorId}
          AND ds_actor_type = #{actorType}
    </select>

    <!-- 사용자 저장공간 최초 생성 -->
    <insert id="insertStorage">
        INSERT INTO docs_storage (
            ds_actor_id
          , ds_actor_type
          , ds_max_capa
          , ds_used_capa
        ) VALUES (
            #{actorId}
          , #{actorType}
          , 5368709120
          , 0
        )
    </insert>

    <!-- 업로드 후 사용량 증가 -->
    <update id="updateStorageUsed">
        UPDATE docs_storage
        SET ds_used_capa = ds_used_capa + #{size}
        WHERE ds_actor_id = #{actorId}
          AND ds_actor_type = #{actorType}
    </update>

    <!-- 일반 폴더 생성 -->
    <insert id="insertFolder">
        INSERT INTO docs_folder (
            df_folder_no
          , df_parent_no
          , df_actor_id
          , df_actor_type
          , df_nm
          , df_ty_cd
          , df_del_yn
          , df_regist_dt
        ) VALUES (
            #{folderNo}
          , #{parentNo}
          , #{actorId}
          , #{actorType}
          , #{name}
          , 'GENERAL'
          , 'N'
          , SYSDATE
        )
    </insert>

    <!-- 실제 파일 원장 등록: DOCS_FILE_DATA -->
    <insert id="insertFileData" parameterType="kr.or.tacs.dto.FileInfoDTO">
        INSERT INTO docs_file_data (
            dfi_file_no
          , dfi_actor_id
          , dfi_actor_type
          , dfi_org_nm
          , dfi_str_nm
          , dfi_size
          , dfi_path
          , dfi_ext
          , dfi_mime_ty
          , dfi_del_yn
          , dfi_regist_dt
          , dfi_biz_ty_cd
          , dfi_drive_file_id
          , dfi_upload_stts_cd
        ) VALUES (
            #{dfiFileNo}
          , #{dfiActorId}
          , #{dfiActorType}
          , #{dfiOrgNm}
          , #{dfiStrNm}
          , #{dfiSize}
          , #{dfiPath}
          , #{dfiExt}
          , #{dfiMimeTy}
          , 'N'
          , SYSDATE
          , 'CLOUD'
          , #{dfiDriveFileId}
          , NVL(#{dfiUploadSttsCd}, 'DONE')
        )
    </insert>

    <!-- 문서함 파일 항목 등록: DOCS_BOX_FILE -->
    <insert id="insertBoxFile">
        INSERT INTO docs_box_file (
            dbf_no
          , dbf_dfd_no
          , dbf_dfi_no
          , dbf_disp_nm
          , dbf_trash_yn
          , dbf_regist_dt
        ) VALUES (
            #{dbfNo}
          , #{folderNo}
          , #{dfiNo}
          , #{displayName}
          , 'N'
          , SYSDATE
        )
    </insert>

    <!-- 파일 휴지통 이동 -->
    <update id="updateFileTrash">
        UPDATE docs_box_file B
        SET B.dbf_trash_yn = 'Y'
        WHERE B.dbf_no = #{dbfNo}
          AND NVL(B.dbf_trash_yn, 'N') = 'N'
          AND EXISTS (
              SELECT
                  1
              FROM docs_file_data F
              WHERE F.dfi_file_no = B.dbf_dfi_no
                AND F.dfi_actor_id = #{actorId}
                AND F.dfi_actor_type = #{actorType}
                AND NVL(F.dfi_del_yn, 'N') = 'N'
          )
    </update>

    <!-- 폴더 휴지통 이동 -->
    <update id="updateFolderTrash">
        UPDATE docs_folder
        SET df_del_yn = 'Y'
        WHERE df_folder_no = #{folderNo}
          AND df_actor_id = #{actorId}
          AND df_actor_type = #{actorType}
          AND df_ty_cd = 'GENERAL'
          AND df_del_yn = 'N'
    </update>

    <!-- 파일 표시명 변경 -->
    <update id="updateFileName">
        UPDATE docs_box_file B
        SET B.dbf_disp_nm = #{name}
        WHERE B.dbf_no = #{dbfNo}
          AND NVL(B.dbf_trash_yn, 'N') = 'N'
          AND EXISTS (
              SELECT
                  1
              FROM docs_file_data F
              WHERE F.dfi_file_no = B.dbf_dfi_no
                AND F.dfi_actor_id = #{actorId}
                AND F.dfi_actor_type = #{actorType}
                AND NVL(F.dfi_del_yn, 'N') = 'N'
          )
    </update>

    <!-- 폴더명 변경 -->
    <update id="updateFolderName">
        UPDATE docs_folder
        SET df_nm = #{name}
        WHERE df_folder_no = #{folderNo}
          AND df_actor_id = #{actorId}
          AND df_actor_type = #{actorType}
          AND df_ty_cd = 'GENERAL'
          AND df_del_yn = 'N'
    </update>

    <!-- 파일 다운로드용 실제 파일 정보 조회 -->
    <select id="selectDownloadFile" resultType="kr.or.tacs.dto.FileInfoDTO">
        SELECT
            F.dfi_file_no AS "dfiFileNo"
          , F.dfi_actor_id AS "dfiActorId"
          , F.dfi_actor_type AS "dfiActorType"
          , B.dbf_disp_nm AS "dfiOrgNm"
          , F.dfi_str_nm AS "dfiStrNm"
          , F.dfi_size AS "dfiSize"
          , F.dfi_path AS "dfiPath"
          , F.dfi_ext AS "dfiExt"
          , F.dfi_mime_ty AS "dfiMimeTy"
          , F.dfi_del_yn AS "dfiDelYn"
          , F.dfi_biz_ty_cd AS "dfiBizTyCd"
          , F.dfi_drive_file_id AS "dfiDriveFileId"
          , F.dfi_upload_stts_cd AS "dfiUploadSttsCd"
        FROM docs_box_file B
        INNER JOIN docs_file_data F
                ON F.dfi_file_no = B.dbf_dfi_no
        WHERE B.dbf_no = #{dbfNo}
          AND F.dfi_actor_id = #{actorId}
          AND F.dfi_actor_type = #{actorType}
          AND NVL(B.dbf_trash_yn, 'N') = 'N'
          AND NVL(F.dfi_del_yn, 'N') = 'N'
          AND F.dfi_biz_ty_cd = 'CLOUD'
    </select>

    <!-- 휴지통 항목 수 계산 -->
    <select id="countTrashItems" resultType="int">
        SELECT
            (
                SELECT
                    COUNT(1)
                FROM docs_box_file B
                WHERE NVL(B.dbf_trash_yn, 'N') = 'Y'
                  AND EXISTS (
                      SELECT
                          1
                      FROM docs_file_data F
                      WHERE F.dfi_file_no = B.dbf_dfi_no
                        AND F.dfi_actor_id = #{actorId}
                        AND F.dfi_actor_type = #{actorType}
                        AND NVL(F.dfi_del_yn, 'N') = 'N'
                  )
            ) +
            (
                SELECT
                    COUNT(1)
                FROM docs_folder
                WHERE df_del_yn = 'Y'
                  AND df_actor_id = #{actorId}
                  AND df_actor_type = #{actorType}
                  AND df_ty_cd = 'GENERAL'
            ) AS CNT
        FROM dual
    </select>

    <!-- 휴지통 목록 조회 -->
    <select id="selectTrashItems" resultType="kr.or.tacs.dto.common.docs.DocsTrashItemDTO">
        SELECT
            X.ID AS "id"
          , X.ITEM_TYPE AS "type"
          , X.ITEM_NAME AS "name"
          , X.ITEM_SIZE AS "size"
          , X.TRASH_DT AS "trashDt"
        FROM (
            SELECT
                ROWNUM AS RNUM
              , T.ID
              , T.ITEM_TYPE
              , T.ITEM_NAME
              , T.ITEM_SIZE
              , T.TRASH_DT
            FROM (
                SELECT
                    'folder-' || df_folder_no AS ID
                  , 'folder' AS ITEM_TYPE
                  , df_nm AS ITEM_NAME
                  , NULL AS ITEM_SIZE
                  , TO_CHAR(df_regist_dt, 'YYYY-MM-DD HH24:MI:SS') AS TRASH_DT
                FROM docs_folder
                WHERE df_del_yn = 'Y'
                  AND df_actor_id = #{actorId}
                  AND df_actor_type = #{actorType}
                  AND df_ty_cd = 'GENERAL'
                UNION ALL
                SELECT
                    'file-' || B.dbf_no AS ID
                  , 'file' AS ITEM_TYPE
                  , B.dbf_disp_nm AS ITEM_NAME
                  , F.dfi_size AS ITEM_SIZE
                  , TO_CHAR(B.dbf_regist_dt, 'YYYY-MM-DD HH24:MI:SS') AS TRASH_DT
                FROM docs_box_file B
                INNER JOIN docs_file_data F
                        ON F.dfi_file_no = B.dbf_dfi_no
                WHERE NVL(B.dbf_trash_yn, 'N') = 'Y'
                  AND F.dfi_actor_id = #{actorId}
                  AND F.dfi_actor_type = #{actorType}
                  AND NVL(F.dfi_del_yn, 'N') = 'N'
                ORDER BY TRASH_DT DESC NULLS LAST
            ) T
        ) X
        WHERE X.RNUM BETWEEN #{pagingVO.startRow} AND #{pagingVO.endRow}
    </select>

    <!-- 휴지통 파일 원장 영구삭제 처리 -->
    <update id="deleteTrashFileDataPerm">
        UPDATE docs_file_data F
        SET F.dfi_del_yn = 'Y'
        WHERE F.dfi_actor_id = #{actorId}
          AND F.dfi_actor_type = #{actorType}
          AND EXISTS (
              SELECT
                  1
              FROM docs_box_file B
              WHERE B.dbf_dfi_no = F.dfi_file_no
                AND B.dbf_no = #{dbfNo}
                AND NVL(B.dbf_trash_yn, 'N') = 'Y'
          )
    </update>

    <!-- 휴지통 파일 화면 항목 영구삭제 -->
    <delete id="deleteTrashFilePerm">
        DELETE FROM docs_box_file B
        WHERE B.dbf_no = #{dbfNo}
          AND NVL(B.dbf_trash_yn, 'N') = 'Y'
          AND EXISTS (
              SELECT
                  1
              FROM docs_file_data F
              WHERE F.dfi_file_no = B.dbf_dfi_no
                AND F.dfi_actor_id = #{actorId}
                AND F.dfi_actor_type = #{actorType}
          )
    </delete>

    <!-- 휴지통 폴더 하위 파일 원장 영구삭제 처리 -->
    <update id="deleteTrashFolderFileDataPerm">
        UPDATE docs_file_data F
        SET F.dfi_del_yn = 'Y'
        WHERE F.dfi_actor_id = #{actorId}
          AND F.dfi_actor_type = #{actorType}
          AND EXISTS (
              SELECT
                  1
              FROM docs_box_file B
              WHERE B.dbf_dfi_no = F.dfi_file_no
                AND B.dbf_dfd_no IN (
                    SELECT
                        df_folder_no
                    FROM docs_folder
                    WHERE df_actor_id = #{actorId}
                      AND df_actor_type = #{actorType}
                    START WITH df_folder_no = #{folderNo}
                           AND df_actor_id = #{actorId}
                           AND df_actor_type = #{actorType}
                           AND df_ty_cd = 'GENERAL'
                           AND df_del_yn = 'Y'
                    CONNECT BY PRIOR df_folder_no = df_parent_no
                           AND df_actor_id = #{actorId}
                           AND df_actor_type = #{actorType}
                )
          )
    </update>

    <!-- 휴지통 폴더 하위 파일 화면 항목 영구삭제 -->
    <delete id="deleteTrashFolderFilesPerm">
        DELETE FROM docs_box_file B
        WHERE B.dbf_dfd_no IN (
            SELECT
                df_folder_no
            FROM docs_folder
            WHERE df_actor_id = #{actorId}
              AND df_actor_type = #{actorType}
            START WITH df_folder_no = #{folderNo}
                   AND df_actor_id = #{actorId}
                   AND df_actor_type = #{actorType}
                   AND df_ty_cd = 'GENERAL'
                   AND df_del_yn = 'Y'
            CONNECT BY PRIOR df_folder_no = df_parent_no
                   AND df_actor_id = #{actorId}
                   AND df_actor_type = #{actorType}
        )
    </delete>

    <!-- 휴지통 폴더 영구삭제 -->
    <delete id="deleteTrashFolderPerm">
        DELETE FROM docs_folder
        WHERE df_folder_no IN (
            SELECT
                df_folder_no
            FROM docs_folder
            WHERE df_actor_id = #{actorId}
              AND df_actor_type = #{actorType}
            START WITH df_folder_no = #{folderNo}
                   AND df_actor_id = #{actorId}
                   AND df_actor_type = #{actorType}
                   AND df_ty_cd = 'GENERAL'
                   AND df_del_yn = 'Y'
            CONNECT BY PRIOR df_folder_no = df_parent_no
                   AND df_actor_id = #{actorId}
                   AND df_actor_type = #{actorType}
        )
    </delete>

    <!-- 휴지통 전체 파일 원장 영구삭제 처리 -->
    <update id="emptyTrashFileData">
        UPDATE docs_file_data F
        SET F.dfi_del_yn = 'Y'
        WHERE F.dfi_actor_id = #{actorId}
          AND F.dfi_actor_type = #{actorType}
          AND EXISTS (
              SELECT
                  1
              FROM docs_box_file B
              WHERE B.dbf_dfi_no = F.dfi_file_no
                AND NVL(B.dbf_trash_yn, 'N') = 'Y'
          )
    </update>

    <!-- 휴지통 전체 파일 화면 항목 영구삭제 -->
    <delete id="emptyTrashFiles">
        DELETE FROM docs_box_file B
        WHERE NVL(B.dbf_trash_yn, 'N') = 'Y'
          AND EXISTS (
              SELECT
                  1
              FROM docs_file_data F
              WHERE F.dfi_file_no = B.dbf_dfi_no
                AND F.dfi_actor_id = #{actorId}
                AND F.dfi_actor_type = #{actorType}
          )
    </delete>

    <!-- 휴지통 전체 폴더 하위 파일 원장 영구삭제 처리 -->
    <update id="emptyTrashFolderFileData">
        UPDATE docs_file_data F
        SET F.dfi_del_yn = 'Y'
        WHERE F.dfi_actor_id = #{actorId}
          AND F.dfi_actor_type = #{actorType}
          AND EXISTS (
              SELECT
                  1
              FROM docs_box_file B
              WHERE B.dbf_dfi_no = F.dfi_file_no
                AND B.dbf_dfd_no IN (
                    SELECT
                        df_folder_no
                    FROM docs_folder
                    WHERE df_actor_id = #{actorId}
                      AND df_actor_type = #{actorType}
                    START WITH df_del_yn = 'Y'
                           AND df_actor_id = #{actorId}
                           AND df_actor_type = #{actorType}
                           AND df_ty_cd = 'GENERAL'
                    CONNECT BY PRIOR df_folder_no = df_parent_no
                           AND df_actor_id = #{actorId}
                           AND df_actor_type = #{actorType}
                )
          )
    </update>

    <!-- 휴지통 전체 폴더 하위 파일 화면 항목 영구삭제 -->
    <delete id="emptyTrashFolderFiles">
        DELETE FROM docs_box_file B
        WHERE B.dbf_dfd_no IN (
            SELECT
                df_folder_no
            FROM docs_folder
            WHERE df_actor_id = #{actorId}
              AND df_actor_type = #{actorType}
            START WITH df_del_yn = 'Y'
                   AND df_actor_id = #{actorId}
                   AND df_actor_type = #{actorType}
                   AND df_ty_cd = 'GENERAL'
            CONNECT BY PRIOR df_folder_no = df_parent_no
                   AND df_actor_id = #{actorId}
                   AND df_actor_type = #{actorType}
        )
    </delete>

    <!-- 휴지통 전체 폴더 영구삭제 -->
    <delete id="emptyTrashFolders">
        DELETE FROM docs_folder
        WHERE df_folder_no IN (
            SELECT
                df_folder_no
            FROM docs_folder
            WHERE df_actor_id = #{actorId}
              AND df_actor_type = #{actorType}
            START WITH df_del_yn = 'Y'
                   AND df_actor_id = #{actorId}
                   AND df_actor_type = #{actorType}
                   AND df_ty_cd = 'GENERAL'
            CONNECT BY PRIOR df_folder_no = df_parent_no
                   AND df_actor_id = #{actorId}
                   AND df_actor_type = #{actorType}
        )
    </delete>

</mapper>
