/* =========================================================
   TACS 검역기관 공통 스타일
   - 전체 초기화
   - 공통 레이아웃
   - 사이드바
   - 상단바
   - 공통 버튼
   - 공통 폼
   - 공통 테이블
   - 공통 탭
   - 공통 푸터
========================================================= */

/* ===== Reset / Base ===== */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  border-radius: 0 !important;
  font-family: 'Inter', sans-serif;
}

body {
  background: #f6f9ff;
  color: #203444;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
select,
textarea {
  font-family: inherit;
}

.material-symbols-outlined {
  font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
}

/* ===== Layout ===== */
.app {
  display: flex;
  min-height: 100vh;
  background: #f6f9ff;
  color: #203444;
}

.main-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.content {
  flex: 1;
  padding: 32px;
  background: #f6f9ff;
}

.page {
  display: none;
}

.page.active {
  display: block;
}

/* ===== Sidebar ===== */
.aside {
  width: 256px;
  min-height: 100vh;
  height: 100vh;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  padding: 32px 0 24px;
  background: #f1f5f9;
}

.logo-area {
  padding: 0 24px;
  margin-bottom: 40px;
}

.logo-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.logo-icon {
  width: 32px;
  height: 32px;
  background: #565e74;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon .material-symbols-outlined {
  color: #f7f7ff;
  font-size: 20px;
}

.logo-text h1 {
  font-size: 18px;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.2;
}

.logo-text p {
  font-size: 10px;
  color: #4d6172;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
}

/* ===== Sidebar Basic Menu ===== */
.nav-link {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 24px;
  border: none;
  background: none;
  color: #64748b;
  font-size: 14px;
  text-align: left;
  cursor: pointer;
  transition: all .15s;
}

.nav-link:hover {
  background: #e2e8f0;
  color: #334155;
}

.nav-link.active {
  background: #fff;
  color: #0f172a;
  font-weight: 700;
  border-left: 4px solid #0f172a;
}

.nav-link .material-symbols-outlined {
  font-size: 22px;
}

.nav-link .notif {
  width: 18px;
  height: 18px;
  margin-left: auto;
  background: #9f403d;
  color: #fff;
  font-size: 9px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-divider {
  height: 1px;
  background: #e2e8f0;
  margin: 12px 0;
}

.nav-bottom {
  margin-top: auto;
  padding-top: 12px;
  border-top: 1px solid #e2e8f0;
}

.nav-cta {
  height: 44px;
  margin: 0 20px 12px;
  border: none;
  background: #565e74;
  color: #f7f7ff;
  font-size: 14px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  cursor: pointer;
  transition: background .15s;
}

.nav-cta:hover {
  background: #4a5268;
}

/* ===== Sidebar Card Menu ===== */
.nav-card {
  margin: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  overflow: hidden;
}

.nav-card.single {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 16px;
  color: #203444;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
}

.nav-card.single:hover {
  background: #f8fafc;
}

.nav-card.single.active {
  background: #eef4ff;
  color: #0f172a;
  font-weight: 700;
  border-left: 4px solid #0f172a;
}

.nav-card.single .material-symbols-outlined {
  font-size: 20px;
  color: #334155;
}

/* 검역 합격 증명서 발급 메뉴와 문서함 사이 간격 조정 */
.nav-card.single[data-p="docs"] {
  margin-top: 20px;
}

.nav-group-header {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 24px;
  border: none;
  background: transparent;
  color: #64748b;
  font-size: 14px;
  font-weight: 400;
  cursor: pointer;
  transition: all .15s;
}

.nav-group-header:hover {
  background: #e2e8f0;
  color: #334155;
}

.nav-card.active .nav-group-header {
  background: #fff;
  color: #0f172a;
  font-weight: 700;
  border-left: 4px solid #0f172a;
  padding-left: 20px;
}

.nav-group-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.nav-group-left .material-symbols-outlined {
  font-size: 22px;
  color: currentColor;
}

.nav-group-arrow {
  font-size: 18px;
  color: #64748b;
  transition: transform .2s ease;
}

.nav-submenu {
  display: none;
  border-top: none;
  background: transparent;
}

.nav-submenu.open {
  display: block;
}

.nav-hover-group:hover .nav-submenu {
  display: block;
}

.nav-hover-group:hover .nav-group-arrow,
.nav-group-arrow.open {
  transform: rotate(180deg);
}

.nav-sub-link {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 12px 18px 12px 48px;
  border: none;
  background: transparent;
  color: #475569;
  font-size: 13px;
  cursor: pointer;
  text-align: left;
  transition: all .15s;
}

.nav-sub-link:hover {
  background: #e2e8f0;
  color: #0f172a;
}

.nav-sub-link.active-sub {
  background: #eef4ff;
  color: #0f172a;
  font-weight: 700;
  border-left: 4px solid #0f172a;
  padding-left: 44px;
}

/* ===== Topbar ===== */
.topbar {
  height: 64px;
  position: sticky;
  top: 0;
  z-index: 10;
  background: #fafbfc;
  border-bottom: 2px solid #0f172a;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
}

.tb-left {
  display: flex;
  align-items: center;
  gap: 24px;
}

.tb-brand {
  font-size: 20px;
  font-weight: 900;
  color: #0f172a;
  letter-spacing: -1px;
}

.search-wrap {
  position: relative;
}

.search-wrap .material-symbols-outlined {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: #697d8f;
  font-size: 18px;
}

.search-wrap input {
  width: 340px;
  padding: 8px 16px 8px 40px;
  background: #d0e5fa;
  border: none;
  border-bottom: 2px solid #a0b4c8;
  font-size: 13px;
  color: #203444;
  outline: none;
  transition: all .2s;
}

.search-wrap input:focus {
  border-bottom-color: #565e74;
  background: #c4ddf5;
}

.search-wrap input::placeholder {
  color: #697d8f;
}

.tb-right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.tb-btn {
  padding: 8px;
  color: #475569;
  cursor: pointer;
  background: none;
  border: none;
  transition: background .15s;
  position: relative;
}

.tb-btn:hover {
  background: #e2e8f0;
}

.tb-btn .dot {
  position: absolute;
  top: 6px;
  right: 6px;
  width: 7px;
  height: 7px;
  background: #9f403d;
}

.tb-sep {
  width: 1px;
  height: 32px;
  background: #cbd5e1;
  margin: 0 8px;
}

.tb-user {
  display: flex;
  align-items: center;
  gap: 10px;
}

.tb-user-info {
  text-align: right;
}

.tb-user-info .name {
  font-size: 12px;
  font-weight: 700;
  color: #0f172a;
}

.tb-user-info .role {
  font-size: 10px;
  color: #64748b;
}

.tb-avatar {
  width: 40px;
  height: 40px;
  background: #565e74;
  color: #f7f7ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 14px;
}

/* ===== Common Page Header ===== */
.breadcrumb {
  font-size: 11px;
  color: #697d8f;
  margin-bottom: 14px;
}

.breadcrumb span {
  cursor: pointer;
}

.breadcrumb span:hover {
  color: #565e74;
}

.breadcrumb .sep {
  margin: 0 4px;
}

.sub-page {
  background: #fff;
  padding: 24px;
  margin-bottom: 16px;
}

.sub-page h2 {
  font-size: 16px;
  font-weight: 800;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 10px;
  color: #203444;
}

.sub-page h2 .material-symbols-outlined {
  font-size: 22px;
  color: #565e74;
}

/* ===== Common Tabs ===== */
.sub-tabs {
  display: flex;
  border-bottom: 2px solid #e2e8f0;
  margin-bottom: 18px;
  gap: 0;
}

.sub-tab {
  padding: 8px 20px;
  font-size: 12px;
  font-weight: 700;
  color: #697d8f;
  cursor: pointer;
  border: none;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  background: none;
  transition: all .12s;
  white-space: nowrap;
}

.sub-tab.active {
  color: #565e74;
  border-bottom-color: #565e74;
}

.sub-tab:hover {
  color: #203444;
}

.page-top-tabs {
  display: flex;
  border-bottom: 1px solid #e2e8f0;
  margin-bottom: 24px;
}

.page-top-tab {
  padding: 14px 24px;
  font-size: 13px;
  font-weight: 700;
  color: #64748b;
  border: none;
  background: none;
  cursor: pointer;
}

.page-top-tab.active {
  color: #0f172a;
  border-bottom: 2px solid #0f172a;
}

/* ===== Common Form ===== */
.selector-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 18px;
  padding: 10px 16px;
  background: #ecf4ff;
  border-left: 4px solid #565e74;
}

.selector-bar label {
  font-size: 11px;
  font-weight: 700;
  color: #4d6172;
  white-space: nowrap;
}

.selector-bar select {
  min-width: 220px;
  padding: 6px 10px;
  border: 1px solid #a0b4c8;
  background: #fff;
  color: #203444;
  font-size: 13px;
  outline: none;
}

.selector-bar select:focus {
  border-color: #565e74;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px 24px;
  margin-bottom: 18px;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.form-item.full {
  grid-column: 1 / -1;
}

.form-item label {
  font-size: 11px;
  font-weight: 700;
  color: #4d6172;
  text-transform: uppercase;
  letter-spacing: .5px;
}

.form-item label .req {
  color: #9f403d;
}

.form-item input,
.form-item select,
.form-item textarea {
  padding: 8px 10px;
  border: 1px solid #a0b4c8;
  background: #fff;
  color: #203444;
  font-size: 13px;
  outline: none;
  transition: border-color .2s, background .2s;
}

.form-item input:focus,
.form-item select:focus,
.form-item textarea:focus {
  border-color: #565e74;
  background: #f6f9ff;
}

/* ===== Common Button ===== */
.btn-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.btn {
  padding: 8px 18px;
  font-size: 12px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  transition: all .12s;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.btn-primary {
  background: #565e74;
  color: #f7f7ff;
}

.btn-primary:hover {
  background: #4a5268;
}

.btn-secondary {
  background: #ecf4ff;
  color: #565e74;
  border: 1px solid #a0b4c8;
}

.btn-secondary:hover {
  background: #d9eafc;
}

.btn-danger {
  background: #9f403d;
  color: #fff;
}

.btn-danger:hover {
  background: #752121;
}

.btn-outline {
  background: transparent;
  border: 1px solid #697d8f;
  color: #203444;
}

.btn-outline:hover {
  background: #ecf4ff;
}

.btn-success {
  background: #1d6b4f;
  color: #fff;
}

.btn-success:hover {
  background: #145239;
}

.mini {
  padding: 6px 12px;
  font-size: 10px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  transition: all .12s;
}

.mini-view {
  background: #ecf4ff;
  color: #565e74;
}

.mini-view:hover {
  background: #d0e5fa;
}

.mini-accept {
  background: #d1fae5;
  color: #065f46;
}

.mini-accept:hover {
  background: #a7f3d0;
}

.mini-reject {
  background: #fecaca;
  color: #991b1b;
}

.mini-reject:hover {
  background: #fca5a5;
}

.mini-sup {
  background: #fef3c7;
  color: #92400e;
}

.mini-sup:hover {
  background: #fde68a;
}

/* ===== Common Badge / Alert ===== */
.badge-new {
  background: #dae2fd;
  color: #373f54;
}

.badge-urgent {
  background: #fe8983;
  color: #752121;
}

.badge-wait {
  background: #fef3c7;
  color: #92400e;
}

.badge-ok {
  background: #565e74;
  color: #f7f7ff;
}

.badge-doc {
  background: #fe8983;
  color: #752121;
}

.badge-rev {
  background: #fff;
  border-left: 3px solid #605c78;
  color: #605c78;
}

.alert-bar {
  padding: 10px 16px;
  margin-bottom: 14px;
  font-size: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.alert-bar.info {
  background: #dae2fd;
  color: #373f54;
}

.alert-bar.warn {
  background: #fe8983;
  color: #752121;
}

.alert-bar.success {
  background: #d1fae5;
  color: #065f46;
}

/* ===== Common Table ===== */
table.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}

table.data-table thead tr {
  background: #ecf4ff;
}

table.data-table thead th {
  padding: 8px 16px;
  text-align: left;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: #4d6172;
}

table.data-table tbody td {
  padding: 10px 16px;
  border-bottom: 1px solid #d9eafc;
}

table.data-table tbody tr:hover {
  background: #f0f7ff;
}

.td-id {
  font-weight: 700;
  color: #203444;
}

.td-muted {
  color: #697d8f;
  font-size: 11px;
}

/* ===== Simple Common List ===== */
.simple-list {
  display: grid;
  gap: 12px;
}

.simple-item {
  background: #fff;
  border: 1px solid #dbe5ef;
  padding: 18px 20px;
}

.simple-item h4 {
  font-size: 14px;
  font-weight: 800;
  color: #203444;
  margin-bottom: 6px;
}

.simple-item p {
  font-size: 12px;
  color: #64748b;
  line-height: 1.6;
}

/* ===== Utility ===== */
.summary-grid {
  display: grid;
  gap: 16px;
  margin-bottom: 20px;
}

.summary-grid-4 {
  grid-template-columns: repeat(4, 1fr);
}

.section-title-line {
  font-size: 12px;
  font-weight: 700;
  color: #4d6172;
  margin-bottom: 10px;
  border-left: 3px solid #565e74;
  padding-left: 8px;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* ===== Footer ===== */
.footer {
  padding: 12px 24px;
  background: #d9eafc;
  border-top: 1px solid #cbd5e1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 10px;
  color: #4d6172;
}

.footer a {
  color: #4d6172;
  text-decoration: none;
  margin-left: 16px;
}

.footer a:hover {
  color: #565e74;
}

.footer-right {
  display: flex;
  align-items: center;
  gap: 6px;
}

.footer-dot {
  width: 5px;
  height: 5px;
  background: #22c55e;
}

/* ===== Responsive ===== */
@media (max-width: 1280px) {
  .summary-grid-4 {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 900px) {
  .aside {
    display: none;
  }

  .topbar {
    position: static;
  }

  .search-wrap input {
    width: 220px;
  }

  .form-grid {
    grid-template-columns: 1fr;
  }

  .summary-grid-4 {
    grid-template-columns: 1fr;
  }
}


/* 문서함용 팝업은 기본적으로 숨김 */
#docs-ctx-menu,
#docs-drop-overlay {
  display: none;
}
