<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ include file="/WEB-INF/views/officer/common/taglibs.jsp" %>
<%@ taglib uri="http://www.springframework.org/security/tags" prefix="sec" %>

<c:set var="ctx" value="${pageContext.request.contextPath}" />
<c:set var="activeMenu" value="cargo" />
<c:set var="activeSub" value="loadedCargoList" />

<!DOCTYPE html>
<html lang="ko">
    <head>
        <%@ include file="/WEB-INF/views/officer/header/head.jsp" %>
        <title>TACS · 적재화물목록 / 혼재화물 적하목록 조회</title>
        <link rel="stylesheet" href="${ctx}/resources/css/officer/pages/loadedCargoList.css">
    </head>

    <body>
        <%@ include file="/WEB-INF/views/officer/header/sidebar.jsp" %>
        <%@ include file="/WEB-INF/views/officer/header/header.jsp" %>

        <main class="officer-main">
            <div class="page-content loadedCargoList-page">
                <div class="mb-5">
                    <h2 class="text-xl font-black text-slate-900">적재화물목록 / 혼재화물 적하목록 조회</h2>
                </div>

                <div class="inline-screen-host active" id="screen-host-TACS-AD-017">
                    <div class="inline-screen-header">
                        <h3 class="font-black text-base">적재화물목록 / 혼재화물 적하목록 조회</h3>
                    </div>
                    <div class="inline-screen-body">
                        <div class="receipt-search-panel white-bg">
                            <p class="section-title receipt-search-title">검색 조건</p>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">신고번호</div>
                                <div class="receipt-search-field receipt-search-field-wide">
                                    <input class="receipt-search-input" placeholder="신고번호 입력" style="width:100%;" type="text"/>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">제출 상태</div>
                                <div class="receipt-search-field receipt-search-field-md">
                                    <select class="receipt-search-select w-full">
                                        <option>전체</option>
                                        <option>제출완료</option>
                                        <option>미제출</option>
                                        <option>불일치</option>
                                    </select>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">구분</div>
                                <div class="receipt-search-radio-group">
                                    <label class="receipt-check-item"><input checked="" type="checkbox"/> 전체</label>
                                    <label class="receipt-check-item"><input type="checkbox"/> 수입</label>
                                    <label class="receipt-check-item"><input type="checkbox"/> 수출</label>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">제출 일자</div>
                                <div class="receipt-search-date-wrap">
                                    <input class="receipt-search-date" type="date" value="2026-04-01"/>
                                    <span class="receipt-search-date-sep">~</span>
                                    <input class="receipt-search-date" type="date" value="2026-04-30"/>
                                    <button class="receipt-inline-btn">최근 1주일</button>
                                </div>
                            </div>
                            <div class="receipt-search-row receipt-search-row-last">
                                <div class="receipt-search-label">통합 검색</div>
                                <div class="receipt-search-bottom">
                                    <input class="receipt-search-input" placeholder="B/L번호 또는 화주명 입력" type="text"/>
                                    <button class="btn-primary receipt-action-btn">조회</button>
                                    <button class="btn-secondary receipt-action-btn">초기화</button>
                                </div>
                            </div>
                        </div>
                        <div class="cargo-tab-table-shell">
                            <div class="line-tabs cargo-bookmark-tabs">
                                <button class="line-tab active" data-tab-group="cargo-list-type" data-tab-key="loading-list" onclick="setCargoListTab('loading-list',this)">적재화물목록</button>
                                <button class="line-tab" data-tab-group="cargo-list-type" data-tab-key="house-list" onclick="setCargoListTab('house-list',this)">혼재화물 적하목록</button>
                            </div>

                            <div data-panel-group="cargo-list-type" data-panel-key="loading-list" style="display:block;">
                                <div class="flex items-center justify-between mb-3">
                                    <div class="text-[15px] font-bold text-slate-800">적재화물목록 검증 대상 <span class="text-blue-600 ml-2">3건</span></div>
                                </div>
                                <div class="bg-white border border-slate-200 mb-4">
                                    <table class="data-table cargo-list-table">
                                        <thead>
                                            <tr>
                                                <th>No.</th>
                                                <th>B/L번호</th>
                                                <th>신고번호</th>
                                                <th>선박명</th>
                                                <th>화주명</th>
                                                <th>품명</th>
                                                <th>목록제출</th>
                                                <th>비고</th>
                                                <th>상세</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr class="cargo-click-row"
                                                data-type="loading"
                                                data-list-no="ECM-001"
                                                data-bl-no="MBL-KR26041801"
                                                data-req-no="ER-20260418-007"
                                                data-vessel-name="HMM OCEAN"
                                                data-owner-name="미래로지스(주)"
                                                data-item-name="자동차부품"
                                                data-manifest-item-name="자동차부품"
                                                data-submit-status="제출완료"
                                                data-submit-date="2026-04-18"
                                                data-remark="신고내용 일치 확인">
                                                <td>1</td>
                                                <td class="font-bold text-blue-600">MBL-KR26041801</td>
                                                <td>ER-20260418-007</td>
                                                <td>HMM OCEAN</td>
                                                <td>미래로지스(주)</td>
                                                <td>자동차부품</td>
                                                <td><span class="badge-done">제출완료</span></td>
                                                <td>신고내용 일치 확인</td>
                                                <td><button type="button" class="btn-secondary receipt-action-btn btn-cargo-detail">상세</button></td>
                                            </tr>
                                            <tr class="cargo-click-row"
                                                data-type="loading"
                                                data-list-no="ECM-002"
                                                data-bl-no="MBL-KR26041711"
                                                data-req-no="ER-20260417-011"
                                                data-vessel-name="MSC GRACE"
                                                data-owner-name="서해테크"
                                                data-item-name="산업기기"
                                                data-manifest-item-name="산업기기"
                                                data-item-result="중량 차이 확인"
                                                data-submit-status="확인필요"
                                                data-submit-date="2026-04-17"
                                                data-remark="중량 차이 60KG">
                                                <td>2</td>
                                                <td class="font-bold text-blue-600">MBL-KR26041711</td>
                                                <td>ER-20260417-011</td>
                                                <td>MSC GRACE</td>
                                                <td>서해테크</td>
                                                <td>산업기기</td>
                                                <td><span class="badge-wait">확인필요</span></td>
                                                <td>중량 차이 60KG</td>
                                                <td><button type="button" class="btn-secondary receipt-action-btn btn-cargo-detail">상세</button></td>
                                            </tr>
                                            <tr class="cargo-click-row"
                                                data-type="loading"
                                                data-list-no="ECM-003"
                                                data-bl-no="MBL-KR26041209"
                                                data-req-no="ER-20260310-022"
                                                data-vessel-name="KMTC BUSAN"
                                                data-owner-name="코오롱(주)"
                                                data-item-name="화학제품"
                                                data-manifest-item-name="-"
                                                data-submit-status="미제출"
                                                data-submit-date="-"
                                                data-remark="적재목록 미제출 기한초과">
                                                <td>3</td>
                                                <td class="font-bold text-blue-600">MBL-KR26041209</td>
                                                <td>ER-20260310-022</td>
                                                <td>KMTC BUSAN</td>
                                                <td>코오롱(주)</td>
                                                <td>화학제품</td>
                                                <td><span class="badge-fail">미제출</span></td>
                                                <td>적재목록 미제출 기한초과</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div data-panel-group="cargo-list-type" data-panel-key="house-list" style="display:none;">
                                <div class="flex items-center justify-between mb-3">
                                    <div class="text-[15px] font-bold text-slate-800">혼재화물 적하목록 검증 대상 <span class="text-blue-600 ml-2">3건</span></div>
                                </div>
                                <div class="bg-white border border-slate-200 mb-4">
                                    <table class="data-table cargo-list-table">
                                        <thead>
                                            <tr>
                                                <th>No.</th>
                                                <th>MBL</th>
                                                <th>HBL</th>
                                                <th>신고번호</th>
                                                <th>화주명</th>
                                                <th>품명</th>
                                                <th>신고상태</th>
                                                <th>비고</th>
                                                <th>상세</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr class="cargo-click-row"
                                                data-type="house"
                                                data-list-no="ICM-001"
                                                data-mbl-no="MBL-KR26041801"
                                                data-hbl-no="HBL-260418-031"
                                                data-req-no="IR-20260418-031"
                                                data-owner-name="정다운무역"
                                                data-item-name="냉동망고"
                                                data-manifest-item-name="냉동망고"
                                                data-submit-status="수리완료"
                                                data-submit-date="2026-04-18"
                                                data-remark="화주·수량 일치 확인">
                                                <td>1</td>
                                                <td class="font-bold text-blue-600">MBL-KR26041801</td>
                                                <td>HBL-260418-031</td>
                                                <td>IR-20260418-031</td>
                                                <td>정다운무역</td>
                                                <td>냉동망고</td>
                                                <td><span class="badge-done">수리완료</span></td>
                                                <td>화주·수량 일치 확인</td>
                                                <td><button type="button" class="btn-secondary receipt-action-btn btn-cargo-detail">상세</button></td>
                                            </tr>
                                            <tr class="cargo-click-row"
                                                data-type="house"
                                                data-list-no="ICM-002"
                                                data-mbl-no="MBL-KR26041801"
                                                data-hbl-no="HBL-260418-044"
                                                data-req-no="IR-20260418-044"
                                                data-owner-name="동해전자(주)"
                                                data-item-name="전자부품"
                                                data-manifest-item-name="전자부품류"
                                                data-item-result="품명 상이 확인 필요"
                                                data-submit-status="심사중"
                                                data-submit-date="2026-04-18"
                                                data-remark="품명 상이 확인 필요">
                                                <td>2</td>
                                                <td class="font-bold text-blue-600">MBL-KR26041801</td>
                                                <td>HBL-260418-044</td>
                                                <td>IR-20260418-044</td>
                                                <td>동해전자(주)</td>
                                                <td>전자부품</td>
                                                <td><span class="badge-progress">심사중</span></td>
                                                <td>품명 상이 확인 필요</td>
                                                <td><button type="button" class="btn-secondary receipt-action-btn btn-cargo-detail">상세</button></td>
                                            </tr>
                                            <tr class="cargo-click-row"
                                                data-type="house"
                                                data-list-no="ICM-003"
                                                data-mbl-no="MBL-KR26041718"
                                                data-hbl-no="HBL-260417-009"
                                                data-req-no="IR-20260417-009"
                                                data-owner-name="세림푸드(주)"
                                                data-item-name="가공식품"
                                                data-manifest-item-name="가공식품"
                                                data-submit-status="심사중"
                                                data-submit-date="2026-04-17"
                                                data-remark="HBL 누락 의심, 원본 대조 필요">
                                                <td>3</td>
                                                <td class="font-bold text-blue-600">MBL-KR26041718</td>
                                                <td>HBL-260417-009</td>
                                                <td>IR-20260417-009</td>
                                                <td>세림푸드(주)</td>
                                                <td>가공식품</td>
                                                <td><span class="badge-wait">심사중</span></td>
                                                <td>HBL 누락 의심, 원본 대조 필요</td>
                                                <td><button type="button" class="btn-secondary receipt-action-btn btn-cargo-detail">상세</button></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div id="cargo-list-detail-panel" class="detail-panel" style="display:none;">
                            <div class="info-card mb-0">
                                <p class="section-title">상세 정보</p>
                                <div class="cargo-detail-grid">
                                    <div class="cargo-detail-item"><span class="cargo-detail-label">목록구분</span><span class="cargo-detail-value" id="detailType">-</span></div>
                                    <div class="cargo-detail-item"><span class="cargo-detail-label" id="detailMainNoLabel">B/L번호</span><span class="cargo-detail-value" id="detailMainNo">-</span></div>
                                    <div class="cargo-detail-item"><span class="cargo-detail-label">신고번호</span><span class="cargo-detail-value" id="detailReqNo">-</span></div>
                                    <div class="cargo-detail-item"><span class="cargo-detail-label">목록번호</span><span class="cargo-detail-value" id="detailListNo">-</span></div>
                                    <div class="cargo-detail-item"><span class="cargo-detail-label">화주명</span><span class="cargo-detail-value" id="detailOwnerName">-</span></div>
                                    <div class="cargo-detail-item"><span class="cargo-detail-label">품명</span><span class="cargo-detail-value" id="detailItemName">-</span></div>
                                    <div class="cargo-detail-item"><span class="cargo-detail-label">선박명</span><span class="cargo-detail-value" id="detailVesselName">-</span></div>
                                    <div class="cargo-detail-item"><span class="cargo-detail-label">제출/신고상태</span><span class="cargo-detail-value" id="detailSubmitStatus">-</span></div>
                                    <div class="cargo-detail-item"><span class="cargo-detail-label">제출일자</span><span class="cargo-detail-value" id="detailSubmitDate">-</span></div>
                                    <div class="cargo-detail-item cargo-detail-item-wide"><span class="cargo-detail-label">비고</span><span class="cargo-detail-value" id="detailRemark">-</span></div>
                                </div>

                                <p class="section-title">신고정보 ↔ 목록정보 확인</p>
                                <table class="data-table mb-4">
                                    <thead>
                                        <tr>
                                            <th>확인항목</th>
                                            <th>신고서 값</th>
                                            <th>목록 값</th>
                                            <th>확인결과</th>
                                        </tr>
                                    </thead>
                                    <tbody id="cargoCompareBody"></tbody>
                                </table>

                                <p class="section-title">처리 메모</p>
                                <div class="cargo-memo-box">
                                    <textarea id="cargoMemo" class="cargo-memo-textarea" placeholder="확인 내용, 추가 확인 필요사항, 증빙 확인 결과 등을 입력하세요."></textarea>
                                    <div class="cargo-memo-actions">
                                        <button type="button" id="btnSaveCargoMemo" class="btn-primary receipt-action-btn">메모 저장</button>
                                        <span id="cargoMemoSavedText" class="cargo-memo-saved"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </main>

        <%@ include file="/WEB-INF/views/officer/footer/footer.jsp" %>
        <%@ include file="/WEB-INF/views/officer/footer/scripts.jsp" %>

        <script defer src="${ctx}/resources/js/officer/pages/loadedCargoList.js"></script>
    </body>
</html>
