// dashboard.js - 대시보드 전용 스크립트

document.addEventListener('DOMContentLoaded', function () {
  // type 없는 버튼에 type="button" 자동 부여 (폼 submit 방지)
  document.querySelectorAll('button:not([type])').forEach(function (btn) {
    btn.setAttribute('type', 'button');
  });

  // 상단 업무 카드 클릭 이동
  document.querySelectorAll('#page-dashboard .dashboard-stat-card[data-href]').forEach(function (card) {
    card.addEventListener('click', function () {
      var href = card.getAttribute('data-href');
      if (href) location.href = href;
    });
  });

  // 테이블 행 클릭 이동 (버튼/링크 클릭은 제외)
  document.querySelectorAll('#page-dashboard .dashboard-table tbody tr[data-href]').forEach(function (row) {
    row.addEventListener('click', function (e) {
      if (e.target.closest('button, a')) return;
      var href = row.getAttribute('data-href');
      if (href) location.href = href;
    });
  });
});