                                        <td>2026-04-17</td>
                                        <td><span class="badge-done">반출완료</span></td>
                                        <td><button class="btn-secondary btn-sm" onclick="toggleFulfillmentDetail(this,'import-release')">상세</button></td>
                                    </tr>
                                    <tr>
                                        <td>3</td>
                                        <td><span class="badge-progress">수입 반출</span></td>
                                        <td class="font-bold text-blue-600">IR-20260412-014</td>
                                        <td>세림푸드(주)</td>
                                        <td>냉동식품</td>
                                        <td>평택 냉동보세창고 · 냉동A구역</td>
                                        <td>2026-04-12</td>
                                        <td><span class="badge-wait">미반출 D+6</span></td>
                                        <td><button class="btn-secondary btn-sm" onclick="toggleFulfillmentDetail(this,'import-release')">상세</button></td>
                                    </tr>
                                    <tr>
                                        <td>4</td>
                                        <td><span class="badge-wait">즉시반출</span></td>
                                        <td class="font-bold text-blue-600">IR-20260418-009</td>
                                        <td>동해전자(주)</td>
                                        <td>반도체 설비부품</td>
                                        <td>인천항 CFS창고 · C-03구역</td>
                                        <td>2026-04-18</td>
                                        <td><span class="badge-progress">허용대기</span></td>
                                        <td><button class="btn-secondary btn-sm" onclick="toggleFulfillmentDetail(this,'immediate-release')">상세</button></td>
                                    </tr>
                                    <tr>
                                        <td>5</td>
                                        <td><span class="badge-wait">즉시반출</span></td>
                                        <td class="font-bold text-blue-600">IR-20260418-014</td>
                                        <td>정다운무역</td>
                                        <td>냉동망고</td>
                                        <td>평택 냉동보세창고 · 냉동B구역</td>
                                        <td>2026-04-18</td>
                                        <td><span class="badge-wait">검토중</span></td>
                                        <td><button class="btn-secondary btn-sm" onclick="toggleFulfillmentDetail(this,'immediate-release')">상세</button></td>
                                    </tr>
                                    <tr>
                                        <td>6</td>
                                        <td><span class="badge-done">수출 적재</span></td>
                                        <td class="font-bold text-blue-600">ER-20260418-007</td>
                                        <td>미래로지스(주)</td>
                                        <td>자동차부품</td>
                                        <td>HMM OCEAN · MBL-KR26041801</td>
                                        <td>2026-04-23</td>
                                        <td><span class="badge-progress">적재대기</span></td>
                                        <td><button class="btn-secondary btn-sm" onclick="toggleFulfillmentDetail(this,'export-loading')">상세</button></td>
