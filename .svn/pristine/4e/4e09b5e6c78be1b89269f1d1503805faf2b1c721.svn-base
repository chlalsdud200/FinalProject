                                        <th>신고번호</th>
                                        <th>화주명</th>
                                        <th>품명</th>
                                        <th>창고 / 선박</th>
                                        <th>기준일</th>
                                        <th>현재상태</th>
                                        <th>상세</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>1</td>
                                        <td><span class="badge-progress">수입 반출</span></td>
                                        <td class="font-bold text-blue-600">IR-20260418-001</td>
                                        <td>노선호</td>
                                        <td>쌀</td>
                                        <td>인천항 CFS창고 · A-01구역</td>
                                        <td>2026-04-18</td>
                                        <td><span class="badge-progress">반출대기</span></td>
                                        <td><button class="btn-secondary btn-sm" onclick="toggleFulfillmentDetail(this,'import-release')">상세</button></td>
                                    </tr>
                                    <tr>
