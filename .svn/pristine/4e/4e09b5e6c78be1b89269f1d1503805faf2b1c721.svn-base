        <main class="officer-main">
            <div class="page-content exportAndFulfillment-page">
                <div class="mb-5">
                    <h2 class="text-xl font-black text-slate-900">반출 및 이행 관리</h2>
                </div>

                <div class="inline-screen-host active" id="screen-host-TACS-AD-018">
                    <div class="inline-screen-header">
                        <h3 class="font-black text-base">반출 및 이행 관리</h3>
                    </div>
                    <div class="inline-screen-body">

                        <div class="receipt-search-panel white-bg">
                            <p class="section-title receipt-search-title">검색 조건</p>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">신고번호</div>
                                <div class="receipt-search-field receipt-search-field-wide">
                                    <input class="receipt-search-input" placeholder="신고번호 입력" style="width:100%;" type="text"/>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">업무 구분</div>
                                <div class="receipt-search-radio-group">
                                    <label class="receipt-check-item"><input checked="" type="checkbox" value="ALL"/> 전체</label>
                                    <label class="receipt-check-item"><input type="checkbox" value="IMP_REL"/> 수입 반출</label>
                                    <label class="receipt-check-item"><input type="checkbox" value="IMM_REL"/> 즉시반출</label>
                                    <label class="receipt-check-item"><input type="checkbox" value="EXP_LOAD"/> 수출 적재이행</label>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">처리 상태</div>
                                <div class="receipt-search-field receipt-search-field-md">
                                    <select class="receipt-search-select w-full">
                                        <option value="">전체</option>
                                        <option value="WAIT">반출대기</option>
                                        <option value="DONE">반출완료</option>
                                        <option value="IMM_WAIT">허용대기</option>
                                        <option value="LOAD_WAIT">적재대기</option>
                                        <option value="OVERDUE">기한초과</option>
                                        <option value="HOLD">보류</option>
                                    </select>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">신고 일자</div>
                                <div class="receipt-search-date-wrap">
                                    <input class="receipt-search-date" type="date" value="2026-04-01"/>
                                    <span class="receipt-search-date-sep">~</span>
                                    <input class="receipt-search-date" type="date" value="2026-04-30"/>
                                    <button class="receipt-inline-btn">최근 1주일</button>
                                </div>
                            </div>
                            <div class="receipt-search-row receipt-search-row-last">
                                <div class="receipt-search-label">통합 검색</div>
                                <div class="receipt-search-bottom">
                                    <input class="receipt-search-input" placeholder="신고번호 또는 화주명 입력" type="text"/>
                                    <button class="btn-primary receipt-action-btn">조회</button>
                                    <button class="btn-secondary receipt-action-btn">초기화</button>
                                </div>
                            </div>
                        </div>

                        <div class="flex items-center justify-between mb-3">
                            <div class="text-[15px] font-bold text-slate-800">반출 및 이행 처리 대상 <span class="text-blue-600 ml-2">8건</span></div>
                        </div>
