    @Override
    @Transactional
    public String modifyImpUnloadingInDelivered(String trcNo,
                                                 String wirNo,
                                                 String wmId,
                                                 String wzNo,
                                                 String inPlanDt,
                                                 String cargoMgmtNo,
                                                 String invoiceNo,
                                                 String incoTermsCd,
                                                 String remark,
                                                 List<TransportRequestVO> goodsList) {
        String resolvedCargoMgmtNo = resolveImpCargoMgmtNo(trcNo, cargoMgmtNo);
        int updated = importTransportMapper.updateImpUnloadingInDelivered(
                wirNo,
                trcNo,
                wmId,
                wzNo,
                inPlanDt,
                resolvedCargoMgmtNo,
                invoiceNo,
                incoTermsCd,
                remark
        );

        /*
         * 여기서 MyBatis/Oracle PL/SQL 블록의 update count를 믿으면 안 된다.
         * 실제 INSERT/UPDATE가 성공했어도 드라이버가 0 또는 -1을 돌려줄 수 있고,
         * 그러면 Controller가 success:false를 반환해서 화면에는 "처리에 실패했습니다."가 뜬다.
         *
         * 그래서 DML이 예외 없이 끝나면 성공으로 보고, 실제 저장된 WIR_NO는
         * 기존 상세조회(selectImpUnloadingInDetail)가 TRC_NO 조회도 허용한다는 점을 이용해 다시 찾는다.
         * currentTmId()가 꼬인 테스트 데이터(TRC_TM_NO 1/3/5 혼재) 때문에 목록조회로 찾지 않는다.
         */
        String savedWirNo = null;
        TransportRequestVO savedRow = null;
        if (trcNo != null && !trcNo.isBlank()) {
            savedRow = importTransportMapper.selectImpUnloadingInDetail(trcNo);
        }
        if ((savedRow == null || savedRow.getWirNo() == null || savedRow.getWirNo().isBlank())
                && wirNo != null && !wirNo.isBlank()) {
            savedRow = importTransportMapper.selectImpUnloadingInDetail(wirNo);
        }
        if (savedRow != null && savedRow.getWirNo() != null && !savedRow.getWirNo().isBlank()) {
            savedWirNo = savedRow.getWirNo();
        }
        if (savedWirNo == null || savedWirNo.isBlank()) {
            savedWirNo = blankToNull(wirNo);
        }

        // 실제 WIR_NO를 찾은 경우에만 품목을 저장한다. 찾지 못했을 때 TRC_NO로 억지 저장하지 않는다.
        if (savedWirNo != null && !savedWirNo.isBlank()) {
            saveImpUnloadingInGoods(savedWirNo, goodsList);
        }

        // 입고의뢰가 창고로 전달(입고대기 생성)됨 → 담당 창고관리자에게 입고 처리 알림
        if (savedWirNo != null && !savedWirNo.isBlank()) {
            Map<String, String> bindings = new HashMap<>();
            bindings.put("wirNo", savedWirNo);
            notificationService.registNotification("WH_INBOUND_REQUESTED", "WIR-" + savedWirNo, null, bindings);
        }

        // DML에서 예외가 안 났으면 입고요청 처리는 성공이다. update count가 0이어도 실패로 보지 않는다.
        // 화면 재조회용 WIR_NO를 못 찾은 특이 케이스도 TRC_NO를 반환해 프론트가 성공 처리 후 재조회하게 한다.
        return savedWirNo != null && !savedWirNo.isBlank() ? savedWirNo : trcNo;
    }

    @Override
    public List<TransportRequestVO> retriveImpManifestList() {
        // 운송담당자는 적하목록 작성/제출을 하지 않고, 적하목록·패킹리스트 비교조회만 수행한다.
        return attachManifestGoodsList(applyKoreanRouteDisplay(importTransportMapper.retriveImpManifestCompareList(currentTmId())));
    }

    @Override
    public List<TransportRequestVO> retriveImpManifestCompareList() {
        return attachManifestGoodsList(applyKoreanRouteDisplay(importTransportMapper.retriveImpManifestCompareList(currentTmId())));
    }

    private List<TransportRequestVO> attachManifestGoodsList(List<TransportRequestVO> manifestList) {
        Map<Integer, List<TransportRequestVO>> goodsByGroup = new HashMap<>();
        for (TransportRequestVO manifest : manifestList) {
            if (manifest.getGgNo() == null) {
                continue;
            }
            manifest.setGoodsList(goodsByGroup.computeIfAbsent(
                    manifest.getGgNo(),
                    importTransportMapper::retriveImpUnloadingInGoodsList
            ));
        }
        return manifestList;
    }

    @Override
    @Transactional
    public List<TransportRequestVO> retriveImpDoList() {
        String tmId = currentTmId();
        importTransportMapper.ensureImpDoReadyForPaidSettlement(null, tmId);
        return applyKoreanRouteDisplay(importTransportMapper.retriveImpDoList(tmId));
    }

    @Override
    @Transactional
    public void ensureImpDoReadyAfterSettlementPaid(String trcNo) {
        if (trcNo == null || trcNo.isBlank()) {
            throw new IllegalArgumentException("운송의뢰번호가 없습니다.");
        }
        importTransportMapper.ensureImpDoReadyForPaidSettlement(trcNo, null);
    }

    @Override
    @Transactional
    public boolean modifyImpDoSettlementPaid(String trcNo, Integer freightAmt, Integer warehouseAmt, Integer totalBillAmt, String settlementExpln) {
        importTransportMapper.updateImpDoSettlementPaid(trcNo, freightAmt, warehouseAmt, totalBillAmt, settlementExpln);
        boolean requested = importTransportMapper.countImpDoSettlementPaid(trcNo) > 0;

        // 운송담당자가 운임 정산요청(TRC_STL_REQ) 생성 → 화주가 정산(결제)해야 D/O·필증 전달이 진행된다.
        if (requested) {
            // 알림 클릭 시 해당 운임 정산건 상세로 직접 이동 (없으면 목록으로 폴백)
            String tcsNo = importTransportMapper.selectTcsNoByTrcNo(trcNo);
            String linkUrl = (tcsNo != null && !tcsNo.isBlank())
                    ? "/owner/transport/freight/detail.do/" + tcsNo
                    : "/owner/transport/freight/list.do";

            Map<String, String> bindings = new HashMap<>();
            bindings.put("trcNo", trcNo);
            bindings.put("linkUrl", linkUrl);
            notificationService.registNotification("FREIGHT_STL_REQUESTED", trcNo, null, bindings);
        }

        return requested;
    }

    @Override
    @Transactional
    public boolean modifyImpDoFilesUploaded(String trcNo,
                                            String actorId,
                                            List<MultipartFile> docFiles) {
        Long doTfgNo = uploadDoRequestFiles(trcNo, actorId, docFiles);
        if (doTfgNo == null) {
            return false;
        }
        importTransportMapper.updateImpDoFileDocTypes(doTfgNo);
        importTransportMapper.updateImpDoUploadedFiles(trcNo, doTfgNo);
        if (importTransportMapper.countImpDoCertFile(trcNo) > 0) {
            importTransportMapper.updateImpTransportCertYn(trcNo, "Y");
        } else {
            connectOwnerCertIfPresent(trcNo);
        }
        return true;
    }


    @Override
    @Transactional
    public boolean connectImpOwnerCustomsCert(String trcNo, Long fileNo) {
        if (trcNo == null || trcNo.isBlank()) {
            throw new IllegalArgumentException("운송의뢰번호를 찾을 수 없습니다.");
        }
        if (importTransportMapper.countImpDoCertFile(trcNo) > 0) {
            importTransportMapper.updateImpTransportCertYn(trcNo, "Y");
            return true;
        }

        Long targetFileNo = fileNo;
        if (targetFileNo == null || targetFileNo <= 0) {
            targetFileNo = importTransportMapper.selectLatestUnmappedImpCustomsCertFileNo(trcNo);
        }
        if (targetFileNo == null || targetFileNo <= 0) {
            throw new IllegalArgumentException("연결할 화주 수입신고필증 PDF를 찾을 수 없습니다. 화주 업로드 파일이 없는 건은 D/O 첨부문서에 수입신고필증 PDF를 추가하세요.");
        }
        if (importTransportMapper.countImpCustomsCertFileCandidate(targetFileNo) <= 0) {
            throw new IllegalArgumentException("수입신고필증 PDF 파일만 연결할 수 있습니다.");
        }

        importTransportMapper.insertImpCustomsCertFileMap(trcNo, targetFileNo);
        importTransportMapper.updateImpTransportCertYn(trcNo, "Y");
        return true;
    }

    @Override
    @Transactional
    public boolean deleteImpDoFile(String trcNo, Long fileNo) {
        if (trcNo == null || trcNo.isBlank()) {
            throw new IllegalArgumentException("운송의뢰번호를 찾을 수 없습니다.");
        }
        if (fileNo == null || fileNo <= 0) {
            throw new IllegalArgumentException("삭제할 첨부문서 번호를 찾을 수 없습니다.");
        }

        int mapDeleted = importTransportMapper.deleteImpDoFileMap(trcNo, fileNo);
        if (mapDeleted <= 0) {
            throw new IllegalArgumentException("해당 D/O 첨부문서를 찾을 수 없습니다.");
        }
        importTransportMapper.updateImpDoFileDeleted(fileNo);
        return true;
    }

    @Override
    @Transactional
    public String modifyImpDoIssued(String trcNo,
                                    String doNo,
                                    String receiveDt,
                                    String actorId,
                                    List<MultipartFile> docFiles) {
        String manualDoNo = doNo == null ? "" : doNo.trim();
        if (manualDoNo.length() > 30) {
            throw new IllegalArgumentException("D/O 번호는 30자 이내로 입력해주세요.");
        }

        ensureImpDoReadyAfterSettlementPaid(trcNo);

        // D/O 발급 단계는 파일명에 D/O가 들어가야 한다고 막지 않는다.
        // 화면의 단일 첨부문서 영역에서 선택한 PDF 1개 이상이면 발급 가능하게 처리한다.
        Long doTfgNo = null;
        if (docFiles != null && !docFiles.isEmpty()) {
            doTfgNo = uploadDoRequestFiles(trcNo, actorId, docFiles);
        }

        int result = importTransportMapper.updateImpDoIssued(trcNo, manualDoNo, receiveDt, doTfgNo);
        // MyBatis/Oracle PL/SQL 블록은 실제 UPDATE/INSERT가 성공해도 -1을 반환할 수 있다.
        // 0만 실패로 보고, -1은 성공 가능 값으로 처리한 뒤 발급된 D/O 번호를 다시 조회한다.
        String issuedDoNo = importTransportMapper.selectIssuedImpDoNo(trcNo);
        if (result == 0 && (issuedDoNo == null || issuedDoNo.isBlank())) {
            return null;
        }
        if (issuedDoNo == null || issuedDoNo.isBlank()) {
            return null;
        }

        Long effectiveDoTfgNo = importTransportMapper.selectImpDoTfgNo(trcNo);
        Long generatedDoTfgNo = generateAndUploadImpDoPdf(trcNo, issuedDoNo, effectiveDoTfgNo, actorId);
        if (generatedDoTfgNo != null) {
            importTransportMapper.updateImpDoFileDocTypes(generatedDoTfgNo);
        }
        if (doTfgNo != null) {
            importTransportMapper.updateImpDoFileDocTypes(doTfgNo);
        }
        if (importTransportMapper.countImpDoCertFile(trcNo) > 0) {
            importTransportMapper.updateImpTransportCertYn(trcNo, "Y");
        } else {
            connectOwnerCertIfPresent(trcNo);
        }
        return issuedDoNo;
    }

    private Long generateAndUploadImpDoPdf(String trcNo,
                                           String issuedDoNo,
                                           Long doTfgNo,
                                           String actorId) {
        TransportRequestVO detail = importTransportMapper.selectImpDoPdfDetail(trcNo);
        if (detail == null) {
            throw new IllegalStateException("D/O PDF를 생성할 의뢰 정보를 찾을 수 없습니다.");
        }
        if (detail.getDoNo() == null || detail.getDoNo().isBlank()) {
            detail.setDoNo(issuedDoNo);
        }

        byte[] pdfBytes = buildImpDoPdf(detail, issuedDoNo);
        String fileName = "D_O_" + safeFileToken(trcNo) + "_" + safeFileToken(issuedDoNo) + ".pdf";
        String uploadActorId = normalizeActorId(actorId);

        try {
            if (doTfgNo != null) {
                fileService.uploadFilesToGroup(
                        doTfgNo,
                        TacsTrSt.TRC_DO_REQ.name(),
                        List.of(new ByteArrayMultipartFile("file", fileName, PDF_MIME_TYPE, pdfBytes)),
                        uploadActorId,
                        TacsUserType.TRANSPORT_MANAGER.name()
                );
                return doTfgNo;
            }

            Long newTfgNo = fileService.uploadGeneratedFile(
                    TacsTrSt.TRC_DO_REQ.name(),
                    pdfBytes,
                    fileName,
                    PDF_MIME_TYPE,
                    IMP_DO_DOC_TYPE,
                    uploadActorId,
                    TacsUserType.TRANSPORT_MANAGER.name()
            );
            if (newTfgNo != null) {
                importTransportMapper.updateImpDoUploadedFiles(trcNo, newTfgNo);
            }
            return newTfgNo;
        } catch (Exception e) {
            throw new IllegalStateException("D/O PDF 저장에 실패했습니다.", e);
        }
    }

    private byte[] buildImpDoPdf(TransportRequestVO detail, String issuedDoNo) {
        try (PDDocument document = new PDDocument();
             ByteArrayOutputStream out = new ByteArrayOutputStream()) {
            DoPdfWriter writer = new DoPdfWriter(document, loadDoPdfFont(document));
            writer.title("DELIVERY ORDER (D/O)");
            writer.row("D/O 번호", firstNonBlank(issuedDoNo, detail.getDoNo()));
            writer.row("발급일", firstNonBlank(detail.getDoReceiveDt(), LocalDate.now().format(DateTimeFormatter.ISO_DATE)));
            writer.row("운송의뢰번호", detail.getTrcNo());
            writer.row("입고요청번호", detail.getWirNo());

            writer.section("B/L 정보");
            writer.row("Master B/L", firstNonBlank(detail.getMblNo(), detail.getBlNo(), detail.getTcsMblNo()));
            writer.row("House B/L", firstNonBlank(detail.getHblNo(), detail.getTcsHblNo()));

            writer.section("의뢰 정보");
            writer.row("화주", appendId(detail.getOwnerNm(), detail.getOwnerId()));
            writer.row("요청일", detail.getRequestDt());
            writer.row("바이어", detail.getBuyerNm());
            writer.row("바이어 국가", detail.getBuyerCountryCd());
            writer.row("운송수단", firstNonBlank(detail.getTransportMeanNm(), detail.getTransportMeanCd()));
            writer.row("운송유형", detail.getTransportTypeCd());
            writer.row("인코텀즈", detail.getIncoTermsCd());
            writer.row("출발항", firstNonBlank(detail.getDeptPortNm(), detail.getDeptPortCd()));
            writer.row("도착항", firstNonBlank(detail.getArvlPortNm(), detail.getArvlPortCd()));
            writer.row("품목분류", detail.getItemCategory());
            writer.row("품명", firstNonBlank(detail.getGoodsName(), detail.getItemNm()));
            writer.row("수량", detail.getQty());
            writer.row("중량", detail.getWeight());
            writer.row("요청내용", detail.getRequestCn());

            writer.section("입고/창고 정보");
            writer.row("창고", firstNonBlank(detail.getWarehouseNm(), detail.getWarehouseZoneNm(), detail.getWhNm()));
            writer.row("창고관리자", firstNonBlank(detail.getWarehouseManagerNm(), detail.getWmId()));
            writer.row("보세구역", firstNonBlank(detail.getWarehouseZoneNm(), detail.getWzNo()));
            writer.row("입고상태", firstNonBlank(detail.getWarehouseInStatusNm(), detail.getWarehouseInStatusCd()));
            writer.row("입고예정일", detail.getInPlanDt());
            writer.row("화물관리번호", detail.getCargoMgmtNo());
            writer.row("송장번호", detail.getInvoiceNo());

            writer.section("정산 정보");
            writer.row("정산상태", firstNonBlank(detail.getTcsStlStatusNm(), detail.getTcsStlStatusCd()));
            writer.row("운임비", money(detail.getFreightAmt()));
            writer.row("창고비", money(detail.getWarehouseAmt()));
            writer.row("총 청구금액", money(detail.getTotalBillAmt()));
            writer.row("정산 설명", detail.getSettlementExpln());

            writer.section("첨부/전달 정보");
            writer.row("수입신고필증", detail.getDoCertFile());
            writer.row("전달대상자", detail.getDeliveryTargetNm());
            writer.row("전달일", detail.getDeliveryDt());
            writer.close();

            document.save(out);
            return out.toByteArray();
        } catch (IOException e) {
            throw new IllegalStateException("D/O PDF 생성에 실패했습니다.", e);
        }
    }

    private PDFont loadDoPdfFont(PDDocument document) throws IOException {
        List<String> fontPaths = new ArrayList<>();
        String windir = System.getenv("WINDIR");
        if (windir != null && !windir.isBlank()) {
            fontPaths.add(windir + File.separator + "Fonts" + File.separator + "malgun.ttf");
        }
        fontPaths.add("C:\\Windows\\Fonts\\malgun.ttf");
        fontPaths.add("/usr/share/fonts/truetype/noto/NotoSansCJK-Regular.ttc");
        fontPaths.add("/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.otf");

        for (String path : fontPaths) {
            File fontFile = new File(path);
            if (fontFile.isFile()) {
                try {
                    return PDType0Font.load(document, fontFile);
                } catch (IOException ignored) {
                    // 다음 후보 폰트를 확인한다.
                }
            }
        }
        throw new IOException("D/O PDF 한글 폰트를 찾을 수 없습니다.");
    }

    private String firstNonBlank(Object... values) {
        if (values == null) {
            return "";
        }
        for (Object value : values) {
            if (value == null) {
                continue;
            }
            String text = String.valueOf(value).trim();
            if (!text.isEmpty() && !"-".equals(text)) {
                return text;
            }
        }
        return "";
    }

    private String appendId(String name, String id) {
        String cleanName = firstNonBlank(name);
        String cleanId = firstNonBlank(id);
        if (cleanName.isEmpty()) {
            return cleanId;
        }
        if (cleanId.isEmpty() || cleanName.equals(cleanId)) {
            return cleanName;
        }
        return cleanName + " (" + cleanId + ")";
    }

    private String money(Integer amount) {
        return amount == null ? "" : String.format("%,d원", amount);
    }

    private String safeFileToken(String value) {
        String text = firstNonBlank(value);
        if (text.isEmpty()) {
            return "UNKNOWN";
        }
        return text.replaceAll("[^A-Za-z0-9._-]", "_");
    }

    private static final class DoPdfWriter {
        private static final float MARGIN = 48f;
        private static final float LINE_HEIGHT = 15f;

        private final PDDocument document;
        private final PDFont font;
        private PDPageContentStream content;
        private float y;

        private DoPdfWriter(PDDocument document, PDFont font) throws IOException {
            this.document = document;
            this.font = font;
            addPage();
        }

        private void title(String text) throws IOException {
            writeText(text, 18f, 22f);
            y -= 10f;
        }

        private void section(String text) throws IOException {
            ensureSpace(28f);
            y -= 4f;
            writeText(text, 12f, 18f);
        }

        private void row(String label, Object value) throws IOException {
            String normalized = value == null ? "" : String.valueOf(value).trim();
            if (normalized.isEmpty()) {
                normalized = "-";
            }
            writeWrapped(label + " : " + normalized, 10.5f);
        }

        private void writeWrapped(String text, float fontSize) throws IOException {
            for (String line : wrap(text, fontSize, PDRectangle.A4.getWidth() - (MARGIN * 2))) {
                writeText(line, fontSize, LINE_HEIGHT);
            }
        }

        private List<String> wrap(String text, float fontSize, float maxWidth) throws IOException {
            List<String> lines = new ArrayList<>();
            String source = text == null ? "" : text.replace('\n', ' ').replace('\r', ' ').trim();
            if (source.isEmpty()) {
                lines.add("");
                return lines;
            }

            StringBuilder line = new StringBuilder();
            for (int i = 0; i < source.length(); i++) {
                char ch = source.charAt(i);
                String next = line.toString() + ch;
                if (!line.isEmpty() && width(next, fontSize) > maxWidth) {
                    lines.add(line.toString());
                    line.setLength(0);
                }
                line.append(ch);
            }
            if (!line.isEmpty()) {
                lines.add(line.toString());
            }
            return lines;
        }

        private float width(String text, float fontSize) throws IOException {
            return font.getStringWidth(text) / 1000f * fontSize;
        }

        private void writeText(String text, float fontSize, float lineHeight) throws IOException {
            ensureSpace(lineHeight);
            content.beginText();
            content.setFont(font, fontSize);
            content.newLineAtOffset(MARGIN, y);
            content.showText(text == null ? "" : text);
            content.endText();
            y -= lineHeight;
        }

        private void ensureSpace(float neededHeight) throws IOException {
            if (y - neededHeight >= MARGIN) {
                return;
            }
            content.close();
            addPage();
        }

        private void addPage() throws IOException {
            PDPage page = new PDPage(PDRectangle.A4);
            document.addPage(page);
            content = new PDPageContentStream(document, page);
            y = PDRectangle.A4.getHeight() - MARGIN;
        }

        private void close() throws IOException {
            if (content != null) {
                content.close();
                content = null;
            }
        }
    }

    private Long uploadDoRequestFiles(String trcNo,
                                      String actorId,
                                      List<MultipartFile> docFiles) {
        if (docFiles == null || docFiles.isEmpty()) {
            return null;
        }

        List<MultipartFile> uploadFiles = new ArrayList<>();
        for (MultipartFile file : docFiles) {
            if (file == null || file.isEmpty()) {
                continue;
            }
            validatePdfFile(file);
            uploadFiles.add(file);
        }

        if (uploadFiles.isEmpty()) {
            return null;
        }

        String uploadActorId = actorId;
        if (uploadActorId == null || uploadActorId.isBlank()) {
            uploadActorId = trcNo;
        }

        try {
            // 화주(owner) 첨부파일 방식과 동일하게 문서유형을 나누지 않고 하나의 파일그룹으로 저장한다.
            // TACS_FILE_MAP.TFM_DOC_TY_CD는 NULL로 들어가고, DO_ISSUANCE.DI_TFG_NO가 그 파일그룹을 참조한다.
            Long tfgNo = fileService.uploadFiles(
                    TacsTrSt.TRC_DO_REQ.name(),
                    uploadFiles,
                    uploadActorId,
                    TacsUserType.TRANSPORT_MANAGER.name()
            );
            if (tfgNo != null) {
                importTransportMapper.updateImpDoFileDocTypes(tfgNo);
            }
            return tfgNo;
        } catch (Exception e) {
            throw new IllegalStateException("D/O 요청 첨부파일 저장에 실패했습니다.", e);
        }
    }

    private void connectOwnerCertIfPresent(String trcNo) {
        try {
            connectImpOwnerCustomsCert(trcNo, null);
        } catch (IllegalArgumentException ignored) {
            // 화주가 실제 필증 PDF를 전달하지 않은 건은 이후 전달/반출요청 검증에서 안내한다.
        }
    }



    private void validateDoPdfIncluded(List<MultipartFile> docFiles) {
        boolean hasDoPdf = false;

        if (docFiles != null) {
            for (MultipartFile file : docFiles) {
                if (file == null || file.isEmpty()) {
                    continue;
                }

                validatePdfFile(file);

                String filename = file.getOriginalFilename();
                String normalized = filename == null ? "" : filename.toLowerCase();

                /*
                 * D/O 발급 단계에서는 D/O PDF가 반드시 필요하다.
                 * 파일명이 한글/영문 어느 쪽으로 오더라도 최대한 판단한다.
                 */
                if (normalized.contains("d/o")
                        || normalized.contains("do")
                        || normalized.contains("delivery order")
                        || normalized.contains("delivery-order")
                        || normalized.contains("디오")
                        || normalized.contains("d_o")) {
                    hasDoPdf = true;
                }
            }
        }

        if (!hasDoPdf) {
            throw new IllegalArgumentException("D/O PDF를 첨부해야 D/O 발급이 가능합니다.");
        }
    }

    private void validatePdfFile(MultipartFile file) {
        if (file == null || file.isEmpty()) {
            return;
        }

        String filename = file.getOriginalFilename();
        String contentType = file.getContentType();
        boolean pdfByName = filename != null && filename.toLowerCase().endsWith(".pdf");
        boolean pdfByType = contentType != null && contentType.toLowerCase().contains("pdf");

        if (!pdfByName && !pdfByType) {
            throw new IllegalArgumentException("PDF 파일만 첨부할 수 있습니다.");
        }
    }

    private boolean isImportDeclarationCert(MultipartFile file) {
        String filename = file.getOriginalFilename();
        if (filename == null) {
            return false;
        }
        String normalized = filename.toLowerCase();
        return normalized.contains("cert")
                || normalized.contains("declaration")
                || normalized.contains("신고")
                || normalized.contains("필증");
    }

    @Override
    @Transactional
    public boolean modifyImpDoDelivered(String trcNo, String deliveryDt, String deliveryTargetNm, String deliveryMethodCd) {
        if (trcNo == null || trcNo.isBlank()) {
            throw new IllegalArgumentException("운송의뢰번호를 찾을 수 없습니다.");
        }

        /*
         * D/O 전달은 창고 반출승인 화면에서 바로 검증된다.
         * 그래서 D/O 파일 1개만 보고 전달완료로 넘기면, 창고 쪽에는 D/O만 보이고
         * 수입신고필증이 없어 반출승인 버튼이 비활성/실패 상태가 된다.
         *
         * 전달 직전에 화주가 올린 수입신고필증 PDF를 D/O 파일그룹(DI_TFG_NO)에 자동 연결하고,
         * D/O PDF + 수입신고필증 PDF가 둘 다 확인될 때만 전달완료 처리한다.
         */
        if (importTransportMapper.countImpDoPdfFile(trcNo) <= 0) {
            throw new IllegalArgumentException("D/O PDF를 등록해야 D/O 전달이 가능합니다.");
        }

        if (importTransportMapper.countImpDoCertFile(trcNo) <= 0) {
            try {
                connectImpOwnerCustomsCert(trcNo, null);
            } catch (IllegalArgumentException ignored) {
                // 아래 재검증에서 사용자 메시지를 통일해서 반환한다.
            }
        }

        if (importTransportMapper.countImpDoCertFile(trcNo) <= 0) {
            throw new IllegalArgumentException("화주 수입신고필증 PDF가 연결되어야 D/O 전달이 가능합니다.");
        }

        int updated = importTransportMapper.updateImpDoDelivered(trcNo, deliveryDt, deliveryTargetNm, deliveryMethodCd);

        // Oracle/MyBatis 환경에서 UPDATE가 성공해도 -1로 반환되는 경우가 있으므로 0만 실패로 본다.
        if (updated == 0) {
            return false;
        }

        /*
         * 프로젝트 상태 기준:
         * TRC_DO_READY  = D/O 발급대기
         * TRC_DO_ISSUED = D/O 발급완료
         * TRC_DO_REQ    = D/O 전달완료
         *
         * D/O 전달완료(TRC_DO_REQ) 이후에는 반출관리 탭이 바로 열려야 하므로,
         * CARGO_RELEASE_REQ 기본 REL_WAIT 행이 없으면 이 시점에 자동 생성한다.
         * 이미 생성된 반출요청이 있으면 중복 생성하지 않는다.
         */
        if (importTransportMapper.countImpReleaseReqByTrcNo(trcNo) <= 0) {
            importTransportMapper.insertImpReleaseReq(
                    trcNo,
                    null,
                    null,
                    null,
                    null,
                    null,
                    "D/O 전달완료 자동 반출요청 생성"
            );
        }

        return true;
    }


    // 수입 보세구역 반출요청
    @Override
    public List<TransportRequestVO> retriveImpReleaseReqList() {
        return applyKoreanRouteDisplay(importTransportMapper.retriveImpReleaseReqList(currentTmId()));
    }

    @Override
    public TransportRequestVO retriveImpReleaseReqDetail(String trcNo) {
        return applyKoreanRouteDisplay(importTransportMapper.selectImpReleaseReqDetail(trcNo));
    }

    @Override
    public List<TransportRequestVO> retriveImpReleaseReqGoodsList(Integer ggNo) {
        return importTransportMapper.retriveImpReleaseReqGoodsList(ggNo);
    }

    @Override
    @Transactional
    public boolean registImpReleaseReq(String trcNo,
                                       String wmId,
                                       String wzNo,
                                       String releaseReqDt,
                                       String releaseDt,
                                       String itemNm,
                                       String remark,
                                       List<TransportRequestVO> goodsList) {
        if (importTransportMapper.countImpDoCertFile(trcNo) <= 0) {
            try {
                connectImpOwnerCustomsCert(trcNo, null);
            } catch (IllegalArgumentException ignored) {
                // 아래 재검증에서 반출요청용 메시지를 반환한다.
            }
        }
        if (importTransportMapper.countImpDoCertFile(trcNo) <= 0) {
            throw new IllegalArgumentException("화주 수입신고필증 PDF가 연결되어야 반출요청이 가능합니다.");
        }

        importTransportMapper.insertImpReleaseReq(
                trcNo,
                blankToNull(wmId),
                blankToNull(wzNo),
                blankToNull(releaseReqDt),
                blankToNull(releaseDt),
                blankToNull(itemNm),
                blankToNull(remark)
        );
        int updated = importTransportMapper.updateImpReleaseReqData(
                null,
                trcNo,
                blankToNull(wmId),
                blankToNull(wzNo),
                blankToNull(releaseReqDt),
                blankToNull(releaseDt),
                blankToNull(itemNm),
                blankToNull(remark)
        );
        saveImpReleaseGoods(trcNo, goodsList);

        boolean ok = updated > 0 || importTransportMapper.countImpReleaseReqByTrcNo(trcNo) > 0;

        // 반출요청이 창고로 접수됨 → 담당 창고관리자에게 반출 처리 알림
        if (ok) {
            String crrNo = importTransportMapper.selectCrrNoByTrcNo(trcNo);
            if (crrNo != null && !crrNo.isBlank()) {
                Map<String, String> bindings = new HashMap<>();
                bindings.put("crrNo", crrNo);
                notificationService.registNotification("WH_OUTBOUND_REQUESTED", "CRR-" + crrNo, null, bindings);
            }
        }

        return ok;
    }





    @Override
    public List<TransportRequestVO> retriveImpInlandDispatchList() {
        return applyKoreanRouteDisplay(importTransportMapper.retriveImpInlandDispatchList(currentTmId()));
    }

    @Override
    public List<TransportRequestVO> retriveImpAvailableCarList() {
        return importTransportMapper.retriveImpAvailableCarList(currentTmId());
    }

    @Override
    public int modifyImpInlandDispatch(TransportRequestVO vo) {
        if (vo == null || vo.getCarNo() == null) {
            throw new IllegalStateException("배차완료 처리할 차량번호를 선택해주세요.");
        }
        if (importTransportMapper.countImpReleaseApprovedByTrcNo(vo.getTrcNo()) <= 0) {
            throw new IllegalStateException("창고관리자 반출승인 완료 이후에만 내륙배차가 가능합니다.");
        }
        return importTransportMapper.updateImpInlandDispatch(vo);
    }


    /**
     * 화면 표시용 항로명 보정.
     * 매퍼 SQL을 건드리지 않고 서비스 조회 응답에서만 KRPUS/THBKK/BUSAN 같은 코드값을
     * 부산행/방콕행 형태로 바꾼다. 저장 로직에는 적용하지 않는다.
     */
    private List<TransportRequestVO> applyKoreanRouteDisplay(List<TransportRequestVO> rows) {
        if (rows == null || rows.isEmpty()) {
            return rows;
        }
        for (TransportRequestVO row : rows) {
            applyKoreanRouteDisplay(row);
        }
        return rows;
    }

    private TransportRequestVO applyKoreanRouteDisplay(TransportRequestVO row) {
        if (row == null) {
            return null;
        }

        String deptDisplay = koreanRouteDisplay(firstNonBlank(row.getDeptPortNm(), row.getDeptPortCd()));
        String arvlDisplay = koreanRouteDisplay(firstNonBlank(row.getArvlPortNm(), row.getArvlPortCd()));
        String currentDisplay = koreanRouteDisplay(row.getCurrentLoc());

        if (blankToNull(deptDisplay) != null) {
            row.setDeptPortNm(deptDisplay);
            row.setDeptPortCd(deptDisplay);
        }
        if (blankToNull(arvlDisplay) != null) {
            row.setArvlPortNm(arvlDisplay);
            row.setArvlPortCd(arvlDisplay);
        }
        if (blankToNull(currentDisplay) != null) {
            row.setCurrentLoc(currentDisplay);
        }
        return row;
    }

    private String koreanRouteDisplay(String value) {
        String raw = blankToNull(value);
        if (raw == null) {
            return value;
        }
        if (raw.endsWith("행")) {
            return raw;
        }

        String upper = raw.toUpperCase(Locale.ROOT);
        String token = upper.replaceAll("[^A-Z0-9가-힣]", "");

        if (token.contains("KRPUS") || token.contains("PUS") || token.contains("BUSAN") || token.contains("부산")) {
            return "부산행";
        }
        if (token.contains("THBKK") || token.contains("BKK") || token.contains("BANGKOK") || token.contains("방콕")) {
            return "방콕행";
        }
        if (token.contains("KRINC") || token.contains("INCHEON") || token.contains("인천")) {
            return "인천행";
        }
        if (token.contains("USLAX") || token.contains("LAX") || token.contains("LOSANGELES") || token.contains("로스앤젤레스")) {
            return "로스앤젤레스행";
        }
        if (token.contains("CNSHA") || token.contains("SHA") || token.contains("SHANGHAI") || token.contains("상하이") || token.contains("상해")) {
            return "상하이행";
        }
        if (token.contains("JPTYO") || token.contains("TYO") || token.contains("TOKYO") || token.contains("도쿄")) {
            return "도쿄행";
        }
        if (token.contains("JPOSA") || token.contains("OSA") || token.contains("OSAKA") || token.contains("오사카")) {
            return "오사카행";
        }
        if (token.contains("SGSIN") || token.contains("SIN") || token.contains("SINGAPORE") || token.contains("싱가포르")) {
            return "싱가포르행";
        }

        // 이미 한글 항만명으로 온 값만 '항'을 빼고 '~행'으로 바꾼다. 예: 부산항 → 부산행
        if (raw.matches(".*[가-힣].*") && raw.endsWith("항")) {
            return raw.substring(0, raw.length() - 1) + "행";
        }

        // 모르는 영문/코드는 그대로 둔다. 임의 변환으로 저장값/상태값이 깨지는 것을 막기 위함.
        return raw;
    }

    private String currentTmId() {
        Authentication authentication = SecurityContextHolder.getContext().getAuthentication();
        if (authentication == null || authentication.getName() == null || authentication.getName().isBlank()) {
            return null;
        }
        return authentication.getName();
    }
}
