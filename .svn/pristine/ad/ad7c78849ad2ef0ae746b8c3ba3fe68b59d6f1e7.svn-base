package kr.or.tacs.warehouse.outbound.service;

import java.util.Collections;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import kr.or.tacs.dto.warehouse.WarehouseOutboundDocDTO;
import kr.or.tacs.dto.warehouse.WarehouseOutboundProcessDTO;
import kr.or.tacs.warehouse.outbound.mapper.OutboundMapper;

@Service
public class OutboundServiceImpl implements OutboundService {

	@Autowired
	private OutboundMapper outboundMapper;
	
	@Override
	public List<WarehouseOutboundDocDTO> selectOutboundDocList(String wmId) {
		
		return  outboundMapper.selectOutboundDocList(wmId);
	}

	@Override
	public List<WarehouseOutboundProcessDTO> selectOutboundProcessList(String wmId) {
		
		return outboundMapper.selectOutboundProcessList(wmId);
	}

	@Transactional
	@Override
	public int insertOutboundSupplementRequest(String crrNo,String wmId, String reason) {
		
		String receiverId = outboundMapper.selectTransportManagerIdByCrrNo(crrNo);
		
		if (receiverId == null || receiverId.isBlank()) {
		    return 0;
		}
		
		Map<String, Object> paramMap = new HashMap<>();
		
		paramMap.put("crrNo", crrNo);						// 반출 요청 번호
		paramMap.put("srRefBizCd", "CARGO_RELEASE_REQ");	// 보완 요청 기준 업무
		paramMap.put("srRefNo", crrNo);						// 보완요청 대상 번호
		paramMap.put("senderId", wmId);						// 창고관리자 ID,유형(송신자)
		paramMap.put("senderTyCd", "WAREHOUSE_MANAGER");
		paramMap.put("receiverId", receiverId);				// 운송업체 ID,유형(수신자)
		paramMap.put("receiverTyCd", "TRANSPORT_MANAGER");	
		paramMap.put("srStatusCd", "REQ");					// 보완 요청 상태
		paramMap.put("srReqCn", reason);					// 보완 요청 사유
		
		int statusResult = outboundMapper.updateCargoReleaseReqStatusToRelFix(paramMap);
		
		// 같은 반출요청건에 대해 보완요청은 1번만 가능하게 함
		if(statusResult == 0) {
			return 0;
		}
		
		int insertResult = outboundMapper.insertOutboundSupplementRequest(paramMap);
		
		return statusResult + insertResult;
		
	}


	/*
	 * cargo_release_req 상태를 -> rel_done 으로 변경
	 * warehouse_item 물품 비활성화 -> 3d에서 안 보이게 함	-> 단순히 상태만 바꾸는게 아니라 3개가 같이 성공해야함
	 * warehouse_zone 사용량/사용률 재계산	
	 * 
	 * 처리 순서:
     * 1. CARGO_RELEASE_REQ 상태를 REL_DONE으로 변경
     * 2. WH_OUT_HIS에 반출 당시 이력 저장
     * 3. WAREHOUSE_ITEM을 현재 재고/3D 조회 대상에서 제외
     * 4. WAREHOUSE_ZONE 사용량/사용률 재계산			
	 */
	
	@Transactional
	@Override
	public int approveOutbound(String crrNo, String wmId) {
	
		// 반출요청 상태 변경(REL_DONE)
		int stateResult = outboundMapper.updateCargoReleaseReqToDone(crrNo,wmId);
		
		if(stateResult == 0) {
			return 0;
		}
		
		// 반출 이력 저장
		int historyResult = outboundMapper.insertWarehouseOutboundHistory(crrNo,wmId);
		if(historyResult == 0) {
			throw new IllegalStateException("반출이력 저장 대상 물품이 없습니다. crrNo=" + crrNo);
		}
		
		// 창고 물품 비활성화
		int itemResult = outboundMapper.updateWarehouseItemUseYnToN(crrNo);
		if(itemResult == 0) {
			throw new IllegalStateException("반출 대상 창고 물품 비활성화 실패. crrNo=" + crrNo);
		}
		
		// 창고구역 사용량/사용률 재계산
		//  WI_USE_YN = 'Y'인 물품 기준으로 재계산하는 방식
		int zoneResult = outboundMapper.updateWarehouseZoneUsageByCrrNo(crrNo);
		if(zoneResult == 0) {
			throw new IllegalStateException("창고구역 사용량/사용률 재계산 실패. crrNo=" + crrNo);
		}
		
		return stateResult + historyResult + itemResult + zoneResult ;
	}

	/*
	 * 보세반출 처리 목록 전체 개수 조회
	 *
	 * 검색조건과 페이징 조건은 searchDTO에 담겨 있고,
	 * wmId는 로그인한 창고관리자 본인 담당 건만 조회하기 위해 사용한다.
	 */
	@Override
	public int selectOutboundProcessCount(WarehouseOutboundProcessDTO searchDTO, String wmId) {
	    return outboundMapper.selectOutboundProcessCount(searchDTO, wmId);
	}

	/*
	 * 보세반출 처리 목록 페이징 조회
	 *
	 * Mapper 조회 결과가 null이면 화면 JS에서 오류가 날 수 있으므로
	 * 빈 리스트로 반환한다.
	 */
	@Override
	public List<WarehouseOutboundProcessDTO> selectOutboundProcessPagingList(
	        WarehouseOutboundProcessDTO searchDTO,
	        String wmId
	) {
	    List<WarehouseOutboundProcessDTO> outboundProcessList =
	            outboundMapper.selectOutboundProcessPagingList(searchDTO, wmId);

	    if (outboundProcessList == null) {
	        return Collections.emptyList();
	    }

	    return outboundProcessList;
	}

}
