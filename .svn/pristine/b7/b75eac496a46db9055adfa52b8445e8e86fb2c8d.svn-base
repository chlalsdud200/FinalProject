<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>

<div id="docs-ctx-menu" style="display:none;">
    <div class="docs-ctx-item" onclick="docsCtxPreview()">
        <span class="material-symbols-outlined" style="font-size:16px">preview</span>
        미리보기
    </div>

    <div class="docs-ctx-item" onclick="docsCtxDownload()">
        <span class="material-symbols-outlined" style="font-size:16px">download</span>
        다운로드
    </div>

    <div class="docs-ctx-sep"></div>

    <div class="docs-ctx-item" onclick="docsCtxRename()">
        <span class="material-symbols-outlined" style="font-size:16px">edit</span>
        이름 변경
    </div>

    <div class="docs-ctx-item danger" onclick="docsCtxDelete()">
        <span class="material-symbols-outlined" style="font-size:16px">delete</span>
        삭제
    </div>
</div>

<div id="docs-drop-overlay" style="display:none;">
    <div class="inner">문서를 이곳에 놓아 업로드</div>
</div>