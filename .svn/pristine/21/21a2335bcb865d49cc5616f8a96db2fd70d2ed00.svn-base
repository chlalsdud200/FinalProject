<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.common.file.mapper.IFileMapper">

    <select id="selectTfgNo" resultType="long">
        SELECT NVL(MAX(tfg_no), 0) + 1 FROM tacs_file_grp
    </select>

    <insert id="insertFileGroup" parameterType="kr.or.tacs.dto.FileGroupDTO">
        INSERT INTO tacs_file_grp (
                                    tfg_no
                                  , tfg_biz_se_cd
                                  , tfg_regist_dt
        ) VALUES (
                   #{tfgNo}
                 , #{tfgBizSeCd}
                 , SYSDATE
                 )
    </insert>

    <select id="selectDfiNo" resultType="long">
        SELECT NVL(MAX(dfi_file_no), 0) + 1 FROM docs_file_data
    </select>

    <insert id="insertFileInfo" parameterType="kr.or.tacs.dto.FileInfoDTO">
        INSERT INTO docs_file_data (
                                     dfi_file_no
                                   , dfi_actor_id
                                   , dfi_actor_type
                                   , dfi_org_nm
                                   , dfi_str_nm
                                   , dfi_size
                                   , dfi_path
                                   , dfi_ext
                                   , dfi_mime_ty
                                   , dfi_del_yn
                                   , dfi_regist_dt
                                   , dfi_biz_ty_cd
                                   , DFI_DRIVE_FILE_ID
                                   , dfi_upload_stts_cd
        ) VALUES (
                   #{dfiFileNo}
                 , #{dfiActorId}
                 , #{dfiActorType}
                 , #{dfiOrgNm}
                 , #{dfiStrNm}
                 , #{dfiSize}
                 , #{dfiPath}
                 , #{dfiExt}
                 , #{dfiMimeTy}
                 , NVL(#{dfiDelYn}, 'N')
                 , SYSDATE
                 , #{dfiBizTyCd}
                 , #{dfiDriveFileId}
                 , NVL(#{dfiUploadSttsCd}, 'UPLOADING')
                 )
    </insert>

    <update id="updateDriveUploadSuccess" parameterType="kr.or.tacs.dto.FileInfoDTO">
        UPDATE docs_file_data
        SET dfi_drive_file_id = #{dfiDriveFileId}
          , dfi_upload_stts_cd = 'DONE'
        WHERE dfi_file_no = #{dfiFileNo}
    </update>

    <update id="updateDriveUploadFail" parameterType="long">
        UPDATE docs_file_data
        SET dfi_upload_stts_cd = 'FAIL'
        WHERE dfi_file_no = #{dfiFileNo}
    </update>

    <select id="selectTfmNo" resultType="long">
        SELECT NVL(MAX(tfm_no), 0) + 1 FROM tacs_file_map
    </select>

    <insert id="insertFileMap" parameterType="kr.or.tacs.dto.FileMapDTO">
        INSERT INTO tacs_file_map (
                                    tfm_no
                                  , tfm_tfg_no
                                  , tfm_dfi_no
                                  <if test="tfmDocTyCd != null and tfmDocTyCd != ''">
                                  , tfm_doc_ty_cd
                                  </if>
        ) VALUES (
                   #{tfmNo}
                 , #{tfmTfgNo}
                 , #{tfmDfiNo}
                 <if test="tfmDocTyCd != null and tfmDocTyCd != ''">
                 , #{tfmDocTyCd}
                 </if>
                 )
    </insert>

    <select id="selectFileList" parameterType="long" resultType="kr.or.tacs.dto.FileInfoDTO">
        SELECT
            dfi.dfi_file_no
             , dfi.dfi_actor_id
             , dfi.dfi_actor_type
             , dfi.dfi_org_nm
             , dfi.dfi_str_nm
             , dfi.dfi_size
             , dfi.dfi_path
             , dfi.dfi_del_yn
             , dfi.dfi_regist_dt
             , dfi.dfi_biz_ty_cd
             , dfi.dfi_drive_file_id
             , dfi.dfi_upload_stts_cd
             , tfm.tfm_no
             , tfm.tfm_tfg_no
             , tfm.tfm_dfi_no
             , tfm.tfm_doc_ty_cd
        FROM tacs_file_map tfm
                 JOIN docs_file_data dfi
                      ON dfi.dfi_file_no = tfm.tfm_dfi_no
        WHERE tfm.tfm_tfg_no = #{tfgNo}
          AND NVL(dfi.dfi_del_yn, 'N') = 'N'
        ORDER BY dfi.dfi_regist_dt DESC, dfi.dfi_file_no DESC
    </select>

    <select id="selectFileInfo" parameterType="long" resultType="kr.or.tacs.dto.FileInfoDTO">
        SELECT
            dfi_file_no
            , dfi_actor_id
            , dfi_actor_type
            , dfi_org_nm
            , dfi_str_nm
            , dfi_path
            , dfi_size
            , dfi_ext
            , dfi_mime_ty
            , dfi_del_yn
            , dfi_biz_ty_cd
            , dfi.dfi_drive_file_id
            , dfi.dfi_upload_stts_cd
        FROM docs_file_data dfi
        WHERE dfi_file_no = #{fileNo}
          AND dfi_del_yn  = 'N'
    </select>

    <update id="deleteFile" parameterType="long">
        UPDATE docs_file_data
        SET dfi_del_yn = 'Y'
        WHERE dfi_file_no = #{dfiFileNo}
    </update>

</mapper>
