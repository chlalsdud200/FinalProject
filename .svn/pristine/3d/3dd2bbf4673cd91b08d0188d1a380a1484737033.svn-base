document.addEventListener('DOMContentLoaded', function () {
  bindDetailTabs();
  bindDetailButtons();
  initWorkForm();
});

function bindDetailTabs() {
  var tabBar = document.querySelector('.det-tab-bar');
  if (!tabBar) return;

  tabBar.addEventListener('click', function (e) {
    var tab = e.target.closest('.det-tab-i');
    if (!tab) return;

    e.preventDefault();
    e.stopPropagation();

    if (tab.classList.contains('locked')) return;

    openDetailTab(tab.dataset.tab);
  });
}

function openDetailTab(tabName) {
  if (!tabName) return;

  document.querySelectorAll('.det-tab-i').forEach(function (tab) {
    tab.classList.toggle('on', tab.dataset.tab === tabName);
  });

  document.querySelectorAll('.tab-pane').forEach(function (pane) {
    pane.classList.remove('on');
  });

  var targetPane = document.getElementById('tab-' + tabName);
  if (targetPane) {
    targetPane.classList.add('on');
  }
}

function bindDetailButtons() {
  safeClick('btnBack', goList);
  safeClick('btnBackBottom', goList);

  safeChange('workType', changeWorkForm);
  safeClick('btnWorkSubmit', submitWork);
  
  safeClick('btnReceiptBottom', submitDetailAccept);
  safeClick('btnRejectBottom', openDetailRejectModal);

  safeClick('btnApproveBottom', function () {
    if (!confirm('승인 처리하시겠습니까?')) return;

    setStatus('세금납부대기');
    openDetailTab('tax');

    toast('세금납부 탭으로 이동했습니다.', 'g');
  });

  safeClick('btnTaxComplete', function () {
    if (!confirm('납부완료 처리하시겠습니까?')) return;

    setText('taxStatus', '납부완료');
    setText('taxStateCell', '납부완료');
    setText('vatStateCell', '납부완료');

    setStatus('승인완료');
    addHistory('납부완료 확인', 'green', '관세 및 부가세 납부완료 상태로 변경되었습니다.');

    toast('납부완료 처리되었습니다.', 'g');
  });
}

function initWorkForm() {
  changeWorkForm();
}

function changeWorkForm() {
  var workType = document.getElementById('workType');
  var workTitle = document.getElementById('workTitle');
  var workReason = document.getElementById('workReason');
  var workDesc = document.getElementById('workDesc');
  var btnWorkSubmit = document.getElementById('btnWorkSubmit');

  // JSP 실제 ID 기준
  var workFileArea = document.getElementById('workFileRow');
  var workFile = document.getElementById('workFile');

  if (!workType || !workTitle || !workReason) return;

  var value = workType.value;

  var titleMap = {
    supplement: '보완요청',
    hold: '통관보류'
  };

  var descMap = {
    supplement: '보완이 필요한 서류나 내용을 수입자에게 요청합니다.',
    hold: '통관보류 사유를 등록하고 관련 근거파일을 첨부합니다.'
  };

  var buttonTextMap = {
    supplement: '보완요청 등록',
    hold: '통관보류 처리'
  };

  var title = titleMap[value] || '보완요청';
  var desc = descMap[value] || '보완이 필요한 서류나 내용을 수입자에게 요청합니다.';
  var buttonText = buttonTextMap[value] || '처리 등록';

  workTitle.textContent = title;
  workReason.placeholder = title + ' 사유를 입력하세요.';

  if (workDesc) {
    workDesc.textContent = desc;
  }

  if (btnWorkSubmit) {
    btnWorkSubmit.textContent = buttonText;
  }

  if (workFileArea) {
    if (value === 'hold') {
      workFileArea.classList.remove('hidden');
    } else {
      workFileArea.classList.add('hidden');

      if (workFile) {
        workFile.value = '';
      }
    }
  }
}

function submitWork() {
  var workType = document.getElementById('workType');
  var workReason = document.getElementById('workReason');
  var workTitle = document.getElementById('workTitle');
  var workFile = document.getElementById('workFile');

  if (!workType || !workReason || !workTitle) {
    alert('업무처리 입력 영역을 찾을 수 없습니다.');
    return;
  }

  if (!workReason.value.trim()) {
    alert('처리 사유를 입력하세요.');
    workReason.focus();
    return;
  }

  var value = workType.value;
  var title = workTitle.textContent;
  var reason = workReason.value.trim();

  var fileName = '-';
  if (workFile && workFile.files && workFile.files.length > 0) {
    fileName = workFile.files[0].name;
  }

  addWorkRequestHistory(title, reason, value, fileName);

  if (value === 'hold') {
    setStatus('통관보류');
  } else {
    setStatus('보완요청');
  }

  openDetailTab('work');

  toast(title + ' 등록 완료', getToastType(value));

  workReason.value = '';
  if (workFile) {
    workFile.value = '';
  }
}

function setStatus(status) {
  setText('detailStatus', status);
  setText('inlineStatus', status);

  var panel = document.getElementById('statusPanel');
  if (!panel) return;

  panel.className = 'status-panel sp-' + status;
}

function addHistory(title, color, note) {
  var list = document.getElementById('historyList');
  if (!list) return;

  var count = list.querySelectorAll('.tl-item').length + 1;

  var item = document.createElement('div');
  item.className = 'tl-item';

  item.innerHTML =
    '<div class="tl-dot ' + escapeHtml(color || 'blue') + '">' + count + '</div>' +
    '<div class="tl-body">' +
      '<div class="tl-title">' + escapeHtml(title) + '</div>' +
      '<div class="tl-time">방금 전 · 김세관</div>' +
      '<div class="tl-note">' + escapeHtml(note || '처리 이력이 추가되었습니다.') + '</div>' +
    '</div>';

  list.appendChild(item);
}

function addWorkRequestHistory(title, reason, value, fileName) {
  var tbody =
    document.getElementById('workHistoryBody') ||
    document.querySelector('.work-history-table tbody') ||
    document.querySelector('.request-history-table tbody');

  if (!tbody) {
    alert('처리요청이력 표를 찾을 수 없습니다. tbody id="workHistoryBody"를 JSP에 넣어주세요.');
    return;
  }

  var emptyRow = tbody.querySelector('.empty-cell');
  if (emptyRow) {
    var emptyTr = emptyRow.closest('tr');
    if (emptyTr) emptyTr.remove();
  }

  var attachText = '-';
  if (fileName && fileName !== '-') {
    attachText =
      '<button type="button" class="btn-secondary btn-sm" onclick="previewFile(\'' +
      escapeJs(fileName) +
      '\')">첨부확인</button>';
  }

  var tr = document.createElement('tr');
  tr.innerHTML =
    '<td>' + escapeHtml(title) + '</td>' +
    '<td>방금 전</td>' +
    '<td>' + escapeHtml(reason) + '</td>' +
    '<td>-</td>' +
    '<td><span class="work-badge-orange">답변대기</span></td>' +
    '<td>' + attachText + '</td>';

  tbody.appendChild(tr);
}

function getHistoryColor(value) {
  if (value === 'supplement') return 'orange';
  if (value === 'clarify') return 'cyan';
  if (value === 'hold') return 'gray';
  return 'blue';
}

function getToastType(value) {
  if (value === 'supplement') return 'o';
  if (value === 'clarify') return 'b';
  if (value === 'hold') return 'o';
  return 'b';
}

function goList() {
  location.href = (window.contextPath || '') + '/officer/basicScreenList.do';
}

function previewFile(fileName) {
  if (!fileName) {
    toast('미리보기할 파일이 없습니다.', 'r');
    return;
  }

  toast(fileName + ' 파일 미리보기는 파일 뷰어 연결 후 표시됩니다.', 'b');
}

function safeClick(id, handler) {
  var el = document.getElementById(id);
  if (el) {
    el.addEventListener('click', handler);
  }
}

function safeChange(id, handler) {
  var el = document.getElementById(id);
  if (el) {
    el.addEventListener('change', handler);
  }
}

function setText(id, text) {
  var el = document.getElementById(id);
  if (el) {
    el.textContent = text;
  }
}

function toast(message, type) {
  var oldToast = document.querySelector('.toast');
  if (oldToast) {
    oldToast.remove();
  }

  var box = document.createElement('div');
  box.className = 'toast ' + (type || 'b');
  box.innerHTML =
    '<span class="material-symbols-outlined" style="font-size:18px">info</span>' +
    '<span>' + escapeHtml(message) + '</span>';

  document.body.appendChild(box);

  setTimeout(function () {
    box.classList.add('on');
  }, 10);

  setTimeout(function () {
    box.classList.remove('on');

    setTimeout(function () {
      box.remove();
    }, 300);
  }, 300);
}

function escapeHtml(value) {
  return String(value)
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');
}

function escapeJs(value) {
  return String(value)
    .replaceAll('\\', '\\\\')
    .replaceAll("'", "\\'")
    .replaceAll('"', '\\"');
}

function submitDetailAccept() {
  if (!confirm('접수 처리하시겠습니까?')) return;

  var form = document.getElementById('detailAcceptForm');
  if (form) {
    form.submit();
  }
}

function openDetailRejectModal() {
  var modal = document.getElementById('m-reject');
  if (modal) {
    modal.style.display = 'flex';
  }
}

function closeDetailRejectModal() {
  var modal = document.getElementById('m-reject');
  if (modal) {
    modal.style.display = 'none';
  }
  
  /* =============================================================
     workTab.js — basicScreenDetail.js 하단에 붙여넣기
     · SUPP_RQST(보완요청) / CUSTOMS_STATUS_HISTORY(통관보류) 연동
     · 등록 → DB 저장, 버튼 해지로 전환, 승인 버튼 비활성
     · 해지 → DB 해지, 버튼 등록으로 복원, 승인 버튼 재활성
     ============================================================= */
  (function () {
      'use strict';

      /* ── 페이지 메타 ── */
      function meta(id) { const e = document.getElementById(id); return e ? e.getAttribute('content') : ''; }
      const REQ_NO = meta('pageReqNo');
      const CTX    = meta('pageCtx');
      const CSRF   = meta('pageCsrf');

      /* ── DOM ── */
      const workType    = document.getElementById('workType');
      const workTitle   = document.getElementById('workTitle');
      const workBadge   = document.getElementById('workBadge');
      const workDesc    = document.getElementById('workDesc');
      const workReason  = document.getElementById('workReason');
      const workDueDate = document.getElementById('workDueDate');
      const workFileRow = document.getElementById('workFileRow');
      const workFile    = document.getElementById('workFile');
      const btnReset    = document.getElementById('btnWorkReset');
      const btnSubmit   = document.getElementById('btnWorkSubmit');
      const btnCancel   = document.getElementById('btnWorkCancel');
      const historyBody = document.getElementById('workHistoryBody');
      const historyList = document.getElementById('historyList');
      const btnApprove  = document.getElementById('btnApproveBottom');

      if (!btnSubmit || !btnCancel || !historyBody) return;

      /* ── 상수 ── */
      const LABEL = { supplement: '보완요청', hold: '통관보류', hold_release: '통관보류 해지' };
      const BADGE  = { supplement: 'badge-suppl', hold: 'badge-hold', hold_release: 'badge-cancel' };
      const DESC   = {
          supplement: '보완이 필요한 서류나 내용을 수입자에게 요청합니다.',
          hold:       '통관보류 사유를 등록합니다.',
      };

      /* ── 유틸 ── */
      function esc(s) {
          return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;')
                                .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }
      function toast(msg) {
          if (typeof window.showToast === 'function') { window.showToast(msg); return; }
          const t = document.getElementById('toastEl');
          if (!t) return;
          t.textContent = msg; t.classList.add('show');
          setTimeout(() => t.classList.remove('show'), 2800);
      }
      function show(el) { if (el) { el.classList.remove('hidden'); el.style.removeProperty('display'); } }
      function hide(el) { if (el) { el.classList.add('hidden');    el.style.display = 'none'; } }

      /* ── 승인 버튼 잠금/해제 ── */
      function lockApprove() {
          if (!btnApprove) return;
          btnApprove.disabled = true;
          btnApprove.classList.add('btn-disabled');
          btnApprove.title = '보완요청 또는 통관보류 진행 중 — 해지 후 승인 가능합니다.';
      }
      function unlockApprove() {
          if (!btnApprove) return;
          btnApprove.disabled = false;
          btnApprove.classList.remove('btn-disabled');
          btnApprove.title = '';
      }

      /* ── 셀렉트 변경 → 카드 UI 갱신 ── */
      function applyType(type) {
          const label = LABEL[type] || '보완요청';
          if (workTitle)  workTitle.textContent = label;
          if (workBadge)  { workBadge.textContent = label; workBadge.className = 'badge ' + (BADGE[type] || 'badge-suppl'); }
          if (workDesc)   workDesc.textContent = DESC[type] || '';
          if (workFileRow) type === 'hold' ? show(workFileRow) : hide(workFileRow);
          if (btnSubmit)  btnSubmit.textContent = label + ' 등록';
          if (btnCancel)  btnCancel.textContent = label + ' 해지';
      }

      /* ── 처리요청이력 테이블에 행 추가 ── */
      function addHistoryRow(type, reason, dueDate) {
          const empty = document.getElementById('emptyWorkRow');
          if (empty) empty.remove();

          const tr = document.createElement('tr');
          tr.dataset.workType = type;
          tr.innerHTML = `
              <td><span class="badge ${BADGE[type] || 'badge-suppl'}">${esc(LABEL[type] || type)}</span></td>
              <td>${new Date().toLocaleString('ko-KR', {hour12:false})}</td>
              <td>${esc(reason)}</td>
              <td>${esc(dueDate || '-')}</td>
              <td><span class="badge badge-wait" id="activeRowStatus">진행중</span></td>
              <td>-</td>`;
          historyBody.prepend(tr);
      }

      /* ── 처리이력 탭 타임라인 추가 ── */
      function addTimeline(type, reason) {
          if (!historyList) return;
          const empty = document.getElementById('historyEmptyBox');
          if (empty) empty.remove();

          const div = document.createElement('div');
          div.className = 'tl-item'; div.id = 'activeTimeline';
          div.innerHTML = `
              <div class="tl-dot purple">●</div>
              <div class="tl-body">
                  <div class="tl-title">${esc(LABEL[type] || type)} 등록</div>
                  <div class="tl-time">${new Date().toLocaleString('ko-KR', {hour12:false})}</div>
                  <div class="tl-note">${esc(reason)}</div>
              </div>`;
          historyList.prepend(div);
      }

      /* ── 처리이력 탭 타임라인 제거 ── */
      function removeTimeline() {
          const item = document.getElementById('activeTimeline');
          if (item) item.remove();
          if (historyList && !historyList.querySelector('.tl-item')) {
              const div = document.createElement('div');
              div.className = 'empty-box'; div.id = 'historyEmptyBox';
              div.textContent = '등록된 처리이력이 없습니다.';
              historyList.appendChild(div);
          }
      }

      /* ── 폼 잠금 ── */
      function lockForm() {
          [workType, workReason, workDueDate, workFile].forEach(e => { if(e) e.disabled = true; });
          hide(btnReset); hide(btnSubmit); show(btnCancel);
      }

      /* ── 폼 복원 ── */
      function unlockForm() {
          [workType, workReason, workDueDate, workFile].forEach(e => { if(e) e.disabled = false; });
          if (workReason)  workReason.value  = '';
          if (workDueDate) workDueDate.value = '';
          if (workFile)    workFile.value    = '';
          show(btnReset); show(btnSubmit); hide(btnCancel);
      }

      /* ── fetch 헬퍼 ── */
      async function api(path, body) {
          const res = await fetch(CTX + path, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': CSRF },
              body: JSON.stringify(body),
          });
          if (!res.ok) throw new Error('서버 오류 ' + res.status);
          return res.json();
      }

      /* ══ 셀렉트 변경 ══ */
      if (workType) workType.onchange = () => applyType(workType.value);

      /* ══ 등록 버튼 ══ */
      btnSubmit.onclick = async function () {
          const type   = workType ? workType.value : 'supplement';
          const reason = (workReason  ? workReason.value  : '').trim();
          const due    = (workDueDate ? workDueDate.value : '') || null;

          if (!reason) { alert('처리 사유를 입력하세요.'); if (workReason) workReason.focus(); return; }

          btnSubmit.disabled = true;
          btnSubmit.textContent = '처리 중...';

          try {
              await api('/officer/workHistory/save', {
                  reqNo:    REQ_NO,
                  workType: type,
                  reason:   reason,
                  dueDate:  due,
              });

              addHistoryRow(type, reason, due);   // ① 이력 테이블
              addTimeline(type, reason);           // ② 처리이력 탭
              lockForm();                          // ③ 버튼 → 해지
              lockApprove();                       // ④ 승인 비활성

              toast((LABEL[type] || type) + '이 등록되었습니다.');
          } catch (e) {
              alert('등록 중 오류가 발생했습니다.\n' + e.message);
              btnSubmit.disabled = false;
              applyType(type);
          }
      };

      /* ══ 해지 버튼 ══ */
      btnCancel.onclick = async function () {
          const type  = workType ? workType.value : 'supplement';
          const label = LABEL[type] || type;
          if (!confirm(label + '을 해지하시겠습니까?')) return;

          btnCancel.disabled = true;
          btnCancel.textContent = '처리 중...';

          try {
              await api('/officer/workHistory/cancel', { reqNo: REQ_NO, workType: type });

              const badge = document.getElementById('activeRowStatus');
              if (badge) { badge.className = 'badge badge-cancel'; badge.textContent = '해지'; badge.removeAttribute('id'); }

              removeTimeline();
              unlockForm();
              unlockApprove();

              toast(label + '이 해지되었습니다.');
          } catch (e) {
              alert('해지 중 오류가 발생했습니다.\n' + e.message);
              btnCancel.disabled = false;
              btnCancel.textContent = label + ' 해지';
          }
      };

      /* ══ 초기화 버튼 ══ */
      if (btnReset) {
          btnReset.onclick = function () {
              if (workReason)  workReason.value  = '';
              if (workDueDate) workDueDate.value = '';
              if (workFile)    workFile.value    = '';
          };
      }

      /* ══ 페이지 로드: 활성 건 있으면 잠금 상태 복원 ══ */
      (async function init() {
          applyType(workType ? workType.value : 'supplement');
          hide(btnCancel);

          try {
              const active = await fetch(CTX + '/officer/workHistory/active?reqNo=' + encodeURIComponent(REQ_NO))
                  .then(r => r.json());

              if (active && active.workType) {
                  // 활성 건 있음 → 셀렉트 복원 후 잠금
                  if (workType) workType.value = active.workType;
                  applyType(active.workType);
                  lockForm();
                  lockApprove();
              }
          } catch (e) {
              // 조회 실패해도 기본 UI 표시
          }
      })();

  })();
  
}