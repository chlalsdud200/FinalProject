window.openInitialTransportView = bootInitialTransportView;
window.bootInitialTransportView = bootInitialTransportView;
window.buildDetailHtml = buildDetailHtml;
window.buildMainPanel = buildMainPanel;
window.buildTransportTrashPanel = buildTransportTrashPanel;
window.buildFields = buildFields;
window.buildField = buildField;
window.typeLabel = typeLabel;
window.resolveActionButtonLabel = resolveActionButtonLabel;
window.getStatusChipClass = getStatusChipClass;
window.buildStatusChip = buildStatusChip;
window.normalizeStatusChips = normalizeStatusChips;
window.closeRejectModal = closeRejectModal;
window.getCurrentExportRequestNo = getCurrentExportRequestNo;
window.getCurrentImportRequestNo = getCurrentImportRequestNo;
window.setExportRequestStatus = setExportRequestStatus;
window.setImportRequestStatus = setImportRequestStatus;
window.postExportStatusToServer = postExportStatusToServer;
window.postImportStatusToServer = postImportStatusToServer;
window.transportTrashLoad = transportTrashLoad;
window.transportTrashToggleAll = transportTrashToggleAll;
window.transportTrashCheckItem = transportTrashCheckItem;
window.transportTrashEmptyAll = transportTrashEmptyAll;
