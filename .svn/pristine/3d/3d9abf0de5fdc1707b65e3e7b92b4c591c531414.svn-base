/*
 * TACS Transport Manager common.js
 *
 * 역할
 * - 운송담당자 공통 사이드바 라우팅
 * - 공통 화면 전환 openDetail()
 * - 상태 chip 공통 렌더링
 * - 수출/수입 운송의뢰 접수완료/접수반려 AJAX 처리
 * - CSRF header 공통 적용
 *
 * 제거한 내용
 * - 원본 HTML script block 잔재
 * - 문서함 샘플 업로드/샘플 다운로드/로컬 배열 패치
 * - 커뮤니티 샘플 공지/FAQ 하드코딩
 * - 마이페이지 알림 localStorage 핫픽스
 * - 동일 기능을 여러 번 덮어쓰던 0429/0506 runtime patch
 */

const menuData = [
    {
        key: 'export',
        title: '수출운송',
        icon: 'local_shipping',
        selectItems: [
            { id: 'TACS-FW-001', title: '운송의뢰' },
            { id: 'TACS-FW-009B', title: '보세구역 입고관리' },
            { id: 'TACS-FW-009', title: '보세구역 반출요청' },
            { id: 'TACS-FW-007', title: '선적배차처리' },
            { id: 'TACS-FW-010', title: '선적지시서 작성 및 제출' },
            { id: 'TACS-FW-010B', title: 'B/L 발행, 제출 및 정산' },
            { id: 'TACS-FW-011', title: '적하목록 작성 및 제출' }
        ]
    },
    {
        key: 'import',
        title: '수입운송',
        icon: 'inventory_2',
        selectItems: [
            { id: 'TACS-FW-015', title: '운송의뢰' },
            { id: 'TACS-FW-023', title: '적하목록 조회' },
            { id: 'TACS-FW-025', title: '보세구역 입고관리' },
            { id: 'TACS-FW-030', title: 'D/O 관리' },
            { id: 'TACS-FW-033', title: '보세구역 반출관리' },
            { id: 'TACS-FW-035', title: '내륙운송 배차처리' }
        ]
    },
    {
        key: 'docs',
        title: '문서함',
        icon: 'folder',
        selectItems: [
            { id: 'TACS-DC-001', title: '문서함' },
            { id: 'TACS-DC-002', title: '휴지통' }
        ]
    },
    {
        key: 'community',
        title: '커뮤니티',
        icon: 'forum',
        selectItems: [
            { id: 'TACS-CM-001', title: '공지사항' },
            { id: 'TACS-CM-003', title: '자료실' },
            { id: 'TACS-CM-004', title: '고객센터' }
        ]
    },
    {
        key: 'mypage',
        title: '마이페이지',
        icon: 'person',
        selectItems: [
            { id: 'TACS-MY-001', title: '회원정보 수정' },
            { id: 'TACS-MY-002', title: '알림 수신 설정' }
        ]
    }
];

const DEFAULT_ITEMS = {
    export: 'TACS-FW-001',
    import: 'TACS-FW-015',
    docs: 'TACS-DC-001',
    community: 'TACS-CM-001',
    mypage: 'TACS-MY-001'
};

const GROUP_PATHS = {
    dashboard: 'dashboard.do',
    export: 'export.do',
    import: 'import.do',
    docs: 'docs.do',
    community: 'community.do',
    mypage: 'mypage.do'
};

const EXPORT_ITEM_TABS = {
    'TACS-FW-001': 'request',
    'TACS-FW-011': 'manifest'
};

const IMPORT_ITEM_TABS = {
    'TACS-FW-015': 'request',
    'TACS-FW-020': 'arrival',
    'TACS-FW-023': 'manifest',
    'TACS-FW-025': 'inbound',
    'TACS-FW-030': 'do',
    'TACS-FW-033': 'release',
    'TACS-FW-035': 'inland'
};

const PAGE_SCRIPTS = {
    export: '/resources/js/transport/pages/export.js',
    import: '/resources/js/transport/pages/import-main.js',
    docs: '/resources/js/common/docs.js',
    community: '/resources/js/transport/pages/community.js'
};

const PAGE_SCRIPT_VERSION = '20260529-dashboard-async-route6';
const PAGE_STYLES = {
    export: '/resources/css/transport/pages/export.css',
    import: '/resources/css/transport/pages/import.css'
};
const loadingScripts = {};

let selectedShippingDoc = null;
let selectedExportRequest = null;
let selectedImportRequest = null;
let currentRejectContext = null;
let currentGroupKey = 'dashboard';
let currentItemId = '';
let initialTransportViewBooted = false;

const importRequestStatusOverrides = {};
const importRequestRejectReasons = {};
const exportRequestStatusOverrides = {};
const exportRequestRejectReasons = {};
const shippingDocStatusOverrides = {};

window.selectedShippingDoc = selectedShippingDoc;
window.selectedExportRequest = selectedExportRequest;
window.selectedImportRequest = selectedImportRequest;
window.currentRejectContext = currentRejectContext;
window.importRequestStatusOverrides = importRequestStatusOverrides;
window.importRequestRejectReasons = importRequestRejectReasons;
window.exportRequestStatusOverrides = exportRequestStatusOverrides;
window.exportRequestRejectReasons = exportRequestRejectReasons;
window.shippingDocStatusOverrides = shippingDocStatusOverrides;

function qs(selector, root) {
    return (root || document).querySelector(selector);
}

function qsa(selector, root) {
    return Array.from((root || document).querySelectorAll(selector));
}

function getContextPath() {
    if (window.contextPath) return window.contextPath;
    const meta = qs('meta[name="ctx-path"]');
    return meta ? meta.getAttribute('content') || '' : '';
}

function getDashboardView() {
    return qs('#dashboard-view');
}

function getDetailView() {
    return qs('#detail-view');
}

function getDetailBody() {
    const body = qs('#detail-body');
    if (body) window.detailBody = body;
    return body;
}

function getPageTitle() {
    return qs('#page-title');
}

function getBreadcrumb() {
    return qs('#breadcrumb');
}

function getBackBtn() {
    return qs('#backBtn');
}

function escapeHtml(value) {
    return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function escapeAttr(value) {
    return String(value || '').replace(/"/g, '&quot;');
}

function getCsrfHeaders() {
    const headers = {};
    const metaToken = qs('meta[name="_csrf"]');
    const metaHeader = qs('meta[name="_csrf_header"]');
    const csrf = window.TRANSPORT_CSRF || {};
    const token = csrf.token || (metaToken ? metaToken.getAttribute('content') : '');
    const header = csrf.header || (metaHeader ? metaHeader.getAttribute('content') : '');

    if (token && header) {
        headers[header] = token;
    }

    return headers;
}

function getMenuGroup(groupKey) {
    return menuData.find(function (group) {
        return group.key === groupKey;
    }) || null;
}

function getMenuItem(groupKey, itemId) {
    const group = getMenuGroup(groupKey);
    if (!group) return null;
    const id = itemId || DEFAULT_ITEMS[groupKey];
    const item = (group.selectItems || []).find(function (menuItem) {
        return menuItem.id === id;
    });
    return item || (group.selectItems && group.selectItems[0]) || null;
}

function isValidMenuItem(groupKey, itemId) {
    const group = getMenuGroup(groupKey);
    return !!(group && group.selectItems && group.selectItems.some(function (item) {
        return item.id === itemId;
    }));
}

function isImportListItem(itemId) {
    return [
        'TACS-FW-015',
        'TACS-FW-020',
        'TACS-FW-023',
        'TACS-FW-025',
        'TACS-FW-030',
        'TACS-FW-033',
        'TACS-FW-035'
    ].indexOf(itemId) > -1;
}

function makeUrl(group, item) {
    const base = getContextPath() + '/transport/';
    const path = GROUP_PATHS[group] || GROUP_PATHS.dashboard;
    const defaultItem = DEFAULT_ITEMS[group] || '';
    const resolvedItem = item || defaultItem;

    if (group === 'mypage') {
        return base + path + '?tab=' + (item === 'TACS-MY-002' ? 'alarm' : 'profile');
    }

    if (group === 'dashboard') return base + path;
    if (group === 'export' && EXPORT_ITEM_TABS[resolvedItem]) return base + path + '?tab=' + EXPORT_ITEM_TABS[resolvedItem];
    if (group === 'import' && IMPORT_ITEM_TABS[resolvedItem]) return base + path + '?tab=' + IMPORT_ITEM_TABS[resolvedItem];
    if (group === 'docs' && resolvedItem === 'TACS-DC-002') return base + 'docs/trash.do';
    if (!item) return base + path;
    return base + path + '?page=' + encodeURIComponent(item);
}

function makeMypageUrl(item, href) {
    const targetUrl = new URL(href || makeUrl('mypage', item), window.location.origin);
    if (!targetUrl.searchParams.get('tab')) {
        targetUrl.searchParams.set('tab', item === 'TACS-MY-002' ? 'alarm' : 'profile');
    }
    return targetUrl.pathname + targetUrl.search;
}

function getTargetFromLink(link) {
    const group = link.dataset.group || 'dashboard';
    const item = link.dataset.itemId || (group === 'dashboard' ? '' : DEFAULT_ITEMS[group]);
    return { group: group, item: item || '' };
}

function setActiveNav(groupKey, itemId) {
    qsa('.menu-item').forEach(function (menu) {
        menu.classList.toggle('active', menu.dataset.group === groupKey);
    });

    qsa('.sub-item').forEach(function (sub) {
        sub.classList.toggle('active-sub', sub.dataset.group === groupKey && sub.dataset.itemId === itemId);
    });

    qsa('.menu-group').forEach(function (wrap) {
        const open = wrap.dataset.groupWrap === groupKey;
        const children = qs('.menu-children', wrap);
        const arrow = qs('.menu-arrow', wrap);
        if (children) children.classList.toggle('open', open);
        if (arrow) arrow.classList.toggle('rotated', open);
    });
}

function toggleMenuGroup(groupKey, forceOpen) {
    qsa('.menu-group').forEach(function (wrap) {
        const isTarget = wrap.dataset.groupWrap === groupKey;
        const children = qs('.menu-children', wrap);
        const arrow = qs('.menu-arrow', wrap);
        if (!children) return;

        const shouldOpen = isTarget ? (forceOpen === true || !children.classList.contains('open')) : false;
        children.classList.toggle('open', shouldOpen);
        if (arrow) arrow.classList.toggle('rotated', shouldOpen);
    });
}

function activateDashboardMenu() {
    setActiveNav('dashboard', '');
    qsa('.menu-children').forEach(function (children) {
        children.classList.remove('open');
    });
    qsa('.menu-arrow').forEach(function (arrow) {
        arrow.classList.remove('rotated');
    });
}

function showDashboard(event) {
    if (event) event.preventDefault();

    if (window.location.pathname.indexOf('/transport/dashboard.do') === -1) {
        window.location.href = getContextPath() + '/transport/dashboard.do';
        return;
    }

    currentGroupKey = 'dashboard';
    currentItemId = '';
    window.TRANSPORT_INITIAL_VIEW = { group: 'dashboard', item: '' };

    activateDashboardMenu();

    const dashboardView = getDashboardView();
    const detailView = getDetailView();
    if (dashboardView) dashboardView.classList.remove('hidden');
    if (detailView) detailView.classList.add('hidden');
}

function showLoading(message) {
    return '' +
        '<div class="section-card p-8 text-center text-sm text-slate-500">' +
        escapeHtml(message || '화면을 불러오는 중입니다.') +
        '</div>';
}

function setDetailShell(groupKey, itemId) {
    const group = getMenuGroup(groupKey);
    const item = getMenuItem(groupKey, itemId);
    const dashboardView = getDashboardView();
    const detailView = getDetailView();
    const detailBody = getDetailBody();
    const pageTitle = getPageTitle();
    const breadcrumb = getBreadcrumb();
    const backBtn = getBackBtn();

    if (!group || !item || !detailBody) return null;

    currentGroupKey = groupKey;
    currentItemId = item.id;
    window.TRANSPORT_INITIAL_VIEW = { group: groupKey, item: item.id };

    setActiveNav(groupKey, item.id);
    if (dashboardView) dashboardView.classList.add('hidden');
    if (detailView) detailView.classList.remove('hidden');
    if (pageTitle) pageTitle.textContent = item.title;
    if (breadcrumb) {
        breadcrumb.innerHTML = escapeHtml(group.title) + ' &gt; <span class="font-semibold text-slate-900">' + escapeHtml(item.title) + '</span>';
    }

    detailBody.dataset.currentGroup = groupKey;
    detailBody.dataset.currentItem = item.id;

    if (backBtn) {
        backBtn.innerHTML = '<span class="material-symbols-outlined text-lg">arrow_back</span><span>대시보드로</span>';
        backBtn.onclick = showDashboard;
    }

    return { group: group, item: item };
}

function buildDetailHtml(group, item) {
    return '<div class="space-y-6">' + buildMainPanel(item, group) + '</div>';
}

function buildTransportTrashPanel() {
    return '' +
        '<div id="transport-docs-trash" class="tacs-docs-trash" style="padding:0;">' +
        '  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;gap:16px;flex-wrap:wrap;">' +
        '    <div>' +
        '      <h1 style="font-size:28px;font-weight:900;color:#0f172a;letter-spacing:0;margin:0 0 8px;">휴지통</h1>' +
        '      <div style="font-size:13px;color:#64748b;">휴지통으로 이동된 항목을 확인하고 영구삭제할 수 있습니다.</div>' +
        '    </div>' +
        '    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;justify-content:flex-end;">' +
        '      <button class="btn btn-outline" id="transport-trash-empty" onclick="transportTrashEmptyAll()" style="display:flex;align-items:center;gap:4px;padding:7px 11px;border:1px solid #cbd5e1;background:#fff;color:#dc2626;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;"><span class="material-symbols-outlined" style="font-size:16px;">delete_forever</span>전체 삭제</button>' +
        '      <button class="btn btn-primary" id="transport-trash-delete-selected" onclick="transportTrashDeleteSelected()" style="display:flex;align-items:center;gap:4px;padding:7px 11px;border:1px solid #0f172a;background:#0f172a;color:#fff;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;opacity:.5;" disabled><span class="material-symbols-outlined" style="font-size:16px;">delete</span>선택 영구삭제</button>' +
        '      <button class="btn btn-secondary" id="transport-trash-delete-current" onclick="transportTrashDeleteCurrentList()" style="display:flex;align-items:center;gap:4px;padding:7px 11px;border:1px solid #64748b;background:#64748b;color:#fff;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;"><span class="material-symbols-outlined" style="font-size:16px;">delete_sweep</span>현재목록 삭제</button>' +
        '    </div>' +
        '  </div>' +
        '  <div id="transport-trash-table-wrap" style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;">' +
        '    <table style="width:100%;border-collapse:collapse;text-align:left;font-size:13px;"><thead><tr style="background:#f8fafc;border-bottom:1px solid #e2e8f0;">' +
        '      <th style="padding:12px 16px;width:40px;text-align:center;"><input type="checkbox" id="transport-trash-check-all" onclick="transportTrashToggleAll(this.checked)" style="cursor:pointer;"></th>' +
        '      <th style="padding:12px 16px;color:#475569;font-weight:600;width:72px;">유형</th><th style="padding:12px 16px;color:#475569;font-weight:600;">이름</th><th style="padding:12px 16px;color:#475569;font-weight:600;width:120px;">크기</th><th style="padding:12px 16px;color:#475569;font-weight:600;width:180px;">휴지통 이동일</th>' +
        '    </tr></thead><tbody id="transport-trash-list-body"></tbody></table>' +
        '  </div>' +
        '  <div id="transport-trash-pagination" style="display:flex;justify-content:center;margin-top:20px;gap:4px;"></div>' +
        '  <div id="transport-trash-empty-state" style="display:none;padding:60px 20px;text-align:center;background:#fff;border:1px solid #e2e8f0;border-radius:12px;margin-top:0;">' +
        '    <span class="material-symbols-outlined" style="font-size:48px;color:#cbd5e1;margin-bottom:16px;">delete</span><div style="font-size:16px;font-weight:700;color:#0f172a;margin-bottom:8px;">휴지통이 비어 있음</div><div style="font-size:13px;color:#64748b;line-height:1.5;">휴지통으로 이동된 항목이 없습니다.</div>' +
        '  </div>' +
        '</div>';
}

function buildMainPanel(item, group) {
    if (!item) return showLoading();

    if (item.id === 'TACS-DC-001') {
        if (typeof window.buildDocumentArchivePanel === 'function') {
            return '<div id="docArchiveRoot">' + window.buildDocumentArchivePanel('all') + '</div>';
        }
        return '<div id="docArchiveRoot">' + showLoading('문서함 스크립트를 불러오는 중입니다.') + '</div>';
    }

    if (item.id === 'TACS-DC-002') {
        return buildTransportTrashPanel();
    }

    if (group && group.key === 'community') {
        if (typeof window.buildBrokerCommunityPanel === 'function') {
            return window.buildBrokerCommunityPanel();
        }
        return showLoading('커뮤니티 화면을 불러오는 중입니다.');
    }
    if (typeof window.buildRequestListPanel === 'function' && item.id === 'TACS-FW-015') {
        return window.buildRequestListPanel(item);
    }

    return '' +
        '<div class="section-card p-8 text-center">' +
        '<h4 class="text-sm font-bold text-slate-900 mb-2">' + escapeHtml(item.title) + '</h4>' +
        '<p class="text-xs text-slate-500">해당 화면은 페이지별 JS에서 렌더링됩니다.</p>' +
        '</div>';
}

function openDetail(groupKey, itemId) {
    const resolvedItemId = itemId || DEFAULT_ITEMS[groupKey];

    if (groupKey === 'mypage') {
        window.location.href = makeMypageUrl(resolvedItemId);
        return Promise.resolve();
    }

    /*
     * If a page-specific router is already loaded, let it render the screen.
     * Without this, /transport/import.do first render could fall back to the
     * old generic common panel until the user refreshed or clicked the menu.
     */
    if (
        groupKey !== 'dashboard' &&
        hasPageScript(groupKey) &&
        !window.__TRANSPORT_COMMON_OPEN_FALLBACK &&
        typeof window.openDetail === 'function' &&
        window.openDetail !== openDetail
    ) {
        window.__TRANSPORT_COMMON_OPEN_FALLBACK = true;
        try {
            return Promise.resolve(window.openDetail(groupKey, resolvedItemId));
        } finally {
            window.__TRANSPORT_COMMON_OPEN_FALLBACK = false;
        }
    }

    if (groupKey !== 'dashboard' && !hasPageScript(groupKey)) {
        const shell = setDetailShell(groupKey, resolvedItemId);
        const loadingBody = getDetailBody();
        if (shell && loadingBody) {
            loadingBody.innerHTML = showLoading(shell.group.title + ' 화면을 불러오는 중입니다.');
        }

        return loadPageScript(groupKey)
            .then(function () {
                return refreshTransportRequestCache(groupKey);
            })
            .then(function () {
                if (typeof window.openDetail === 'function' && window.openDetail !== openDetail) {
                    return window.openDetail(groupKey, resolvedItemId);
                }
                return openDetail(groupKey, resolvedItemId);
            })
            .catch(function (error) {
                console.error('transport detail script load failed', groupKey, error);
                const detailBody = getDetailBody();
                if (detailBody) {
                    detailBody.innerHTML = '' +
                        '<div class="section-card p-8 text-center text-sm text-red-600">' +
                        escapeHtml('화면을 불러오지 못했습니다. 새로고침 후 다시 시도해주세요.') +
                        '</div>';
                }
            });
    }

    const shell = setDetailShell(groupKey, itemId);
    const detailBody = getDetailBody();
    if (!shell || !detailBody) return;

    window.detailBody = detailBody;
    detailBody.innerHTML = buildDetailHtml(shell.group, shell.item);

    if (shell.item.id === 'TACS-DC-001') {
        ensureDocsBoot();
    }

    if (shell.item.id === 'TACS-DC-002') {
        bootTransportTrashPanel();
    }

    if (shell.group.key === 'community') {
        bootCommunityTab(shell.item.id);
    }

    if (shell.group.key === 'mypage') {
        bootMypageTab(shell.item.id);
    }

    normalizeStatusChips(detailBody);
}

function hasPageScript(group) {
    const pageReady = window.TRANSPORT_PAGE_READY || {};
    if (group === 'dashboard') return true;
    if (group === 'docs') return typeof window.docsInit === 'function' && typeof window.buildDocumentArchivePanel === 'function';
    if (group === 'community') return typeof window.buildBrokerCommunityPanel === 'function';
    if (group === 'mypage') return true;
    if (group === 'export') return pageReady.export === true || typeof window.renderExportRequestDetailPage === 'function';
    if (group === 'import') return window.__TACS_IMPORT_SPLIT_BOOTED === true;
    return true;
}

function ensurePageStyle(group) {
    const path = PAGE_STYLES[group];
    if (!path) return;

    const href = getContextPath() + path;
    const exists = qsa('link[rel="stylesheet"]').some(function (link) {
        return (link.getAttribute('href') || '').indexOf(path) > -1;
    });
    if (exists) return;

    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = href + '?v=' + PAGE_SCRIPT_VERSION;
    document.head.appendChild(link);
}

function loadPageScript(group) {
    if (hasPageScript(group)) return Promise.resolve();
    if (loadingScripts[group]) return loadingScripts[group];

    const path = PAGE_SCRIPTS[group];
    if (!path) return Promise.resolve();

    ensurePageStyle(group);

    loadingScripts[group] = new Promise(function (resolve, reject) {
        const script = document.createElement('script');
        script.src = getContextPath() + path + '?v=' + PAGE_SCRIPT_VERSION;
        script.async = false;
        script.onload = function () {
            if (group === 'import' && window.__TACS_IMPORT_SPLIT_READY && typeof window.__TACS_IMPORT_SPLIT_READY.then === 'function') {
                window.__TACS_IMPORT_SPLIT_READY.then(resolve).catch(resolve);
                return;
            }
            resolve();
        };
        script.onerror = reject;
        document.head.appendChild(script);
    }).finally(function () {
        delete loadingScripts[group];
    });

    return loadingScripts[group];
}

function refreshTransportRequestCache(group) {
    if (group !== 'export' && group !== 'import') return Promise.resolve();

    const targetName = group === 'export' ? 'TRANSPORT_EXPORT_REQUESTS' : 'TRANSPORT_IMPORT_REQUESTS';
    const url = getContextPath() + '/transport/' + group + '/request/list.do';

    return fetch(url, {
        method: 'GET',
        headers: { 'Accept': 'application/json' },
        cache: 'no-store'
    })
        .then(function (response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.json();
        })
        .then(function (list) {
            window[targetName] = Array.isArray(list) ? list : [];
        })
        .catch(function (error) {
            console.error(group + ' request cache refresh failed', error);
        });
}

function navigate(group, item, url, replace) {
    const targetUrl = url || makeUrl(group, item);
    const resolvedItem = item || DEFAULT_ITEMS[group];

    if (group === 'mypage') {
        window.location.href = makeMypageUrl(item, targetUrl);
        return Promise.resolve();
    }

    if (!getDetailBody()) {
        window.location.href = targetUrl;
        return Promise.resolve();
    }

    setActiveNav(group, item || '');
    window.TRANSPORT_INITIAL_VIEW = { group: group, item: resolvedItem };

    if (group === 'dashboard') {
        showDashboard();
        updateHistory(group, '', targetUrl, replace);
        return Promise.resolve();
    }

    const shell = setDetailShell(group, resolvedItem);
    const detailBody = getDetailBody();
    if (shell && detailBody) {
        detailBody.innerHTML = showLoading(shell.item.title + ' 화면을 불러오는 중입니다.');
        detailBody.dataset.routePending = 'true';
    }

    return loadPageScript(group)
        .then(function () {
            return refreshTransportRequestCache(group);
        })
        .then(function () {
            openDetail(group, resolvedItem);
            const renderedBody = getDetailBody();
            if (renderedBody) renderedBody.dataset.routePending = '';
            updateHistory(group, resolvedItem, targetUrl, replace);
        })
        .catch(function (error) {
            console.error('transport navigation failed', error);
            window.location.href = targetUrl;
        });
}

function updateHistory(group, item, url, replace) {
    if (!window.history || !window.history.pushState) return;
    const method = replace ? 'replaceState' : 'pushState';
    history[method]({ group: group, item: item || '' }, '', url);
}

function ensureDocsBoot() {
    setTimeout(function () {
        if (typeof window.docsInit === 'function') {
            window.docsInit();
        }
    }, 0);
}

const transportTrashState = {
    currentPage: 1,
    selectedIds: new Set(),
    items: []
};

function transportTrashRequest(url, options) {
    const opt = options || {};
    opt.credentials = 'same-origin';
    opt.headers = Object.assign({ 'X-Requested-With': 'XMLHttpRequest' }, getCsrfHeaders(), opt.headers || {});

    return fetch(getContextPath() + url, opt).then(function (response) {
        if (!response.ok) {
            return response.text().then(function (text) {
                throw new Error(text || ('HTTP ' + response.status));
            });
        }
        const contentType = response.headers.get('content-type') || '';
        if (contentType.indexOf('application/json') >= 0) return response.json();
        return response.text();
    });
}

function transportTrashFormatSize(size) {
    let value = Number(size || 0);
    if (!value) return '-';
    const units = ['B', 'KB', 'MB', 'GB'];
    let idx = 0;
    while (value >= 1024 && idx < units.length - 1) {
        value = value / 1024;
        idx += 1;
    }
    return (idx === 0 ? value.toFixed(0) : value.toFixed(1)) + ' ' + units[idx];
}

function bootTransportTrashPanel() {
    setTimeout(function () {
        if (document.getElementById('transport-docs-trash')) {
            transportTrashLoad(1);
        } else if (typeof window.trashLoad === 'function' && document.getElementById('pg-docs-trash')) {
            window.trashLoad(1);
        }
    }, 0);
}

function transportTrashLoad(page) {
    transportTrashState.currentPage = page || 1;
    transportTrashState.selectedIds.clear();
    transportTrashUpdateUI();

    transportTrashRequest('/api/docs/trash/list.do?page=' + encodeURIComponent(transportTrashState.currentPage), { method: 'GET' })
        .then(function (result) {
            transportTrashRenderList(result || {});
        })
        .catch(function (error) {
            console.error(error);
            alert('휴지통 목록을 불러오는데 실패했습니다.');
            transportTrashRenderEmpty();
        });
}

function transportTrashRenderList(pagingVO) {
    transportTrashState.items = Array.isArray(pagingVO.dataList) ? pagingVO.dataList : [];
    const tbody = qs('#transport-trash-list-body');
    const tableWrap = qs('#transport-trash-table-wrap');
    const emptyState = qs('#transport-trash-empty-state');
    const pagination = qs('#transport-trash-pagination');
    const checkAll = qs('#transport-trash-check-all');

    if (!tbody || !tableWrap || !emptyState || !pagination) return;
    if (transportTrashState.items.length === 0) {
        transportTrashRenderEmpty();
        return;
    }

    tableWrap.style.display = 'block';
    emptyState.style.display = 'none';
    tbody.innerHTML = transportTrashState.items.map(function (item) {
        const id = escapeHtml(item.id || '');
        const type = item.type === 'folder' ? 'folder' : 'file';
        const icon = type === 'folder' ? 'folder' : 'description';
        const color = type === 'folder' ? '#6366f1' : '#64748b';
        return '' +
            '<tr style="border-bottom:1px solid #f1f5f9;">' +
            '  <td style="padding:12px 16px;text-align:center;"><input type="checkbox" class="transport-trash-item-chk" value="' + id + '" onclick="transportTrashCheckItem()"></td>' +
            '  <td style="padding:12px 16px;"><span class="material-symbols-outlined" style="color:' + color + ';font-size:20px;vertical-align:middle;">' + icon + '</span></td>' +
            '  <td style="padding:12px 16px;font-weight:500;color:#0f172a;">' + escapeHtml(item.name || '-') + '</td>' +
            '  <td style="padding:12px 16px;color:#64748b;">' + transportTrashFormatSize(item.size) + '</td>' +
            '  <td style="padding:12px 16px;color:#64748b;">' + escapeHtml(item.trashDt || '-') + '</td>' +
            '</tr>';
    }).join('');

    const totalPage = Number(pagingVO.totalPage || 0);
    const startPage = Number(pagingVO.startPage || 1);
    const endPage = Number(pagingVO.endPage || totalPage);
    const currentPage = Number(pagingVO.currentPage || transportTrashState.currentPage);
    let pageHtml = '';

    if (totalPage > 0) {
        if (startPage > 1) pageHtml += '<button onclick="transportTrashLoad(' + (startPage - 1) + ')" style="padding:6px 10px;border:1px solid #e2e8f0;background:#fff;border-radius:6px;cursor:pointer;">이전</button>';
        for (let i = startPage; i <= endPage; i += 1) {
            pageHtml += i === currentPage
                ? '<button style="padding:6px 10px;border:1px solid #0f172a;background:#0f172a;color:#fff;border-radius:6px;cursor:default;font-weight:700;">' + i + '</button>'
                : '<button onclick="transportTrashLoad(' + i + ')" style="padding:6px 10px;border:1px solid #e2e8f0;background:#fff;border-radius:6px;cursor:pointer;">' + i + '</button>';
        }
        if (endPage < totalPage) pageHtml += '<button onclick="transportTrashLoad(' + (endPage + 1) + ')" style="padding:6px 10px;border:1px solid #e2e8f0;background:#fff;border-radius:6px;cursor:pointer;">다음</button>';
    }

    pagination.innerHTML = pageHtml;
    if (checkAll) checkAll.checked = false;
    transportTrashUpdateUI();
}

function transportTrashRenderEmpty() {
    transportTrashState.items = [];
    transportTrashState.selectedIds.clear();
    const tbody = qs('#transport-trash-list-body');
    const tableWrap = qs('#transport-trash-table-wrap');
    const emptyState = qs('#transport-trash-empty-state');
    const pagination = qs('#transport-trash-pagination');
    if (tbody) tbody.innerHTML = '';
    if (tableWrap) tableWrap.style.display = 'none';
    if (emptyState) emptyState.style.display = 'block';
    if (pagination) pagination.innerHTML = '';
    transportTrashUpdateUI();
}

function transportTrashToggleAll(checked) {
    const checks = qsa('.transport-trash-item-chk');
    transportTrashState.selectedIds.clear();
    checks.forEach(function (check) {
        check.checked = checked;
        if (checked) transportTrashState.selectedIds.add(check.value);
    });
    transportTrashUpdateUI();
}

function transportTrashCheckItem() {
    const checks = qsa('.transport-trash-item-chk');
    let allChecked = checks.length > 0;
    transportTrashState.selectedIds.clear();
    checks.forEach(function (check) {
        if (check.checked) transportTrashState.selectedIds.add(check.value);
        else allChecked = false;
    });
    const checkAll = qs('#transport-trash-check-all');
    if (checkAll) checkAll.checked = allChecked;
    transportTrashUpdateUI();
}

function transportTrashUpdateUI() {
    const selectedBtn = qs('#transport-trash-delete-selected');
    const currentBtn = qs('#transport-trash-delete-current');
    const emptyBtn = qs('#transport-trash-empty');
    const hasSelected = transportTrashState.selectedIds.size > 0;
    const hasItems = transportTrashState.items.length > 0;

    if (selectedBtn) {
        selectedBtn.disabled = !hasSelected;
        selectedBtn.style.opacity = hasSelected ? '1' : '.5';
    }

    [currentBtn, emptyBtn].forEach(function (button) {
        if (!button) return;
        button.disabled = !hasItems;
        button.style.opacity = hasItems ? '1' : '.5';
        button.style.cursor = hasItems ? 'pointer' : 'not-allowed';
    });
}

function transportTrashDeleteIds(ids, page, message) {
    transportTrashRequest('/api/docs/trash/items.do', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: ids })
    }).then(function () {
        alert(message);
        transportTrashLoad(page || 1);
    }).catch(function (error) {
        console.error(error);
        alert('처리 중 오류가 발생했습니다.');
    });
}

function transportTrashEmptyAll() {
    if (transportTrashState.items.length === 0) {
        alert('휴지통에 삭제할 항목이 없습니다.');
        return;
    }
    if (!confirm('휴지통을 비우시겠습니까?\n모든 항목이 영구적으로 삭제되며 복구할 수 없습니다.')) return;

    transportTrashRequest('/api/docs/trash/all.do', { method: 'DELETE' })
        .then(function () {
            alert('휴지통을 비웠습니다.');
            transportTrashLoad(1);
        })
        .catch(function (error) {
            console.error(error);
            alert('처리 중 오류가 발생했습니다.');
        });
}

function transportTrashDeleteSelected() {
    if (transportTrashState.selectedIds.size === 0) return;
    if (!confirm('선택한 항목을 영구적으로 삭제하시겠습니까?')) return;
    transportTrashDeleteIds(Array.from(transportTrashState.selectedIds), transportTrashState.currentPage, '선택한 항목이 영구 삭제되었습니다.');
}

function transportTrashDeleteCurrentList() {
    if (transportTrashState.items.length === 0) {
        alert('현재 목록에 삭제할 항목이 없습니다.');
        return;
    }
    if (!confirm('현재 페이지의 목록을 영구적으로 삭제하시겠습니까?')) return;
    transportTrashDeleteIds(transportTrashState.items.map(function (item) { return item.id; }), transportTrashState.currentPage, '현재 목록의 항목들이 영구 삭제되었습니다.');
}

function bootCommunityTab(itemId) {
    const target = itemId === 'TACS-CM-003' ? 'download' : (itemId === 'TACS-CM-004' ? 'cs' : 'notice');

    setTimeout(function () {
        if (typeof window.initBrokerCommunity === 'function') window.initBrokerCommunity();
        if (typeof window.cTab === 'function') window.cTab('cm', target);

        if (target === 'notice') {
            if (typeof window.mountTransportNoticePanel === 'function') window.mountTransportNoticePanel();
            else if (typeof window.renderNoticeList === 'function') window.renderNoticeList();
            else if (typeof window.initCommonNotice === 'function') window.initCommonNotice();
        }

        if (target === 'download') {
            if (typeof window.mountTransportResourceArchivePanel === 'function') window.mountTransportResourceArchivePanel();
            else if (typeof window.initResourceArchive === 'function') window.initResourceArchive();
        }

        if (target === 'cs') {
            if (typeof window.mountTransportFaqPanel === 'function') window.mountTransportFaqPanel();
            else if (typeof window.initCommonFaq === 'function') window.initCommonFaq();
        }
    }, 0);
}

function bootMypageTab(itemId) {
    const target = itemId === 'TACS-MY-002' ? 'alarm' : 'profile';
    setTimeout(function () {
        if (window.TacsMyPage && typeof window.TacsMyPage.init === 'function') {
            window.TacsMyPage.init();
        }
        if (window.TacsMyPage && typeof window.TacsMyPage.syncTab === 'function') {
            window.TacsMyPage.syncTab(target);
        }
    }, 0);
}

function readExportRequestFromButton(btn) {
    const requestNo = btn && btn.dataset ? btn.dataset.requestNo || '' : '';
    selectedExportRequest = {
        requestNo: requestNo,
        receiptDate: btn.dataset.receiptDate || '',
        shipperName: btn.dataset.shipperName || '',
        shipperContact: btn.dataset.shipperContact || '',
        shipperPhone: btn.dataset.shipperPhone || '',
        shipperEmail: btn.dataset.shipperEmail || '',
        consigneeName: btn.dataset.consigneeName || '',
        consigneeCountry: btn.dataset.consigneeCountry || '',
        consigneeAddress: btn.dataset.consigneeAddress || '',
        consigneePhone: btn.dataset.consigneePhone || '',
        origin: btn.dataset.origin || '',
        destination: btn.dataset.destination || '',
        transportMode: btn.dataset.transportMode || '',
        transportType: btn.dataset.transportType || '',
        tradeTerm: btn.dataset.tradeTerm || '',
        requestNote: btn.dataset.requestNote || '',
        requestFile: btn.dataset.requestFile || '',
        invoiceFile: btn.dataset.invoiceFile || '',
        packingListFile: btn.dataset.packingListFile || '',
        receiptStatus: exportRequestStatusOverrides[requestNo] || btn.dataset.receiptStatus || '접수대기',
        rejectReason: exportRequestRejectReasons[requestNo] || btn.dataset.rejectReason || ''
    };
    window.selectedExportRequest = selectedExportRequest;
}

function readImportRequestFromButton(btn) {
    const requestNo = btn && btn.dataset ? btn.dataset.requestNo || '' : '';
    selectedImportRequest = {
        requestNo: requestNo,
        receiptDate: btn.dataset.receiptDate || '',
        shipperName: btn.dataset.shipperName || btn.dataset.shipper || '',
        shipperContact: btn.dataset.shipperContact || btn.dataset.manager || '',
        shipperPhone: btn.dataset.shipperPhone || btn.dataset.phone || '',
        shipperEmail: btn.dataset.shipperEmail || '',
        consignorName: btn.dataset.consignorName || '',
        consignorCountry: btn.dataset.consignorCountry || '',
        consignorAddress: btn.dataset.consignorAddress || '',
        consignorPhone: btn.dataset.consignorPhone || '',
        carrierName: btn.dataset.carrierName || '',
        originPort: btn.dataset.originPort || btn.dataset.origin || '',
        destinationPort: btn.dataset.destinationPort || btn.dataset.destination || btn.dataset.dischargePort || '',
        transportMode: btn.dataset.transportMode || '',
        transportType: btn.dataset.transportType || '',
        transshipYn: btn.dataset.transshipYn || '',
        requestNote: btn.dataset.requestNote || '',
        blType: btn.dataset.blType || '',
        bondedWarehouse: btn.dataset.bondedWarehouse || btn.dataset.warehouse || '',
        importDeclNo: btn.dataset.importDeclNo || '',
        desiredDeliveryAt: btn.dataset.desiredDeliveryAt || '',
        containerSpec: btn.dataset.containerSpec || '',
        itemCategory: btn.dataset.itemCategory || btn.dataset.cargo || '',
        hblFile: btn.dataset.hblFile || '',
        invoiceFile: btn.dataset.invoiceFile || '',
        packingListFile: btn.dataset.packingListFile || '',
        receiptStatus: importRequestStatusOverrides[requestNo] || btn.dataset.receiptStatus || btn.dataset.status || '접수대기',
        rejectReason: importRequestRejectReasons[requestNo] || btn.dataset.rejectReason || ''
    };
    window.selectedImportRequest = selectedImportRequest;
}

function getCurrentExportRequestNo() {
    if (selectedExportRequest && selectedExportRequest.requestNo) return selectedExportRequest.requestNo;
    const body = getDetailBody();
    const acceptBtn = body ? qs('.export-request-accept-btn[data-request-no]', body) : null;
    if (acceptBtn && acceptBtn.dataset.requestNo) return acceptBtn.dataset.requestNo;
    const rejectBtn = body ? qs('.request-reject-btn[data-request-type="수출"][data-request-no]', body) : null;
    if (rejectBtn && rejectBtn.dataset.requestNo) return rejectBtn.dataset.requestNo;
    return '';
}

function getCurrentImportRequestNo() {
    if (selectedImportRequest && selectedImportRequest.requestNo) return selectedImportRequest.requestNo;
    const body = getDetailBody();
    const acceptBtn = body ? qs('.import-request-submit-btn[data-request-no]', body) : null;
    if (acceptBtn && acceptBtn.dataset.requestNo) return acceptBtn.dataset.requestNo;
    const rejectBtn = body ? qs('.request-reject-btn[data-request-type="수입"][data-request-no]', body) : null;
    if (rejectBtn && rejectBtn.dataset.requestNo) return rejectBtn.dataset.requestNo;
    return '';
}

function setExportRequestStatus(status, reason, requestNo) {
    const targetRequestNo = requestNo || getCurrentExportRequestNo();
    if (!targetRequestNo) return false;

    exportRequestStatusOverrides[targetRequestNo] = status;
    if (status === '접수반려') {
        exportRequestRejectReasons[targetRequestNo] = reason || '운송담당자가 화주에게 반려 처리했습니다.';
    } else {
        delete exportRequestRejectReasons[targetRequestNo];
    }

    if (selectedExportRequest && selectedExportRequest.requestNo === targetRequestNo) {
        selectedExportRequest.receiptStatus = status;
        selectedExportRequest.rejectReason = status === '접수반려' ? exportRequestRejectReasons[targetRequestNo] : '';
    }

    if (Array.isArray(window.TRANSPORT_EXPORT_REQUESTS)) {
        const request = window.TRANSPORT_EXPORT_REQUESTS.find(function (item) {
            return item && item.trcNo === targetRequestNo;
        });
        if (request) {
            request.statusCd = status;
            request.statusNm = status;
            request.rejectReason = status === '접수반려' ? exportRequestRejectReasons[targetRequestNo] : '';
            request.rejectMemo = status === '접수반려' ? reason || '' : '';
        }
    }

    return true;
}

function setImportRequestStatus(status, reason, requestNo) {
    const targetRequestNo = requestNo || getCurrentImportRequestNo();
    if (!targetRequestNo) return false;

    importRequestStatusOverrides[targetRequestNo] = status;
    if (status === '접수반려') {
        importRequestRejectReasons[targetRequestNo] = reason || '운송담당자가 화주에게 반려 처리했습니다.';
    } else {
        delete importRequestRejectReasons[targetRequestNo];
    }

    if (selectedImportRequest && selectedImportRequest.requestNo === targetRequestNo) {
        selectedImportRequest.receiptStatus = status;
        selectedImportRequest.rejectReason = status === '접수반려' ? importRequestRejectReasons[targetRequestNo] : '';
    }

    if (Array.isArray(window.TRANSPORT_IMPORT_REQUESTS)) {
        const request = window.TRANSPORT_IMPORT_REQUESTS.find(function (item) {
            return item && item.trcNo === targetRequestNo;
        });
        if (request) {
            request.statusCd = status;
            request.statusNm = status;
            request.rejectReason = status === '접수반려' ? importRequestRejectReasons[targetRequestNo] : '';
            request.rejectMemo = status === '접수반려' ? reason || '' : '';
        }
    }

    return true;
}

function postStatusToServer(type, requestNo, statusCd, rejectType, rejectMemo) {
    const params = new URLSearchParams();
    params.set('trcNo', requestNo || '');
    params.set('statusCd', statusCd || '');
    if (rejectType) params.set('rejectType', rejectType);
    if (rejectMemo) params.set('rejectMemo', rejectMemo);

    const headers = Object.assign({
        'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8'
    }, getCsrfHeaders());

    const url = getContextPath() + '/transport/' + type + '/request/status.do';

    return fetch(url, {
        method: 'POST',
        headers: headers,
        body: params.toString()
    })
        .then(function (response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.json();
        })
        .then(function (result) {
            if (!result || result.success !== true) throw new Error('status update failed');
            return result;
        });
}

function postExportStatusToServer(requestNo, statusCd, rejectType, rejectMemo) {
    return postStatusToServer('export', requestNo, statusCd, rejectType || '', rejectMemo || '');
}

function postImportStatusToServer(requestNo, statusCd, rejectType, rejectMemo) {
    return postStatusToServer('import', requestNo, statusCd, rejectType || '', rejectMemo || '');
}

function openRequestRejectModal(requestType, requestNo) {
    currentRejectContext = {
        groupKey: requestType === '수입' ? 'import' : 'export',
        itemId: requestType === '수입' ? 'TACS-FW-016' : 'TACS-FW-002',
        requestType: requestType,
        requestNo: requestNo || ''
    };
    window.currentRejectContext = currentRejectContext;

    const modal = qs('#rejectModal');
    const type = qs('#rejectType');
    if (type) type.value = requestType + ' 운송 의뢰 반려';

    if (modal) {
        const memo = qs('textarea', modal);
        if (memo) memo.value = '';
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }
}

function closeRejectModal() {
    const modal = qs('#rejectModal');
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
}

function getRejectReasonText() {
    const modal = qs('#rejectModal');
    const reasonSelect = modal ? qs('select', modal) : null;
    const memoField = modal ? qs('textarea', modal) : null;
    return [
        reasonSelect ? reasonSelect.value : '',
        memoField ? memoField.value.trim() : ''
    ].filter(Boolean).join(' / ') || '운송담당자가 화주에게 반려 처리했습니다.';
}

function getRejectPayload() {
    const modal = qs('#rejectModal');
    const reasonSelect = modal ? qs('select', modal) : null;
    const memoField = modal ? qs('textarea', modal) : null;

    return {
        rejectType: reasonSelect ? reasonSelect.value : '',
        rejectMemo: memoField ? memoField.value.trim() : '',
        reason: getRejectReasonText()
    };
}

function reopenRequestList(type) {
    if (type === 'import') {
        setTimeout(function () {
            openDetail('import', 'TACS-FW-016');
        }, 0);
        return;
    }
    setTimeout(function () {
        openDetail('export', 'TACS-FW-001');
    }, 0);
}

function handleTransportClick(event) {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const exportDetailBtn = target.closest('.export-request-detail-btn[data-request-no]');
    if (exportDetailBtn) {
        event.preventDefault();
        event.stopPropagation();
        if (event.stopImmediatePropagation) event.stopImmediatePropagation();
        readExportRequestFromButton(exportDetailBtn);
        if (typeof window.renderExportRequestDetailPage === 'function') {
            window.renderExportRequestDetailPage();
        } else {
            openDetail('export', 'TACS-FW-002');
        }
        return;
    }

    const importDetailBtn = target.closest('.import-request-detail-btn[data-request-no]');
    if (importDetailBtn) {
        event.preventDefault();
        event.stopPropagation();
        if (event.stopImmediatePropagation) event.stopImmediatePropagation();
        readImportRequestFromButton(importDetailBtn);
        openDetail('import', 'TACS-FW-016');
        return;
    }

    const exportAcceptBtn = target.closest('.export-request-accept-btn[data-request-no]');
    if (exportAcceptBtn) {
        event.preventDefault();
        event.stopPropagation();
        if (event.stopImmediatePropagation) event.stopImmediatePropagation();
        const requestNo = exportAcceptBtn.dataset.requestNo || getCurrentExportRequestNo();
        if (!requestNo) return;
        postExportStatusToServer(requestNo, 'ACCEPTED')
            .then(function () {
                setExportRequestStatus('접수완료', '', requestNo);
                alert('접수완료로 변경되었습니다.');
                reopenRequestList('export');
            })
            .catch(function (error) {
                console.error('수출 접수완료 업데이트 실패', error);
                alert('접수완료 처리 중 오류가 발생했습니다. ' + (error && error.message ? error.message : ''));
            });
        return;
    }

    const importAcceptBtn = target.closest('.import-request-submit-btn[data-request-no]');
    if (importAcceptBtn) {
        event.preventDefault();
        event.stopPropagation();
        if (event.stopImmediatePropagation) event.stopImmediatePropagation();
        const requestNo = importAcceptBtn.dataset.requestNo || getCurrentImportRequestNo();
        if (!requestNo) return;
        postImportStatusToServer(requestNo, 'ACCEPTED')
            .then(function () {
                setImportRequestStatus('접수완료', '', requestNo);
                alert('접수완료로 변경되었습니다.');
                reopenRequestList('import');
            })
            .catch(function (error) {
                console.error('수입 접수완료 업데이트 실패', error);
                alert('접수완료 처리 중 오류가 발생했습니다. ' + (error && error.message ? error.message : ''));
            });
        return;
    }

    const rejectBtn = target.closest('.request-reject-btn[data-request-type]');
    if (rejectBtn) {
        event.preventDefault();
        event.stopPropagation();
        if (event.stopImmediatePropagation) event.stopImmediatePropagation();
        const requestType = rejectBtn.dataset.requestType || (selectedImportRequest ? '수입' : '수출');
        const requestNo = rejectBtn.dataset.requestNo || (requestType === '수입' ? getCurrentImportRequestNo() : getCurrentExportRequestNo());
        openRequestRejectModal(requestType, requestNo);
        return;
    }

    if (target.closest('#rejectModalSave')) {
        event.preventDefault();
        event.stopPropagation();
        if (event.stopImmediatePropagation) event.stopImmediatePropagation();

        const payload = getRejectPayload();
        const ctx = currentRejectContext || {};

        if (ctx.requestType === '수입') {
            const requestNo = ctx.requestNo || getCurrentImportRequestNo();
            if (!requestNo) return;
            postImportStatusToServer(requestNo, 'REJECTED', payload.rejectType, payload.rejectMemo)
                .then(function () {
                    setImportRequestStatus('접수반려', payload.reason, requestNo);
                    alert('접수반려로 변경되었습니다.');
                    closeRejectModal();
                    reopenRequestList('import');
                })
                .catch(function (error) {
                    console.error('수입 접수반려 업데이트 실패', error);
                    alert('접수반려 처리 중 오류가 발생했습니다. ' + (error && error.message ? error.message : ''));
                });
            return;
        }

        if (ctx.requestType === '수출') {
            const requestNo = ctx.requestNo || getCurrentExportRequestNo();
            if (!requestNo) return;
            postExportStatusToServer(requestNo, 'REJECTED', payload.rejectType, payload.rejectMemo)
                .then(function () {
                    setExportRequestStatus('접수반려', payload.reason, requestNo);
                    alert('접수반려로 변경되었습니다.');
                    closeRejectModal();
                    reopenRequestList('export');
                })
                .catch(function (error) {
                    console.error('수출 접수반려 업데이트 실패', error);
                    alert('접수반려 처리 중 오류가 발생했습니다. ' + (error && error.message ? error.message : ''));
                });
        }
    }
}

function handleSidebarClick(event) {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const toggleBtn = target.closest('#sideNav .menu-toggle[data-group]');
    if (toggleBtn) {
        event.preventDefault();
        event.stopPropagation();
        if (event.stopImmediatePropagation) event.stopImmediatePropagation();
        const group = toggleBtn.dataset.group;
        toggleMenuGroup(group);
        return;
    }

    const link = target.closest('#sideNav a[data-group]');
    if (!link || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

    event.preventDefault();
    event.stopPropagation();
    if (event.stopImmediatePropagation) event.stopImmediatePropagation();

    const targetInfo = getTargetFromLink(link);
    if (targetInfo.group === 'dashboard' && window.location.pathname.indexOf('/transport/dashboard.do') === -1) {
        window.location.href = getContextPath() + '/transport/dashboard.do';
        return;
    }
    const href = (targetInfo.group === 'export' || targetInfo.group === 'import')
        ? makeUrl(targetInfo.group, targetInfo.item)
        : (link.dataset.url || makeUrl(targetInfo.group, targetInfo.item));

    if (targetInfo.group === 'export') {
        window.__TACS_TRANSPORT_USER_NAV = {
            group: 'export',
            item: targetInfo.item,
            ts: Date.now()
        };
    }

    if (targetInfo.group === 'import') {
        if (
            window.location.pathname.indexOf('/transport/import.do') > -1 &&
            (window.__TACS_IMPORT_UNIFIED_ROUTER || (window.TRANSPORT_PAGE_READY || {}).import === true) &&
            typeof window.openDetail === 'function'
        ) {
            window.__TACS_TRANSPORT_USER_NAV = {
                group: 'import',
                item: targetInfo.item,
                ts: Date.now()
            };
            window.openDetail('import', targetInfo.item);
            return;
        }
        if (isImportListItem(targetInfo.item)) {
            try {
                sessionStorage.setItem('TACS_IMPORT_TARGET_ITEM', targetInfo.item);
            } catch (e) {}
        }
        window.location.href = href;
        return;
    }

    if (targetInfo.group === 'mypage') {
        window.location.href = makeMypageUrl(targetInfo.item, href);
        return;
    }

    const current = window.TRANSPORT_INITIAL_VIEW || {};
    const replace = current.group === targetInfo.group && (current.item || '') === (targetInfo.item || '');

    navigate(targetInfo.group, targetInfo.item, href, replace);
}

function handlePopState(event) {
    const url = new URL(window.location.href);
    let group = 'dashboard';

    if (url.pathname.indexOf('/transport/export.do') > -1) group = 'export';
    else if (url.pathname.indexOf('/transport/import.do') > -1) group = 'import';
    else if (url.pathname.indexOf('/transport/docs/trash.do') > -1) group = 'docs';
    else if (url.pathname.indexOf('/transport/docs.do') > -1) group = 'docs';
    else if (url.pathname.indexOf('/transport/community.do') > -1) group = 'community';
    else if (url.pathname.indexOf('/transport/mypage.do') > -1) group = 'mypage';

    const state = event && event.state ? event.state : {};
    let item = state.group === group && state.item
        ? state.item
        : (url.pathname.indexOf('/transport/docs/trash.do') > -1 ? 'TACS-DC-002' : (url.searchParams.get('page') || (group === 'dashboard' ? '' : DEFAULT_ITEMS[group])));
    if (group === 'export' && url.searchParams.get('tab')) {
        const tab = url.searchParams.get('tab');
        item = tab === 'manifest' ? 'TACS-FW-011' : 'TACS-FW-001';
    }
    if (group === 'import' && url.searchParams.get('tab')) {
        const tab = url.searchParams.get('tab');
        item = Object.keys(IMPORT_ITEM_TABS).find(function (key) {
            return IMPORT_ITEM_TABS[key] === tab;
        }) || 'TACS-FW-015';
    }
    if (group === 'mypage') {
        item = url.searchParams.get('tab') === 'alarm' ? 'TACS-MY-002' : 'TACS-MY-001';
    }
    navigate(group, item, url.pathname + url.search, true);
}

function bootInitialTransportView() {
    if (initialTransportViewBooted) return;
    initialTransportViewBooted = true;

    const initial = window.TRANSPORT_INITIAL_VIEW || { group: 'dashboard', item: '' };
    const group = initial.group || 'dashboard';
    const item = initial.item || (group === 'dashboard' ? '' : DEFAULT_ITEMS[group]);

    if (!getDetailBody()) {
        initialTransportViewBooted = false;
        return;
    }

    if (group === 'dashboard') {
        showDashboard();
        return;
    }

    if (window.TRANSPORT_DEFER_PAGE_BOOT === true) {
        initialTransportViewBooted = false;
        return;
    }

    loadPageScript(group)
        .then(function () {
            openDetail(group, item);
        })
        .catch(function (error) {
            initialTransportViewBooted = false;
            console.error('initial transport view failed', error);
        });
}

function getStatusChipClass(label) {
    const value = String(label || '').trim();
    if (!value) return '';
    if (/(반려|실패|오류|불가)/.test(value)) return 'status-reject';
    if (/(대기|진행|요청|작성중|심사중)/.test(value)) return 'status-pending';
    return 'status-confirmed';
}

function buildStatusChip(label) {
    const value = String(label || '').trim();
    if (!value) return '';
    return '<span class="status-chip ' + getStatusChipClass(value) + '">' + escapeHtml(value) + '</span>';
}

function normalizeStatusChips(root) {
    const scope = root || document;
    const statusPattern = /^(접수대기|접수완료|접수반려|미확인|확인완료|반려|요청대기|승인완료|승인|발급완료|발급가능|발급대기|전달완료|배차대기|완료대기|배차완료|최종완료|픽업완료|미정산|정산완료|발행준비|작성대기|작성중|작성완료|제출완료|미작성|확인중|이상발견|미발송|발송완료|배송중|반출완료|인도완료|회신대기|전송완료|심사대기|심사중|심사완료)$/;

    qsa('td, span.info-chip, .status-host, .manifest-status-cell, .manifest-review-cell, .doc-status-cell, .request-status-cell, .do-status-cell, .current-status-cell, .bl-list-status-cell', scope).forEach(function (el) {
        if (!el || el.closest('button,input,select,textarea')) return;

        if (el.matches('span.info-chip')) {
            const value = (el.textContent || '').trim();
            if (statusPattern.test(value)) {
                el.classList.add('status-chip', getStatusChipClass(value));
            }
            return;
        }

        if (el.querySelector('.status-chip')) return;
        if (el.children && el.children.length > 0) return;

        const value = (el.textContent || '').trim();
        if (statusPattern.test(value)) {
            el.innerHTML = buildStatusChip(value);
        }
    });
}

function installStatusObserver() {
    normalizeStatusChips(document);

    const observer = new MutationObserver(function (mutations) {
        mutations.forEach(function (mutation) {
            mutation.addedNodes.forEach(function (node) {
                if (node && node.nodeType === 1) normalizeStatusChips(node);
            });
        });
    });

    if (document.body) {
        observer.observe(document.body, { childList: true, subtree: true });
    }
}

// 일부 페이지별 JS가 참조하는 기본 fallback 함수들이다.
function buildFields(fields, cols) {
    const list = Array.isArray(fields) ? fields : [];
    const columnCount = cols || 2;
    return '<div class="grid grid-cols-1 md:grid-cols-' + columnCount + ' gap-5">' +
        list.map(function (label) {
            return '<div>' + buildField(label) + '</div>';
        }).join('') +
        '</div>';
}

function buildField(label) {
    const safeLabel = escapeHtml(label || '');
    if ((label || '').indexOf('첨부') > -1) {
        return '<label class="field-label">' + safeLabel + '</label><input class="field-input" type="file" />';
    }
    if (/(요청사항|의견|사유|메모|설명|내용|특이사항|지원사항|메시지)/.test(label || '')) {
        return '<label class="field-label">' + safeLabel + '</label><textarea class="field-textarea h-28" placeholder="' + safeLabel + ' 입력"></textarea>';
    }
    if (/(일시|시간|ETA|ETD)/.test(label || '')) {
        return '<label class="field-label">' + safeLabel + '</label><input class="field-input" type="datetime-local" />';
    }
    if (/(일|기한|기간)/.test(label || '')) {
        return '<label class="field-label">' + safeLabel + '</label><input class="field-input" type="date" />';
    }
    if (/(수량|중량|부피|금액|비용|수수료|단가|총액)/.test(label || '')) {
        return '<label class="field-label">' + safeLabel + '</label><input class="field-input" type="number" placeholder="' + safeLabel + ' 입력" />';
    }
    return '<label class="field-label">' + safeLabel + '</label><input class="field-input" type="text" placeholder="' + safeLabel + ' 입력" />';
}

function typeLabel(type) {
    const labels = {
        lookup: '조회',
        form: '입력 폼',
        review: '검토',
        upload: '서류 수신',
        schedule: '일정/배차',
        checklist: '체크리스트',
        process: '처리',
        request: '요청',
        delivery: '전달',
        tracking: '실시간 조회',
        notify: '알림',
        cost: '정산',
        share: '공유'
    };
    return labels[type] || '업무';
}

function resolveActionButtonLabel(item, fallbackLabel) {
    const title = item && item.title ? item.title : '';
    if (/발송|통지/.test(title)) return '발송';
    if (/제출/.test(title)) return '제출';
    if (/저장|작성/.test(title)) return '저장';
    if (/반출|요청/.test(title)) return '요청';
    return fallbackLabel || '처리';
}

function bindCommonEvents() {
    document.addEventListener('click', handleSidebarClick, true);
    document.addEventListener('click', handleTransportClick, true);
    window.addEventListener('popstate', handlePopState);

    const rejectClose = qs('#rejectModalClose');
    const rejectCancel = qs('#rejectModalCancel');
    [rejectClose, rejectCancel].forEach(function (btn) {
        if (!btn || btn.dataset.commonBound === 'true') return;
        btn.dataset.commonBound = 'true';
        btn.addEventListener('click', closeRejectModal);
    });

    const rejectModal = qs('#rejectModal');
    if (rejectModal && rejectModal.dataset.commonBound !== 'true') {
        rejectModal.dataset.commonBound = 'true';
        rejectModal.addEventListener('click', function (event) {
            if (event.target === rejectModal) closeRejectModal();
        });
    }
}

function bootCommon() {
    bindCommonEvents();
    installStatusObserver();
    bootInitialTransportView();
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootCommon);
} else {
    bootCommon();
}

