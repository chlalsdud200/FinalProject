package kr.or.tacs.vo.broker;

/**
 * TACS_FILE_GRP + TACS_FILE_MAP + DOCS_FILE_DATA 조인 결과
 *  · 1 첨부파일 1 row
 *  · AI 파싱 시 PDF 파일 경로/타입 식별용
 */
public class TfgFileDto {

    /** DOCS_FILE_DATA.DFI_FILE_NO */
    private Long dfiFileNo;
    /** 원본 파일명 (예: invoice.pdf) */
    private String orgNm;
    /** 서버 저장 파일명 (UUID) */
    private String strNm;
    /** 저장 디렉토리 (DFI_PATH) */
    private String path;
    /** 확장자 (DFI_EXT — 예: pdf) */
    private String ext;
    /** 문서 타입 코드 (TFM_DOC_TY_CD — INVOICE/PACKING_LIST/BL/PHYTO/ETC) */
    private String docTyCd;

    /** 풀 파일 경로 — 디렉토리 + 저장명 조합 */
    public String getFullPath() {
        if (path == null || strNm == null) return null;
        String sep = path.endsWith("/") || path.endsWith("\\") ? "" : java.io.File.separator;
        return path + sep + strNm;
    }

    public Long getDfiFileNo() { return dfiFileNo; }
    public void setDfiFileNo(Long dfiFileNo) { this.dfiFileNo = dfiFileNo; }
    public String getOrgNm() { return orgNm; }
    public void setOrgNm(String orgNm) { this.orgNm = orgNm; }
    public String getStrNm() { return strNm; }
    public void setStrNm(String strNm) { this.strNm = strNm; }
    public String getPath() { return path; }
    public void setPath(String path) { this.path = path; }
    public String getExt() { return ext; }
    public void setExt(String ext) { this.ext = ext; }
    public String getDocTyCd() { return docTyCd; }
    public void setDocTyCd(String docTyCd) { this.docTyCd = docTyCd; }
}
