@charset "UTF-8";

/* dashboard.css - 대시보드 전용 CSS */

#page-dashboard {
  width: 100% !important;
}

#page-dashboard.page-section:not(.active) {
  display: none !important;
}

#page-dashboard.page-section.active {
  display: block !important;
  padding-top: 28px !important;
}

/* 상단 안내 */
#page-dashboard .dashboard-head {
  margin: 0 0 30px 0 !important;
  padding: 0 !important;
  background: transparent !important;
  border: 0 !important;
  max-width: 760px !important;
}

#page-dashboard .dashboard-kicker {
  margin: 0 0 8px 0 !important;
  font-size: 10px !important;
  line-height: 1.3 !important;
  font-weight: 900 !important;
  color: #243b60 !important;
  letter-spacing: -0.01em !important;
}

#page-dashboard .dashboard-head h1 {
  margin: 0 0 14px 0 !important;
  font-size: 24px !important;
  line-height: 1.25 !important;
  font-weight: 900 !important;
  color: #0f172a !important;
  letter-spacing: -0.04em !important;
}

#page-dashboard .dashboard-desc {
  margin: 0 !important;
  max-width: 720px !important;
  font-size: 13px !important;
  line-height: 1.7 !important;
  color: #64748b !important;
  word-break: keep-all !important;
}

/* 상단 업무 카드 */
.dashboard-stat-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14px;
  margin-bottom: 24px;
}

.dashboard-stat-card {
  background: #fff;
  border: 1px solid #d9eafc;
  border-left: 4px solid #565e74;
  padding: 18px 18px 17px;
  min-height: 112px;
  cursor: pointer;
  transition: background .15s, border-color .15s, transform .15s;
}

.dashboard-stat-card:hover {
  background: #f8fbff;
  border-color: #bdd3ee;
  transform: translateY(-1px);
}

/* 카드별 왼쪽 강조선 색상 */
.dashboard-stat-card:nth-child(1) { border-left-color: #64748b; } /* 접수대기 - 회색 */
.dashboard-stat-card:nth-child(2) { border-left-color: #2563eb; } /* 심사중 - 파랑 */
.dashboard-stat-card:nth-child(3) { border-left-color: #d97706; } /* 보완요청 - 주황 */
.dashboard-stat-card:nth-child(4) { border-left-color: #16a34a; } /* 납부대기 - 초록 */

.stat-label {
  display: block;
  margin-bottom: 8px;
  font-size: 12px;
  font-weight: 900;
  color: #536178;
}

.dashboard-stat-card strong {
  display: block;
  font-size: 30px;
  line-height: 1;
  font-weight: 900;
  color: #0f172a;
  letter-spacing: -0.04em;
}

.stat-sub {
  display: block;
  margin-top: 10px;
  font-size: 12px;
  line-height: 1.45;
  color: #64748b;
  word-break: keep-all;
}

/* 레이아웃 */
.dashboard-layout {
  display: grid;
  gap: 22px;
  margin-bottom: 24px;
}

.dashboard-layout-top {
  grid-template-columns: 1fr;
}

.dashboard-card {
  background: #fff;
  border: 1px solid #d9eafc;
  border-left: 4px solid #565e74;
  padding: 20px 24px;
  min-width: 0;
}

.dashboard-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 16px;
}

.dashboard-card-head.compact {
  align-items: center;
}

.dashboard-card-head h2 {
  margin: 0;
  font-size: 18px;
  font-weight: 900;
  letter-spacing: -0.02em;
  color: #0f172a;
}

.dashboard-card-head h2::before {
  display: none !important;
}

.dashboard-card-head p {
  margin: 7px 0 0;
  font-size: 13px;
  line-height: 1.6;
  color: #64748b;
  word-break: keep-all;
}

.dashboard-head-tag {
  flex: 0 0 auto;
  font-size: 13px;
  font-weight: 900;
  color: #64748b;
  white-space: nowrap;
}

/* 버튼 */
#page-dashboard button {
  font-weight: 900 !important;
}

.dash-link-btn {
  height: 32px;
  padding: 0 12px;
  border: 1px solid #aebbd0;
  background: #fff;
  color: #0f172a;
  font-size: 12px;
  font-weight: 900;
  cursor: pointer;
  white-space: nowrap;
}

.dash-link-btn:hover {
  background: #ecf4ff;
  border-color: #8ca2bd;
}

/* 내 미처리 건 카드 */
.my-task-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.my-task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 4px;
  border-bottom: 1px solid #d9eafc;
  cursor: pointer;
  transition: background .12s;
  border-radius: 4px;
}

.my-task-item:last-child {
  border-bottom: none;
}

.my-task-item:hover {
  background: #f0f7ff;
}

.my-task-left {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.my-task-dot {
  flex-shrink: 0;
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.dot-blue   { background: #2563eb; }
.dot-orange { background: #d97706; }
.dot-green  { background: #16a34a; }

.my-task-label {
  font-size: 14px;
  font-weight: 900;
  color: #0f172a;
  white-space: nowrap;
}

.my-task-sub {
  font-size: 12px;
  color: #94a3b8;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.my-task-right {
  display: flex;
  align-items: baseline;
  gap: 2px;
  flex-shrink: 0;
  margin-left: 12px;
}

.my-task-count {
  font-size: 24px;
  font-weight: 900;
  color: #0f172a;
  letter-spacing: -0.04em;
  line-height: 1;
}

.my-task-unit {
  font-size: 13px;
  color: #64748b;
  font-weight: 700;
}

.my-task-notice {
  margin: 14px 0 0;
  font-size: 11px;
  color: #94a3b8;
  text-align: center;
  line-height: 1.5;
}

#page-dashboard .btn-sm {
  height: 32px !important;
  min-width: 64px !important;
  padding: 0 12px !important;
  border: 1px solid #cbd5e1 !important;
  background: #fff !important;
  color: #334155 !important;
  font-size: 12px !important;
  font-weight: 900 !important;
  cursor: pointer;
}

#page-dashboard .btn-sm:hover {
  background: #ecf4ff !important;
  border-color: #a0b4c8 !important;
}

/* 테이블 */
.dashboard-table-wrap {
  width: 100%;
  overflow-x: auto;
  border-top: 1px solid #d9eafc;
}

.dashboard-table {
  width: 100%;
  min-width: 650px;
  border-collapse: collapse;
  background: #fff;
}

.dashboard-table-small {
  min-width: 540px;
}

.dashboard-table thead tr {
  background: #ecf4ff;
}

.dashboard-table th {
  padding: 10px 12px !important;
  border-bottom: 2px solid #d9eafc;
  color: #334155 !important;
  font-size: 13px !important;
  font-weight: 900 !important;
  text-align: left;
  white-space: nowrap;
  letter-spacing: 0 !important;
  text-transform: none !important;
}

.dashboard-table td {
  padding: 13px 12px !important;
  border-bottom: 1px solid #d9eafc;
  font-size: 13px !important;
  color: #203444;
  vertical-align: middle;
}

.dashboard-table tbody tr[data-href] {
  cursor: pointer;
}

.dashboard-table tbody tr:hover {
  background: #f8fbff;
}

.dashboard-empty {
  height: 90px;
  text-align: center !important;
  color: #94a3b8 !important;
  font-weight: 400 !important;
  background: #fff;
  vertical-align: middle;
}

.dashboard-empty .empty-icon {
  display: block;
  font-size: 20px;
  margin-bottom: 6px;
  line-height: 1;
}

.dashboard-empty .empty-msg {
  display: block;
  font-size: 13px;
  color: #94a3b8;
}

/* NEW / 상태 */
.new-line-badge {
  display: inline-flex;
  align-items: center;
  margin-right: 8px;
  padding: 2px 7px;
  border: 1px solid #fca5a5;
  border-radius: 999px;
  background: transparent;
  color: #fb0000;
  font-size: 10px;
  font-weight: 900;
  line-height: 1.2;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 62px;
  height: 24px;
  padding: 0 9px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 900;
  border: 1px solid #cbd5e1;
  background: #fff;
}

.status-blue {
  color: #1e3a8a;
  border-color: #bfdbfe;
  background: #eff6ff;
}

.status-warn {
  color: #92400e;
  border-color: #fde68a;
  background: #fffbeb;
}

/* 신규 신고접수 테이블 컬럼 비율 */
.dashboard-table-receipt {
  table-layout: fixed;
}

.dashboard-table-receipt th:nth-child(1),
.dashboard-table-receipt td:nth-child(1) {
  width: 27%;
}

.dashboard-table-receipt th:nth-child(2),
.dashboard-table-receipt td:nth-child(2) {
  width: 10%;
}

.dashboard-table-receipt th:nth-child(3),
.dashboard-table-receipt td:nth-child(3) {
  width: 17%;
}

.dashboard-table-receipt th:nth-child(4),
.dashboard-table-receipt td:nth-child(4) {
  width: 18%;
}

.dashboard-table-receipt th:nth-child(5),
.dashboard-table-receipt td:nth-child(5) {
  width: 18%;
}

.dashboard-table-receipt th:nth-child(6),
.dashboard-table-receipt td:nth-child(6) {
  width: 10%;
}

/* 반응형 */
@media (max-width: 1280px) {
  .dashboard-stat-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .dashboard-layout-top {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 760px) {
  .dashboard-stat-grid {
    grid-template-columns: 1fr;
  }

  .my-task-sub {
    display: none;
  }

  .dashboard-card {
    padding: 18px;
  }

  .dashboard-card-head {
    display: block;
  }

  .dash-link-btn {
    margin-top: 12px;
  }
}