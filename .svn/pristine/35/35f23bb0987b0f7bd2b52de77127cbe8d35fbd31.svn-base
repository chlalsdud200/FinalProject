<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib uri="jakarta.tags.core" prefix="c" %>
<%@ taglib uri="jakarta.tags.fmt" prefix="fmt" %>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>보세재고 통합 조회 - TACS</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet"/>

    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/base.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/sidebar.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/topbar.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/inventory.css">
</head>
<body>
<div class="app" id="app">

    <!-- Sidebar -->
    <jsp:include page="/WEB-INF/views/warehouse/common/sidebar.jsp" />

    <!-- Main Wrapper -->
    <div class="main-wrap">

        <!-- Header -->
        <jsp:include page="/WEB-INF/views/warehouse/common/header.jsp" />

        <!-- Content -->
        <div class="content">

            <div class="page-title-row">
                <h2>보세재고 통합 조회</h2>

                <div class="btn-row">
                    <button class="btn btn-outline" onclick="toggle3DView()" id="btn-3d-toggle">
                        <span class="material-symbols-outlined">3d_rotation</span>
                        3D 창고 보기
                    </button>
                </div>
            </div>

			<!-- 구역별 적재 현황 카드 -->
			<div class="zone-status-grid">
			    <c:choose>
			        <c:when test="${empty zoneStatusList}">
			            <div class="zone-status-empty">
			                창고 구역 적재 현황이 없습니다.
			            </div>
			        </c:when>
			
			        <c:otherwise>
			            <c:forEach var="zone" items="${zoneStatusList}">
			                <div class="zone-status-card">
			                    <div class="zone-status-top">
			                        <div>
			                            <div class="zone-status-name">${zone.wzNm}</div>
			                            <div class="zone-status-no">${zone.wzNo}</div>
			                        </div>
			
			                        <div class="zone-status-rate">
			                            <fmt:formatNumber value="${zone.wzUseRt}" pattern="0.##"/>%
			                        </div>
			                    </div>
			
			                    <div class="zone-progress">
			                        <div class="zone-progress-bar"
			                             style="width: ${zone.wzUseRt}%;">
			                        </div>
			                    </div>
			
			                    <div class="zone-status-bottom">
								    <span>
								        사용 <fmt:formatNumber value="${zone.wzUseCapa}" pattern="#,##0"/>칸
								    </span>
								    <span>
								        전체 <fmt:formatNumber value="${zone.wzTtlCapa}" pattern="#,##0"/>칸
								    </span>
								</div>
			                </div>
			            </c:forEach>
			        </c:otherwise>
			    </c:choose>
			</div>

            <!-- 창고 보관 현황 목록 -->
            <div class="card-section" id="inventory-2d-view">
                <div class="card-header">
                    <h3>창고 보관 현황</h3>
                </div>

                <form class="inventory-search-panel"
                      method="get"
                      action="${pageContext.request.contextPath}/warehouse/inventory.do">

                    <div class="search-row">
                        <div class="form-item">
                            <label>보관 구역</label>
                            <select id="inventoryZone" name="zone">
                                <option value="">전체 구역</option>
                                <option value="GENERAL">일반 보관 구역</option>
                                <option value="COLD">냉동·냉장 보관 구역</option>
                                <option value="DANGER">위험물 보관 구역</option>
                            </select>
                        </div>

                        <div class="form-item">
                            <label>조회 기간</label>
                            <div class="date-range">
                                <input type="date" id="startDate" name="startDate">
									<span>~</span>
								<input type="date" id="endDate" name="endDate">
                            </div>
                        </div>

	            <div class="form-item search-item">
				    <label>검색어</label>
				    <div class="search-wrap">
				        <span class="search-icon material-symbols-outlined">search</span>
				        <input id="inventoryKeyword"
						       name="keyword"
						       class="keyword-input"
						       placeholder="입고의뢰번호, 물품명, 창고구역번호, 보관위치 검색">
				    </div>
				</div>
                        <button type="button" id="inventorySearchBtn" class="btn btn-dark inventory-search-btn">
                            <span class="material-symbols-outlined">manage_search</span>
                            재고 검색
                        </button>
                    </div>
                </form>

                <div class="inventory-table-wrap">
                    <table class="inventory-table">
                        <thead>
                            <tr>
                            	<th class="col-no">NO</th>
							    <th>입고의뢰번호</th>
							    <th>물품명</th>
							    <th>창고구역번호</th>
							    <th>유형</th>
							    <th>보관위치</th>
							    <th>위치반입일시</th>
							    <th>위치반출일시</th>
							    <th>상태</th>
							</tr>
                        </thead>

                        <tbody id="inventoryTableBody">
	                        <c:choose>
	                        	<c:when test="${empty inventoryList }">
	                        		<tr>
		                                <td colspan="9" class="empty-table-result">
		                                    조회하신 재고가 없습니다.
		                                </td>
		                            </tr>
	                        	</c:when>
	                        	<c:otherwise>
	                        		<c:forEach var="item" items="${inventoryList}" varStatus="status">
	                        			<tr>
	                        			
	                        			<td class="td-no">${status.index + 1 }</td>
									    <!-- 입고의뢰번호 -->
									    <td>${item.wirNo}</td>
									
									    <!-- 물품명 -->
									    <td>${item.goodsName}</td>
									
									    <!-- 창고구역번호 -->
									    <td>${item.wilWhZoneNo}</td>
									
									    <!-- 유형: 수입/수출 -->
									    <td>
									        <span class="inventory-badge ${item.wirIoSeCd == 'IMP' ? 'type-import' : 'type-export'}">
									            ${item.wirIoSeNm}
									        </span>
									    </td>
									
									    <!-- 보관위치 -->
									    <td>${item.locationCode}</td>
									
									    <td>${item.wilInDt}</td>

										<td>
										    <c:choose>
										        <c:when test="${not empty item.wilOutDt}">
										            ${item.wilOutDt}
										        </c:when>
										        <c:otherwise>-</c:otherwise>
										    </c:choose>
										</td>
									
									    <!-- 상태 -->
									    <td>
									        <c:choose>
											    <c:when test="${item.wiStatusNm eq '반출완료' or not empty item.wilOutDt}">
											        <span class="inventory-badge status-out-done">
											            ${item.wiStatusNm}
											        </span>
											    </c:when>
											
											    <c:when test="${item.wiStatusCd eq 'IN_DONE' or item.wiStatusNm eq '입고완료' or item.wiStatusNm eq '보관중'}">
											        <span class="inventory-badge status-in-done">
											            ${item.wiStatusNm}
											        </span>
											    </c:when>
											
											    <c:when test="${item.wiStatusNm eq '반려'}">
											        <span class="inventory-badge status-reject">
											            ${item.wiStatusNm}
											        </span>
											    </c:when>
											
											    <c:otherwise>
											        <span class="inventory-badge status-wait">
											            ${item.wiStatusNm}
											        </span>
											    </c:otherwise>
											</c:choose>
									    </td>
									</tr>
	                        		</c:forEach>
	                        	</c:otherwise>
	                        </c:choose>
                            
                        </tbody>
                    </table>
                    <div id="inventoryPagination" class="inventory-pagination"></div>
                </div>
            </div>

            <!-- 3D 창고 시각화 -->
			<div class="card-section" id="inventory-3d-view">
			    <div class="card-header">
			        <h3>3D 창고 시각화</h3>
			
			        <!-- iframe 전체화면 버튼: React 내부가 아니라 JSP 카드 헤더에 배치 -->
			        <button type="button"
			                class="btn btn-outline"
			                onclick="toggle3DIframeFullscreen()"
			                style="padding:6px 12px; font-size:12px;">
			            전체 화면
			        </button>
			    </div>

                <div class="wh3d-wrap">
                  <iframe id="wh3d-frame" src="about:blank" allow="fullscreen" allowfullscreen></iframe>

                    <div id="wh3d-overlay">
                        <div class="wh3d-message-box">
                            <div class="wh3d-title">3D 창고 화면 연결 중</div>

                            <div id="wh3d-status" class="wh3d-status">
                                로컬 3D 서버를 확인하고 있습니다. 기본 주소: http://localhost:5173/
                            </div>

                            <div class="wh3d-btn-row">
                                <button type="button" class="btn btn-outline" onclick="retry3DConnect()">
                                    다시 연결
                                </button>
                                <button type="button" class="btn btn-dark" onclick="open3DInNewTab()">
                                    새 탭에서 열기
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Footer -->
        <jsp:include page="/WEB-INF/views/warehouse/common/footer.jsp" />

    </div>
</div>

<script src="${pageContext.request.contextPath}/resources/js/warehouse/common.js"></script>
<script src="${pageContext.request.contextPath}/resources/js/warehouse/navigation.js"></script>
<script src="${pageContext.request.contextPath}/resources/js/warehouse/inventory.js"></script>
</body>
</html>
