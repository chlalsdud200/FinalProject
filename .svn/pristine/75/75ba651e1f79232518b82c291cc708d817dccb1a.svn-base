(function () {
  if (window.__tacsResourceArchiveLoaded) return;
  window.__tacsResourceArchiveLoaded = true;
  function contextPath() {
    var wrap = document.querySelector('.resource-archive-wrap');
    if (wrap && wrap.getAttribute('data-context-path') !== null) {
      return wrap.getAttribute('data-context-path');
    }
    var meta = document.querySelector('meta[name="ctx-path"]');
    if (meta) return meta.getAttribute('content') || '';
    return window.contextPath || '';
  }

  function formatSize(size) {
    if (size === null || size === undefined || size === '') return '-';
    var n = Number(size);
    if (Number.isNaN(n)) return '-';
    if (n < 1024) return n + ' B';
    if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KB';
    return (n / 1024 / 1024).toFixed(1) + ' MB';
  }

  function escapeHtml(value) {
    return String(value || '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function buildQuery() {
    var params = new URLSearchParams();
    var docTyCd = document.getElementById('res-archive-doc-ty')?.value || 'all';
    var keyword = document.getElementById('res-archive-keyword')?.value || '';
    var fromDate = document.getElementById('res-archive-from')?.value || '';
    var toDate = document.getElementById('res-archive-to')?.value || '';

    params.set('docTyCd', docTyCd);
    if (keyword) params.set('keyword', keyword);
    if (fromDate) params.set('fromDate', fromDate);
    if (toDate) params.set('toDate', toDate);
    return params.toString();
  }

  function render(list) {
    var tbody = document.getElementById('res-archive-tbody');
    if (!tbody) return;

    if (!list || list.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="resource-archive-empty">조회된 자료가 없습니다.</td></tr>';
      return;
    }

    tbody.innerHTML = list.map(function (item) {
      return ''
        + '<tr>'
        + '<td><strong>' + escapeHtml(item.resTtl) + '</strong><div class="resource-archive-desc">' + escapeHtml(item.resCn || '') + '</div></td>'
        + '<td>' + escapeHtml(item.docTyNm || item.docTyCd || '기타') + '</td>'
        + '<td>' + escapeHtml(item.orgFileName || '-') + '</td>'
        + '<td>' + formatSize(item.fileSize) + '</td>'
        + '<td>' + escapeHtml(item.resRegDt || '') + '</td>'
        + '<td><button type="button" class="resource-archive-download" data-res-no="' + item.resNo + '" data-file-no="' + item.fileNo + '">다운로드</button></td>'
        + '</tr>';
    }).join('');
  }

  async function load() {
    var tbody = document.getElementById('res-archive-tbody');
    if (tbody) {
      tbody.innerHTML = '<tr><td colspan="6" class="resource-archive-empty">자료를 조회 중입니다.</td></tr>';
    }

    try {
      var response = await fetch(contextPath() + '/resource/archive/list.do?' + buildQuery(), {
        headers: { 'Accept': 'application/json' }
      });

      if (!response.ok) {
        if (tbody) {
          tbody.innerHTML = '<tr><td colspan="6" class="resource-archive-empty">자료 조회 중 오류가 발생했습니다.</td></tr>';
        }
        return;
      }

      render(await response.json());
    } catch (e) {
      if (tbody) {
        tbody.innerHTML = '<tr><td colspan="6" class="resource-archive-empty">자료 조회 중 오류가 발생했습니다.</td></tr>';
      }
    }
  }

  function bind() {
    var searchBtn = document.getElementById('res-archive-search-btn');
    if (searchBtn && !searchBtn.dataset.bound) {
      searchBtn.dataset.bound = '1';
      searchBtn.addEventListener('click', load);
    }

    var keyword = document.getElementById('res-archive-keyword');
    if (keyword && !keyword.dataset.bound) {
      keyword.dataset.bound = '1';
      keyword.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') load();
      });
    }

    if (!document.documentElement.dataset.resourceArchiveDownloadBound) {
      document.documentElement.dataset.resourceArchiveDownloadBound = '1';
      document.addEventListener('click', function (e) {
        var btn = e.target.closest('.resource-archive-download');
        if (!btn) return;
        var resNo = btn.getAttribute('data-res-no');
        var fileNo = btn.getAttribute('data-file-no');
        window.location.href = contextPath() + '/resource/archive/download.do?resNo=' + encodeURIComponent(resNo) + '&fileNo=' + encodeURIComponent(fileNo);
      });
    }
  }

  window.TacsResourceArchive = {
    load: load,
    bind: bind
  };

  document.addEventListener('DOMContentLoaded', function () {
    bind();
    load();
  });
})();
