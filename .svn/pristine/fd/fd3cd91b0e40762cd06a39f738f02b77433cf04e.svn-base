@charset "UTF-8";

* {
    box-sizing: border-box;
}

:root {
    --icon-w: 34px;
    --input-w: 260px;
    --button-w: 78px;
    --gap: 8px;
    --col-gap: 22px;
    --field-w: calc(var(--icon-w) + var(--gap) + var(--input-w));
    --field-button-w: calc(var(--icon-w) + var(--gap) + var(--input-w) + var(--gap) + var(--button-w));
    --left-two-col-w: calc((var(--field-button-w) * 2) + var(--col-gap));

    --second-col-offset: 0px;
    --password-input-w: 260px;
    --ident-input-w: 260px;
    --ident-front-input-w: var(--password-input-w);
    --ident-hyphen-w: calc(var(--col-gap) + var(--icon-w));
    --biz-input-w: 260px;
    --corp-input-w: 260px;
    --auth-input-w: 174px;
    --address-wide-input-w: 672px;
    --email-local-left-trim: 10px;
    --email-domain-input-w: 174px;
    --email-domain-select-w: var(--button-w);
}

html,
body {
    min-height: 100%;
    margin: 0;
    font-family: "Inter", "Noto Sans KR", sans-serif;
    overflow-x: hidden;
    overflow-y: auto;
    background: #f8fafc;
}

.hidden {
    display: none !important;
}

.material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
}

.page-bg {
    position: fixed;
    inset: 0;
    overflow: hidden;
}

.page-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.03);
}

.page-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, rgba(5, 10, 20, 0.76) 0%, rgba(10, 23, 46, 0.56) 30%, rgba(248, 250, 252, 0.30) 100%);
}

.page-wrap {
    position: relative;
    z-index: 2;
    min-height: 100vh;
}

.page-shell {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 376px minmax(1060px, 1fr);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(16px);
}

.left-pane {
    position: relative;
    padding: 30px;
    color: #ffffff;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-right: 1px solid rgba(255, 255, 255, 0.10);
}

.logo-wrap,
.left-badge,
.back-link,
.section-head,
.field-row,
.agreement-row,
.agree-left,
.submit-row {
    display: flex;
    align-items: center;
}

.logo-wrap {
    gap: 11px;
}

.logo-box {
    width: 42px;
    height: 42px;
    border-radius: 13px;
    background: rgba(214, 227, 255, 0.96);
    display: flex;
    align-items: center;
    justify-content: center;
}

.left-badge {
    gap: 7px;
    width: fit-content;
    margin-top: 16px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.10);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #d9e8ff;
}

.left-title {
    font-size: 28px;
    font-weight: 900;
    line-height: 1.08;
    margin: 18px 0 8px;
}

.left-desc {
    font-size: 13px;
    line-height: 1.52;
    color: rgba(226, 232, 240, 0.92);
}

.left-panel {
    border-radius: 18px;
    padding: 22px;
    background: rgba(5, 10, 20, 0.31);
    border: 1px solid rgba(255, 255, 255, 0.10);
    backdrop-filter: blur(12px);
}

.left-panel h3 {
    margin: 0 0 10px;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #d9e8ff;
}

.left-panel ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 7px;
}

.left-panel li {
    display: flex;
    gap: 8px;
    font-size: 11px;
    line-height: 1.42;
    color: rgba(226, 232, 240, 0.93);
}

.left-panel li strong {
    min-width: 18px;
    color: #b8d0ff;
    font-weight: 900;
}

.terms-panel {
    max-height: 46vh;
    overflow-y: auto;
    padding-right: 6px;
}

.terms-block {
    padding: 10px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.11);
}

.terms-block:first-of-type {
    border-top: 0;
    padding-top: 0;
}

.terms-block h4 {
    margin: 0 0 5px;
    font-size: 12px;
    font-weight: 900;
    color: #ffffff;
}

.terms-block p {
    margin: 0;
    font-size: 11px;
    line-height: 1.55;
    color: rgba(226, 232, 240, 0.90);
}

.terms-close-btn {
    margin-top: 10px;
    width: 100%;
    height: 32px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.10);
    color: #ffffff;
    font-size: 11px;
    font-weight: 900;
    cursor: pointer;
}

.right-pane {
    height: 100vh;
    min-height: 0;
    padding: 14px 38px 10px;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(12px);
    display: flex;
    flex-direction: column;
    overflow-y: hidden;
}

.right-head {
    display: none;
}

.right-head h2 {
    margin: 0;
    font-size: 25px;
    font-weight: 900;
    color: #0f172a;
    line-height: 1.05;
}

.right-head p {
    margin: 2px 0 0;
    font-size: 12px;
    color: #5b6472;
    font-weight: 700;
}

.back-link {
    gap: 4px;
    font-size: 12px;
    font-weight: 900;
    color: #0b2348;
    text-decoration: none;
    white-space: nowrap;
}

.compact-form {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
}

.form-section {
    padding: 22px 0 27px;
    border-bottom: 1px solid #dde5ef;
}

.form-section + .form-section {
    margin-top: 10px;
}

.form-section:first-of-type {
    padding-top: 4px;
}

.form-section:last-of-type {
    border-bottom: 0;
}

.section-head {
    gap: 8px;
    min-height: 30px;
    margin-bottom: 14px;
}

.section-head-icon {
    width: 30px;
    min-width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0f172a;
}

.section-head-icon .material-symbols-outlined {
    font-size: 19px;
}

.section-head-title {
    font-size: 14px;
    font-weight: 900;
    color: #0f172a;
    line-height: 30px;
}

.grid-12 {
    display: grid;
    gap: 18px 20px;
}

.account-grid {
    grid-template-columns: var(--field-button-w) var(--field-w) var(--field-w);
    column-gap: var(--col-gap);
    align-items: start;
}

.owner-basic-grid {
    grid-template-columns: var(--field-button-w) var(--field-w) var(--field-w);
    column-gap: var(--col-gap);
    row-gap: 0;
    align-items: start;
}

.contact-grid {
    width: 100%;
    grid-template-columns: var(--field-button-w) var(--field-w) minmax(360px, 1fr);
    column-gap: var(--col-gap);
    row-gap: 10px;
    align-items: start;
}

.account-id-field,
.contact-phone-field {
    grid-column: 1;
}

.account-pw-field,
#identNoBox,
#bizNoBox,
.contact-auth-field {
    grid-column: 2;
    margin-left: var(--second-col-offset);
}

.account-pw-confirm-field,
#corpRegNoBox {
    grid-column: 3;
}

.email-field,
.address-fields {
    grid-column: 1 / span 2;
    width: var(--left-two-col-w);
    max-width: var(--left-two-col-w);
}

.email-field {
    grid-row: 2;
}

.address-fields {
    grid-row: 3;
    display: grid;
    gap: 8px;
}

.contact-map-field {
    grid-column: 3;
    grid-row: 1 / span 3;
    min-width: 0;
    align-self: stretch;
}

.field-label {
    display: flex;
    align-items: center;
    min-height: 16px;
    margin-bottom: 5px;
    color: #1e293b;
    font-size: 12px;
    font-weight: 900;
    gap: 6px;
}

.field-feedback {
    font-size: 10px;
    font-weight: 900;
}

.field-feedback.ok {
    color: #16794c;
}

.field-feedback.error {
    color: #ba1a1a;
}

.required {
    color: #ba1a1a;
}

.field-row {
    gap: var(--gap);
    min-width: 0;
}

.icon-box,
.input-box,
.side-btn {
    height: 32px;
}

.icon-box {
    width: var(--icon-w);
    min-width: var(--icon-w);
    border-radius: 10px;
    background: #eef3f8;
    color: #0b2348;
    display: flex;
    align-items: center;
    justify-content: center;
}

.icon-box .material-symbols-outlined {
    font-size: 18px;
}

.input-box {
    min-width: 0;
    border: 1px solid #cfd8e5;
    border-radius: 10px;
    background: #ffffff;
    color: #0f172a;
    font-size: 12px;
    font-weight: 800;
    outline: none;
    padding: 0 11px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
}

.input-box:focus {
    border-color: #0b2348;
    box-shadow: 0 0 0 3px rgba(11, 35, 72, 0.10);
}

.input-box.readonly {
    background: #f8fafc;
    color: #334155;
}

.input-box::placeholder {
    color: #94a3b8;
    font-size: 12px;
    font-weight: 700;
}

.side-btn {
    width: var(--button-w);
    min-width: var(--button-w);
    flex: 0 0 var(--button-w);
    padding: 0;
    border: 0;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 900;
    cursor: pointer;
}

.btn-dark {
    background: #0b2348;
    color: #ffffff;
}

.btn-light {
    background: #e8edf4;
    color: #0b2348;
}

.account-id-field .input-box,
.owner-basic-grid > .span-3:first-child .input-box,
.contact-phone-field .input-box,
.address-fields > div:first-child .input-box {
    width: var(--input-w);
    flex: 0 0 var(--input-w);
}

.account-pw-field .password-input-wrap {
    width: var(--password-input-w);
    flex: 0 0 var(--password-input-w);
}

.account-pw-confirm-field .password-input-wrap {
    width: var(--input-w);
    flex: 0 0 var(--input-w);
}

#identNoBox {
    grid-column: 2 / span 2;
}

.ident-no-row {
    gap: var(--gap);
}

.ident-front-input {
    width: var(--ident-front-input-w);
    flex: 0 0 var(--ident-front-input-w);
}

.ident-hyphen {
    width: var(--ident-hyphen-w);
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #475569;
    font-size: 14px;
    font-weight: 900;
}

.ident-back-wrap {
    position: relative;
    width: var(--input-w);
    flex: 0 0 var(--input-w);
    display: flex;
    align-items: center;
    padding: 0 34px 0 11px;
}

.ident-back-first,
.ident-back-rest {
    height: 100%;
    border: 0;
    outline: 0;
    background: transparent;
    color: #0f172a;
    font-size: 12px;
    font-weight: 800;
}

.ident-back-first {
    width: 18px;
    flex: 0 0 18px;
    padding: 0;
}

.ident-back-rest {
    flex: 1 1 auto;
    min-width: 0;
    padding: 0;
    letter-spacing: 2px;
}

.ident-back-first::placeholder,
.ident-back-rest::placeholder {
    color: #94a3b8;
    font-size: 12px;
    font-weight: 700;
}

#bizNoBox .input-box {
    width: var(--biz-input-w);
    flex: 0 0 var(--biz-input-w);
}

#corpRegNoBox .input-box {
    width: var(--corp-input-w);
    flex: 0 0 var(--corp-input-w);
}

.contact-auth-field .input-box {
    width: var(--auth-input-w);
    flex: 0 0 var(--auth-input-w);
}

.password-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0 34px 0 11px;
}

.password-input {
    width: 100%;
    height: 100%;
    border: 0;
    outline: 0;
    background: transparent;
    color: #0f172a;
    font-size: 12px;
    font-weight: 800;
}

.password-input::placeholder {
    color: #94a3b8;
    font-size: 12px;
    font-weight: 700;
}

.password-toggle {
    position: absolute;
    right: 7px;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 24px;
    border: 0;
    border-radius: 8px;
    background: transparent;
    color: #64748b;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
}

.password-toggle .material-symbols-outlined {
    font-size: 18px;
}

.owner-type-field {
    margin-left: 24px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.owner-type-field .field-label {
    margin: 0;
    white-space: nowrap;
}

.owner-type-row {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 28px;
}

.owner-type-option {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 28px;
    padding: 0 10px;
    border: 1px solid #dde5ef;
    border-radius: 999px;
    background: #f8fafc;
    color: #475569;
    font-size: 11px;
    font-weight: 900;
    cursor: pointer;
    user-select: none;
}

.owner-type-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
}

.owner-type-option:has(input:checked) {
    border-color: #0b2348;
    background: #0b2348;
    color: #ffffff;
}

.email-row {
    width: var(--left-two-col-w);
    display: grid;
    grid-template-columns:
        var(--icon-w)
        354px
        70px
        var(--email-domain-input-w)
        var(--email-domain-select-w);
    gap: 0px;
    align-items: center;
}

.email-local {
    width: calc(100% - var(--email-local-left-trim));
    justify-self: end;
}

.email-domain {
    width: var(--email-domain-input-w);
}
.email-at {
    margin-right: -18px;
}
.email-at {
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #475569;
    font-size: 13px;
    font-weight: 900;
}

.email-at,
.email-domain {
    transform: translateX(-4px);
}

.email-select {
    display: block;
    width: var(--email-domain-select-w);
    margin-left: 4px;
    cursor: pointer;
}

.address-fields .field-row {
    width: var(--left-two-col-w);
}

.address-fields > div:not(:first-child) .input-box {
    width: var(--address-wide-input-w);
    flex: 0 0 var(--address-wide-input-w);
}

.address-map {
    position: relative;
    width: 100%;
    height: 326px;
    min-width: 0;
    border-radius: 14px;
    border: 1px solid #cfd8e5;
    overflow: hidden;
    background: #e8edf4;
}

#kakaoAddressMap {
    position: absolute;
    inset: 0;
    z-index: 1;
}

.address-map-placeholder {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 20px;
    text-align: center;
    color: #64748b;
    background: linear-gradient(135deg, #f8fafc, #e8edf4);
}

.address-map-placeholder.hidden {
    display: none !important;
}

.address-map-title {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #0b2348;
    font-size: 13px;
    font-weight: 900;
}

.address-map-text {
    max-width: 280px;
    font-size: 12px;
    line-height: 1.45;
    font-weight: 800;
}

.agreement-section {
    margin-top: 30px;
    padding-top: 18px;
    padding-bottom: 8px;
}

.agreement-row {
    justify-content: space-between;
    gap: 14px;
}

.agree-left {
    gap: 9px;
    color: #334155;
    font-size: 12px;
    font-weight: 800;
}

.agree-left input {
    width: 17px;
    height: 17px;
    accent-color: #0b2348;
}

.terms-view-btn {
    margin-top: 8px;
    height: 28px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid #cfd8e5;
    background: #f8fafc;
    color: #0b2348;
    font-size: 11px;
    font-weight: 900;
    cursor: pointer;
}

.submit-row {
    justify-content: flex-end;
    gap: 8px;
    margin-top: 12px;
    padding: 12px 0 8px;
    flex-shrink: 0;
}

.submit-btn {
    height: 34px;
    min-width: 128px;
    padding: 0 16px;
    border: 0;
    border-radius: 12px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 900;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    text-decoration: none;
}

.submit-primary {
    background: #0b2348;
    color: #ffffff;
}

.submit-primary:disabled {
    background: #cbd5e1;
    color: #64748b;
    cursor: not-allowed;
}

.submit-secondary {
    background: #e8edf4;
    color: #0b2348;
}

@media (max-width: 1280px) {
    html,
    body {
        overflow-y: auto;
    }

    .page-shell {
        min-height: 100vh;
        grid-template-columns: 1fr;
    }

    .left-pane {
        min-height: auto;
        padding: 24px;
        gap: 20px;
    }

    .right-pane {
        height: auto;
        min-height: auto;
        padding: 24px;
        overflow: visible;
    }

    .account-grid,
    .owner-basic-grid,
    .contact-grid {
        grid-template-columns: 1fr;
    }

    .account-id-field,
    .account-pw-field,
    .account-pw-confirm-field,
    #identNoBox,
    #bizNoBox,
    #corpRegNoBox,
    .contact-phone-field,
    .contact-auth-field,
    .email-field,
    .address-fields,
    .contact-map-field {
        grid-column: 1;
        grid-row: auto;
        margin-left: 0;
        width: 100%;
        max-width: 100%;
    }

    .field-row,
    .email-row,
    .address-fields .field-row {
        width: 100%;
    }

    .email-row {
        grid-template-columns: var(--icon-w) minmax(0, 1fr) 18px minmax(0, 1fr);
    }

    .input-box,
    .password-input-wrap,
    .account-id-field .input-box,
    .account-pw-field .password-input-wrap,
    .account-pw-confirm-field .password-input-wrap,
    #identNoBox .input-box,
    #bizNoBox .input-box,
    #corpRegNoBox .input-box,
    .contact-phone-field .input-box,
    .contact-auth-field .input-box,
    .address-fields > div:first-child .input-box,
    .address-fields > div:not(:first-child) .input-box {
        width: 100%;
        flex: 1 1 auto;
    }

    .owner-type-field {
        margin-left: 0;
        flex-wrap: wrap;
    }

    .section-head {
        flex-wrap: wrap;
    }
}
