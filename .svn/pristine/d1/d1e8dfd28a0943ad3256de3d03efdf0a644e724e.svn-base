<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fn" uri="jakarta.tags.functions" %>
<c:set var="ctx" value="${pageContext.request.contextPath}" />

<c:set var="vIrNo" value="${not empty applyVO.iirAplyNo ? applyVO.iirAplyNo : applyVO.irNo}" />

<!DOCTYPE html>
<html lang="ko">
<head>
    <%@ include file="/WEB-INF/views/broker/common/meta.jsp" %>

    <link rel="stylesheet" href="${ctx}/resources/css/broker/common.css">
    <link rel="stylesheet" href="${ctx}/resources/css/broker/pages/quarantine.css">

    <title>수입검역신청 | TACS</title>
</head>

<body>
<div class="app" id="app">

    <%@ include file="/WEB-INF/views/broker/common/sidebar.jsp" %>

    <div class="main-wrap">

        <%@ include file="/WEB-INF/views/broker/common/header.jsp" %>

        <div class="content">

            <div class="page active" id="pg-quarantine">

                <div class="sub-page">


                    <!-- 검역관리 탭 -->
                    <div class="sub-tabs" id="tabs-qu">
                        <a class="sub-tab ${activeSub eq 'result' ? 'active' : ''}"
                           href="${ctx}/broker/quarantine/result.do">검역결과조회</a>

                        <a class="sub-tab ${activeSub eq 'import' ? 'active' : ''}"
                           href="${ctx}/broker/quarantine/import.do">수입검역신청</a>

                        <a class="sub-tab ${activeSub eq 'export' ? 'active' : ''}"
                           href="${ctx}/broker/quarantine/export.do">수출검역신청</a>
                    </div>

                    <!-- ===== 수입검역신청 ===== -->
                    <div id="qu-import">

                        <div class="qu-section-head">
                            <h3>
                                <span class="material-symbols-outlined">assignment_add</span>
                                수입검역신청
                            </h3>

                            <button type="button"
                                    class="btn btn-outline"
                                    onclick="openImportRqstModal()">
                                <span class="material-symbols-outlined" style="font-size:16px;">search</span>
                                수입의뢰 조회
                            </button>
                        </div>

                        <c:if test="${not empty errorMsg}">
                            <div class="alert-bar danger">
                                <span class="material-symbols-outlined" style="font-size:18px">error</span>
                                ${errorMsg}
                            </div>
                        </c:if>

                        <c:if test="${not empty successMsg}">
                            <div class="alert-bar success">
                                <span class="material-symbols-outlined" style="font-size:18px">check_circle</span>
                                ${successMsg}
                            </div>
                        </c:if>

                        <form id="quImportForm"
                              action="${ctx}/broker/quarantine/import/apply.do"
                              method="post"
                              enctype="multipart/form-data"
                              onsubmit="return validateQuarantineForm();">

                            <c:if test="${not empty _csrf}">
                                <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}" />
                            </c:if>

                            <!-- 수입통관의뢰번호 바인딩 -->
                            <input type="hidden" name="iirAplyNo" id="selectedIrNo" value="${vIrNo}">
                            <input type="hidden" name="irNo" value="${vIrNo}">

                            <!-- 1. 신청 기본정보 -->
                            <div class="qu-form-card mb-4">
                                <h4>1. 신청 기본정보</h4>

                                <div class="qu-form-grid">

                                    <div>
                                        <label>수입통관의뢰번호</label>
                                        <input type="text"
                                               value="${empty vIrNo ? '수입의뢰를 선택하세요' : vIrNo}"
                                               readonly>
                                    </div>

                                    <div>
                                        <label>수입자명</label>
                                        <input type="text"
                                               value="${empty applyVO.importerNm ? applyVO.idImprNm : applyVO.importerNm}"
                                               readonly>
                                    </div>

                                </div>
                            </div>
                            
                            <!-- 2. 첨부문서 -->
							<div class="qu-form-card mb-4">
							    <div class="flex-between" style="margin-bottom:12px;">
							        <h4 style="margin-bottom:0;">2. 첨부문서</h4>
							
							        <button type="button" id="aiFillBtn" class="btn-ai-fill" onclick="autoFillFromAttachedPdf()">
									    <span class="material-symbols-outlined">auto_awesome</span>
									    첨부문서 자동입력
									</button>
							    </div>
							
							    <div class="alert-bar">
							        <span class="material-symbols-outlined" style="font-size:18px;">description</span>
							        식물검역증명서, Invoice, Packing List, B/L 등 관련 문서를 첨부한 뒤 자동입력을 실행하세요.
							    </div>
							
							    <div class="qu-attach-box" id="quAttachBox" ondragover="handleQuAttachDragOver(event)"
							         ondragleave="handleQuAttachDragLeave(event)" ondrop="handleQuAttachDrop(event)"
							         style="border:2px dashed #cbd5e1; padding:24px; text-align:center; background:#f8fafc;">
							
							        <span class="material-symbols-outlined"
							              style="font-size:36px; color:#64748b;">upload_file</span>
							
							        <div style="font-size:13px; font-weight:700; color:#334155; margin-top:8px;">
							            첨부파일을 드래그하거나 선택하세요.
							        </div>
							
							        <div style="font-size:12px; color:#64748b; margin-top:4px;">
							            PDF, JPG, PNG, XLSX, DOCX 파일 첨부 가능
							        </div>
							
							        <input type="file" id="quAttachFiles" name="attachFiles" multiple style="display:none;" onchange="handleQuAttachFiles(this.files)">
							
							        <button type="button" class="btn btn-outline" style="margin-top:12px;" onclick="document.getElementById('quAttachFiles').click();">
									    파일 선택
									</button>
									
									<div id="quAttachFileList" class="qu-attach-file-list"></div>
									</div>
							</div>
                            

                            <!-- 3. 수출자 및 공급자 정보 -->
							<div class="qu-form-card mb-4">
							    <h4>3. 수출자 및 공급자 정보</h4>
							
							    <div class="qu-form-grid">
							
							        <!-- 1행: 수출자/공급자명 / 수출자 회사명 -->
							        <div>
							            <label>수출자/공급자명</label>
										<input type="text" name="iirExporterNm" value="${applyVO.iirExporterNm}" placeholder="수출자명을 입력하세요">
							        </div>
							
							        <div>
							            <label>수출자 회사명</label>
							            <input type="text" name="iirExporterCompanyNm"
							                   value="${applyVO.iirExporterCompanyNm}"
							                   placeholder="수출자 회사명을 입력하세요">
							        </div>
							
							        <!-- 2행: 수출국 / 수출자 주소 -->
							        <div>
							            <label>수출국</label>
							            <input type="text" name="iirExportCountryCd"
									       	   value="${empty applyVO.iirExportCountryCd ? applyVO.idShipoutCntryCd : applyVO.iirExportCountryCd}"
									           maxlength="2" style="text-transform:uppercase;"  placeholder="예: US, CN, JP">
							        </div>
							
							        <div>
							            <label>수출자 주소</label>
							            <input type="text"
							                   name="iirExporterAdres"
							                   value="${applyVO.iirExporterAdres}"
							                   placeholder="수출자 주소를 입력하세요">
							        </div>
							
							        <!-- 3행: 식물검역증명서 번호 / 식물검역증명서 발급일 -->
							        <div>
							            <label>식물검역증명서 번호</label>
							            <input type="text"
							                   name="iirPhytoCertNo"
							                   value="${applyVO.iirPhytoCertNo}"
							                   placeholder="증명서 번호를 입력하세요">
							        </div>
							
							        <div>
							            <label>식물검역증명서 발급일</label>
							            <input type="date"
							                   name="iirPhytoCertIssueDt"
							                   value="${applyVO.iirPhytoCertIssueDt}">
							        </div>
							    </div>
							</div>


                            <!-- 4. 운송 및 입항 정보 -->
							<div class="qu-form-card mb-4">
							    <h4>4. 운송 및 입항 정보</h4>
							
							    <div class="qu-form-grid">
							
							        <!-- 1행: B/L 또는 AWB 번호 / 운송수단명 -->
							        <div>
							            <label>B/L 또는 AWB 번호</label>
							            <input type="text"
							                   value="${applyVO.irBlAwbNo}"
							                   readonly>
							        </div>
							
							        <div>
							            <label>운송수단명</label>
							            
							            <input type="hidden" name="iirTransportTypeCd" value="${empty applyVO.iirTransportTypeCd ? applyVO.idTrnspMnCd : applyVO.iirTransportTypeCd}">
							            
							            <input type="text" name="iirTransportNm" value="${applyVO.iirTransportNm}" placeholder="예: 선박명, 항공편명">
							        </div>
							
							        <!-- 2행: 선적항 / 도착항 -->
							        <div>
							            <label>선적항</label>
							            <input type="text"
							                   name="iirLoadPortCd"
							                   value="${applyVO.iirLoadPortCd}"
							                   placeholder="예: 상하이항, LA항">
							        </div>
							
							        <div>
							            <label>도착항</label>
							            <input type="text"
							                   name="iirArrvPortCd"
							                   value="${empty applyVO.iirArrvPortCd ? applyVO.irArrvPortCd : applyVO.iirArrvPortCd}"
							                   placeholder="예: 부산항, 인천항">
							        </div>
							
							        <!-- 3행: 선적일 / 도착일 -->
							        <div>
							            <label>선적일</label>
							            <input type="date"
							                   name="iirShipDt"
							                   value="${applyVO.iirShipDt}">
							        </div>
							
							        <div>
							            <label>도착일</label>
							            <input type="date"
							                   name="iirArrvDt"
							                   value="${empty applyVO.iirArrvDt ? applyVO.irArrvSchdYmd : applyVO.iirArrvDt}">
							        </div>
							    </div>
							</div>
                            

                            <!-- 5. 대표 품목 및 포장 정보 -->
							<div class="qu-form-card mb-4">
							    <h4>5. 대표 품목 및 포장 정보</h4>
							
							    <div class="qu-form-grid">
							
							        <!-- 1행: 대표 물품 정보 -->
							        <div>
							            <label>대표 검역대상 물품명</label>
							            <input type="text"
							                   name="iirMainGoodsNm"
							                   value="${empty applyVO.iirMainGoodsNm ? applyVO.idiDclrGdsnm : applyVO.iirMainGoodsNm}"
							                   placeholder="예: 냉동망고, 쌀, 목재 팔렛">
							        </div>
							
							        <div>
							            <label>대표 HS Code</label>
							            <input type="text"
							                   name="iirMainHsCd"
							                   value="${empty applyVO.iirMainHsCd ? applyVO.idiHsCd : applyVO.iirMainHsCd}"
							                   placeholder="예: 0804.50.0000">
							        </div>
							
							        <!-- 2행: 중량 / 포장 개수 -->
							        <div>
							            <label>전체 총중량</label>
							            <input type="number"
							                   step="0.001"
							                   name="iirTotalWeight"
							                   value="${empty applyVO.iirTotalWeight ? applyVO.idTotWt : applyVO.iirTotalWeight}"
							                   placeholder="예: 2500.500">
							        </div>
							
							        <div>
							            <label>전체 포장 개수</label>
							            <input type="number"
							                   name="iirTotalPkgCnt"
							                   value="${empty applyVO.iirTotalPkgCnt ? applyVO.idTotPkgCnt : applyVO.iirTotalPkgCnt}"
							                   placeholder="예: 120">
							        </div>
							
							        <!-- 3행: 포장 단위 / 포장재질 -->
							        <div>
							            <label>포장 단위</label>
							            <input type="text"
							                   name="iirPkgUnitCd"
							                   value="${applyVO.iirPkgUnitCd}"
							                   placeholder="예: BOX, CT, BAG">
							        </div>
							
							        <div>
							            <label>포장재질</label>
							            <input type="text"
							                   name="iirPkgMaterial"
							                   value="${applyVO.iirPkgMaterial}"
							                   placeholder="예: 박스, 포대, 팔렛">
							        </div>
							
							        <!-- 4행: 목재포장재 -->
							        <div>
							            <label class="required-label">목재포장재 사용 여부</label>
							            <select name="iirWoodPkgYn">
							                <option value="">선택</option>
							                <option value="Y" ${applyVO.iirWoodPkgYn eq 'Y' ? 'selected' : ''}>사용</option>
							                <option value="N" ${applyVO.iirWoodPkgYn eq 'N' ? 'selected' : ''}>미사용</option>
							            </select>
							        </div>
							
							        <div>
							            <label class="required-label">목재포장재 표시/인증번호</label>
							            <input type="text"
							                   name="iirWoodPkgMarkNo"
							                   value="${applyVO.iirWoodPkgMarkNo}"
							                   placeholder="예: KR-000 HT, MB 등">
							        </div>
							    </div>
							</div>
							
								<!-- 6. 검역기관 및 담당자 선택 -->
								<div class="qu-form-card mb-4">
								    <h4>6. 검역기관 및 담당자 선택</h4>
								
								    <div class="qu-form-grid">
								
								        <div class="full">
								            <label class="required-label">검역기관 / 담당 현장공무원</label>
								
								            <!--
								                iirQrtnOfficerId
								                - 관세사가 선택한 현장공무원 ID
								                - IMP_INS_REQ.IIR_QRTN_OFFICER_ID에 저장된다.
								
								                화면 표시:
								                - officerName : 기관명 또는 검역소명
								                - officerNm   : 현장공무원명
								                - officerInstCd: 소속기관 코드
								            -->
								            <select name="iirQrtnOfficerId" id="iirQrtnOfficerId">
								                <option value="">검역기관 및 담당자를 선택하세요</option>
								
								                <c:forEach var="officer" items="${fieldOfficerList}">
								                    <option value="${officer.officerId}"
								                            ${applyVO.iirQrtnOfficerId eq officer.officerId ? 'selected' : ''}>
								                        ${officer.officerName} / ${officer.officerNm} (${officer.officerInstCd})
								                    </option>
								                </c:forEach>
								            </select>
								
								            <div style="font-size:12px; color:#64748b; margin-top:6px;">
								                선택한 현장공무원에게 수입검역요청이 배정됩니다.
								            </div>
								        </div>
								
								    </div>
								</div>

                                <!-- 7. 검역 위치 정보 -->
								<div class="qu-form-card mb-4">
								    <h4>7. 검역 위치 정보</h4>
								
								    <div class="qu-form-grid">
								
								        <!-- 창고 위치번호: IMP_INS_LOC.IIL_WIL_NO에 저장됨 -->
								        <input type="hidden"
								               name="iilWilNo"
								               id="iilWilNo"
								               value="${applyVO.iilWilNo}">
								
								        <!-- 검역장소유형: 보세창고로 고정 -->
								        <input type="hidden"
								               name="iilTyCd"
								               id="iilTyCd"
								               value="${empty applyVO.iilTyCd ? 'BONDED_WH' : applyVO.iilTyCd}">
								
								        <div>
								            <label>검역장소유형</label>
								            <input type="text"
								                   value="보세창고"
								                   readonly>
								        </div>
								
								        <div>
								            <label class="required-label">검역장소명</label>
								
								            <select name="iilNm"
								                    id="iilNm"
								                    onchange="setQuarantineLocationInfo(this);">
								                <option value="">검역장소를 선택하세요</option>
								
								                <c:forEach var="loc" items="${warehouseLocationList}">
								                    <option value="${loc.iilNm}"
								                            data-wil-no="${loc.iilWilNo}"
								                            data-ty-cd="${loc.iilTyCd}"
								                            data-zip="${loc.iilZip}"
								                            data-adres="${loc.iilAdres}"
								                            data-detail-adres="${loc.iilDetailAdres}"
								                            ${applyVO.iilWilNo eq loc.iilWilNo ? 'selected' : ''}>
								                        ${loc.iilNm}
								                    </option>
								                </c:forEach>
								            </select>
								        </div>
								
								        <div>
								            <label class="required-label">검역 예정 일시</label>
								            <input type="datetime-local"
								                   name="iilPlanDt"
								                   value="${applyVO.iilPlanDt}">
								        </div>
								
								        <div>
								            <label>우편번호</label>
								            <input type="text"
								                   name="iilZip"
								                   id="iilZip"
								                   value="${applyVO.iilZip}"
								                   readonly
								                   placeholder="창고 우편번호">
								        </div>
								
								        <div>
								            <label>기본주소</label>
								            <input type="text"
								                   name="iilAdres"
								                   id="iilAdres"
								                   value="${applyVO.iilAdres}"
								                   readonly
								                   placeholder="창고 기본주소">
								        </div>
								
								        <div>
								            <label>상세주소</label>
								            <input type="text"
								                   name="iilDetailAdres"
								                   id="iilDetailAdres"
								                   value="${applyVO.iilDetailAdres}"
								                   readonly
								                   placeholder="창고 상세주소">
								        </div>
								
								        <div class="full">
								            <label class="required-label">검역 요청 사유</label>
								            <textarea name="iirRsnCn"
								                      rows="4"
								                      placeholder="검역 요청 사유를 입력하세요. 예: 수입 식물류 검역 대상 물품으로 검역 신청합니다.">${applyVO.iirRsnCn}</textarea>
								        </div>
								    </div>
								</div>

                            <!-- 8. 검역대상 품목 -->
                            <div class="qu-form-card mb-4">
                                <div class="flex-between" style="margin-bottom:12px;">
                                    <h4 style="margin-bottom:0;">8. 검역대상 품목</h4>

                                    <button type="button"
                                            class="btn btn-outline"
                                            onclick="addQuarantineItem()">
                                        <span class="material-symbols-outlined" style="font-size:16px;">add</span>
                                        품목 추가
                                    </button>
                                </div>

                                <div style="overflow-x:auto; border:1px solid #e2e8f0; border-top:2px solid #334155;">
                                    <table class="data-table" style="width:100%; margin-top:0; min-width:980px;">
                                        <thead style="background:#ecf4ff;">
										<tr>
										    <th style="width:120px;">HS코드 <span class="req">*</span></th>
										    <th style="width:180px;">품명 <span class="req">*</span></th>
										    <th style="width:100px;">용도 <span class="req">*</span></th>
										    <th style="width:100px;">수량 <span class="req">*</span></th>
										    <th style="width:100px;">수량단위 <span class="req">*</span></th>
										    <th style="width:100px;">순중량 <span class="req">*</span></th>
										    <th style="width:100px;">포장개수 <span class="req">*</span></th>
										    <th style="width:100px;">원산지 <span class="req">*</span></th>
										    <th style="width:60px;">삭제</th>
										</tr>
										</thead>

                                        <tbody id="quarantineItemBody">
                                        <tr class="quarantine-item-row">
                                            <td>
                                                <input type="text"
                                                       name="itemList[0].hsCd"
                                                       value="${applyVO.idiHsCd}"
                                                       placeholder="HS코드">
                                            </td>

                                            <td>
                                                <input type="text"
                                                       name="itemList[0].goodsNm"
                                                       value="${applyVO.idiDclrGdsnm}"
                                                       placeholder="품명">
                                            </td>

                                            <td>
                                                <input type="text"
                                                       name="itemList[0].useCd"
                                                       placeholder="용도">
                                            </td>

                                            <td>
                                                <input type="number"
                                                       step="0.001"
                                                       name="itemList[0].qty"
                                                       value="${applyVO.idiQty}"
                                                       placeholder="수량">
                                            </td>

                                            <td>
                                                <input type="text"
                                                       name="itemList[0].qtyUnitCd"
                                                       value="${applyVO.idiQtyUnitCd}"
                                                       placeholder="단위">
                                            </td>

                                            <td>
                                                <input type="number"
                                                       step="0.001"
                                                       name="itemList[0].netWeight"
                                                       value="${applyVO.idiNetWt}"
                                                       placeholder="순중량">
                                            </td>

                                            <td>
                                                <input type="number"
                                                       name="itemList[0].pkgCnt"
                                                       placeholder="포장개수">
                                            </td>

                                            <td>
                                                <input type="text"
                                                       name="itemList[0].originCountryCd"
                                                       value="${applyVO.idiOrgnCntryCd}"
                                                       placeholder="예: US">
                                            </td>

                                            <td style="text-align:center;">
                                                <button type="button"
                                                        class="qu-trash-btn"
                                                        onclick="removeQuarantineItem(this)"
                                                        title="삭제">
                                                    <span class="material-symbols-outlined">delete</span>
                                                </button>
                                            </td>
                                        </tr>
                                        </tbody>
                                    </table>
	                            </div>
	                          </div>

                            <!-- 버튼 -->
                            <div class="btn-row" style="justify-content:flex-end; gap:8px;">
                                <button type="button"
                                        class="btn btn-secondary"
                                        onclick="location.href='${ctx}/broker/quarantine/result.do'">
                                    취소
                                </button>

                                <button type="submit"
                                        class="btn btn-primary"
                                        style="background:#565e74;">
                                    <span class="material-symbols-outlined" style="font-size:16px;">send</span>
                                    검역신청 전송
                                </button>
                            </div>

                        </form>
                        
                        <!-- 첨부문서 자동입력 로딩 오버레이 -->
						<div id="aiFillLoadingOverlay" class="ai-fill-loading-overlay" style="display:none;">
						    <div class="ai-fill-loading-box">
						
						        <div class="ai-fill-loading-title">
						            첨부문서 자동입력 중입니다
						        </div>
						
						        <div class="ai-fill-loading-text" id="aiFillLoadingText">
						            PDF 문서를 분석하고 있습니다.
						        </div>
						
						        <div class="ai-fill-progress-wrap">
						            <div class="ai-fill-progress-bar" id="aiFillProgressBar"></div>
						        </div>
						
						        <div class="ai-fill-progress-percent" id="aiFillProgressPercent">
						            0%
						        </div>						
						    </div>
						</div>

                    </div>
                    <!-- /#qu-import -->

                </div>
                <!-- /.sub-page -->

            </div>
            <!-- /.page -->

        </div>
        <!-- /.content -->

    </div>
    <!-- /.main-wrap -->

</div>
<!-- /.app -->


<!-- 수입의뢰 조회 모달 -->
<div class="modal-bg" id="importRqstModal">
    <div class="modal-box" style="width:900px; max-width:95vw;">

        <h3>
            <span class="material-symbols-outlined">search</span>
            수입의뢰 조회
        </h3>

        <button type="button"
                class="modal-close"
                onclick="closeImportRqstModal()">
            ×
        </button>

        <div style="margin-top:20px;">

            <div class="alert-bar success">
                <span class="material-symbols-outlined" style="font-size:18px;">info</span>
                검역신청할 수입통관의뢰를 선택하세요.
            </div>

            <div style="overflow-x:auto; border:1px solid #e2e8f0; border-top:2px solid #334155;">
                <table class="data-table" style="width:100%; margin-top:0; min-width:820px;">
                    <thead style="background:#ecf4ff;">
                    <tr>
                        <th style="width:140px;">수입의뢰번호</th>
                        <th style="width:120px;">수입자명</th>
                        <th style="width:160px;">품명</th>
                        <th style="width:100px;">HS코드</th>
                        <th style="width:120px;">B/L 번호</th>
                        <th style="width:100px;">도착항</th>
                        <th style="width:100px;">선택</th>
                    </tr>
                    </thead>

                    <tbody>
                    <c:choose>
                        <c:when test="${empty candidateList}">
                            <tr>
                                <td colspan="7" style="text-align:center; color:#697d8f; padding:24px;">
                                    검역신청 가능한 수입의뢰가 없습니다.
                                </td>
                            </tr>
                        </c:when>

                        <c:otherwise>
                            <c:forEach var="row" items="${candidateList}">
                                <tr>
                                    <td class="td-id">${row.irNo}</td>
                                    <td>${empty row.importerNm ? row.idImprNm : row.importerNm}</td>
                                    <td>${row.idiDclrGdsnm}</td>
                                    <td>${row.idiHsCd}</td>
                                    <td>${row.irBlAwbNo}</td>
                                    <td>${row.irArrvPortCd}</td>
                                    <td>
                                        <a class="mini mini-view"
                                           href="${ctx}/broker/quarantine/import.do?irNo=${row.irNo}">
                                            선택
                                        </a>
                                    </td>
                                </tr>
                            </c:forEach>
                        </c:otherwise>
                    </c:choose>
                    </tbody>
                </table>
            </div>

            <div class="btn-row" style="justify-content:flex-end; margin-top:16px;">
                <button type="button"
                        class="btn btn-secondary"
                        onclick="closeImportRqstModal()">
                    닫기
                </button>
            </div>

        </div>
    </div>
</div>


<%@ include file="/WEB-INF/views/broker/common/modals.jsp" %>

<script>
    window.contextPath = '${ctx}';
</script>

<script src="${ctx}/resources/js/broker/common.js"></script>
<script src="${ctx}/resources/js/broker/pages/quarantine.js"></script>

</body>
</html>