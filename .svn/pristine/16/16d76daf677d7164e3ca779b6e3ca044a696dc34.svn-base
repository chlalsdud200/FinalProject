package kr.or.tacs.officer.basicscreen.service;

import java.util.List;
import java.util.Map;

import kr.or.tacs.dto.officer.BasicScreenDetailDTO;
import kr.or.tacs.dto.officer.TaxDTO;

public interface IScreenDetailService {

    BasicScreenDetailDTO selectBasicDetail(String reqNo);
    List<BasicScreenDetailDTO> selectItemList(String reqNo);

    /** 세금납부 탭 데이터 조회 */
    TaxDTO selectTaxInfo(String reqNo);

    /** 세금탭 품목별 최신 세율·세액 조회 */
    List<Map<String, Object>> selectTaxItems(String reqNo);

    /** 세율 재조회 결과 IDI_TAXT_RT DB 저장 */
    void updateItemTaxRate(Map<String, Object> param);

    /** 관세사에게 세금정보 전달 (CUSTOMS_TAX 기준 상태 TAX_UNPAID 유지/생성시각 관리) */
    void sendTaxToBroker(String reqNo);

    /** 납부완료 처리: CUSTOMS_TAX 상태 갱신 + 납부이력 INSERT */
    void taxPayComplete(String reqNo);

    void updateItemStatus(String reqNo, int itemNo, String statusCd, String reason, String officerId);

    /** 신고 상태 직접 변경 */
    void updateDeclrStatus(String reqNo, String statusCd);

    /** 보완요청완료 처리 (DCLR_SUPP_SUB → DCLR_REVIEW) */
    void completeSupplement(String reqNo, String officerId);

    /** 기본심사 승인 + 통관완료 + 필증발급 */
    void approveDeclaration(String reqNo, String officerId);

    /** 필증 발급 */
    void issueCertificate(String reqNo, String officerId);
    
    String selectReviewMemo(String reqNo);

    void saveReviewMemo(String reqNo, String reviewMemo, String officerId);
}