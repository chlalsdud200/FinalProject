<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="sec" uri="http://www.springframework.org/security/tags" %>
<!DOCTYPE html>
<html class="light" lang="ko">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#00091b",
                        "primary-container": "#002045",
                        secondary: "#515f74",
                        surface: "#f7f9fb",
                        "surface-container-high": "#e6e8ea",
                        "surface-container-highest": "#e0e3e5",
                        error: "#ba1a1a"
                    },
                    borderRadius: { xl: "0.5rem" },
                    fontFamily: { body: ["Inter", "Noto Sans KR"] }
                }
            }
        };

        function validatePasswordMatch(event) {
            const password = document.getElementById("newPassword").value;
            const confirmPassword = document.getElementById("confirmPassword").value;

            if (password !== confirmPassword) {
                event.preventDefault();
                alert("입력하신 비밀번호가 서로 다릅니다. 다시 확인해주세요.");
                return false;
            }

            if (password.length < 8) {
                event.preventDefault();
                alert("비밀번호는 8자 이상이어야 합니다.");
                return false;
            }

            return true;
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .hero-gradient {
            background: linear-gradient(135deg, #00091b 0%, #002045 100%);
        }
    </style>
</head>
<body class="bg-surface font-body text-primary antialiased">
<main class="flex min-h-screen w-full overflow-hidden">
    <section class="relative hidden lg:flex w-3/5 hero-gradient flex-col justify-between p-16 overflow-hidden">
        <div class="absolute inset-0 opacity-20 pointer-events-none">
            <img class="w-full h-full object-cover mix-blend-overlay"
                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuCKBvKzKT0PUR1x_m_5h2iKWSna3tsFo2OJ7ONMZJTT-JzqjeH_BhyBGiJa7mejJhqMCwn3GBOVCfntODxI6N_fG4AMLUS_qlP0bO046fKgLa8wOunoGZM6PPdSn6D6C3Z7BhVREd99Y3WgFKQMHGodUv_AFykEOBmoWOXVs9U5LuQ0EZAFaS5lwM8zqhVmFcqxDrJ6tA6BkMa-5dsXfBLWV6lm9bj413gSqp3hDKfe9QBS1Gl4Hn34VhzTuxaQpJ9sdttPpTVsS4E" />
        </div>

        <div class="relative z-10 flex items-center space-x-4">
            <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center">
                <span class="material-symbols-outlined text-primary text-3xl">shield</span>
            </div>
            <div>
                <h2 class="text-2xl font-black tracking-tight text-white leading-none">TACS</h2>
                <p class="text-xs font-bold text-blue-200 tracking-widest uppercase">Sentinel Systems</p>
            </div>
        </div>

        <div class="relative z-10 max-w-2xl">
            <h1 class="text-6xl font-black text-white leading-tight mb-6 tracking-tight">비밀번호 찾기</h1>
            <p class="text-lg text-slate-300 leading-relaxed font-light">
                가입 시 등록한 휴대폰 번호가 아이디와 일치하는 경우에만 인증번호가 발송됩니다.
            </p>
        </div>
        <div class="relative z-10"></div>
    </section>

    <section class="w-full lg:w-2/5 bg-surface flex flex-col items-center justify-center p-8 lg:p-24 relative">
        <div class="lg:hidden absolute top-8 left-8 flex items-center space-x-3">
            <div class="w-10 h-10 rounded-lg bg-primary-container flex items-center justify-center">
                <span class="material-symbols-outlined text-white">shield</span>
            </div>
            <h2 class="text-xl font-black tracking-tight text-primary">TACS</h2>
        </div>

        <div class="w-full max-w-md">
            <div class="mb-10">
                <a class="inline-flex items-center gap-1 text-xs font-bold text-secondary hover:text-primary mb-6"
                   href="${pageContext.request.contextPath}/login.do">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    로그인으로 돌아가기
                </a>
                <h3 class="text-3xl font-black text-primary tracking-tight mb-2">비밀번호 찾기</h3>
                <p class="text-sm text-secondary">아이디와 가입된 휴대폰 번호를 입력한 뒤 인증번호를 확인하세요.</p>

                <c:if test="${not empty errorMessage}">
                    <p class="mt-4 rounded-xl bg-red-50 px-4 py-3 text-sm font-bold text-error">${errorMessage}</p>
                </c:if>
                <c:if test="${not empty successMessage}">
                    <p class="mt-4 rounded-xl bg-blue-50 px-4 py-3 text-sm font-bold text-primary">${successMessage}</p>
                </c:if>
            </div>

            <c:choose>
                <c:when test="${verified}">
                    <!-- 인증이 완료되었으므로 아이디/전화번호는 읽기 전용으로 보여주고 비밀번호 변경 폼을 노출합니다 -->
                    <div class="space-y-5">
                        <div class="space-y-1.5">
                            <label class="text-[11px] font-black text-primary uppercase tracking-widest pl-1">사용자 아이디</label>
                            <div class="relative group">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-secondary text-lg">person</span>
                                <input class="w-full bg-slate-200 border-none rounded-xl py-4 pl-12 pr-4 text-sm text-slate-500 cursor-not-allowed"
                                       type="text" value="${loginId}" disabled />
                            </div>
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-[11px] font-black text-primary uppercase tracking-widest pl-1">가입 휴대폰 번호</label>
                            <div class="relative group">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-secondary text-lg">smartphone</span>
                                <input class="w-full bg-slate-200 border-none rounded-xl py-4 pl-12 pr-4 text-sm text-slate-500 cursor-not-allowed"
                                       type="text" value="${phoneNo}" disabled />
                            </div>
                        </div>
                    </div>

                    <form class="space-y-5 mt-8 pt-8 border-t border-slate-200" action="${pageContext.request.contextPath}/find-password/change.do" method="post" onsubmit="return validatePasswordMatch(event)">
                        <sec:csrfInput/>
                        <input type="hidden" name="loginId" value="${loginId}" />
                        <input type="hidden" name="phoneNo" value="${phoneNo}" />

                        <div class="space-y-1.5">
                            <label class="text-[11px] font-black text-primary uppercase tracking-widest pl-1" for="newPassword">새 비밀번호</label>
                            <div class="relative group">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-secondary text-lg">lock</span>
                                <input id="newPassword"
                                       name="newPassword"
                                       class="w-full bg-surface-container-high border-none rounded-xl py-4 pl-12 pr-4 focus:ring-0 focus:bg-surface-container-highest transition-all text-sm"
                                       placeholder="새로운 비밀번호를 입력하세요 (8자 이상)"
                                       type="password"
                                       required />
                            </div>
                        </div>

                        <div class="space-y-1.5">
                            <label class="text-[11px] font-black text-primary uppercase tracking-widest pl-1" for="confirmPassword">비밀번호 확인</label>
                            <div class="relative group">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-secondary text-lg">lock</span>
                                <input id="confirmPassword"
                                       class="w-full bg-surface-container-high border-none rounded-xl py-4 pl-12 pr-4 focus:ring-0 focus:bg-surface-container-highest transition-all text-sm"
                                       placeholder="비밀번호를 한번 더 입력하세요"
                                       type="password"
                                       required />
                            </div>
                        </div>

                        <button class="w-full py-4 rounded-xl bg-gradient-to-br from-primary to-primary-container text-white font-black text-base hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center space-x-2"
                                type="submit">
                            <span class="material-symbols-outlined">key</span>
                            <span>비밀번호 변경하기</span>
                        </button>
                    </form>
                </c:when>

                <c:otherwise>
                    <!-- 인증 진행 중인 상태 (아이디/전화번호 입력 폼) -->
                    <form class="space-y-5" action="${pageContext.request.contextPath}/find-password/send-code.do" method="post">
                        <sec:csrfInput/>
                        <div class="space-y-1.5">
                            <label class="text-[11px] font-black text-primary uppercase tracking-widest pl-1" for="loginId">사용자 아이디</label>
                            <div class="relative group">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-secondary text-lg">person</span>
                                <input id="loginId"
                                       name="loginId"
                                       class="w-full bg-surface-container-high border-none rounded-xl py-4 pl-12 pr-4 focus:ring-0 focus:bg-surface-container-highest transition-all text-sm"
                                       placeholder="아이디를 입력하세요"
                                       type="text"
                                       autocomplete="username"
                                       value="${loginId}" />
                            </div>
                        </div>

                        <div class="space-y-1.5">
                            <label class="text-[11px] font-black text-primary uppercase tracking-widest pl-1" for="phoneNo">가입 휴대폰 번호</label>
                            <div class="relative group">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-secondary text-lg">smartphone</span>
                                <input id="phoneNo"
                                       name="phoneNo"
                                       class="w-full bg-surface-container-high border-none rounded-xl py-4 pl-12 pr-4 focus:ring-0 focus:bg-surface-container-highest transition-all text-sm"
                                       placeholder="01012345678"
                                       type="tel"
                                       inputmode="numeric"
                                       autocomplete="tel"
                                       value="${phoneNo}" />
                            </div>
                        </div>

                        <button class="w-full py-4 rounded-xl bg-gradient-to-br from-primary to-primary-container text-white font-black text-base hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center space-x-2"
                                type="submit">
                            <span class="material-symbols-outlined">sms</span>
                            <span>인증번호 발송</span>
                        </button>
                    </form>

                    <c:if test="${codeSent}">
                        <form class="space-y-5 mt-8 pt-8 border-t border-slate-200" action="${pageContext.request.contextPath}/find-password/verify-code.do" method="post">
                            <sec:csrfInput/>
                            <input type="hidden" name="loginId" value="${loginId}" />
                            <input type="hidden" name="phoneNo" value="${phoneNo}" />

                            <div class="space-y-1.5">
                                <label class="text-[11px] font-black text-primary uppercase tracking-widest pl-1" for="authCode">인증번호</label>
                                <div class="relative group">
                                    <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-secondary text-lg">pin</span>
                                    <input id="authCode"
                                           name="authCode"
                                           class="w-full bg-surface-container-high border-none rounded-xl py-4 pl-12 pr-4 focus:ring-0 focus:bg-surface-container-highest transition-all text-sm"
                                           placeholder="문자로 받은 6자리 숫자"
                                           type="text"
                                           inputmode="numeric"
                                           maxlength="6"
                                           value="${authCode}" />
                                </div>
                            </div>

                            <button class="w-full py-4 rounded-xl bg-white border border-slate-300 text-primary font-black text-base hover:bg-slate-50 active:scale-[0.98] transition-all flex items-center justify-center space-x-2"
                                    type="submit">
                                <span class="material-symbols-outlined">verified</span>
                                <span>인증번호 확인</span>
                            </button>
                        </form>
                    </c:if>
                </c:otherwise>
            </c:choose>
        </div>
    </section>
</main>
</body>
</html>