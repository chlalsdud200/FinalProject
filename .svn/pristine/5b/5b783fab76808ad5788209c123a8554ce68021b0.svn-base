<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.officer.basicscreen.mapper.IWorkHistoryMapper">

    <!-- ════════════════════════════════════════════════
         보완요청 — SUPP_RQST
         SR_STATUS_CD: REQ(요청중) | SUB(보완제출) | APR(승인)
         해지 시 DELETE 처리
    ════════════════════════════════════════════════ -->

    <!-- 관세사 ID 조회 -->
    <select id="selectBrokerIdByReqNo"
            parameterType="kr.or.tacs.dto.officer.WorkHistoryDTO"
            resultType="string">
        <choose>
            <when test="refBizCd == 'IMP_RQST'">
                SELECT IR_BROKER_ID FROM IMP_RQST WHERE IR_NO = #{reqNo}
            </when>
            <otherwise>
                SELECT ER_BROKER_ID FROM EXP_RQST WHERE ER_NO = #{reqNo}
            </otherwise>
        </choose>
    </select>

    <!-- 보완요청 등록 -->
    <!-- ★ SR_DUE_DT 컬럼은 SUPP_RQST 테이블에 없으므로 제거. 필요시 ALTER TABLE로 컬럼 추가 후 아래 주석 해제 -->
    <insert id="insertSupplement" parameterType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        <selectKey keyProperty="srNo" resultType="string" order="BEFORE">
            SELECT 'SR-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-'
                   || LPAD(SEQ_SUPP_RQST.NEXTVAL, 4, '0')
            FROM DUAL
        </selectKey>
        INSERT INTO SUPP_RQST (
            SR_NO, SR_REF_BIZ_CD, SR_REF_NO,
            SENDER_ID, SENDER_TY_CD,
            RECEIVER_ID, RECEIVER_TY_CD,
            SR_STATUS_CD, SR_REQ_DT, SR_REQ_CN
            <!-- SR_DUE_DT 사용 시: ALTER TABLE SUPP_RQST ADD SR_DUE_DT DATE NULL; 후 아래 추가
            , SR_DUE_DT
            -->
        ) VALUES (
            #{srNo}, #{refBizCd}, #{reqNo},
            #{officerId}, 'OFFICER',
            #{receiverId}, 'BROKER',
            'REQ', SYSDATE, #{reason}
            <!-- , TO_DATE(#{dueDate}, 'YYYY-MM-DD') -->
        )
    </insert>

    <!-- 보완요청 해지: 이력 보존을 위해 DELETE 대신 상태를 CANCEL로 업데이트 -->
    <update id="cancelSupplement" parameterType="string">
        UPDATE SUPP_RQST
           SET SR_STATUS_CD = 'CANCEL'
         WHERE SR_NO = #{srNo}
    </update>

    <!-- 최근 활성(REQ) 보완요청 단건 조회 (공무원용 — 해지 대상 찾기) -->
    <select id="selectLatestActiveSupplement"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        SELECT
            SR_NO                                    AS srNo,
            SR_NO                                    AS workHistoryId,
            SR_REF_NO                                AS reqNo,
            SR_REF_BIZ_CD                            AS refBizCd,
            RECEIVER_ID                              AS receiverId,
            'supplement'                             AS workType,
            'ACTIVE'                                 AS status
        FROM SUPP_RQST
        WHERE SR_REF_NO    = #{reqNo}
          AND SR_STATUS_CD = 'REQ'
          AND SENDER_TY_CD = 'OFFICER'
          AND RECEIVER_TY_CD = 'BROKER'
        ORDER BY SR_REQ_DT DESC
        FETCH FIRST 1 ROWS ONLY
    </select>

    <!-- SR_NO 기준 단건 전체 조회 (공무원 확인 + 관세사 제출용) -->
    <select id="selectSupplementBySrNo"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        SELECT
            SR_NO                                         AS srNo,
            SR_NO                                         AS workHistoryId,
            SR_REF_NO                                     AS reqNo,
            SR_REF_BIZ_CD                                 AS refBizCd,
            SENDER_ID                                     AS officerId,
            RECEIVER_ID                                   AS receiverId,
            'supplement'                                  AS workType,
            SR_REQ_CN                                     AS reason,
            SR_SUBMIT_CN                                  AS submitContent,
            TO_CHAR(SR_SUBMIT_DT, 'YYYY-MM-DD HH24:MI')  AS submitDt,
            TO_CHAR(SR_REQ_DT,    'YYYY-MM-DD HH24:MI')  AS registDt,
            CASE SR_STATUS_CD
                WHEN 'REQ'    THEN '진행중'
                WHEN 'SUB'    THEN '보완제출'
                WHEN 'APR'    THEN '승인'
                WHEN 'CANCEL' THEN '해지'
                ELSE SR_STATUS_CD
            END                                           AS status
        FROM SUPP_RQST
        WHERE SR_NO = #{srNo}
    </select>

    <!-- 관세사에게 할당된 미처리(REQ) 보완요청 목록 -->
    <select id="selectActiveSupplementsByReceiver"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        SELECT
            SR_NO                                         AS srNo,
            SR_NO                                         AS workHistoryId,
            SR_REF_NO                                     AS reqNo,
            SR_REF_BIZ_CD                                 AS refBizCd,
            SENDER_ID                                     AS officerId,
            RECEIVER_ID                                   AS receiverId,
            'supplement'                                  AS workType,
            SR_REQ_CN                                     AS reason,
            TO_CHAR(SR_REQ_DT, 'YYYY-MM-DD HH24:MI')     AS registDt,
            '진행중'                                       AS status
        FROM SUPP_RQST
        WHERE RECEIVER_ID   = #{receiverId}
          AND SR_STATUS_CD  = 'REQ'
          AND RECEIVER_TY_CD = 'BROKER'
          AND SENDER_TY_CD = 'OFFICER'
        ORDER BY SR_REQ_DT DESC
    </select>

    <!-- 관세사 보완제출: 상태 SUB + 제출내용 + 제출일시 업데이트 -->
    <update id="submitSupplement" parameterType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        UPDATE SUPP_RQST
           SET SR_STATUS_CD  = 'SUB',
               SR_SUBMIT_DT  = SYSDATE,
               SR_SUBMIT_CN  = #{submitContent}
         WHERE SR_NO         = #{srNo}
           AND RECEIVER_ID   = #{receiverId}
           AND RECEIVER_TY_CD = 'BROKER'
           AND SENDER_TY_CD = 'OFFICER'
           AND SR_STATUS_CD  = 'REQ'
    </update>


    <!-- ════════════════════════════════════════════════
         통관보류 — CUSTOMS_STATUS_HISTORY
    ════════════════════════════════════════════════ -->

    <!-- 통관보류 등록 -->
    <insert id="insertHold" parameterType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        <selectKey keyProperty="cshNo" resultType="long" order="BEFORE">
            SELECT SEQ_CUSTOMS_STATUS_HIST.NEXTVAL FROM DUAL
        </selectKey>
        INSERT INTO CUSTOMS_STATUS_HISTORY (
            CSH_PAY_SCHD_NO,
            CSH_SCOPE_CD,
            CSH_EVENT_TYPE_CD,
            CSH_BEFORE_STATUS_CD,
            CSH_AFTER_STATUS_CD,
            CSH_ACTOR_ROLE_CD,
            CSH_PUBLIC_YN,
            CSH_SRC_TABLE_CD,
            CSH_SRC_PK_NO,
            CSH_MSG,
            CSH_DT
        ) VALUES (
            #{cshNo},
            #{scopeCd},
            'CSTM_HOLD',
            #{beforeStatus},
            'CSTM_HOLD',
            'OFFICER',
            'N',
            #{refBizCd},
            #{reqNo},
            #{reason},
            SYSDATE
        )
    </insert>

    <!-- 통관보류 해지: DELETE -->
    <delete id="cancelHold" parameterType="long">
        DELETE FROM CUSTOMS_STATUS_HISTORY
         WHERE CSH_PAY_SCHD_NO = #{cshNo}
    </delete>

    <!-- 최근 활성 통관보류 조회 -->
    <select id="selectLatestActiveHold"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        SELECT
            TO_CHAR(CSH_PAY_SCHD_NO) AS workHistoryId,
            CSH_PAY_SCHD_NO          AS cshNo,
            CSH_SRC_PK_NO            AS reqNo,
            'hold'                   AS workType,
            'ACTIVE'                 AS status,
            CSH_SCOPE_CD             AS scopeCd,
            CSH_SRC_TABLE_CD         AS refBizCd
        FROM CUSTOMS_STATUS_HISTORY
        WHERE CSH_SRC_PK_NO    = #{reqNo}
          AND CSH_EVENT_TYPE_CD = 'CSTM_HOLD'
        ORDER BY CSH_DT DESC
        FETCH FIRST 1 ROWS ONLY
    </select>


    <!-- ════════════════════════════════════════════════
         반려 처리 — RJCT_MNG + CUSTOMS_STATUS_HISTORY
    ════════════════════════════════════════════════ -->

    <!-- 반려 처리이력 등록 -->
    <insert id="insertRejectStatusHistory" parameterType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        <selectKey keyProperty="cshNo" resultType="long" order="BEFORE">
            SELECT SEQ_CUSTOMS_STATUS_HIST.NEXTVAL FROM DUAL
        </selectKey>
        INSERT INTO CUSTOMS_STATUS_HISTORY (
            CSH_PAY_SCHD_NO,
            CSH_SCOPE_CD,
            CSH_EVENT_TYPE_CD,
            CSH_BEFORE_STATUS_CD,
            CSH_AFTER_STATUS_CD,
            CSH_ACTOR_ROLE_CD,
            CSH_PUBLIC_YN,
            CSH_SRC_TABLE_CD,
            CSH_SRC_PK_NO,
            CSH_MSG,
            CSH_DT
        ) VALUES (
            #{cshNo},
            #{scopeCd},
            'DCLR_REJ',
            #{beforeStatus},
            'DCLR_REJ',
            'OFFICER',
            'N',
            #{refBizCd},
            #{reqNo},
            #{reason},
            SYSDATE
        )
    </insert>

    <!-- 반려관리 등록/갱신 -->
    <insert id="insertRejectMng" parameterType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        MERGE INTO RJCT_MNG RJ
        USING DUAL
           ON (
               RJ.RM_REF_BIZ_CD = #{refBizCd}
           AND RJ.RM_REF_NO     = #{reqNo}
           )
        WHEN MATCHED THEN
            UPDATE SET
                RJ.RM_RJCT_DT   = SYSDATE,
                RJ.RM_RJCT_CN   = #{reason},
                RJ.RM_RJCTR_ID  = #{officerId},
                RJ.RM_TARGET_ID = #{receiverId}
        WHEN NOT MATCHED THEN
            INSERT (
                RM_NO,
                RM_REF_BIZ_CD,
                RM_REF_NO,
                RM_RJCT_DT,
                RM_RJCT_CN,
                RM_RJCTR_ID,
                RM_TARGET_ID
            ) VALUES (
                'RM-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' || LPAD(SEQ_RJCT_MNG_NO.NEXTVAL, 5, '0'),
                #{refBizCd},
                #{reqNo},
                SYSDATE,
                #{reason},
                #{officerId},
                #{receiverId}
            )
    </insert>


    <!-- ════════════════════════════════════════════════
         통합 이력 조회 (SUPP_RQST + CUSTOMS_STATUS_HISTORY)
    ════════════════════════════════════════════════ -->
    <select id="selectWorkHistoryList"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        SELECT *
          FROM (
              /* 보완요청 이력 */
              SELECT
                  SR_NO                                     AS workHistoryId,
                  SR_REF_NO                                 AS reqNo,
                  'supplement'                              AS workType,
                  SR_REQ_CN                                 AS reason,
                  NULL                                      AS dueDate,
                  TO_CHAR(SR_REQ_DT, 'YYYY-MM-DD HH24:MI') AS registDt,
                  CASE SR_STATUS_CD
                      WHEN 'REQ'    THEN '진행중'
                      WHEN 'SUB'    THEN '보완제출'
                      WHEN 'APR'    THEN '승인'
                      WHEN 'CANCEL' THEN '해지'
                      ELSE SR_STATUS_CD
                  END                                       AS status,
                  SENDER_ID                                 AS officerId,
                  SR_SUBMIT_CN                              AS submitContent,
                  TO_CHAR(SR_SUBMIT_DT, 'YYYY-MM-DD HH24:MI') AS submitDt,
                  SR_REQ_DT                                 AS sortDt
              FROM SUPP_RQST
              WHERE SR_REF_NO = #{reqNo}
                AND SENDER_TY_CD = 'OFFICER'
                AND RECEIVER_TY_CD = 'BROKER'

              UNION ALL

              /* 통관보류 이력 */
              SELECT
                  TO_CHAR(CSH_PAY_SCHD_NO)                  AS workHistoryId,
                  CSH_SRC_PK_NO                             AS reqNo,
                  'hold'                                    AS workType,
                  CSH_MSG                                   AS reason,
                  NULL                                      AS dueDate,
                  TO_CHAR(CSH_DT, 'YYYY-MM-DD HH24:MI')    AS registDt,
                  '진행중'                                   AS status,
                  NULL                                      AS officerId,
                  NULL                                      AS submitContent,
                  NULL                                      AS submitDt,
                  CSH_DT                                    AS sortDt
              FROM CUSTOMS_STATUS_HISTORY
              WHERE CSH_SRC_PK_NO    = #{reqNo}
                AND CSH_EVENT_TYPE_CD = 'CSTM_HOLD'

              UNION ALL

              /* 반려 이력 */
              SELECT
                  TO_CHAR(CSH_PAY_SCHD_NO)                  AS workHistoryId,
                  CSH_SRC_PK_NO                             AS reqNo,
                  'reject'                                  AS workType,
                  CSH_MSG                                   AS reason,
                  NULL                                      AS dueDate,
                  TO_CHAR(CSH_DT, 'YYYY-MM-DD HH24:MI')    AS registDt,
                  '반려'                                     AS status,
                  NULL                                      AS officerId,
                  NULL                                      AS submitContent,
                  NULL                                      AS submitDt,
                  CSH_DT                                    AS sortDt
              FROM CUSTOMS_STATUS_HISTORY
              WHERE CSH_SRC_PK_NO     = #{reqNo}
                AND CSH_EVENT_TYPE_CD = 'DCLR_REJ'
          )
        ORDER BY sortDt DESC
    </select>

    <!-- 현재 수입 신고 상태 조회 (통관보류 before_status 기록용) -->
    <select id="selectImpDeclStatus" parameterType="string" resultType="string">
        SELECT ID_STATUS_CD FROM IMP_DCLR WHERE ID_IR_NO = #{reqNo}
    </select>

    <!-- 현재 수출 신고 상태 조회 -->
    <select id="selectExpDeclStatus" parameterType="string" resultType="string">
        SELECT ED_STATUS_CD FROM EXP_DCLR WHERE ED_ER_NO = #{reqNo}
    </select>

    <!-- 수입 신고 상태 업데이트 (IMP_DCLR + IMP_RQST 동시 반영) -->
    <update id="updateImpDeclStatus">
        UPDATE IMP_DCLR
           SET ID_STATUS_CD = #{statusCd}
         WHERE ID_IR_NO = #{reqNo}
    </update>

    <update id="updateImpRqstStatus">
        UPDATE IMP_RQST
           SET IR_STATUS_CD = #{statusCd}
         WHERE IR_NO = #{reqNo}
    </update>

    <!-- 수출 신고 상태 업데이트 (EXP_DCLR + EXP_RQST 동시 반영) -->
    <update id="updateExpDeclStatus">
        UPDATE EXP_DCLR
           SET ED_STATUS_CD = #{statusCd}
         WHERE ED_ER_NO = #{reqNo}
    </update>

    <update id="updateExpRqstStatus">
        UPDATE EXP_RQST
           SET ER_STATUS_CD = #{statusCd}
         WHERE ER_NO = #{reqNo}
    </update>

</mapper>