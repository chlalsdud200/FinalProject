<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.transport.importp.mapper.ImportTransportMapper">

    <sql id="impReleaseStatusCdCase">
        CASE
        WHEN CRR.CRR_RELEASE_DT IS NOT NULL THEN 'REL_DONE'
        ELSE NVL(CRR.CRR_STATUS_CD, 'REL_WAIT')
        END
    </sql>

    <sql id="impReleaseStatusNmCase">
        CASE
        WHEN CRR.CRR_RELEASE_DT IS NOT NULL THEN '반출완료'
        WHEN NVL(CRR.CRR_STATUS_CD, 'REL_WAIT') IN ('REL_WAIT', 'REL_REQ', 'REQUESTED', 'READY') THEN '반출대기'
        WHEN NVL(CRR.CRR_STATUS_CD, 'REL_WAIT') IN ('REL_DONE', 'DONE', 'RELEASED') THEN '반출완료'
        WHEN NVL(CRR.CRR_STATUS_CD, 'REL_WAIT') IN ('REL_FIX', 'REL_REJECT', 'REJECT') THEN '보완요청'
        WHEN NVL(CRR.CRR_STATUS_CD, 'REL_WAIT') IN ('REL_SENT', 'REQ_SENT') THEN '보완제출완료'
        ELSE NVL(CRR.CRR_STATUS_CD, '반출대기')
        END
    </sql>

    <select id="retriveImpTransportReqList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        /* 수입 운송의뢰 목록: HTML 화면에 쓰는 값만 TRAN_RCP 기준으로 조회 */
        SELECT
        T.TRC_NO                         AS trcNo
        , T.TRC_TFG_NO                     AS ggNo
        , T.TRC_OWR_ID                     AS ownerId
        , NVL(O.OWR_NM, T.TRC_OWR_ID)      AS ownerNm
        , T.TRC_OWR_PIC_NM                 AS ownerPicNm
        , O.OWR_TELNO                      AS ownerTelno
        , O.OWR_EMAIL                      AS ownerEmail
        , T.TRC_TRDR_NM                    AS buyerNm
        , T.TRC_TRDR_COUNTRY_CD            AS buyerCountryCd
        , T.TRC_DEPT_PORT_CD               AS deptPortCd
        , CASE T.TRC_DEPT_PORT_CD
        WHEN 'BUSAN' THEN '부산항'
        WHEN 'KRPUS' THEN '부산항'
        WHEN 'INCHEON' THEN '인천항'
        WHEN 'KRINC' THEN '인천항'
        WHEN 'PYEONGTAEK' THEN '평택항'
        WHEN 'OSAKA' THEN '오사카항'
        WHEN 'TOKYO' THEN '도쿄항'
        WHEN 'SHANGHAI' THEN '상하이항'
        ELSE T.TRC_DEPT_PORT_CD
        END                              AS deptPortNm
        , T.TRC_ARVL_PORT_CD               AS arvlPortCd
        , CASE T.TRC_ARVL_PORT_CD
        WHEN 'BUSAN' THEN '부산항'
        WHEN 'KRPUS' THEN '부산항'
        WHEN 'INCHEON' THEN '인천항'
        WHEN 'KRINC' THEN '인천항'
        WHEN 'PYEONGTAEK' THEN '평택항'
        WHEN 'OSAKA' THEN '오사카항'
        WHEN 'TOKYO' THEN '도쿄항'
        WHEN 'SHANGHAI' THEN '상하이항'
        ELSE T.TRC_ARVL_PORT_CD
        END                              AS arvlPortNm
        , T.TRC_TRAN_MN_CD                 AS transportMeanCd
        , CASE T.TRC_TRAN_MN_CD
        WHEN 'SEA' THEN '해상'
        ELSE T.TRC_TRAN_MN_CD
        END                              AS transportMeanNm
        , T.TRC_TRAN_TY_CD                 AS transportTypeCd
        , T.TRC_INCO_TERMS_CD              AS incoTermsCd
        , T.TRC_RQST_CN                    AS requestCn
        , T.TRC_STATUS_CD                  AS statusCd
        , CASE T.TRC_STATUS_CD
        WHEN 'TRC_WAIT' THEN '접수대기'
        WHEN 'TRC_DONE' THEN '접수완료'
        WHEN 'TRC_REJECT' THEN '접수반려'
        ELSE T.TRC_STATUS_CD
        END AS statusNm
        , SR_REQ.SR_NO                    AS supplementNo
        , SR_REQ.SR_STATUS_CD             AS supplementStatusCd
        , CASE
        WHEN T.TRC_STATUS_CD = 'TRC_DONE'
        AND (
        W.WIR_STATUS_CD = 'IN_DONE'
        OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        ) THEN '입고완료'
        WHEN T.TRC_STATUS_CD = 'TRC_DONE' AND SR_REQ.SR_STATUS_CD = 'REQ' THEN '보완요청'
        WHEN T.TRC_STATUS_CD = 'TRC_DONE' AND SR_REQ.SR_STATUS_CD = 'SUB' THEN '보완제출완료'
        WHEN T.TRC_STATUS_CD = 'TRC_DONE' AND SR_REQ.SR_STATUS_CD = 'APR' THEN '입고완료'
        ELSE NULL
        END                              AS supplementStatusNm
        , CASE
        WHEN CRR_REQ.CRR_RELEASE_DT IS NOT NULL THEN 'REL_DONE'
        ELSE CRR_REQ.CRR_STATUS_CD
        END                              AS releaseStatusCd
        , CASE
        WHEN CRR_REQ.CRR_RELEASE_DT IS NOT NULL THEN '반출완료'
        WHEN CRR_REQ.CRR_STATUS_CD IN ('REL_DONE', 'DONE', 'RELEASED') THEN '반출완료'
        WHEN CRR_REQ.CRR_STATUS_CD IN ('REL_WAIT', 'REL_REQ', 'REQUESTED', 'READY') THEN '반출대기'
        WHEN CRR_REQ.CRR_STATUS_CD IN ('REL_FIX', 'REL_REJECT', 'REJECT') THEN '보완요청'
        WHEN CRR_REQ.CRR_STATUS_CD IN ('REL_SENT', 'REQ_SENT') THEN '보완제출완료'
        ELSE CRR_REQ.CRR_STATUS_CD
        END                              AS releaseStatusNm
        , CASE
        WHEN T.TRC_STATUS_CD = 'TRC_WAIT' THEN '접수대기'
        WHEN T.TRC_STATUS_CD = 'TRC_REJECT' THEN '접수반려'
        WHEN T.TRC_STATUS_CD = 'TRC_DONE'
        AND (
        CRR_REQ.CRR_RELEASE_DT IS NOT NULL
        OR CRR_REQ.CRR_STATUS_CD IN ('REL_DONE', 'DONE', 'RELEASED')
        ) THEN '반출완료'
        WHEN T.TRC_STATUS_CD = 'TRC_DONE'
        AND (
        W.WIR_STATUS_CD = 'IN_DONE'
        OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        ) THEN '입고완료'
        WHEN T.TRC_STATUS_CD = 'TRC_DONE' AND SR_REQ.SR_STATUS_CD = 'REQ' THEN '보완요청'
        WHEN T.TRC_STATUS_CD = 'TRC_DONE' AND SR_REQ.SR_STATUS_CD = 'SUB' THEN '보완제출완료'
        WHEN T.TRC_STATUS_CD = 'TRC_DONE' AND SR_REQ.SR_STATUS_CD = 'APR' THEN '입고완료'
        WHEN T.TRC_STATUS_CD = 'TRC_DONE' THEN '접수완료'
        ELSE T.TRC_STATUS_CD
        END                              AS requestDisplayStatusNm
        , SR_REQ.SRI_REQ_CN               AS suppReqCn
        , DI.DI_STATUS_CD                   AS doStatusCd
        , CASE DI.DI_STATUS_CD
        WHEN 'TRC_DO_READY' THEN 'D/O발급대기'
        WHEN 'TRC_DO_ISSUED' THEN 'D/O발급완료'
        WHEN 'TRC_DO_REQ' THEN 'D/O전달완료'
        ELSE 'D/O발급대기'
        END                              AS doStatusNm
        , TO_CHAR(T.TRC_RQST_DT, 'YYYY-MM-DD HH24:MI') AS requestDt
        , T.TRC_REJ_TYPE                   AS rejectType
        , T.TRC_REJ_MEMO                   AS rejectMemo
        , T.TRC_RJCT_RSN                   AS rejectReason
        , INV_FILE.DFI_ORG_NM              AS invoiceFile
        , INV_FILE.DFI_FILE_NO             AS invoiceFileNo
        , INV_FILE.DFI_FILE_NO             AS invFileNo
        , INV_FILE.DFI_ORG_NM              AS invoiceFileNm
        , INV_FILE.DFI_ORG_NM              AS invFileNm
        , INV_FILE.DFI_PATH                AS invoicePath
        , INV_FILE.DFI_STR_NM              AS invoiceStoredName
        , PKG_FILE.DFI_ORG_NM              AS packingListFile
        , PKG_FILE.DFI_FILE_NO             AS packingListFileNo
        , PKG_FILE.DFI_FILE_NO             AS pkgFileNo
        , PKG_FILE.DFI_ORG_NM              AS packingListFileNm
        , PKG_FILE.DFI_ORG_NM              AS pkgFileNm
        , PKG_FILE.DFI_PATH                AS packingListPath
        , PKG_FILE.DFI_STR_NM              AS packingListStoredName
        , NVL(M.ICM_MBL_NO, NVL(B.BI_MBL_NO, IR.IR_BL_AWB_NO)) AS blNo
        , NVL(M.ICM_MBL_NO, NVL(B.BI_MBL_NO, IR.IR_BL_AWB_NO)) AS mblNo
        , NVL(M.ICM_HBL_NO, NVL(B.BI_HBL_NO, IR.IR_BL_AWB_NO)) AS hblNo
        , B.BI_STATUS_CD                   AS blStatusCd
        , B.BI_STL_STATUS_CD               AS settlementStatusCd
        , B.BI_XPROT_FEE                   AS freightAmt
        , B.BI_WH_FEE                      AS warehouseAmt
        , B.BI_TTL_AMT                     AS totalBillAmt
        , CASE
        WHEN NVL(M.ICM_MBL_NO, NVL(B.BI_MBL_NO, IR.IR_BL_AWB_NO)) IS NULL THEN NULL
        WHEN LOWER(NVL(M.ICM_MBL_NO, NVL(B.BI_MBL_NO, IR.IR_BL_AWB_NO))) LIKE '%.pdf'
        THEN NVL(M.ICM_MBL_NO, NVL(B.BI_MBL_NO, IR.IR_BL_AWB_NO))
        ELSE NVL(M.ICM_MBL_NO, NVL(B.BI_MBL_NO, IR.IR_BL_AWB_NO)) || '.pdf'
        END                              AS requestFile
        , NULL                             AS desiredDeliveryAt
        , IAN.IAN_NO                       AS arrivalNoticeNo
        , IAN.IAN_NO                       AS arrivalNoticeReqNo
        , NVL(IAN.IAN_SEND_STTS_CD, 'TRC_NTC_NSENT') AS noticeStatus
        , CASE NVL(IAN.IAN_SEND_STTS_CD, 'TRC_NTC_NSENT')
        WHEN 'TRC_NTC_SENT' THEN '발송완료'
        WHEN 'SENT' THEN '발송완료'
        ELSE '미발송'
        END AS noticeStatusNm
        , T.TRC_ITEM_CTGRY_NM              AS itemCategory
        , GOODS_SUM.CG_NO                  AS cgNo
        , GOODS_SUM.GOODS_NO               AS goodsNo
        , GOODS_SUM.GOODS_NAME             AS goodsName
        , GOODS_SUM.GOODS_NAME             AS itemNm
        , GOODS_SUM.QTY                    AS qty
        , GOODS_SUM.PRICE                  AS price
        , GOODS_SUM.GOODS_TOTAL_PRICE      AS goodsTotalPrice
        , GOODS_SUM.WEIGHT                 AS weight
        , GOODS_SUM.ORIGIN                 AS origin
        FROM TRAN_RCP T
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        LEFT JOIN DO_ISSUANCE DI
        ON DI.DI_TRC_NO = T.TRC_NO
        AND NVL(DI.DI_TRDE_SE_CD, 'IMP') = 'IMP'
        LEFT JOIN BL_ISSU B
        ON B.BI_TRE_ID = T.TRC_NO
        LEFT JOIN IMP_RQST IR
        ON (
        IR.IR_NO = REGEXP_REPLACE(
            T.TRC_NO,
            '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
            '\1-\2\3\4-\5'
        )
        OR IR.IR_TFG_NO = T.TRC_TFG_NO
        )
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        M0.*,
        ROW_NUMBER() OVER (
        PARTITION BY M0.ICM_GG_NO
        ORDER BY M0.ICM_SBMSN_DT DESC NULLS LAST, M0.ICM_NO DESC
        ) AS RN
        FROM IMP_CARGO_MANIFEST M0
        )
        WHERE RN = 1
        ) M
        ON M.ICM_GG_NO = T.TRC_TFG_NO
        LEFT JOIN IMP_ARRV_NTC IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        OR IAN.IAN_TRC_NO = IR.IR_NO
        OR IAN.IAN_TRC_NO = IR.IR_NO
        LEFT JOIN (
        SELECT
        WIR_GG_NO
        , MIN(WIR_NO) AS WIR_NO
        , MAX(WIR_STATUS_CD) AS WIR_STATUS_CD
        , MAX(WIR_WH_REPLY_STATUS_CD) AS WIR_WH_REPLY_STATUS_CD
        FROM WH_IN_RPT
        WHERE WIR_IO_SE_CD = 'IMP'
        GROUP BY WIR_GG_NO
        ) W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        LEFT JOIN (
        SELECT
        SR_NO
        , SR_REF_NO
        , SR_STATUS_CD
        , SRI_REQ_CN
        FROM (
        SELECT
        SR.SR_NO
        , SR.SR_REF_NO
        , SR.SR_STATUS_CD
        , CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)) AS SRI_REQ_CN
        , ROW_NUMBER() OVER (
        PARTITION BY SR.SR_REF_NO
        ORDER BY SR.SR_REQ_DT DESC, SR.SR_NO DESC
        ) AS RN
        FROM SUPP_RQST SR
        WHERE SR.SR_REF_BIZ_CD = 'WH_IN_RPT'
        AND SR.RECEIVER_TY_CD IN ('TRC', 'WHM', 'TRANSPORT', 'TRANSPORT_MANAGER', 'WAREHOUSE_MANAGER')
        AND SR.SR_STATUS_CD IN ('REQ', 'SUB', 'APR')
        AND EXISTS (
        SELECT 1
        FROM WH_IN_RPT WX
        WHERE WX.WIR_IO_SE_CD = 'IMP'
        AND (
        WX.WIR_WM_ID = SR.SENDER_ID
        OR WX.WIR_WM_ID = SR.RECEIVER_ID
        )
        AND (
        WX.WIR_NO = SR.SR_REF_NO
        OR EXISTS (
        SELECT 1
        FROM TRAN_RCP TX
        WHERE TX.TRC_NO = SR.SR_REF_NO
        AND TX.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND TX.TRC_TFG_NO = WX.WIR_GG_NO
        )
        )
        )
        )
        WHERE RN = 1
        ) SR_REQ
        ON (SR_REQ.SR_REF_NO = T.TRC_NO OR SR_REQ.SR_REF_NO = W.WIR_NO)
        LEFT JOIN (
        SELECT
        CRR_NO
        , CRR_TRE_ID
        , CRR_STATUS_CD
        , CRR_RELEASE_DT
        FROM (
        SELECT
        CRR0.CRR_NO
        , CRR0.CRR_TRE_ID
        , CRR0.CRR_STATUS_CD
        , CRR0.CRR_RELEASE_DT
        , ROW_NUMBER() OVER (
        PARTITION BY CRR0.CRR_TRE_ID
        ORDER BY CRR0.CRR_RELEASE_DT DESC NULLS LAST, CRR0.CRR_CR_DT DESC NULLS LAST, CRR0.CRR_NO DESC
        ) AS RN
        FROM CARGO_RELEASE_REQ CRR0
        )
        WHERE RN = 1
        ) CRR_REQ
        ON CRR_REQ.CRR_TRE_ID = T.TRC_NO
        LEFT JOIN (
        SELECT
        CG.GG_NO
        , MIN(CG.CG_NO)                  AS CG_NO
        , MIN(CG.GOODS_NO)               AS GOODS_NO
        , MIN(G.GOODS_NAME)              AS GOODS_NAME
        , NVL(SUM(CG.CG_QTY), 0)         AS QTY
        , NVL(MAX(CG.CG_PRICE), 0)       AS PRICE
        , NVL(SUM(CG.CG_TOTAL_PRICE), 0) AS GOODS_TOTAL_PRICE
        , NVL(SUM(CG.CG_WEIGHT), 0)      AS WEIGHT
        , MIN(CG.CG_ORIGIN)              AS ORIGIN
        FROM CUSTOMS_GOODS CG
        LEFT JOIN GOODS G
        ON G.GOODS_NO = CG.GOODS_NO
        GROUP BY CG.GG_NO
        ) GOODS_SUM
        ON GOODS_SUM.GG_NO = T.TRC_TFG_NO
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        FM.TFM_TFG_NO
        , D.DFI_FILE_NO
        , D.DFI_ORG_NM
        , D.DFI_PATH
        , D.DFI_STR_NM
        , ROW_NUMBER() OVER (PARTITION BY FM.TFM_TFG_NO ORDER BY FM.TFM_NO DESC) AS RN
        FROM TACS_FILE_MAP FM
        JOIN DOCS_FILE_DATA D
        ON D.DFI_FILE_NO = FM.TFM_DFI_NO
        WHERE FM.TFM_DOC_TY_CD = 'INVOICE'
        AND NVL(D.DFI_DEL_YN, 'N') = 'N'
        AND NVL(D.DFI_UPLOAD_STTS_CD, 'DONE') = 'DONE'
        )
        WHERE RN = 1
        ) INV_FILE
        ON INV_FILE.TFM_TFG_NO = T.TRC_TFG_NO
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        FM.TFM_TFG_NO
        , D.DFI_FILE_NO
        , D.DFI_ORG_NM
        , D.DFI_PATH
        , D.DFI_STR_NM
        , ROW_NUMBER() OVER (PARTITION BY FM.TFM_TFG_NO ORDER BY FM.TFM_NO DESC) AS RN
        FROM TACS_FILE_MAP FM
        JOIN DOCS_FILE_DATA D
        ON D.DFI_FILE_NO = FM.TFM_DFI_NO
        WHERE FM.TFM_DOC_TY_CD = 'PACKING_LIST'
        AND NVL(D.DFI_DEL_YN, 'N') = 'N'
        AND NVL(D.DFI_UPLOAD_STTS_CD, 'DONE') = 'DONE'
        )
        WHERE RN = 1
        ) PKG_FILE
        ON PKG_FILE.TFM_TFG_NO = T.TRC_TFG_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
        ORDER BY T.TRC_RQST_DT DESC NULLS LAST, T.TRC_NO DESC
    </select>

    <update id="updateImpTransportReqStatus">
        UPDATE TRAN_RCP
        SET
        TRC_STATUS_CD =
        CASE #{statusCd}
        WHEN 'ACC' THEN 'TRC_DONE'
        WHEN 'ACCEPTED' THEN 'TRC_DONE'
        WHEN 'TRC_DONE' THEN 'TRC_DONE'
        WHEN '접수완료' THEN 'TRC_DONE'
        WHEN 'REJ' THEN 'TRC_REJECT'
        WHEN 'REJECTED' THEN 'TRC_REJECT'
        WHEN 'TRC_REJECT' THEN 'TRC_REJECT'
        WHEN '접수반려' THEN 'TRC_REJECT'
        ELSE #{statusCd}
        END
        , TRC_RCEPT_DT = CASE
        WHEN #{statusCd} IN ('ACC', 'ACCEPTED', 'TRC_DONE', '접수완료') THEN SYSDATE
        ELSE TRC_RCEPT_DT
        END
        , TRC_REJ_TYPE = CASE
        WHEN #{statusCd} IN ('REJ', 'REJECTED', 'TRC_REJECT', '접수반려') THEN #{rejectType,jdbcType=VARCHAR}
        ELSE NULL
        END
        , TRC_REJ_MEMO = CASE
        WHEN #{statusCd} IN ('REJ', 'REJECTED', 'TRC_REJECT', '접수반려') THEN #{rejectMemo,jdbcType=VARCHAR}
        ELSE NULL
        END
        , TRC_RJCT_RSN = CASE
        WHEN #{statusCd} IN ('REJ', 'REJECTED', 'TRC_REJECT', '접수반려') THEN #{rejectReason,jdbcType=VARCHAR}
        ELSE NULL
        END
        WHERE TRC_NO = #{trcNo}
        AND TRC_SE_CD IN ('IMP', 'IMPORT')
    </update>


    <update id="updateImpTransportReqDetail">
        UPDATE TRAN_RCP
        SET TRC_TRDR_NM = NVL(TRIM(#{buyerNm,jdbcType=VARCHAR}), TRC_TRDR_NM)
          , TRC_TRDR_COUNTRY_CD = NVL(CASE TRIM(#{buyerCountryCd,jdbcType=VARCHAR})
              WHEN '대한민국' THEN 'KR'
              WHEN '한국' THEN 'KR'
              WHEN '일본' THEN 'JP'
              WHEN '중국' THEN 'CN'
              WHEN '미국' THEN 'US'
              ELSE TRIM(#{buyerCountryCd,jdbcType=VARCHAR})
            END, TRC_TRDR_COUNTRY_CD)
          , TRC_TRAN_MN_CD = NVL(CASE TRIM(#{transportMeanCd,jdbcType=VARCHAR})
              WHEN '해상' THEN 'SEA'
              WHEN '항공' THEN 'AIR'
              ELSE TRIM(#{transportMeanCd,jdbcType=VARCHAR})
            END, TRC_TRAN_MN_CD)
          , TRC_TRAN_TY_CD = NVL(TRIM(#{transportTypeCd,jdbcType=VARCHAR}), TRC_TRAN_TY_CD)
          , TRC_DEPT_PORT_CD = NVL(CASE TRIM(#{deptPortCd,jdbcType=VARCHAR})
              WHEN '부산항' THEN 'KRPUS'
              WHEN '인천항' THEN 'KRINC'
              WHEN '평택항' THEN 'PYEONGTAEK'
              WHEN '오사카항' THEN 'OSAKA'
              WHEN '도쿄항' THEN 'TOKYO'
              WHEN '상하이항' THEN 'CNSHA'
              ELSE TRIM(#{deptPortCd,jdbcType=VARCHAR})
            END, TRC_DEPT_PORT_CD)
          , TRC_ARVL_PORT_CD = NVL(CASE TRIM(#{arvlPortCd,jdbcType=VARCHAR})
              WHEN '부산항' THEN 'KRPUS'
              WHEN '인천항' THEN 'KRINC'
              WHEN '평택항' THEN 'PYEONGTAEK'
              WHEN '오사카항' THEN 'OSAKA'
              WHEN '도쿄항' THEN 'TOKYO'
              WHEN '상하이항' THEN 'CNSHA'
              ELSE TRIM(#{arvlPortCd,jdbcType=VARCHAR})
            END, TRC_ARVL_PORT_CD)
          , TRC_ITEM_CTGRY_NM = NVL(TRIM(#{itemCategory,jdbcType=VARCHAR}), TRC_ITEM_CTGRY_NM)
          , TRC_RQST_CN = #{requestCn,jdbcType=VARCHAR}
        WHERE TRC_NO = #{trcNo}
          AND TRC_SE_CD IN ('IMP', 'IMPORT')
    </update>

    <update id="updateImpTransportReqMasterBl">
        UPDATE BL_ISSU
        SET BI_MBL_NO = NVL(TRIM(#{mblNo,jdbcType=VARCHAR}), BI_MBL_NO)
        WHERE BI_TRE_ID = #{trcNo}
    </update>

    <insert id="insertImportTransportReject">
        INSERT INTO RJCT_MNG (
        RM_NO,
        RM_REF_BIZ_CD,
        RM_REF_NO,
        RM_RJCT_DT,
        RM_RJCT_CN,
        RM_RJCTR_ID,
        RM_TARGET_ID
        )
        SELECT
        'RM-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' || LPAD(SEQ_RJCT_MNG_NO.NEXTVAL, 5, '0'),
        'TRAN_RCP',
        T.TRC_NO,
        SYSDATE,
        #{rejectReason,jdbcType=VARCHAR},
        #{rejecterId,jdbcType=VARCHAR},
        T.TRC_OWR_ID
        FROM TRAN_RCP T
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND NOT EXISTS (
        SELECT 1
        FROM RJCT_MNG RM
        WHERE RM.RM_REF_BIZ_CD = 'TRAN_RCP'
        AND RM.RM_REF_NO = T.TRC_NO
        AND RM.RM_RJCT_CN = #{rejectReason,jdbcType=VARCHAR}
        )
    </insert>

    <insert id="insertImportSupplementRequest">
        DECLARE
        V_SR_NO SUPP_RQST.SR_NO%TYPE;
        BEGIN
        SELECT 'SR-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' || LPAD(SEQ_SUPP_RQST.NEXTVAL, 4, '0')
        INTO V_SR_NO
        FROM DUAL;

        INSERT INTO SUPP_RQST (
        SR_NO,
        SR_REF_BIZ_CD,
        SR_REF_NO,
        SENDER_ID,
        SENDER_TY_CD,
        RECEIVER_ID,
        RECEIVER_TY_CD,
        SR_STATUS_CD,
        SR_REQ_DT,
        SR_REQ_CN
        )
        VALUES (
        V_SR_NO,
        #{refBizCd},
        #{refNo},
        #{senderId},
        CASE #{senderTyCd}
        WHEN 'TRANSPORT_MANAGER' THEN 'TRC'
        WHEN 'TRANSPORT' THEN 'TRC'
        WHEN 'WAREHOUSE_MANAGER' THEN 'WHM'
        WHEN 'WAREHOUSE' THEN 'WHM'
        WHEN 'OWNER' THEN 'OWR'
        WHEN 'BROKER' THEN 'BRK'
        ELSE #{senderTyCd}
        END,
        #{receiverId},
        CASE #{receiverTyCd}
        WHEN 'TRANSPORT_MANAGER' THEN 'TRC'
        WHEN 'TRANSPORT' THEN 'TRC'
        WHEN 'WAREHOUSE_MANAGER' THEN 'WHM'
        WHEN 'WAREHOUSE' THEN 'WHM'
        WHEN 'OWNER' THEN 'OWR'
        WHEN 'BROKER' THEN 'BRK'
        ELSE #{receiverTyCd}
        END,
        'REQ',
        SYSDATE,
        #{suppReqCn,jdbcType=VARCHAR}
        );
        END;
    </insert>

    <update id="updateImpUnloadingInSupplementRequested">
        UPDATE WH_IN_RPT
        SET
        WIR_STATUS_CD = 'REQ_FIX',
        WIR_WH_REPLY_STATUS_CD = 'REQ_FIX'
        WHERE WIR_NO = #{wirNo}
        AND WIR_IO_SE_CD = 'IMP'
    </update>

    <update id="updateImpReleaseSupplementRequested">
        UPDATE CARGO_RELEASE_REQ CRR
        SET CRR.CRR_STATUS_CD = 'REL_FIX'
        WHERE TO_CHAR(CRR.CRR_NO) = #{releaseReqNo}
    </update>

    <update id="updateImpReleaseReqData">
        UPDATE CARGO_RELEASE_REQ CRR
        SET
        CRR.CRR_WZ_NO = COALESCE(#{wzNo,jdbcType=VARCHAR}, CRR.CRR_WZ_NO)
        , CRR.CRR_WM_ID = COALESCE(#{wmId,jdbcType=VARCHAR}, CRR.CRR_WM_ID)
        , CRR.CRR_WHM_NO = COALESCE(#{wmId,jdbcType=VARCHAR}, CRR.CRR_WHM_NO)
        , CRR.CRR_PROC_MEM_ID = COALESCE(#{wmId,jdbcType=VARCHAR}, CRR.CRR_PROC_MEM_ID)
        , CRR.CRR_WH_NO = COALESCE(
        (
        SELECT WZ.WZ_WH_NO
        FROM WAREHOUSE_ZONE WZ
        WHERE WZ.WZ_NO = #{wzNo,jdbcType=VARCHAR}
        FETCH FIRST 1 ROW ONLY
        ),
        CRR.CRR_WH_NO
        )
        , CRR.CRR_FRGHT_IEM_NM = COALESCE(#{itemNm,jdbcType=VARCHAR}, CRR.CRR_FRGHT_IEM_NM)
        , CRR.CRR_REQ_CN = COALESCE(#{remark,jdbcType=VARCHAR}, CRR.CRR_REQ_CN)
        , CRR.CRR_CR_DT = CASE
        WHEN #{releaseReqDt,jdbcType=VARCHAR} IS NULL THEN CRR.CRR_CR_DT
        WHEN LENGTH(#{releaseReqDt,jdbcType=VARCHAR}) &gt; 10
        THEN TO_DATE(SUBSTR(#{releaseReqDt,jdbcType=VARCHAR}, 1, 10), 'YYYY-MM-DD')
        ELSE TO_DATE(#{releaseReqDt,jdbcType=VARCHAR}, 'YYYY-MM-DD')
        END
        , CRR.CRR_STATUS_CD = CASE
        WHEN CRR.CRR_STATUS_CD IN ('REL_REJECT', 'REJECT') THEN 'REL_FIX'
        ELSE CRR.CRR_STATUS_CD
        END
        WHERE (
        #{releaseReqNo,jdbcType=VARCHAR} IS NOT NULL
        AND TO_CHAR(CRR.CRR_NO) = #{releaseReqNo,jdbcType=VARCHAR}
        )
        OR (
        #{trcNo,jdbcType=VARCHAR} IS NOT NULL
        AND CRR.CRR_TRE_ID = #{trcNo,jdbcType=VARCHAR}
        )
    </update>

    <update id="updateImpReleaseSupplementSubmitted">
        BEGIN
        UPDATE SUPP_RQST SR
        SET
        SR.SR_STATUS_CD = 'SUB'
        , SR.SR_SUBMIT_DT = SYSDATE
        WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
        AND SR.RECEIVER_TY_CD IN ('TRC', 'WHM', 'TRANSPORT', 'TRANSPORT_MANAGER', 'WAREHOUSE_MANAGER')
        AND SR.SR_STATUS_CD = 'REQ'
        AND SR.SR_REF_NO IN (
        #{releaseReqNo,jdbcType=VARCHAR}
        , (
        SELECT MAX(TO_CHAR(CRR.CRR_NO))
        FROM CARGO_RELEASE_REQ CRR
        WHERE CRR.CRR_TRE_ID = #{trcNo,jdbcType=VARCHAR}
        )
        );

        UPDATE CARGO_RELEASE_REQ CRR
        SET CRR.CRR_STATUS_CD = 'REL_SENT'
        WHERE (
        #{releaseReqNo,jdbcType=VARCHAR} IS NOT NULL
        AND TO_CHAR(CRR.CRR_NO) = #{releaseReqNo,jdbcType=VARCHAR}
        )
        OR (
        #{trcNo,jdbcType=VARCHAR} IS NOT NULL
        AND CRR.CRR_TRE_ID = #{trcNo,jdbcType=VARCHAR}
        );
        END;
    </update>

    <update id="updateImpUnloadingInSupplementData">
        UPDATE WH_IN_RPT W
        SET
        W.WIR_WM_ID = COALESCE(#{wmId,jdbcType=VARCHAR}, W.WIR_WM_ID)
        , W.WIR_WZ_NO = COALESCE(#{wzNo,jdbcType=VARCHAR}, W.WIR_WZ_NO)
        , W.WIR_IN_PLAN_DT = CASE
        WHEN #{inPlanDt,jdbcType=VARCHAR} IS NULL THEN W.WIR_IN_PLAN_DT
        WHEN LENGTH(#{inPlanDt,jdbcType=VARCHAR}) &gt; 10
        THEN TO_DATE(SUBSTR(#{inPlanDt,jdbcType=VARCHAR}, 1, 16), 'YYYY-MM-DD HH24:MI')
        ELSE TO_DATE(#{inPlanDt,jdbcType=VARCHAR}, 'YYYY-MM-DD')
        END
        , W.WIR_RQST_CN = COALESCE(#{remark,jdbcType=VARCHAR}, W.WIR_RQST_CN)
        , W.WIR_CARGO_MGMT_NO = COALESCE(#{cargoMgmtNo,jdbcType=VARCHAR}, W.WIR_CARGO_MGMT_NO)
        , W.WIR_INVOICE_NO = COALESCE(#{invoiceNo,jdbcType=VARCHAR}, W.WIR_INVOICE_NO)
        , W.WIR_INCO_TERMS_CD = COALESCE(#{incoTermsCd,jdbcType=VARCHAR}, W.WIR_INCO_TERMS_CD)
        WHERE W.WIR_NO = #{wirNo}
        AND W.WIR_IO_SE_CD = 'IMP'
        AND (
        W.WIR_STATUS_CD = 'REQ_FIX'
        OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX'
        )
    </update>

    <update id="updateImpUnloadingInSupplementGoods"
            parameterType="kr.or.tacs.vo.transport.TransportRequestVO">
        UPDATE CUSTOMS_GOODS CG
        SET
        CG.CG_QTY = COALESCE(#{qty,jdbcType=NUMERIC}, CG.CG_QTY)
        , CG.CG_PRICE = COALESCE(#{price,jdbcType=NUMERIC}, CG.CG_PRICE)
        , CG.CG_TOTAL_PRICE = COALESCE(#{goodsTotalPrice,jdbcType=NUMERIC}, CG.CG_TOTAL_PRICE)
        , CG.CG_WEIGHT = COALESCE(#{weight,jdbcType=NUMERIC}, CG.CG_WEIGHT)
        , CG.CG_ORIGIN = COALESCE(#{origin,jdbcType=VARCHAR}, CG.CG_ORIGIN)
        WHERE CG.CG_NO = #{cgNo}
    </update>

    <update id="updateImpUnloadingInSupplementGoodsName"
            parameterType="kr.or.tacs.vo.transport.TransportRequestVO">
        UPDATE GOODS G
        SET
        G.GOODS_NAME = COALESCE(#{goodsName,jdbcType=VARCHAR}, G.GOODS_NAME)
        WHERE G.GOODS_NO = COALESCE(
        #{goodsNo,jdbcType=NUMERIC},
        (
        SELECT CG.GOODS_NO
        FROM CUSTOMS_GOODS CG
        WHERE CG.CG_NO = #{cgNo}
        FETCH FIRST 1 ROW ONLY
        )
        )
    </update>

    <select id="retriveImpArrivalTrackingList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        IAN.IAN_NO AS reqNo
        , T.TRC_NO AS trcNo
        , T.TRC_OWR_ID AS ownerId
        , NVL(O.OWR_NM, T.TRC_OWR_ID) AS ownerNm
        , NVL(O.OWR_NM, T.TRC_OWR_ID) AS owrNm

        /* B/L은 입력값을 바꿀 때마다 매퍼를 고치지 않도록 TFG_NO 기준으로 자동 매칭 */
        , NVL(M.ICM_MBL_NO, NVL(BI.BI_MBL_NO, IR.IR_BL_AWB_NO)) AS mblNo
        , NVL(M.ICM_HBL_NO, NVL(BI.BI_HBL_NO, IR.IR_BL_AWB_NO)) AS hblNo
        , NVL(M.ICM_HBL_NO, NVL(BI.BI_HBL_NO, IR.IR_BL_AWB_NO)) AS blNo
        , (
        SELECT MAX(W.WIR_CARGO_MGMT_NO)
        FROM WH_IN_RPT W
        WHERE W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_GG_NO = T.TRC_TFG_NO
        ) AS cargoMgmtNo

        , NULL AS carrierNm

        , T.TRC_DEPT_PORT_CD AS deptPortCd
        , CASE T.TRC_DEPT_PORT_CD
        WHEN 'OSAKA' THEN '오사카항'
        WHEN 'BUSAN' THEN '부산항'
        WHEN 'KRPUS' THEN '부산항'
        ELSE T.TRC_DEPT_PORT_CD
        END AS deptPortNm

        , T.TRC_ARVL_PORT_CD AS arvlPortCd
        , CASE T.TRC_ARVL_PORT_CD
        WHEN 'BUSAN' THEN '부산항'
        WHEN 'KRPUS' THEN '부산항'
        WHEN 'OSAKA' THEN '오사카항'
        ELSE T.TRC_ARVL_PORT_CD
        END AS arvlPortNm

        , T.TRC_NO AS importRequestNo
        , IAN.IAN_NO AS arrivalNoticeNo
        , IR.IR_NO AS customsRequestNo
        , TO_CHAR(NVL(IAN.IAN_REGIST_DT, NVL(T.TRC_RCEPT_DT, T.TRC_RQST_DT)) + 1, 'YYYY-MM-DD') AS eta
        , NVL(IAN.IAN_CURR_LOC, '-') AS currentLoc

        , NVL(IAN.IAN_ARRV_STATUS_CD, 'TRC_ARR_PENDING') AS arrivalStatus
        , CASE NVL(IAN.IAN_ARRV_STATUS_CD, 'TRC_ARR_PENDING')
        WHEN 'TRC_ARR_ARRIVED' THEN '도착'
        WHEN 'ARRIVED' THEN '도착'
        WHEN 'TRC_ARR_IN_TRANSIT' THEN '운송중'
        WHEN 'IN_TRANSIT' THEN '운송중'
        WHEN 'SAILING' THEN '운항중'
        WHEN 'TRC_ARR_DELAYED' THEN '지연'
        WHEN 'DELAYED' THEN '지연'
        WHEN 'TRC_ARR_PENDING' THEN '입항전'
        WHEN 'PENDING' THEN '입항전'
        WHEN 'BEFORE_ARRIVAL' THEN '입항전'
        ELSE NVL(IAN.IAN_ARRV_STATUS_CD, '입항전')
        END AS arrivalStatusNm

        , NVL(IAN.IAN_SEND_STTS_CD, 'TRC_NTC_NSENT') AS noticeStatus
        , CASE NVL(IAN.IAN_SEND_STTS_CD, 'TRC_NTC_NSENT')
        WHEN 'TRC_NTC_SENT' THEN '발송완료'
        WHEN 'SENT' THEN '발송완료'
        ELSE '미발송'
        END AS noticeStatusNm
        , IAN.IAN_SEND_DT AS noticeSendDt
        , IAN.IAN_NO AS arrivalNoticeReqNo

        , T.TRC_STATUS_CD AS statusCd
        , CASE T.TRC_STATUS_CD
        WHEN 'TRC_WAIT' THEN '접수대기'
        WHEN 'TRC_DONE' THEN '접수완료'
        WHEN 'TRC_REJECT' THEN '접수반려'
        ELSE T.TRC_STATUS_CD
        END AS statusNm

        FROM TRAN_RCP T

        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO

        LEFT JOIN IMP_RQST IR
        ON IR.IR_NO = REGEXP_REPLACE(
        T.TRC_NO,
        '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
        '\1-\2\3\4-\5'
        )

        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        M0.*,
        ROW_NUMBER() OVER (
        PARTITION BY M0.ICM_GG_NO
        ORDER BY M0.ICM_SBMSN_DT DESC NULLS LAST, M0.ICM_NO DESC
        ) AS RN
        FROM IMP_CARGO_MANIFEST M0
        )
        WHERE RN = 1
        ) M
        ON M.ICM_GG_NO = T.TRC_TFG_NO

        LEFT JOIN IMP_ARRV_NTC IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        OR IAN.IAN_TRC_NO = IR.IR_NO

        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID

        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        ORDER BY T.TRC_RCEPT_DT DESC NULLS LAST, T.TRC_NO DESC
    </select>

    <select id="selectImpArrivalNoticeTargetNo" resultType="string">
        /*
        * 도착통지서 발송 기준 운송의뢰번호 찾기.
        * 화면에서는 TRC_NO, IR_NO, IAN_NO, WIR_NO, MBL/HBL, 화물그룹번호가 섞여 넘어올 수 있다.
        * 그래서 가능한 연결값을 모두 받아 최종 기준값은 TRAN_RCP.TRC_NO로 통일한다.
        */
        SELECT MAX(T.TRC_NO)
        FROM TRAN_RCP T
        LEFT JOIN IMP_RQST IR
        ON (
        IR.IR_NO = REGEXP_REPLACE(
            T.TRC_NO,
            '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
            '\1-\2\3\4-\5'
        )
        OR IR.IR_TFG_NO = T.TRC_TFG_NO
        )
        LEFT JOIN IMP_ARRV_NTC IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        OR IAN.IAN_TRC_NO = IR.IR_NO
        OR IAN.IAN_OWR_ID = IR.IR_NO
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_GG_NO = T.TRC_TFG_NO
        LEFT JOIN IMP_CARGO_MANIFEST M
        ON M.ICM_GG_NO = T.TRC_TFG_NO
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (
        T.TRC_NO = #{reqNo}
        OR IR.IR_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo}
        OR IAN.IAN_OWR_ID = #{reqNo}
        OR W.WIR_NO = #{reqNo}
        OR TO_CHAR(M.ICM_NO) = #{reqNo}
        OR M.ICM_MBL_NO = #{reqNo}
        OR M.ICM_HBL_NO = #{reqNo}
        OR BI.BI_MBL_NO = #{reqNo}
        OR BI.BI_HBL_NO = #{reqNo}
        OR T.TRC_TFG_NO = TO_NUMBER(#{reqNo} DEFAULT NULL ON CONVERSION ERROR)
        OR M.ICM_GG_NO = TO_NUMBER(#{reqNo} DEFAULT NULL ON CONVERSION ERROR)
        OR REGEXP_REPLACE(
        T.TRC_NO,
        '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
        '\1-\2\3\4-\5'
        ) = #{reqNo}
        )
    </select>

    <update id="updateImpArrivalNoticeSent">
        /*
        * 도착통지서 발송 처리.
        * - MERGE 금지 규칙 때문에 UPDATE 먼저 실행하고, 없으면 INSERT 한다.
        * - FK_IMP_ARRV_NTC_IR 구조상 IAN_OWR_ID에는 반드시 IMP_RQST.IR_NO를 넣는다.
        * - 기존 데이터가 IAN_TRC_NO = TRC_NO 형태로 들어간 경우도 다시 발송 성공으로 처리한다.
        */
        BEGIN
        UPDATE IMP_ARRV_NTC IAN
        SET IAN.IAN_SEND_STTS_CD = 'TRC_NTC_SENT'
        , IAN.IAN_SEND_DT = NVL(IAN.IAN_SEND_DT, SYSDATE)
        , IAN.IAN_CURR_LOC = NVL(IAN.IAN_CURR_LOC, (
        SELECT MAX(T2.TRC_ARVL_PORT_CD)
        FROM TRAN_RCP T2
        LEFT JOIN IMP_RQST IR2
        ON (
        IR2.IR_NO = REGEXP_REPLACE(
            T2.TRC_NO,
            '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
            '\1-\2\3\4-\5'
        )
        OR IR2.IR_TFG_NO = T2.TRC_TFG_NO
        )
        WHERE T2.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (IAN.IAN_TRC_NO = T2.TRC_NO
        OR IAN.IAN_TRC_NO = IR2.IR_NO
        OR IAN.IAN_OWR_ID = IR2.IR_NO)
        ))
        , IAN.IAN_ARRV_STATUS_CD = NVL(IAN.IAN_ARRV_STATUS_CD, 'TRC_ARR_PENDING')
        , IAN.IAN_OWR_ID = NVL((
        SELECT MAX(IR3.IR_NO)
        FROM TRAN_RCP T3
        INNER JOIN IMP_RQST IR3
        ON (
        IR3.IR_NO = REGEXP_REPLACE(
            T3.TRC_NO,
            '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
            '\1-\2\3\4-\5'
        )
        OR IR3.IR_TFG_NO = T3.TRC_TFG_NO
        )
        WHERE T3.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (IAN.IAN_TRC_NO = T3.TRC_NO
        OR IAN.IAN_TRC_NO = IR3.IR_NO
        OR IAN.IAN_OWR_ID = IR3.IR_NO)
        ), IAN.IAN_OWR_ID)
        WHERE EXISTS (
        SELECT 1
        FROM TRAN_RCP T
        LEFT JOIN IMP_RQST IR
        ON (
        IR.IR_NO = REGEXP_REPLACE(
            T.TRC_NO,
            '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
            '\1-\2\3\4-\5'
        )
        OR IR.IR_TFG_NO = T.TRC_TFG_NO
        )
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_GG_NO = T.TRC_TFG_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (T.TRC_NO = #{reqNo}
        OR IR.IR_NO = #{reqNo}
        OR W.WIR_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo}
        OR IAN.IAN_OWR_ID = #{reqNo})
        AND (IAN.IAN_TRC_NO = T.TRC_NO
        OR IAN.IAN_TRC_NO = IR.IR_NO
        OR IAN.IAN_OWR_ID = IR.IR_NO)
        );

        IF SQL%ROWCOUNT = 0 THEN
        INSERT INTO IMP_ARRV_NTC (
        IAN_NO,
        IAN_TRC_NO,
        IAN_OWR_ID,
        IAN_REGIST_DT,
        IAN_CURR_LOC,
        IAN_ARRV_STATUS_CD,
        IAN_SEND_STTS_CD,
        IAN_SEND_DT
        )
        SELECT
        'IAN-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' || LPAD(
        NVL((
        SELECT MAX(TO_NUMBER(REGEXP_SUBSTR(IAN2.IAN_NO, '[0-9]+$')))
        FROM IMP_ARRV_NTC IAN2
        WHERE REGEXP_LIKE(IAN2.IAN_NO, '^IAN-[0-9]{8}-[0-9]+$')
        ), 0) + 1,
        4,
        '0'
        ),
        T.TRC_NO,
        IR.IR_NO,
        SYSDATE,
        T.TRC_ARVL_PORT_CD,
        'TRC_ARR_PENDING',
        'TRC_NTC_SENT',
        SYSDATE
        FROM TRAN_RCP T
        INNER JOIN IMP_RQST IR
        ON (
        IR.IR_NO = REGEXP_REPLACE(
            T.TRC_NO,
            '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
            '\1-\2\3\4-\5'
        )
        OR IR.IR_TFG_NO = T.TRC_TFG_NO
        )
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_GG_NO = T.TRC_TFG_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (T.TRC_NO = #{reqNo}
        OR IR.IR_NO = #{reqNo}
        OR W.WIR_NO = #{reqNo})
        AND NOT EXISTS (
        SELECT 1
        FROM IMP_ARRV_NTC IAN
        WHERE IAN.IAN_TRC_NO = T.TRC_NO
        OR IAN.IAN_TRC_NO = IR.IR_NO
        OR IAN.IAN_OWR_ID = IR.IR_NO
        );
        END IF;
        END;
    </update>

    <select id="selectImpArrivalNoticeNo" resultType="string">
        /*
        * 도착통지서 번호 재조회.
        * 발송 후 success=false가 뜨던 원인은 기존 조회가 IAN_TRC_NO 위주라서
        * IAN_OWR_ID = IR_NO 형태의 데이터나 화면에서 넘어온 IAN_NO/IR_NO를 놓쳤기 때문이다.
        */
        SELECT MAX(IAN.IAN_NO)
        FROM IMP_ARRV_NTC IAN
        WHERE IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo}
        OR IAN.IAN_OWR_ID = #{reqNo}
        OR EXISTS (
        SELECT 1
        FROM TRAN_RCP T
        LEFT JOIN IMP_RQST IR
        ON (
        IR.IR_NO = REGEXP_REPLACE(
            T.TRC_NO,
            '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
            '\1-\2\3\4-\5'
        )
        OR IR.IR_TFG_NO = T.TRC_TFG_NO
        )
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_GG_NO = T.TRC_TFG_NO
        LEFT JOIN IMP_CARGO_MANIFEST M
        ON M.ICM_GG_NO = T.TRC_TFG_NO
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (
        T.TRC_NO = #{reqNo}
        OR IR.IR_NO = #{reqNo}
        OR W.WIR_NO = #{reqNo}
        OR TO_CHAR(M.ICM_NO) = #{reqNo}
        OR M.ICM_MBL_NO = #{reqNo}
        OR M.ICM_HBL_NO = #{reqNo}
        OR BI.BI_MBL_NO = #{reqNo}
        OR BI.BI_HBL_NO = #{reqNo}
        OR T.TRC_TFG_NO = TO_NUMBER(#{reqNo} DEFAULT NULL ON CONVERSION ERROR)
        OR M.ICM_GG_NO = TO_NUMBER(#{reqNo} DEFAULT NULL ON CONVERSION ERROR)
        OR REGEXP_REPLACE(
        T.TRC_NO,
        '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
        '\1-\2\3\4-\5'
        ) = #{reqNo}
        )
        AND (
        IAN.IAN_TRC_NO = T.TRC_NO
        OR IAN.IAN_TRC_NO = IR.IR_NO
        OR IAN.IAN_OWR_ID = IR.IR_NO
        OR IAN.IAN_NO = #{reqNo}
        )
        )
    </select>

    <select id="retriveImpUnloadingInList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        T.TRC_NO                                        AS trcNo
        , W.WIR_NO                                        AS wirNo
        , W.WIR_GG_NO                                     AS ggNo
        , T.TRC_OWR_ID                                    AS ownerId
        , O.OWR_NM                                        AS ownerNm
        , T.TRC_ITEM_CTGRY_NM                            AS itemCategory
        , T.TRC_ITEM_CTGRY_NM                            AS itemNm
        , T.TRC_ITEM_CTGRY_NM                            AS frghtIemNm
        , W.WIR_WM_ID                                     AS bondedManagerId
        , WM.WM_NM                                        AS bondedManagerNm
        , WM.WM_NM                                        AS warehouseManagerNm
        , WH.WH_NM                                        AS whNm
        , WH.WH_NM                                        AS warehouseNm
        , W.WIR_WZ_NO                                     AS bondedZoneNo
        , NVL(NVL(WZ.WZ_NM, WM.WM_DETAIL_ADRES), TO_CHAR(W.WIR_WZ_NO)) AS warehouseZoneNm
        , TO_CHAR(W.WIR_IN_PLAN_DT, 'YYYY-MM-DD HH24:MI') AS inPlanDt
        , W.WIR_RQST_CN                                AS remark
        , W.WIR_RQST_CN                                AS wirRmrk
        , W.WIR_RQST_CN                                AS requestCn
        , W.WIR_CARGO_MGMT_NO                             AS cargoMgmtNo
        , NVL(W.WIR_INCO_TERMS_CD, T.TRC_INCO_TERMS_CD) AS incoTermsCd
        , W.WIR_INVOICE_NO                                AS invoiceNo
        , BI.BI_MBL_NO                                    AS mblNo
        , BI.BI_HBL_NO                                    AS hblNo
        , SR_WH.SRI_REQ_CN                              AS rejectReason
        , SR_WH.SRI_REQ_CN                              AS suppReqCn
        , CASE
        /* 창고가 SUPP_RQST로 보완요청/보완완료를 관리하므로 WH_IN_RPT보다 보완 상태를 우선 표시 */
        WHEN W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN 'IN_DONE'
        WHEN SR_WH.SR_STATUS_CD = 'REQ' THEN 'REQ_FIX'
        WHEN SR_WH.SR_STATUS_CD = 'SUB' THEN 'REQ_SENT'
        WHEN SR_WH.SR_STATUS_CD = 'APR' THEN 'IN_DONE'
        WHEN W.WIR_STATUS_CD = 'REQ_FIX' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN 'REQ_FIX'
        WHEN W.WIR_STATUS_CD = 'REQ_SENT' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN 'REQ_SENT'
        WHEN W.WIR_STATUS_CD IN ('REJECT', 'REJECTED') OR W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED') THEN 'REJECT'
        ELSE W.WIR_STATUS_CD
        END                                             AS statusCd
        , W.WIR_WH_REPLY_STATUS_CD                      AS warehouseReplyStatusCd
        , W.WIR_WH_REPLY_STATUS_CD                      AS wirWhReplyStatusCd
        , CASE
        WHEN W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN '입고완료'
        WHEN SR_WH.SR_STATUS_CD = 'REQ' THEN '보완요청'
        WHEN SR_WH.SR_STATUS_CD = 'SUB' THEN '보완제출완료'
        WHEN SR_WH.SR_STATUS_CD = 'APR' THEN '입고완료'
        WHEN W.WIR_STATUS_CD = 'REQ_FIX' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN '보완요청'
        WHEN W.WIR_STATUS_CD = 'REQ_SENT' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN '보완제출완료'
        WHEN W.WIR_STATUS_CD IN ('REJECT', 'REJECTED') OR W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED') THEN '반려'
        WHEN W.WIR_STATUS_CD = 'WAIT' OR W.WIR_WH_REPLY_STATUS_CD = 'WAIT' THEN '입고요청'
        WHEN W.WIR_STATUS_CD IS NULL AND W.WIR_WH_REPLY_STATUS_CD IS NULL THEN NULL
        ELSE '입고대기'
        END                                             AS statusNm
        , W.WIR_IO_SE_CD                                  AS ioSeCd
        , MIN(C.CG_NO)                                    AS cgNo
        , MIN(C.GOODS_NO)                                 AS goodsNo
        , MIN(G.GOODS_NAME)                               AS goodsName
        , COUNT(C.CG_NO)                                  AS goodsCnt
        , NVL(SUM(C.CG_QTY), 0)                           AS qty
        , NVL(SUM(C.CG_QTY), 0)                           AS totalQty
        , NVL(MAX(C.CG_PRICE), 0)                         AS price
        , NVL(SUM(C.CG_TOTAL_PRICE), 0)                   AS goodsTotalPrice
        , NVL(SUM(C.CG_WEIGHT), 0)                        AS weight
        , NVL(SUM(C.CG_WEIGHT), 0)                        AS totalWeight
        , NVL(SUM(C.CG_TOTAL_PRICE), 0)                   AS summaryTotalPrice
        , MIN(C.CG_ORIGIN)                                AS origin
        FROM TRAN_RCP T

        LEFT JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        LEFT JOIN OWNER O
        ON T.TRC_OWR_ID = O.OWR_ID
        LEFT JOIN CUSTOMS_GOODS C
        ON C.GG_NO = T.TRC_TFG_NO
        LEFT JOIN GOODS G
        ON C.GOODS_NO = G.GOODS_NO
        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = W.WIR_WM_ID
        LEFT JOIN (
        SELECT
        Z.WM_ID
        , MIN(Z.WZ_NO) AS WZ_NO
        FROM WAREHOUSE_ZONE Z
        WHERE NVL(Z.WZ_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_STATUS_CD, 'ACTIVE') = 'ACTIVE'
        GROUP BY Z.WM_ID
        ) WZ_BY_WM
        ON WZ_BY_WM.WM_ID = W.WIR_WM_ID
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = NVL(W.WIR_WZ_NO, WZ_BY_WM.WZ_NO)
        LEFT JOIN WAREHOUSE WH
        ON WH.WH_NO = WZ.WZ_WH_NO
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        LEFT JOIN (
        SELECT
        SR_NO
        , SR_REF_NO
        , SR_STATUS_CD
        , SR_REQ_DT
        , SRI_REQ_CN
        FROM (
        SELECT
        SR.SR_NO
        , SR.SR_REF_NO
        , SR.SR_STATUS_CD
        , SR.SR_REQ_DT
        , CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)) AS SRI_REQ_CN
        , ROW_NUMBER() OVER (
        PARTITION BY SR.SR_REF_NO
        ORDER BY SR.SR_REQ_DT DESC, SR.SR_NO DESC
        ) AS RN
        FROM SUPP_RQST SR
        WHERE SR.SR_REF_BIZ_CD = 'WH_IN_RPT'
        AND SR.RECEIVER_TY_CD IN ('TRC', 'WHM', 'TRANSPORT', 'TRANSPORT_MANAGER', 'WAREHOUSE_MANAGER')
        AND SR.SR_STATUS_CD IN ('REQ', 'SUB', 'APR')
        AND EXISTS (
        SELECT 1
        FROM WH_IN_RPT WX
        WHERE WX.WIR_IO_SE_CD = 'IMP'
        AND (
        WX.WIR_WM_ID = SR.SENDER_ID
        OR WX.WIR_WM_ID = SR.RECEIVER_ID
        )
        AND (
        WX.WIR_NO = SR.SR_REF_NO
        OR EXISTS (
        SELECT 1
        FROM TRAN_RCP TX
        WHERE TX.TRC_NO = SR.SR_REF_NO
        AND TX.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND TX.TRC_TFG_NO = WX.WIR_GG_NO
        )
        )
        )
        )
        WHERE RN = 1
        ) SR_WH
        ON (SR_WH.SR_REF_NO = W.WIR_NO OR SR_WH.SR_REF_NO = T.TRC_NO)
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        AND (
        W.WIR_NO IS NULL
        OR W.WIR_STATUS_CD IS NULL
        OR W.WIR_STATUS_CD IN ('WAIT', 'REQ_FIX', 'REQ_SENT', 'IN_DONE', 'REJECT', 'REJECTED')
        OR W.WIR_WH_REPLY_STATUS_CD IS NULL
        OR W.WIR_WH_REPLY_STATUS_CD IN ('WAIT', 'REQ_FIX', 'REQ_SENT', 'IN_DONE', 'REJECT', 'REJECTED')
        )
        GROUP BY
        T.TRC_NO
        , W.WIR_NO
        , W.WIR_GG_NO
        , T.TRC_OWR_ID
        , O.OWR_NM
        , T.TRC_ITEM_CTGRY_NM
        , W.WIR_WM_ID
        , WM.WM_NM
        , WH.WH_NM
        , W.WIR_WZ_NO
        , WZ.WZ_NM
        , WM.WM_DETAIL_ADRES
        , W.WIR_IN_PLAN_DT
        , W.WIR_RQST_CN
        , W.WIR_CARGO_MGMT_NO
        , W.WIR_INCO_TERMS_CD
        , T.TRC_INCO_TERMS_CD
        , W.WIR_INVOICE_NO
        , BI.BI_MBL_NO
        , BI.BI_HBL_NO
        , W.WIR_STATUS_CD
        , W.WIR_WH_REPLY_STATUS_CD
        , W.WIR_IO_SE_CD
        , SR_WH.SR_STATUS_CD
        , SR_WH.SRI_REQ_CN
        ORDER BY W.WIR_IN_PLAN_DT DESC, W.WIR_NO DESC
    </select>

    <!-- 수입 보세구역 입고관리 상세 기본정보 조회 -->
    <select id="selectImpUnloadingInDetail" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        T.TRC_NO                                        AS trcNo
        , W.WIR_NO                                        AS wirNo
        , W.WIR_GG_NO                                     AS ggNo
        , T.TRC_OWR_ID                                    AS ownerId
        , O.OWR_NM                                        AS ownerNm
        , T.TRC_ITEM_CTGRY_NM                            AS itemCategory
        , T.TRC_ITEM_CTGRY_NM                            AS itemNm
        , T.TRC_ITEM_CTGRY_NM                            AS frghtIemNm
        , W.WIR_WM_ID                                     AS bondedManagerId
        , WH.WH_NO                                        AS whNo
        , WH.WH_NO                                        AS warehouseNo
        , WH.WH_NM                                        AS whNm
        , WH.WH_NM                                        AS warehouseNm
        , WM.WM_NM                                        AS bondedManagerNm
        , WM.WM_NM                                        AS warehouseManagerNm
        , W.WIR_WZ_NO                                     AS bondedZoneNo
        , NVL(NVL(WZ.WZ_NM, WM.WM_DETAIL_ADRES), TO_CHAR(W.WIR_WZ_NO)) AS warehouseZoneNm
        , TO_CHAR(W.WIR_IN_PLAN_DT, 'YYYY-MM-DD HH24:MI') AS inPlanDt
        , W.WIR_RQST_CN                                   AS requestCn
        , W.WIR_CARGO_MGMT_NO                             AS cargoMgmtNo
        , NVL(W.WIR_INCO_TERMS_CD, T.TRC_INCO_TERMS_CD) AS incoTermsCd
        , W.WIR_INVOICE_NO                                AS invoiceNo
        , W.WIR_INVOICE_YMD                               AS requestDt
        , W.WIR_RQST_CN                                   AS rejectMemo
        , BI.BI_MBL_NO                                    AS mblNo
        , BI.BI_HBL_NO                                    AS hblNo
        , SR_WH.SRI_REQ_CN                              AS rejectReason
        , SR_WH.SRI_REQ_CN                              AS suppReqCn
        , CASE
        /* 창고가 SUPP_RQST로 보완요청/보완완료를 관리하므로 WH_IN_RPT보다 보완 상태를 우선 표시 */
        WHEN W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN 'IN_DONE'
        WHEN SR_WH.SR_STATUS_CD = 'REQ' THEN 'REQ_FIX'
        WHEN SR_WH.SR_STATUS_CD = 'SUB' THEN 'REQ_SENT'
        WHEN SR_WH.SR_STATUS_CD = 'APR' THEN 'IN_DONE'
        WHEN W.WIR_STATUS_CD = 'REQ_FIX' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN 'REQ_FIX'
        WHEN W.WIR_STATUS_CD = 'REQ_SENT' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN 'REQ_SENT'
        WHEN W.WIR_STATUS_CD IN ('REJECT', 'REJECTED') OR W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED') THEN 'REJECT'
        ELSE W.WIR_STATUS_CD
        END                                             AS statusCd
        , W.WIR_WH_REPLY_STATUS_CD                      AS warehouseReplyStatusCd
        , W.WIR_WH_REPLY_STATUS_CD                      AS wirWhReplyStatusCd
        , CASE
        WHEN W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN '입고완료'
        WHEN SR_WH.SR_STATUS_CD = 'REQ' THEN '보완요청'
        WHEN SR_WH.SR_STATUS_CD = 'SUB' THEN '보완제출완료'
        WHEN SR_WH.SR_STATUS_CD = 'APR' THEN '입고완료'
        WHEN W.WIR_STATUS_CD = 'REQ_FIX' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN '보완요청'
        WHEN W.WIR_STATUS_CD = 'REQ_SENT' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN '보완제출완료'
        WHEN W.WIR_STATUS_CD IN ('REJECT', 'REJECTED') OR W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED') THEN '반려'
        WHEN W.WIR_STATUS_CD = 'WAIT' OR W.WIR_WH_REPLY_STATUS_CD = 'WAIT' THEN '입고요청'
        WHEN W.WIR_STATUS_CD IS NULL AND W.WIR_WH_REPLY_STATUS_CD IS NULL THEN NULL
        ELSE '입고대기'
        END                                             AS statusNm
        , W.WIR_IO_SE_CD                                  AS ioSeCd
        , GOODS_SUM.CG_NO                                AS cgNo
        , GOODS_SUM.GOODS_NO                             AS goodsNo
        , GOODS_SUM.GOODS_NAME                           AS goodsName
        , GOODS_SUM.GOODS_NAME                           AS itemNm
        , GOODS_SUM.QTY                                  AS qty
        , GOODS_SUM.QTY                                  AS totalQty
        , GOODS_SUM.PRICE                                AS price
        , GOODS_SUM.GOODS_TOTAL_PRICE                    AS goodsTotalPrice
        , GOODS_SUM.GOODS_TOTAL_PRICE                    AS summaryTotalPrice
        , GOODS_SUM.WEIGHT                               AS weight
        , GOODS_SUM.WEIGHT                               AS totalWeight
        , GOODS_SUM.ORIGIN                               AS origin
        FROM WH_IN_RPT W
        INNER JOIN TRAN_RCP T
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')

        LEFT JOIN OWNER O
        ON T.TRC_OWR_ID = O.OWR_ID
        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = W.WIR_WM_ID
        LEFT JOIN (
        SELECT
        Z.WM_ID
        , MIN(Z.WZ_NO) AS WZ_NO
        FROM WAREHOUSE_ZONE Z
        WHERE NVL(Z.WZ_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_STATUS_CD, 'ACTIVE') = 'ACTIVE'
        GROUP BY Z.WM_ID
        ) WZ_BY_WM
        ON WZ_BY_WM.WM_ID = W.WIR_WM_ID
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = NVL(W.WIR_WZ_NO, WZ_BY_WM.WZ_NO)
        LEFT JOIN WAREHOUSE WH
        ON WH.WH_NO = WZ.WZ_WH_NO
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        LEFT JOIN (
        SELECT
        SR_NO
        , SR_REF_NO
        , SR_STATUS_CD
        , SR_REQ_DT
        , SRI_REQ_CN
        FROM (
        SELECT
        SR.SR_NO
        , SR.SR_REF_NO
        , SR.SR_STATUS_CD
        , SR.SR_REQ_DT
        , CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)) AS SRI_REQ_CN
        , ROW_NUMBER() OVER (
        PARTITION BY SR.SR_REF_NO
        ORDER BY SR.SR_REQ_DT DESC, SR.SR_NO DESC
        ) AS RN
        FROM SUPP_RQST SR
        WHERE SR.SR_REF_BIZ_CD = 'WH_IN_RPT'
        AND SR.RECEIVER_TY_CD IN ('TRC', 'WHM', 'TRANSPORT', 'TRANSPORT_MANAGER', 'WAREHOUSE_MANAGER')
        AND SR.SR_STATUS_CD IN ('REQ', 'SUB', 'APR')
        AND EXISTS (
        SELECT 1
        FROM WH_IN_RPT WX
        WHERE WX.WIR_IO_SE_CD = 'IMP'
        AND (
        WX.WIR_WM_ID = SR.SENDER_ID
        OR WX.WIR_WM_ID = SR.RECEIVER_ID
        )
        AND (
        WX.WIR_NO = SR.SR_REF_NO
        OR EXISTS (
        SELECT 1
        FROM TRAN_RCP TX
        WHERE TX.TRC_NO = SR.SR_REF_NO
        AND TX.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND TX.TRC_TFG_NO = WX.WIR_GG_NO
        )
        )
        )
        )
        WHERE RN = 1
        ) SR_WH
        ON (SR_WH.SR_REF_NO = W.WIR_NO OR SR_WH.SR_REF_NO = T.TRC_NO)
        LEFT JOIN (
        SELECT
        CG.GG_NO
        , MIN(CG.CG_NO)                  AS CG_NO
        , MIN(CG.GOODS_NO)               AS GOODS_NO
        , MIN(G.GOODS_NAME)              AS GOODS_NAME
        , NVL(SUM(CG.CG_QTY), 0)         AS QTY
        , NVL(MAX(CG.CG_PRICE), 0)       AS PRICE
        , NVL(SUM(CG.CG_TOTAL_PRICE), 0) AS GOODS_TOTAL_PRICE
        , NVL(SUM(CG.CG_WEIGHT), 0)      AS WEIGHT
        , MIN(CG.CG_ORIGIN)              AS ORIGIN
        FROM CUSTOMS_GOODS CG
        LEFT JOIN GOODS G
        ON G.GOODS_NO = CG.GOODS_NO
        GROUP BY CG.GG_NO
        ) GOODS_SUM
        ON GOODS_SUM.GG_NO = W.WIR_GG_NO
        WHERE W.WIR_NO = #{wirNo}
        AND W.WIR_IO_SE_CD = 'IMP'
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        AND (
        (W.WIR_STATUS_CD IS NULL OR W.WIR_STATUS_CD IN ('WAIT', 'REQ_FIX', 'REQ_SENT', 'IN_DONE', 'REJECT', 'REJECTED'))
        AND (
        W.WIR_NO IS NULL
        OR W.WIR_STATUS_CD IS NULL
        OR W.WIR_STATUS_CD IN ('WAIT', 'REQ_FIX', 'REQ_SENT', 'IN_DONE', 'REJECT', 'REJECTED')
        OR W.WIR_WH_REPLY_STATUS_CD IS NULL
        OR W.WIR_WH_REPLY_STATUS_CD IN ('WAIT', 'REQ_FIX', 'REQ_SENT', 'IN_DONE', 'REJECT', 'REJECTED')
        )
    </select>

    <!-- 수입 보세구역 입고관리 상세 화물정보 조회 -->
    <select id="retriveImpUnloadingInGoodsList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        C.CG_NO           AS cgNo
        , C.GOODS_NO        AS goodsNo
        , G.GOODS_NAME      AS goodsName
        , G.GOODS_NAME      AS itemNm
        , C.GG_NO           AS ggNo
        , C.CG_QTY          AS qty
        , C.CG_PRICE        AS price
        , C.CG_TOTAL_PRICE  AS goodsTotalPrice
        , C.CG_WEIGHT       AS weight
        , C.CG_ORIGIN       AS origin
        FROM CUSTOMS_GOODS C
        LEFT JOIN GOODS G
        ON C.GOODS_NO = G.GOODS_NO
        WHERE C.GG_NO = #{ggNo}
        ORDER BY C.CG_NO
    </select>

    <!-- 수입 보세구역 입고관리 전달대상 창고관리자 목록 조회 -->
    <select id="retriveImportWarehouseManagerList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        W.WH_NO AS whNo
        , W.WH_NO AS warehouseNo
        , W.WH_NM AS whNm
        , W.WH_NM AS warehouseNm

        , WZ.WZ_NO AS wzNo
        , WZ.WZ_NO AS bondedZoneNo
        , WZ.WZ_NO AS warehouseZoneNo
        , WZ.WZ_NM AS wzNm
        , WZ.WZ_NM AS warehouseZoneNm

        , WM.WM_ID AS wmId
        , WM.WM_ID AS bondedManagerId
        , WM.WM_ID AS warehouseManagerId
        , WM.WM_NM AS wmNm
        , WM.WM_NM AS bondedManagerNm
        , WM.WM_NM AS warehouseManagerNm

        FROM WAREHOUSE_ZONE WZ
        JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = WZ.WM_ID
        JOIN WAREHOUSE W
        ON W.WH_NO = WZ.WZ_WH_NO

        WHERE NVL(WM.WM_USE_YN,'Y')='Y'
        AND NVL(WZ.WZ_USE_YN,'Y')='Y'

        ORDER BY W.WH_NM, WZ.WZ_NM, WM.WM_NM
    </select>

    <!-- 수입 보세구역 입고관리 전달 처리: 운송담당자가 창고로 입고요청 발송할 때만 WAIT/WAIT(입고요청)으로 만든다. -->
    <!-- 수입 보세구역 입고관리 전달 처리: 운송담당자가 창고로 입고요청 발송할 때만 WAIT/WAIT(입고요청)으로 만든다. -->
    <update id="updateImpUnloadingInDelivered">
        /*
        * 입고요청 발송 처리.
        * - MERGE 금지 규칙 때문에 UPDATE 후 SQL%ROWCOUNT=0이면 INSERT 한다.
        * - 최초 화면에서는 상태값을 비워두고, 이 쿼리가 실행될 때만 WAIT/WAIT로 변경한다.
        * - 입고요청일은 사용자가 입력하지 않고 발송 시점(SYSDATE)으로 저장한다.
        * - 화면 입력값은 창고담당자/보세구역/요청사항만 저장하고, 인코텀즈는 TRAN_RCP에서 조회한다.
        */
        BEGIN
        UPDATE WH_IN_RPT W
        SET W.WIR_STATUS_CD = 'WAIT'
        , W.WIR_WH_REPLY_STATUS_CD = 'WAIT'
        , W.WIR_WM_ID = #{wmId}
        , W.WIR_WZ_NO = #{wzNo}
        , W.WIR_IN_PLAN_DT = SYSDATE
        , W.WIR_RQST_CN = #{remark}
        , W.WIR_CARGO_MGMT_NO = NVL(W.WIR_CARGO_MGMT_NO, 'CARGO-' || #{trcNo})
        , W.WIR_INCO_TERMS_CD = NVL(W.WIR_INCO_TERMS_CD, (
        SELECT T.TRC_INCO_TERMS_CD
        FROM TRAN_RCP T
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        ))
        WHERE W.WIR_IO_SE_CD = 'IMP'
        AND (
        W.WIR_NO = #{wirNo}
        OR W.WIR_GG_NO = (
        SELECT T.TRC_TFG_NO
        FROM TRAN_RCP T
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        )
        );

        IF SQL%ROWCOUNT = 0 THEN
        INSERT INTO WH_IN_RPT (
        WIR_NO,
        WIR_GG_NO,
        WIR_OWR_ID,
        WIR_WM_ID,
        WIR_WZ_NO,
        WIR_IN_PLAN_DT,
        WIR_STATUS_CD,
        WIR_WH_REPLY_STATUS_CD,
        WIR_CARGO_MGMT_NO,
        WIR_INCO_TERMS_CD,
        WIR_RQST_CN,
        WIR_OWR_NM,
        WIR_IO_SE_CD
        )
        SELECT
        REGEXP_REPLACE(
        T.TRC_NO,
        '-[0-9]+$',
        '-' || LPAD(
        NVL((
        SELECT MAX(TO_NUMBER(REGEXP_SUBSTR(W3.WIR_NO, '[0-9]+$')))
        FROM WH_IN_RPT W3
        WHERE W3.WIR_IO_SE_CD = 'IMP'
        AND REGEXP_LIKE(W3.WIR_NO, '^IMP-[0-9]{4}-[0-9]{4}-[0-9]+$')
        ), 9000) + 1,
        4,
        '0'
        )
        ) AS WIR_NO,
        COALESCE(
        (
        SELECT MAX(CG.GG_NO)
        FROM CUSTOMS_GOODS CG
        WHERE CG.GG_NO = IR.IR_GG_NO
        ),
        (
        SELECT MAX(CG.GG_NO)
        FROM CUSTOMS_GOODS CG
        WHERE CG.GG_NO = T.TRC_TFG_NO
        )
        ),
        T.TRC_OWR_ID,
        #{wmId},
        #{wzNo},
        SYSDATE,
        'WAIT',
        'WAIT',
        'CARGO-' || T.TRC_NO,
        T.TRC_INCO_TERMS_CD,
        #{remark},
        O.OWR_NM,
        'IMP'
        FROM TRAN_RCP T
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT');
        END IF;
        END;
    </update>

    <!-- 보완제출완료 처리: 창고의 보완요청(REQ_FIX/REQ) 이후 운송담당자가 보완자료를 제출할 때만 REQ_SENT로 변경한다. -->
    <update id="updateImpUnloadingInSupplementSubmitted">
        BEGIN
        UPDATE SUPP_RQST SR
        SET
        SR.SR_STATUS_CD = 'SUB'
        , SR.SR_SUBMIT_DT = SYSDATE
        WHERE SR.SR_REF_BIZ_CD = 'WH_IN_RPT'
        AND SR.RECEIVER_TY_CD IN ('TRC', 'WHM', 'TRANSPORT', 'TRANSPORT_MANAGER', 'WAREHOUSE_MANAGER')
        AND SR.SR_STATUS_CD = 'REQ'
        AND SR.SR_REF_NO IN (
        #{wirNo}
        , (
        SELECT MAX(T.TRC_NO)
        FROM WH_IN_RPT W
        INNER JOIN TRAN_RCP T
        ON T.TRC_TFG_NO = W.WIR_GG_NO
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        WHERE W.WIR_NO = #{wirNo}
        AND W.WIR_IO_SE_CD = 'IMP'
        )
        );
        /* SUPP_RQST_ITEM 테이블은 삭제되고 SUPP_RQST로 통합되어 ITEM 상태 업데이트는 제거한다. */

        UPDATE WH_IN_RPT W
        SET W.WIR_STATUS_CD = 'REQ_SENT'
        , W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT'
        WHERE W.WIR_NO = #{wirNo}
        AND W.WIR_IO_SE_CD = 'IMP'
        /* 최초 입고요청(WAIT)은 보완제출완료로 덮어쓰면 안 된다.
        창고가 먼저 보완요청(REQ_FIX)을 보낸 건만 REQ_SENT로 변경한다. */
        AND (
        W.WIR_STATUS_CD = 'REQ_FIX'
        OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX'
        );

        END;
    </update>

    <!-- 수입 적하목록·패킹리스트 비교조회 보조 목록 조회(작성/제출 없음) -->
    <select id="retriveImpManifestList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        /*
        * 운송담당자는 적하목록 작성/제출을 하지 않고 비교조회만 수행한다.
        * 보세구역 입고관리 전 단계이므로 WH_IN_RPT가 아직 없어도 목록에 노출한다.
        * 적하목록 상태/제출완료 표시는 제거하고 비교에 필요한 DB 값만 조회한다.
        */
        SELECT
        NVL(T.TRC_NO, FTCS.TCS_TRC_NO)                      AS trcNo
        , W.WIR_NO                                            AS wirNo
        , W.WIR_NO                                            AS inRptNo
        , NVL(W.WIR_GG_NO, T.TRC_TFG_NO)                      AS ggNo
        , NVL(T.TRC_OWR_ID, W.WIR_OWR_ID)                     AS ownerId
        , NVL(O.OWR_NM, W.WIR_OWR_NM)                         AS ownerNm
        , O.OWR_TELNO                                         AS ownerTelno
        , O.OWR_EMAIL                                         AS ownerEmail
        , T.TRC_TRDR_NM                                       AS buyerNm
        , T.TRC_TRDR_COUNTRY_CD                               AS buyerCountryCd
        , NVL(W.WIR_INVOICE_NO, (
        SELECT MAX(W2.WIR_INVOICE_NO)
        FROM WH_IN_RPT W2
        WHERE W2.WIR_IO_SE_CD = 'IMP'
        AND W2.WIR_GG_NO = T.TRC_TFG_NO
        ))                                                    AS invoiceNo
        , INV_FILE.DFI_ORG_NM                                  AS invoiceFile
        , INV_FILE.DFI_FILE_NO                                  AS invoiceFileNo
        , INV_FILE.DFI_PATH                                    AS invoicePath
        , INV_FILE.DFI_STR_NM                                  AS invoiceStoredName
        , PKG_FILE.DFI_ORG_NM                                  AS packingListFile
        , PKG_FILE.DFI_FILE_NO                                  AS packingListFileNo
        , PKG_FILE.DFI_PATH                                    AS packingListPath
        , PKG_FILE.DFI_STR_NM                                  AS packingListStoredName
        , NVL(W.WIR_CARGO_MGMT_NO, (
        SELECT MAX(W2.WIR_CARGO_MGMT_NO)
        FROM WH_IN_RPT W2
        WHERE W2.WIR_IO_SE_CD = 'IMP'
        AND W2.WIR_GG_NO = T.TRC_TFG_NO
        ))                                                    AS cargoMgmtNo
        , NVL(W.WIR_INCO_TERMS_CD, (
        SELECT MAX(W2.WIR_INCO_TERMS_CD)
        FROM WH_IN_RPT W2
        WHERE W2.WIR_IO_SE_CD = 'IMP'
        AND W2.WIR_GG_NO = T.TRC_TFG_NO
        ))                                                    AS incoTermsCd
        , W.WIR_IO_SE_CD                                      AS ioSeCd
        , W.WIR_STATUS_CD                                     AS warehouseInStatusCd
        , W.WIR_WH_REPLY_STATUS_CD                            AS warehouseReplyStatusCd
        , '입고완료'                                          AS warehouseInStatusNm
        , W.WIR_WZ_NO                                         AS wzNo
        , W.WIR_WZ_NO                                         AS bondedZoneNo
        , NVL(NVL(WZ.WZ_NM, WM.WM_DETAIL_ADRES), TO_CHAR(W.WIR_WZ_NO)) AS warehouseZoneNm
        , W.WIR_WM_ID                                         AS wmId
        , W.WIR_WM_ID                                         AS bondedManagerId
        , WM.WM_NM                                            AS bondedManagerNm
        , NVL(WM.WM_NM, W.WIR_WM_ID)                          AS warehouseManagerNm
        , TO_CHAR(W.WIR_IN_PLAN_DT, 'YYYY-MM-DD')             AS inPlanDt
        , M.ICM_NO                                            AS icmNo
        , M.ICM_NO                                            AS manifestNo
        , NVL(M.ICM_MBL_NO, NVL(BI.BI_MBL_NO, NVL(FB.BI_MBL_NO, NVL(FTCS.TCS_MBL_NO, IR.IR_BL_AWB_NO)))) AS mblNo
        , NVL(M.ICM_HBL_NO, NVL(BI.BI_HBL_NO, NVL(FB.BI_HBL_NO, FTCS.TCS_HBL_NO))) AS hblNo
        , NVL(M.ICM_MBL_NO, NVL(BI.BI_MBL_NO, NVL(FB.BI_MBL_NO, NVL(FTCS.TCS_MBL_NO, IR.IR_BL_AWB_NO)))) AS blNo
        , CASE
        WHEN NVL(M.ICM_HBL_NO, NVL(BI.BI_HBL_NO, NVL(FB.BI_HBL_NO, FTCS.TCS_HBL_NO))) IS NULL THEN NULL
        WHEN LOWER(NVL(M.ICM_HBL_NO, NVL(BI.BI_HBL_NO, NVL(FB.BI_HBL_NO, FTCS.TCS_HBL_NO)))) LIKE '%.pdf' THEN NVL(M.ICM_HBL_NO, NVL(BI.BI_HBL_NO, NVL(FB.BI_HBL_NO, FTCS.TCS_HBL_NO)))
        ELSE NVL(M.ICM_HBL_NO, NVL(BI.BI_HBL_NO, NVL(FB.BI_HBL_NO, FTCS.TCS_HBL_NO))) || '.pdf'
        END                                                 AS requestFile
        , NULL                                                AS carrierNm
        , T.TRC_DEPT_PORT_CD                                  AS deptPortCd
        , CASE T.TRC_DEPT_PORT_CD
        WHEN 'KRPUS' THEN '부산항'
        WHEN 'BUSAN' THEN '부산항'
        ELSE T.TRC_DEPT_PORT_CD
        END                                                 AS deptPortNm
        , T.TRC_ARVL_PORT_CD                                  AS arvlPortCd
        , CASE T.TRC_ARVL_PORT_CD
        WHEN 'KRPUS' THEN '부산항'
        WHEN 'BUSAN' THEN '부산항'
        ELSE T.TRC_ARVL_PORT_CD
        END                                                 AS arvlPortNm
        , IR.IR_ARRV_SCHD_YMD                                 AS eta
        , TRIM(REGEXP_REPLACE(M.ICM_RMRK_CN, ' *\[(WIR_NO|TRC_NO|TFG_NO|MBL_NO):[^]]+\]', '')) AS manifestRemark
        , M.ICM_GG_NO                                        AS manifestTfgNo
        , MF_FILE.DFI_ORG_NM                                  AS manifestPdfFile
        , C.CG_NO                                             AS cgNo
        , C.GOODS_NO                                          AS goodsNo
        , C.GOODS_NAME                                       AS goodsName
        , C.CG_QTY                                            AS qty
        , C.CG_PRICE                                          AS price
        , C.CG_TOTAL_PRICE                                    AS goodsTotalPrice
        , C.CG_WEIGHT                                         AS weight
        , C.CG_ORIGIN                                         AS origin
        FROM TRAN_RCP T
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND (
        W.WIR_OWR_ID = T.TRC_OWR_ID
        OR W.WIR_OWR_ID IS NULL
        )
        LEFT JOIN OWNER O
        ON O.OWR_ID = NVL(T.TRC_OWR_ID, W.WIR_OWR_ID)
        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = W.WIR_WM_ID
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = W.WIR_WZ_NO
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        /* TRAN_RCP와 직접 연결되지 않는 입고건은 정산테이블의 TRC_NO를 통해 B/L을 B/L 단위로 펼친다. */
        LEFT JOIN TRAN_COST_STL FTCS
        ON T.TRC_NO IS NULL
        AND FTCS.TCS_GG_NO = W.WIR_GG_NO
        AND FTCS.TCS_TRC_NO LIKE 'TRC-IMP-%'
        LEFT JOIN BL_ISSU FB
        ON FB.BI_TRE_ID = FTCS.TCS_TRC_NO
        LEFT JOIN IMP_RQST IR
        ON IR.IR_NO = REGEXP_REPLACE(
        NVL(T.TRC_NO, FTCS.TCS_TRC_NO),
        '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
        '\1-\2\3\4-\5'
        )
        LEFT JOIN TACS_FILE_MAP INV_MAP
        ON INV_MAP.TFM_TFG_NO = T.TRC_TFG_NO
        AND (INV_MAP.TFM_DOC_TY_CD = 'INVOICE' OR INV_MAP.TFM_DOC_TY_CD IS NULL)
        LEFT JOIN DOCS_FILE_DATA INV_FILE
        ON INV_FILE.DFI_FILE_NO = INV_MAP.TFM_DFI_NO
        AND INV_FILE.DFI_DEL_YN = 'N'
        AND INV_FILE.DFI_UPLOAD_STTS_CD = 'DONE'
        AND INV_FILE.DFI_DRIVE_FILE_ID IS NOT NULL
        AND (
        INV_MAP.TFM_DOC_TY_CD = 'INVOICE'
        OR LOWER(INV_FILE.DFI_ORG_NM) LIKE '%invoice%'
        OR INV_FILE.DFI_ORG_NM LIKE '%송장%'
        )
        LEFT JOIN TACS_FILE_MAP PKG_MAP
        ON PKG_MAP.TFM_TFG_NO = T.TRC_TFG_NO
        AND (PKG_MAP.TFM_DOC_TY_CD = 'PACKING_LIST' OR PKG_MAP.TFM_DOC_TY_CD IS NULL)
        LEFT JOIN DOCS_FILE_DATA PKG_FILE
        ON PKG_FILE.DFI_FILE_NO = PKG_MAP.TFM_DFI_NO
        AND PKG_FILE.DFI_DEL_YN = 'N'
        AND PKG_FILE.DFI_UPLOAD_STTS_CD = 'DONE'
        AND PKG_FILE.DFI_DRIVE_FILE_ID IS NOT NULL
        AND (
        PKG_MAP.TFM_DOC_TY_CD = 'PACKING_LIST'
        OR LOWER(PKG_FILE.DFI_ORG_NM) LIKE '%packing%'
        OR LOWER(PKG_FILE.DFI_ORG_NM) LIKE '%pack%'
        OR PKG_FILE.DFI_ORG_NM LIKE '%패킹%'
        OR PKG_FILE.DFI_ORG_NM LIKE '%포장%'
        )
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        M0.*,
        ROW_NUMBER() OVER (
        PARTITION BY M0.ICM_GG_NO, M0.ICM_OWR_ID, NVL(M0.ICM_MBL_NO, '#'), NVL(M0.ICM_HBL_NO, '#')
        ORDER BY M0.ICM_SBMSN_DT DESC NULLS LAST, M0.ICM_NO DESC
        ) AS RN
        FROM IMP_CARGO_MANIFEST M0
        )
        WHERE RN = 1
        ) M
        ON M.ICM_GG_NO = NVL(W.WIR_GG_NO, T.TRC_TFG_NO)
        AND M.ICM_OWR_ID = NVL(T.TRC_OWR_ID, W.WIR_OWR_ID)
        AND (
        /* B/L 단위 매칭은 GG_NO만 보지 말고 MBL/HBL까지 같이 본다. */
        (
        NVL(NVL(BI.BI_MBL_NO, FB.BI_MBL_NO), IR.IR_BL_AWB_NO) IS NOT NULL
        AND M.ICM_MBL_NO = NVL(NVL(BI.BI_MBL_NO, FB.BI_MBL_NO), IR.IR_BL_AWB_NO)
        AND (
        NVL(NVL(BI.BI_HBL_NO, FB.BI_HBL_NO), FTCS.TCS_HBL_NO) IS NULL
        OR M.ICM_HBL_NO = NVL(NVL(BI.BI_HBL_NO, FB.BI_HBL_NO), FTCS.TCS_HBL_NO)
        )
        )
        /* 과거 B/L 값 없이 저장된 건만 TRC_NO 비고로 보조 매칭한다. WIR_NO 매칭은 같은 입고건 전체가 제출완료로 보이므로 금지. */
        OR (
        NVL(NVL(BI.BI_MBL_NO, FB.BI_MBL_NO), IR.IR_BL_AWB_NO) IS NULL
        AND NVL(T.TRC_NO, FTCS.TCS_TRC_NO) IS NOT NULL
        AND M.ICM_RMRK_CN LIKE '%[TRC_NO:' || NVL(T.TRC_NO, FTCS.TCS_TRC_NO) || ']%'
        )
        )
        LEFT JOIN (
        SELECT
        FM.TFM_TFG_NO
        , LISTAGG(FD.DFI_ORG_NM, ', ') WITHIN GROUP (ORDER BY FM.TFM_NO) AS DFI_ORG_NM
        FROM TACS_FILE_MAP FM
        INNER JOIN DOCS_FILE_DATA FD
        ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
        AND FD.DFI_DEL_YN = 'N'
        GROUP BY FM.TFM_TFG_NO
        ) MF_FILE
        ON MF_FILE.TFM_TFG_NO = M.ICM_GG_NO
        LEFT JOIN (
        SELECT
        CG_NO
        , GOODS_NO
        , GOODS_NAME
        , GG_NO
        , CG_QTY
        , CG_PRICE
        , CG_TOTAL_PRICE
        , CG_WEIGHT
        , CG_ORIGIN
        FROM (
        SELECT
        CG.CG_NO
        , CG.GOODS_NO
        , G.GOODS_NAME
        , CG.GG_NO
        , CG.CG_QTY
        , CG.CG_PRICE
        , CG.CG_TOTAL_PRICE
        , CG.CG_WEIGHT
        , CG.CG_ORIGIN
        , ROW_NUMBER() OVER (PARTITION BY CG.GG_NO ORDER BY CG.CG_NO) AS RN
        FROM CUSTOMS_GOODS CG
        LEFT JOIN GOODS G
        ON G.GOODS_NO = CG.GOODS_NO
        )
        WHERE RN = 1
        ) C
        ON C.GG_NO = NVL(W.WIR_GG_NO, T.TRC_TFG_NO)
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        ORDER BY T.TRC_RCEPT_DT DESC NULLS LAST, T.TRC_RQST_DT DESC NULLS LAST, W.WIR_NO DESC, FTCS.TCS_TRC_NO
    </select>

    <!-- 수입 적하목록/패킹리스트 대조 전용 최소 목록 조회 -->
    <select id="retriveImpManifestCompareList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        T.TRC_NO                                            AS trcNo
        , W.WIR_NO                                            AS wirNo
        , NVL(M.ICM_GG_NO, T.TRC_TFG_NO)                      AS ggNo
        , NVL(M.ICM_OWR_ID, T.TRC_OWR_ID)                     AS ownerId
        , NVL(O.OWR_NM, T.TRC_OWR_ID)                         AS ownerNm
        , O.OWR_TELNO                                          AS ownerTelno
        , O.OWR_EMAIL                                          AS ownerEmail
        , T.TRC_TRDR_NM                                        AS buyerNm
        , T.TRC_TRDR_COUNTRY_CD                                AS buyerCountryCd
        , T.TRC_TRAN_MN_CD                                     AS transportMeanCd
        , W.WIR_INVOICE_NO                                    AS invoiceNo
        , W.WIR_INVOICE_NO                                    AS wirInvoiceNo
        , NVL(M_INV_FILE.DFI_ORG_NM, INV_FILE.DFI_ORG_NM)     AS invoiceFile
        , NVL(M_INV_FILE.DFI_FILE_NO, INV_FILE.DFI_FILE_NO)   AS invoiceFileNo
        , NVL(M_INV_FILE.DFI_PATH, INV_FILE.DFI_PATH)         AS invoicePath
        , NVL(M_INV_FILE.DFI_STR_NM, INV_FILE.DFI_STR_NM)     AS invoiceStoredName
        , NVL(M_PKG_FILE.DFI_ORG_NM, PKG_FILE.DFI_ORG_NM)     AS packingListFile
        , NVL(M_PKG_FILE.DFI_FILE_NO, PKG_FILE.DFI_FILE_NO)   AS packingListFileNo
        , NVL(M_PKG_FILE.DFI_PATH, PKG_FILE.DFI_PATH)         AS packingListPath
        , NVL(M_PKG_FILE.DFI_STR_NM, PKG_FILE.DFI_STR_NM)     AS packingListStoredName
        , NVL(W.WIR_CARGO_MGMT_NO, (
        SELECT MAX(W2.WIR_CARGO_MGMT_NO)
        FROM WH_IN_RPT W2
        WHERE W2.WIR_IO_SE_CD = 'IMP'
        AND W2.WIR_GG_NO = NVL(M.ICM_GG_NO, T.TRC_TFG_NO)
        ))                                                  AS cargoMgmtNo
        , NVL(W.WIR_INCO_TERMS_CD, (
        SELECT MAX(W2.WIR_INCO_TERMS_CD)
        FROM WH_IN_RPT W2
        WHERE W2.WIR_IO_SE_CD = 'IMP'
        AND W2.WIR_GG_NO = NVL(M.ICM_GG_NO, T.TRC_TFG_NO)
        ))                                                  AS incoTermsCd
        , M.ICM_NO                                            AS icmNo
        , M.ICM_NO                                            AS manifestNo
        , NVL(M.ICM_MBL_NO, BI.BI_MBL_NO)                     AS mblNo
        , NVL(M.ICM_HBL_NO, BI.BI_HBL_NO)                     AS hblNo
        , T.TRC_ITEM_CTGRY_NM                                  AS itemCategory
        , T.TRC_ITEM_CTGRY_NM                                  AS itemNm
        , T.TRC_ITEM_CTGRY_NM                                  AS frghtIemNm
        , T.TRC_DEPT_PORT_CD                                  AS deptPortCd
        , CASE T.TRC_DEPT_PORT_CD
        WHEN 'KRPUS' THEN '부산항'
        WHEN 'BUSAN' THEN '부산항'
        ELSE T.TRC_DEPT_PORT_CD
        END                                                 AS deptPortNm
        , T.TRC_ARVL_PORT_CD                                  AS arvlPortCd
        , CASE T.TRC_ARVL_PORT_CD
        WHEN 'KRPUS' THEN '부산항'
        WHEN 'BUSAN' THEN '부산항'
        ELSE T.TRC_ARVL_PORT_CD
        END                                                 AS arvlPortNm
        , IAN.IAN_NO                                          AS reqNo
        , IAN.IAN_NO                                          AS arrivalNoticeNo
        , IAN.IAN_NO                                          AS arrivalNoticeReqNo
        , TO_CHAR(NVL(IAN.IAN_REGIST_DT, NVL(T.TRC_RCEPT_DT, T.TRC_RQST_DT)) + 1, 'YYYY-MM-DD') AS eta
        , NVL(IAN.IAN_CURR_LOC, T.TRC_ARVL_PORT_CD)           AS currentLoc
        , NVL(IAN.IAN_ARRV_STATUS_CD, 'TRC_ARR_PENDING')      AS arrivalStatus
        , CASE NVL(IAN.IAN_ARRV_STATUS_CD, 'TRC_ARR_PENDING')
        WHEN 'TRC_ARR_ARRIVED' THEN '도착'
        WHEN 'ARRIVED' THEN '도착'
        WHEN 'TRC_ARR_IN_TRANSIT' THEN '운송중'
        WHEN 'IN_TRANSIT' THEN '운송중'
        WHEN 'SAILING' THEN '운항중'
        WHEN 'TRC_ARR_DELAYED' THEN '지연'
        WHEN 'DELAYED' THEN '지연'
        WHEN 'TRC_ARR_PENDING' THEN '입항전'
        WHEN 'PENDING' THEN '입항전'
        WHEN 'BEFORE_ARRIVAL' THEN '입항전'
        ELSE NVL(IAN.IAN_ARRV_STATUS_CD, '입항전')
        END                                                   AS arrivalStatusNm
        , NVL(IAN.IAN_SEND_STTS_CD, 'TRC_NTC_NSENT')          AS noticeStatus
        , CASE NVL(IAN.IAN_SEND_STTS_CD, 'TRC_NTC_NSENT')
        WHEN 'TRC_NTC_SENT' THEN '발송완료'
        WHEN 'SENT' THEN '발송완료'
        ELSE '미발송'
        END                                                   AS noticeStatusNm
        , IAN.IAN_SEND_DT                                     AS noticeSendDt
        , NVL(M.ICM_GG_NO, T.TRC_TFG_NO)                    AS manifestTfgNo
        , CASE
        WHEN M.ICM_RMRK_CN IS NULL THEN NULL
        ELSE TRIM(REGEXP_REPLACE(M.ICM_RMRK_CN, ' *\[(WIR_NO|TRC_NO|TFG_NO|MBL_NO):[^]]+\]', ''))
        END                                                   AS manifestRemark
        , C.CG_NO                                             AS cgNo
        , C.GOODS_NO                                          AS goodsNo
        , C.GOODS_NAME                                        AS goodsName
        , C.CG_QTY                                            AS qty
        , C.CG_PRICE                                          AS price
        , C.CG_TOTAL_PRICE                                    AS goodsTotalPrice
        , C.CG_WEIGHT                                         AS weight
        , C.CG_ORIGIN                                         AS origin
        FROM TRAN_RCP T
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        LEFT JOIN IMP_RQST IR
        ON IR.IR_NO = REGEXP_REPLACE(
        T.TRC_NO,
        '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
        '\1-\2\3\4-\5'
        )
        LEFT JOIN (
        SELECT
        ICM_NO
        , ICM_GG_NO
        , ICM_OWR_ID
        , ICM_MBL_NO
        , ICM_HBL_NO
        , ICM_SBMSN_DT
        , ICM_RMRK_CN
        FROM (
        SELECT
        M0.ICM_NO
        , M0.ICM_GG_NO
        , M0.ICM_OWR_ID
        , M0.ICM_MBL_NO
        , M0.ICM_HBL_NO
        , M0.ICM_SBMSN_DT
        , M0.ICM_RMRK_CN
        , ROW_NUMBER() OVER (
        PARTITION BY M0.ICM_GG_NO, M0.ICM_OWR_ID, NVL(M0.ICM_MBL_NO, '#'), NVL(M0.ICM_HBL_NO, '#')
        ORDER BY M0.ICM_SBMSN_DT DESC NULLS LAST, M0.ICM_NO DESC
        ) AS RN
        FROM IMP_CARGO_MANIFEST M0
        )
        WHERE RN = 1
        ) M
        ON M.ICM_GG_NO = T.TRC_TFG_NO
        AND (
        M.ICM_OWR_ID = T.TRC_OWR_ID
        OR T.TRC_OWR_ID IS NULL
        OR M.ICM_OWR_ID IS NULL
        )
        AND (
        (
        NVL(BI.BI_MBL_NO, IR.IR_BL_AWB_NO) IS NOT NULL
        AND M.ICM_MBL_NO = NVL(BI.BI_MBL_NO, IR.IR_BL_AWB_NO)
        AND (
        BI.BI_HBL_NO IS NULL
        OR M.ICM_HBL_NO = BI.BI_HBL_NO
        )
        )
        OR M.ICM_RMRK_CN LIKE '%[TRC_NO:' || T.TRC_NO || ']%'
        OR (
        NVL(BI.BI_MBL_NO, IR.IR_BL_AWB_NO) IS NULL
        AND M.ICM_RMRK_CN IS NULL
        )
        )
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND (
        W.WIR_OWR_ID = T.TRC_OWR_ID
        OR W.WIR_OWR_ID IS NULL
        )
        LEFT JOIN IMP_ARRV_NTC IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        LEFT JOIN TACS_FILE_MAP INV_MAP
        ON INV_MAP.TFM_TFG_NO = T.TRC_TFG_NO
        AND INV_MAP.TFM_DOC_TY_CD = 'INVOICE'
        LEFT JOIN DOCS_FILE_DATA INV_FILE
        ON INV_FILE.DFI_FILE_NO = INV_MAP.TFM_DFI_NO
        AND INV_FILE.DFI_DEL_YN = 'N'
        AND INV_FILE.DFI_UPLOAD_STTS_CD = 'DONE'
        AND INV_FILE.DFI_DRIVE_FILE_ID IS NOT NULL
        LEFT JOIN TACS_FILE_MAP M_INV_MAP
        ON M_INV_MAP.TFM_TFG_NO = NVL(M.ICM_GG_NO, T.TRC_TFG_NO)
        AND M_INV_MAP.TFM_DOC_TY_CD = 'INVOICE'
        LEFT JOIN DOCS_FILE_DATA M_INV_FILE
        ON M_INV_FILE.DFI_FILE_NO = M_INV_MAP.TFM_DFI_NO
        AND M_INV_FILE.DFI_DEL_YN = 'N'
        AND M_INV_FILE.DFI_UPLOAD_STTS_CD = 'DONE'
        AND M_INV_FILE.DFI_DRIVE_FILE_ID IS NOT NULL
        LEFT JOIN TACS_FILE_MAP PKG_MAP
        ON PKG_MAP.TFM_TFG_NO = T.TRC_TFG_NO
        AND PKG_MAP.TFM_DOC_TY_CD = 'PACKING_LIST'
        LEFT JOIN DOCS_FILE_DATA PKG_FILE
        ON PKG_FILE.DFI_FILE_NO = PKG_MAP.TFM_DFI_NO
        AND PKG_FILE.DFI_DEL_YN = 'N'
        AND PKG_FILE.DFI_UPLOAD_STTS_CD = 'DONE'
        AND PKG_FILE.DFI_DRIVE_FILE_ID IS NOT NULL
        LEFT JOIN TACS_FILE_MAP M_PKG_MAP
        ON M_PKG_MAP.TFM_TFG_NO = NVL(M.ICM_GG_NO, T.TRC_TFG_NO)
        AND M_PKG_MAP.TFM_DOC_TY_CD = 'PACKING_LIST'
        LEFT JOIN DOCS_FILE_DATA M_PKG_FILE
        ON M_PKG_FILE.DFI_FILE_NO = M_PKG_MAP.TFM_DFI_NO
        AND M_PKG_FILE.DFI_DEL_YN = 'N'
        LEFT JOIN (
        SELECT
        CG_NO
        , GOODS_NO
        , GOODS_NAME
        , GG_NO
        , CG_QTY
        , CG_PRICE
        , CG_TOTAL_PRICE
        , CG_WEIGHT
        , CG_ORIGIN
        FROM (
        SELECT
        CG.CG_NO
        , CG.GOODS_NO
        , G.GOODS_NAME
        , CG.GG_NO
        , CG.CG_QTY
        , CG.CG_PRICE
        , CG.CG_TOTAL_PRICE
        , CG.CG_WEIGHT
        , CG.CG_ORIGIN
        , ROW_NUMBER() OVER (PARTITION BY CG.GG_NO ORDER BY CG.CG_NO) AS RN
        FROM CUSTOMS_GOODS CG
        LEFT JOIN GOODS G
        ON G.GOODS_NO = CG.GOODS_NO
        )
        WHERE RN = 1
        ) C
        ON C.GG_NO = NVL(M.ICM_GG_NO, T.TRC_TFG_NO)
        <where>
            T.TRC_SE_CD IN ('IMP', 'IMPORT')
            AND T.TRC_STATUS_CD = 'TRC_DONE'
            <if test="tmId != null and tmId != ''">
                AND T.TRC_TM_NO = (
                SELECT TM.TM_NO
                FROM TRANSPORT_MANAGER TM
                WHERE TM.TM_ID = #{tmId}
                )
            </if>
        </where>
        ORDER BY NVL(M.ICM_SBMSN_DT, T.TRC_RCEPT_DT) DESC NULLS LAST
        , T.TRC_NO DESC
        , W.WIR_NO DESC
        , M.ICM_NO DESC
    </select>


    <select id="retriveImpDoList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        <!--
        D/O 화면 조회 기준:
        - 운임비/창고비/총청구금액은 TRAN_COST_STL 기준으로 항상 보여준다.
        - 입고완료(IN_DONE)는 정산처리/D/O 발급 가능 조건이지 금액 조회 조건이 아니다.
        - 입고완료 전에는 기존 DO_ISSUANCE 더미가 있어도 D/O 번호/발급상태를 화면에 노출하지 않는다.
        -->
        SELECT
        T.TRC_NO                                  AS trcNo
        , T.TRC_OWR_ID                            AS ownerId
        , NVL(O.OWR_NM, T.TRC_OWR_ID)             AS ownerNm

        , W.WIR_NO                                AS wirNo
        , W.WIR_STATUS_CD                         AS warehouseInStatusCd
        , W.WIR_WH_REPLY_STATUS_CD                AS warehouseReplyStatusCd
        , CASE
        WHEN W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN '입고완료'
        WHEN W.WIR_STATUS_CD = 'REQ_FIX' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN '보완요청'
        WHEN W.WIR_STATUS_CD = 'REQ_SENT' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN '보완제출완료'
        WHEN W.WIR_STATUS_CD IN ('REJECT', 'REJECTED') OR W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED') THEN '반려'
        WHEN W.WIR_STATUS_CD = 'WAIT' OR W.WIR_WH_REPLY_STATUS_CD = 'WAIT' THEN '입고요청'
        WHEN W.WIR_STATUS_CD IS NULL AND W.WIR_WH_REPLY_STATUS_CD IS NULL THEN NULL
        ELSE '입고대기'
        END                                      AS warehouseInStatusNm
        , CASE
        WHEN W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN 'Y'
        ELSE 'N'
        END                                      AS warehouseInDoneYn

        /*
        * D/O 번호/상태는 DB에 실제로 존재하고, 입고완료+정산완료 조건을 만족한 경우에만 노출한다.
        * WAIT_IN_DONE, WAIT_SETTLEMENT 같은 화면 전용 가짜 상태값은 만들지 않는다.
        */
        , CASE
        WHEN (W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE')
        AND NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID') = 'TRC_STL_PAID'
        AND DI.DI_STATUS_CD IN ('TRC_DO_ISSUED', 'TRC_DO_REQ')
        THEN DI.DI_DO_NO
        ELSE NULL
        END                                      AS doNo

        , CASE
        WHEN (W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE')
        AND NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID') = 'TRC_STL_PAID'
        THEN DI.DI_STATUS_CD
        ELSE NULL
        END                                      AS doStatusCd

        , CASE
        WHEN (W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE')
        AND NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID') = 'TRC_STL_PAID'
        THEN NVL(DO_CODE.CC_NM, DI.DI_STATUS_CD)
        ELSE NULL
        END                                      AS doStatusNm

        , DI.DI_HBL_PRESENT_YN                    AS hblPresentYn
        , DI.DI_DO_FEE                            AS doFee
        , TO_CHAR(DI.DI_REQ_DT, 'YYYY-MM-DD')     AS doReqDt
        , TO_CHAR(DI.DI_RECEIVE_DT, 'YYYY-MM-DD') AS doReceiveDt
        , NVL(DI.DI_DLVRY_OWR_NM, NVL(O.OWR_NM, T.TRC_OWR_ID)) AS deliveryTargetNm
        , TO_CHAR(DI.DI_DLVRY_DT, 'YYYY-MM-DD')   AS deliveryDt
        , DI.DI_DLVRY_MTHD_CD                     AS deliveryMethodCd
        , DI.DI_ISSUER_NM                         AS doIssuerNm
        , NVL(DI.DI_ISSU_OWR_NM, NVL(WM.WM_NM, W.WIR_WM_ID)) AS issueTargetNm
        , DI.DI_TFG_NO                            AS doTfgNo
        , DI.DI_TFG_NO                            AS doCertTfgNo
        , DO_PDF_FILE.DFI_FILE_NO                 AS doPdfFileNo
        , DO_PDF_FILE.DFI_ORG_NM                  AS doPdfFile
        , DO_CERT_FILE.DFI_FILE_NO                AS doCertFileNo
        , DO_CERT_FILE.DFI_ORG_NM                 AS doCertFile

        , TCS.TCS_NO                              AS tcsNo
        , NVL(M.ICM_MBL_NO, NVL(BI.BI_MBL_NO, TCS.TCS_MBL_NO)) AS mblNo
        , NVL(M.ICM_HBL_NO, NVL(BI.BI_HBL_NO, TCS.TCS_HBL_NO)) AS hblNo

        /* 정산/금액은 오직 TRAN_COST_STL 기준 */
        , NVL(TCS.TCS_FRGT_AMT, 0)                AS freightAmt
        , NVL(TCS.TCS_WH_AMT, 0)                  AS warehouseAmt
        , NVL(TCS.TCS_TOT_BILL_AMT, 0)            AS totalBillAmt
        , NVL(TCS.TCS_FRGT_AMT, 0)                AS tcsFrgtAmt
        , NVL(TCS.TCS_WH_AMT, 0)                  AS tcsWhAmt
        , NVL(TCS.TCS_TOT_BILL_AMT, 0)            AS tcsTotBillAmt
        , NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID')    AS settlementStatusCd
        , NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID')    AS tcsStlStatusCd
        , CASE NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID')
        WHEN 'TRC_STL_UNPAID' THEN '미정산'
        WHEN 'TRC_STL_PAID'   THEN '정산완료'
        ELSE TCS.TCS_STL_STATUS_CD
        END                                      AS settlementStatusNm
        , CASE NVL(TCS.TCS_STL_STATUS_CD, 'TRC_STL_UNPAID')
        WHEN 'TRC_STL_UNPAID' THEN '미정산'
        WHEN 'TRC_STL_PAID'   THEN '정산완료'
        ELSE TCS.TCS_STL_STATUS_CD
        END                                      AS tcsStlStatusNm
        , TCS.TCS_STL_EXPLN                       AS settlementExpln
        , TO_CHAR(T.TRC_RQST_DT, 'YYYY-MM-DD')    AS requestDt

        FROM TRAN_RCP T
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID

        /* 입고상태는 조회용으로 최신 1건만 붙인다. IN_DONE 조건을 여기서 걸지 않는다. */
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        W0.*
        , ROW_NUMBER() OVER (
        PARTITION BY W0.WIR_GG_NO
        ORDER BY
        CASE
        WHEN W0.WIR_STATUS_CD = 'IN_DONE' OR W0.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN 1
        WHEN W0.WIR_STATUS_CD = 'REQ_SENT' OR W0.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN 2
        WHEN W0.WIR_STATUS_CD = 'REQ_FIX' OR W0.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN 3
        ELSE 4
        END,
        W0.WIR_IN_PLAN_DT DESC NULLS LAST,
        W0.WIR_NO DESC
        ) AS RN
        FROM WH_IN_RPT W0
        WHERE W0.WIR_IO_SE_CD = 'IMP'
        )
        WHERE RN = 1
        ) W
        ON W.WIR_GG_NO = T.TRC_TFG_NO

        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = W.WIR_WM_ID

        LEFT JOIN DO_ISSUANCE DI
        ON DI.DI_TRC_NO = T.TRC_NO
        AND NVL(DI.DI_TRDE_SE_CD, 'IMP') = 'IMP'

        LEFT JOIN COM_CODE DO_CODE
        ON DO_CODE.CC_CCG_ID = 'DO_STATUS'
        AND DO_CODE.CC_CD = DI.DI_STATUS_CD
        AND NVL(DO_CODE.CC_USE_YN, 'Y') = 'Y'

        LEFT JOIN (
        SELECT
        FM.TFM_TFG_NO
        , LISTAGG(TO_CHAR(FD.DFI_FILE_NO), ', ') WITHIN GROUP (ORDER BY FM.TFM_NO) AS DFI_FILE_NO
        , LISTAGG(FD.DFI_ORG_NM, ', ') WITHIN GROUP (ORDER BY FM.TFM_NO) AS DFI_ORG_NM
        FROM TACS_FILE_MAP FM
        INNER JOIN DOCS_FILE_DATA FD
        ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
        AND FD.DFI_DEL_YN = 'N'
        GROUP BY FM.TFM_TFG_NO
        ) DO_PDF_FILE
        ON DO_PDF_FILE.TFM_TFG_NO = DI.DI_TFG_NO

        LEFT JOIN (
        SELECT
        FM.TFM_TFG_NO
        , LISTAGG(TO_CHAR(FD.DFI_FILE_NO), ', ') WITHIN GROUP (ORDER BY FM.TFM_NO) AS DFI_FILE_NO
        , LISTAGG(FD.DFI_ORG_NM, ', ') WITHIN GROUP (ORDER BY FM.TFM_NO) AS DFI_ORG_NM
        FROM TACS_FILE_MAP FM
        INNER JOIN DOCS_FILE_DATA FD
        ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
        AND FD.DFI_DEL_YN = 'N'
        WHERE FM.TFM_DOC_TY_CD = 'IMP_DO_CERT'
        OR FD.DFI_BIZ_TY_CD = 'IMP_DO_CERT'
        GROUP BY FM.TFM_TFG_NO
        ) DO_CERT_FILE
        ON DO_CERT_FILE.TFM_TFG_NO = DI.DI_TFG_NO

        LEFT JOIN TRAN_COST_STL TCS
        ON TCS.TCS_TRC_NO = T.TRC_NO

        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO

        LEFT JOIN (
        SELECT
        ICM_GG_NO
        , ICM_MBL_NO
        , ICM_HBL_NO
        FROM (
        SELECT
        ICM_GG_NO
        , ICM_MBL_NO
        , ICM_HBL_NO
        , ROW_NUMBER() OVER (PARTITION BY ICM_GG_NO ORDER BY ICM_SBMSN_DT DESC NULLS LAST, ICM_NO DESC) AS RN
        FROM IMP_CARGO_MANIFEST
        )
        WHERE RN = 1
        ) M
        ON M.ICM_GG_NO = T.TRC_TFG_NO

        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        ORDER BY T.TRC_RQST_DT DESC NULLS LAST, T.TRC_NO DESC
    </select>


    <!-- D/O 전달 처리 -->
    <update id="updateImpDoDelivered">
        UPDATE DO_ISSUANCE
        SET
        DI_STATUS_CD      = 'TRC_DO_REQ'
        , DI_TRDE_SE_CD   = 'IMP'
        , DI_DLVRY_DT     = TO_DATE(#{deliveryDt}, 'YYYY-MM-DD')
        , DI_DLVRY_OWR_NM = COALESCE(
        NULLIF(#{deliveryTargetNm}, ''),
        (
        SELECT NVL(O.OWR_NM, T.TRC_OWR_ID)
        FROM TRAN_RCP T
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        WHERE T.TRC_NO = #{trcNo}
        ),
        DI_DLVRY_OWR_NM
        )
        , DI_DLVRY_MTHD_CD = COALESCE(
        NULLIF(#{deliveryMethodCd}, ''),
        (
        SELECT W.WIR_WZ_NO
        FROM TRAN_RCP T
        JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_NO LIKE 'IMP-%'
        WHERE T.TRC_NO = #{trcNo}
        ORDER BY W.WIR_NO DESC
        FETCH FIRST 1 ROW ONLY
        ),
        DI_DLVRY_MTHD_CD
        )
        WHERE DI_TRC_NO = #{trcNo}
        AND NVL(DI_TRDE_SE_CD, 'IMP') = 'IMP'
        AND EXISTS (
        SELECT 1
        FROM TRAN_RCP T
        JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_STATUS_CD = 'IN_DONE'
        AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        )
    </update>

    <!-- D/O 발급 처리: 기존 D/O가 없으면 생성, 있으면 발급완료로 갱신 -->
    <update id="updateImpDoIssued">
        /*
        * D/O 발급 처리.
        * MERGE 금지 규칙 때문에 기존 D/O가 있으면 UPDATE, 없으면 INSERT 한다.
        * 입고완료(IN_DONE/IN_DONE) 조건을 만족해야만 발급된다.
        */
        BEGIN
        UPDATE DO_ISSUANCE D
        SET D.DI_DO_NO = NVL(D.DI_DO_NO,
        'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' ||
        LPAD((
        SELECT NVL(MAX(TO_NUMBER(SUBSTR(DI_DO_NO, -3))), 0) + 1
        FROM DO_ISSUANCE
        WHERE DI_DO_NO LIKE 'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
        ), 3, '0'))
        , D.DI_STATUS_CD = 'TRC_DO_ISSUED'
        , D.DI_REQ_DT = NVL(D.DI_REQ_DT, SYSDATE)
        , D.DI_RECEIVE_DT = TO_DATE(NVL(#{receiveDt}, TO_CHAR(SYSDATE, 'YYYY-MM-DD')), 'YYYY-MM-DD')
        , D.DI_TFG_NO = NVL(#{doTfgNo,jdbcType=NUMERIC}, D.DI_TFG_NO)
        , D.DI_ISSU_OWR_NM = NVL(D.DI_ISSU_OWR_NM, (
        SELECT NVL(WM.WM_NM, W.WIR_WM_ID)
        FROM TRAN_RCP T
        JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_STATUS_CD = 'IN_DONE'
        AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = W.WIR_WM_ID
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        FETCH FIRST 1 ROW ONLY
        ))
        WHERE D.DI_TRC_NO = #{trcNo}
        AND NVL(D.DI_TRDE_SE_CD, 'IMP') = 'IMP'
        AND NVL(D.DI_STATUS_CD, 'TRC_DO_READY') = 'TRC_DO_READY'
        AND EXISTS (
        SELECT 1
        FROM TRAN_RCP T
        JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_STATUS_CD = 'IN_DONE'
        AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        AND EXISTS (
        SELECT 1
        FROM TRAN_COST_STL TCS
        WHERE TCS.TCS_TRC_NO = T.TRC_NO
        AND TCS.TCS_STL_STATUS_CD = 'TRC_STL_PAID'
        )
        );

        IF SQL%ROWCOUNT = 0 THEN
        INSERT INTO DO_ISSUANCE (
        DI_DO_NO,
        DI_TRAN_NO,
        DI_TRC_NO,
        DI_TRDE_SE_CD,
        DI_STATUS_CD,
        DI_HBL_PRESENT_YN,
        DI_REQ_DT,
        DI_RECEIVE_DT,
        DI_TFG_NO,
        DI_ISSU_OWR_NM
        )
        SELECT
        'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' ||
        LPAD((
        SELECT NVL(MAX(TO_NUMBER(SUBSTR(DI_DO_NO, -3))), 0) + 1
        FROM DO_ISSUANCE
        WHERE DI_DO_NO LIKE 'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
        ), 3, '0'),
        (SELECT NVL(MAX(DI_TRAN_NO), 0) + 1 FROM DO_ISSUANCE),
        T.TRC_NO,
        'IMP',
        'TRC_DO_ISSUED',
        'Y',
        SYSDATE,
        TO_DATE(NVL(#{receiveDt}, TO_CHAR(SYSDATE, 'YYYY-MM-DD')), 'YYYY-MM-DD'),
        #{doTfgNo,jdbcType=NUMERIC},
        (
        SELECT NVL(WM.WM_NM, W.WIR_WM_ID)
        FROM WH_IN_RPT W
        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = W.WIR_WM_ID
        WHERE W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_STATUS_CD = 'IN_DONE'
        AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        FETCH FIRST 1 ROW ONLY
        )
        FROM TRAN_RCP T
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        AND EXISTS (
        SELECT 1
        FROM WH_IN_RPT W
        WHERE W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_STATUS_CD = 'IN_DONE'
        AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        )
        AND EXISTS (
        SELECT 1
        FROM TRAN_COST_STL TCS
        WHERE TCS.TCS_TRC_NO = T.TRC_NO
        AND TCS.TCS_STL_STATUS_CD = 'TRC_STL_PAID'
        )
        AND NOT EXISTS (
        SELECT 1
        FROM DO_ISSUANCE D
        WHERE D.DI_TRC_NO = T.TRC_NO
        AND NVL(D.DI_TRDE_SE_CD, 'IMP') = 'IMP'
        );
        END IF;
        END;
    </update>


    <!-- D/O 발급 전 첨부문서 업로드: D/O 번호는 만들지 않고 파일그룹만 연결한다. -->
    <update id="updateImpDoUploadedFiles">
        /*
        * 첨부문서 업로드 전용.
        * - 파일만 DI_TFG_NO에 연결한다.
        * - DB 제약상 DI_DO_NO는 생성하되 화면 조회에서는 TRC_DO_ISSUED 전까지 숨긴다.
        * - 기존 D/O row가 없으면 발급대기(TRC_DO_READY) row만 준비한다.
        */
        BEGIN
        UPDATE DO_ISSUANCE D
        SET
        D.DI_TFG_NO = #{doTfgNo,jdbcType=NUMERIC}
        , D.DI_TRDE_SE_CD = 'IMP'
        , D.DI_STATUS_CD = NVL(D.DI_STATUS_CD, 'TRC_DO_READY')
        WHERE D.DI_TRC_NO = #{trcNo}
        AND NVL(D.DI_TRDE_SE_CD, 'IMP') = 'IMP'
        AND NVL(D.DI_STATUS_CD, 'TRC_DO_READY') IN ('TRC_DO_READY', 'TRC_DO_ISSUED', 'TRC_DO_REQ')
        AND EXISTS (
        SELECT 1
        FROM TRAN_RCP T
        JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_STATUS_CD = 'IN_DONE'
        AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        JOIN TRAN_COST_STL TCS
        ON TCS.TCS_TRC_NO = T.TRC_NO
        AND TCS.TCS_STL_STATUS_CD = 'TRC_STL_PAID'
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        );

        IF SQL%ROWCOUNT = 0 THEN
        INSERT INTO DO_ISSUANCE (
        DI_DO_NO,
        DI_TRAN_NO,
        DI_TRC_NO,
        DI_TRDE_SE_CD,
        DI_STATUS_CD,
        DI_HBL_PRESENT_YN,
        DI_TFG_NO
        )
        SELECT
        'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' ||
        LPAD((
        SELECT NVL(MAX(TO_NUMBER(SUBSTR(DI_DO_NO, -3))), 0) + 1
        FROM DO_ISSUANCE
        WHERE DI_DO_NO LIKE 'DO-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
        ), 3, '0'),
        (SELECT NVL(MAX(DI_TRAN_NO), 0) + 1 FROM DO_ISSUANCE),
        T.TRC_NO,
        'IMP',
        'TRC_DO_READY',
        'Y',
        #{doTfgNo,jdbcType=NUMERIC}
        FROM TRAN_RCP T
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        AND EXISTS (
        SELECT 1
        FROM WH_IN_RPT W
        WHERE W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_STATUS_CD = 'IN_DONE'
        AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        )
        AND EXISTS (
        SELECT 1
        FROM TRAN_COST_STL TCS
        WHERE TCS.TCS_TRC_NO = T.TRC_NO
        AND TCS.TCS_STL_STATUS_CD = 'TRC_STL_PAID'
        )
        AND NOT EXISTS (
        SELECT 1
        FROM DO_ISSUANCE D
        WHERE D.DI_TRC_NO = T.TRC_NO
        AND NVL(D.DI_TRDE_SE_CD, 'IMP') = 'IMP'
        );
        END IF;
        END;
    </update>

    <!-- D/O 발급 이후 수입신고필증 첨부파일만 등록/교체 -->
    <update id="updateImpDoCertFile">
        UPDATE DO_ISSUANCE
        SET
        DI_TFG_NO = #{doTfgNo,jdbcType=NUMERIC}
        WHERE DI_TRC_NO = #{trcNo}
        AND NVL(DI_TRDE_SE_CD, 'IMP') = 'IMP'
        AND DI_STATUS_CD IN ('TRC_DO_ISSUED', 'TRC_DO_REQ')
        AND EXISTS (
        SELECT 1
        FROM TRAN_RCP T
        JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_STATUS_CD = 'IN_DONE'
        AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        )
    </update>

    <!-- 발급된 D/O 번호 조회 -->
    <select id="selectIssuedImpDoNo" resultType="String">
        SELECT DI_DO_NO
        FROM DO_ISSUANCE
        WHERE DI_TRC_NO = #{trcNo}
        AND NVL(DI_TRDE_SE_CD, 'IMP') = 'IMP'
        AND DI_STATUS_CD IN ('TRC_DO_ISSUED', 'TRC_DO_REQ')
        ORDER BY DI_RECEIVE_DT DESC NULLS LAST, DI_DO_NO DESC
        FETCH FIRST 1 ROW ONLY
    </select>

    <!-- D/O 정산 처리 -->
    <update id="updateImpDoSettlementPaid">
        UPDATE TRAN_COST_STL
        SET
        TCS_FRGT_AMT      = #{freightAmt}
        , TCS_WH_AMT       = #{warehouseAmt}
        , TCS_TOT_BILL_AMT = #{totalBillAmt}
        , TCS_STL_STATUS_CD = 'TRC_STL_PAID'
        WHERE TCS_TRC_NO = #{trcNo}
        AND EXISTS (
        SELECT 1
        FROM TRAN_RCP T
        JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_STATUS_CD = 'IN_DONE'
        AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        )
    </update>

    <!-- 수입 보세구역 반출요청 목록 조회 -->
    <select id="retriveImpReleaseReqList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        /*
        * 반출요청 대상은 D/O 발급완료 + 운송비 정산완료 + 보세구역 입고완료 건만 조회한다.
        * 창고 회신 상태는 WAIT/NULL 등으로 남을 수 있으므로 입고완료 여부는 WIR_STATUS_CD 기준으로 판단한다.
        * 기존처럼 WH_IN_RPT 최신 1건을 ON 1=1로 붙이면 더미/중복 데이터가 섞이므로
        * 운송의뢰의 화물그룹(TRC_TFG_NO) = WH_IN_RPT.WIR_GG_NO 기준으로 정확히 매칭한다.
        * TCS_GG_NO가 과거 더미값(9001 등)인 경우가 있어 반출요청 기준에서는 사용하지 않는다.
        */
        SELECT
        T.TRC_NO                                      AS trcNo
        , T.TRC_OWR_ID                                  AS ownerId
        , NVL(O.OWR_NM, T.TRC_OWR_ID)                   AS ownerNm
        , NVL(O.OWR_NM, T.TRC_OWR_ID)                   AS owrNm
        , W.WIR_NO                                      AS wirNo
        , W.WIR_GG_NO                                   AS ggNo
        , W.WIR_WZ_NO                                   AS bondedZoneNo
        , W.WIR_WZ_NO                                   AS warehouseZoneNo
        , W.WIR_WZ_NO                                   AS wzNo
        , W.WIR_WM_ID                                   AS bondedManagerId
        , W.WIR_WM_ID                                   AS wmId
        , WM.WM_NM                                      AS bondedManagerNm
        , WM.WM_NM                                      AS warehouseManagerNm
        , WM.WM_NM                                      AS wmNm
        , WH.WH_NM                                      AS whNm
        , WH.WH_NM                                      AS warehouseNm
        , NVL(WZ.WZ_NM, TO_CHAR(W.WIR_WZ_NO))           AS warehouseZoneNm
        , W.WIR_CARGO_MGMT_NO                           AS cargoMgmtNo
        , CRR.CRR_NO                                    AS releaseReqNo
        , CRR.CRR_NO                                    AS crrNo
        , CRR.CRR_NO                                    AS reqNo
        , NULL                                          AS releaseNo
        , <include refid="impReleaseStatusCdCase"/>   AS releaseStatusCd
        , <include refid="impReleaseStatusCdCase"/>   AS statusCd
        , <include refid="impReleaseStatusNmCase"/>   AS releaseStatusNm
        , <include refid="impReleaseStatusNmCase"/>   AS statusNm
        , TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD') AS releaseReqDt
        , TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD') AS crrReqDt
        , TO_CHAR(NVL(CRR.CRR_RELEASE_DT, CRR.CRR_CR_DT), 'YYYY-MM-DD') AS releaseDt
        , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS itemNm
        , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS itemCategory
        , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS frghtIemNm
        , MIN(G.GOODS_NAME)                              AS goodsName
        , MIN(C.GOODS_NO)                                AS goodsNo
        , NVL(SUM(C.CG_QTY), 0)                          AS qty
        , NVL(SUM(C.CG_QTY), 0)                          AS totalQty
        , NVL(MAX(C.CG_PRICE), 0)                        AS price
        , NVL(SUM(C.CG_TOTAL_PRICE), 0)                  AS goodsTotalPrice
        , NVL(SUM(C.CG_WEIGHT), 0)                       AS weight
        , NVL(SUM(C.CG_WEIGHT), 0)                       AS totalWeight
        , MIN(C.CG_ORIGIN)                               AS origin
        , CRR.CRR_REQ_CN                                AS releaseRemark
        , (
        SELECT MAX(CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)))
        FROM SUPP_RQST SR
        WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
        AND SR.SR_REF_NO = CRR.CRR_NO
        )                                                AS rejectReason
        , (
        SELECT MAX(CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)))
        FROM SUPP_RQST SR
        WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
        AND SR.SR_REF_NO = CRR.CRR_NO
        )                                                AS suppReqCn
        , (
        SELECT MAX(SR.SR_STATUS_CD) KEEP (DENSE_RANK LAST ORDER BY SR.SR_REQ_DT, SR.SR_NO)
        FROM SUPP_RQST SR
        WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
        AND SR.SR_REF_NO = TO_CHAR(CRR.CRR_NO)
        )                                                AS supplementStatusCd
        , CRR.CRR_REQ_CN                                AS crrRmrk
        , CRR.CRR_REQ_CN                                AS remark
        , DI.DI_DO_NO                                   AS doNo
        , DI.DI_STATUS_CD                               AS doStatusCd
        , CASE NVL(DI.DI_STATUS_CD, 'TRC_DO_READY')
        WHEN 'TRC_DO_READY'  THEN 'D/O발급대기'
        WHEN 'TRC_DO_ISSUED' THEN 'D/O발급완료'
        WHEN 'TRC_DO_REQ'    THEN 'D/O전달완료'
        ELSE DI.DI_STATUS_CD
        END                                           AS doStatusNm
        , TO_CHAR(DI.DI_DLVRY_DT, 'YYYY-MM-DD')         AS doDlvrDt
        , NVL(WM.WM_NM, DI.DI_DLVRY_OWR_NM)             AS doDlvrOwnerNm
        , NVL(TCS.TCS_MBL_NO, BI.BI_MBL_NO)              AS mblNo
        , NVL(TCS.TCS_HBL_NO, BI.BI_HBL_NO)              AS hblNo
        , COUNT(C.CG_NO)                                AS goodsCnt
        , NVL(SUM(C.CG_TOTAL_PRICE), 0)                 AS summaryTotalPrice
        , TO_CHAR(T.TRC_RQST_DT, 'YYYY-MM-DD')          AS requestDt
        FROM TRAN_RCP T
        LEFT JOIN TRAN_COST_STL TCS
        ON TCS.TCS_TRC_NO = T.TRC_NO
        LEFT JOIN DO_ISSUANCE DI
        ON DI.DI_TRC_NO = T.TRC_NO
        AND NVL(DI.DI_TRDE_SE_CD, 'IMP') = 'IMP'
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_NO LIKE 'IMP-%'
        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = W.WIR_WM_ID
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = W.WIR_WZ_NO
        LEFT JOIN WAREHOUSE WH
        ON WH.WH_NO = WZ.WZ_WH_NO
        LEFT JOIN CARGO_RELEASE_REQ CRR
        ON CRR.CRR_TRE_ID = T.TRC_NO
        LEFT JOIN CUSTOMS_GOODS C
        ON C.GG_NO = W.WIR_GG_NO
        LEFT JOIN GOODS G
        ON G.GOODS_NO = C.GOODS_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        AND TCS.TCS_STL_STATUS_CD = 'TRC_STL_PAID'
        AND DI.DI_STATUS_CD = 'TRC_DO_REQ'
        AND W.WIR_STATUS_CD = 'IN_DONE'
        AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
        GROUP BY
        T.TRC_NO
        , T.TRC_OWR_ID
        , O.OWR_NM
        , W.WIR_NO
        , W.WIR_GG_NO
        , W.WIR_WZ_NO
        , W.WIR_WM_ID
        , WM.WM_NM
        , WH.WH_NM
        , WZ.WZ_NM
        , W.WIR_CARGO_MGMT_NO
        , CRR.CRR_NO
        , CRR.CRR_STATUS_CD
        , CRR.CRR_RELEASE_DT
        , CRR.CRR_CR_DT
        , CRR.CRR_FRGHT_IEM_NM
        , T.TRC_ITEM_CTGRY_NM
        , CRR.CRR_REQ_CN
        , DI.DI_DO_NO
        , DI.DI_STATUS_CD
        , DI.DI_DLVRY_DT
        , DI.DI_DLVRY_OWR_NM
        , TCS.TCS_MBL_NO
        , TCS.TCS_HBL_NO
        , BI.BI_MBL_NO
        , BI.BI_HBL_NO
        , T.TRC_RQST_DT
        ORDER BY T.TRC_RQST_DT DESC NULLS LAST, T.TRC_NO DESC
    </select>

    <!-- 수입 보세구역 반출요청 상세 조회 -->
    <select id="selectImpReleaseReqDetail" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        T.TRC_NO                                      AS trcNo
        , T.TRC_OWR_ID                                  AS ownerId
        , NVL(O.OWR_NM, T.TRC_OWR_ID)                   AS ownerNm
        , NVL(O.OWR_NM, T.TRC_OWR_ID)                   AS owrNm
        , W.WIR_NO                                      AS wirNo
        , W.WIR_GG_NO                                   AS ggNo
        , W.WIR_WZ_NO                                   AS bondedZoneNo
        , W.WIR_WZ_NO                                   AS warehouseZoneNo
        , W.WIR_WZ_NO                                   AS wzNo
        , W.WIR_WM_ID                                   AS bondedManagerId
        , W.WIR_WM_ID                                   AS wmId
        , WM.WM_NM                                      AS bondedManagerNm
        , WM.WM_NM                                      AS warehouseManagerNm
        , WM.WM_NM                                      AS wmNm
        , WH.WH_NM                                      AS whNm
        , WH.WH_NM                                      AS warehouseNm
        , NVL(WZ.WZ_NM, TO_CHAR(W.WIR_WZ_NO))           AS warehouseZoneNm
        , W.WIR_CARGO_MGMT_NO                           AS cargoMgmtNo
        , CRR.CRR_NO                                    AS releaseReqNo
        , CRR.CRR_NO                                    AS crrNo
        , CRR.CRR_NO                                    AS reqNo
        , NULL                                          AS releaseNo
        , <include refid="impReleaseStatusCdCase"/>   AS releaseStatusCd
        , <include refid="impReleaseStatusCdCase"/>   AS statusCd
        , <include refid="impReleaseStatusNmCase"/>   AS releaseStatusNm
        , <include refid="impReleaseStatusNmCase"/>   AS statusNm
        , TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD') AS releaseReqDt
        , TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD') AS crrReqDt
        , TO_CHAR(NVL(CRR.CRR_RELEASE_DT, CRR.CRR_CR_DT), 'YYYY-MM-DD') AS releaseDt
        , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS itemNm
        , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS itemCategory
        , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS frghtIemNm
        , MIN(G.GOODS_NAME)                              AS goodsName
        , MIN(C.GOODS_NO)                                AS goodsNo
        , NVL(SUM(C.CG_QTY), 0)                          AS qty
        , NVL(SUM(C.CG_QTY), 0)                          AS totalQty
        , NVL(MAX(C.CG_PRICE), 0)                        AS price
        , NVL(SUM(C.CG_TOTAL_PRICE), 0)                  AS goodsTotalPrice
        , NVL(SUM(C.CG_WEIGHT), 0)                       AS weight
        , NVL(SUM(C.CG_WEIGHT), 0)                       AS totalWeight
        , MIN(C.CG_ORIGIN)                               AS origin
        , CRR.CRR_REQ_CN                                AS releaseRemark
        , (
        SELECT MAX(CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)))
        FROM SUPP_RQST SR
        WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
        AND SR.SR_REF_NO = CRR.CRR_NO
        )                                                AS rejectReason
        , (
        SELECT MAX(CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)))
        FROM SUPP_RQST SR
        WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
        AND SR.SR_REF_NO = CRR.CRR_NO
        )                                                AS suppReqCn
        , (
        SELECT MAX(SR.SR_STATUS_CD) KEEP (DENSE_RANK LAST ORDER BY SR.SR_REQ_DT, SR.SR_NO)
        FROM SUPP_RQST SR
        WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
        AND SR.SR_REF_NO = TO_CHAR(CRR.CRR_NO)
        )                                                AS supplementStatusCd
        , CRR.CRR_REQ_CN                                AS crrRmrk
        , CRR.CRR_REQ_CN                                AS remark
        , DI.DI_DO_NO                                   AS doNo
        , DI.DI_STATUS_CD                               AS doStatusCd
        , CASE NVL(DI.DI_STATUS_CD, 'TRC_DO_READY')
        WHEN 'TRC_DO_READY'  THEN 'D/O발급대기'
        WHEN 'TRC_DO_ISSUED' THEN 'D/O발급완료'
        WHEN 'TRC_DO_REQ'    THEN 'D/O전달완료'
        ELSE DI.DI_STATUS_CD
        END                                           AS doStatusNm
        , TO_CHAR(DI.DI_DLVRY_DT, 'YYYY-MM-DD')         AS doDlvrDt
        , NVL(WM.WM_NM, DI.DI_DLVRY_OWR_NM)             AS doDlvrOwnerNm
        , NVL(TCS.TCS_MBL_NO, BI.BI_MBL_NO)              AS mblNo
        , NVL(TCS.TCS_HBL_NO, BI.BI_HBL_NO)              AS hblNo
        , TO_CHAR(T.TRC_RQST_DT, 'YYYY-MM-DD')          AS requestDt
        FROM TRAN_RCP T
        LEFT JOIN TRAN_COST_STL TCS
        ON TCS.TCS_TRC_NO = T.TRC_NO
        LEFT JOIN DO_ISSUANCE DI
        ON DI.DI_TRC_NO = T.TRC_NO
        AND NVL(DI.DI_TRDE_SE_CD, 'IMP') = 'IMP'
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = W.WIR_WM_ID
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = W.WIR_WZ_NO
        LEFT JOIN WAREHOUSE WH
        ON WH.WH_NO = WZ.WZ_WH_NO
        LEFT JOIN CARGO_RELEASE_REQ CRR
        ON CRR.CRR_TRE_ID = T.TRC_NO
        LEFT JOIN CUSTOMS_GOODS C
        ON C.GG_NO = W.WIR_GG_NO
        LEFT JOIN GOODS G
        ON G.GOODS_NO = C.GOODS_NO
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        GROUP BY
        T.TRC_NO
        , T.TRC_OWR_ID
        , O.OWR_NM
        , W.WIR_NO
        , W.WIR_GG_NO
        , W.WIR_WZ_NO
        , W.WIR_WM_ID
        , WM.WM_NM
        , WH.WH_NM
        , WZ.WZ_NM
        , W.WIR_CARGO_MGMT_NO
        , CRR.CRR_NO
        , CRR.CRR_RELEASE_DT
        , CRR.CRR_STATUS_CD
        , CRR.CRR_CR_DT
        , CRR.CRR_FRGHT_IEM_NM
        , T.TRC_ITEM_CTGRY_NM
        , CRR.CRR_REQ_CN
        , DI.DI_DO_NO
        , DI.DI_STATUS_CD
        , DI.DI_DLVRY_DT
        , DI.DI_DLVRY_OWR_NM
        , TCS.TCS_MBL_NO
        , TCS.TCS_HBL_NO
        , BI.BI_MBL_NO
        , BI.BI_HBL_NO
        , T.TRC_RQST_DT
    </select>

    <!-- 수입 보세구역 반출요청 화물정보 조회 -->
    <select id="retriveImpReleaseReqGoodsList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        C.CG_NO           AS cgNo
        , C.GOODS_NO        AS goodsNo
        , G.GOODS_NAME      AS goodsName
        , G.GOODS_NAME      AS itemNm
        , C.GG_NO           AS ggNo
        , C.CG_QTY          AS qty
        , C.CG_PRICE        AS price
        , C.CG_TOTAL_PRICE  AS goodsTotalPrice
        , C.CG_WEIGHT       AS weight
        , C.CG_ORIGIN       AS origin
        FROM CUSTOMS_GOODS C
        LEFT JOIN GOODS G
        ON C.GOODS_NO = G.GOODS_NO
        WHERE C.GG_NO = #{ggNo}
        ORDER BY C.CG_NO
    </select>

    <!-- 수입 보세구역 반출요청 등록 -->
    <!-- 수입 보세구역 반출요청 등록 -->
    <insert id="insertImpReleaseReq">
        DECLARE
        V_REQ_NO        CARGO_RELEASE_REQ.CRR_NO%TYPE;
        V_TRC_NO        TRAN_RCP.TRC_NO%TYPE;
        V_OWR_ID        TRAN_RCP.TRC_OWR_ID%TYPE;
        V_WZ_NO         WH_IN_RPT.WIR_WZ_NO%TYPE;
        V_WM_ID         WH_IN_RPT.WIR_WM_ID%TYPE;
        V_WH_NO         WAREHOUSE_ZONE.WZ_WH_NO%TYPE;
        V_OWNER_NM      OWNER.OWR_NM%TYPE;
        V_DO_NO         DO_ISSUANCE.DI_DO_NO%TYPE;
        V_ITEM_NM       TRAN_RCP.TRC_ITEM_CTGRY_NM%TYPE;
        V_EXISTS        NUMBER;
        BEGIN
        SELECT COUNT(*)
        INTO V_EXISTS
        FROM CARGO_RELEASE_REQ
        WHERE CRR_TRE_ID = #{trcNo};

        IF V_EXISTS = 0 THEN

        SELECT
        X.TRC_NO,
        X.TRC_OWR_ID,
        X.WIR_WZ_NO,
        X.WIR_WM_ID,
        X.WZ_WH_NO,
        X.OWNER_NM,
        X.DI_DO_NO,
        X.ITEM_NM
        INTO
        V_TRC_NO,
        V_OWR_ID,
        V_WZ_NO,
        V_WM_ID,
        V_WH_NO,
        V_OWNER_NM,
        V_DO_NO,
        V_ITEM_NM
        FROM (
        SELECT
        T.TRC_NO,
        T.TRC_OWR_ID,
        COALESCE(#{wzNo,jdbcType=VARCHAR}, W.WIR_WZ_NO) AS WIR_WZ_NO,
        COALESCE(#{wmId,jdbcType=VARCHAR}, W.WIR_WM_ID) AS WIR_WM_ID,
        Z.WZ_WH_NO,
        NVL(O.OWR_NM, T.TRC_OWR_ID) AS OWNER_NM,
        DI.DI_DO_NO,
        COALESCE(#{itemNm,jdbcType=VARCHAR}, T.TRC_ITEM_CTGRY_NM) AS ITEM_NM
        FROM TRAN_RCP T
        JOIN TRAN_COST_STL TCS
        ON TCS.TCS_TRC_NO = T.TRC_NO
        AND TCS.TCS_STL_STATUS_CD = 'TRC_STL_PAID'
        JOIN DO_ISSUANCE DI
        ON DI.DI_TRC_NO = T.TRC_NO
        AND NVL(DI.DI_TRDE_SE_CD, 'IMP') = 'IMP'
        AND DI.DI_STATUS_CD IN ('TRC_DO_REQ')
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_NO LIKE 'IMP-%'
        LEFT JOIN WAREHOUSE_ZONE Z
        ON Z.WZ_NO = COALESCE(#{wzNo,jdbcType=VARCHAR}, W.WIR_WZ_NO)
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND COALESCE(#{wzNo,jdbcType=VARCHAR}, W.WIR_WZ_NO) IS NOT NULL
        AND COALESCE(#{wmId,jdbcType=VARCHAR}, W.WIR_WM_ID) IS NOT NULL
        AND Z.WZ_WH_NO IS NOT NULL
        ORDER BY W.WIR_NO DESC
        ) X
        WHERE ROWNUM = 1;

        SELECT SEQ_CARGO_RELEASE_REQ.NEXTVAL
        INTO V_REQ_NO
        FROM DUAL;

        INSERT INTO CARGO_RELEASE_REQ (
        CRR_NO,
        CRR_TRE_ID,
        CRR_OWR_ID,
        CRR_WZ_NO,
        CRR_WM_ID,
        CRR_NM,
        CRR_CERT_NO,
        CRR_FRGHT_IEM_NM,
        CRR_WHM_NO,
        CRR_REQ_CN,
        CRR_CR_DT,
        CRR_STATUS_CD,
        CRR_WH_NO,
        CRR_PROC_MEM_ID,
        DI_TRDE_SE_CD
        )
        VALUES (
        V_REQ_NO,
        V_TRC_NO,
        V_OWR_ID,
        V_WZ_NO,
        V_WM_ID,
        V_OWNER_NM,
        V_DO_NO,
        V_ITEM_NM,
        V_WM_ID,
        #{remark,jdbcType=VARCHAR},
        CASE
        WHEN #{releaseReqDt,jdbcType=VARCHAR} IS NULL THEN SYSDATE
        WHEN LENGTH(#{releaseReqDt,jdbcType=VARCHAR}) &gt; 10
        THEN TO_DATE(SUBSTR(#{releaseReqDt,jdbcType=VARCHAR}, 1, 10), 'YYYY-MM-DD')
        ELSE TO_DATE(#{releaseReqDt,jdbcType=VARCHAR}, 'YYYY-MM-DD')
        END,
        'REL_WAIT',
        V_WH_NO,
        V_WM_ID,
        'IMP'
        );

        END IF;
        END;
    </insert>

    <select id="countImpReleaseReqByTrcNo" resultType="int">
        SELECT COUNT(*)
        FROM CARGO_RELEASE_REQ
        WHERE CRR_TRE_ID = #{trcNo}
    </select>


    <!-- 수입 보세구역 반출 후 내륙운송 배차 대상 목록 -->
    <select id="retriveImpInlandDispatchList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        T.TRC_NO AS trcNo,
        T.TRC_OWR_ID AS ownerId,
        NVL(O.OWR_NM, NVL(RQ.CRR_NM, T.TRC_OWR_ID)) AS ownerNm,
        NVL(RQ.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS itemNm,
        NVL(GS.GOODS_NAME, NVL(RQ.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM)) AS goodsName,
        GS.GOODS_NO AS goodsNo,
        GS.QTY AS qty,
        GS.QTY AS totalQty,
        GS.PRICE AS price,
        GS.GOODS_TOTAL_PRICE AS goodsTotalPrice,
        GS.GOODS_TOTAL_PRICE AS summaryTotalPrice,
        GS.WEIGHT AS weight,
        GS.WEIGHT AS totalWeight,
        GS.ORIGIN AS origin,
        RQ.CRR_NO AS releaseReqNo,
        RQ.CRR_WZ_NO AS bondedZoneNo,
        RQ.CRR_WZ_NO AS warehouseZoneNo,
        RQ.CRR_WZ_NO AS wzNo,
        NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO)) AS warehouseZoneNm,
        RQ.CRR_WM_ID AS warehouseManagerId,
        RQ.CRR_WM_ID AS wmId,
        NVL(WM.WM_NM, RQ.CRR_WHM_NO) AS warehouseManagerNm,
        NULL AS releaseNo,
        TO_CHAR(RQ.CRR_CR_DT, 'YYYY-MM-DD') AS releaseReqDt,
        TO_CHAR(RQ.CRR_RELEASE_DT, 'YYYY-MM-DD') AS releaseDt,
        NVL(RQ.CRR_STATUS_CD, 'REL_WAIT') AS releaseStatusCd,
        CASE NVL(RQ.CRR_STATUS_CD, 'REL_WAIT')
        WHEN 'REL_REQ' THEN '반출대기'
        WHEN 'REL_WAIT' THEN '반출대기'
        WHEN 'REL_DONE' THEN '반출완료'
        WHEN 'REL_FIX' THEN '보완요청'
        WHEN 'REL_REJECT' THEN '보완요청'
        WHEN 'REL_SENT' THEN '보완제출완료'
        ELSE NVL(RQ.CRR_STATUS_CD, '반출대기')
        END AS releaseStatusNm,
        D.DISPATCH_NO AS dispatchNo,
        NVL(D.DISPATCH_STATUS_CD, 'TRC_DISPATCH_WAIT') AS dispatchStatusCd,
        CASE NVL(D.DISPATCH_STATUS_CD, 'TRC_DISPATCH_WAIT')
        WHEN 'TRC_DISPATCH_DONE' THEN '배차완료'
        ELSE '배차대기'
        END AS dispatchStatusNm,
        D.DISPATCH_CAR_NO AS carNo,
        NVL(C.CAR_NM, TO_CHAR(D.DISPATCH_CAR_NO)) AS carNm,
        NVL(D.DISPATCH_DRV_NM, C.CAR_DRIVER_NM) AS driverNm,
        D.DISPATCH_DRV_TELNO AS driverTelno,
        NVL(
        NULLIF(TRIM(NVL(O.OWR_ADRES, '') || ' ' || NVL(O.OWR_DETAIL_ADRES, '')), ''),
        NVL(D.DISPATCH_LOADG_ADRES, NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO)))
        ) AS destinationAdres,
        NVL(D.DISPATCH_LOADG_ADRES, NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO))) AS loadgAdres,
        NVL(D.DISPATCH_LOADG_ADRES, NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO))) AS releasePlace,
        TO_CHAR(D.DISPATCH_PICKUP_DT, 'YYYY-MM-DD') AS pickupDt
        FROM TRAN_RCP T
        JOIN CARGO_RELEASE_REQ RQ
        ON RQ.CRR_TRE_ID = T.TRC_NO
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = RQ.CRR_WZ_NO
        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = RQ.CRR_WM_ID
        LEFT JOIN DISPATCH D
        ON D.DISPATCH_TRE_ID = T.TRC_NO
        LEFT JOIN CAR C
        ON C.CAR_NO = D.DISPATCH_CAR_NO
        LEFT JOIN (
        SELECT
        CG.GG_NO
        , MIN(CG.GOODS_NO) AS GOODS_NO
        , MIN(G.GOODS_NAME) AS GOODS_NAME
        , NVL(SUM(CG.CG_QTY), 0) AS QTY
        , NVL(MAX(CG.CG_PRICE), 0) AS PRICE
        , NVL(SUM(CG.CG_TOTAL_PRICE), 0) AS GOODS_TOTAL_PRICE
        , NVL(SUM(CG.CG_WEIGHT), 0) AS WEIGHT
        , MIN(CG.CG_ORIGIN) AS ORIGIN
        FROM CUSTOMS_GOODS CG
        LEFT JOIN GOODS G
        ON G.GOODS_NO = CG.GOODS_NO
        GROUP BY CG.GG_NO
        ) GS
        ON GS.GG_NO = T.TRC_TFG_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        AND (RQ.CRR_STATUS_CD = 'REL_DONE' OR RQ.CRR_RELEASE_DT IS NOT NULL)
        ORDER BY RQ.CRR_CR_DT DESC, RQ.CRR_NO DESC
    </select>

    <!-- 내륙운송 배차 가능 차량 목록 -->
    <select id="retriveImpAvailableCarList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        C.CAR_NO AS carNo,
        C.CAR_NM AS carNm,
        C.CAR_DRIVER_NM AS driverNm,
        C.CAR_WORK_PSBL_PRD AS driverTelno,
        TM.TM_CP_NM AS transportCompanyNm
        FROM CAR C
        LEFT JOIN TRANSPORT_MANAGER TM
        ON TM.TM_NO = C.CAR_TM_NO
        WHERE UPPER(NVL(C.CAR_USE, 'Y')) = 'Y'
        <if test="tmId != null and tmId != ''">
            AND TM.TM_ID = #{tmId}
        </if>
        ORDER BY C.CAR_NO
    </select>

    <!-- 내륙운송 배차 저장/수정 -->
    <update id="updateImpInlandDispatch" parameterType="kr.or.tacs.vo.transport.TransportRequestVO">
        /*
        * 내륙운송 배차 저장/수정.
        * MERGE 금지 규칙 때문에 기존 배차가 있으면 UPDATE, 없으면 INSERT 한다.
        */
        BEGIN
        UPDATE DISPATCH D
        SET
        D.DISPATCH_CAR_NO = COALESCE(
        #{carNo,jdbcType=NUMERIC},
        D.DISPATCH_CAR_NO,
        (SELECT MIN(C.CAR_NO) FROM CAR C WHERE UPPER(NVL(C.CAR_USE, 'Y')) = 'Y')
        ),
        D.DISPATCH_DRV_NM = (
        SELECT C.CAR_DRIVER_NM
        FROM CAR C
        WHERE C.CAR_NO = COALESCE(
        #{carNo,jdbcType=NUMERIC},
        D.DISPATCH_CAR_NO,
        (SELECT MIN(C2.CAR_NO) FROM CAR C2 WHERE UPPER(NVL(C2.CAR_USE, 'Y')) = 'Y')
        )
        ),
        D.DISPATCH_LOADG_ADRES = COALESCE(
        NULLIF(#{destinationAdres,jdbcType=VARCHAR}, ''),
        D.DISPATCH_LOADG_ADRES,
        (
        SELECT NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO))
        FROM CARGO_RELEASE_REQ RQ
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = RQ.CRR_WZ_NO
        WHERE RQ.CRR_TRE_ID = #{trcNo}
        ORDER BY RQ.CRR_NO DESC
        FETCH FIRST 1 ROW ONLY
        )
        ),
        D.DISPATCH_DRV_TELNO = (
        SELECT C.CAR_WORK_PSBL_PRD
        FROM CAR C
        WHERE C.CAR_NO = COALESCE(
        #{carNo,jdbcType=NUMERIC},
        D.DISPATCH_CAR_NO,
        (SELECT MIN(C2.CAR_NO) FROM CAR C2 WHERE UPPER(NVL(C2.CAR_USE, 'Y')) = 'Y')
        )
        ),
        D.DISPATCH_PICKUP_DT = CASE
        WHEN #{pickupDt} IS NULL OR TRIM(#{pickupDt}) IS NULL THEN SYSDATE
        ELSE TO_DATE(#{pickupDt}, 'YYYY-MM-DD')
        END,
        D.DISPATCH_STATUS_CD = 'TRC_DISPATCH_DONE'
        WHERE D.DISPATCH_TRE_ID = #{trcNo};

        IF SQL%ROWCOUNT = 0 THEN
        INSERT INTO DISPATCH (
        DISPATCH_NO,
        DISPATCH_TRE_ID,
        DISPATCH_OWR_ID,
        DISPATCH_CAR_NO,
        DISPATCH_DRV_NM,
        DISPATCH_LOADG_ADRES,
        DISPATCH_DRV_TELNO,
        DISPATCH_PICKUP_DT,
        DISPATCH_STATUS_CD
        )
        SELECT
        (SELECT NVL(MAX(DISPATCH_NO), 0) + 1 FROM DISPATCH),
        T.TRC_NO,
        T.TRC_OWR_ID,
        CAR_PICK.CAR_NO,
        (SELECT C.CAR_DRIVER_NM FROM CAR C WHERE C.CAR_NO = CAR_PICK.CAR_NO),
        COALESCE(
        NULLIF(#{destinationAdres,jdbcType=VARCHAR}, ''),
        (
        SELECT NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO))
        FROM CARGO_RELEASE_REQ RQ
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = RQ.CRR_WZ_NO
        WHERE RQ.CRR_TRE_ID = #{trcNo}
        ORDER BY RQ.CRR_NO DESC
        FETCH FIRST 1 ROW ONLY
        )
        ),
        (SELECT C.CAR_WORK_PSBL_PRD FROM CAR C WHERE C.CAR_NO = CAR_PICK.CAR_NO),
        CASE
        WHEN #{pickupDt} IS NULL OR TRIM(#{pickupDt}) IS NULL THEN SYSDATE
        ELSE TO_DATE(#{pickupDt}, 'YYYY-MM-DD')
        END,
        'TRC_DISPATCH_DONE'
        FROM TRAN_RCP T
        CROSS JOIN (
        SELECT COALESCE(
        #{carNo,jdbcType=NUMERIC},
        (SELECT MIN(C.CAR_NO) FROM CAR C WHERE UPPER(NVL(C.CAR_USE, 'Y')) = 'Y')
        ) AS CAR_NO
        FROM DUAL
        ) CAR_PICK
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND NOT EXISTS (
        SELECT 1
        FROM DISPATCH D
        WHERE D.DISPATCH_TRE_ID = T.TRC_NO
        );
        END IF;
        END;
    </update>


    <update id="mergeImpWarehouseInAfterArrivalNotice">
        /*
        * 도착통지 발송 후 입고관리 기본 행을 준비한다.
        *
        * 중요 상태 규칙:
        * - 운송담당자가 아직 창고로 입고요청을 보내기 전이면 상태값은 비워둔다(NULL/NULL).
        * - 입고관리 화면에서 실제 "발송"을 누르는 updateImpUnloadingInDelivered에서만 WAIT/WAIT(입고요청)으로 바뀐다.
        * - 보완요청 흐름은 WAIT -> REQ_FIX -> REQ_SENT -> IN_DONE 만 사용한다.
        *
        * MERGE 금지 규칙 때문에 SELECT COUNT 후 UPDATE/INSERT로 분기한다.
        * id 이름은 기존 서비스 호출과 호환하려고 유지한다.
        */
        DECLARE
        V_EXISTS NUMBER;
        BEGIN
        SELECT COUNT(*)
        INTO V_EXISTS
        FROM WH_IN_RPT W
        WHERE W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_GG_NO = (
        SELECT MAX(T.TRC_TFG_NO)
        FROM TRAN_RCP T
        LEFT JOIN IMP_ARRV_NTC IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        );

        IF V_EXISTS > 0 THEN
        UPDATE WH_IN_RPT W
        SET
        W.WIR_CARGO_MGMT_NO = NVL(W.WIR_CARGO_MGMT_NO, (
        SELECT 'CARGO-' || T.TRC_NO
        FROM TRAN_RCP T
        LEFT JOIN IMP_ARRV_NTC IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        FETCH FIRST 1 ROW ONLY
        )),
        W.WIR_OWR_ID = NVL(W.WIR_OWR_ID, (
        SELECT T.TRC_OWR_ID
        FROM TRAN_RCP T
        LEFT JOIN IMP_ARRV_NTC IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        FETCH FIRST 1 ROW ONLY
        )),
        W.WIR_OWR_NM = NVL(W.WIR_OWR_NM, (
        SELECT O.OWR_NM
        FROM TRAN_RCP T
        LEFT JOIN IMP_ARRV_NTC IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        FETCH FIRST 1 ROW ONLY
        )),
        W.WIR_WM_ID = NVL(W.WIR_WM_ID, (
        SELECT COALESCE(DFLT.WM_ID, (
        SELECT MIN(WM.WM_ID)
        FROM WAREHOUSE_MANAGER WM
        WHERE NVL(WM.WM_USE_YN, 'Y') = 'Y'
        ))
        FROM (
        SELECT Z.WM_ID, Z.WZ_NO
        FROM WAREHOUSE_ZONE Z
        INNER JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = Z.WM_ID
        WHERE NVL(WM.WM_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_STATUS_CD, 'ACTIVE') = 'ACTIVE'
        ORDER BY Z.WZ_NO
        FETCH FIRST 1 ROW ONLY
        ) DFLT
        )),
        W.WIR_WZ_NO = NVL(W.WIR_WZ_NO, (
        SELECT DFLT.WZ_NO
        FROM (
        SELECT Z.WZ_NO
        FROM WAREHOUSE_ZONE Z
        INNER JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = Z.WM_ID
        WHERE NVL(WM.WM_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_STATUS_CD, 'ACTIVE') = 'ACTIVE'
        ORDER BY Z.WZ_NO
        FETCH FIRST 1 ROW ONLY
        ) DFLT
        )),
        W.WIR_INCO_TERMS_CD = NVL(W.WIR_INCO_TERMS_CD, (
        SELECT T.TRC_INCO_TERMS_CD
        FROM TRAN_RCP T
        LEFT JOIN IMP_ARRV_NTC IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        FETCH FIRST 1 ROW ONLY
        ))
        /*
        * 여기서는 상태값을 절대 WAIT/REQ_SENT로 만들지 않는다.
        * 최초 화면은 상태 없음이어야 하므로 기존 상태가 있으면 그대로 두고, 없으면 NULL 유지.
        */
        WHERE W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_GG_NO = (
        SELECT MAX(T.TRC_TFG_NO)
        FROM TRAN_RCP T
        LEFT JOIN IMP_ARRV_NTC IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        );
        ELSE
        INSERT INTO WH_IN_RPT (
        WIR_NO,
        WIR_GG_NO,
        WIR_OWR_ID,
        WIR_WM_ID,
        WIR_WZ_NO,
        WIR_IN_PLAN_DT,
        WIR_STATUS_CD,
        WIR_WH_REPLY_STATUS_CD,
        WIR_CARGO_MGMT_NO,
        WIR_INCO_TERMS_CD,
        WIR_OWR_NM,
        WIR_IO_SE_CD
        )
        SELECT
        REGEXP_REPLACE(
        T.TRC_NO,
        '-[0-9]+$',
        '-' || LPAD(
        NVL((
        SELECT MAX(TO_NUMBER(REGEXP_SUBSTR(W3.WIR_NO, '[0-9]+$')))
        FROM WH_IN_RPT W3
        WHERE W3.WIR_IO_SE_CD = 'IMP'
        AND REGEXP_LIKE(W3.WIR_NO, '^IMP-[0-9]{4}-[0-9]{4}-[0-9]+$')
        ), 9000) + 1,
        4,
        '0'
        )
        ) AS WIR_NO,
        T.TRC_TFG_NO,
        T.TRC_OWR_ID,
        COALESCE(DFLT.WM_ID, (
        SELECT MIN(WM.WM_ID)
        FROM WAREHOUSE_MANAGER WM
        WHERE NVL(WM.WM_USE_YN, 'Y') = 'Y'
        )),
        DFLT.WZ_NO,
        NULL,
        NULL,
        NULL,
        'CARGO-' || T.TRC_NO,
        T.TRC_INCO_TERMS_CD,
        O.OWR_NM,
        'IMP'
        FROM TRAN_RCP T
        LEFT JOIN IMP_RQST IR
        ON IR.IR_NO = REGEXP_REPLACE(
        T.TRC_NO,
        '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
        '\1-\2\3\4-\5'
        )
        LEFT JOIN IMP_ARRV_NTC IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        OR IAN.IAN_TRC_NO = IR.IR_NO
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        LEFT JOIN (
        SELECT WM_ID, WZ_NO
        FROM (
        SELECT
        Z.WM_ID,
        Z.WZ_NO,
        ROW_NUMBER() OVER (ORDER BY Z.WZ_NO) AS RN
        FROM WAREHOUSE_ZONE Z
        INNER JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = Z.WM_ID
        WHERE NVL(WM.WM_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_STATUS_CD, 'ACTIVE') = 'ACTIVE'
        )
        WHERE RN = 1
        ) DFLT
        ON 1 = 1
        WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        AND COALESCE(
        (
        SELECT MAX(CG.GG_NO)
        FROM CUSTOMS_GOODS CG
        WHERE CG.GG_NO = IR.IR_GG_NO
        ),
        (
        SELECT MAX(CG.GG_NO)
        FROM CUSTOMS_GOODS CG
        WHERE CG.GG_NO = T.TRC_TFG_NO
        )
        ) IS NOT NULL;
        END IF;
        END;
    </update>


    <!-- D/O 전달 전 D/O PDF 존재 여부 확인 -->
    <select id="countImpDoPdfFile" resultType="int">
        SELECT COUNT(1)
        FROM DO_ISSUANCE DI
        JOIN TACS_FILE_MAP FM
        ON FM.TFM_TFG_NO = DI.DI_TFG_NO
        JOIN DOCS_FILE_DATA FD
        ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
        AND FD.DFI_DEL_YN = 'N'
        AND FD.DFI_UPLOAD_STTS_CD = 'DONE'
        AND FD.DFI_DRIVE_FILE_ID IS NOT NULL
        WHERE DI.DI_TRC_NO = #{trcNo}
        AND NVL(DI.DI_TRDE_SE_CD, 'IMP') = 'IMP'
        AND (
        FM.TFM_DOC_TY_CD = 'IMP_DO'
        OR LOWER(FD.DFI_ORG_NM) LIKE '%do%'
        OR LOWER(FD.DFI_ORG_NM) LIKE '%d/o%'
        OR LOWER(FD.DFI_ORG_NM) LIKE '%delivery%'
        OR FD.DFI_ORG_NM LIKE '%딜리버리%'
        )
        AND NOT (
        FM.TFM_DOC_TY_CD = 'IMP_DO_CERT'
        OR LOWER(FD.DFI_ORG_NM) LIKE '%cert%'
        OR LOWER(FD.DFI_ORG_NM) LIKE '%declaration%'
        OR FD.DFI_ORG_NM LIKE '%신고%'
        OR FD.DFI_ORG_NM LIKE '%필증%'
        )
    </select>

    <!-- D/O 전달 전 수입신고필증 PDF 존재 여부 확인 -->
    <select id="countImpDoCertFile" resultType="int">
        SELECT COUNT(1)
        FROM DO_ISSUANCE DI
        JOIN TACS_FILE_MAP FM
        ON FM.TFM_TFG_NO = DI.DI_TFG_NO
        JOIN DOCS_FILE_DATA FD
        ON FD.DFI_FILE_NO = FM.TFM_DFI_NO
        AND FD.DFI_DEL_YN = 'N'
        AND FD.DFI_UPLOAD_STTS_CD = 'DONE'
        AND FD.DFI_DRIVE_FILE_ID IS NOT NULL
        WHERE DI.DI_TRC_NO = #{trcNo}
        AND NVL(DI.DI_TRDE_SE_CD, 'IMP') = 'IMP'
        AND (
        FM.TFM_DOC_TY_CD = 'IMP_DO_CERT'
        OR LOWER(FD.DFI_ORG_NM) LIKE '%cert%'
        OR LOWER(FD.DFI_ORG_NM) LIKE '%declaration%'
        OR FD.DFI_ORG_NM LIKE '%신고%'
        OR FD.DFI_ORG_NM LIKE '%필증%'
        )
    </select>

</mapper>
