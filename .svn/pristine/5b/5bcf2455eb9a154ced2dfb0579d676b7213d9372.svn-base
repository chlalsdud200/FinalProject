<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ include file="/WEB-INF/views/officer/common/taglibs.jsp" %>
<c:set var="ctx" value="${pageContext.request.contextPath}" />
<%@ taglib uri="jakarta.tags.core" prefix="c" %>
<%@ taglib uri="http://www.springframework.org/security/tags" prefix="sec" %>
<%
    request.setAttribute("docsRole", "OFFICER");
%>
<!DOCTYPE html>
<html class="light" lang="ko">
<head>
  
    <%@ include file="/WEB-INF/views/officer/header/head.jsp" %>
<meta charset="UTF-8">
  <meta name="ctx-path" content="${ctx}">
  <meta name="_csrf" content="${_csrf.token}">
  <meta name="_csrf_header" content="${_csrf.headerName}">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TACS - &#47928;&#49436;&#54632;</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="${ctx}/resources/css/officer/pages/header.css">
  <link rel="stylesheet" href="${ctx}/resources/css/officer/pages/footer.css">
  <link rel="stylesheet" href="${ctx}/resources/css/common/docs.css">
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <script>window.contextPath = '${ctx}';</script>
  <script src="${ctx}/resources/js/officer/officer-main.js" defer></script>
  <script src="${ctx}/resources/js/officer/pages/sidebar.js" defer></script>
</head>
<body class="bg-background text-on-surface">
  <%@ include file="/WEB-INF/views/officer/header/sidebar.jsp" %>
  <%@ include file="/WEB-INF/views/officer/header/header.jsp" %>

  <main class="officer-main">
    <section class="p-8">
      <c:choose>
        <c:when test="${activeSub eq 'trash'}">
          <jsp:include page="/WEB-INF/views/common/trashContent.jsp" />
        </c:when>
        <c:otherwise>
          <jsp:include page="/WEB-INF/views/common/docsContent.jsp" />
        </c:otherwise>
      </c:choose>
    </section>
  </main>

  <script src="${ctx}/resources/js/common/docs.js"></script>
    <%@ include file="/WEB-INF/views/officer/footer/footer.jsp" %>

    <%@ include file="/WEB-INF/views/officer/footer/scripts.jsp" %>

</body>
</html>
