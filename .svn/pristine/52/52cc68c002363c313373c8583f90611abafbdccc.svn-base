<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ include file="/WEB-INF/views/officer/common/taglibs.jsp" %>
<%@ taglib uri="http://www.springframework.org/security/tags" prefix="sec" %>

<c:set var="ctx" value="${pageContext.request.contextPath}" />

<!DOCTYPE html>
<html lang="ko">
<head>
    <%@ include file="/WEB-INF/views/officer/header/head.jsp" %>
    <title>TACS · 대시보드</title>
    <link rel="stylesheet" href="${ctx}/resources/css/officer/pages/dashboard.css">
</head>

<body>
<%@ include file="/WEB-INF/views/officer/header/sidebar.jsp" %>
<%@ include file="/WEB-INF/views/officer/header/header.jsp" %>

<main class="main-content">
    <div class="page-content dashboard-page">
        <section class="dashboard-page page-section active" id="page-dashboard">

            <div class="dashboard-head">
                <p class="dashboard-kicker">TACS · 행정공무원 업무 시작 화면</p>
                <h1>대시보드</h1>
                <p class="dashboard-desc">
                    접수대기, 심사 진행, 보완요청, 세금납부 상태를 한 화면에서 확인하고 바로 처리할 수 있습니다.
                </p>
            </div>

            <div class="dashboard-stat-grid">
                <article class="dashboard-stat-card" data-href="${ctx}/officer/basicScreening.do">
                    <span class="stat-label">접수대기</span>
                    <strong><c:out value="${receiptWaitCount}" default="0"/>건</strong>
                    <span class="stat-sub">내 배정 전 신규 접수</span>
                </article>

                <article class="dashboard-stat-card" data-href="${ctx}/officer/basicScreenList.do?mine=true&statusCd=DCLR_REVIEW">
                    <span class="stat-label">심사중</span>
                    <strong><c:out value="${myReviewCount}" default="0"/>건</strong>
                    <span class="stat-sub">내 담당 기본심사 진행 중</span>
                </article>

                <article class="dashboard-stat-card" data-href="${ctx}/officer/supplementaryRequest.do?mine=true">
                    <span class="stat-label">보완요청</span>
                    <strong><c:out value="${mySupplementCount}" default="0"/>건</strong>
                    <span class="stat-sub">내 담당 답변 확인 필요</span>
                </article>

                <article class="dashboard-stat-card" data-href="${ctx}/officer/taxInquiryForward.do?mine=true">
                    <span class="stat-label">납부대기</span>
                    <strong><c:out value="${myTaxWaitCount}" default="0"/>건</strong>
                    <span class="stat-sub">내 담당 세금납부 확인 필요</span>
                </article>
            </div>

            <div class="dashboard-layout dashboard-layout-top">
                <article class="dashboard-card">
                    <div class="dashboard-card-head">
                        <div>
                            <h2>신규 수입/수출 신고접수</h2>
                            <p>24시간 이내 접수된 신고 중 현재상태가 접수대기인 신규 건입니다.</p>
                        </div>
                        <button class="dash-link-btn" onclick="location.href='${ctx}/officer/reportReceiptList.do'" type="button" data-href="${ctx}/officer/basicScreening.do">전체보기 →</button>
                    </div>

                    <div class="dashboard-table-wrap">
                        <table class="dashboard-table dashboard-table-receipt">
                            <thead>
                            <tr>
                                <th>신고번호</th>
                                <th>구분</th>
                                <th>업체명</th>
                                <th>품명</th>
                                <th>접수일시</th>
                                <th>처리</th>
                            </tr>
                            </thead>
                            <tbody>
                            <c:choose>
                                <c:when test="${not empty list}">
                                    <c:forEach items="${list}" var="dash" begin="0" end="4">
                                        <tr data-href="${ctx}/officer/basicScreenDetail.do?reqNo=${dash.reqNo}&mode=edit">
                                            <td>
                                                <span class="new-line-badge">NEW</span>
                                                <strong><c:out value="${dash.reqNo}"/></strong>
                                            </td>
                                            <td><c:out value="${dash.declareType}"/></td>
                                            <td><c:out value="${dash.companyName}"/></td>
                                            <td><c:out value="${dash.itemName}" default="-"/></td>
                                            <td><c:out value="${dash.requestDate}"/></td>
                                            <td>
                                                <button class="btn-sm btn-secondary" type="button"
                                                        onclick="event.stopPropagation(); location.href='${ctx}/officer/basicScreenDetail.do?reqNo=${dash.reqNo}&mode=edit'">상세</button>
                                            </td>
                                        </tr>
                                    </c:forEach>
                                </c:when>
                                <c:otherwise>
                                    <tr>
                                        <td colspan="6" class="dashboard-empty">
                                            <span class="empty-icon">📭</span>
                                            <span class="empty-msg">최근 24시간 이내 접수대기 신고가 없습니다.</span>
                                        </td>
                                    </tr>
                                </c:otherwise>
                            </c:choose>
                            </tbody>
                        </table>
                    </div>
                </article>
            </div>

        </section>
    </div>
</main>

<%@ include file="/WEB-INF/views/officer/footer/footer.jsp" %>
<%@ include file="/WEB-INF/views/officer/footer/scripts.jsp" %>

<script defer src="${ctx}/resources/js/officer/pages/dashboard.js"></script>
</body>
</html>
