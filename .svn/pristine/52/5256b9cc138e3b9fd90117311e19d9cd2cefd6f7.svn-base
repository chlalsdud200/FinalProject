<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%
    request.setAttribute("activeMenu", "dashboard");
    request.setAttribute("activeGroup", "");
    request.setAttribute("activeSub", "");
%>
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="ctx-path" content="${pageContext.request.contextPath}">
  <title>TACS 화주 대시보드</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet">
  <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/owner.css">
</head>
<body>
<div class="app" id="app">
  <%@ include file="/WEB-INF/views/owner/sidebar.jsp" %>

  <div class="main-wrap">
    <%@ include file="/WEB-INF/views/common/header.jsp" %>

    <main class="content">
<div class="page active" id="pg-dash">
<!-- 타이틀 -->
<div class="page-title-row">
<h2>업무 현황</h2>
<span class="date-label">2026년 4월 16일 (목)</span>
</div>
<!-- KPI 4개 -->
<div class="stats-grid">
<div class="stat-card" onclick="go('export')">
<div class="s-label">수출통관 진행</div>
<div class="s-num">6</div>
<div class="s-sub">필증 대기 2건</div>
</div>
<div class="stat-card c2" onclick="go('import')">
<div class="s-label">수입통관 진행</div>
<div class="s-num">9</div>
<div class="s-sub">세액확인 3건</div>
</div>
<div class="stat-card c3" onclick="go('arrival-notice')">
<div class="s-label">도착 통지</div>
<div class="s-num">3</div>
<div class="s-sub">미확인 2건</div>
</div>
<div class="stat-card c4" onclick="goSub('refund','duty')">
<div class="s-label">관세 납부</div>
<div class="s-num">2</div>
<div class="s-sub">납부 대기 ₩3.1M</div>
</div>
</div>
<!-- 3컬럼 메인 영역 -->
<div class="dash-3col">
<!-- ① 진행 건 목록 (수출/수입 탭) -->
<div class="card-section" style="margin-bottom:0">
<div class="card-header">
<h3>진행 중인 통관 건</h3>
<button onclick="go('status')">전체</button>
</div>
<div class="prog-tab-bar">
<button class="prog-tab active" onclick="switchProgTab('export', this)">수출 (6건)</button>
<button class="prog-tab" onclick="switchProgTab('import', this)">수입 (9건)</button>
</div>
<!-- 수출 목록 -->
<div class="prog-list active" id="prog-export">
<div class="prog-item">
<div class="prog-item-left">
<div class="prog-item-id">EXP-OW-001</div>
<div class="prog-item-party">Global Trade Inc.</div>
</div>
<div class="prog-item-right">
<button class="mini mini-sup" onclick="go('export'); showSupplement();">보완요청 확인</button>
</div>
</div>
<div class="prog-item">
<div class="prog-item-left">
<div class="prog-item-id">EXP-OW-003</div>
<div class="prog-item-party">Euro Parts GmbH</div>
</div>
<div class="prog-item-right">
<button class="mini mini-sup" onclick="go('export')">조회</button>
</div>
</div>
<div class="prog-item">
<div class="prog-item-left">
<div class="prog-item-id">EXP-OW-005</div>
<div class="prog-item-party">Asia Logistics Ltd.</div>
</div>
<div class="prog-item-right">
<button class="mini mini-sup" onclick="go('export')">조회</button>
</div>
</div>
<div class="prog-item">
<div class="prog-item-left">
<div class="prog-item-id">EXP-OW-006</div>
<div class="prog-item-party">US Tech Corp.</div>
</div>
<div class="prog-item-right">
<button class="mini mini-sup" onclick="go('export')">조회</button>
</div>
</div>
</div>
<!-- 수입 목록 -->
<div class="prog-list" id="prog-import">
<div class="prog-item">
<div class="prog-item-left">
<div class="prog-item-id">IMP-OW-004</div>
<div class="prog-item-party">Shenzhen Device Co., Ltd.</div>
</div>
<div class="prog-item-right">
<span class="badge badge-urgent">AI세액</span>
<span class="prog-dday urgent">D-0</span>
<button class="mini mini-sup" onclick="go('import')">처리</button>
</div>
</div>
<div class="prog-item">
<div class="prog-item-left">
<div class="prog-item-id">IMP-OW-007</div>
<div class="prog-item-party">Tokyo Electronics KK</div>
</div>
<div class="prog-item-right">
<span class="badge badge-new">선적서류</span>
<span class="prog-dday warn">D-3</span>
<button class="mini mini-view" onclick="go('import')">열기</button>
</div>
</div>
<div class="prog-item">
<div class="prog-item-left">
<div class="prog-item-id">IMP-OW-009</div>
<div class="prog-item-party">Munich Precision GmbH</div>
</div>
<div class="prog-item-right">
<span class="badge badge-ok">D/O발급</span>
<span class="prog-dday safe">완료</span>
<button class="mini mini-view" onclick="go('import')">열기</button>
</div>
</div>
<div class="prog-item">
<div class="prog-item-left">
<div class="prog-item-id">IMP-OW-011</div>
<div class="prog-item-party">Shanghai Components Co.</div>
</div>
<div class="prog-item-right">
<span class="badge badge-wait">세금납부</span>
<span class="prog-dday urgent">14:00</span>
<button class="mini mini-sup" onclick="go('import')">처리</button>
</div>
</div>
</div>
</div>
<!-- ② 추가 서류 제출 요청 -->
<div class="card-section" style="margin-bottom:0">
<div class="card-header">
<h3>추가 서류 제출 요청 <span style="background:#fe8983;color:#752121;font-size:10px;font-weight:800;padding:2px 8px;margin-left:6px">3건</span></h3>
<button onclick="go('docs')">전체</button>
</div>
<div class="prog-tab-bar">
<button class="prog-tab active" onclick="switchDocReqTab('export', this)">수출 (1건)</button>
<button class="prog-tab" onclick="switchDocReqTab('import', this)">수입 (2건)</button>
</div>
<!-- 수출 추가 서류 요청 -->
<div class="prog-list active" id="doc-req-export">
<div class="doc-req-item">
<div class="doc-req-icon broker"></div>
<div class="doc-req-body">
<div class="doc-req-title">원산지증명서 최종본</div>
<div class="doc-req-meta">관세사 요청  ·  EXP-OW-001  ·  에이스관세사무소</div>
</div>
<div class="doc-req-right">
<span class="doc-req-dday warn">D-3</span>
<button class="mini mini-view" onclick="go('export')">열기</button>
</div>
</div>
</div>
<!-- 수입 추가 서류 요청 -->
<div class="prog-list" id="doc-req-import">
<div class="doc-req-item">
<div class="doc-req-icon customs"></div>
<div class="doc-req-body">
<div class="doc-req-title">거래가격 소명자료 재업로드</div>
<div class="doc-req-meta">관세사 요청  ·  IMP-OW-004  ·  삼일관세법인</div>
</div>
<div class="doc-req-right">
<span class="doc-req-dday urgent">D-1</span>
<button class="mini mini-sup" onclick="go('import')">업로드</button>
</div>
</div>
<div class="doc-req-item">
<div class="doc-req-icon broker"></div>
<div class="doc-req-body">
<div class="doc-req-title">HS코드 카탈로그 파일</div>
<div class="doc-req-meta">관세사 요청  ·  IMP-OW-004  ·  삼일관세법인</div>
</div>
<div class="doc-req-right">
<span class="doc-req-dday warn">이번 주</span>
<button class="mini mini-view" onclick="go('import')">열기</button>
</div>
</div>
</div>
<!-- 안내 메시지 -->
<div style="padding:12px 16px;background:#fff8f8;border-top:1px solid #f1f5f9">
<div style="font-size:11px;color:#9f403d;font-weight:600">⚠ 관세사 요청 1건은 D-1 마감입니다. 즉시 처리하세요.</div>
</div>
</div>
<!-- ③ 최근 알림 피드 -->
<div class="card-section" style="margin-bottom:0">
<div class="card-header">
<h3>최근 알림</h3>
<button>전체</button>
</div>
<div class="feed-item">
<div class="feed-dot" style="background:#1d6b4f"></div>
<div class="feed-body">
<div class="feed-time">방금 전</div>
<div class="feed-text">수입건 AI 세액 계산 완료</div>
</div>
</div>
<div class="feed-item">
<div class="feed-dot"></div>
<div class="feed-body">
<div class="feed-time">1시간 전</div>
<div class="feed-text">수출신고필증 발급 완료</div>
</div>
</div>
<div class="feed-item">
<div class="feed-dot"></div>
<div class="feed-body">
<div class="feed-time">2시간 전</div>
<div class="feed-text">B/L 초안 v2 업로드됨</div>
</div>
</div>
<div class="feed-item">
<div class="feed-dot" style="background:#9f403d"></div>
<div class="feed-body">
<div class="feed-time">오늘 09:00</div>
<div class="feed-text">관세사 보완요청 수신</div>
</div>
</div>
<div class="feed-item">
<div class="feed-dot" style="background:#1d6b4f"></div>
<div class="feed-body">
<div class="feed-time">어제</div>
<div class="feed-text">환급 후보 건 알림 도착</div>
</div>
</div>
</div>
</div><!-- /dash-3col -->
<!-- ④ 운송 ETA · 선박 위치 요약 -->
<div class="card-section" style="margin-bottom:20px">
<div class="card-header">
<h3>운송 ETA · 선박 위치 요약</h3>
<button onclick="go('transport')">전체</button>
</div>
<div class="eta-strip" style="padding:16px;margin-bottom:0">
<div class="eta-card">
<div class="eta-route">상하이 → 인천</div>
<div class="eta-vessel">Ever Given  ·  IMP-OW-004</div>
<div class="eta-footer">
<div class="eta-date">ETA 04/22</div>
</div>
</div>
<div class="eta-card">
<div class="eta-route">부산 → LA</div>
<div class="eta-vessel">Maersk Star  ·  EXP-OW-003</div>
<div class="eta-footer">
<div class="eta-date">ETA 04/27</div>
</div>
</div>
<div class="eta-card">
<div class="eta-route">인천 → 함부르크</div>
<div class="eta-vessel">MSC Luna  ·  EXP-OW-006</div>
<div class="eta-footer">
<div class="eta-date">ETA 05/10</div>
</div>
</div>
</div>
</div>
</div>
    </main>

    <%@ include file="/WEB-INF/views/common/ownerModals.jsp" %>
    <%@ include file="/WEB-INF/views/common/footer.jsp" %>
  </div>
</div>

<%@ include file="/WEB-INF/views/common/ownerScripts.jsp" %>

<script>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof initExportRankChart === 'function') initExportRankChart();
});
</script>
</body>
</html>
