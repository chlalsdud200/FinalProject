<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>보세창고 통합현황 - TACS</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/base.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/sidebar.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/topbar.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/dashboard.css">
</head>
<body>
<div class="app" id="app">
    <!-- Sidebar -->
    <jsp:include page="/WEB-INF/views/warehouse/common/sidebar.jsp" />
    
    <!-- Main Wrapper -->
    <div class="main-wrap">
        <!-- Header -->
        <jsp:include page="/WEB-INF/views/warehouse/common/header.jsp" />
        
        <!-- Content -->
        <div class="content">
            <div class="page-title-row">
                <h2>보세창고 통합현황</h2>
                <div class="btn-row" style="align-items: center;">
                <c:set var="today" value="<%= new java.util.Date() %>"/>
                    <span class="date-label">
                    	<fmt:formatDate value="${today}" pattern="yyyy-MM-dd (E)"/>
                    </span>
                </div>
            </div>

            <!-- ── KPI 요약 (metric-strip 스타일) ── -->
            <div class="metric-strip">
                <div class="metric-box" onclick="location.href='${pageContext.request.contextPath}/warehouse/inbound.do'">
                    <span class="material-symbols-outlined">archive</span>
                    <div class="k">당일 반입 예정</div><div class="v">14</div><div class="s">B/L 데이터 연동 완료</div>
                </div>
                <div class="metric-box" onclick="location.href='${pageContext.request.contextPath}/warehouse/outbound.do'" style="border-left-color: #3b82f6;">
                    <span class="material-symbols-outlined">unarchive</span>
                    <div class="k">당일 반출 대기</div><div class="v">6</div><div class="s">필증 수리 100% 연동</div>
                </div>
                <div class="metric-box" onclick="location.href='${pageContext.request.contextPath}/warehouse/mypage.do'" style="border-left-color: #9f403d;">
                    <span class="material-symbols-outlined">warning</span>
                    <div class="k">미처리 알림</div><div class="v">3</div><div class="s">신규 업무 확인 필요</div>
                </div>
                <div class="metric-box" onclick="location.href='${pageContext.request.contextPath}/warehouse/customs.do'" style="border-left-color: #7c3aed;">
                    <span class="material-symbols-outlined">assignment_ind</span>
                    <div class="k">금일 세관 검사</div><div class="v">2</div><div class="s">검사 대상 건수</div>
                </div>
            </div>

            <!-- ── 대시보드 메인 그리드 ── -->
            <div class="dash-3col">
                <!-- 1컬럼: 실시간 현황 -->
                <div class="flex-col" style="gap:20px">
                    <div class="card-section">
                        <div class="card-header">
                            <h3>당일 화물 입출고 현황</h3>
                            <button onclick="location.href='${pageContext.request.contextPath}/warehouse/inventory'">전체</button>
                        </div>
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>유형</th>
                                    <th>운송의뢰번호</th>
                                    <th>화주</th>
                                    <th>상태</th>
                                    <th>시간</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span class="badge badge-new">입고</span></td>
                                    <td style="font-weight:700">HDMU-1029384</td><td>삼성전자</td>
                                    <td><span class="doc-status ok">반입신고완료</span></td><td style="color:#94a3b8;font-size:11px">
                                    	
                                    </td>
                                </tr>
                                <tr>
                                    <td><span class="badge badge-ok">출고</span></td>
                                    <td style="font-weight:700">ONEU-2233445</td><td>신선유통</td>
                                    <td><span class="doc-status wait">반출증대기</span></td><td style="color:#94a3b8;font-size:11px">
                                    
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- 2컬럼: 업무 알림 -->
                <div class="card-section" style="margin-bottom:0">
                    <div class="card-header"><h3>업무 알림</h3><button>전체</button></div>
                    <div style="padding:10px 0">
                        <div class="feed-item">
                            <div class="feed-dot" style="background:#1d6b4f"></div>
                            <div class="feed-body">
                                <div class="feed-time">방금 전</div>
                                <div class="feed-text">세관 고시 개정안 실시간 수신 완료</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3컬럼: 창고별 적재 현황 그래프 -->
                <div class="card-section" style="margin-bottom:0">
                    <div class="card-header">
                        <h3>창고별 적재 현황</h3>
                        <button onclick="location.href='${pageContext.request.contextPath}/warehouse/inventory'">전체</button>
                    </div>
                    <div style="padding: 20px;">
                        <div style="margin-bottom: 20px;">
                            <div class="flex-sb" style="margin-bottom: 8px;">
                                <span style="font-size: 12px; font-weight: 700;">A창고 (일반화물)</span>
                                <span style="font-size: 11px; color: #565e74; font-weight: 800;">85%</span>
                            </div>
                            <div style="height: 8px; background: #f1f5f9; border-radius: 4px; overflow: hidden;">
                                <div style="width: 85%; height: 100%; background: #565e74;"></div>
                            </div>
                        </div>
                        <div style="margin-bottom: 20px;">
                            <div class="flex-sb" style="margin-bottom: 8px;">
                                <span style="font-size: 12px; font-weight: 700;">B창고 (냉동/냉장)</span>
                                <span style="font-size: 11px; color: #3b82f6; font-weight: 800;">62%</span>
                            </div>
                            <div style="height: 8px; background: #f1f5f9; border-radius: 4px; overflow: hidden;">
                                <div style="width: 62%; height: 100%; background: #3b82f6;"></div>
                            </div>
                        </div>
                        <div style="margin-bottom: 20px;">
                            <div class="flex-sb" style="margin-bottom: 8px;">
                                <span style="font-size: 12px; font-weight: 700;">C창고 (위험물)</span>
                                <span style="font-size: 11px; color: #9f403d; font-weight: 800;">45%</span>
                            </div>
                            <div style="height: 8px; background: #f1f5f9; border-radius: 4px; overflow: hidden;">
                                <div style="width: 45%; height: 100%; background: #9f403d;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <jsp:include page="/WEB-INF/views/warehouse/common/footer.jsp" />
    </div>
</div>

<script src="${pageContext.request.contextPath}/resources/js/warehouse/common.js"></script>
<script src="${pageContext.request.contextPath}/resources/js/warehouse/navigation.js"></script>
<script src="${pageContext.request.contextPath}/resources/js/warehouse/dashboard.js"></script>
</body>
</html>
