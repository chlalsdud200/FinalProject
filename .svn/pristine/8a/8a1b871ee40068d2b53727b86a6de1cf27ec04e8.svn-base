/* import-arrival.js
 * 수입 도착예정 및 입항추적 화면 정리본.
 *
 * 정리 기준
 * - D/O 첨부 업로드가 정상 동작하는 import-ui.js는 건드리지 않음.
 * - 도착/입항 화면에 직접 필요한 함수만 유지.
 * - 사용하지 않는 중복 화면 함수 제거:
 *   buildRealtimeTrackingPanel, buildCargoStatusSharePanel,
 *   buildStatusNotificationPanel, bindShareStatusActions.
 */

function buildImportEtaTrackingListPanel() {
    var arrivalList = Array.isArray(window.TRANSPORT_IMPORT_ARRIVAL_TRACKING)
        ? window.TRANSPORT_IMPORT_ARRIVAL_TRACKING
        : [];

    // JSP를 거치지 않고 비동기로 화면을 열면 초기 배열이 비어 있을 수 있어서 JSON API로 보강 조회한다.
    if (arrivalList.length === 0 && !window.__TACS_IMPORT_ARRIVAL_LOADING && !window.__TACS_IMPORT_ARRIVAL_LOADED) {
        window.__TACS_IMPORT_ARRIVAL_LOADING = true;
        const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';

        fetch(contextPath + '/transport/import/arrival-tracking/list.do', {
            method: 'GET',
            headers: {'X-Requested-With': 'XMLHttpRequest'}
        })
            .then(function (res) {
                if (!res.ok) throw new Error('HTTP ' + res.status);
                return res.json();
            })
            .then(function (list) {
                window.TRANSPORT_IMPORT_ARRIVAL_TRACKING = Array.isArray(list) ? list : [];
                window.__TACS_IMPORT_ARRIVAL_LOADED = true;

                const body = document.getElementById('detail-body');
                if (!body) return;

                const currentItem = body.dataset ? (body.dataset.currentItem || '') : '';
                const isEtaScreen = currentItem === 'TACS-FW-020' || (body.textContent || '').includes('도착예정 및 입항추적');
                if (isEtaScreen) {
                    body.innerHTML = '<div class="space-y-6">' + buildImportEtaTrackingListPanel() + '</div>';
                    body.dataset.currentGroup = 'import';
                    body.dataset.currentItem = 'TACS-FW-020';
                    if (typeof normalizeDetailActionButtons === 'function') normalizeDetailActionButtons();
                }
            })
            .catch(function (err) {
                console.error('[도착예정 및 입항추적 목록 조회 실패]', err);
                window.__TACS_IMPORT_ARRIVAL_LOADED = true;
            })
            .finally(function () {
                window.__TACS_IMPORT_ARRIVAL_LOADING = false;
            });
    }

    function normalizeArrivalStatus(row, fallbackStatus, etaValue) {
        /*
         * 2026-05-28 fix
         * 화면 요구사항: 도착/입항 화면의 도착상태는 DB의 PENDING/IN_TRANSIT 등
         * 원본 값을 그대로 보여주지 않고 무조건 '도착'으로 표시한다.
         */
        return '도착';
    }

    function formatArrivalDate(value) {
        const raw = (value == null ? '' : String(value)).trim();
        if (!raw || raw === '-') return '-';
        const digits = raw.replace(/[^0-9]/g, '');
        if (digits.length === 8) {
            return `${digits.slice(0, 4)}-${digits.slice(4, 6)}-${digits.slice(6, 8)}`;
        }
        return raw;
    }

    function safeEscape(value) {
        if (typeof escapeHtml === 'function') return escapeHtml(value);
        return String(value == null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function displayPortName(value) {
        const raw = String(value == null ? '' : value).trim();
        if (!raw || raw === '-') return '';
        const upper = raw.toUpperCase();
        if (upper === 'KPPUS' || upper === 'KRPUS' || upper === 'BUSAN') return '부산항';
        if (upper === 'OSAKA') return '오사카항';
        return raw;
    }

    function arrivalStatusChip(value) {
        const label = String(value || '').trim();
        if (!label) return '';
        if (typeof buildStatusChip === 'function') return buildStatusChip(label);
        return `<span class="status-chip status-confirmed">${safeEscape(label)}</span>`;
    }

    const rows = arrivalList.length > 0
        ? arrivalList.map(row => {
            const trcNo = row.trcNo || row.TRC_NO || row.transportRequestNo || row.requestNo || row.tcsTrcNo || row.ianTrcNo || row.IAN_TRC_NO || '';
            const noticeNo = importArrivalNoticeNoValue(row.arrivalNoticeNo, row.arrivalNoticeReqNo, row.noticeNo, row.ntcNo, row.ianNo, row.IAN_NO);
            const mblNo = row.mblNo || '-';
            const hblNo = row.hblNo || '-';
            const ownerNm = row.ownerNm || row.owner || row.owrNm || '-';
            const carrierNm = row.carrierNm || '-';
            const cargoMgmtNo = row.cargoMgmtNo || row.wirCargoMgmtNo || row.WIR_CARGO_MGMT_NO || '';
            const deptPortNm = displayPortName(row.deptPortNm) || displayPortName(row.deptPortCd) || '-';
            const arvlPortNm = displayPortName(row.currentLoc) || displayPortName(row.arvlPortNm) || displayPortName(row.arvlPortCd) || '-';
            const statusNm = row.statusNm || row.statusCd || '-';

            const vessel = row.shipNo || carrierNm || '-';
            const location = arvlPortNm || '-';
            const eta = formatArrivalDate(row.eta || row.arrivalEta || row.arrvDt || row.irArrvSchdYmd || row.desiredDeliveryAt || row.requestDt || '-');
            const arrivalStatus = normalizeArrivalStatus(row, statusNm, eta);
            const isNoticeSent = isImportArrivalNoticeSent(row);
            const isNoticeIssued = isImportArrivalNoticeIssued(row) || isNoticeSent;
            const issueStatus = isNoticeIssued ? '발급완료' : '미발급';
            const sendStatus = isNoticeSent ? '발송완료' : '미발송';

            const route = `${deptPortNm} 출항 → ${location} 입항 예정`;
            const terminal = `${arvlPortNm} 터미널`;
            const commonDataAttrs = `
                    data-request-no="${safeEscape(trcNo)}"
                    data-notice-no="${safeEscape(noticeNo)}"
                    data-display-request-no="${safeEscape(noticeNo || trcNo)}"
                    data-transport-request-no="${safeEscape(trcNo)}"
                    data-trc-no="${safeEscape(trcNo)}"
                    data-owner-id="${safeEscape(row.ownerId || row.owrId || '')}"
                    data-owner-nm="${safeEscape(ownerNm)}"
                    data-mbl-no="${safeEscape(mblNo)}"
                    data-hbl-no="${safeEscape(hblNo)}"
                    data-cargo-mgmt-no="${safeEscape(cargoMgmtNo)}"
                    data-vessel="${safeEscape(vessel)}"
                    data-location="${safeEscape(location)}"
                    data-status="${safeEscape(arrivalStatus)}"
                    data-eta="${safeEscape(eta)}"
                    data-arrival-status="${safeEscape(arrivalStatus)}"
                    data-issue-status="${safeEscape(issueStatus)}"
                    data-send-status="${safeEscape(sendStatus)}"
                    data-notice-status="${safeEscape(sendStatus)}"
                    data-notice-issued="${isNoticeIssued ? 'Y' : 'N'}"
                    data-notice-sent="${isNoticeSent ? 'Y' : 'N'}"
                    data-route="${safeEscape(route)}"
                    data-terminal="${safeEscape(terminal)}"`;

            const issueStatusBtn = `<button type="button"
                    onclick="window.openImportArrivalNoticeStatusModalFromButton(this); return false;"
                    class="arrival-notice-issue-status-btn status-chip ${isNoticeIssued ? 'status-confirmed' : 'status-wait'}"
                    style="border:0; cursor:pointer;"
                    ${commonDataAttrs}>${issueStatus}</button>`;

            const noticeBtn = !isNoticeSent
                ? `<button type="button"
                    onclick="window.openImportArrivalNoticeSendModalFromButton(this); return false;"
                    class="arrival-notice-send-btn"
                    style="min-width:104px; min-height:30px; padding:0 12px; border:1px solid #cbd5e1; background:#f8fafc; color:#334155; font-size:11px; font-weight:900; line-height:1; white-space:nowrap; display:inline-flex; align-items:center; justify-content:center; cursor:pointer;"
                    ${commonDataAttrs}>도착통지서 발송</button>`
                : '<span class="status-chip status-confirmed">발송완료</span>';

            return `
                <tr>
                    <td class="font-bold">${safeEscape(noticeNo || '-')}</td>
                    <td>${safeEscape(mblNo)}</td>
                    <td>${safeEscape(hblNo)}</td>
                    <td>${safeEscape(location)}</td>
                    <td class="arrival-status-cell">${arrivalStatusChip(arrivalStatus)}</td>
                    <td>${safeEscape(eta)}</td>
                    <td class="arrival-notice-status-cell arrival-notice-issue-status-cell">${issueStatusBtn}</td>
                    <td class="arrival-notice-send-action-cell">${noticeBtn}</td>
                </tr>
            `;
        }).join('')
        : `
            <tr>
                <td colspan="8" class="text-center text-slate-500 py-6">
                    ${window.__TACS_IMPORT_ARRIVAL_LOADING ? '도착예정 및 입항추적 데이터를 불러오는 중입니다.' : '도착예정 및 입항추적 데이터가 없습니다.'}
                </td>
            </tr>
        `;

    return `
        <div class="section-card">
            <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
                <div>
                    <h4 class="text-sm font-bold text-slate-900">도착예정 및 입항추적</h4>
                </div>
            </div>
            <div class="p-6 space-y-6">
                <div class="list-search-grid">
                    <div><label class="field-label">Master B/L</label><input class="field-input" type="text" placeholder="Master B/L 검색" /></div>
                    <div><label class="field-label">House B/L</label><input class="field-input" type="text" placeholder="House B/L 검색" /></div>
                    <div><label class="field-label">도착상태</label><select class="field-select"><option>전체</option><option>입항전</option><option>운항중</option><option>도착</option></select></div>
                    <div><label class="field-label">도착예정일</label><input class="field-input" type="date" /></div>
                    <button type="button" id="importArrivalSearchBtn">조회</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full tbl">
                        <thead>
                            <tr>
                                <th>도착통지서 번호</th>
                                <th>Master B/L</th>
                                <th>House B/L</th>
                                <th>현재 위치</th>
                                <th>도착상태</th>
                                <th>도착예정일</th>
                                <th>도착통지서 상태</th>
                                <th>도착통지서 발송</th>
                            </tr>
                        </thead>
                        <tbody class="text-[11px] text-slate-700">
                            ${rows}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    `;
}


function importArrivalRequestNoKeys(value) {
    const raw = String(value == null ? '' : value).trim().toUpperCase();
    if (!raw || raw === '-') return [];
    const noTrc = raw.replace(/^TRC-/, '');
    const compact = noTrc.replace(/-/g, '');
    const compactNoPrefix = compact.replace(/^TRC/, '');
    const nums = noTrc.match(/^(IMP|EXP)-?(\d{4})-?(\d{2})-?(\d{2})-?(\d+)$/);
    const canonical = nums ? (nums[1] + nums[2] + nums[3] + nums[4] + String(parseInt(nums[5], 10))) : '';
    return [raw, noTrc, compact, compactNoPrefix, canonical].filter(function (item, index, arr) {
        return item && arr.indexOf(item) === index;
    });
}

function importArrivalRowValues(row) {
    row = row || {};
    return [
        row.trcNo, row.TRC_NO, row.transportRequestNo, row.requestNo, row.tcsTrcNo,
        row.reqNo, row.arrivalNoticeNo, row.arrivalNoticeReqNo, row.noticeNo, row.ntcNo,
        row.ianNo, row.IAN_NO, row.ianTrcNo, row.IAN_TRC_NO, row.ianIrNo, row.IAN_IR_NO,
        row.irNo, row.IR_NO, row.relatedTrcNo
    ];
}

function importArrivalRowMatches(row, no) {
    const target = importArrivalRequestNoKeys(no);
    if (!target.length || !row) return false;
    const keys = [];
    importArrivalRowValues(row).forEach(function (value) {
        keys.push.apply(keys, importArrivalRequestNoKeys(value));
    });
    return target.some(function (key) { return keys.indexOf(key) >= 0; });
}

function importArrivalEscape(value) {
    if (typeof escapeHtml === 'function') return escapeHtml(value);
    return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function isImportArrivalNoticeNo(value) {
    return /^IAN[-_]/i.test(String(value || '').trim());
}

function importArrivalNoticeNoValue() {
    for (let i = 0; i < arguments.length; i++) {
        const value = String(arguments[i] || '').trim();
        if (isImportArrivalNoticeNo(value)) return value;
    }
    return '';
}

function importArrivalClean(value) {
    return String(value == null ? '' : value).trim();
}

function importArrivalIsTruthyValue(value) {
    const raw = importArrivalClean(value);
    if (!raw || raw === '-') return false;
    return !['N', 'NO', 'FALSE', '0', '미발급', '미발송', 'TRC_NTC_NSENT', 'NSENT', 'NOT_SENT'].includes(raw.toUpperCase());
}

function isImportArrivalNoticeSent(row) {
    if (!row) return false;
    const values = [
        row.noticeStatus, row.noticeStatusCd, row.noticeStatusNm,
        row.arrivalNoticeStatus, row.arrivalNoticeStatusCd, row.arrivalNoticeStatusNm,
        row.arrivalNoticeSendStatusCd, row.ianSendSttsCd, row.ianSendSttsNm,
        row.IAN_SEND_STTS_CD, row.IAN_SEND_STTS_NM, row.sendStatusCd, row.sendSttsCd, row.sendStatusNm
    ];
    return values.some(function (value) {
        const raw = importArrivalClean(value);
        const upper = raw.toUpperCase();
        return raw === '발송완료' || raw === '통지완료' || ['TRC_NTC_SENT', 'SENT', 'SEND', 'Y', 'DONE'].includes(upper);
    });
}

function isImportArrivalNoticeIssued(row) {
    if (!row) return false;
    if (isImportArrivalNoticeSent(row)) return true;
    const issueValues = [
        row.noticeIssueStatus, row.noticeIssueStatusCd, row.noticeIssueStatusNm,
        row.arrivalNoticeIssueStatus, row.arrivalNoticeIssueStatusCd, row.arrivalNoticeIssueStatusNm,
        row.noticeIssuedYn, row.arrivalNoticeIssuedYn, row.issuedYn, row.IAN_ISSUED_YN
    ];
    if (issueValues.some(function (value) {
        const raw = importArrivalClean(value);
        const upper = raw.toUpperCase();
        return raw === '발급완료' || ['ISSUED', 'TRC_NTC_ISSUED', 'Y', 'DONE'].includes(upper);
    })) return true;

    const noticeNo = importArrivalNoticeNoValue(row.arrivalNoticeNo, row.arrivalNoticeReqNo, row.noticeNo, row.ntcNo, row.ianNo, row.IAN_NO);
    return importArrivalIsTruthyValue(noticeNo);
}

function findImportArrivalRowByNo(no) {
    const storeNames = [
        'TRANSPORT_IMPORT_ARRIVAL_TRACKING',
        'TRANSPORT_IMPORT_ARRIVAL_LIST',
        '__TACS_IMPORT_ARRIVAL_TRACKING_ROWS'
    ];
    for (const name of storeNames) {
        const list = window[name];
        if (!Array.isArray(list)) continue;
        const row = list.find(function (item) { return importArrivalRowMatches(item, no); });
        if (row) return row;
    }
    return null;
}

function markImportArrivalRowIssued(row, trcNo, noticeNo) {
    if (!row) return;
    if (trcNo && trcNo !== '-') {
        row.trcNo = row.trcNo || trcNo;
        row.TRC_NO = row.TRC_NO || trcNo;
        row.transportRequestNo = row.transportRequestNo || trcNo;
        row.requestNo = row.requestNo || trcNo;
    }
    if (noticeNo && noticeNo !== '-') {
        row.reqNo = row.reqNo || trcNo || noticeNo;
        row.arrivalNoticeNo = noticeNo;
        row.arrivalNoticeReqNo = noticeNo;
        row.noticeNo = noticeNo;
        row.ntcNo = noticeNo;
        row.ianNo = noticeNo;
        row.IAN_NO = noticeNo;
    }
    row.noticeIssuedYn = 'Y';
    row.arrivalNoticeIssuedYn = 'Y';
    row.noticeIssueStatusCd = 'ISSUED';
    row.noticeIssueStatusNm = '발급완료';
    row.arrivalNoticeIssueStatusCd = 'ISSUED';
    row.arrivalNoticeIssueStatusNm = '발급완료';
    if (!isImportArrivalNoticeSent(row)) {
        row.noticeStatus = 'TRC_NTC_NSENT';
        row.noticeStatusCd = 'TRC_NTC_NSENT';
        row.noticeStatusNm = '미발송';
        row.arrivalNoticeStatus = 'TRC_NTC_NSENT';
        row.arrivalNoticeStatusCd = 'TRC_NTC_NSENT';
        row.arrivalNoticeSendStatusCd = 'TRC_NTC_NSENT';
        row.ianSendSttsCd = 'TRC_NTC_NSENT';
        row.ianSendSttsNm = '미발송';
        row.IAN_SEND_STTS_CD = 'TRC_NTC_NSENT';
        row.IAN_SEND_STTS_NM = '미발송';
        row.sendStatusCd = 'TRC_NTC_NSENT';
        row.sendSttsCd = 'TRC_NTC_NSENT';
        row.sendStatusNm = '미발송';
    }
}

function markImportArrivalStoresIssued(trcNo, noticeNo) {
    const storeNames = [
        'TRANSPORT_IMPORT_ARRIVAL_TRACKING',
        'TRANSPORT_IMPORT_ARRIVAL_LIST',
        '__TACS_IMPORT_ARRIVAL_TRACKING_ROWS'
    ];
    let matched = false;
    storeNames.forEach(function (name) {
        const list = window[name];
        if (!Array.isArray(list)) return;
        list.forEach(function (row) {
            if (importArrivalRowMatches(row, trcNo) || importArrivalRowMatches(row, noticeNo)) {
                markImportArrivalRowIssued(row, trcNo, noticeNo);
                matched = true;
            }
        });
    });
    if (!matched) {
        window.TRANSPORT_IMPORT_ARRIVAL_TRACKING = Array.isArray(window.TRANSPORT_IMPORT_ARRIVAL_TRACKING) ? window.TRANSPORT_IMPORT_ARRIVAL_TRACKING : [];
        const row = {trcNo: trcNo || '', TRC_NO: trcNo || '', requestNo: trcNo || '', reqNo: trcNo || ''};
        markImportArrivalRowIssued(row, trcNo, noticeNo || '');
        window.TRANSPORT_IMPORT_ARRIVAL_TRACKING.push(row);
    }
    window.__TACS_IMPORT_ARRIVAL_LOADED = true;
    window.__TACS_IMPORT_ARRIVAL_LOADING = false;
}

function markImportArrivalRowSent(row, trcNo, noticeNo) {
    if (!row) return;
    markImportArrivalRowIssued(row, trcNo, noticeNo);
    if (trcNo && trcNo !== '-') {
        row.trcNo = row.trcNo || trcNo;
        row.TRC_NO = row.TRC_NO || trcNo;
        row.transportRequestNo = row.transportRequestNo || trcNo;
        row.requestNo = row.requestNo || trcNo;
    }
    if (noticeNo && noticeNo !== '-') {
        row.reqNo = noticeNo;
        row.arrivalNoticeNo = noticeNo;
        row.arrivalNoticeReqNo = noticeNo;
        row.noticeNo = noticeNo;
        row.ianNo = noticeNo;
        row.IAN_NO = noticeNo;
    }
    row.noticeStatus = 'TRC_NTC_SENT';
    row.noticeStatusCd = 'TRC_NTC_SENT';
    row.noticeStatusNm = '발송완료';
    row.arrivalNoticeStatus = 'TRC_NTC_SENT';
    row.arrivalNoticeStatusCd = 'TRC_NTC_SENT';
    row.arrivalNoticeSendStatusCd = 'TRC_NTC_SENT';
    row.ianSendSttsCd = 'TRC_NTC_SENT';
    row.ianSendSttsNm = '발송완료';
    row.IAN_SEND_STTS_CD = 'TRC_NTC_SENT';
    row.IAN_SEND_STTS_NM = '발송완료';
    row.sendStatusCd = 'TRC_NTC_SENT';
    row.sendSttsCd = 'TRC_NTC_SENT';
    row.sendStatusNm = '발송완료';
    row.statusCd = 'TRC_NTC_SENT';
    row.statusNm = '발송완료';
}

function markImportArrivalStoresSent(trcNo, noticeNo) {
    const storeNames = [
        'TRANSPORT_IMPORT_ARRIVAL_TRACKING',
        'TRANSPORT_IMPORT_ARRIVAL_LIST',
        '__TACS_IMPORT_ARRIVAL_TRACKING_ROWS'
    ];
    let matched = false;
    storeNames.forEach(function (name) {
        const list = window[name];
        if (!Array.isArray(list)) return;
        list.forEach(function (row) {
            if (importArrivalRowMatches(row, trcNo) || importArrivalRowMatches(row, noticeNo)) {
                markImportArrivalRowSent(row, trcNo, noticeNo);
                matched = true;
            }
        });
    });
    if (!matched) {
        window.TRANSPORT_IMPORT_ARRIVAL_TRACKING = Array.isArray(window.TRANSPORT_IMPORT_ARRIVAL_TRACKING) ? window.TRANSPORT_IMPORT_ARRIVAL_TRACKING : [];
        const row = {trcNo: trcNo || '', TRC_NO: trcNo || '', requestNo: trcNo || '', reqNo: noticeNo || trcNo || ''};
        markImportArrivalRowSent(row, trcNo, noticeNo || trcNo);
        window.TRANSPORT_IMPORT_ARRIVAL_TRACKING.push(row);
    }
    window.__TACS_IMPORT_ARRIVAL_LOADED = true;
    window.__TACS_IMPORT_ARRIVAL_LOADING = false;
}

function importArrivalButtonDataAttrs(data) {
    const row = data.row || {};
    const trcNo = data.trcNo || row.trcNo || row.TRC_NO || row.transportRequestNo || row.requestNo || '';
    const noticeNo = importArrivalNoticeNoValue(data.noticeNo, row.arrivalNoticeNo, row.arrivalNoticeReqNo, row.noticeNo, row.ntcNo, row.ianNo, row.IAN_NO);
    const mblNo = data.mblNo || row.mblNo || row.MBL_NO || '';
    const hblNo = data.hblNo || row.hblNo || row.HBL_NO || '';
    const ownerNm = data.ownerNm || row.ownerNm || row.owner || row.owrNm || '';
    const issueStatus = data.issueStatus || (isImportArrivalNoticeIssued(row) || data.issued ? '발급완료' : '미발급');
    const sendStatus = data.sendStatus || (isImportArrivalNoticeSent(row) || data.sent ? '발송완료' : '미발송');
    return `data-request-no="${importArrivalEscape(trcNo)}"
            data-notice-no="${importArrivalEscape(noticeNo)}"
            data-display-request-no="${importArrivalEscape(noticeNo || trcNo)}"
            data-transport-request-no="${importArrivalEscape(trcNo)}"
            data-trc-no="${importArrivalEscape(trcNo)}"
            data-owner-nm="${importArrivalEscape(ownerNm)}"
            data-mbl-no="${importArrivalEscape(mblNo)}"
            data-hbl-no="${importArrivalEscape(hblNo)}"
            data-issue-status="${importArrivalEscape(issueStatus)}"
            data-send-status="${importArrivalEscape(sendStatus)}"
            data-notice-status="${importArrivalEscape(sendStatus)}"
            data-notice-issued="${issueStatus === '발급완료' ? 'Y' : 'N'}"
            data-notice-sent="${sendStatus === '발송완료' ? 'Y' : 'N'}"`;
}

function importArrivalIssueStatusButton(data) {
    const issued = !!data.issued;
    const attrs = importArrivalButtonDataAttrs(Object.assign({}, data, {issueStatus: issued ? '발급완료' : '미발급'}));
    return `<button type="button" onclick="window.openImportArrivalNoticeStatusModalFromButton(this); return false;"
            class="arrival-notice-issue-status-btn status-chip ${issued ? 'status-confirmed' : 'status-wait'}"
            style="border:0; cursor:pointer;" ${attrs}>${issued ? '발급완료' : '미발급'}</button>`;
}

function importArrivalIssueActionButton(data) {
    const issued = !!data.issued;
    if (issued) return '<span class="status-chip status-confirmed">발급완료</span>';
    const attrs = importArrivalButtonDataAttrs(Object.assign({}, data, {issueStatus: '미발급'}));
    return `<button type="button" onclick="window.issueImportArrivalNoticeFromButton(this); return false;"
            class="arrival-notice-issue-btn px-4 py-2 bg-slate-600 text-white text-xs font-bold"
            style="min-width:52px; white-space:nowrap; display:inline-flex; align-items:center; justify-content:center;" ${attrs}>발급</button>`;
}

function importArrivalSendActionButton(data) {
    const issued = !!data.issued;
    const sent = !!data.sent;
    if (sent) return '<span class="status-chip status-confirmed">발송완료</span>';
    const attrs = importArrivalButtonDataAttrs(Object.assign({}, data, {issueStatus: issued ? '발급완료' : '미발급', sendStatus: '미발송'}));
    return `<button type="button" onclick="window.openImportArrivalNoticeSendModalFromButton(this); return false;"
            class="arrival-notice-send-btn"
            style="min-width:104px; min-height:30px; padding:0 12px; border:1px solid #cbd5e1; background:#f8fafc; color:#334155; font-size:11px; font-weight:900; line-height:1; white-space:nowrap; display:inline-flex; align-items:center; justify-content:center; cursor:pointer;"
            ${attrs}>도착통지서 발송</button>`;
}

function patchImportArrivalNoticeIssuedDom(trcNo, noticeNo) {
    const keys = [];
    [trcNo, noticeNo].forEach(function (no) { keys.push.apply(keys, importArrivalRequestNoKeys(no)); });
    const selector = '.arrival-notice-issue-btn, .arrival-notice-send-btn, .arrival-notice-issue-status-btn, .import-ui-arrival-send-btn';
    document.querySelectorAll(selector).forEach(function (el) {
        const btnKeys = [];
        [
            el.dataset.trcNo, el.dataset.transportRequestNo, el.dataset.requestNo,
            el.dataset.noticeNo, el.dataset.displayRequestNo
        ].forEach(function (no) { btnKeys.push.apply(btnKeys, importArrivalRequestNoKeys(no)); });
        const matched = keys.length === 0 || keys.some(function (key) { return btnKeys.indexOf(key) >= 0; });
        if (!matched) return;

        el.dataset.noticeIssued = 'Y';
        el.dataset.issueStatus = '발급완료';
        if (noticeNo && noticeNo !== '-') {
            el.dataset.noticeNo = noticeNo;
            el.dataset.displayRequestNo = noticeNo;
        }

        const rowEl = el.closest('tr');
        if (rowEl) {
            const noCell = rowEl.querySelector('td:first-child');
            const table = rowEl.closest('table');
            const firstHeader = table ? (table.querySelector('thead th:first-child')?.textContent || '') : '';
            const issueStatusCell = rowEl.querySelector('.arrival-notice-issue-status-cell, .arrival-notice-status-cell');
            const issueActionCell = rowEl.querySelector('.arrival-notice-issue-action-cell');
            const sendActionCell = rowEl.querySelector('.arrival-notice-send-action-cell');
            const sendBtn = rowEl.querySelector('.arrival-notice-send-btn, .import-ui-arrival-send-btn');
            if (noCell && noticeNo && firstHeader.indexOf('의뢰번호') < 0) noCell.textContent = noticeNo;
            if (issueStatusCell) issueStatusCell.innerHTML = importArrivalIssueStatusButton({trcNo: trcNo, noticeNo: noticeNo, issued: true, sent: false});
            if (sendBtn) {
                sendBtn.classList.add('bg-slate-600', 'text-white');
                sendBtn.dataset.noticeIssued = 'Y';
                if (noticeNo) sendBtn.dataset.noticeNo = noticeNo;
            }
            if (sendActionCell && !sendActionCell.querySelector('.arrival-notice-send-btn')) {
                sendActionCell.innerHTML = importArrivalSendActionButton({trcNo: trcNo, noticeNo: noticeNo, issued: true, sent: false});
            }
        }
    });
}

window.patchImportArrivalNoticeIssuedDom = patchImportArrivalNoticeIssuedDom;

function patchImportArrivalNoticeSentDom(trcNo, noticeNo) {
    const keys = [];
    [trcNo, noticeNo].forEach(function (no) { keys.push.apply(keys, importArrivalRequestNoKeys(no)); });
    document.querySelectorAll('.arrival-notice-send-btn, .import-ui-arrival-send-btn').forEach(function (btn) {
        const btnKeys = [];
        [
            btn.dataset.trcNo, btn.dataset.transportRequestNo, btn.dataset.requestNo,
            btn.dataset.noticeNo, btn.dataset.displayRequestNo
        ].forEach(function (no) { btnKeys.push.apply(btnKeys, importArrivalRequestNoKeys(no)); });
        const matched = keys.length === 0 || keys.some(function (key) { return btnKeys.indexOf(key) >= 0; });
        if (!matched) return;
        const rowEl = btn.closest('tr');
        if (rowEl) {
            const noCell = rowEl.querySelector('td:first-child');
            const table = rowEl.closest('table');
            const firstHeader = table ? (table.querySelector('thead th:first-child')?.textContent || '') : '';
            const issueStatusCell = rowEl.querySelector('.arrival-notice-issue-status-cell, .arrival-notice-status-cell');
            if (noCell && noticeNo && firstHeader.indexOf('의뢰번호') < 0) noCell.textContent = noticeNo;
            if (issueStatusCell) issueStatusCell.innerHTML = importArrivalIssueStatusButton({trcNo: trcNo, noticeNo: noticeNo, issued: true, sent: true});
        }
        const detail = btn.closest('.import-ui-request-detail[data-work-type="arrival"]');
        if (detail) {
            detail.querySelectorAll('.arrival-notice-send-status-cell').forEach(function (el) { el.textContent = '발송완료'; });
            detail.querySelectorAll('.arrival-notice-issue-status-cell, .arrival-notice-status-cell').forEach(function (el) {
                if ((el.textContent || '').trim() !== '발송완료') {
                    el.innerHTML = importArrivalIssueStatusButton({trcNo: trcNo, noticeNo: noticeNo, issued: true, sent: true});
                }
            });
        }
        btn.outerHTML = '<span class="status-chip status-confirmed">발송완료</span>';
    });
}

window.patchImportArrivalNoticeSentDom = patchImportArrivalNoticeSentDom;

window.openImportArrivalNoticeStatusModalFromButton = function (button) {
    if (!button) return;
    const baseTrcNo = button.dataset.trcNo || button.dataset.transportRequestNo || button.dataset.requestNo || '';
    const baseNoticeNo = importArrivalNoticeNoValue(button.dataset.noticeNo);
    const row = findImportArrivalRowByNo(baseTrcNo || baseNoticeNo) || {};
    const trcNo = baseTrcNo || row.trcNo || row.TRC_NO || row.transportRequestNo || row.requestNo || '';
    const noticeNo = importArrivalNoticeNoValue(baseNoticeNo, row.arrivalNoticeNo, row.arrivalNoticeReqNo, row.noticeNo, row.ntcNo, row.ianNo, row.IAN_NO);
    const ownerNm = button.dataset.ownerNm || row.ownerNm || row.owner || row.owrNm || '-';
    const mblNo = button.dataset.mblNo || row.mblNo || row.MBL_NO || '-';
    const hblNo = button.dataset.hblNo || row.hblNo || row.HBL_NO || '-';
    const issued = (button.dataset.noticeIssued || '').toUpperCase() === 'Y' || isImportArrivalNoticeIssued(row);
    const issueStatus = button.dataset.issueStatus || (issued ? '발급완료' : '미발급');

    let modal = document.getElementById('importArrivalNoticeStatusModal');
    if (!modal) {
        modal = document.createElement('div');
        modal.id = 'importArrivalNoticeStatusModal';
        modal.style.cssText = 'position:fixed; inset:0; z-index:99999; display:none; align-items:center; justify-content:center; background:rgba(15,23,42,.45);';
        modal.innerHTML = `
            <div style="width:min(560px,calc(100vw - 32px)); background:#fff; border:1px solid #cbd5e1; box-shadow:0 20px 40px rgba(15,23,42,.18);">
                <div style="display:flex; justify-content:space-between; align-items:center; padding:16px 18px; border-bottom:1px solid #e2e8f0;">
                    <strong style="font-size:16px; color:#0f172a;">도착통지서 상태</strong>
                    <button type="button" data-close-arrival-notice-modal="Y" style="border:0; background:transparent; font-size:20px; line-height:1; cursor:pointer;">×</button>
                </div>
                <div class="import-arrival-notice-modal-body" style="padding:18px;"></div>
                <div class="import-arrival-notice-modal-actions" style="display:flex; justify-content:flex-end; gap:8px; padding:14px 18px; border-top:1px solid #e2e8f0;"></div>
            </div>`;
        document.body.appendChild(modal);
        modal.addEventListener('click', function (e) {
            if (e.target === modal || e.target?.dataset?.closeArrivalNoticeModal === 'Y') {
                modal.style.display = 'none';
            }
        });
    }

    const body = modal.querySelector('.import-arrival-notice-modal-body');
    const actions = modal.querySelector('.import-arrival-notice-modal-actions');
    body.innerHTML = `
        <div style="display:grid; grid-template-columns:120px 1fr; row-gap:10px; column-gap:12px; font-size:13px; color:#0f172a;">
            <div style="font-weight:700; color:#475569;">의뢰번호</div><div>${importArrivalEscape(trcNo || '-')}</div>
            <div style="font-weight:700; color:#475569;">도착통지서번호</div><div>${importArrivalEscape(noticeNo || '-')}</div>
            <div style="font-weight:700; color:#475569;">화주</div><div>${importArrivalEscape(ownerNm)}</div>
            <div style="font-weight:700; color:#475569;">MASTER B/L</div><div>${importArrivalEscape(mblNo)}</div>
            <div style="font-weight:700; color:#475569;">HOUSE B/L</div><div>${importArrivalEscape(hblNo)}</div>
            <div style="font-weight:700; color:#475569;">도착통지서 상태</div><div><span class="status-chip ${issueStatus === '발급완료' ? 'status-confirmed' : 'status-wait'}">${importArrivalEscape(issueStatus)}</span></div>
        </div>
        <p style="margin:16px 0 0; color:#64748b; font-size:12px; line-height:1.5;">이 칸은 도착통지서 발급 여부만 표시합니다. 발송은 오른쪽의 ‘도착통지서 발송’ 버튼에서 진행합니다.</p>`;

    const attrs = importArrivalButtonDataAttrs({trcNo: trcNo, noticeNo: noticeNo, ownerNm: ownerNm, mblNo: mblNo, hblNo: hblNo, issued: issueStatus === '발급완료', sent: isImportArrivalNoticeSent(row)});
    actions.innerHTML = `
        ${issueStatus !== '발급완료' ? `<button type="button" onclick="window.issueImportArrivalNoticeFromButton(this); document.getElementById('importArrivalNoticeStatusModal').style.display='none'; return false;" class="arrival-notice-issue-btn px-4 py-2 bg-slate-600 text-white text-xs font-bold" ${attrs}>도착통지서 발급</button>` : ''}
        <button type="button" data-close-arrival-notice-modal="Y" style="padding:8px 14px; border:1px solid #cbd5e1; background:#fff; font-weight:700; font-size:12px;">닫기</button>`;
    modal.style.display = 'flex';
};

window.openImportArrivalNoticeSendModalFromButton = function (button) {
    if (!button) return;
    const baseTrcNo = button.dataset.trcNo || button.dataset.transportRequestNo || button.dataset.requestNo || '';
    const baseNoticeNo = importArrivalNoticeNoValue(button.dataset.noticeNo);
    const row = findImportArrivalRowByNo(baseTrcNo || baseNoticeNo) || {};
    const trcNo = baseTrcNo || row.trcNo || row.TRC_NO || row.transportRequestNo || row.requestNo || '';
    const noticeNo = importArrivalNoticeNoValue(baseNoticeNo, row.arrivalNoticeNo, row.arrivalNoticeReqNo, row.noticeNo, row.ntcNo, row.ianNo, row.IAN_NO);
    const ownerNm = button.dataset.ownerNm || row.ownerNm || row.owner || row.owrNm || '-';
    const mblNo = button.dataset.mblNo || row.mblNo || row.MBL_NO || '-';
    const hblNo = button.dataset.hblNo || row.hblNo || row.HBL_NO || '-';
    const issued = (button.dataset.noticeIssued || '').toUpperCase() === 'Y' || isImportArrivalNoticeIssued(row);
    const sent = (button.dataset.noticeSent || '').toUpperCase() === 'Y' || isImportArrivalNoticeSent(row);
    const issueStatus = button.dataset.issueStatus || (issued ? '발급완료' : '미발급');
    const sendStatus = button.dataset.sendStatus || button.dataset.noticeStatus || (sent ? '발송완료' : '미발송');

    let modal = document.getElementById('importArrivalNoticeSendModal');
    if (!modal) {
        modal = document.createElement('div');
        modal.id = 'importArrivalNoticeSendModal';
        modal.style.cssText = 'position:fixed; inset:0; z-index:100000; display:none; align-items:center; justify-content:center; background:rgba(15,23,42,.48); padding:20px;';
        modal.innerHTML = `
            <div style="width:min(760px,100%); background:#fff; border:1px solid #cbd5e1; border-radius:8px; box-shadow:0 22px 48px rgba(15,23,42,.22); overflow:hidden;">
                <div style="display:flex; justify-content:space-between; align-items:center; padding:18px 22px; border-bottom:1px solid #e2e8f0; background:#f8fafc;">
                    <div>
                        <strong style="font-size:17px; color:#0f172a;">도착통지서 발송</strong>
                        <div style="margin-top:4px; font-size:12px; color:#64748b;">발급된 도착통지서를 화주에게 발송합니다.</div>
                    </div>
                    <button type="button" data-close-arrival-notice-send-modal="Y" style="width:32px; height:32px; border:1px solid #cbd5e1; background:#fff; color:#475569; font-size:18px; line-height:1; cursor:pointer; border-radius:6px;">×</button>
                </div>
                <div class="import-arrival-notice-send-modal-body" style="padding:20px 22px; background:#fff;"></div>
                <div class="import-arrival-notice-send-modal-actions" style="display:flex; justify-content:flex-end; gap:8px; padding:16px 22px; border-top:1px solid #e2e8f0; background:#f8fafc;"></div>
            </div>`;
        document.body.appendChild(modal);
        modal.addEventListener('click', function (e) {
            if (e.target === modal || e.target?.dataset?.closeArrivalNoticeSendModal === 'Y') {
                modal.style.display = 'none';
            }
        });
    }

    const body = modal.querySelector('.import-arrival-notice-send-modal-body');
    const actions = modal.querySelector('.import-arrival-notice-send-modal-actions');
    const displayNoticeNo = noticeNo || '-';
    body.innerHTML = `
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:18px;">
            <div style="border:1px solid #dbe3ef; border-radius:8px; overflow:hidden;">
                <div style="padding:12px 14px; background:#f8fafc; border-bottom:1px solid #e2e8f0; font-weight:800; color:#0f172a;">기본 정보</div>
                <div style="display:grid; grid-template-columns:118px 1fr; row-gap:0; font-size:13px;">
                    <div style="padding:12px 14px; color:#64748b; font-weight:700; border-bottom:1px solid #eef2f7;">도착통지서번호</div>
                    <div style="padding:12px 14px; color:#0f172a; font-weight:800; border-bottom:1px solid #eef2f7; word-break:break-all;">${importArrivalEscape(displayNoticeNo)}</div>
                    <div style="padding:12px 14px; color:#64748b; font-weight:700; border-bottom:1px solid #eef2f7;">의뢰번호</div>
                    <div style="padding:12px 14px; color:#0f172a; font-weight:700; border-bottom:1px solid #eef2f7; word-break:break-all;">${importArrivalEscape(trcNo || '-')}</div>
                    <div style="padding:12px 14px; color:#64748b; font-weight:700; border-bottom:1px solid #eef2f7;">화주명</div>
                    <div style="padding:12px 14px; color:#0f172a; font-weight:700; border-bottom:1px solid #eef2f7;">${importArrivalEscape(ownerNm)}</div>
                    <div style="padding:12px 14px; color:#64748b; font-weight:700; border-bottom:1px solid #eef2f7;">Master B/L</div>
                    <div style="padding:12px 14px; color:#0f172a; font-weight:700; border-bottom:1px solid #eef2f7; word-break:break-all;">${importArrivalEscape(mblNo)}</div>
                    <div style="padding:12px 14px; color:#64748b; font-weight:700;">House B/L</div>
                    <div style="padding:12px 14px; color:#0f172a; font-weight:700; word-break:break-all;">${importArrivalEscape(hblNo)}</div>
                </div>
            </div>
            <div style="border:1px solid #dbe3ef; border-radius:8px; padding:16px; background:#fbfdff;">
                <div style="font-weight:800; color:#0f172a; margin-bottom:14px;">처리 상태</div>
                <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid #e2e8f0;">
                    <span style="font-size:13px; color:#64748b; font-weight:700;">도착통지서 상태</span>
                    <span class="status-chip ${issueStatus === '발급완료' ? 'status-confirmed' : 'status-wait'}">${importArrivalEscape(issueStatus)}</span>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid #e2e8f0;">
                    <span style="font-size:13px; color:#64748b; font-weight:700;">발송상태</span>
                    <span class="status-chip ${sendStatus === '발송완료' ? 'status-confirmed' : 'status-wait'}">${importArrivalEscape(sendStatus)}</span>
                </div>
                <p style="margin:14px 0 0; color:#64748b; font-size:12px; line-height:1.6;">도착통지서번호는 IMP_ARRV_NTC.IAN_NO 기준으로 표시됩니다.</p>
                ${issueStatus !== '발급완료' ? '<p style="margin:10px 0 0; color:#b45309; font-size:12px; line-height:1.6; font-weight:800;">발송하려면 먼저 도착통지서를 발급해야 합니다.</p>' : ''}
            </div>
        </div>`;

    const attrs = importArrivalButtonDataAttrs({trcNo: trcNo, noticeNo: noticeNo, ownerNm: ownerNm, mblNo: mblNo, hblNo: hblNo, issued: issueStatus === '발급완료', sent: sendStatus === '발송완료'});
    actions.innerHTML = `
        ${issueStatus !== '발급완료' ? `<button type="button" onclick="window.issueImportArrivalNoticeFromButton(this); document.getElementById('importArrivalNoticeSendModal').style.display='none'; return false;" class="arrival-notice-issue-btn px-4 py-2 bg-slate-600 text-white text-xs font-bold" ${attrs}>도착통지서 먼저 발급</button>` : ''}
        ${issueStatus === '발급완료' && sendStatus !== '발송완료' ? `<button type="button" onclick="window.sendImportArrivalNoticeFromButton(this); document.getElementById('importArrivalNoticeSendModal').style.display='none'; return false;" class="arrival-notice-send-confirm-btn px-4 py-2 bg-slate-600 text-white text-xs font-bold" ${attrs}>도착통지서 발송</button>` : ''}
        <button type="button" data-close-arrival-notice-send-modal="Y" style="padding:8px 14px; border:1px solid #cbd5e1; background:#fff; font-weight:700; font-size:12px;">취소</button>`;
    modal.style.display = 'flex';
};
window.issueImportArrivalNoticeFromButton = function (button) {
    if (!button || button.disabled) return;
    const trcNo = button.dataset.trcNo || button.dataset.transportRequestNo || button.dataset.requestNo || '';
    const reqNo = trcNo || button.dataset.noticeNo || '';
    if (!reqNo || reqNo === '-') {
        alert('도착통지서 발급 대상 의뢰번호가 없습니다.');
        return;
    }

    const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';
    const oldText = button.textContent;
    button.disabled = true;
    button.textContent = '발급중';

    fetch(contextPath + '/transport/import/arrival-notice/issue-get.do?reqNo=' + encodeURIComponent(reqNo), {
        method: 'GET',
        headers: {'X-Requested-With': 'XMLHttpRequest'}
    })
        .then(function (res) {
            if (!res.ok) throw new Error('HTTP ' + res.status);
            return res.json();
        })
        .then(function (data) {
            if (data && data.success === false) {
                throw new Error(data.message || '도착통지서 발급 대상이 없습니다.');
            }
            const savedNoticeNo = data.noticeNo || data.arrivalNoticeNo || data.arrivalNoticeReqNo || data.ianNo || button.dataset.noticeNo || '';
            const savedTrcNo = data.trcNo || data.transportRequestNo || trcNo || reqNo;

            markImportArrivalStoresIssued(savedTrcNo, savedNoticeNo);
            patchImportArrivalNoticeIssuedDom(savedTrcNo, savedNoticeNo);
            if (typeof window.enhanceImportArrivalNoticeActions === 'function') {
                window.enhanceImportArrivalNoticeActions(document, savedTrcNo);
            }

            const issuedDetail = {trcNo: savedTrcNo, reqNo: savedTrcNo, noticeNo: savedNoticeNo, arrivalNoticeNo: savedNoticeNo, arrivalNoticeReqNo: savedNoticeNo};
            window.dispatchEvent(new CustomEvent('tacs:import-arrival-notice-issued', { detail: issuedDetail }));

            alert('도착통지서가 발급되었습니다.');
        })
        .catch(function (err) {
            console.error('[도착통지서 발급 실패]', err);
            button.disabled = false;
            button.textContent = oldText || '발급';
            alert('도착통지서 발급 중 오류가 발생했습니다. ' + (err.message || ''));
        });
};

window.sendImportArrivalNoticeFromButton = function (button) {
    if (!button || button.disabled) return;
    const trcNo = button.dataset.trcNo || button.dataset.transportRequestNo || '';
    const noticeNoFromButton = importArrivalNoticeNoValue(button.dataset.noticeNo);
    const reqNo = trcNo || noticeNoFromButton;
    if (!reqNo || reqNo === '-') {
        alert('도착통지 발송 대상 의뢰번호가 없습니다.');
        return;
    }
    if ((button.dataset.noticeIssued || '').toUpperCase() === 'N') {
        alert('도착통지서를 먼저 발급한 뒤 발송해주세요.');
        return;
    }

    const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';
    const oldText = button.textContent;
    button.disabled = true;
    button.textContent = '발송중';

    fetch(contextPath + '/transport/import/arrival-notice/send-get.do?reqNo=' + encodeURIComponent(reqNo), {
        method: 'GET',
        headers: {'X-Requested-With': 'XMLHttpRequest'}
    })
        .then(function (res) {
            if (!res.ok) throw new Error('HTTP ' + res.status);
            return res.json();
        })
        .then(function (data) {
            if (data && data.success === false) {
                throw new Error(data.message || '도착통지 발송 대상이 없습니다.');
            }

            const savedNoticeNo = data.noticeNo || data.arrivalNoticeNo || data.arrivalNoticeReqNo || data.ianNo || noticeNoFromButton || reqNo;
            const savedTrcNo = data.trcNo || data.transportRequestNo || trcNo || reqNo;

            markImportArrivalStoresSent(savedTrcNo, savedNoticeNo);
            patchImportArrivalNoticeSentDom(savedTrcNo, savedNoticeNo);

            const sentDetail = {
                trcNo: savedTrcNo,
                reqNo: savedTrcNo,
                noticeNo: savedNoticeNo,
                arrivalNoticeNo: savedNoticeNo,
                arrivalNoticeReqNo: savedNoticeNo
            };
            if (typeof window.refreshImportArrivalNoticeSentState === 'function') {
                window.refreshImportArrivalNoticeSentState(sentDetail);
            }
            window.dispatchEvent(new CustomEvent('tacs:import-arrival-notice-sent', { detail: sentDetail }));

            setTimeout(function () { patchImportArrivalNoticeSentDom(savedTrcNo, savedNoticeNo); }, 0);
            setTimeout(function () { patchImportArrivalNoticeSentDom(savedTrcNo, savedNoticeNo); }, 80);
            setTimeout(function () { patchImportArrivalNoticeSentDom(savedTrcNo, savedNoticeNo); }, 250);
            setTimeout(function () {
                if (typeof window.syncManifestArrivalNoticeStatus === 'function') window.syncManifestArrivalNoticeStatus(savedTrcNo);
            }, 0);

            alert('도착통지서가 발송되었습니다.');
        })
        .catch(function (err) {
            console.error('[도착통지 발송 실패]', err);
            alert(err.message || '도착통지 발송 중 오류가 발생했습니다.');
            button.disabled = false;
            button.textContent = oldText;
        });
};


function normalizeDetailActionButtons() {
    const root =
        (typeof detailMain !== 'undefined' && detailMain)
            ? detailMain
            : document.getElementById('detail-view');

    if (!root) return;

    root.querySelectorAll('button').forEach((btn) => {
        const label = (btn.textContent || '').replace(/\s+/g, ' ').trim();
        if (label.includes('미리보기')) btn.remove();
    });

    const actionPattern = /(제출|저장|발송|요청|등록|수락|반려|처리|회신|전달)/;
    const keepPattern = /(조회|상세|대시보드|삭제|닫기|이전|다음)/;

    root.querySelectorAll('.section-card').forEach((card) => {
        let footer = card.querySelector('.section-card-action-footer');
        if (!footer) {
            footer = document.createElement('div');
            footer.className = 'section-card-action-footer flex justify-end gap-2 px-6 py-4 border-t border-slate-200';
            card.appendChild(footer);
        }

        const movableButtons = Array.from(card.querySelectorAll('button')).filter((btn) => {
            if (footer.contains(btn)) return false;
            if (btn.closest('table, thead, tbody, tfoot, tr, td, th')) return false;
            if (btn.closest('#importArrivalNoticeCompareActionArea')) return false;
            const label = (btn.textContent || '').replace(/\s+/g, ' ').trim();
            if (!label) return false;
            if (label.includes('미리보기')) return false;
            if (keepPattern.test(label)) return false;
            return actionPattern.test(label);
        });

        movableButtons.forEach((btn) => footer.appendChild(btn));

        if (!footer.querySelector('button')) {
            footer.remove();
        }
    });
}

function startDetailActionObserver() {
    const root =
        (typeof detailMain !== 'undefined' && detailMain)
            ? detailMain
            : document.getElementById('detail-view');

    if (!root || root.dataset.actionObserverBound === 'true') return;

    const observer = new MutationObserver(() => {
        normalizeDetailActionButtons();
    });
    observer.observe(root, {childList: true, subtree: true});
    root.dataset.actionObserverBound = 'true';
}

function buildRequestListPanel(item) {
    const isImport = item.id === 'TACS-FW-015';
    const rows = isImport
        ? '<tr><td colspan="8" class="text-center py-8 text-slate-500">수입 운송의뢰 목록을 불러오는 중입니다.</td></tr>'
        : '<tr><td colspan="8" class="text-center py-8 text-slate-500">수출 운송의뢰 목록을 불러오는 중입니다.</td></tr>';

    return `
        <div class="section-card">
            <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
                <div>
                    <h4 class="text-sm font-bold text-slate-900">운송의뢰</h4>
                    <p class="text-xs text-slate-500 mt-1">${isImport ? '수입 의뢰 접수 상태와 화주가 보낸 Master B/L 첨부파일 정보를 확인하고 상세 접수 화면으로 이동합니다.' : '수출 운송의뢰 접수 상태와 선적 기본 정보를 확인하고 상세 검토를 진행합니다.'}</p>
                </div>
                <button class="px-4 py-2 bg-primary text-white text-xs font-bold hover:bg-primary-dim">조회</button>
            </div>
            <div class="p-6 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
                    <div><label class="field-label">의뢰번호</label><input class="field-input" type="text" placeholder="의뢰번호 검색" /></div>
                    <div><label class="field-label">화주명</label><input class="field-input js-import-filter-shipper" type="text" placeholder="화주명 검색" /></div>
                    <div><label class="field-label">${isImport ? 'Master B/L / House B/L' : '바이어명'}</label><input class="field-input" type="text" placeholder="${isImport ? 'Master B/L / House B/L 검색' : '바이어명 검색'}" /></div>
                    <div><label class="field-label">상태</label><select class="field-select"><option>전체</option><option>접수대기</option><option>접수반려</option><option>접수완료</option></select></div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full tbl">
                        <thead>
                            <tr>
                                <th>의뢰번호</th>
                                <th>화주명</th>
                                <th>${isImport ? 'Master B/L / House B/L' : '바이어명'}</th>
                                <th>${isImport ? '선사' : '운송수단'}</th>
                                <th>${isImport ? '도착항' : '선적항'}</th>
                                <th>상태</th>
                                <th>등록일시</th>
                                <th>처리</th>
                            </tr>
                        </thead>
                        <tbody class="text-[11px] text-slate-700">
                            ${rows}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    `;
}

var importCargoManifestRows = Array.isArray(window.importCargoManifestRows) ? window.importCargoManifestRows : [];

/* import-ui.js는 수정하지 않고, 운송의뢰 상세 내부 '도착/입항' 요약카드만
 * 원래 도착예정 및 입항추적 목록 화면으로 복구한다.
 */
(function installImportArrivalInlineRestore() {
    if (window.__TACS_IMPORT_ARRIVAL_INLINE_RESTORE_20260516) return;
    window.__TACS_IMPORT_ARRIVAL_INLINE_RESTORE_20260516 = true;

    function isArrivalInlineRoot(root) {
        return root && root.classList && root.classList.contains('import-inline-tabs-0513')
            && root.dataset && root.dataset.activeWorkId === 'arrival';
    }

    function looksLikeSummaryOnly(panel) {
        if (!panel) return false;
        if (panel.querySelector('table.tbl')) return false;
        const text = (panel.textContent || '').replace(/\s+/g, ' ').trim();
        return text.includes('도착예정 및 입항추적')
            && text.includes('상세화면 열기')
            && text.includes('통지상태');
    }

    function restoreInlineArrivalPanel(root) {
        if (!isArrivalInlineRoot(root)) return;
        const panel = root.querySelector('.import-ui-panel');
        if (!panel) return;

        // 이미 목록형 화면이면 다시 건드리지 않는다.
        if (panel.querySelector('table.tbl')) return;

        // import-ui.js가 그린 요약카드 또는 빈 패널만 목록형으로 교체한다.
        if (!looksLikeSummaryOnly(panel) && (panel.textContent || '').trim()) return;

        panel.classList.add('is-active');
        panel.innerHTML = buildImportEtaTrackingListPanel();
        if (typeof normalizeDetailActionButtons === 'function') normalizeDetailActionButtons();
    }

    function restoreAllInlineArrivalPanels() {
        document.querySelectorAll('.import-inline-tabs-0513[data-active-work-id="arrival"]').forEach(restoreInlineArrivalPanel);
    }

    // 탭 클릭 후 import-ui.js가 먼저 요약카드를 그린 다음, 이 파일이 목록형으로 교체한다.
    document.addEventListener('click', function (event) {
        const target = event.target instanceof Element ? event.target : null;
        const tab = target ? target.closest('.import-ui-tab, .import-inline-tab') : null;
        if (!tab || tab.dataset.workId !== 'arrival') return;
        setTimeout(restoreAllInlineArrivalPanels, 0);
        setTimeout(restoreAllInlineArrivalPanels, 80);
    }, true);

    const observer = new MutationObserver(function () {
        restoreAllInlineArrivalPanels();
    });

    function startObserver() {
        const body = document.getElementById('detail-body') || document.body;
        if (!body) return;
        observer.observe(body, {childList: true, subtree: true});
        restoreAllInlineArrivalPanels();
    }

    if (!window.TRANSPORT_DEFER_PAGE_BOOT) {
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', startObserver);
        } else {
            startObserver();
        }
    }
})();


/*
 * 2026-06-02 fix: 적하목록/도착통지서 패널의 상태값은 미발급/발급완료만 표시하고,
 * 도착통지서 발송 버튼을 별도 컬럼으로 분리한다.
 */
(function separateArrivalNoticeIssueAndSendActions() {
    if (window.__TACS_ARRIVAL_NOTICE_SEPARATE_ACTIONS_20260602) return;
    window.__TACS_ARRIVAL_NOTICE_SEPARATE_ACTIONS_20260602 = true;

    function headerTexts(table) {
        return Array.prototype.slice.call(table.querySelectorAll('thead th')).map(function (th) {
            return (th.textContent || '').replace(/\s+/g, '').trim();
        });
    }

    function findHeaderIndex(texts, candidates) {
        for (let i = 0; i < texts.length; i++) {
            if (candidates.some(function (keyword) { return texts[i].indexOf(keyword) >= 0; })) return i;
        }
        return -1;
    }

    function ensureHeader(table, title, className) {
        const tr = table.querySelector('thead tr');
        if (!tr) return;
        const exists = Array.prototype.slice.call(tr.children).some(function (th) {
            return (th.textContent || '').replace(/\s+/g, '').trim() === title.replace(/\s+/g, '').trim();
        });
        if (exists) return;
        const th = document.createElement('th');
        th.textContent = title;
        if (className) th.className = className;
        tr.appendChild(th);
    }

    function removeLegacyActionColumns(table) {
        const tr = table.querySelector('thead tr');
        if (!tr) return;
        const removable = ['발급', '발송상태', '발송'];
        const headers = Array.prototype.slice.call(tr.children);
        for (let i = headers.length - 1; i >= 0; i--) {
            const text = (headers[i].textContent || '').replace(/\s+/g, '').trim();
            if (removable.indexOf(text) < 0) continue;
            headers[i].remove();
            table.querySelectorAll('tbody tr').forEach(function (row) {
                if (row.children[i]) row.children[i].remove();
            });
        }
    }

    function removeArrivalNoticeSendColumn(table) {
        const tr = table.querySelector('thead tr');
        if (!tr) return;
        const headers = Array.prototype.slice.call(tr.children);
        for (let i = headers.length - 1; i >= 0; i--) {
            const text = (headers[i].textContent || '').replace(/\s+/g, '').trim();
            if (text !== '도착통지서발송' && !headers[i].classList.contains('arrival-notice-send-header')) continue;
            headers[i].remove();
            table.querySelectorAll('tbody tr').forEach(function (row) {
                if (row.children[i]) row.children[i].remove();
            });
        }
    }

    function renderCompareAction(table, data) {
        const panel = table.closest('#importManifestDetailModePanel');
        const area = panel && panel.querySelector('#importArrivalNoticeCompareActionArea');
        if (!area) return;
        area.innerHTML = importArrivalSendActionButton(data);
    }

    function enhanceTable(table, forcedTrcNo) {
        if (!table || !table.querySelectorAll) return;
        if (table.closest('#importManifestListOnlyPanel')) return;
        const detailMode = !!table.closest('#importManifestDetailModePanel');
        let texts = headerTexts(table);
        const reqIdx = findHeaderIndex(texts, ['의뢰번호']);
        const statusIdx = findHeaderIndex(texts, ['도착통지서상태', '발급상태']);
        if (reqIdx < 0 || statusIdx < 0) return;

        removeLegacyActionColumns(table);
        if (detailMode) {
            removeArrivalNoticeSendColumn(table);
        } else {
            ensureHeader(table, '도착통지서 발송', 'arrival-notice-send-header');
        }
        texts = headerTexts(table);

        table.querySelectorAll('tbody tr').forEach(function (tr) {
            const cells = tr.children;
            if (!cells || cells.length <= Math.max(reqIdx, statusIdx)) return;
            const trcNo = forcedTrcNo || (cells[reqIdx].textContent || '').trim();
            if (!trcNo || trcNo === '-') return;
            const row = findImportArrivalRowByNo(trcNo) || {};
            const oldStatusText = (cells[statusIdx].textContent || '').trim();
            const sent = isImportArrivalNoticeSent(row) || oldStatusText === '발송완료' || oldStatusText === '통지완료';
            const issued = isImportArrivalNoticeIssued(row) || sent || oldStatusText === '발급완료';
            const noticeNo = importArrivalNoticeNoValue(row.arrivalNoticeNo, row.arrivalNoticeReqNo, row.noticeNo, row.ntcNo, row.ianNo, row.IAN_NO);
            const ownerNm = cells[reqIdx + 1] ? (cells[reqIdx + 1].textContent || '').trim() : (row.ownerNm || '');
            const mblNo = cells[reqIdx + 2] ? (cells[reqIdx + 2].textContent || '').trim() : (row.mblNo || '');
            const hblNo = cells[reqIdx + 3] ? (cells[reqIdx + 3].textContent || '').trim() : (row.hblNo || '');
            const data = {trcNo: trcNo, noticeNo: noticeNo, ownerNm: ownerNm, mblNo: mblNo, hblNo: hblNo, row: row, issued: issued, sent: sent};

            cells[statusIdx].classList.add('arrival-notice-status-cell', 'arrival-notice-issue-status-cell');
            cells[statusIdx].innerHTML = importArrivalIssueStatusButton(data);

            tr.querySelectorAll('.arrival-notice-issue-action-cell, .arrival-notice-send-status-cell').forEach(function (cell) { cell.remove(); });

            if (detailMode) {
                renderCompareAction(table, data);
                return;
            }

            let sendCell = tr.querySelector('.arrival-notice-send-action-cell');
            if (!sendCell) {
                sendCell = document.createElement('td');
                sendCell.className = 'arrival-notice-send-action-cell';
                tr.appendChild(sendCell);
            }
            sendCell.innerHTML = importArrivalSendActionButton(data);
        });
    }

    window.enhanceImportArrivalNoticeActions = function (root, forcedTrcNo) {
        root = root || document;
        if (!root.querySelectorAll) return;
        root.querySelectorAll('table').forEach(function (table) { enhanceTable(table, forcedTrcNo); });
    };

    document.addEventListener('DOMContentLoaded', function () {
        window.enhanceImportArrivalNoticeActions(document);
        setTimeout(function () { window.enhanceImportArrivalNoticeActions(document); }, 120);
        setTimeout(function () { window.enhanceImportArrivalNoticeActions(document); }, 600);
    });
    document.addEventListener('click', function () {
        setTimeout(function () { window.enhanceImportArrivalNoticeActions(document); }, 0);
        setTimeout(function () { window.enhanceImportArrivalNoticeActions(document); }, 120);
    }, true);
    if (window.MutationObserver) {
        new MutationObserver(function (mutations) {
            mutations.forEach(function (mutation) {
                Array.prototype.slice.call(mutation.addedNodes || []).forEach(function (node) {
                    if (node && node.nodeType === 1) window.enhanceImportArrivalNoticeActions(node);
                });
            });
        }).observe(document.documentElement, {childList:true, subtree:true});
    }
})();


/*
 * 2026-05-28 fix: 기존 렌더러/캐시/비동기 재렌더가 PENDING을 다시 넣어도
 * 도착상태 칸은 최종적으로 '도착'만 보이게 방어한다.
 */
(function forceImportArrivalStatusDone() {
    if (window.__TACS_IMPORT_ARRIVAL_STATUS_ALWAYS_DONE_20260528) return;
    window.__TACS_IMPORT_ARRIVAL_STATUS_ALWAYS_DONE_20260528 = true;

    function patch(root) {
        root = root || document;
        if (!root.querySelectorAll) return;
        root.querySelectorAll('.arrival-status-cell').forEach(function (cell) {
            cell.innerHTML = '<span class="status-chip status-confirmed">도착</span>';
        });
        root.querySelectorAll('[data-arrival-status], [data-status]').forEach(function (el) {
            if (el.dataset) {
                if (el.dataset.arrivalStatus !== undefined) el.dataset.arrivalStatus = '도착';
                if (el.dataset.status !== undefined && /PENDING|입항전|운항중|IN_TRANSIT|BEFORE_ARRIVAL/i.test(el.dataset.status || '')) {
                    el.dataset.status = '도착';
                }
            }
        });
    }

    document.addEventListener('DOMContentLoaded', function () {
        patch(document);
        setTimeout(function () { patch(document); }, 100);
        setTimeout(function () { patch(document); }, 500);
    });

    document.addEventListener('click', function () {
        setTimeout(function () { patch(document); }, 0);
        setTimeout(function () { patch(document); }, 120);
    }, true);

    if (window.MutationObserver) {
        new MutationObserver(function (mutations) {
            mutations.forEach(function (mutation) {
                Array.prototype.slice.call(mutation.addedNodes || []).forEach(function (node) {
                    if (node && node.nodeType === 1) patch(node);
                });
            });
        }).observe(document.documentElement, { childList: true, subtree: true });
    }
})();
