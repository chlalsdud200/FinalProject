(function () {
    if (window.__TACS_IMPORT_MANIFEST_PDF_COMPARE_CLEAN) return;
    window.__TACS_IMPORT_MANIFEST_PDF_COMPARE_CLEAN = true;

    function ctxPath() {
        if (typeof getTransportContextPath === 'function') return getTransportContextPath();
        var path = window.location.pathname || '';
        var idx = path.indexOf('/transport/');
        return idx >= 0 ? path.substring(0, idx) : (window.contextPath || '');
    }

    function esc(v) {
        if (typeof safeText === 'function') return safeText(v);
        return String(v == null || v === '' ? '-' : v)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/\"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function fileNo(item) {
        item = item || {};
        return item.packingListFileNo || item.pkgFileNo || item.fileNo || '';
    }

    function buildDownloadUrl(item) {
        item = item || {};
        if (item.__uploadedPackingObjectUrl) return item.__uploadedPackingObjectUrl;
        var no = fileNo(item);
        return no ? ctxPath() + '/common/file/download.do?fileNo=' + encodeURIComponent(no) : '';
    }

    function buildPreviewUrl(item) {
        item = item || {};
        if (item.__uploadedPackingObjectUrl) return item.__uploadedPackingObjectUrl;
        var no = fileNo(item);
        /*
         * iframe에는 download.do를 쓰면 탭 진입/대상 선택 시 자동 다운로드가 발생한다.
         * 미리보기는 preview.do, 실제 다운로드는 버튼 클릭 시 download.do만 사용한다.
         */
        return no ? ctxPath() + '/common/file/preview.do?fileNo=' + encodeURIComponent(no) : '';
    }

    function buildPdfUrl(item) {
        return buildPreviewUrl(item);
    }

    function injectManifestStyle() {
        if (document.getElementById('tacsManifestOneUploadStyle')) return;

        var style = document.createElement('style');
        style.id = 'tacsManifestOneUploadStyle';
        style.textContent = ''
            + '#manifestPackingViewBtn,#manifestManualConfirmArea{display:none!important;}'
            + '#manifestPackingUploadInput{display:none!important;}'
            + '.manifest-packing-upload-label input{display:none!important;}'
            + '.manifest-pdf-frame{width:100%!important;height:560px!important;background:#fff!important;border:1px solid #cbd5e1!important;}'
            + '.manifest-packing-download-link{display:inline-flex!important;align-items:center!important;justify-content:center!important;min-height:32px!important;padding:7px 12px!important;border:1px solid #334155!important;background:#1e293b!important;color:#fff!important;-webkit-text-fill-color:#fff!important;font-size:12px!important;font-weight:900!important;text-decoration:none!important;}'
            + '.manifest-pdf-value-input{background:#fff!important;color:#0f172a!important;}'
            + '.manifest-compare-result span{white-space:nowrap;}'
            + '#importManifestResetBtn,#importManifestReloadBtn,#importManifestResetBtn *,#importManifestReloadBtn *{color:#fff!important;}';
        document.head.appendChild(style);
    }

    window.buildManifestPackingPdfUrl = buildPdfUrl;

    window.hasManifestPackingFile = function (item) {
        return !!buildPdfUrl(item || {});
    };

    window.hideManifestPackingExtraControls = function () {
        ['manifestPackingViewBtn', 'manifestManualConfirmArea'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) el.style.display = 'none';
        });
    };

    function bindUploadInput(item) {
        var input = document.getElementById('manifestPackingUploadInput');
        if (!input) return;

        input.onchange = function () {
            var file = input.files && input.files[0];
            if (!file) return;

            if (typeof window.handleManifestPackingUpload === 'function') {
                window.handleManifestPackingUpload(file, item);
            } else if (typeof handlePackingPdfUpload === 'function') {
                handlePackingPdfUpload(file);
            } else {
                alert('PDF 업로드 대조 함수가 없습니다. import-manifest.js를 확인하세요.');
            }
        };
    }

    window.renderManifestAttachmentDownloadBox = function (item) {
        injectManifestStyle();

        item = item || window.SELECTED_IMPORT_MANIFEST || {};
        var name = item.packingListFile || item.packingListFileName || item.pkgFileNm || '포장명세서 PDF를 업로드하세요.';
        var previewUrl = buildPreviewUrl(item);
        var downloadUrl = buildDownloadUrl(item);
        var body = document.getElementById('manifestPackingPreviewBody');
        if (!body) return;

        if (previewUrl || downloadUrl) {
            body.innerHTML =
                '<div class="min-h-[390px] border-2 border-dashed border-slate-300 rounded-lg bg-slate-100 p-4">' +
                '  <div class="flex items-center justify-between gap-3 mb-3">' +
                '    <div class="min-w-0">' +
                '      <p class="text-xs font-bold text-slate-700 break-all">' + esc(name || '포장명세서.pdf') + '</p>' +
                '      <p class="text-[11px] text-slate-500 mt-1">포장명세서 PDF를 확인하면서 오른쪽 비교값을 수정할 수 있습니다.</p>' +
                '    </div>' +
                '    <div class="flex items-center gap-2">' +
                '      <a href="' + esc(downloadUrl || previewUrl) + '" class="manifest-packing-download-link" target="_blank" rel="noopener">PDF 다운로드</a>' +
                '      <label class="manifest-packing-upload-label" title="PDF 업로드" aria-label="PDF 업로드">PDF 업로드<input id="manifestPackingUploadInput" type="file" accept="application/pdf,.pdf"></label>' +
                '    </div>' +
                '  </div>' +
                '  <iframe src="' + esc(previewUrl) + '#toolbar=0&navpanes=0" title="포장명세서 PDF" class="manifest-pdf-frame"></iframe>' +
                '</div>';
        } else {
            body.innerHTML =
                '<div class="flex flex-col items-center justify-center min-h-[390px] text-center border-2 border-dashed border-slate-300 rounded-lg bg-slate-100 p-6">' +
                '  <span class="material-symbols-outlined text-5xl text-slate-400 mb-3">upload_file</span>' +
                '  <p class="text-xs font-bold text-slate-700 break-all">' + esc(name) + '</p>' +
                '  <p class="text-[11px] text-slate-500 mt-2">포장명세서 PDF를 업로드하면 PDF 화면과 오른쪽 비교표에 반영됩니다.</p>' +
                '  <div class="mt-4 flex justify-center">' +
                '    <label class="manifest-packing-upload-label" title="PDF 업로드" aria-label="PDF 업로드">PDF 업로드<input id="manifestPackingUploadInput" type="file" accept="application/pdf,.pdf"></label>' +
                '  </div>' +
                '</div>';
        }

        bindUploadInput(item);
        window.hideManifestPackingExtraControls();
    };

    window.loadManifestPackingText = function (item) {
        item = item || {};
        var no = fileNo(item);

        if (!no || item.__uploadedPackingObjectUrl) {
            item.packingText = item.packingText || '';
            item.__packingTextLoaded = !!item.packingText;
            item.__packingTextLoading = false;
            if (typeof window.renderManifestAttachmentDownloadBox === 'function') window.renderManifestAttachmentDownloadBox(item);
            if (typeof window.renderImportManifestCargoItems === 'function') window.renderImportManifestCargoItems(item);
            return;
        }

        if (item.__packingTextLoaded || item.__packingTextLoading) {
            if (typeof window.renderManifestAttachmentDownloadBox === 'function') window.renderManifestAttachmentDownloadBox(item);
            if (typeof window.renderImportManifestCargoItems === 'function') window.renderImportManifestCargoItems(item);
            return;
        }

        item.__packingTextLoading = true;
        fetch(ctxPath() + '/transport/import/manifest/packing-text.do?fileNo=' + encodeURIComponent(no) + '&_=' + Date.now(), {
            method: 'GET',
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            cache: 'no-store',
            credentials: 'same-origin'
        })
            .then(function (res) { return res.ok ? res.json() : Promise.reject(new Error('HTTP ' + res.status)); })
            .then(function (data) {
                item.packingText = data && data.success ? (data.text || '') : '';
                item.__packingTextLoaded = true;
                item.__packingTextLoading = false;
                window.renderManifestAttachmentDownloadBox(item);
                window.renderImportManifestCargoItems(item);
            })
            .catch(function () {
                item.packingText = '';
                item.__packingTextLoaded = true;
                item.__packingTextLoading = false;
                window.renderManifestAttachmentDownloadBox(item);
                window.renderImportManifestCargoItems(item);
            });
    };
})();

(function () {
    if (window.__TACS_IMPORT_MANIFEST_COMPARE_UI_CLEAN) return;
    window.__TACS_IMPORT_MANIFEST_COMPARE_UI_CLEAN = true;

    var originalSelect = window.selectImportManifestItem;

    function ctxPath() {
        if (typeof getTransportContextPath === 'function') return getTransportContextPath();
        var path = window.location.pathname || '';
        var idx = path.indexOf('/transport/');
        return idx >= 0 ? path.substring(0, idx) : (window.contextPath || '');
    }

    function csrfHeaders(extra) {
        var headers = extra || {};
        var token = (window.TRANSPORT_CSRF && window.TRANSPORT_CSRF.token) || (document.querySelector('meta[name="_csrf"]') && document.querySelector('meta[name="_csrf"]').getAttribute('content')) || '';
        var headerName = (window.TRANSPORT_CSRF && window.TRANSPORT_CSRF.header) || (document.querySelector('meta[name="_csrf_header"]') && document.querySelector('meta[name="_csrf_header"]').getAttribute('content')) || '';
        if (token && headerName && token !== '${_csrf.token}' && headerName !== '${_csrf.headerName}') {
            headers[headerName] = token;
        }
        return headers;
    }

    function text(v) {
        if (typeof safeText === 'function') return safeText(v);
        return String(v == null || v === '' ? '-' : v)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function attr(v) {
        if (typeof escapeAttr === 'function') return escapeAttr(v);
        return String(v == null ? '' : v)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function norm(v) {
        return String(v == null ? '' : v)
            .replace(/,/g, '')
            .replace(/\s+/g, '')
            .replace(/[()\-_/.:]/g, '')
            .trim()
            .toLowerCase();
    }

    function normalizeWeight(value) {
        if (typeof normalizeWeightForDisplay === 'function') return normalizeWeightForDisplay(value);
        var raw = String(value == null ? '' : value).trim();
        return raw && !/kg/i.test(raw) ? raw + ' KG' : raw;
    }

    function linesOf(rawText) {
        return String(rawText || '')
            .replace(/\r/g, '')
            .split('\n')
            .map(function (line) { return line.trim(); })
            .filter(Boolean);
    }

    function lineAfter(lines, marker) {
        for (var i = 0; i < lines.length; i += 1) {
            if (lines[i].toLowerCase().indexOf(marker.toLowerCase()) >= 0) return lines[i + 1] || '';
        }
        return '';
    }

    function parseManifestPackingText(rawText) {
        var raw = String(rawText || '');
        var lines = linesOf(raw);
        var invoiceMatch = raw.match(/Invoice No\. and date\s+([A-Z0-9-]+)/i);
        var originMatch = raw.match(/Country of Origin:\s*([^\n]+)/i);
        var qtyMatch = raw.match(/\(\s*25\s*KG\s*\/\s*BAG\s*\)\s*([\d,]+\s*KG)\s+([\d,]+\s*KG)/i)
            || raw.match(/TOTAL\s+([\d,]+\s*KG)\s+([\d,]+\s*KG)/i);
        var tableStart = lines.findIndex(function (line) { return /⑰\s*Measurement/i.test(line); });
        var tableRows = tableStart >= 0 ? lines.slice(tableStart + 1) : [];
        var packageGoodsLine = tableRows[4] || '';
        var packageGoodsMatch = packageGoodsLine.match(/^(.+?BAGS)\s+(.+)$/i);
        var goodsLines = [];

        if (packageGoodsMatch && packageGoodsMatch[2]) goodsLines.push(packageGoodsMatch[2]);
        for (var i = 5; i < tableRows.length; i += 1) {
            if (/^(TOTAL|Signed by|⑱)/i.test(tableRows[i])) break;
            if (/^[\d,]+\s*KG\s+[\d,]+\s*KG$/i.test(tableRows[i])) break;
            goodsLines.push(tableRows[i]);
        }

        return {
            invoiceNo: invoiceMatch ? invoiceMatch[1].trim() : '',
            departure: lineAfter(lines, '⑤ From') || lineAfter(lines, 'From'),
            destination: lineAfter(lines, '⑥ To') || lineAfter(lines, 'To'),
            goodsDescription: goodsLines.join(' / '),
            quantity: qtyMatch ? qtyMatch[1].trim() : '',
            grossWeight: qtyMatch ? qtyMatch[2].trim() : '',
            origin: originMatch ? originMatch[1].trim() : ''
        };
    }

    function getCargoRows(item) {
        item = item || {};
        var rows = Array.isArray(item.cargoItems) ? item.cargoItems : [];

        if (!rows.length) {
            rows = [{
                cgNo: item.cgNo || item.goodsNo,
                goodsNo: item.goodsNo,
                goodsName: item.goodsName || item.itemNm || item.itemCategory || item.frghtIemNm,
                qty: item.cgQty || item.goodsQty || item.qty,
                weight: item.cgWeight || item.goodsWeight || item.weight || item.totalWeight,
                origin: item.cgOrigin || item.originCountryCd || item.origin
            }];
        }

        return rows.map(function (cargo) {
            return typeof normalizeManifestCargoItem === 'function' ? normalizeManifestCargoItem(cargo) : cargo;
        }).filter(function (cargo) {
            return cargo && ['goodsName', 'qty', 'weight', 'origin', 'cgNo', 'goodsNo'].some(function (key) {
                return cargo[key] !== null && cargo[key] !== undefined && String(cargo[key]).trim() !== '';
            });
        });
    }

    function compareBadge(dbValue, pdfValue, hasFile, loaded) {
        if (!hasFile) return '<span data-compare="empty" class="inline-flex px-3 py-1 text-[11px] font-extrabold bg-slate-100 text-slate-500 border border-slate-200">포장명세서 없음</span>';
        if (!loaded) return '<span data-compare="empty" class="inline-flex px-3 py-1 text-[11px] font-extrabold bg-slate-100 text-slate-600 border border-slate-200">PDF 업로드 대기</span>';
        if (!norm(pdfValue)) return '<span data-compare="empty" class="inline-flex px-3 py-1 text-[11px] font-extrabold bg-amber-50 text-amber-700 border border-amber-200">수동입력 필요</span>';

        var d = norm(dbValue);
        var p = norm(pdfValue);

        if (!d) return '<span data-compare="empty" class="inline-flex px-3 py-1 text-[11px] font-extrabold bg-slate-100 text-slate-500 border border-slate-200">DB 값 없음</span>';
        if (d === p || (d.length > 2 && p.indexOf(d) >= 0) || (p.length > 2 && d.indexOf(p) >= 0)) {
            return '<span data-compare="match" class="inline-flex px-3 py-1 text-[11px] font-extrabold bg-emerald-50 text-emerald-700 border border-emerald-200">일치</span>';
        }

        return '<span data-compare="warn" class="inline-flex px-3 py-1 text-[11px] font-extrabold bg-rose-50 text-rose-700 border border-rose-200">불일치</span>';
    }

    function rowHtml(label, key, dbValue, pdfValue, hasFile, loaded) {
        var db = dbValue == null || String(dbValue).trim() === '' ? '' : String(dbValue);
        var pdf = pdfValue == null ? '' : String(pdfValue);

        return '' +
            '<tr class="border-t border-slate-200 hover:bg-slate-50">' +
            '<td class="px-5 py-4 font-extrabold text-slate-800 bg-slate-50 align-top">' + text(label) + '</td>' +
            '<td class="px-5 py-4 align-top text-slate-900">' + text(db || '-') + '</td>' +
            '<td class="px-5 py-4 align-top text-slate-600">' +
            '<input data-manifest-pdf-field="' + attr(key) + '" data-manifest-db-value="' + attr(db) + '" class="manifest-pdf-value-input w-full border border-slate-300 px-3 py-2 text-xs font-bold" value="' + attr(pdf) + '" placeholder="PDF 추출불가 시 직접 입력">' +
            '</td>' +
            '<td class="px-5 py-4 align-top text-slate-600 manifest-compare-result">' + compareBadge(db, pdf, hasFile, loaded) + '</td>' +
            '</tr>';
    }

    function ensureCompareLayout() {
        var tbody = document.getElementById('manifestCargoItemBody');
        var table = tbody && tbody.closest('table');

        if (table) {
            var headRow = table.querySelector('thead tr');
            if (headRow) {
                headRow.innerHTML = '<th class="px-5 py-3 w-40">항목</th><th class="px-5 py-3">적하목록 DB 값</th><th class="px-5 py-3">포장명세서 PDF 추출/수정값</th><th class="px-5 py-3 w-32">결과</th>';
                table.classList.remove('min-w-[720px]');
                table.classList.add('min-w-[920px]');
            }
        }

        var panel = tbody && tbody.closest('.bg-white.border');
        if (panel && !document.getElementById('manifestCompareSummary')) {
            var summary = document.createElement('div');
            summary.id = 'manifestCompareSummary';
            summary.className = 'grid grid-cols-4 gap-2 px-5 py-3 border-b border-slate-200 bg-slate-50 text-center text-xs';
            summary.innerHTML =
                '<div class="border border-slate-200 bg-white py-2"><div class="text-[11px] text-slate-500">전체</div><div class="text-lg font-black text-slate-900">-</div></div>' +
                '<div class="border border-emerald-200 bg-white py-2"><div class="text-[11px] text-emerald-700">일치</div><div class="text-lg font-black text-emerald-700">-</div></div>' +
                '<div class="border border-rose-200 bg-white py-2"><div class="text-[11px] text-rose-700">불일치</div><div class="text-lg font-black text-rose-700">-</div></div>' +
                '<div class="border border-amber-200 bg-white py-2"><div class="text-[11px] text-amber-700">확인필요</div><div class="text-lg font-black text-amber-700">-</div></div>';

            var scroll = panel.querySelector('.overflow-x-auto');
            panel.insertBefore(summary, scroll);
        }
    }

    function updateSummary() {
        var summary = document.getElementById('manifestCompareSummary');
        var tbody = document.getElementById('manifestCargoItemBody');
        if (!summary || !tbody) return;

        var badges = tbody.querySelectorAll('[data-compare]');
        var counts = {match: 0, warn: 0, empty: 0};

        badges.forEach(function (badge) {
            var key = badge.getAttribute('data-compare');
            if (counts[key] !== undefined) counts[key] += 1;
        });

        var nums = summary.querySelectorAll('.text-lg');
        if (nums[0]) nums[0].textContent = String(badges.length);
        if (nums[1]) nums[1].textContent = String(counts.match);
        if (nums[2]) nums[2].textContent = String(counts.warn);
        if (nums[3]) nums[3].textContent = String(counts.empty);
    }

    function refreshOneInput(input) {
        var row = input.closest('tr');
        var cell = row && row.querySelector('.manifest-compare-result');
        if (!cell) return;

        var item = window.SELECTED_IMPORT_MANIFEST || {};
        var hasFile = typeof window.hasManifestPackingFile === 'function' ? window.hasManifestPackingFile(item) : false;

        cell.innerHTML = compareBadge(input.dataset.manifestDbValue || '', input.value || '', hasFile, item.__packingTextLoaded === true);
        item.__manualPdfValues = item.__manualPdfValues || {};
        item.__manualPdfValues[input.dataset.manifestPdfField || ''] = input.value || '';
        updateSummary();
    }

    function bindInputs() {
        document.querySelectorAll('.manifest-pdf-value-input').forEach(function (input) {
            if (input.dataset.bound === 'true') return;
            input.dataset.bound = 'true';
            input.addEventListener('input', function () { refreshOneInput(input); });
        });
    }

    window.renderImportManifestCargoItems = function (item) {
        var tbody = document.getElementById('manifestCargoItemBody');
        if (!tbody) return;

        ensureCompareLayout();

        item = item || {};
        var parsed = parseManifestPackingText(item.packingText || '');
        var manual = item.__manualPdfValues || {};
        var pdf = Object.assign({}, parsed, manual);
        var hasFile = typeof window.hasManifestPackingFile === 'function' ? window.hasManifestPackingFile(item) : false;
        var loaded = item.__packingTextLoaded === true;
        var cargos = getCargoRows(item);
        var rows = [];

        rows.push(rowHtml('송장번호', 'invoiceNo', item.invoiceNo || item.wirInvoiceNo || item.invoice || '', pdf.invoiceNo, hasFile, loaded));
        rows.push(rowHtml('출발지', 'departure', item.deptPortNm || item.deptPortCd || item.loadingPort || '', pdf.departure, hasFile, loaded));
        rows.push(rowHtml('목적지', 'destination', item.arvlPortNm || item.arvlPortCd || item.dischargePort || '', pdf.destination, hasFile, loaded));
        rows.push(rowHtml('Master B/L', 'mblNo', item.mblNo || item.blNo || item.masterBl || '', pdf.mblNo, hasFile, loaded));
        rows.push(rowHtml('House B/L', 'hblNo', item.hblNo || item.houseBl || '', pdf.hblNo, hasFile, loaded));

        if (!cargos.length) {
            rows.push('<tr><td colspan="4" class="px-3 py-4 text-center text-slate-500 border-t border-slate-200">품목 DB 조회값이 없습니다.</td></tr>');
        } else {
            cargos.forEach(function (cargo, idx) {
                rows.push(rowHtml('품명 및 상품설명', 'goodsName' + idx, cargo.goodsName || '', pdf.goodsDescription, hasFile, loaded));
                rows.push(rowHtml('수량 또는 순중량', 'qty' + idx, cargo.qty || '', pdf.quantity, hasFile, loaded));
                rows.push(rowHtml('총중량', 'grossWeight' + idx, normalizeWeight(cargo.weight), pdf.grossWeight, hasFile, loaded));
                if (cargo.origin) rows.push(rowHtml('원산지', 'origin' + idx, cargo.origin, pdf.origin, hasFile, loaded));
            });
        }

        tbody.innerHTML = rows.join('');
        bindInputs();
        updateSummary();
    };

    window.selectImportManifestItem = function (item) {
        if (typeof originalSelect === 'function') originalSelect(item);

        ensureCompareLayout();
        if (typeof window.hideManifestPackingExtraControls === 'function') window.hideManifestPackingExtraControls();
        if (typeof window.renderManifestAttachmentDownloadBox === 'function') window.renderManifestAttachmentDownloadBox(item);
        if (typeof window.renderImportManifestCargoItems === 'function') window.renderImportManifestCargoItems(item);
    };

    window.handleManifestPackingUpload = function (file, item) {
        item = item || window.SELECTED_IMPORT_MANIFEST || {};
        if (!file) return;

        if (item.__uploadedPackingObjectUrl) {
            URL.revokeObjectURL(item.__uploadedPackingObjectUrl);
        }

        item.__uploadedPackingObjectUrl = URL.createObjectURL(file);
        item.__uploadedPackingFile = file;
        item.packingListFile = file.name;
        item.__packingTextLoading = true;
        item.__packingTextLoaded = false;

        window.renderManifestAttachmentDownloadBox(item);
        window.renderImportManifestCargoItems(item);

        var formData = new FormData();
        formData.append('file', file);

        fetch(ctxPath() + '/transport/import/manifest/upload-packing-text.do', {
            method: 'POST',
            headers: csrfHeaders({'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json'}),
            body: formData,
            credentials: 'same-origin'
        })
            .then(function (res) {
                if (!res.ok) {
                    return res.text().then(function (body) {
                        throw new Error('HTTP ' + res.status + (body ? ' / ' + body.substring(0, 120) : ''));
                    });
                }
                return res.json();
            })
            .then(function (data) {
                item.packingText = data && data.success ? (data.text || '') : '';
                item.__packingTextLoading = false;
                item.__packingTextLoaded = true;
                item.__manualPdfValues = {};

                window.renderManifestAttachmentDownloadBox(item);
                window.renderImportManifestCargoItems(item);

                if (!data || !data.success) {
                    console.warn('포장명세서 PDF 텍스트 추출 실패 응답', data);
                    alert((data && data.message) ? data.message : 'PDF 텍스트를 추출하지 못했습니다. 비교값을 직접 입력해주세요.');
                }
            })
            .catch(function (error) {
                console.error('포장명세서 업로드 텍스트 추출 실패', error);

                item.packingText = '';
                item.__packingTextLoading = false;
                item.__packingTextLoaded = true;

                window.renderManifestAttachmentDownloadBox(item);
                window.renderImportManifestCargoItems(item);

                alert('업로드한 PDF 텍스트 추출 요청이 실패했습니다. CSRF/컨트롤러 매핑 또는 PDFBox 의존성을 확인해주세요.');
            });
    };

    document.addEventListener('DOMContentLoaded', function () {
        if (typeof window.hideManifestPackingExtraControls === 'function') window.hideManifestPackingExtraControls();
    });
})();
