package kr.or.tacs.systemadmin.hsknowledge.mapper;

import java.util.List;

import org.apache.ibatis.annotations.Mapper;
import org.apache.ibatis.annotations.Param;

import kr.or.tacs.vo.systemadmin.hsknowledge.HsRefChunkVO;
import kr.or.tacs.vo.systemadmin.hsknowledge.HsRefDocSearchVO;
import kr.or.tacs.vo.systemadmin.hsknowledge.HsRefDocVO;

@Mapper
public interface IHsRefDocMapper {

    List<HsRefDocVO> selectHsRefDocList(HsRefDocSearchVO search);

    int selectHsRefDocTotalRecord(HsRefDocSearchVO search);

    HsRefDocVO selectHsRefDoc(@Param("hsRefDocNo") Long hsRefDocNo);

    List<HsRefDocVO> selectHsRefDocsByNos(@Param("hsRefDocNos") List<Long> hsRefDocNos);

    int insertHsRefDoc(HsRefDocVO doc);

    int updateHsRefDoc(HsRefDocVO doc);

    int updateHsRefDocUseYn(@Param("hsRefDocNo") Long hsRefDocNo, @Param("useYn") String useYn);

    List<HsRefChunkVO> selectHsRefChunkList(@Param("hsRefDocNo") Long hsRefDocNo);

    int insertHsRefChunk(HsRefChunkVO chunk);

    int deleteHsRefChunks(@Param("hsRefDocNo") Long hsRefDocNo);

    int updateHsRefDocEmbedStatus(@Param("hsRefDocNo") Long hsRefDocNo, @Param("statusCd") String statusCd);

    int updateHsRefDocEmbedResult(@Param("hsRefDocNo") Long hsRefDocNo,
                                  @Param("statusCd") String statusCd,
                                  @Param("totalChunks") int totalChunks);
}
