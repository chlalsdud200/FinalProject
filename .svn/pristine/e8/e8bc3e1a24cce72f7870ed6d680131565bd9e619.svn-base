/* ===== 검역 관리 전용 스타일 ===== */
.qu-tab-row {
  display: flex;
  gap: 0;
  border-bottom: 2px solid #e2e8f0;
  margin-bottom: 18px;
}
.qu-tab {
  padding: 9px 20px;
  font-size: 12px;
  font-weight: 800;
  color: #697d8f;
  text-decoration: none;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
}
.qu-tab.active { color: #565e74; border-bottom-color: #565e74; }
.qu-section-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; }
.qu-section-head h3 { font-size:16px; font-weight:800; display:flex; align-items:center; gap:8px; }
.qu-search-card, .qu-form-card { background:#fff; border:1px solid #e2e8f0; padding:18px 20px; margin-bottom:16px; }
.qu-search-grid { display:grid; grid-template-columns:repeat(4, 1fr); gap:14px 16px; }
.qu-btn-pair { display:flex; gap:6px; }
.qu-count-bar { font-size:12px; color:#4d6172; margin:8px 0; }
.qu-table-wrap { overflow-x:auto; border:1px solid #e2e8f0; border-top:2px solid #334155; }
.qu-table { min-width:980px; }
.qu-table th { white-space:nowrap; }
.qu-empty { text-align:center; color:#697d8f; padding:28px !important; }
.qu-status { display:inline-flex; padding:4px 9px; font-size:10px; font-weight:800; }
.qu-status.done { background:#d1fae5; color:#065f46; }
.qu-status.wait { background:#fef3c7; color:#92400e; }
.qu-detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
.qu-card { background:#fff; border:1px solid #e2e8f0; padding:18px; }
.qu-card h4 { font-size:13px; font-weight:800; color:#203444; border-bottom:1px solid #e2e8f0; padding-bottom:8px; margin-bottom:12px; }
.qu-dl { display:grid; grid-template-columns:130px 1fr; gap:8px 12px; font-size:12px; }
.qu-dl dt { color:#697d8f; font-weight:800; }
.qu-dl dd { color:#203444; min-width:0; word-break:break-all; }
.qu-form-card h4 { font-size:14px; font-weight:800; margin-bottom:14px; }
.qu-form-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px 18px; }
.qu-form-grid .full { grid-column:1 / -1; }
.mb-4 { margin-bottom:16px; }
@media (max-width: 1100px) {
  .qu-search-grid, .qu-form-grid, .qu-detail-grid { grid-template-columns:1fr; }
}


/* ===== 검역 첨부파일/품목 삭제 버튼 ===== */
.qu-trash-btn {
  width: 28px;
  height: 28px;
  border: 1px solid #fecaca;
  background: #fff1f2;
  color: #dc2626;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all .12s ease;
}

.qu-trash-btn:hover {
  background: #fee2e2;
  border-color: #fca5a5;
  color: #991b1b;
  transform: translateY(-1px);
}

.qu-trash-btn .material-symbols-outlined {
  font-size: 17px;
  line-height: 1;
}

/* =========================================================
   관세사 검역관리 - 수입검역신청 폼 정리
   JSP 분리 후 input/select/textarea 기본 스타일 보정
========================================================= */

.qu-section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.qu-section-head h3 {
  font-size: 16px;
  font-weight: 800;
  display: flex;
  align-items: center;
  gap: 6px;
  margin: 0;
  color: #203444;
}

.qu-form-card {
  background: #fff;
  border: 1px solid #e2e8f0;
  padding: 18px 20px;
  margin-bottom: 16px;
}

.qu-form-card h4 {
  font-size: 14px;
  font-weight: 800;
  color: #203444;
  margin: 0 0 14px;
  padding-bottom: 8px;
  border-bottom: 1px solid #e2e8f0;
}

.qu-form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px 18px;
}

.qu-form-grid .full {
  grid-column: 1 / -1;
}

.qu-form-grid label,
.qu-form-card label {
  display: block;
  font-size: 12px;
  font-weight: 800;
  color: #4d6172;
  margin-bottom: 5px;
}

.qu-form-grid input,
.qu-form-grid select,
.qu-form-grid textarea,
.qu-form-card input,
.qu-form-card select,
.qu-form-card textarea {
  width: 100%;
  min-height: 36px;
  padding: 8px 10px;
  border: 1px solid #cbd5e1;
  background: #fff;
  color: #203444;
  font-size: 13px;
  box-sizing: border-box;
  outline: none;
}

.qu-form-grid textarea,
.qu-form-card textarea {
  min-height: 90px;
  resize: vertical;
  line-height: 1.5;
}

.qu-form-grid input:focus,
.qu-form-grid select:focus,
.qu-form-grid textarea:focus,
.qu-form-card input:focus,
.qu-form-card select:focus,
.qu-form-card textarea:focus {
  border-color: #565e74;
  box-shadow: 0 0 0 2px rgba(86, 94, 116, 0.08);
}

.qu-form-grid input[readonly],
.qu-form-card input[readonly] {
  background: #f8fafc;
  color: #64748b;
}

.qu-form-grid input::placeholder,
.qu-form-card input::placeholder,
.qu-form-card textarea::placeholder {
  color: #94a3b8;
}

.req {
  color: #dc2626;
  font-weight: 900;
}

/* 품목 테이블 안 input 깨짐 방지 */
.qu-form-card .data-table input,
.qu-form-card .data-table select {
  width: 100%;
  min-width: 0;
  height: 32px;
  padding: 6px 8px;
  font-size: 12px;
  box-sizing: border-box;
}

.qu-form-card .data-table th,
.qu-form-card .data-table td {
  vertical-align: middle;
  white-space: nowrap;
}

.qu-form-card .data-table td {
  padding: 6px;
}

/* 첨부파일 박스 */
.qu-attach-box {
  border: 2px dashed #cbd5e1;
  padding: 24px;
  text-align: center;
  background: #f8fafc;
}

.qu-attach-box:hover {
  background: #f1f5f9;
  border-color: #94a3b8;
}

.qu-attach-box.drag-over {
  background: #ecfdf5;
  border-color: #10b981;
}

/* 버튼 정렬 */
.btn-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 작은 화면 대응 */
@media (max-width: 1100px) {
  .qu-form-grid {
    grid-template-columns: 1fr;
  }

  .qu-section-head {
    align-items: flex-start;
    flex-direction: column;
    gap: 10px;
  }
}


/* 필수 입력 표시 */
.required-label::after {
    content: " *";
    color: #dc2626;
    font-weight: 700;
}

/* 필수 입력 안내 문구 */
.required-guide {
    font-size: 13px;
    color: #64748b;
    margin-bottom: 12px;
}

.required-guide .star {
    color: #dc2626;
    font-weight: 700;
}

/* 첨부파일 목록 - 첨부 박스 내부 표시 */
.qu-attach-file-list {
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
}

/* 첨부파일 카드 */
.qu-attach-file-item {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 220px;
    max-width: 320px;
    padding: 8px 10px;
    border: 1px solid #cbd5e1;
    background: #ffffff;
    color: #334155;
    font-size: 12px;
    text-align: left;
}

/* 파일 아이콘 */
.qu-attach-file-item .file-icon {
    font-size: 20px;
    color: #475569;
    flex-shrink: 0;
}

/* 파일명 영역 */
.qu-attach-file-info {
    min-width: 0;
    flex: 1;
}

/* 파일명 */
.qu-attach-file-name {
    font-weight: 700;
    color: #1e293b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* 파일 크기 */
.qu-attach-file-size {
    margin-top: 2px;
    font-size: 11px;
    color: #64748b;
}