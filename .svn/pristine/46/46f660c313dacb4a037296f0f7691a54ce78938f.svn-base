<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<header class="topbar">
      <div class="tb-left">
        <span class="tb-brand">TACS</span>
        <div class="search-wrap">
          <span class="material-symbols-outlined">search</span>
          <input placeholder="통관의뢰번호 · 업체명 · HS코드 통합 검색..." id="gSearch" onkeydown="if(event.key==='Enter')doSearch()">
        </div>
      </div>
      <div class="tb-right">
        <% if (request.isUserInRole("SYSTEM_ADMIN")) { %>
        <button class="tb-btn" title="액터 목록" onclick="location.href='${ctx}/systemadmin/dashboard.do'">
          <span class="material-symbols-outlined">list</span>
        </button>
        <% } %>
        <jsp:include page="/WEB-INF/views/common/notification_bell.jsp" />
        <button class="tb-btn"
          onclick="alert('TACS 도움말\n\n• 화주관리: 화주의 신청을 수락/거절\n• 신고서작성: 셀렉트박스로 업무 선택\n• 처리현황: 통합 조회')"><span
            class="material-symbols-outlined">help</span></button>
        <div class="tb-sep"></div>
        <div class="tb-user">
          <div class="tb-user-info">
            <div class="name">관세사 김관세</div>
            <div class="role">인천본부세관 · CS-20241</div>
          </div>
          <div class="tb-avatar" onclick="if(confirm('로그아웃 하시겠습니까?')) location.href='${pageContext.request.contextPath}/logout'" style="cursor:pointer">김</div>
        </div>
      </div>
</header>
