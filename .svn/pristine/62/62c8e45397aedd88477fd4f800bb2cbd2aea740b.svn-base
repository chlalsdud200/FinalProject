<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.officer.xlsx.mapper.ICustomsTariffRateMapper">

    <insert id="insertTariffRate"
            parameterType="kr.or.tacs.dto.officer.xlsx.CustomsTariffRateDTO">
        INSERT INTO CUSTOMS_TARIFF_RATE (
            CTR_NO,
            CTR_HS_CODE,
            CTR_RATE_TYPE,
            CTR_TARIFF_RATE,
            CTR_UNIT_TAX_AMOUNT,
            CTR_BASE_PRICE,
            CTR_APPLY_COUNTRY_TYPE,
            CTR_USE_RATE_TYPE,
            CTR_START_DATE,
            CTR_END_DATE
        ) VALUES (
            SEQ_CUSTOMS_TARIFF_RATE.NEXTVAL,
            #{ctrHsCode},
            #{ctrRateType},
            #{ctrTariffRate},
            #{ctrUnitTaxAmount},
            #{ctrBasePrice},
            #{ctrApplyCountryType},
            #{ctrUseRateType},
            #{ctrStartDate},
            #{ctrEndDate}
        )
    </insert>

    <delete id="deleteAllTariffRate">
        DELETE FROM CUSTOMS_TARIFF_RATE
    </delete>
    
    <select id="selectTariffRateByHsCode"
        parameterType="string"
        resultType="kr.or.tacs.dto.officer.xlsx.CustomsTariffRateDTO">
    SELECT
        CTR_NO AS ctrNo,
        CTR_HS_CODE AS ctrHsCode,
        CTR_RATE_TYPE AS ctrRateType,
        CTR_TARIFF_RATE AS ctrTariffRate,
        CTR_UNIT_TAX_AMOUNT AS ctrUnitTaxAmount,
        CTR_BASE_PRICE AS ctrBasePrice,
        CTR_APPLY_COUNTRY_TYPE AS ctrApplyCountryType,
        CTR_USE_RATE_TYPE AS ctrUseRateType,
        CTR_START_DATE AS ctrStartDate,
        CTR_END_DATE AS ctrEndDate
    FROM CUSTOMS_TARIFF_RATE
    WHERE CTR_HS_CODE = REPLACE(REPLACE(#{hsCode}, '.', ''), '-', '')
    ORDER BY CTR_RATE_TYPE
</select>

</mapper>