package kr.or.tacs.broker.status.service;

import java.util.List;
import java.util.Map;

import kr.or.tacs.broker.status.mapper.IStatusMapper;
import kr.or.tacs.dto.PageDTO;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import java.math.BigDecimal;
import java.util.HashMap;

@Service
public class StatusServiceImpl implements IStatusService {

    private final IStatusMapper statusMapper;

    public StatusServiceImpl(IStatusMapper statusMapper) {
        this.statusMapper = statusMapper;
    }


    @Override
    public int selectImportDeclareCount(String brokerId, PageDTO pageDTO) {
        return statusMapper.selectImportDeclareCount(brokerId, pageDTO);
    }

    @Override
    public List<Map<String, Object>> selectImportDeclareList(String brokerId, PageDTO pageDTO) {
        return statusMapper.selectImportDeclareList(brokerId, pageDTO);
    }

    @Override
    public Map<String, Object> selectImportDeclareDetail(String idIrNo, String brokerId) {
        return statusMapper.selectImportDeclareDetail(idIrNo, brokerId);
    }

    @Override
    public List<Map<String, Object>> selectImportDeclareItemList(String idIrNo) {
        return statusMapper.selectImportDeclareItemList(idIrNo);
    }

    @Override
    public List<Map<String, Object>> selectImportDeclareMdlspecList(String idIrNo) {
        return statusMapper.selectImportDeclareMdlspecList(idIrNo);
    }
    
    @Override
    public List<Map<String, Object>> selectTaxList(String brokerId, PageDTO pageDTO) {
        return statusMapper.selectTaxList(brokerId, pageDTO);
    }

    @Override
    public List<Map<String, Object>> selectCertList(String brokerId, PageDTO pageDTO) {
        return statusMapper.selectCertList(brokerId, pageDTO);
    }
    
    @Override
    public Map<String, Object> selectSupplementItem(String idIrNo, Integer idiSn, String brokerId) {
        return statusMapper.selectSupplementItem(idIrNo, idiSn, brokerId);
    }

    @Override
    public List<Map<String, Object>> selectSupplementMdlspecList(String idIrNo, Integer idiSn) {
        return statusMapper.selectSupplementMdlspecList(idIrNo, idiSn);
    }

    @Transactional
    @Override
    public void submitSupplementItem(
            String idIrNo,
            Integer idiSn,
            String brokerId,
            String idiHsCd,
            String idiDclrGdsnm,
            String idiTrdngGdsnm,
            String idiTrdmkNm,
            String idiQty,
            String idiQtyUnitCd,
            String idiNetWt,
            String idiTaxtPrcKrw,
            String idiOrgnCntryCd,
            String[] idimMdlspecNo,
            String[] idimMdlspecNm,
            String[] idimQty1,
            String[] idimQty1UnitCd,
            String[] idimUnitPrc,
            String[] idimAmt
    ) {
        Map<String, Object> item = statusMapper.selectSupplementItem(idIrNo, idiSn, brokerId);

        if (item == null) {
            throw new IllegalArgumentException("수정 가능한 란사항을 찾을 수 없습니다.");
        }

        Object statusObj = item.get("IDISTATUSCD");
        String statusCd = statusObj == null ? null : String.valueOf(statusObj);

        if (!"ITEM_SUPP_REQ".equals(statusCd)) {
            throw new IllegalStateException("보완요청 상태의 란사항만 수정할 수 있습니다.");
        }

        Map<String, Object> param = new HashMap<>();
        param.put("idIrNo", idIrNo);
        param.put("idiSn", idiSn);
        param.put("idiHsCd", emptyToNull(idiHsCd));
        param.put("idiDclrGdsnm", emptyToNull(idiDclrGdsnm));
        param.put("idiTrdngGdsnm", emptyToNull(idiTrdngGdsnm));
        param.put("idiTrdmkNm", emptyToNull(idiTrdmkNm));
        param.put("idiQty", toDecimal(idiQty));
        param.put("idiQtyUnitCd", emptyToNull(idiQtyUnitCd));
        param.put("idiNetWt", toDecimal(idiNetWt));
        param.put("idiTaxtPrcKrw", toDecimal(idiTaxtPrcKrw));
        param.put("idiOrgnCntryCd", emptyToNull(idiOrgnCntryCd));

        statusMapper.updateSupplementItem(param);

        statusMapper.deleteSupplementMdlspecByItem(idIrNo, idiSn);

        if (idimMdlspecNo != null) {
            for (int i = 0; i < idimMdlspecNo.length; i++) {
                String specNo = getArrayValue(idimMdlspecNo, i);
                String specNm = getArrayValue(idimMdlspecNm, i);

                if (isBlank(specNo) && isBlank(specNm)) {
                    continue;
                }

                Map<String, Object> m = new HashMap<>();
                m.put("idimSn", idiSn);
                m.put("idimIrNo", idIrNo);
                m.put("idimMdlspecNo", emptyToNull(specNo));
                m.put("idimMdlspecNm", emptyToNull(specNm));
                m.put("idimQty1", toDecimal(getArrayValue(idimQty1, i)));
                m.put("idimQty1UnitCd", emptyToNull(getArrayValue(idimQty1UnitCd, i)));
                m.put("idimUnitPrc", toDecimal(getArrayValue(idimUnitPrc, i)));
                m.put("idimAmt", toDecimal(getArrayValue(idimAmt, i)));

                statusMapper.insertSupplementMdlspec(m);
            }
        }

        statusMapper.updateItemStatusToSuppSub(idIrNo, idiSn);
    }

    
    @Override
    public List<Map<String, Object>> selectTaxChargeList(String brokerId) {
        return statusMapper.selectTaxChargeList(brokerId);
    }

    @Transactional
    @Override
    public void createBrokerCharge(String irNo, Long ctNo, String brokerId) {
        if (isBlank(irNo)) {
            throw new IllegalArgumentException("수입통관의뢰번호가 없습니다.");
        }

        if (ctNo == null) {
            throw new IllegalArgumentException("통관세금번호가 없습니다.");
        }

        if (isBlank(brokerId)) {
            throw new IllegalArgumentException("로그인 관세사 정보가 없습니다.");
        }

        int exists = statusMapper.countBrokerChargeByTax(irNo, ctNo);
        if (exists > 0) {
            throw new IllegalStateException("이미 생성된 화주 청구가 있습니다.");
        }

        Map<String, Object> src = statusMapper.selectChargeSourceForCreate(irNo, ctNo, brokerId);
        if (src == null) {
            throw new IllegalArgumentException("청구 생성 가능한 세금 내역을 찾을 수 없습니다.");
        }

        BigDecimal dclrAmt = getDecimal(src, "DCLRAMT");
        BigDecimal taxAmt = getDecimal(src, "TAXAMT");

        if (dclrAmt.compareTo(BigDecimal.ZERO) <= 0) {
            dclrAmt = taxAmt;
        }

        Map<String, Object> policy = statusMapper.selectBrokerFeePolicyByAmount(dclrAmt);
        if (policy == null) {
            throw new IllegalStateException("신고금액에 맞는 수수료 정책을 찾을 수 없습니다.");
        }

        BigDecimal baseFee = getDecimal(policy, "BFPBASEFEEAMT");
        BigDecimal rate = getDecimal(policy, "BFPRATE");
        BigDecimal minFee = getDecimal(policy, "BFPMINFEEAMT");
        BigDecimal maxFee = getDecimal(policy, "BFPMAXFEEAMT");
        BigDecimal vatRate = getDecimal(policy, "BFPVATRATE");

        BigDecimal rateFee = dclrAmt.multiply(rate);
        BigDecimal brokerFee = baseFee.max(rateFee).max(minFee);

        if (maxFee.compareTo(BigDecimal.ZERO) > 0) {
            brokerFee = brokerFee.min(maxFee);
        }

        brokerFee = brokerFee.setScale(0, java.math.RoundingMode.HALF_UP);
        BigDecimal feeVat = brokerFee.multiply(vatRate).setScale(0, java.math.RoundingMode.HALF_UP);
        BigDecimal totalAmt = taxAmt.add(brokerFee).add(feeVat);

        String bcNo = makeBrokerChargeNo();
        String paymentId = "PAY-" + bcNo;

        Map<String, Object> param = new HashMap<>();
        param.put("bcNo", bcNo);
        param.put("ctNo", ctNo);
        param.put("irNo", irNo);
        param.put("owrId", getString(src, "OWRID"));
        param.put("brokerId", getString(src, "BROKERID"));
        param.put("bfpNo", getString(policy, "BFPNO"));
        param.put("taxAmt", taxAmt);
        param.put("brokerFeeAmt", brokerFee);
        param.put("feeVatAmt", feeVat);
        param.put("totalAmt", totalAmt);
        param.put("orderNm", "수입통관 비용 청구 " + irNo);
        param.put("paymentId", paymentId);

        statusMapper.insertBrokerCharge(param);
    }

    private String makeBrokerChargeNo() {
        String ymd = java.time.LocalDate.now().format(java.time.format.DateTimeFormatter.BASIC_ISO_DATE);
        String tail = String.valueOf(System.currentTimeMillis());
        tail = tail.substring(tail.length() - 6);
        return "BC-" + ymd + "-" + tail;
    }

    private String getString(Map<String, Object> map, String key) {
        Object value = map.get(key);
        if (value == null) {
            value = map.get(toSnakeUpper(key));
        }
        return value == null ? null : String.valueOf(value);
    }

    private BigDecimal getDecimal(Map<String, Object> map, String key) {
        Object value = map.get(key);
        if (value == null) {
            value = map.get(toSnakeUpper(key));
        }
        return toBigDecimal(value);
    }

    private String toSnakeUpper(String key) {
        if ("DCLRAMT".equals(key)) return "DCLR_AMT";
        if ("TAXAMT".equals(key)) return "TAX_AMT";
        if ("OWRID".equals(key)) return "OWR_ID";
        if ("BROKERID".equals(key)) return "BROKER_ID";
        if ("BFPNO".equals(key)) return "BFP_NO";
        if ("BFPBASEFEEAMT".equals(key)) return "BFP_BASE_FEE_AMT";
        if ("BFPRATE".equals(key)) return "BFP_RATE";
        if ("BFPMINFEEAMT".equals(key)) return "BFP_MIN_FEE_AMT";
        if ("BFPMAXFEEAMT".equals(key)) return "BFP_MAX_FEE_AMT";
        if ("BFPVATRATE".equals(key)) return "BFP_VAT_RATE";
        return key;
    }

    private BigDecimal toBigDecimal(Object value) {
        if (value == null) {
            return BigDecimal.ZERO;
        }

        if (value instanceof BigDecimal) {
            return (BigDecimal) value;
        }

        if (value instanceof Number) {
            return new BigDecimal(String.valueOf(value));
        }

        String str = String.valueOf(value).replace(",", "").trim();
        if (str.isEmpty()) {
            return BigDecimal.ZERO;
        }

        return new BigDecimal(str);
    }

    private boolean isBlank(String value) {
        return value == null || value.trim().isEmpty();
    }
    
    private String getArrayValue(String[] arr, int idx) {
        if (arr == null || idx >= arr.length) return null;
        return arr[idx];
    }

    private String emptyToNull(String value) {
        if (value == null) return null;
        String trimmed = value.trim();
        return trimmed.isEmpty() ? null : trimmed;
    }


    private BigDecimal toDecimal(String value) {
        if (value == null || value.trim().isEmpty()) {
            return null;
        }
        return new BigDecimal(value.replace(",", "").trim());
    }
}