<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ include file="/WEB-INF/views/officer/common/taglibs.jsp" %>
<%@ taglib uri="http://www.springframework.org/security/tags" prefix="sec" %>

<c:set var="ctx" value="${pageContext.request.contextPath}" />
<c:set var="activeMenu" value="cargo" />
<c:set var="activeSub" value="exportAndFulfillment" />

<!DOCTYPE html>
<html lang="ko">
    <head>
        <%@ include file="/WEB-INF/views/officer/header/head.jsp" %>
        <title>TACS · 반출 및 이행 관리</title>
        <link rel="stylesheet" href="${ctx}/resources/css/officer/pages/exportAndFulfillment.css">
    </head>

    <body>
        <%@ include file="/WEB-INF/views/officer/header/sidebar.jsp" %>
        <%@ include file="/WEB-INF/views/officer/header/header.jsp" %>

        <main class="officer-main">
            <div class="page-content exportAndFulfillment-page">
                <div class="mb-5">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="text-[10px] font-black text-on-surface-variant">이행·반출 및 화물 조회</span>
                        <span class="text-on-surface-variant">›</span>
                        <span class="bg-primary text-on-primary text-[10px] font-black px-2 py-0.5">TACS-AD-018</span>
                    </div>
                    <h2 class="text-xl font-black text-slate-900">반출 및 이행 관리</h2>
                </div>

                <div class="inline-screen-host active" id="screen-host-TACS-AD-018">
                    <div class="inline-screen-header">
                        <h3 class="font-black text-base">반출 및 이행 관리</h3>
                        <p class="text-[10px] text-primary-fixed mt-0.5">TACS-AD-018 · 수입 반출, 즉시반출, 수출 적재이행을 처리 가능 여부 중심으로 관리합니다.</p>
                    </div>
                    <div class="inline-screen-body">
                        <div class="line-tabs" style="margin-bottom:16px;">
                            <button class="line-tab active" data-tab-group="fulfillment-type" onclick="setCommonTab('fulfillment-type','import-release',this)">수입 반출</button>
                            <button class="line-tab" data-tab-group="fulfillment-type" onclick="setCommonTab('fulfillment-type','immediate-release',this)">즉시반출</button>
                            <button class="line-tab" data-tab-group="fulfillment-type" onclick="setCommonTab('fulfillment-type','export-loading',this)">수출 적재이행</button>
                        </div>
                        <div class="receipt-search-panel white-bg">
                            <p class="section-title receipt-search-title">검색 조건</p>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">신고번호</div>
                                <div class="receipt-search-field receipt-search-field-wide">
                                    <input class="receipt-search-input" placeholder="신고번호 입력" style="width:100%;" type="text"/>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">처리 상태</div>
                                <div class="receipt-search-field receipt-search-field-md">
                                    <select class="receipt-search-select w-full">
                                        <option>전체</option>
                                        <option>접수대기</option>
                                        <option>심사중</option>
                                        <option>처리대기</option>
                                        <option>완료</option>
                                    </select>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">구분</div>
                                <div class="receipt-search-radio-group">
                                    <label class="receipt-check-item"><input checked="" type="checkbox"/> 전체</label>
                                    <label class="receipt-check-item"><input type="checkbox"/> 수입</label>
                                    <label class="receipt-check-item"><input type="checkbox"/> 수출</label>
                                </div>
                            </div>
                            <div class="receipt-search-row">
                                <div class="receipt-search-label">신고 일자</div>
                                <div class="receipt-search-date-wrap">
                                    <input class="receipt-search-date" type="date" value="2026-04-01"/>
                                    <span class="receipt-search-date-sep">~</span>
                                    <input class="receipt-search-date" type="date" value="2026-04-14"/>
                                    <button class="receipt-inline-btn">최근 1주일</button>
                                </div>
                            </div>
                            <div class="receipt-search-row receipt-search-row-last">
                                <div class="receipt-search-label">통합 검색</div>
                                <div class="receipt-search-bottom">
                                    <input class="receipt-search-input" placeholder="신고번호 또는 업체명 입력" type="text"/>
                                    <button class="btn-primary receipt-action-btn"><span class="material-symbols-outlined text-[16px]">search</span>조회</button>
                                    <button class="btn-secondary receipt-action-btn">초기화</button>
                                </div>
                            </div>
                        </div> <div data-panel-group="fulfillment-type" data-panel-key="import-release" style="display:block;">
                        <div class="flex items-center justify-between mb-3"><div class="text-[15px] font-bold text-slate-800">수입 반출 처리 대상 <span class="text-blue-600 ml-2">3건</span></div></div>
                        <div class="bg-white border border-slate-200 mb-4">
                            <table class="data-table">
                                <thead><tr><th>No.</th><th>신고번호</th><th>업체명</th><th>품명</th><th>보세구역</th><th>처리 가능 여부</th><th>기준일</th><th>현재상태</th><th>상세</th></tr></thead>
                                <tbody>
                                    <tr><td>1</td><td class="font-bold text-blue-600">IMP-2026-0418-001</td><td>노선호</td><td>쌀</td><td>인천 CFS</td><td>가능</td><td>2026-04-18</td><td><span class="badge-progress">반출대기</span></td><td><button class="btn-secondary btn-sm" onclick="toggleTradeStatusDetail(this)">상세</button></td></tr>
                                    <tr><td>2</td><td class="font-bold text-blue-600">IMP-2026-0417-021</td><td>김대한</td><td>전자부품</td><td>부산 CY</td><td>완료</td><td>2026-04-17</td><td><span class="badge-done">반출완료</span></td><td><button class="btn-secondary btn-sm" onclick="toggleTradeStatusDetail(this)">상세</button></td></tr>
                                    <tr><td>3</td><td class="font-bold text-blue-600">IMP-2026-0412-014</td><td>세림푸드</td><td>냉동식품</td><td>평택 냉동창고</td><td>검역증명서 확인필요</td><td>2026-04-12</td><td><span class="badge-wait">미반출 D+4</span></td><td><button class="btn-secondary btn-sm" onclick="toggleTradeStatusDetail(this)">상세</button></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div data-panel-group="fulfillment-type" data-panel-key="immediate-release" style="display:none;">
                        <div class="flex items-center justify-between mb-3"><div class="text-[15px] font-bold text-slate-800">즉시반출 검토 대상 <span class="text-blue-600 ml-2">2건</span></div></div>
                        <div class="bg-white border border-slate-200 mb-4">
                            <table class="data-table">
                                <thead><tr><th>No.</th><th>신고번호</th><th>업체명</th><th>품명</th><th>담보상태</th><th>요건상태</th><th>법규준수도</th><th>현재상태</th><th>상세</th></tr></thead>
                                <tbody>
                                    <tr><td>1</td><td class="font-bold text-blue-600">IMP-2026-0418-009</td><td>동해전자</td><td>반도체 설비부품</td><td>담보제공 완료</td><td>요건확인 완료</td><td>A등급</td><td><span class="badge-progress">허용대기</span></td><td><button class="btn-secondary btn-sm" onclick="toggleTradeStatusDetail(this)">상세</button></td></tr>
                                    <tr><td>2</td><td class="font-bold text-blue-600">IMP-2026-0418-014</td><td>정다운무역</td><td>냉동망고</td><td>담보 확인필요</td><td>검역 진행중</td><td>B등급</td><td><span class="badge-wait">검토중</span></td><td><button class="btn-secondary btn-sm" onclick="toggleTradeStatusDetail(this)">상세</button></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div data-panel-group="fulfillment-type" data-panel-key="export-loading" style="display:none;">
                        <div class="flex items-center justify-between mb-3"><div class="text-[15px] font-bold text-slate-800">수출 적재이행 처리 대상 <span class="text-blue-600 ml-2">3건</span></div></div>
                        <div class="bg-white border border-slate-200 mb-4">
                            <table class="data-table">
                                <thead><tr><th>No.</th><th>신고번호</th><th>업체명</th><th>품명</th><th>선박/항차</th><th>적재목록</th><th>D-Day</th><th>현재상태</th><th>상세</th></tr></thead>
                                <tbody>
                                    <tr><td>1</td><td class="font-bold text-blue-600">EXP-2026-0418-007</td><td>미래로지스</td><td>자동차부품</td><td>HMM OCEAN / 0418E</td><td>확인완료</td><td>D-5</td><td><span class="badge-progress">적재대기</span></td><td><button class="btn-secondary btn-sm" onclick="toggleTradeStatusDetail(this)">상세</button></td></tr>
                                    <tr><td>2</td><td class="font-bold text-blue-600">EXP-2026-0417-011</td><td>서해테크</td><td>산업기기</td><td>MSC GRACE / 2526E</td><td>중량 차이</td><td>D-2</td><td><span class="badge-wait">적재확인 필요</span></td><td><button class="btn-secondary btn-sm" onclick="toggleTradeStatusDetail(this)">상세</button></td></tr>
                                    <tr><td>3</td><td class="font-bold text-blue-600">EXP-2026-0310-022</td><td>코오롱</td><td>화학제품</td><td>KMTC BUSAN / 119W</td><td>미확인</td><td>D+5</td><td><span class="badge-fail">기한초과</span></td><td><button class="btn-secondary btn-sm" onclick="toggleTradeStatusDetail(this)">상세</button></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div id="trade-status-detail-panel" style="display:none;">
                        <div class="info-card mb-0">
                            <p class="section-title">신고 기본정보</p>
                            <div class="grid grid-cols-4 gap-3 mb-4">
                                <div><label class="form-label">신고번호</label><input class="form-input" readonly="" type="text" value="IMP-2026-0412-014"/></div>
                                <div><label class="form-label">업체명</label><input class="form-input" readonly="" type="text" value="세림푸드"/></div>
                                <div><label class="form-label">품명</label><input class="form-input" readonly="" type="text" value="냉동식품"/></div>
                                <div><label class="form-label">현재상태</label><input class="form-input" readonly="" type="text" value="미반출 D+4"/></div>
                                <div><label class="form-label">보세구역</label><input class="form-input" readonly="" type="text" value="평택 냉동창고"/></div>
                                <div><label class="form-label">화물관리번호</label><input class="form-input" readonly="" type="text" value="CARGO-2026-0412-014"/></div>
                                <div><label class="form-label">연결 B/L</label><input class="form-input" readonly="" type="text" value="HB-2604120091"/></div>
                                <div><label class="form-label">처리기준일</label><input class="form-input" readonly="" type="text" value="2026-04-12"/></div>
                            </div>
                            <p class="section-title">처리 가능 여부 체크</p>
                            <table class="data-table mb-4">
                                <thead><tr><th>확인항목</th><th>확인값</th><th>결과</th><th>비고</th></tr></thead>
                                <tbody>
                                    <tr><td class="font-bold">신고수리 완료 여부</td><td>수리완료</td><td><span class="badge-done">정상</span></td><td>수리번호 AC-2026-0412-014</td></tr>
                                    <tr><td class="font-bold">세금 납부 여부</td><td>납부완료</td><td><span class="badge-done">정상</span></td><td>전자납부 확인</td></tr>
                                    <tr><td class="font-bold">검사/검역 완료 여부</td><td>검역증명서 미수신</td><td><span class="badge-wait">확인필요</span></td><td>검역기관 결과 대기</td></tr>
                                    <tr><td class="font-bold">통관보류 여부</td><td>보류 없음</td><td><span class="badge-done">정상</span></td><td>-</td></tr>
                                    <tr><td class="font-bold">보세구역 반입 여부</td><td>반입완료</td><td><span class="badge-done">정상</span></td><td>평택 냉동창고</td></tr>
                                </tbody>
                            </table>
                            <p class="section-title">반출/적재 정보</p>
                            <table class="data-table mb-4">
                                <tbody>
                                    <tr><td class="font-bold">수입 반출 정보</td><td>반출장소: 평택 냉동창고 / 반출예정일: 검역증명서 수신 후</td></tr>
                                    <tr><td class="font-bold">즉시반출 정보</td><td>담보상태: 확인필요 / 법규준수도: B등급 / 요건상태: 검역 진행중</td></tr>
                                    <tr><td class="font-bold">수출 적재 정보</td><td>선박명·항차, 적재예정일, 적재목록 검증결과를 기준으로 적재완료 처리</td></tr>
                                </tbody>
                            </table>
                            <p class="section-title">처리 이력</p>
                            <table class="data-table mb-4">
                                <thead><tr><th>일시</th><th>처리내용</th><th>담당</th></tr></thead>
                                <tbody>
                                    <tr><td>2026-04-12 10:20</td><td>수입신고 수리 완료</td><td>김심사</td></tr>
                                    <tr><td>2026-04-12 13:10</td><td>보세구역 반입 확인</td><td>시스템</td></tr>
                                    <tr><td>2026-04-14 09:30</td><td>검역 결과 수신 대기</td><td>이검토</td></tr>
                                </tbody>
                            </table>
                            <div class="mb-4"><label class="form-label">확인 의견</label><textarea class="form-textarea" rows="3">검역증명서 수신 전이므로 반출 처리 전 요건 결과 확인이 필요합니다.</textarea></div>
                            <div class="flex gap-2 flex-wrap">
                                <button class="btn-primary">반출 처리</button>
                                <button class="btn-success">즉시반출 허용</button>
                                <button class="btn-secondary">적재완료 처리</button>
                                <button class="btn-secondary">보완요청</button>
                                <button class="btn-danger" onclick="showPage('cat6')">통관보류</button>
                            </div>
                        </div>
                    </div></div>
                </div>
            </div>
        </main>

        <%@ include file="/WEB-INF/views/officer/footer/footer.jsp" %>
        <%@ include file="/WEB-INF/views/officer/footer/scripts.jsp" %>

        <script defer src="${ctx}/resources/js/officer/pages/exportAndFulfillment.js"></script>
    </body>
</html>
