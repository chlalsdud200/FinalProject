<%@ page pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<c:set var="mp" value="${requestScope.menuPermissions}" />
<c:if test="${menuPermissionEnabled eq true}">
<style>
<c:if test="${mp['/officer/dashboard.do'].readYn ne 'Y'}">.aside a[href$="/officer/dashboard.do"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/reportReceiptList.do'].readYn ne 'Y'}">.aside a[href$="/officer/reportReceiptList.do"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/basicScreenList.do'].readYn ne 'Y'}">.aside a[href$="/officer/basicScreenList.do"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/reportReceiptList.do'].readYn ne 'Y' and mp['/officer/basicScreenList.do'].readYn ne 'Y'}">.aside .nav-card:has(a[href$="/officer/reportReceiptList.do"]){display:none!important;}</c:if>
<c:if test="${mp['/officer/exportAndFulfillment.do'].readYn ne 'Y'}">.aside a[href$="/officer/exportAndFulfillment.do"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/loadedCargoList.do'].readYn ne 'Y'}">.aside a[href$="/officer/loadedCargoList.do"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/warehouseCargoTracking.do'].readYn ne 'Y'}">.aside a[href$="/officer/warehouseCargoTracking.do"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/exportAndFulfillment.do'].readYn ne 'Y' and mp['/officer/loadedCargoList.do'].readYn ne 'Y' and mp['/officer/warehouseCargoTracking.do'].readYn ne 'Y'}">.aside .nav-card:has(a[href$="/officer/exportAndFulfillment.do"]){display:none!important;}</c:if>
<c:if test="${mp['/officer/docs.do'].readYn ne 'Y'}">.aside a[href$="/officer/docs.do"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/docs/trash.do'].readYn ne 'Y'}">.aside a[href$="/officer/docs/trash.do"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/docs.do'].readYn ne 'Y' and mp['/officer/docs/trash.do'].readYn ne 'Y'}">.aside .nav-card:has(a[href$="/officer/docs.do"]){display:none!important;}</c:if>
<c:if test="${mp['/officer/community/notice.do'].readYn ne 'Y'}">.aside a[href$="/officer/community/notice.do"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/community/archive.do'].readYn ne 'Y'}">.aside a[href$="/officer/community/archive.do"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/community/cs.do'].readYn ne 'Y'}">.aside a[href$="/officer/community/cs.do"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/community/notice.do'].readYn ne 'Y' and mp['/officer/community/archive.do'].readYn ne 'Y' and mp['/officer/community/cs.do'].readYn ne 'Y'}">.aside .nav-card:has(a[href$="/officer/community/notice.do"]){display:none!important;}</c:if>
<c:if test="${mp['/officer/mypage.do?tab=profile'].readYn ne 'Y'}">.aside a[href*="/officer/mypage.do?tab=profile"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/mypage.do?tab=alarm'].readYn ne 'Y'}">.aside a[href*="/officer/mypage.do?tab=alarm"]{display:none!important;}</c:if>
<c:if test="${mp['/officer/mypage.do?tab=profile'].readYn ne 'Y' and mp['/officer/mypage.do?tab=alarm'].readYn ne 'Y'}">.aside .nav-card:has(a[href*="/officer/mypage.do?tab=profile"]){display:none!important;}</c:if>
</style>
</c:if>

<aside class="aside">
    <div class="logo-area">
        <div class="logo-row">
            <div class="logo-icon">
                <span class="material-symbols-outlined">account_balance</span>
            </div>
            <div class="logo-text">
                <h1>행정공무원</h1>
                <p>통관 심사 시스템</p>
            </div>
        </div>
    </div>

    <nav>
        <a class="nav-link ${activeMenu eq 'dashboard' ? 'active' : ''}"
           href="${ctx}/officer/dashboard.do">
            <span class="material-symbols-outlined">dashboard</span>
            대시보드
        </a>

        <div class="nav-card nav-hover-group ${activeMenu eq 'basic' ? 'active' : ''}">
            <div class="nav-group-header">
                <span class="nav-group-left">
                    <span class="material-symbols-outlined">fact_check</span>
                    신고 접수 및 기본심사
                </span>
                <span class="material-symbols-outlined nav-group-arrow">expand_more</span>
            </div>

            <div class="nav-submenu">
			    <a class="nav-sub-link ${activeSub eq 'reportReceiptList' ? 'active-sub' : ''}"
			       href="${ctx}/officer/reportReceiptList.do">기본접수목록</a>
			
			    <a class="nav-sub-link ${activeSub eq 'basicScreenList' ? 'active-sub' : ''}"
			       href="${ctx}/officer/basicScreenList.do">기본심사목록</a>
			</div>
        </div>     

        <div class="nav-card nav-hover-group ${activeMenu eq 'cargo' ? 'active' : ''}">
            <div class="nav-group-header">
                <span class="nav-group-left">
                    <span class="material-symbols-outlined">inventory_2</span>
                    이행·반출 및 화물 조회
                </span>
                <span class="material-symbols-outlined nav-group-arrow">expand_more</span>
            </div>

            <div class="nav-submenu">
                <a class="nav-sub-link ${activeSub eq 'exportAndFulfillment' ? 'active-sub' : ''}"
				   href="${ctx}/officer/exportAndFulfillment.do">반출 및 이행 관리</a>
				
				<a class="nav-sub-link ${activeSub eq 'loadedCargoList' ? 'active-sub' : ''}"
				   href="${ctx}/officer/loadedCargoList.do">적재화물목록 조회</a>
				
				<a class="nav-sub-link ${activeSub eq 'warehouseCargoTracking' ? 'active-sub' : ''}"
				   href="${ctx}/officer/warehouseCargoTracking.do">창고·화물 조회</a>
            </div>
        </div>

        <div class="nav-card nav-hover-group ${activeMenu eq 'docs' ? 'active' : ''}">
            <div class="nav-group-header">
                <span class="nav-group-left">
                    <span class="material-symbols-outlined">folder</span>
                    문서함
                </span>
                <span class="material-symbols-outlined nav-group-arrow">expand_more</span>
            </div>

            <div class="nav-submenu" id="docs-menu">
                <a class="nav-sub-link ${activeSub eq 'myDocs' ? 'active-sub' : ''}"
                   data-p="myDocs"
                   href="${ctx}/officer/docs.do">내문서</a>

                <a class="nav-sub-link ${activeSub eq 'trash' ? 'active-sub' : ''}"
                   data-p="trash"
                   href="${ctx}/officer/docs/trash.do">휴지통</a>
            </div>
        </div>

        <div class="nav-card nav-hover-group ${activeMenu eq 'community' ? 'active' : ''}">
            <div class="nav-group-header">
                <span class="nav-group-left">
                    <span class="material-symbols-outlined">forum</span>
                    커뮤니티
                </span>
                <span class="material-symbols-outlined nav-group-arrow">expand_more</span>
            </div>

            <div class="nav-submenu" id="community-menu">
             <a class="nav-sub-link ${activeSub eq 'notice' ? 'active-sub' : ''}"  
             	   data-p="notice"
                   data-community-tab="notice"        
				   href="${ctx}/officer/community/notice.do">공지사항</a>
				
			 <a class="nav-sub-link ${activeSub eq 'download' ? 'active-sub' : ''}"
			  	   data-p="archive"
                   data-community-tab="archive"
				   href="${ctx}/officer/community/archive.do">자료실</a>
				
			 <a class="nav-sub-link ${activeSub eq 'cs' ? 'active-sub' : ''}"
			 		data-p="center"
                    data-community-tab="center"
				   href="${ctx}/officer/community/cs.do">고객센터</a>             
            </div>
        </div>

        <div class="nav-card nav-hover-group ${activeMenu eq 'mypage' ? 'active' : ''}">
            <div class="nav-group-header">
                <span class="nav-group-left">
                    <span class="material-symbols-outlined">account_circle</span>
                    마이페이지
                </span>
                <span class="material-symbols-outlined nav-group-arrow">expand_more</span>
            </div>

            <div class="nav-submenu">
                <a class="nav-sub-link ${activeSub eq 'profile' ? 'active-sub' : ''}"
                   href="${ctx}/officer/mypage.do?tab=profile">회원정보 수정</a>

                <a class="nav-sub-link ${activeSub eq 'alarm' ? 'active-sub' : ''}"
                   href="${ctx}/officer/mypage.do?tab=alarm">알림 수신 설정</a>
            </div> 
        </div>      
    </nav>

    <div class="nav-bottom">
        <form action="${ctx}/logout" method="post" id="logoutForm" style="display:none;">
            <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}" />
        </form>

        <a class="nav-link" href="javascript:void(0)"
           onclick="document.getElementById('logoutForm').submit();">
            <span class="material-symbols-outlined">logout</span>
            로그아웃
        </a>
    </div>
</aside>
