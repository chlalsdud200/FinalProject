    /**
     * HS AI 추천용 임베딩 차원 테스트
     * URL: GET /broker/declare/testEmbedding.do?text=rice
     */
    @GetMapping("/declare/testEmbedding.do")
    @ResponseBody
    public Map<String, Object> testEmbedding(
            @RequestParam(value = "text", defaultValue = "rice") String text) {

        Map<String, Object> result = new HashMap<>();

        try {
            float[] vector = embeddingModel.embed(text);

            result.put("success", true);
            result.put("text", text);
            result.put("dimension", vector.length);
            result.put("message", "작은 임베딩 테스트 성공");

        } catch (Exception e) {
            e.printStackTrace();

            result.put("success", false);
            result.put("text", text);
            result.put("dimension", 0);
            result.put("message", "작은 임베딩 테스트 실패: " + e.getMessage());
        }

        return result;
    }
    
    
    /**
     * Milvus 저장 테스트
     * URL: GET /broker/declare/testMilvusAdd.do?text=rice
     */
    @GetMapping("/declare/testMilvusAdd.do")
    @ResponseBody
    public Map<String, Object> testMilvusAdd(
            @RequestParam(value = "text", defaultValue = "rice") String text) {

        Map<String, Object> result = new HashMap<>();

        try {
            Map<String, Object> metadata = new HashMap<>();
            metadata.put("doc_id", "TEST-RICE-001");
            metadata.put("hs_code", "1006300000");
            metadata.put("source", "TEST");

            Document doc = new Document(
                "TEST-RICE-001",
                text,
                metadata
            );

            vectorStore.add(List.of(doc));

            result.put("success", true);
            result.put("text", text);
            result.put("message", "Milvus 테스트 문서 저장 성공");

        } catch (Exception e) {
            e.printStackTrace();

            result.put("success", false);
            result.put("message", "Milvus 테스트 문서 저장 실패: " + e.getMessage());
        }

        return result;
    }
    
    
