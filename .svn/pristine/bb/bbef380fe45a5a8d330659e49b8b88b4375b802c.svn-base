/**
 * 신고서 작성 Controller
 *  - 페이지 GET    : /broker/declare/imp.do (?id=... 이어쓰기)
 *  - 임시저장 POST : /broker/declare/saveImpDraft.do
 */
@Controller
@RequestMapping("/broker")
public class BrokerDeclareController {

    @Autowired
    private IBrokerDeclareService brokerDeclareService;
    
    @Value("${hs.ai-recommend.enabled:false}")
    private boolean hsAiRecommendEnabled;

    @Value("${hs.ai-recommend.health-url:http://127.0.0.1:9091/healthz}")
    private String hsAiRecommendHealthUrl;

    @Value("${hs.ai-recommend.timeout-ms:1500}")
    private int hsAiRecommendTimeoutMs;

    @Value("${hs.ai-recommend.attu-url:http://localhost:8000}")
    private String hsAiRecommendAttuUrl;
    
    @Autowired
    private ApplicationContext applicationContext;

    @Autowired
    private AiDocumentParserService aiDocumentParserService;
    
    @Autowired
    private ObjectProvider<EmbeddingModel> embeddingModelProvider;

    @Autowired
    private EmbeddingModel embeddingModel;
    
    @Autowired
    private VectorStore vectorStore;
    
    @Autowired
    private Environment environment;
    /** Jackson ObjectMapper — Spring 빈 등록 여부와 무관하게 직접 인스턴스화 (thread-safe) */
    private static final ObjectMapper objectMapper = new ObjectMapper();

    // ==========================================================
    // 페이지 GET
    // ==========================================================

    
    @GetMapping("/declare/hsVector/beans.do")
    @ResponseBody
    public Map<String, Object> checkHsVectorBeans() {
        Map<String, Object> result = new HashMap<>();

        result.put("vectorStoreBeans",
            java.util.Arrays.asList(applicationContext.getBeanNamesForType(org.springframework.ai.vectorstore.VectorStore.class)));

        result.put("embeddingModelBeans",
            java.util.Arrays.asList(applicationContext.getBeanNamesForType(org.springframework.ai.embedding.EmbeddingModel.class)));

        result.put("chatClientBuilderBeans",
            java.util.Arrays.asList(applicationContext.getBeanNamesForType(org.springframework.ai.chat.client.ChatClient.Builder.class)));

        String commonKey = environment.getProperty("spring.ai.google.genai.api-key");
        String embeddingKey = environment.getProperty("spring.ai.google.genai.embedding.api-key");

        result.put("commonKeyExists", commonKey != null && !commonKey.isBlank());
        result.put("commonKeyLength", commonKey == null ? 0 : commonKey.length());
        result.put("commonKeyPrefix", commonKey == null || commonKey.length() < 6 ? "" : commonKey.substring(0, 6));

        result.put("embeddingKeyExists", embeddingKey != null && !embeddingKey.isBlank());
        result.put("embeddingKeyLength", embeddingKey == null ? 0 : embeddingKey.length());
        result.put("embeddingKeyPrefix", embeddingKey == null || embeddingKey.length() < 6 ? "" : embeddingKey.substring(0, 6));
        return result;
    }
    
    /**
     * 수입신고서 페이지
     *  - id 파라미터가 있으면 해당 임시저장 데이터를 조회해 model 에 JSON 으로 담음
     *  - declare.js 가 페이지 로드 시 fillImpForm() 으로 input 채움
     */
    @GetMapping("/declare/imp.do")
    public String declareImp(@RequestParam(value = "id", required = false) String id,
                             Model model,
                             Principal principal) {
        model.addAttribute("activeMenu", "declare");
        model.addAttribute("activeSub",  "imp");

        String brokerId = (principal != null) ? principal.getName() : null;

        // 이어쓰기 모드 — 저장된 신고서 데이터
        String impDclrJson = "null";
        if (id != null && !id.isEmpty() && brokerId != null) {
            ImpDclrVO vo = brokerDeclareService.findImpDclrById(brokerId, id);
            if (vo != null) {
                try {
                    impDclrJson = objectMapper.writeValueAsString(vo);
                } catch (Exception e) {
                    e.printStackTrace();
                }
            }
        }
        model.addAttribute("impDclrJson", impDclrJson);

        // 로그인 사용자(관세사) 정보 — 신고인 영역 자동 채움
        String currentBrokerJson = "null";
        if (brokerId != null) {
            BrokerVO broker = brokerDeclareService.findCurrentBroker(brokerId);
            if (broker != null) {
                // 비밀번호는 SELECT 에서 제외됨 (보안)
                try {
                    currentBrokerJson = objectMapper.writeValueAsString(broker);
                } catch (Exception e) {
                    e.printStackTrace();
                }
            }
        }
        model.addAttribute("currentBrokerJson", currentBrokerJson);

        return "broker/pages/declare";
    }

    @GetMapping("/declare/exp.do")
    public String declareExp(Model model, Principal principal) {
        model.addAttribute("activeMenu", "declare");
        model.addAttribute("activeSub",  "exp");
        model.addAttribute("impDclrJson", "null");

        // 수출도 동일하게 로그인 사용자 정보 주입
        String currentBrokerJson = "null";
        if (principal != null) {
            BrokerVO broker = brokerDeclareService.findCurrentBroker(principal.getName());
            if (broker != null) {
                try {
                    currentBrokerJson = objectMapper.writeValueAsString(broker);
                } catch (Exception e) {
                    e.printStackTrace();
                }
            }
        }
        model.addAttribute("currentBrokerJson", currentBrokerJson);

        return "broker/pages/declare";
    }

    // ==========================================================
    // 수입신고서 임시저장 (INSERT 또는 UPDATE — Service 에서 분기)
    // ==========================================================

    /**
     * URL  : POST /broker/declare/saveImpDraft.do
     * Body : ImpDclrVO JSON (idIrNo 가 있으면 UPDATE, 없으면 INSERT)
     * Resp : { success, idIrNo, message, mode: "insert"|"update" }
     */
    @PostMapping("/declare/saveImpDraft.do")
    @ResponseBody
    public Map<String, Object> saveImpDraft(@RequestBody ImpDclrVO vo, Principal principal) {
        Map<String, Object> result = new HashMap<>();
        try {
            String brokerId = (principal != null) ? principal.getName() : null;
            if (brokerId == null) {
                result.put("success", false);
                result.put("message", "로그인이 필요합니다.");
                return result;
            }

            // 통관의뢰번호 필수
            if (vo.getIdIrNo() == null || vo.getIdIrNo().trim().isEmpty()) {
                result.put("success", false);
                result.put("message", "통관의뢰번호가 없습니다.\n[기존 신고서 조회] 영역에서 의뢰번호를 먼저 조회해주세요.");
                return result;
            }

            if (vo.getIdImprNm() == null || vo.getIdImprNm().trim().isEmpty()) {
                result.put("success", false);
                result.put("message", "수입자 상호는 필수 입력값입니다.");
                return result;
            }

            // INSERT/UPDATE 판단 — service 안에서 selectImpDclrById 로 분기
            String idIrNo = brokerDeclareService.saveImpDraft(vo, brokerId);

            result.put("success", true);
            result.put("idIrNo",  idIrNo);
            result.put("message", "임시저장 완료\n통관의뢰번호: " + idIrNo);

        } catch (IllegalArgumentException e) {
            result.put("success", false);
            result.put("message", e.getMessage());
        } catch (IllegalStateException e) {
            result.put("success", false);
            result.put("message", e.getMessage());
        } catch (Exception e) {
            e.printStackTrace();
            result.put("success", false);
            result.put("message", "저장 실패: " + e.getMessage());
        }
        return result;
    }

    // ==========================================================
    // 의뢰서 단건 조회 — [조회] 버튼 응답 (8B)
    // ==========================================================

    /**
     * URL  : GET /broker/declare/loadImpRqst.do?irNo=IMP-20260502-901
     * Resp : { success, rqst: {...IMP_RQST...}, message }
     *
     * 화면의 [조회] 버튼이 호출 → 결과를 받아 신고서 폼의 일부 필드 자동 채움.
     */
    @GetMapping("/declare/loadImpRqst.do")
    @ResponseBody
    public Map<String, Object> loadImpRqst(@RequestParam("irNo") String irNo,
                                           Principal principal) {
        Map<String, Object> result = new HashMap<>();
        try {
            String brokerId = (principal != null) ? principal.getName() : null;
            if (brokerId == null) {
                result.put("success", false);
                result.put("message", "로그인이 필요합니다.");
                return result;
            }

            ImpRqstVO rqst = brokerDeclareService.findImpRqstById(brokerId, irNo);
            if (rqst == null) {
                result.put("success", false);
                result.put("message", "해당 통관의뢰번호를 찾을 수 없습니다.\n(존재하지 않거나 본인 담당 의뢰서가 아닙니다)");
                return result;
            }

            result.put("success", true);
            result.put("rqst",    rqst);
            result.put("message", "✅ 의뢰서를 불러왔습니다.");

        } catch (Exception e) {
            e.printStackTrace();
            result.put("success", false);
            result.put("message", "조회 실패: " + e.getMessage());
        }
        return result;
    }

    // ==========================================================
    // 의뢰서 검색 — 돋보기 모달 응답 (8C)
    // ==========================================================

    /**
     * URL  : GET /broker/declare/searchImpRqst.do?keyword=삼성
     * Resp : { success, list: [{...IMP_RQST...}, ...], count }
     *
     * 화면의 돋보기 모달이 호출 → 결과 list 를 받아 모달 테이블에 표시.
     */
    @GetMapping("/declare/searchImpRqst.do")
    @ResponseBody
    public Map<String, Object> searchImpRqst(@RequestParam(value = "keyword", required = false) String keyword,
                                             Principal principal) {
        Map<String, Object> result = new HashMap<>();
        try {
            String brokerId = (principal != null) ? principal.getName() : null;
            if (brokerId == null) {
                result.put("success", false);
                result.put("message", "로그인이 필요합니다.");
                return result;
            }

            java.util.List<ImpRqstVO> list = brokerDeclareService.findImpRqstList(brokerId, keyword);

            result.put("success", true);
            result.put("list",    list);
            result.put("count",   (list != null) ? list.size() : 0);

        } catch (Exception e) {
            e.printStackTrace();
            result.put("success", false);
            result.put("message", "검색 실패: " + e.getMessage());
        }
        return result;
    }
    
    
    @GetMapping("/declare/hsVector/embedSmallTest.do")
    @ResponseBody
    public Map<String, Object> embedSmallTest() {
        Map<String, Object> result = new HashMap<>();

        try {
            EmbeddingModel embeddingModel = embeddingModelProvider.getIfAvailable();

            if (embeddingModel == null) {
                result.put("success", false);
                result.put("message", "EmbeddingModel Bean을 찾을 수 없습니다.");
                return result;
            }

            // 아주 짧은 문장 1개만 테스트
            String text = "rice";

            EmbeddingResponse response =
                    embeddingModel.embedForResponse(List.of(text));

            int dimension = 0;

            if (response != null
                    && response.getResults() != null
                    && !response.getResults().isEmpty()
                    && response.getResults().get(0).getOutput() != null) {
                dimension = response.getResults().get(0).getOutput().length;
            }

            result.put("success", true);
            result.put("text", text);
            result.put("dimension", dimension);
            result.put("message", "작은 임베딩 테스트 성공");
            return result;

        } catch (Exception e) {
            e.printStackTrace();

            result.put("success", false);
            result.put("message", "작은 임베딩 테스트 실패: " + e.getMessage());
            return result;
        }
    }
    

    // ==========================================================
    // AI 자동 채움 — 첨부 PDF (Invoice/Packing/BL/Phyto) 종합 파싱 (10E)
    // ==========================================================

    /**
     * URL  : GET /broker/declare/aiParseImpRqst.do?irNo=IMP-20260502-901
     * Resp : { success, parsed: ImportDeclarationParsedDto, message }
     *
     * 의뢰서의 IR_TFG_NO 로 첨부 PDF 들을 조회 → Gemini 가 종합 파싱 →
     * 응답 받은 데이터를 화면에서 form 자동 채움.
     * DB 저장은 사용자 검토 후 [임시저장] 시 기존 흐름 그대로.
     */
    @GetMapping("/declare/aiParseImpRqst.do")
    @ResponseBody
    public Map<String, Object> aiParseImpRqst(@RequestParam("irNo") String irNo,
                                              Principal principal) {
        Map<String, Object> result = new HashMap<>();
        try {
            String brokerId = (principal != null) ? principal.getName() : null;
            if (brokerId == null) {
                result.put("success", false);
                result.put("message", "로그인이 필요합니다.");
                return result;
            }

            // 1) 본인 의뢰서 확인 + IR_TFG_NO 가져오기
            ImpRqstVO rqst = brokerDeclareService.findImpRqstById(brokerId, irNo);
            if (rqst == null) {
                result.put("success", false);
                result.put("message", "해당 의뢰번호를 찾을 수 없습니다.");
                return result;
            }
            if (rqst.getIrTfgNo() == null) {
                result.put("success", false);
                result.put("message", "이 의뢰서에는 첨부파일이 없습니다.");
                return result;
            }

            // 2) AI 파싱 (Gemini)
            ImportDeclarationParsedDto parsed =
                aiDocumentParserService.parseFromTfg(rqst.getIrTfgNo());

            if (parsed == null) {
                result.put("success", false);
                result.put("message", "AI 파싱에 실패했습니다. (PDF 파일이 없거나 읽을 수 없는 형식)");
                return result;
            }

            result.put("success", true);
            result.put("parsed",  parsed);
            result.put("message", "✅ AI 가 첨부 문서를 분석했습니다. 폼을 확인 후 저장하세요.");

        } catch (Exception e) {
            e.printStackTrace();
            result.put("success", false);
            result.put("message", "AI 파싱 실패: " + e.getMessage());
        }
        return result;
    }

    // ==========================================================
    // 수입신고서 전송 (TEMP → SUBMIT)
    // ==========================================================

    /**
     * URL  : POST /broker/declare/sendImp.do
     * Body : ImpDclrVO JSON (현재 폼 데이터)
     * Resp : { success, idIrNo, message }
     *
     * - 현재 폼 데이터를 마지막으로 저장 (insert/update) 한 뒤
     *   status_cd 를 SUBMIT 으로 변경. 트랜잭션 안에서 일괄 처리.
     * - 전송 후엔 임시문서함에서 사라지고, 임시저장 흐름으로는 더 수정 불가.
     */
    @PostMapping("/declare/sendImp.do")
    @ResponseBody
    public Map<String, Object> sendImp(@RequestBody ImpDclrVO vo, Principal principal) {
        Map<String, Object> result = new HashMap<>();
        try {
            String brokerId = (principal != null) ? principal.getName() : null;
            if (brokerId == null) {
                result.put("success", false);
                result.put("message", "로그인이 필요합니다.");
                return result;
            }

            if (vo.getIdImprNm() == null || vo.getIdImprNm().trim().isEmpty()) {
                result.put("success", false);
                result.put("message", "수입자 상호는 필수 입력값입니다.");
                return result;
            }

            String idIrNo = brokerDeclareService.sendImp(vo, brokerId);

            result.put("success", true);
            result.put("idIrNo",  idIrNo);
            result.put("message", "✅ 신고서 전송 완료\n통관의뢰번호: " + idIrNo);

        } catch (IllegalStateException e) {
            result.put("success", false);
            result.put("message", e.getMessage());
        } catch (Exception e) {
            e.printStackTrace();
            result.put("success", false);
            result.put("message", "전송 실패: " + e.getMessage());
        }
        return result;
    }
    
