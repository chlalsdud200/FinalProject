    }
    
    
    
    
    

    /**
     * HS AI추천 후보 조회
     * URL : POST /broker/declare/hsRecommend.do
     *
     * - 화면 보조 기능이므로 DB 저장 없음
     * - 로그인한 관세사만 사용 가능
     * - 기능 OFF / Milvus 없음 / 예외 발생 시에도 JSON으로 응답
     */
    @PostMapping(
    	    value = {"/declare/hsRecommend.do", "/declare/recommendHsCode.do"},
    	    consumes = "application/json",
    	    produces = "application/json"
    	)
    @ResponseBody
    public Map<String, Object> recommendHsCode(@RequestBody Map<String, Object> param,
                                               Principal principal) {
        Map<String, Object> result = new HashMap<>();

        try {
            String brokerId = (principal != null) ? principal.getName() : null;
            if (brokerId == null) {
                result.put("success", false);
                result.put("enabled", false);
                result.put("message", "로그인이 필요합니다.");
                return result;
            }

            if (!brokerDeclareService.isHsAiRecommendEnabled()) {
                result.put("success", false);
                result.put("enabled", false);
                result.put("list", java.util.Collections.emptyList());
                result.put("message", "HS AI추천 기능이 비활성화되어 있습니다.");
                return result;
            }

            param.put("brokerId", brokerId);

            List<Map<String, Object>> list = brokerDeclareService.recommendHsCode(param);

            result.put("success", true);
            result.put("enabled", true);
            result.put("list", list);
            result.put("message", "HS코드 추천 후보를 조회했습니다.");

        } catch (IllegalArgumentException e) {
            result.put("success", false);
            result.put("enabled", true);
            result.put("list", java.util.Collections.emptyList());
            result.put("message", e.getMessage());

        } catch (IllegalStateException e) {
            result.put("success", false);
            result.put("enabled", false);
            result.put("list", java.util.Collections.emptyList());
            result.put("message", e.getMessage());

        } catch (Exception e) {
            e.printStackTrace();
            result.put("success", false);
            result.put("enabled", true);
            result.put("list", java.util.Collections.emptyList());
            result.put("message", "HS AI추천 중 오류가 발생했습니다.");
        }

        return result;
    }
    
    
    /**
     * HS 벡터 재적재 테스트 API
     *
     * URL : POST /broker/declare/hsVector/reindex.do
     *
     * 주의:
     * - 개발/시연용 API
     * - 운영에서는 관리자 권한 또는 내부 배치로 분리하는 것이 안전함
     */
    @PostMapping(
        value = "/declare/hsVector/reindex.do",
        produces = "application/json"
    )
    @ResponseBody
    public Map<String, Object> reindexHsVector(Principal principal) {
        Map<String, Object> result = new HashMap<>();

        try {
            String brokerId = (principal != null) ? principal.getName() : null;

            if (brokerId == null) {
                result.put("success", false);
                result.put("count", 0);
                result.put("message", "로그인이 필요합니다.");
                return result;
            }

            return brokerDeclareService.reindexHsRecommendVector(brokerId);

        } catch (Exception e) {
            e.printStackTrace();

            result.put("success", false);
            result.put("count", 0);
            result.put("message", "HS 벡터 재적재 실패: " + e.getMessage());

            return result;
        }
    }
    
    
    
