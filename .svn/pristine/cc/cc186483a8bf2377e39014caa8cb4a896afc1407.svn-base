<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.common.notification.inbox.mapper.INotificationInboxMapper">

    <select id="selectUnreadSummary"
            resultType="kr.or.tacs.vo.common.notification.inbox.NotificationUnreadCountVO">
        SELECT
            COUNT(CASE WHEN noti_read_yn = 'N' THEN 1 END) AS count
          , TO_CHAR(MAX(CASE WHEN noti_read_yn = 'N' THEN noti_send_dt END), 'YYYY-MM-DD HH24:MI:SS') AS latest_send_dt
        FROM notification
        WHERE noti_receiver_id = #{receiverId}
    </select>

    <select id="selectInboxList"
            resultType="kr.or.tacs.vo.common.notification.inbox.NotificationInboxItemVO">
        SELECT
            n.noti_no
          , n.noti_event_cd
          , p.np_biz_nm
          , n.noti_title
          , n.noti_body
          , n.noti_link_url
          , n.noti_read_yn
          , TO_CHAR(n.noti_send_dt, 'YYYY-MM-DD HH24:MI:SS') AS noti_send_dt
        FROM notification n
        LEFT JOIN noti_policy p
            ON p.np_event_cd = n.noti_event_cd
        WHERE n.noti_receiver_id = #{receiverId}
        ORDER BY n.noti_no DESC
        OFFSET #{offset} ROWS FETCH NEXT #{limit} ROWS ONLY
    </select>

    <update id="updateRead">
        UPDATE notification
        SET noti_read_yn = 'Y'
          , noti_read_dt = SYSDATE
        WHERE noti_no = #{notiNo}
          AND noti_receiver_id = #{receiverId}
          AND noti_read_yn = 'N'
    </update>

    <update id="updateReadAll">
        UPDATE notification
        SET noti_read_yn = 'Y'
          , noti_read_dt = SYSDATE
        WHERE noti_receiver_id = #{receiverId}
          AND noti_read_yn = 'N'
    </update>

</mapper>