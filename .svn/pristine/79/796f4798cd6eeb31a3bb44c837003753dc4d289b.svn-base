<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.fieldofficer.inspection.mapper.IInspectionMapper">

	<!-- 검역 요청 조회 결과 매핑 -->
	<resultMap type="kr.or.tacs.vo.fieldofficer.Inspection.InspectionRequestVO" id="inspectionRequestMap">
		
		<!-- IMP_INS_REQ (수입검역요청) -->
		<id property="iirReqNo" column="IIR_REQ_NO"/>
		
		<result property="iirReqOfficerId" column="IIR_REQ_OFFICER_ID"/>
		<result property="iirQrtnOfficerId" column="IIR_QRTN_OFFICER_ID"/>
		<result property="iirAplyNo" column="IIR_APLY_NO"/>
		<result property="iirTfgNo" column="IIR_TFG_NO"/>

		<result property="iirExporterNm" column="IIR_EXPORTER_NM"/>
		<result property="iirExporterCompanyNm" column="IIR_EXPORTER_COMPANY_NM"/>
		<result property="iirExporterAdres" column="IIR_EXPORTER_ADRES"/>
		<result property="iirOriginCountryCd" column="IIR_ORIGIN_COUNTRY_CD"/>
		<result property="iirPhytoCertNo" column="IIR_PHYTO_CERT_NO"/>
		<result property="iirPhytoCertIssueDt" column="IIR_PHYTO_CERT_ISSUE_DT"/>
		
		<result property="iirTransportTypeCd" column="IIR_TRANSPORT_TYPE_CD"/>
		<result property="iirTransportNm" column="IIR_TRANSPORT_NM"/>
		<result property="iirLoadPortCd" column="IIR_LOAD_PORT_CD"/>
		<result property="iirShipDt" column="IIR_SHIP_DT"/>
		<result property="iirArrvPortCd" column="IIR_ARRV_PORT_CD"/>
		<result property="iirArrvDt" column="IIR_ARRV_DT"/>
		
		<result property="iirTotalPkgCnt" column="IIR_TOTAL_PKG_CNT"/>
		<result property="iirPkgUnitCd" column="IIR_PKG_UNIT_CD"/>
		<result property="iirTotalWeight" column="IIR_TOTAL_WEIGHT"/>
		<result property="iirPkgMaterial" column="IIR_PKG_MATERIAL"/>
		<result property="iirWoodPkgYn" column="IIR_WOOD_PKG_YN"/>
		<result property="iirWoodPkgMarkNo" column="IIR_WOOD_PKG_MARK_NO"/>
		<result property="iirMainGoodsNm" column="IIR_MAIN_GOODS_NM"/>
		<result property="iirMainHsCd" column="IIR_MAIN_HS_CD"/>
		<result property="iirExportCountryCd" column="IIR_EXPORT_COUNTRY_CD"/>
		<result property="iirJrsdRgnAgCd" column="IIR_JRSD_RGN_AG_CD"/>
		<result property="iirQrtnInstCd" column="IIR_QRTN_INST_CD"/>
		<result property="iirRsnCn" column="IIR_RSN_CN"/>
		<result property="iirStatusCd" column="IIR_STATUS_CD"/>
		<result property="iirDt" column="IIR_DT"/>
		<result property="iirAssignDt" column="IIR_ASSIGN_DT"/>
		<result property="iirRplyDdlineDt" column="IIR_RPLY_DDLINE_DT"/>
		<result property="iirCmplDt" column="IIR_CMPL_DT"/>
		<result property="iirRegistDt" column="IIR_REGIST_DT"/>
		<result property="iirUpdtDt" column="IIR_UPDT_DT"/>
		
		<!-- IMP_INS_LOC (수입검역위치) -->
		<result property="iilNo" column="IIL_NO"/>		
		<result property="iilReqNo" column="IIL_REQ_NO"/>		
		<result property="iilWilNo" column="IIL_WIL_NO"/>		
		<result property="iilTyCd" column="IIL_TY_CD"/>		
		<result property="iilNm" column="IIL_NM"/>		
		<result property="iilZip" column="IIL_ZIP"/>		
		<result property="iilAdres" column="IIL_ADRES"/>		
		<result property="iilDetailAdres" column="IIL_DETAIL_ADRES"/>		
		<result property="iilPlanDt" column="IIL_PLAN_DT"/>		
		<result property="iilRegistDt" column="IIL_REGIST_DT"/>		
		<result property="iilUpdtDt" column="IIL_UPDT_DT"/>	
			
		<!-- IMP_INS_RESULT (검역결과) -->
		<result property="iirResultStatusCd" column="IIR_RESULT_STATUS_CD"/>
		<result property="iirNo" column="IIR_NO"/>
		<result property="iirResultCd" column="IIR_RESULT_CD"/>
		<result property="iirResultCn" column="IIR_RESULT_CN"/>
		<result property="iirResultDt" column="IIR_RESULT_DT"/>
		
		<!-- 공통코드 화면 표시명 -->
		<result property="iirStatusNm" column="IIR_STATUS_NM"/>
		<result property="iirResultStatusNm" column="IIR_RESULT_STATUS_NM"/>
		<result property="iirResultNm" column="IIR_RESULT_NM"/>
		</resultMap>
		
		
		<!-- 검역 요청 전체 건수 조회 -->
		<select id="selectInspectionRequestCount" parameterType="kr.or.tacs.vo.common.PaginationInfoVO" resultType="int">
		
		    SELECT COUNT(*)
		    FROM IMP_INS_REQ R
		
		    LEFT JOIN IMP_INS_LOC L
		      ON R.IIR_REQ_NO = L.IIL_REQ_NO
		
		    LEFT JOIN WAREHOUSE_ITEM_LOCATION WIL
			    ON L.IIL_WIL_NO = WIL.WIL_NO
			
			LEFT JOIN WAREHOUSE_ZONE WZ
			    ON WIL.WIL_WH_ZONE_NO = WZ.WZ_NO
			
			LEFT JOIN WAREHOUSE WH
			    ON WZ.WZ_WH_NO = WH.WH_NO
			
			LEFT JOIN IMP_INS_RESULT RES
			    ON R.IIR_REQ_NO = RES.IIR_IMP_INS_REQ_NO
		
		    <where>
		    	<!-- 로그인한 현장공무원에게 배정된 검역요청만 조회 -->
			    <if test="searchDTO.iirQrtnOfficerId != null and searchDTO.iirQrtnOfficerId != ''">
			        AND R.IIR_QRTN_OFFICER_ID = #{searchDTO.iirQrtnOfficerId}
			    </if>
			
			    <if test="searchDTO.iirReqNo != null and searchDTO.iirReqNo != ''">
			        AND R.IIR_REQ_NO LIKE '%' || #{searchDTO.iirReqNo} || '%'
			    </if>
		    
		        <if test="searchDTO.iirReqNo != null and searchDTO.iirReqNo != ''">
		            AND R.IIR_REQ_NO LIKE '%' || #{searchDTO.iirReqNo} || '%'
		        </if>
		
		        <if test="searchDTO.iirAplyNo != null and searchDTO.iirAplyNo != ''">
		             AND R.IR_NO LIKE '%' || #{searchDTO.iirAplyNo} || '%'
		        </if>
		        
		        <if test="searchDTO.iirMainGoodsNm != null and searchDTO.iirMainGoodsNm != ''">
				    AND R.IIR_MAIN_GOODS_NM LIKE '%' || #{searchDTO.iirMainGoodsNm} || '%'
				</if>
				
				<if test="searchDTO.iirMainHsCd != null and searchDTO.iirMainHsCd != ''">
				    AND R.IIR_MAIN_HS_CD LIKE '%' || #{searchDTO.iirMainHsCd} || '%'
				</if>
		
		        <if test="searchDTO.iilNm != null and searchDTO.iilNm != ''">
		           AND NVL(WH.WH_NM, L.IIL_NM) LIKE '%' || #{searchDTO.iilNm} || '%'
		        </if>
		
		        <if test="searchDTO.iirQrtnInstCd != null and searchDTO.iirQrtnInstCd != ''">
		            AND R.IIR_QRTN_INST_CD LIKE '%' || #{searchDTO.iirQrtnInstCd} || '%'
		        </if>
		
		        <if test="searchDTO.iirStatusCd != null and searchDTO.iirStatusCd != ''">
		            AND R.IIR_STATUS_CD = #{searchDTO.iirStatusCd}
		        </if>
		
		        <if test="searchDTO.iirResultStatusCd != null and searchDTO.iirResultStatusCd != ''">
				    AND NVL(RES.IIR_RESULT_STATUS_CD, 'QRTN_INPRG') = #{searchDTO.iirResultStatusCd}
				</if>
		        
		        <if test="searchDTO.rplyDdlineStartDt != null and searchDTO.rplyDdlineStartDt != ''">
				    AND TRUNC(R.IIR_RPLY_DDLINE_DT) &gt;= TO_DATE(#{searchDTO.rplyDdlineStartDt}, 'YYYY-MM-DD')
				</if>
				
				<if test="searchDTO.rplyDdlineEndDt != null and searchDTO.rplyDdlineEndDt != ''">
				    AND TRUNC(R.IIR_RPLY_DDLINE_DT) &lt;= TO_DATE(#{searchDTO.rplyDdlineEndDt}, 'YYYY-MM-DD')
				</if>
		    </where>
		
		</select>
		
		<!-- 검역 요청 목록 조회 -->
		<select id="retriveInspectionRequestList" parameterType="kr.or.tacs.vo.common.PaginationInfoVO" resultMap="inspectionRequestMap">
		
		    SELECT *
		    FROM (
		        SELECT A.*, ROWNUM AS RN
		        FROM (
		            SELECT
		                R.IIR_REQ_NO,
		                NULL AS IIR_REQ_OFFICER_ID,
						R.IIR_QRTN_OFFICER_ID,
						R.IR_NO AS IIR_APLY_NO,
						R.IIR_MAIN_GOODS_NM,
						R.IIR_MAIN_HS_CD,
						R.IIR_EXPORT_COUNTRY_CD,
		                R.IIR_JRSD_RGN_AG_CD,
		                R.IIR_QRTN_INST_CD,
		                R.IIR_RSN_CN,
		                R.IIR_STATUS_CD,
		                TO_CHAR(R.IIR_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIR_DT,
		                TO_CHAR(R.IIR_ASSIGN_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIR_ASSIGN_DT,
		                TO_CHAR(R.IIR_RPLY_DDLINE_DT, 'YYYY-MM-DD') AS IIR_RPLY_DDLINE_DT,
		                TO_CHAR(R.IIR_CMPL_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIR_CMPL_DT,
		                TO_CHAR(R.IIR_REGIST_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIR_REGIST_DT,
		                TO_CHAR(R.IIR_UPDT_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIR_UPDT_DT,
		
		                L.IIL_NO,
						L.IIL_REQ_NO,
						L.IIL_WIL_NO,
						L.IIL_TY_CD,
						
						NVL(WH.WH_NM, L.IIL_NM) AS IIL_NM,
						NVL(WH.WH_ZIP, L.IIL_ZIP) AS IIL_ZIP,
						NVL(WH.WH_ADRES, L.IIL_ADRES) AS IIL_ADRES,
						NVL(WH.WH_DETAIL_ADRES, L.IIL_DETAIL_ADRES) AS IIL_DETAIL_ADRES,
						
						TO_CHAR(L.IIL_PLAN_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIL_PLAN_DT,
						TO_CHAR(L.IIL_REGIST_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIL_REGIST_DT,
						TO_CHAR(L.IIL_UPDT_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIL_UPDT_DT,
		
		                NVL(RES.IIR_RESULT_STATUS_CD, 'QRTN_INPRG') AS IIR_RESULT_STATUS_CD,

						REQ_STATUS_CC.CC_NM AS IIR_STATUS_NM,
						NVL(RESULT_STATUS_CC.CC_NM, '검역진행중') AS IIR_RESULT_STATUS_NM,
						RESULT_CC.CC_NM AS IIR_RESULT_NM
		
		            FROM IMP_INS_REQ R
		
		            LEFT JOIN IMP_INS_LOC L
					    ON R.IIR_REQ_NO = L.IIL_REQ_NO
					
					LEFT JOIN WAREHOUSE_ITEM_LOCATION WIL
					    ON L.IIL_WIL_NO = WIL.WIL_NO
					
					LEFT JOIN WAREHOUSE_ZONE WZ
					    ON WIL.WIL_WH_ZONE_NO = WZ.WZ_NO
					
					LEFT JOIN WAREHOUSE WH
					    ON WZ.WZ_WH_NO = WH.WH_NO
					
					LEFT JOIN IMP_INS_RESULT RES
					    ON R.IIR_REQ_NO = RES.IIR_IMP_INS_REQ_NO
					    
					LEFT JOIN COM_CODE REQ_STATUS_CC
					    ON REQ_STATUS_CC.CC_CCG_ID = 'QRTN_REQ_STATUS'
					   AND REQ_STATUS_CC.CC_CD = R.IIR_STATUS_CD
					
					LEFT JOIN COM_CODE RESULT_STATUS_CC
					    ON RESULT_STATUS_CC.CC_CCG_ID = 'QRTN_RESULT_STATUS'
					   AND RESULT_STATUS_CC.CC_CD = NVL(RES.IIR_RESULT_STATUS_CD, 'QRTN_INPRG')
					
					LEFT JOIN COM_CODE RESULT_CC
					    ON RESULT_CC.CC_CCG_ID = 'QRTN_RESULT_CD'
					   AND RESULT_CC.CC_CD = RES.IIR_RESULT_CD
		
		            <where>
		            	<!-- 로그인한 현장공무원에게 배정된 검역요청만 조회 -->
					    <if test="searchDTO.iirQrtnOfficerId != null and searchDTO.iirQrtnOfficerId != ''">
					        AND R.IIR_QRTN_OFFICER_ID = #{searchDTO.iirQrtnOfficerId}
					    </if>
					
					    <if test="searchDTO.iirReqNo != null and searchDTO.iirReqNo != ''">
					        AND R.IIR_REQ_NO LIKE '%' || #{searchDTO.iirReqNo} || '%'
					    </if>
		            
		                <if test="searchDTO.iirReqNo != null and searchDTO.iirReqNo != ''">
		                    AND R.IIR_REQ_NO LIKE '%' || #{searchDTO.iirReqNo} || '%'
		                </if>
		
		                <if test="searchDTO.iirAplyNo != null and searchDTO.iirAplyNo != ''">
		                    AND R.IR_NO LIKE '%' || #{searchDTO.iirAplyNo} || '%'
		                </if>
		                
		                <if test="searchDTO.iirMainGoodsNm != null and searchDTO.iirMainGoodsNm != ''">
						    AND R.IIR_MAIN_GOODS_NM LIKE '%' || #{searchDTO.iirMainGoodsNm} || '%'
						</if>
						
						<if test="searchDTO.iirMainHsCd != null and searchDTO.iirMainHsCd != ''">
						    AND R.IIR_MAIN_HS_CD LIKE '%' || #{searchDTO.iirMainHsCd} || '%'
						</if>
		
		                <if test="searchDTO.iilNm != null and searchDTO.iilNm != ''">
		                    AND NVL(WH.WH_NM, L.IIL_NM) LIKE '%' || #{searchDTO.iilNm} || '%'
		                </if>
		
		                <if test="searchDTO.iirQrtnInstCd != null and searchDTO.iirQrtnInstCd != ''">
		                    AND R.IIR_QRTN_INST_CD LIKE '%' || #{searchDTO.iirQrtnInstCd} || '%'
		                </if>
		
		                <if test="searchDTO.iirStatusCd != null and searchDTO.iirStatusCd != ''">
		                    AND R.IIR_STATUS_CD = #{searchDTO.iirStatusCd}
		                </if>
		
		                <if test="searchDTO.iirResultStatusCd != null and searchDTO.iirResultStatusCd != ''">
						    AND NVL(RES.IIR_RESULT_STATUS_CD, 'QRTN_INPRG') = #{searchDTO.iirResultStatusCd}
						</if>
		                
		                <if test="searchDTO.rplyDdlineStartDt != null and searchDTO.rplyDdlineStartDt != ''">
						    AND TRUNC(R.IIR_RPLY_DDLINE_DT) &gt;= TO_DATE(#{searchDTO.rplyDdlineStartDt}, 'YYYY-MM-DD')
						</if>
						
						<if test="searchDTO.rplyDdlineEndDt != null and searchDTO.rplyDdlineEndDt != ''">
						    AND TRUNC(R.IIR_RPLY_DDLINE_DT) &lt;= TO_DATE(#{searchDTO.rplyDdlineEndDt}, 'YYYY-MM-DD')
						</if>
		                
		            </where>
		
		            ORDER BY R.IIR_DT DESC
		        ) A
		        WHERE ROWNUM <![CDATA[<=]]> #{endRow}
		    )
		    WHERE RN <![CDATA[>=]]> #{startRow}
		
		</select>
	
	
	    <!-- 검역 요청 상세 조회 -->
		<select id="selectInspectionRequest" resultMap="inspectionRequestMap">
		    SELECT
		        R.IIR_REQ_NO,
		        NULL AS IIR_REQ_OFFICER_ID,
		        R.IIR_QRTN_OFFICER_ID,
		        R.IR_NO AS IIR_APLY_NO,
		        R.IIR_TFG_NO,
		
		        R.IIR_MAIN_GOODS_NM,
		        R.IIR_MAIN_HS_CD,
		        R.IIR_EXPORT_COUNTRY_CD,
		        R.IIR_ORIGIN_COUNTRY_CD,
		
		        R.IIR_EXPORTER_NM,
		        R.IIR_EXPORTER_COMPANY_NM,
		        R.IIR_EXPORTER_ADRES,
		
		        R.IIR_PHYTO_CERT_NO,
		        TO_CHAR(R.IIR_PHYTO_CERT_ISSUE_DT, 'YYYY-MM-DD') AS IIR_PHYTO_CERT_ISSUE_DT,
		
		        R.IIR_TRANSPORT_TYPE_CD,
		        R.IIR_TRANSPORT_NM,
		        R.IIR_LOAD_PORT_CD,
		        TO_CHAR(R.IIR_SHIP_DT, 'YYYY-MM-DD') AS IIR_SHIP_DT,
		        R.IIR_ARRV_PORT_CD,
		        TO_CHAR(R.IIR_ARRV_DT, 'YYYY-MM-DD') AS IIR_ARRV_DT,
		
		        R.IIR_TOTAL_PKG_CNT,
		        R.IIR_PKG_UNIT_CD,
		        R.IIR_TOTAL_WEIGHT,
		        R.IIR_PKG_MATERIAL,
		        R.IIR_WOOD_PKG_YN,
		        R.IIR_WOOD_PKG_MARK_NO,
		
		        R.IIR_JRSD_RGN_AG_CD,
		        R.IIR_QRTN_INST_CD,
		        R.IIR_RSN_CN,
		        R.IIR_STATUS_CD,
		        TO_CHAR(R.IIR_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIR_DT,
		        TO_CHAR(R.IIR_ASSIGN_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIR_ASSIGN_DT,
		        TO_CHAR(R.IIR_RPLY_DDLINE_DT, 'YYYY-MM-DD') AS IIR_RPLY_DDLINE_DT,
		        TO_CHAR(R.IIR_CMPL_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIR_CMPL_DT,
		        TO_CHAR(R.IIR_REGIST_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIR_REGIST_DT,
		        TO_CHAR(R.IIR_UPDT_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIR_UPDT_DT,
		
		        L.IIL_NO,
				L.IIL_REQ_NO,
				L.IIL_WIL_NO,
				L.IIL_TY_CD,
				
				NVL(WH.WH_NM, L.IIL_NM) AS IIL_NM,
				NVL(WH.WH_ZIP, L.IIL_ZIP) AS IIL_ZIP,
				NVL(WH.WH_ADRES, L.IIL_ADRES) AS IIL_ADRES,
				NVL(WH.WH_DETAIL_ADRES, L.IIL_DETAIL_ADRES) AS IIL_DETAIL_ADRES,
				
				TO_CHAR(L.IIL_PLAN_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIL_PLAN_DT,
				TO_CHAR(L.IIL_REGIST_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIL_REGIST_DT,
				TO_CHAR(L.IIL_UPDT_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIL_UPDT_DT,
		
		        RES.IIR_NO,
		        NVL(RES.IIR_RESULT_STATUS_CD, 'QRTN_INPRG') AS IIR_RESULT_STATUS_CD,
				RES.IIR_RESULT_CD,
				
				REQ_STATUS_CC.CC_NM AS IIR_STATUS_NM,
				NVL(RESULT_STATUS_CC.CC_NM, '검역진행중') AS IIR_RESULT_STATUS_NM,
				RESULT_CC.CC_NM AS IIR_RESULT_NM,
		        RES.IIR_RESULT_CN,
		        TO_CHAR(RES.IIR_RESULT_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIR_RESULT_DT
		
		    FROM IMP_INS_REQ R
		
		    LEFT JOIN IMP_INS_LOC L
			    ON R.IIR_REQ_NO = L.IIL_REQ_NO
			
			LEFT JOIN WAREHOUSE_ITEM_LOCATION WIL
			    ON L.IIL_WIL_NO = WIL.WIL_NO
			
			LEFT JOIN WAREHOUSE_ZONE WZ
			    ON WIL.WIL_WH_ZONE_NO = WZ.WZ_NO
			
			LEFT JOIN WAREHOUSE WH
			    ON WZ.WZ_WH_NO = WH.WH_NO
			
			LEFT JOIN IMP_INS_RESULT RES
			    ON R.IIR_REQ_NO = RES.IIR_IMP_INS_REQ_NO
			    
			LEFT JOIN COM_CODE REQ_STATUS_CC
			    ON REQ_STATUS_CC.CC_CCG_ID = 'QRTN_REQ_STATUS'
			   AND REQ_STATUS_CC.CC_CD = R.IIR_STATUS_CD
			
			LEFT JOIN COM_CODE RESULT_STATUS_CC
			    ON RESULT_STATUS_CC.CC_CCG_ID = 'QRTN_RESULT_STATUS'
			   AND RESULT_STATUS_CC.CC_CD = NVL(RES.IIR_RESULT_STATUS_CD, 'QRTN_INPRG')
			
			LEFT JOIN COM_CODE RESULT_CC
			    ON RESULT_CC.CC_CCG_ID = 'QRTN_RESULT_CD'
			   AND RESULT_CC.CC_CD = RES.IIR_RESULT_CD
		
		    WHERE R.IIR_REQ_NO = #{reqNo}
		</select>
		
		
		<!-- 검역 요청 상세 - 품목 목록 매핑 -->
		<resultMap type="kr.or.tacs.vo.fieldofficer.Inspection.InspectionRequestItemVO" id="inspectionItemMap">
		
		    <result property="iiriSn" column="IIRI_SN"/>
		    <result property="iiriReqNo" column="IIRI_REQ_NO"/>
		    <result property="iiriHsCd" column="IIRI_HS_CD"/>
		    <result property="iiriGoodsNm" column="IIRI_GOODS_NM"/>
		    <result property="iiriScientificNm" column="IIRI_SCIENTIFIC_NM"/>
		    <result property="iiriUseCd" column="IIRI_USE_CD"/>
		    <result property="iiriQty" column="IIRI_QTY"/>
		    <result property="iiriQtyUnitCd" column="IIRI_QTY_UNIT_CD"/>
		    <result property="iiriNetWeight" column="IIRI_NET_WEIGHT"/>
		    <result property="iiriPkgCnt" column="IIRI_PKG_CNT"/>
		    <result property="iiriPkgUnitCd" column="IIRI_PKG_UNIT_CD"/>
		    <result property="iiriOriginCountryCd" column="IIRI_ORIGIN_COUNTRY_CD"/>
		    <result property="iiriRegistDt" column="IIRI_REGIST_DT"/>
		
		</resultMap>
		
		
		<!-- 검역 요청 상세 - 품목 목록 조회 -->
		<select id="selectInspectionItemList" parameterType="string" resultMap="inspectionItemMap">
		
		    SELECT
		        IIRI_SN,
		        IIRI_REQ_NO,
		        IIRI_HS_CD,
		        IIRI_GOODS_NM,
		        IIRI_SCIENTIFIC_NM,
		        IIRI_USE_CD,
		        TO_CHAR(IIRI_QTY) AS IIRI_QTY,
		        IIRI_QTY_UNIT_CD,
		        TO_CHAR(IIRI_NET_WEIGHT) AS IIRI_NET_WEIGHT,
		        TO_CHAR(IIRI_PKG_CNT) AS IIRI_PKG_CNT,
		        IIRI_ORIGIN_COUNTRY_CD,
		        TO_CHAR(IIRI_REGIST_DT, 'YYYY-MM-DD HH24:MI:SS') AS IIRI_REGIST_DT
		    FROM IMP_INS_REQ_ITEM
		    WHERE IIRI_REQ_NO = #{reqNo}
		    ORDER BY IIRI_SN
		
		</select>
		
		
		<!-- 검역 요청 첨부서류 매핑 -->
		<resultMap type="kr.or.tacs.vo.fieldofficer.Inspection.InspectionFileVO" id="inspectionFileMap">
			<!-- DOCS_FILE_DATA.DFI_FILE_NO 파일 식별번호 -->
		    <result property="dfiFileNo" column="DFI_FILE_NO"/>
		
		    <!-- IMP_INS_REQ.IIR_TFG_NO 파일그룹번호 -->
		    <result property="tfgNo" column="TFG_NO"/>
		
		    <!-- 사용자가 업로드한 원본 파일명 -->
		    <result property="dfiOrgNm" column="DFI_ORG_NM"/>
		
		    <!-- 서버에 저장된 실제 파일명 -->
		    <result property="dfiStrNm" column="DFI_STR_NM"/>
		
		    <!-- 파일 크기 Byte -->
		    <result property="dfiSize" column="DFI_SIZE"/>
		
		    <!-- 화면 표시용 파일 크기 -->
		    <result property="fileSizeText" column="FILE_SIZE_TEXT"/>
		
		    <!-- 실제 파일 저장 경로 -->
		    <result property="dfiPath" column="DFI_PATH"/>
		
		    <!-- 삭제 여부 -->
		    <result property="dfiDelYn" column="DFI_DEL_YN"/>
		
		    <!-- 업무 파일 구분값 -->
		    <result property="dfiBizTyCd" column="DFI_BIZ_TY_CD"/>
		
		    <!-- 파일 등록일시 -->
		    <result property="dfiRegistDt" column="DFI_REGIST_DT"/>
		</resultMap>		
		
		<!-- 검역 요청 상세 - 첨부서류 목록 조회 -->
		<select id="selectInspectionFileList" parameterType="string" resultMap="inspectionFileMap">
		
		    SELECT
		        /* 파일번호 */
		        F.DFI_FILE_NO,
		
		        /* 파일그룹번호 */
		        R.IIR_TFG_NO AS TFG_NO,
		
		        /* 원본 파일명 */
		        F.DFI_ORG_NM,
		
		        /* 서버 저장 파일명 */
		        F.DFI_STR_NM,
		
		        /* 파일 크기 */
		        F.DFI_SIZE,
		
		        /* 화면 표시용 파일 크기 */
		        CASE
		            WHEN F.DFI_SIZE >= 1048576
		                THEN ROUND(F.DFI_SIZE / 1048576, 1) || ' MB'
		            WHEN F.DFI_SIZE >= 1024
		                THEN ROUND(F.DFI_SIZE / 1024, 1) || ' KB'
		            ELSE F.DFI_SIZE || ' B'
		        END AS FILE_SIZE_TEXT,
		
		        /* 실제 저장 경로 */
		        F.DFI_PATH,
		
		        /* 삭제 여부 */
		        F.DFI_DEL_YN,
		
		        /* 파일 업무 구분 */
		        F.DFI_BIZ_TY_CD,
		
		        /* 등록일시 */
		        TO_CHAR(F.DFI_REGIST_DT, 'YYYY-MM-DD HH24:MI:SS') AS DFI_REGIST_DT
		
		    FROM IMP_INS_REQ R
		
		    INNER JOIN TACS_FILE_MAP M
		        ON R.IIR_TFG_NO = M.TFM_TFG_NO
		
		    INNER JOIN DOCS_FILE_DATA F
		        ON M.TFM_DFI_NO = F.DFI_FILE_NO
		
		    WHERE R.IIR_REQ_NO = #{reqNo}
		      AND F.DFI_DEL_YN = 'N'
		
		    ORDER BY F.DFI_REGIST_DT DESC, F.DFI_FILE_NO DESC
		
		</select>
		
		<!-- 검역 요청 첨부서류 다운로드용 단건 조회 -->
		<select id="selectInspectionFile" parameterType="int" resultMap="inspectionFileMap">
		
		    SELECT
		        /* 파일번호 */
		        F.DFI_FILE_NO,
		
		        /* 단건 다운로드에서는 파일그룹번호가 꼭 필요하지 않으므로 NULL 처리 */
		        NULL AS TFG_NO,
		
		        /* 원본 파일명 */
		        F.DFI_ORG_NM,
		
		        /* 서버 저장 파일명 */
		        F.DFI_STR_NM,
		
		        /* 파일 크기 */
		        F.DFI_SIZE,
		
		        /* 화면 표시용 파일 크기 */
		        CASE
		            WHEN F.DFI_SIZE >= 1048576
		                THEN ROUND(F.DFI_SIZE / 1048576, 1) || ' MB'
		            WHEN F.DFI_SIZE >= 1024
		                THEN ROUND(F.DFI_SIZE / 1024, 1) || ' KB'
		            ELSE F.DFI_SIZE || ' B'
		        END AS FILE_SIZE_TEXT,
		
		        /* 실제 파일 저장 경로 */
		        F.DFI_PATH,
		
		        /* 삭제 여부 */
		        F.DFI_DEL_YN,
		
		        /* 파일 업무 구분 */
		        F.DFI_BIZ_TY_CD,
		
		        /* 등록일시 */
		        TO_CHAR(F.DFI_REGIST_DT, 'YYYY-MM-DD HH24:MI:SS') AS DFI_REGIST_DT
		
		    FROM DOCS_FILE_DATA F
		
		    WHERE F.DFI_FILE_NO = #{fileNo}
		      AND F.DFI_DEL_YN = 'N'
		
		</select>
	

</mapper>
