<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.officer.dash.mapper.IDashMapper">

    <!-- 접수대기 건수 (전체 - 수입 + 수출) -->
    <select id="selectReceiptWaitCount" resultType="int">
        SELECT COUNT(*) FROM (
            SELECT ID_IR_NO
              FROM IMP_DCLR ID
              JOIN IMP_RQST IR ON ID.ID_IR_NO = IR.IR_NO
             WHERE ID.ID_STATUS_CD IN ('DCLR_WAIT', 'CSTM_REJ')
               AND IR.IR_USE_YN = 'Y'
            UNION ALL
            SELECT ED_ER_NO
              FROM EXP_DCLR ED
              JOIN EXP_RQST ER ON ED.ED_ER_NO = ER.ER_NO
             WHERE ED.ED_STATUS_CD IN ('DCLR_WAIT', 'BASIC_WAIT', 'CSTM_REJ')
               AND ER.ER_USE_YN = 'Y'
        )
    </select>

    <!-- 심사중 건수 (내 담당 - 수입 + 수출) -->
    <select id="selectReviewCount" resultType="int">
        SELECT COUNT(*) FROM (
            SELECT ID_IR_NO
              FROM IMP_DCLR
             WHERE ID_STATUS_CD = 'DCLR_REVIEW'
               AND ID_OFFICER_ID = #{officerId}
            UNION ALL
            SELECT ED_ER_NO
              FROM EXP_DCLR
             WHERE ED_STATUS_CD = 'DCLR_REVIEW'
               AND OFFICER_ID = #{officerId}
        )
    </select>

    <!-- 보완요청 건수 (내 담당 - 수입 + 수출) -->
    <select id="selectSupplementCount" resultType="int">
        SELECT COUNT(*) FROM (
            SELECT ID_IR_NO
              FROM IMP_DCLR
             WHERE ID_STATUS_CD = 'DCLR_SUPP_REQ'
               AND ID_OFFICER_ID = #{officerId}
            UNION ALL
            SELECT ED_ER_NO
              FROM EXP_DCLR
             WHERE ED_STATUS_CD = 'DCLR_SUPP_REQ'
               AND OFFICER_ID = #{officerId}
        )
    </select>

    <!-- 납부대기 건수 (내 담당) -->
    <select id="selectTaxWaitCount" resultType="int">
        SELECT COUNT(*)
          FROM CUSTOMS_TAX CT
          JOIN IMP_DCLR ID ON CT.CT_STTEMNT_ID = ID.ID_IR_NO
         WHERE CT.CT_PAY_STATUS_CD = 'TAX_UNPAID'
           AND ID.ID_OFFICER_ID = #{officerId}
    </select>

    <!-- 신규 신고접수 목록 (접수대기 - 수입 + 수출) -->
    <select id="selectNewReceiptList" resultType="kr.or.tacs.dto.officer.DashboardDTO">
        SELECT *
          FROM (
            SELECT
                ID.ID_IR_NO                                                          AS reqNo,
                '수입'                                                               AS declareType,
                NVL(ID.ID_IMPR_NM, IR.IR_OWR_ID)                                    AS companyName,
                (
                    SELECT IDI.IDI_DCLR_GDSNM
                      FROM IMP_DCLR_ITEM IDI
                     WHERE IDI.IDI_IR_NO = ID.ID_IR_NO
                       AND ROWNUM = 1
                )                                                                    AS itemName,
                TO_CHAR(NVL(ID.ID_DCLR_DT, ID.ID_REGIST_DT), 'YYYY-MM-DD HH24:MI') AS requestDate
              FROM IMP_DCLR ID
              JOIN IMP_RQST IR ON ID.ID_IR_NO = IR.IR_NO
             WHERE ID.ID_STATUS_CD IN ('DCLR_WAIT', 'CSTM_REJ')
               AND IR.IR_USE_YN = 'Y'
               AND TRUNC(NVL(ID.ID_DCLR_DT, ID.ID_REGIST_DT)) >= TRUNC(SYSDATE) - 1

            UNION ALL

            SELECT
                ED.ED_ER_NO                                                              AS reqNo,
                '수출'                                                                   AS declareType,
                NVL(ER.ER_ONER_NM, ER.ER_OWR_ID)                                        AS companyName,
                (
                    SELECT EDI.EDI_EXPT_GDS_NM
                      FROM EXP_DCLR_ITEM EDI
                     WHERE EDI.EDI_ER_NO = ED.ED_ER_NO
                       AND ROWNUM = 1
                )                                                                        AS itemName,
                TO_CHAR(NVL(ED.ED_DCLR_DT, ER.ER_REGIST_DT), 'YYYY-MM-DD HH24:MI')    AS requestDate
              FROM EXP_DCLR ED
              JOIN EXP_RQST ER ON ED.ED_ER_NO = ER.ER_NO
             WHERE ED.ED_STATUS_CD IN ('DCLR_WAIT', 'BASIC_WAIT', 'CSTM_REJ')
               AND ER.ER_USE_YN = 'Y'
          )
         ORDER BY requestDate DESC NULLS LAST
    </select>

    <!-- 대시보드 업무알림 목록 -->
    <select id="selectDashboardAlertList" resultType="kr.or.tacs.dto.officer.DashboardDTO">
        SELECT *
          FROM (
                /* 보완제출 도착: 행정공무원이 요청한 보완건에 관세사가 답변 제출 */
                SELECT
                    REGEXP_SUBSTR(S.SR_REF_NO, '^(IMP|EXP)-[0-9]{8}-[0-9]+') AS reqNo,
                    '보완제출 도착' AS declareType,
                    NVL(IMP_OWNER.OWNER_NAME, EXP_OWNER.OWNER_NAME) AS companyName,
                    '보완제출 내용을 확인해야 합니다.' AS itemName,
                    TO_CHAR(NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT), 'YYYY-MM-DD HH24:MI') AS requestDate,
                    NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) AS sortDate
                  FROM SUPP_RQST S
                  LEFT JOIN (
                        SELECT ID.ID_IR_NO AS REQ_NO,
                               NVL(ID.ID_IMPR_NM, IR.IR_OWR_ID) AS OWNER_NAME
                          FROM IMP_DCLR ID
                          LEFT JOIN IMP_RQST IR ON IR.IR_NO = ID.ID_IR_NO
                  ) IMP_OWNER
                    ON IMP_OWNER.REQ_NO = REGEXP_SUBSTR(S.SR_REF_NO, '^IMP-[0-9]{8}-[0-9]+')
                  LEFT JOIN (
                        SELECT ED.ED_ER_NO AS REQ_NO,
                               NVL(ER.ER_ONER_NM, ER.ER_OWR_ID) AS OWNER_NAME
                          FROM EXP_DCLR ED
                          LEFT JOIN EXP_RQST ER ON ER.ER_NO = ED.ED_ER_NO
                  ) EXP_OWNER
                    ON EXP_OWNER.REQ_NO = REGEXP_SUBSTR(S.SR_REF_NO, '^EXP-[0-9]{8}-[0-9]+')
                 WHERE S.SR_STATUS_CD = 'SUB'
                   AND S.SENDER_ID = #{officerId}

                UNION ALL

                /* 세금납부완료 + 아직 필증 미발급: 행정공무원이 승인 및 필증발급해야 하는 건 */
                SELECT
                    ID.ID_IR_NO AS reqNo,
                    '필증발급 가능' AS declareType,
                    NVL(ID.ID_IMPR_NM, IR.IR_OWR_ID) AS companyName,
                    '세금납부가 완료되었습니다. 승인 및 필증발급이 가능합니다.' AS itemName,
                    TO_CHAR(NVL(CTP.PAY_DT, CT.CT_CRT_DT), 'YYYY-MM-DD HH24:MI') AS requestDate,
                    NVL(CTP.PAY_DT, CT.CT_CRT_DT) AS sortDate
                  FROM CUSTOMS_TAX CT
                  JOIN IMP_DCLR ID
                    ON ID.ID_IR_NO = CT.CT_STTEMNT_ID
                  LEFT JOIN IMP_RQST IR
                    ON IR.IR_NO = ID.ID_IR_NO
                  LEFT JOIN (
                        SELECT CTP_TAX_NO, MAX(CTP_DT) AS PAY_DT
                          FROM CUSTOMS_TAX_PAY
                         WHERE CTP_STATUS_CD = 'TAX_PAID'
                         GROUP BY CTP_TAX_NO
                  ) CTP
                    ON CTP.CTP_TAX_NO = CT.CT_NO
                 WHERE CT.CT_PAY_STATUS_CD = 'TAX_PAID'
                   AND ID.ID_OFFICER_ID = #{officerId}
                   AND NOT EXISTS (
                        SELECT 1
                          FROM CERT_INSURANCE CI
                         WHERE CI.CI_DCLR_NO = ID.ID_IR_NO
                   )
          )
         WHERE reqNo IS NOT NULL
         ORDER BY sortDate DESC NULLS LAST
         FETCH FIRST 5 ROWS ONLY
    </select>

</mapper>