// loadedCargoList.js - 적재화물목록 / 혼재화물 적하목록 조회 전용
(function () {
  'use strict';

  function text(value) {
    return value && String(value).trim() ? String(value).trim() : '-';
  }

  function setText(id, value) {
    var el = document.getElementById(id);
    if (el) el.textContent = text(value);
  }

  function escapeHtml(value) {
    return text(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function getMemoKey(row) {
    var type = row.dataset.type || 'loading';
    var keyNo = row.dataset.reqNo || row.dataset.listNo || row.dataset.blNo || row.dataset.mblNo || row.rowIndex;
    return 'loadedCargoMemo:' + type + ':' + keyNo;
  }

  function getActiveColspan(row) {
    var table = row.closest('table');
    if (!table) return 1;
    var thCount = table.querySelectorAll('thead th').length;
    return thCount || row.children.length || 1;
  }

  function removeDetailRow() {
    var detailRow = document.getElementById('cargo-detail-inline-row');
    if (detailRow) detailRow.remove();
  }

  function hideDetail() {
    var panel = document.getElementById('cargo-list-detail-panel');
    if (panel) {
      panel.style.display = 'none';
      document.querySelector('.inline-screen-body').appendChild(panel);
    }

    removeDetailRow();

    document.querySelectorAll('.cargo-click-row').forEach(function (r) {
      r.classList.remove('row-selected');
    });
  }

  function setCargoListTab(key, btn) {
    document.querySelectorAll('[data-tab-group="cargo-list-type"]').forEach(function (b) {
      b.classList.remove('active');
    });
    if (btn) btn.classList.add('active');

    document.querySelectorAll('[data-panel-group="cargo-list-type"]').forEach(function (p) {
      p.style.display = p.dataset.panelKey === key ? 'block' : 'none';
    });

    hideDetail();
  }

  function createInlineDetailRow(row, panel) {
    removeDetailRow();

    var detailRow = document.createElement('tr');
    detailRow.id = 'cargo-detail-inline-row';
    detailRow.className = 'cargo-detail-inline-row';

    var detailCell = document.createElement('td');
    detailCell.colSpan = getActiveColspan(row);
    detailCell.className = 'cargo-detail-inline-cell';

    detailCell.appendChild(panel);
    detailRow.appendChild(detailCell);
    row.parentNode.insertBefore(detailRow, row.nextSibling);
  }

  function renderItemRows(row) {
    var body = document.getElementById('cargoItemBody');
    if (!body) return;

    var raw = row.dataset.itemDetailRows || '';
    var rows = raw.split('§').filter(function (part) {
      return part && part.trim();
    });

    if (!rows.length) {
      body.innerHTML = '<tr><td colspan="4" class="empty-cell">조회된 품목 상세가 없습니다.</td></tr>';
      return;
    }

    body.innerHTML = rows.map(function (part, idx) {
      var cols = part.split('|');
      var name = cols[0];
      var qty = cols[1];
      var weight = cols[2];

      return '<tr>'
        + '<td>' + (idx + 1) + '</td>'
        + '<td class="text-left">' + escapeHtml(name) + '</td>'
        + '<td>' + escapeHtml(qty) + '</td>'
        + '<td>' + escapeHtml(weight) + '</td>'
        + '</tr>';
    }).join('');
  }

  function openCargoDetail(row) {
    var panel = document.getElementById('cargo-list-detail-panel');
    if (!panel || !row) return;

    if (row.classList.contains('row-selected')) {
      hideDetail();
      return;
    }

    document.querySelectorAll('.cargo-click-row').forEach(function (r) {
      r.classList.remove('row-selected');
    });
    row.classList.add('row-selected');

    createInlineDetailRow(row, panel);

    var isHouse = row.dataset.type === 'house';
    var declareType = row.dataset.declareType === 'IMPORT' ? '수입' : row.dataset.declareType === 'EXPORT' ? '수출' : row.dataset.declareType;

    setText('detailReqNo', row.dataset.reqNo);
    setText('detailDeclareType', declareType);
    setText('detailCargoMgmtNo', row.dataset.cargoMgmtNo);
    setText('detailGoodsGroupNo', row.dataset.goodsGroupNo);
    setText('detailTransportReqNo', row.dataset.transportReqNo);
    setText('detailOwnerName', row.dataset.ownerName);

    setText('detailBlNo', isHouse ? row.dataset.blNo : row.dataset.blNo);
    setText('detailMblNo', row.dataset.mblNo);
    setText('detailHblNo', row.dataset.hblNo);
    setText('detailBlStatus', row.dataset.blStatus);

    setText('detailLoadDate', row.dataset.loadDate);
    setText('detailDeparturePort', row.dataset.departurePort);
    setText('detailArrivalPort', row.dataset.arrivalPort);
    setText('detailTransportStatus', row.dataset.transportStatus);
    setText('detailSubmitStatus', isHouse ? row.dataset.declareStatus : row.dataset.submitStatus);
    setText('detailSubmitDate', row.dataset.submitDate);
    setText('detailRemark', row.dataset.remark);

    renderItemRows(row);

    var memo = document.getElementById('cargoMemo');
    if (memo) {
      memo.value = localStorage.getItem(getMemoKey(row)) || '';
      memo.dataset.memoKey = getMemoKey(row);
    }

    var saved = document.getElementById('cargoMemoSavedText');
    if (saved) saved.textContent = '';

    panel.style.display = 'block';
  }

  function bindRows() {
    document.querySelectorAll('.cargo-click-row').forEach(function (row) {
      row.addEventListener('click', function (e) {
        if (e.target.closest('a, input, select, textarea, label')) return;
        openCargoDetail(row);
      });
    });
  }

  function bindMemoSave() {
    var btn = document.getElementById('btnSaveCargoMemo');
    var memo = document.getElementById('cargoMemo');
    var saved = document.getElementById('cargoMemoSavedText');
    if (!btn || !memo) return;

    btn.addEventListener('click', function () {
      var key = memo.dataset.memoKey;
      if (!key) return;

      localStorage.setItem(key, memo.value || '');
      if (saved) {
        saved.textContent = '메모가 저장되었습니다.';
        setTimeout(function () {
          saved.textContent = '';
        }, 1800);
      }
    });
  }

  function bindSearchButtons() {
    var resetBtn = document.getElementById('btnResetLoadedCargoSearch');
    if (resetBtn) {
      resetBtn.addEventListener('click', function () {
        window.location.href = window.location.pathname;
      });
    }

    var recentBtn = document.getElementById('btnRecentWeek');
    if (recentBtn) {
      recentBtn.addEventListener('click', function () {
        var end = new Date();
        var start = new Date();
        start.setDate(end.getDate() - 7);

        function fmt(d) {
          return d.getFullYear() + '-'
            + String(d.getMonth() + 1).padStart(2, '0') + '-'
            + String(d.getDate()).padStart(2, '0');
        }

        var s = document.getElementById('startDate');
        var e = document.getElementById('endDate');
        if (s) s.value = fmt(start);
        if (e) e.value = fmt(end);
      });
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    bindRows();
    bindMemoSave();
    bindSearchButtons();
  });

  window.setCargoListTab = setCargoListTab;
})();
