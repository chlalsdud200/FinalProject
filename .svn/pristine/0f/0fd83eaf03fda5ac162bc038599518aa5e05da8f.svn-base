<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.tacs.transport.importp.mapper.ImportTransportMapper">
  <!-- ============================================================ -->
  <!-- 보세구역 입고관리 / 품목사항 / 입고요청 -->
  <!-- namespace는 기존 ImportTransportMapper와 동일하게 유지한다. -->
  <!-- 발표 전 안전 분리를 위해 Java Mapper/Service/Controller는 변경하지 않는다. -->
  <!-- ============================================================ -->
  <update id="updateImpUnloadingInSupplementRequested">
        UPDATE WH_IN_RPT
        SET
        WIR_STATUS_CD = 'REQ_FIX',
        WIR_WH_REPLY_STATUS_CD = 'REQ_FIX'
        WHERE WIR_NO = #{wirNo}
        AND WIR_IO_SE_CD = 'IMP'
    </update>
  <update id="updateImpUnloadingInSupplementData">
        UPDATE WH_IN_RPT W
        SET
        W.WIR_WM_ID = COALESCE(#{wmId,jdbcType=VARCHAR}, W.WIR_WM_ID)
        , W.WIR_WZ_NO = COALESCE(#{wzNo,jdbcType=VARCHAR}, W.WIR_WZ_NO)
        , W.WIR_IN_PLAN_DT = CASE
        WHEN #{inPlanDt,jdbcType=VARCHAR} IS NULL THEN W.WIR_IN_PLAN_DT
        WHEN LENGTH(#{inPlanDt,jdbcType=VARCHAR}) &gt; 10
        THEN TO_DATE(SUBSTR(#{inPlanDt,jdbcType=VARCHAR}, 1, 16), 'YYYY-MM-DD HH24' || CHR(58) || 'MI')
        ELSE TO_DATE(#{inPlanDt,jdbcType=VARCHAR}, 'YYYY-MM-DD')
        END
        , W.WIR_RQST_CN = COALESCE(#{remark,jdbcType=VARCHAR}, W.WIR_RQST_CN)
        , W.WIR_CARGO_MGMT_NO = COALESCE(#{cargoMgmtNo,jdbcType=VARCHAR}, W.WIR_CARGO_MGMT_NO)
        , W.WIR_INVOICE_NO = COALESCE(#{invoiceNo,jdbcType=VARCHAR}, W.WIR_INVOICE_NO)
        , W.WIR_INCO_TERMS_CD = COALESCE(#{incoTermsCd,jdbcType=VARCHAR}, W.WIR_INCO_TERMS_CD)
        WHERE W.WIR_NO = #{wirNo}
        AND W.WIR_IO_SE_CD = 'IMP'
        AND (
        W.WIR_STATUS_CD = 'REQ_FIX'
        OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX'
        )
    </update>
  <update id="updateImpUnloadingInSupplementGoods" parameterType="kr.or.tacs.vo.transport.TransportRequestVO">
        UPDATE CUSTOMS_GOODS CG
        SET
        CG.CG_QTY = COALESCE(#{qty,jdbcType=NUMERIC}, CG.CG_QTY)
        , CG.CG_PRICE = COALESCE(#{price,jdbcType=NUMERIC}, CG.CG_PRICE)
        , CG.CG_TOTAL_PRICE = COALESCE(#{goodsTotalPrice,jdbcType=NUMERIC}, CG.CG_TOTAL_PRICE)
        , CG.CG_WEIGHT = COALESCE(#{weight,jdbcType=NUMERIC}, CG.CG_WEIGHT)
        , CG.CG_ORIGIN = COALESCE(#{origin,jdbcType=VARCHAR}, CG.CG_ORIGIN)
        WHERE CG.CG_NO = #{cgNo}
    </update>
  <update id="updateImpUnloadingInSupplementGoodsName" parameterType="kr.or.tacs.vo.transport.TransportRequestVO">
        UPDATE GOODS G
        SET
        G.GOODS_NAME = COALESCE(#{goodsName,jdbcType=VARCHAR}, G.GOODS_NAME)
        , G.GOODS_HS_CODE = COALESCE(
        (
        SELECT MAX(H.HS_CODE)
        FROM HS_CODE H
        WHERE H.HS_CODE = #{hsCode,jdbcType=VARCHAR}
        ),
        (
        SELECT MAX(H.HS_CODE)
        FROM HS_CODE H
        WHERE H.HS_CODE = #{goodsHsCode,jdbcType=VARCHAR}
        ),
        G.GOODS_HS_CODE
        )
        WHERE G.GOODS_NO = COALESCE(
        #{goodsNo,jdbcType=NUMERIC},
        (
        SELECT CG.GOODS_NO
        FROM CUSTOMS_GOODS CG
        WHERE CG.CG_NO = #{cgNo}
        FETCH FIRST 1 ROW ONLY
        )
        )
    </update>
  <select id="selectNextImpGoodsNo" resultType="java.lang.Integer">
        SELECT NVL(MAX(GOODS_NO), 0) + 1
        FROM GOODS
    </select>
  <select id="selectNextImpCustomsGoodsNo" resultType="java.lang.Integer">
        SELECT NVL(MAX(CG_NO), 0) + 1
        FROM CUSTOMS_GOODS
    </select>
  <insert id="insertImpGoodsMaster" parameterType="kr.or.tacs.vo.transport.TransportRequestVO">
        INSERT INTO GOODS (
        GOODS_NO,
        GOODS_HS_CODE,
        GOODS_NAME
        )
        SELECT
        #{goodsNo,jdbcType=NUMERIC},
        COALESCE(
        (
        SELECT MAX(H.HS_CODE)
        FROM HS_CODE H
        WHERE H.HS_CODE = #{hsCode,jdbcType=VARCHAR}
        ),
        (
        SELECT MAX(H.HS_CODE)
        FROM HS_CODE H
        WHERE H.HS_CODE = #{goodsHsCode,jdbcType=VARCHAR}
        ),
        (
        SELECT MAX(G0.GOODS_HS_CODE)
        FROM GOODS G0
        WHERE G0.GOODS_HS_CODE IS NOT NULL
        AND G0.GOODS_NAME = COALESCE(#{goodsName,jdbcType=VARCHAR}, #{itemNm,jdbcType=VARCHAR}, '품목')
        ),
        (
        SELECT MIN(H.HS_CODE)
        FROM HS_CODE H
        WHERE H.HS_CODE IS NOT NULL
        )
        ),
        COALESCE(#{goodsName,jdbcType=VARCHAR}, #{itemNm,jdbcType=VARCHAR}, '품목')
        FROM DUAL
        WHERE NOT EXISTS (
        SELECT 1
        FROM GOODS G
        WHERE G.GOODS_NO = #{goodsNo,jdbcType=NUMERIC}
        )
    </insert>
  <insert id="insertImpUnloadingInGoods">
        BEGIN
        /*
        * CUSTOMS_GOODS.GG_NO는 GOODS_GROUP.GG_NO를 참조한다.
        * 운송담당자가 화면에서 품목을 처음 입력하는 건은 GOODS_GROUP 부모행이 아직 없을 수 있으므로
        * 사용자가 SQL을 따로 실행하지 않도록 여기에서 먼저 1회 보장한다.
        */
        INSERT INTO GOODS_GROUP (
        GG_NO
        )
        SELECT W.WIR_GG_NO
        FROM WH_IN_RPT W
        WHERE W.WIR_NO = #{wirNo}
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_GG_NO IS NOT NULL
        AND NOT EXISTS (
        SELECT 1
        FROM GOODS_GROUP GG
        WHERE GG.GG_NO = W.WIR_GG_NO
        );

        INSERT INTO CUSTOMS_GOODS (
        CG_NO,
        GOODS_NO,
        GG_NO,
        CG_QTY,
        CG_PRICE,
        CG_TOTAL_PRICE,
        CG_WEIGHT,
        CG_ORIGIN
        )
        SELECT
        #{goods.cgNo,jdbcType=NUMERIC},
        #{goods.goodsNo,jdbcType=NUMERIC},
        W.WIR_GG_NO,
        #{goods.qty,jdbcType=NUMERIC},
        #{goods.price,jdbcType=NUMERIC},
        NVL(#{goods.goodsTotalPrice,jdbcType=NUMERIC}, NVL(#{goods.qty,jdbcType=NUMERIC}, 0) * NVL(#{goods.price,jdbcType=NUMERIC}, 0)),
        #{goods.weight,jdbcType=NUMERIC},
        #{goods.origin,jdbcType=VARCHAR}
        FROM WH_IN_RPT W
        WHERE W.WIR_NO = #{wirNo}
        AND W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_GG_NO IS NOT NULL
        AND NOT EXISTS (
        SELECT 1
        FROM CUSTOMS_GOODS CG
        WHERE CG.CG_NO = #{goods.cgNo,jdbcType=NUMERIC}
        );
        END;
    </insert>
  <select id="selectImpUnloadingInWirNoByTrcNo" resultType="java.lang.String">
        SELECT MAX(W.WIR_NO) KEEP (DENSE_RANK LAST ORDER BY W.WIR_IN_PLAN_DT, W.WIR_NO)
        FROM WH_IN_RPT W
        INNER JOIN TRAN_RCP T
        ON T.TRC_TFG_NO = W.WIR_GG_NO
        AND T.TRC_SE_CD = 'IMPORT'
        WHERE T.TRC_NO = #{trcNo}
        AND W.WIR_IO_SE_CD = 'IMP'
    </select>
  <select id="retriveImpUnloadingInList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        T.TRC_NO                                        AS trcNo
        , W.WIR_NO                                        AS wirNo
        , W.WIR_GG_NO                                     AS ggNo
        , T.TRC_OWR_ID                                    AS ownerId
        , O.OWR_NM                                        AS ownerNm
        , T.TRC_ITEM_CTGRY_NM                            AS itemCategory
        , T.TRC_ITEM_CTGRY_NM                            AS itemNm
        , T.TRC_ITEM_CTGRY_NM                            AS frghtIemNm
        , W.WIR_WM_ID                                     AS bondedManagerId
        , WM.WM_NM                                        AS bondedManagerNm
        , WM.WM_NM                                        AS warehouseManagerNm
        , WH.WH_NM                                        AS whNm
        , WH.WH_NM                                        AS warehouseNm
        , W.WIR_WZ_NO                                     AS bondedZoneNo
        , NVL(NVL(WZ.WZ_NM, WM.WM_DETAIL_ADRES), TO_CHAR(W.WIR_WZ_NO)) AS warehouseZoneNm
        , TO_CHAR(W.WIR_IN_PLAN_DT, 'YYYY-MM-DD HH24' || CHR(58) || 'MI') AS inPlanDt
        , W.WIR_RQST_CN                                AS remark
        , W.WIR_RQST_CN                                AS wirRmrk
        , W.WIR_RQST_CN                                AS requestCn
        , W.WIR_CARGO_MGMT_NO                             AS cargoMgmtNo
        , NVL(W.WIR_INCO_TERMS_CD, T.TRC_INCO_TERMS_CD) AS incoTermsCd
        , W.WIR_INCO_TERMS_CD                           AS wirIncoTermsCd
        , T.TRC_INCO_TERMS_CD                           AS trcIncoTermsCd
        , W.WIR_INVOICE_NO                                AS invoiceNo
        , COALESCE(M.ICM_MBL_NO, BI.BI_MBL_NO, (SELECT MAX(IR.IR_BL_AWB_NO)
           FROM IMP_RQST IR
          WHERE (IR.IR_NO = T.TRC_NO OR IR.IR_NO = REPLACE(T.TRC_NO, 'TRC-', '') OR IR.IR_OWR_ID = T.TRC_OWR_ID)
            AND IR.IR_BL_AWB_NO IS NOT NULL)) AS mblNo
        , COALESCE(M.ICM_HBL_NO, BI.BI_HBL_NO) AS hblNo
        , SR_WH.SRI_REQ_CN                              AS rejectReason
        , SR_WH.SRI_REQ_CN                              AS suppReqCn
        , CASE
        /* 창고가 SUPP_RQST로 보완요청/보완완료를 관리하므로 WH_IN_RPT보다 보완 상태를 우선 표시 */
        WHEN W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN 'IN_DONE'
        WHEN SR_WH.SR_STATUS_CD = 'REQ' THEN 'REQ_FIX'
        WHEN SR_WH.SR_STATUS_CD = 'SUB' THEN 'REQ_SENT'
        WHEN SR_WH.SR_STATUS_CD = 'APR' THEN 'IN_DONE'
        WHEN W.WIR_STATUS_CD = 'REQ_FIX' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN 'REQ_FIX'
        WHEN W.WIR_STATUS_CD = 'REQ_SENT' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN 'REQ_SENT'
        WHEN W.WIR_STATUS_CD IN ('REJECT', 'REJECTED') OR W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED') THEN 'REJECT'
        ELSE W.WIR_STATUS_CD
        END                                             AS statusCd
        , W.WIR_WH_REPLY_STATUS_CD                      AS warehouseReplyStatusCd
        , W.WIR_WH_REPLY_STATUS_CD                      AS wirWhReplyStatusCd
        , CASE
        WHEN W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN '입고완료'
        WHEN SR_WH.SR_STATUS_CD = 'REQ' THEN '보완요청'
        WHEN SR_WH.SR_STATUS_CD = 'SUB' THEN '보완제출완료'
        WHEN SR_WH.SR_STATUS_CD = 'APR' THEN '입고완료'
        WHEN W.WIR_STATUS_CD = 'REQ_FIX' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN '보완요청'
        WHEN W.WIR_STATUS_CD = 'REQ_SENT' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN '보완제출완료'
        WHEN W.WIR_STATUS_CD IN ('REJECT', 'REJECTED') OR W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED') THEN '반려'
        WHEN W.WIR_STATUS_CD = 'WAIT' OR W.WIR_WH_REPLY_STATUS_CD = 'WAIT' THEN '입고요청'
        WHEN W.WIR_STATUS_CD IS NULL AND W.WIR_WH_REPLY_STATUS_CD IS NULL THEN NULL
        ELSE '입고대기'
        END                                             AS statusNm
        , W.WIR_IO_SE_CD                                  AS ioSeCd
        , MIN(C.CG_NO)                                    AS cgNo
        , MIN(C.GOODS_NO)                                 AS goodsNo
        , MIN(G.GOODS_NAME)                               AS goodsName
        , MIN(G.GOODS_HS_CODE)                            AS goodsHsCode
        , MIN(G.GOODS_HS_CODE)                            AS hsCode
        , MIN(G.GOODS_HS_CODE)                            AS itemHsCode
        , COUNT(C.CG_NO)                                  AS goodsCnt
        , NVL(SUM(C.CG_QTY), 0)                           AS qty
        , NVL(SUM(C.CG_QTY), 0)                           AS totalQty
        , NVL(MAX(C.CG_PRICE), 0)                         AS price
        , NVL(SUM(C.CG_TOTAL_PRICE), 0)                   AS goodsTotalPrice
        , NVL(SUM(C.CG_WEIGHT), 0)                        AS weight
        , NVL(SUM(C.CG_WEIGHT), 0)                        AS totalWeight
        , NVL(SUM(C.CG_TOTAL_PRICE), 0)                   AS summaryTotalPrice
        , MIN(C.CG_ORIGIN)                                AS origin
        FROM TRAN_RCP T

        LEFT JOIN WH_IN_RPT W
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND W.WIR_IO_SE_CD = 'IMP'
        LEFT JOIN OWNER O
        ON T.TRC_OWR_ID = O.OWR_ID
        LEFT JOIN CUSTOMS_GOODS C
        ON C.GG_NO = T.TRC_TFG_NO
        LEFT JOIN GOODS G
        ON C.GOODS_NO = G.GOODS_NO
        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = W.WIR_WM_ID
        LEFT JOIN (
        SELECT
        Z.WM_ID
        , MIN(Z.WZ_NO) AS WZ_NO
        FROM WAREHOUSE_ZONE Z
        WHERE NVL(Z.WZ_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_STATUS_CD, 'ACTIVE') = 'ACTIVE'
        GROUP BY Z.WM_ID
        ) WZ_BY_WM
        ON WZ_BY_WM.WM_ID = W.WIR_WM_ID
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = NVL(W.WIR_WZ_NO, WZ_BY_WM.WZ_NO)
        LEFT JOIN WAREHOUSE WH
        ON WH.WH_NO = WZ.WZ_WH_NO
        LEFT JOIN (
        SELECT
        ICM_GG_NO
        , ICM_OWR_ID
        , ICM_MBL_NO
        , ICM_HBL_NO
        FROM (
        SELECT
        M0.ICM_GG_NO
        , M0.ICM_OWR_ID
        , M0.ICM_MBL_NO
        , M0.ICM_HBL_NO
        , ROW_NUMBER() OVER (
        PARTITION BY M0.ICM_GG_NO, M0.ICM_OWR_ID
        ORDER BY M0.ICM_SBMSN_DT DESC NULLS LAST, M0.ICM_NO DESC
        ) AS RN
        FROM IMP_CARGO_MANIFEST M0
        )
        WHERE RN = 1
        ) M
        ON M.ICM_GG_NO = T.TRC_TFG_NO
        AND M.ICM_OWR_ID = T.TRC_OWR_ID
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        LEFT JOIN (
        SELECT
        SR_NO
        , SR_REF_NO
        , SR_STATUS_CD
        , SR_REQ_DT
        , SRI_REQ_CN
        FROM (
        SELECT
        SR.SR_NO
        , SR.SR_REF_NO
        , SR.SR_STATUS_CD
        , SR.SR_REQ_DT
        , CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)) AS SRI_REQ_CN
        , ROW_NUMBER() OVER (
        PARTITION BY SR.SR_REF_NO
        ORDER BY SR.SR_REQ_DT DESC, SR.SR_NO DESC
        ) AS RN
        FROM SUPP_RQST SR
        WHERE SR.SR_REF_BIZ_CD = 'WH_IN_RPT'
        AND SR.RECEIVER_TY_CD IN ('TRC', 'WHM', 'TRANSPORT', 'TRANSPORT_MANAGER', 'WAREHOUSE_MANAGER')
        AND SR.SR_STATUS_CD IN ('REQ', 'SUB', 'APR')
        AND EXISTS (
        SELECT 1
        FROM WH_IN_RPT WX
        WHERE WX.WIR_IO_SE_CD = 'IMP'
        AND (
        WX.WIR_WM_ID = SR.SENDER_ID
        OR WX.WIR_WM_ID = SR.RECEIVER_ID
        )
        AND (
        WX.WIR_NO = SR.SR_REF_NO
        OR EXISTS (
        SELECT 1
        FROM TRAN_RCP TX
        WHERE TX.TRC_NO = SR.SR_REF_NO
        AND TX.TRC_SE_CD = 'IMPORT'
        AND TX.TRC_TFG_NO = WX.WIR_GG_NO
        )
        )
        )
        )
        WHERE RN = 1
        ) SR_WH
        ON (SR_WH.SR_REF_NO = W.WIR_NO OR SR_WH.SR_REF_NO = T.TRC_NO)
        WHERE T.TRC_SE_CD = 'IMPORT'
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        AND (
        W.WIR_NO IS NULL
        OR W.WIR_STATUS_CD IS NULL
        OR W.WIR_STATUS_CD IN ('WAIT', 'REQ_FIX', 'REQ_SENT', 'IN_DONE', 'REJECT', 'REJECTED')
        OR W.WIR_WH_REPLY_STATUS_CD IS NULL
        OR W.WIR_WH_REPLY_STATUS_CD IN ('WAIT', 'REQ_FIX', 'REQ_SENT', 'IN_DONE', 'REJECT', 'REJECTED')
        )
        GROUP BY
        T.TRC_NO
        , W.WIR_NO
        , W.WIR_GG_NO
        , T.TRC_OWR_ID
        , O.OWR_NM
        , T.TRC_ITEM_CTGRY_NM
        , W.WIR_WM_ID
        , WM.WM_NM
        , WH.WH_NM
        , W.WIR_WZ_NO
        , WZ.WZ_NM
        , WM.WM_DETAIL_ADRES
        , W.WIR_IN_PLAN_DT
        , W.WIR_RQST_CN
        , W.WIR_CARGO_MGMT_NO
        , W.WIR_INCO_TERMS_CD
        , T.TRC_INCO_TERMS_CD
        , W.WIR_INVOICE_NO
        , M.ICM_MBL_NO
        , M.ICM_HBL_NO
        , BI.BI_MBL_NO
        , BI.BI_HBL_NO
        , W.WIR_STATUS_CD
        , W.WIR_WH_REPLY_STATUS_CD
        , W.WIR_IO_SE_CD
        , SR_WH.SR_STATUS_CD
        , SR_WH.SRI_REQ_CN
        ORDER BY W.WIR_IN_PLAN_DT DESC, W.WIR_NO DESC
    </select>
  <select id="selectImpUnloadingInDetail" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        T.TRC_NO                                        AS trcNo
        , W.WIR_NO                                        AS wirNo
        , W.WIR_GG_NO                                     AS ggNo
        , T.TRC_OWR_ID                                    AS ownerId
        , O.OWR_NM                                        AS ownerNm
        , T.TRC_ITEM_CTGRY_NM                            AS itemCategory
        , T.TRC_ITEM_CTGRY_NM                            AS itemNm
        , T.TRC_ITEM_CTGRY_NM                            AS frghtIemNm
        , W.WIR_WM_ID                                     AS bondedManagerId
        , WH.WH_NO                                        AS whNo
        , WH.WH_NO                                        AS warehouseNo
        , WH.WH_NM                                        AS whNm
        , WH.WH_NM                                        AS warehouseNm
        , WM.WM_NM                                        AS bondedManagerNm
        , WM.WM_NM                                        AS warehouseManagerNm
        , W.WIR_WZ_NO                                     AS bondedZoneNo
        , NVL(NVL(WZ.WZ_NM, WM.WM_DETAIL_ADRES), TO_CHAR(W.WIR_WZ_NO)) AS warehouseZoneNm
        , TO_CHAR(W.WIR_IN_PLAN_DT, 'YYYY-MM-DD HH24' || CHR(58) || 'MI') AS inPlanDt
        , W.WIR_RQST_CN                                   AS requestCn
        , W.WIR_CARGO_MGMT_NO                             AS cargoMgmtNo
        , NVL(W.WIR_INCO_TERMS_CD, T.TRC_INCO_TERMS_CD) AS incoTermsCd
        , W.WIR_INCO_TERMS_CD                           AS wirIncoTermsCd
        , T.TRC_INCO_TERMS_CD                           AS trcIncoTermsCd
        , W.WIR_INVOICE_NO                                AS invoiceNo
        , W.WIR_INVOICE_YMD                               AS requestDt
        , W.WIR_RQST_CN                                   AS rejectMemo
        , COALESCE(M.ICM_MBL_NO, BI.BI_MBL_NO, (SELECT MAX(IR.IR_BL_AWB_NO)
           FROM IMP_RQST IR
          WHERE (IR.IR_NO = T.TRC_NO OR IR.IR_NO = REPLACE(T.TRC_NO, 'TRC-', '') OR IR.IR_OWR_ID = T.TRC_OWR_ID)
            AND IR.IR_BL_AWB_NO IS NOT NULL)) AS mblNo
        , COALESCE(M.ICM_HBL_NO, BI.BI_HBL_NO) AS hblNo
        , SR_WH.SRI_REQ_CN                              AS rejectReason
        , SR_WH.SRI_REQ_CN                              AS suppReqCn
        , CASE
        /* 창고가 SUPP_RQST로 보완요청/보완완료를 관리하므로 WH_IN_RPT보다 보완 상태를 우선 표시 */
        WHEN W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN 'IN_DONE'
        WHEN SR_WH.SR_STATUS_CD = 'REQ' THEN 'REQ_FIX'
        WHEN SR_WH.SR_STATUS_CD = 'SUB' THEN 'REQ_SENT'
        WHEN SR_WH.SR_STATUS_CD = 'APR' THEN 'IN_DONE'
        WHEN W.WIR_STATUS_CD = 'REQ_FIX' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN 'REQ_FIX'
        WHEN W.WIR_STATUS_CD = 'REQ_SENT' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN 'REQ_SENT'
        WHEN W.WIR_STATUS_CD IN ('REJECT', 'REJECTED') OR W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED') THEN 'REJECT'
        ELSE W.WIR_STATUS_CD
        END                                             AS statusCd
        , W.WIR_WH_REPLY_STATUS_CD                      AS warehouseReplyStatusCd
        , W.WIR_WH_REPLY_STATUS_CD                      AS wirWhReplyStatusCd
        , CASE
        WHEN W.WIR_STATUS_CD = 'IN_DONE' OR W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN '입고완료'
        WHEN SR_WH.SR_STATUS_CD = 'REQ' THEN '보완요청'
        WHEN SR_WH.SR_STATUS_CD = 'SUB' THEN '보완제출완료'
        WHEN SR_WH.SR_STATUS_CD = 'APR' THEN '입고완료'
        WHEN W.WIR_STATUS_CD = 'REQ_FIX' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN '보완요청'
        WHEN W.WIR_STATUS_CD = 'REQ_SENT' OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN '보완제출완료'
        WHEN W.WIR_STATUS_CD IN ('REJECT', 'REJECTED') OR W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED') THEN '반려'
        WHEN W.WIR_STATUS_CD = 'WAIT' OR W.WIR_WH_REPLY_STATUS_CD = 'WAIT' THEN '입고요청'
        WHEN W.WIR_STATUS_CD IS NULL AND W.WIR_WH_REPLY_STATUS_CD IS NULL THEN NULL
        ELSE '입고대기'
        END                                             AS statusNm
        , W.WIR_IO_SE_CD                                  AS ioSeCd
        , GOODS_SUM.CG_NO                                AS cgNo
        , GOODS_SUM.GOODS_NO                             AS goodsNo
        , GOODS_SUM.GOODS_NAME                           AS goodsName
        , GOODS_SUM.GOODS_NAME                           AS itemNm
        , GOODS_SUM.GOODS_HS_CODE                        AS goodsHsCode
        , GOODS_SUM.HS_CODE                              AS hsCode
        , GOODS_SUM.HS_CODE                              AS itemHsCode
        , GOODS_SUM.QTY                                  AS qty
        , GOODS_SUM.QTY                                  AS totalQty
        , GOODS_SUM.PRICE                                AS price
        , GOODS_SUM.GOODS_TOTAL_PRICE                    AS goodsTotalPrice
        , GOODS_SUM.GOODS_TOTAL_PRICE                    AS summaryTotalPrice
        , GOODS_SUM.WEIGHT                               AS weight
        , GOODS_SUM.WEIGHT                               AS totalWeight
        , GOODS_SUM.ORIGIN                               AS origin
        FROM WH_IN_RPT W
        INNER JOIN TRAN_RCP T
        ON W.WIR_GG_NO = T.TRC_TFG_NO
        AND T.TRC_SE_CD = 'IMPORT'

        LEFT JOIN OWNER O
        ON T.TRC_OWR_ID = O.OWR_ID
        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = W.WIR_WM_ID
        LEFT JOIN (
        SELECT
        Z.WM_ID
        , MIN(Z.WZ_NO) AS WZ_NO
        FROM WAREHOUSE_ZONE Z
        WHERE NVL(Z.WZ_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_STATUS_CD, 'ACTIVE') = 'ACTIVE'
        GROUP BY Z.WM_ID
        ) WZ_BY_WM
        ON WZ_BY_WM.WM_ID = W.WIR_WM_ID
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = NVL(W.WIR_WZ_NO, WZ_BY_WM.WZ_NO)
        LEFT JOIN WAREHOUSE WH
        ON WH.WH_NO = WZ.WZ_WH_NO
        LEFT JOIN (
        SELECT
        ICM_GG_NO
        , ICM_OWR_ID
        , ICM_MBL_NO
        , ICM_HBL_NO
        FROM (
        SELECT
        M0.ICM_GG_NO
        , M0.ICM_OWR_ID
        , M0.ICM_MBL_NO
        , M0.ICM_HBL_NO
        , ROW_NUMBER() OVER (
        PARTITION BY M0.ICM_GG_NO, M0.ICM_OWR_ID
        ORDER BY M0.ICM_SBMSN_DT DESC NULLS LAST, M0.ICM_NO DESC
        ) AS RN
        FROM IMP_CARGO_MANIFEST M0
        )
        WHERE RN = 1
        ) M
        ON M.ICM_GG_NO = T.TRC_TFG_NO
        AND M.ICM_OWR_ID = T.TRC_OWR_ID
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        LEFT JOIN (
        SELECT
        SR_NO
        , SR_REF_NO
        , SR_STATUS_CD
        , SR_REQ_DT
        , SRI_REQ_CN
        FROM (
        SELECT
        SR.SR_NO
        , SR.SR_REF_NO
        , SR.SR_STATUS_CD
        , SR.SR_REQ_DT
        , CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)) AS SRI_REQ_CN
        , ROW_NUMBER() OVER (
        PARTITION BY SR.SR_REF_NO
        ORDER BY SR.SR_REQ_DT DESC, SR.SR_NO DESC
        ) AS RN
        FROM SUPP_RQST SR
        WHERE SR.SR_REF_BIZ_CD = 'WH_IN_RPT'
        AND SR.RECEIVER_TY_CD IN ('TRC', 'WHM', 'TRANSPORT', 'TRANSPORT_MANAGER', 'WAREHOUSE_MANAGER')
        AND SR.SR_STATUS_CD IN ('REQ', 'SUB', 'APR')
        AND EXISTS (
        SELECT 1
        FROM WH_IN_RPT WX
        WHERE WX.WIR_IO_SE_CD = 'IMP'
        AND (
        WX.WIR_WM_ID = SR.SENDER_ID
        OR WX.WIR_WM_ID = SR.RECEIVER_ID
        )
        AND (
        WX.WIR_NO = SR.SR_REF_NO
        OR EXISTS (
        SELECT 1
        FROM TRAN_RCP TX
        WHERE TX.TRC_NO = SR.SR_REF_NO
        AND TX.TRC_SE_CD = 'IMPORT'
        AND TX.TRC_TFG_NO = WX.WIR_GG_NO
        )
        )
        )
        )
        WHERE RN = 1
        ) SR_WH
        ON (SR_WH.SR_REF_NO = W.WIR_NO OR SR_WH.SR_REF_NO = T.TRC_NO)
        LEFT JOIN (
        SELECT
        CG.GG_NO
        , MIN(CG.CG_NO)                  AS CG_NO
        , MIN(CG.GOODS_NO)               AS GOODS_NO
        , MIN(G.GOODS_NAME)              AS GOODS_NAME
        , MIN(G.GOODS_HS_CODE)           AS GOODS_HS_CODE
        , MIN(G.GOODS_HS_CODE)           AS HS_CODE
        , NVL(SUM(CG.CG_QTY), 0)         AS QTY
        , NVL(MAX(CG.CG_PRICE), 0)       AS PRICE
        , NVL(SUM(CG.CG_TOTAL_PRICE), 0) AS GOODS_TOTAL_PRICE
        , NVL(SUM(CG.CG_WEIGHT), 0)      AS WEIGHT
        , MIN(CG.CG_ORIGIN)              AS ORIGIN
        FROM CUSTOMS_GOODS CG
        LEFT JOIN GOODS G
        ON G.GOODS_NO = CG.GOODS_NO
        GROUP BY CG.GG_NO
        ) GOODS_SUM
        ON GOODS_SUM.GG_NO = W.WIR_GG_NO
        WHERE W.WIR_NO = #{wirNo}
        AND W.WIR_IO_SE_CD = 'IMP'
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        AND (
        (W.WIR_STATUS_CD IS NULL OR W.WIR_STATUS_CD IN ('WAIT', 'REQ_FIX', 'REQ_SENT', 'IN_DONE', 'REJECT', 'REJECTED'))
        AND (
        W.WIR_NO IS NULL
        OR W.WIR_STATUS_CD IS NULL
        OR W.WIR_STATUS_CD IN ('WAIT', 'REQ_FIX', 'REQ_SENT', 'IN_DONE', 'REJECT', 'REJECTED')
        OR W.WIR_WH_REPLY_STATUS_CD IS NULL
        OR W.WIR_WH_REPLY_STATUS_CD IN ('WAIT', 'REQ_FIX', 'REQ_SENT', 'IN_DONE', 'REJECT', 'REJECTED')
        )
    </select>
  <select id="retriveImpUnloadingInGoodsList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        C.CG_NO           AS cgNo
        , C.GOODS_NO        AS goodsNo
        , G.GOODS_NAME      AS goodsName
        , G.GOODS_NAME      AS itemNm
        , G.GOODS_HS_CODE   AS goodsHsCode
        , G.GOODS_HS_CODE   AS hsCode
        , G.GOODS_HS_CODE   AS itemHsCode
        , C.GG_NO           AS ggNo
        , C.CG_QTY          AS qty
        , C.CG_PRICE        AS price
        , C.CG_TOTAL_PRICE  AS goodsTotalPrice
        , C.CG_WEIGHT       AS weight
        , C.CG_ORIGIN       AS origin
        FROM CUSTOMS_GOODS C
        LEFT JOIN GOODS G
        ON C.GOODS_NO = G.GOODS_NO
        WHERE C.GG_NO = #{ggNo}
        ORDER BY C.CG_NO
    </select>
  <select id="retriveImportWarehouseManagerList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        W.WH_NO AS whNo
        , W.WH_NO AS warehouseNo
        , W.WH_NM AS whNm
        , W.WH_NM AS warehouseNm

        , WZ.WZ_NO AS wzNo
        , WZ.WZ_NO AS bondedZoneNo
        , WZ.WZ_NO AS warehouseZoneNo
        , WZ.WZ_NM AS wzNm
        , WZ.WZ_NM AS warehouseZoneNm

        , WM.WM_ID AS wmId
        , WM.WM_ID AS bondedManagerId
        , WM.WM_ID AS warehouseManagerId
        , WM.WM_NM AS wmNm
        , WM.WM_NM AS bondedManagerNm
        , WM.WM_NM AS warehouseManagerNm

        FROM WAREHOUSE_ZONE WZ
        JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = WZ.WM_ID
        JOIN WAREHOUSE W
        ON W.WH_NO = WZ.WZ_WH_NO

        WHERE NVL(WM.WM_USE_YN,'Y')='Y'
        AND NVL(WZ.WZ_USE_YN,'Y')='Y'

        ORDER BY W.WH_NM, WZ.WZ_NM, WM.WM_NM
    </select>
  <update id="updateImpUnloadingInDelivered">
        /*
        * 입고요청 발송 처리.
        * - UPDATE 후 SQL%ROWCOUNT=0이면 INSERT 한다.
        * - 최초 화면에서는 상태값을 비워두고, 이 쿼리가 실행될 때만 WAIT/WAIT로 변경한다.
        * - 입고요청일은 사용자가 입력하지 않고 발송 시점(SYSDATE)으로 저장한다.
        * - 화면 입력값은 창고담당자/보세구역/요청사항만 저장하고, 인코텀즈는 TRAN_RCP에서 조회한다.
        */
        BEGIN
        /*
        * WH_IN_RPT.WIR_GG_NO가 GOODS_GROUP.GG_NO를 참조하므로
        * 입고요청/품목저장 전에 부모 화물그룹을 자동 보장한다.
        * 그래서 사용자가 GOODS_GROUP INSERT를 수동 실행할 필요가 없다.
        */
        INSERT INTO GOODS_GROUP (GG_NO)
        SELECT T.TRC_TFG_NO
        FROM TRAN_RCP T
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD = 'IMPORT'
        AND T.TRC_TFG_NO IS NOT NULL
        AND NOT EXISTS (
        SELECT 1
        FROM GOODS_GROUP GG
        WHERE GG.GG_NO = T.TRC_TFG_NO
        );

        UPDATE WH_IN_RPT W
        SET W.WIR_STATUS_CD = 'WAIT'
        , W.WIR_WH_REPLY_STATUS_CD = 'WAIT'
        , W.WIR_WM_ID = #{wmId}
        , W.WIR_WZ_NO = #{wzNo}
        , W.WIR_GG_NO = NVL(W.WIR_GG_NO, (
        SELECT T.TRC_TFG_NO
        FROM TRAN_RCP T
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD = 'IMPORT'
        ))
        , W.WIR_IN_PLAN_DT = CASE
        WHEN #{inPlanDt,jdbcType=VARCHAR} IS NULL THEN NVL(W.WIR_IN_PLAN_DT, SYSDATE)
        WHEN LENGTH(#{inPlanDt,jdbcType=VARCHAR}) &gt; 10
        THEN TO_DATE(SUBSTR(#{inPlanDt,jdbcType=VARCHAR}, 1, 16), 'YYYY-MM-DD HH24' || CHR(58) || 'MI')
        ELSE TO_DATE(#{inPlanDt,jdbcType=VARCHAR}, 'YYYY-MM-DD')
        END
        , W.WIR_RQST_CN = #{remark}
        , W.WIR_CARGO_MGMT_NO = COALESCE(#{cargoMgmtNo,jdbcType=VARCHAR}, W.WIR_CARGO_MGMT_NO, 'CARGO-' || #{trcNo})
        , W.WIR_INVOICE_NO = COALESCE(#{invoiceNo,jdbcType=VARCHAR}, W.WIR_INVOICE_NO)
        , W.WIR_INCO_TERMS_CD = NVL(W.WIR_INCO_TERMS_CD, (
        SELECT T.TRC_INCO_TERMS_CD
        FROM TRAN_RCP T
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD = 'IMPORT'
        ))
        WHERE W.WIR_IO_SE_CD = 'IMP'
        AND (
        W.WIR_NO = #{wirNo}
        OR W.WIR_GG_NO = (
        SELECT T.TRC_TFG_NO
        FROM TRAN_RCP T
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD = 'IMPORT'
        )
        );

        IF SQL%ROWCOUNT = 0 THEN
        INSERT INTO WH_IN_RPT (
        WIR_NO,
        WIR_GG_NO,
        WIR_OWR_ID,
        WIR_WM_ID,
        WIR_WZ_NO,
        WIR_IN_PLAN_DT,
        WIR_STATUS_CD,
        WIR_WH_REPLY_STATUS_CD,
        WIR_CARGO_MGMT_NO,
        WIR_INCO_TERMS_CD,
        WIR_INVOICE_NO,
        WIR_RQST_CN,
        WIR_OWR_NM,
        WIR_IO_SE_CD
        )
        SELECT
        REGEXP_REPLACE(T.TRC_NO, '-[0-9]+$', '-') || LPAD(
        NVL((
        SELECT MAX(TO_NUMBER(REGEXP_SUBSTR(W3.WIR_NO, '[0-9]+$')))
        FROM WH_IN_RPT W3
        WHERE W3.WIR_IO_SE_CD = 'IMP'
        AND W3.WIR_NO LIKE REGEXP_REPLACE(T.TRC_NO, '-[0-9]+$', '-%')
        ), 9000) + 1,
        4,
        '0'
        ) AS WIR_NO,
        T.TRC_TFG_NO,
        T.TRC_OWR_ID,
        #{wmId},
        #{wzNo},
        CASE
        WHEN #{inPlanDt,jdbcType=VARCHAR} IS NULL THEN SYSDATE
        WHEN LENGTH(#{inPlanDt,jdbcType=VARCHAR}) &gt; 10
        THEN TO_DATE(SUBSTR(#{inPlanDt,jdbcType=VARCHAR}, 1, 16), 'YYYY-MM-DD HH24' || CHR(58) || 'MI')
        ELSE TO_DATE(#{inPlanDt,jdbcType=VARCHAR}, 'YYYY-MM-DD')
        END,
        'WAIT',
        'WAIT',
        COALESCE(#{cargoMgmtNo,jdbcType=VARCHAR}, 'CARGO-' || T.TRC_NO),
        T.TRC_INCO_TERMS_CD,
        #{invoiceNo,jdbcType=VARCHAR},
        #{remark},
        O.OWR_NM,
        'IMP'
        FROM TRAN_RCP T
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD = 'IMPORT';
        END IF;
        END;
    </update>
  <update id="updateImpUnloadingInSupplementSubmitted">
        BEGIN
        UPDATE SUPP_RQST SR
        SET
        SR.SR_STATUS_CD = 'SUB'
        , SR.SR_SUBMIT_DT = SYSDATE
        WHERE SR.SR_REF_BIZ_CD = 'WH_IN_RPT'
        AND SR.RECEIVER_TY_CD IN ('TRC', 'WHM', 'TRANSPORT', 'TRANSPORT_MANAGER', 'WAREHOUSE_MANAGER')
        AND SR.SR_STATUS_CD = 'REQ'
        AND SR.SR_REF_NO IN (
        #{wirNo}
        , (
        SELECT MAX(T.TRC_NO)
        FROM WH_IN_RPT W
        INNER JOIN TRAN_RCP T
        ON T.TRC_TFG_NO = W.WIR_GG_NO
        AND T.TRC_SE_CD = 'IMPORT'
        WHERE W.WIR_NO = #{wirNo}
        AND W.WIR_IO_SE_CD = 'IMP'
        )
        );
        /* SUPP_RQST_ITEM 테이블은 삭제되고 SUPP_RQST로 통합되어 ITEM 상태 업데이트는 제거한다. */

        UPDATE WH_IN_RPT W
        SET W.WIR_STATUS_CD = 'REQ_SENT'
        , W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT'
        WHERE W.WIR_NO = #{wirNo}
        AND W.WIR_IO_SE_CD = 'IMP'
        /* 최초 입고요청(WAIT)은 보완제출완료로 덮어쓰면 안 된다.
        창고가 먼저 보완요청(REQ_FIX)을 보낸 건만 REQ_SENT로 변경한다. */
        AND (
        W.WIR_STATUS_CD = 'REQ_FIX'
        OR W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX'
        );

        END;
    </update>
  <update id="prepareImpWarehouseInAfterArrivalNotice">
        /*
        * 도착통지 발송 후 입고관리 기본 행을 준비한다.
        *
        * 중요 상태 규칙:
        * - 운송담당자가 아직 창고로 입고요청을 보내기 전이면 상태값은 비워둔다(NULL/NULL).
        * - 입고관리 화면에서 실제 "발송"을 누르는 updateImpUnloadingInDelivered에서만 WAIT/WAIT(입고요청)으로 바뀐다.
        * - 보완요청 흐름은 WAIT -&gt; REQ_FIX -&gt; REQ_SENT -&gt; IN_DONE 만 사용한다.
        *
        * SELECT COUNT 후 UPDATE/INSERT로 분기한다.
        * 현재 기준: 도착통지서 발송 직후 WH_IN_RPT를 WAIT/WAIT으로 생성/보정한다.
        */
        DECLARE
        V_EXISTS NUMBER;
        BEGIN
        INSERT INTO GOODS_GROUP (GG_NO)
        SELECT T.TRC_TFG_NO
        FROM TRAN_RCP T
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        IAN0.*,
        ROW_NUMBER() OVER (
        PARTITION BY IAN0.IAN_TRC_NO
        ORDER BY
        CASE WHEN IAN0.IAN_SEND_STTS_CD = 'TRC_NTC_SENT' THEN 0 ELSE 1 END,
        IAN0.IAN_SEND_DT DESC NULLS LAST,
        IAN0.IAN_REGIST_DT DESC NULLS LAST,
        IAN0.IAN_NO DESC
        ) AS RN
        FROM IMP_ARRV_NTC IAN0
        )
        WHERE RN = 1
        ) IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        WHERE T.TRC_SE_CD = 'IMPORT'
        AND T.TRC_TFG_NO IS NOT NULL
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        AND NOT EXISTS (
        SELECT 1
        FROM GOODS_GROUP GG
        WHERE GG.GG_NO = T.TRC_TFG_NO
        );

        SELECT COUNT(*)
        INTO V_EXISTS
        FROM WH_IN_RPT W
        WHERE W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_GG_NO = (
        SELECT MAX(T.TRC_TFG_NO)
        FROM TRAN_RCP T
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        IAN0.*,
        ROW_NUMBER() OVER (
        PARTITION BY IAN0.IAN_TRC_NO
        ORDER BY
        CASE WHEN IAN0.IAN_SEND_STTS_CD = 'TRC_NTC_SENT' THEN 0 ELSE 1 END,
        IAN0.IAN_SEND_DT DESC NULLS LAST,
        IAN0.IAN_REGIST_DT DESC NULLS LAST,
        IAN0.IAN_NO DESC
        ) AS RN
        FROM IMP_ARRV_NTC IAN0
        )
        WHERE RN = 1
        ) IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        WHERE T.TRC_SE_CD = 'IMPORT'
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        );

        IF V_EXISTS &gt; 0 THEN
        UPDATE WH_IN_RPT W
        SET
        W.WIR_CARGO_MGMT_NO = NVL(W.WIR_CARGO_MGMT_NO, (
        SELECT 'CARGO-' || T.TRC_NO
        FROM TRAN_RCP T
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        IAN0.*,
        ROW_NUMBER() OVER (
        PARTITION BY IAN0.IAN_TRC_NO
        ORDER BY
        CASE WHEN IAN0.IAN_SEND_STTS_CD = 'TRC_NTC_SENT' THEN 0 ELSE 1 END,
        IAN0.IAN_SEND_DT DESC NULLS LAST,
        IAN0.IAN_REGIST_DT DESC NULLS LAST,
        IAN0.IAN_NO DESC
        ) AS RN
        FROM IMP_ARRV_NTC IAN0
        )
        WHERE RN = 1
        ) IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        WHERE T.TRC_SE_CD = 'IMPORT'
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        FETCH FIRST 1 ROW ONLY
        )),
        W.WIR_OWR_ID = NVL(W.WIR_OWR_ID, (
        SELECT T.TRC_OWR_ID
        FROM TRAN_RCP T
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        IAN0.*,
        ROW_NUMBER() OVER (
        PARTITION BY IAN0.IAN_TRC_NO
        ORDER BY
        CASE WHEN IAN0.IAN_SEND_STTS_CD = 'TRC_NTC_SENT' THEN 0 ELSE 1 END,
        IAN0.IAN_SEND_DT DESC NULLS LAST,
        IAN0.IAN_REGIST_DT DESC NULLS LAST,
        IAN0.IAN_NO DESC
        ) AS RN
        FROM IMP_ARRV_NTC IAN0
        )
        WHERE RN = 1
        ) IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        WHERE T.TRC_SE_CD = 'IMPORT'
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        FETCH FIRST 1 ROW ONLY
        )),
        W.WIR_OWR_NM = NVL(W.WIR_OWR_NM, (
        SELECT O.OWR_NM
        FROM TRAN_RCP T
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        IAN0.*,
        ROW_NUMBER() OVER (
        PARTITION BY IAN0.IAN_TRC_NO
        ORDER BY
        CASE WHEN IAN0.IAN_SEND_STTS_CD = 'TRC_NTC_SENT' THEN 0 ELSE 1 END,
        IAN0.IAN_SEND_DT DESC NULLS LAST,
        IAN0.IAN_REGIST_DT DESC NULLS LAST,
        IAN0.IAN_NO DESC
        ) AS RN
        FROM IMP_ARRV_NTC IAN0
        )
        WHERE RN = 1
        ) IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        WHERE T.TRC_SE_CD = 'IMPORT'
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        FETCH FIRST 1 ROW ONLY
        )),
        W.WIR_WM_ID = NVL(W.WIR_WM_ID, (
        SELECT COALESCE(DFLT.WM_ID, (
        SELECT MIN(WM.WM_ID)
        FROM WAREHOUSE_MANAGER WM
        WHERE NVL(WM.WM_USE_YN, 'Y') = 'Y'
        ))
        FROM (
        SELECT Z.WM_ID, Z.WZ_NO
        FROM WAREHOUSE_ZONE Z
        INNER JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = Z.WM_ID
        WHERE NVL(WM.WM_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_STATUS_CD, 'ACTIVE') = 'ACTIVE'
        ORDER BY Z.WZ_NO
        FETCH FIRST 1 ROW ONLY
        ) DFLT
        )),
        W.WIR_WZ_NO = NVL(W.WIR_WZ_NO, (
        SELECT DFLT.WZ_NO
        FROM (
        SELECT Z.WZ_NO
        FROM WAREHOUSE_ZONE Z
        INNER JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = Z.WM_ID
        WHERE NVL(WM.WM_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_STATUS_CD, 'ACTIVE') = 'ACTIVE'
        ORDER BY Z.WZ_NO
        FETCH FIRST 1 ROW ONLY
        ) DFLT
        )),
        W.WIR_INCO_TERMS_CD = NVL(W.WIR_INCO_TERMS_CD, (
        SELECT T.TRC_INCO_TERMS_CD
        FROM TRAN_RCP T
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        IAN0.*,
        ROW_NUMBER() OVER (
        PARTITION BY IAN0.IAN_TRC_NO
        ORDER BY
        CASE WHEN IAN0.IAN_SEND_STTS_CD = 'TRC_NTC_SENT' THEN 0 ELSE 1 END,
        IAN0.IAN_SEND_DT DESC NULLS LAST,
        IAN0.IAN_REGIST_DT DESC NULLS LAST,
        IAN0.IAN_NO DESC
        ) AS RN
        FROM IMP_ARRV_NTC IAN0
        )
        WHERE RN = 1
        ) IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        WHERE T.TRC_SE_CD = 'IMPORT'
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        FETCH FIRST 1 ROW ONLY
        )),
        W.WIR_STATUS_CD = NVL(W.WIR_STATUS_CD, 'WAIT'),
        W.WIR_WH_REPLY_STATUS_CD = NVL(W.WIR_WH_REPLY_STATUS_CD, 'WAIT')
        /*
        * 도착통지 발송 직후 입고요청 기본 행은 입고신청완료/창고승인대기 상태로 맞춘다.
        * 기존에 더 진행된 상태가 있으면 유지하고, 상태가 없을 때만 WAIT/WAIT로 세팅한다.
        */
        WHERE W.WIR_IO_SE_CD = 'IMP'
        AND W.WIR_GG_NO = (
        SELECT MAX(T.TRC_TFG_NO)
        FROM TRAN_RCP T
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        IAN0.*,
        ROW_NUMBER() OVER (
        PARTITION BY IAN0.IAN_TRC_NO
        ORDER BY
        CASE WHEN IAN0.IAN_SEND_STTS_CD = 'TRC_NTC_SENT' THEN 0 ELSE 1 END,
        IAN0.IAN_SEND_DT DESC NULLS LAST,
        IAN0.IAN_REGIST_DT DESC NULLS LAST,
        IAN0.IAN_NO DESC
        ) AS RN
        FROM IMP_ARRV_NTC IAN0
        )
        WHERE RN = 1
        ) IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        WHERE T.TRC_SE_CD = 'IMPORT'
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo})
        );
        ELSE
        INSERT INTO WH_IN_RPT (
        WIR_NO,
        WIR_GG_NO,
        WIR_OWR_ID,
        WIR_WM_ID,
        WIR_WZ_NO,
        WIR_IN_PLAN_DT,
        WIR_STATUS_CD,
        WIR_WH_REPLY_STATUS_CD,
        WIR_CARGO_MGMT_NO,
        WIR_INCO_TERMS_CD,
        WIR_OWR_NM,
        WIR_IO_SE_CD
        )
        SELECT
        REGEXP_REPLACE(T.TRC_NO, '-[0-9]+$', '-') || LPAD(
        NVL((
        SELECT MAX(TO_NUMBER(REGEXP_SUBSTR(W3.WIR_NO, '[0-9]+$')))
        FROM WH_IN_RPT W3
        WHERE W3.WIR_IO_SE_CD = 'IMP'
        AND W3.WIR_NO LIKE REGEXP_REPLACE(T.TRC_NO, '-[0-9]+$', '-%')
        ), 9000) + 1,
        4,
        '0'
        ) AS WIR_NO,
        T.TRC_TFG_NO,
        T.TRC_OWR_ID,
        COALESCE(DFLT.WM_ID, (
        SELECT MIN(WM.WM_ID)
        FROM WAREHOUSE_MANAGER WM
        WHERE NVL(WM.WM_USE_YN, 'Y') = 'Y'
        )),
        DFLT.WZ_NO,
        NULL,
        'WAIT',
        'WAIT',
        'CARGO-' || T.TRC_NO,
        T.TRC_INCO_TERMS_CD,
        O.OWR_NM,
        'IMP'
        FROM TRAN_RCP T
        LEFT JOIN IMP_RQST IR
        ON IR.IR_NO = REGEXP_REPLACE(
        T.TRC_NO,
        '^TRC-(IMP)-([0-9]{4})([0-9]{2})([0-9]{2})-([0-9]+)$',
        '\1-\2\3\4-\5'
        )
        LEFT JOIN (
        SELECT *
        FROM (
        SELECT
        IAN0.*,
        ROW_NUMBER() OVER (
        PARTITION BY IAN0.IAN_TRC_NO
        ORDER BY
        CASE WHEN IAN0.IAN_SEND_STTS_CD = 'TRC_NTC_SENT' THEN 0 ELSE 1 END,
        IAN0.IAN_SEND_DT DESC NULLS LAST,
        IAN0.IAN_REGIST_DT DESC NULLS LAST,
        IAN0.IAN_NO DESC
        ) AS RN
        FROM IMP_ARRV_NTC IAN0
        )
        WHERE RN = 1
        ) IAN
        ON IAN.IAN_TRC_NO = T.TRC_NO
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        LEFT JOIN (
        SELECT WM_ID, WZ_NO
        FROM (
        SELECT
        Z.WM_ID,
        Z.WZ_NO,
        ROW_NUMBER() OVER (ORDER BY Z.WZ_NO) AS RN
        FROM WAREHOUSE_ZONE Z
        INNER JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = Z.WM_ID
        WHERE NVL(WM.WM_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_USE_YN, 'Y') = 'Y'
        AND NVL(Z.WZ_STATUS_CD, 'ACTIVE') = 'ACTIVE'
        )
        WHERE RN = 1
        ) DFLT
        ON 1 = 1
        WHERE T.TRC_SE_CD = 'IMPORT'
        AND (T.TRC_NO = #{reqNo}
        OR IAN.IAN_NO = #{reqNo}
        OR IAN.IAN_TRC_NO = #{reqNo});
        END IF;
        END;
    </update>
</mapper>
