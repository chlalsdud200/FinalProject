<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.tacs.broker.declare.mapper.IBrokerDeclareMapper">

    <!--
      수입신고서 INSERT (임시저장 / 전송 공용)
      - ID_IR_NO 는 IMP_RQST.IR_NO 의 FK — 사용자가 화면에서 입력한 의뢰번호를 그대로 사용
        (시퀀스/트리거 자체 채번 ❌ — 의뢰서 없이 신고서 만드는 orphan 방지)
      - 모든 #{...} 는 jdbcType 명시 → null 도 안전하게 바인딩
    -->
    <insert id="insertImpDclr" parameterType="kr.or.tacs.vo.broker.declare.ImpDclrVO">
        INSERT INTO IMP_DCLR (
            ID_IR_NO,
            ID_STATUS_CD,
            ID_OFFICER_ID,
            ID_REGIST_DT,
            ID_UPDT_DT,
            <!-- 신고인 -->
            ID_DCLRNT_NM,
            ID_DCLRNT_EML,
            ID_DCLRNT_TELNO,
            <!-- 수입자 -->
            ID_IMPR_NM,
            ID_IMPR_CLNC_CD,
            <!-- 납세의무자 -->
            ID_TAXPYR_NM,
			ID_TAXPYR_CLNC_CD,
			ID_TAXPYR_TELNO,
            ID_TAXPYR_IDNT_SE,
            ID_TAXPYR_IDNT_NO,
            ID_TAXPYR_ZIP,
            ID_TAXPYR_ADDR,
            ID_TAXPYR_DTL_ADDR,
            <!-- 해외공급자 -->
            ID_OVRSS_NM,
            ID_OVRSS_CD,
            ID_OVRSS_CNTRY_CD,
            <!-- 기본신고사항 -->
            ID_DCLR_SE_CD,
            ID_TRDNG_SE_CD,
            ID_IMPORT_CLFC_CD,
            ID_CGO_MNG_NO,
            ID_INSP_PLCE_CD,
            ID_ARVL_YMD,
            ID_SHIPOUT_CNTRY_CD,
            ID_MBL_NO,
            ID_TRNSP_MN_CD,
            ID_CNTNR_SE_CD,
			<!-- 공통사항2: 포장/가격/결제 -->
			ID_TOT_LN_CNT,
			ID_TOT_PKG_CNT,
            ID_TOT_PKG_UNIT_CD,
            ID_TOT_WT,
            ID_ORGN_CERT_YN,
            ID_STLM_AMT,
            ID_DLVR_CNDTN_CD,
            <!-- 공통사항2: 세액 -->
            ID_TOT_TAXT_PRC_KRW,
            ID_TOT_TAXT_PRC_USD,
            ID_TOT_CSTMS_AMT,
            ID_VAT_BASE_AMT,
            ID_TOT_VAT_AMT,
            ID_TOT_TAX_AMT
        ) VALUES (
            #{idIrNo,           jdbcType=VARCHAR},     <!-- IMP_RQST.IR_NO 와 동일 -->
            #{idStatusCd,       jdbcType=VARCHAR},
            #{idOfficerId,      jdbcType=VARCHAR},
            SYSDATE,
            SYSDATE,
            <!-- 신고인 -->
            #{idDclrntNm,       jdbcType=VARCHAR},
            #{idDclrntEml,      jdbcType=VARCHAR},
            #{idDclrntTelno,    jdbcType=VARCHAR},
            <!-- 수입자 -->
            #{idImprNm,         jdbcType=VARCHAR},
            #{idImprClncCd,     jdbcType=VARCHAR},
            <!-- 납세의무자 -->
            #{idTaxpyrNm,       jdbcType=VARCHAR},
			#{idTaxpyrClncCd,   jdbcType=VARCHAR},
			#{idTaxpyrTelno,    jdbcType=VARCHAR},
            #{idTaxpyrIdntSe,   jdbcType=VARCHAR},
            #{idTaxpyrIdntNo,   jdbcType=VARCHAR},
            #{idTaxpyrZip,      jdbcType=VARCHAR},
            #{idTaxpyrAddr,     jdbcType=VARCHAR},
            #{idTaxpyrDtlAddr,  jdbcType=VARCHAR},
            <!-- 해외공급자 -->
            #{idOvrssNm,        jdbcType=VARCHAR},
            #{idOvrssCd,        jdbcType=VARCHAR},
            #{idOvrssCntryCd,   jdbcType=VARCHAR},
            <!-- 기본신고사항 -->
            #{idDclrSeCd,       jdbcType=VARCHAR},
            #{idTrdngSeCd,      jdbcType=VARCHAR},
            #{idImportClfcCd,   jdbcType=VARCHAR},
            #{idCgoMngNo,       jdbcType=VARCHAR},
            #{idInspPlceCd,     jdbcType=VARCHAR},
            #{idArvlYmd,        jdbcType=VARCHAR},
            #{idShipoutCntryCd, jdbcType=VARCHAR},
            #{idMblNo,          jdbcType=VARCHAR},
            #{idTrnspMnCd,      jdbcType=VARCHAR},
            #{idCntnrSeCd,      jdbcType=VARCHAR},
			<!-- 공통사항2: 포장/가격/결제 -->
			#{idTotLnCnt,       jdbcType=NUMERIC},
			#{idTotPkgCnt,      jdbcType=NUMERIC},
            #{idTotPkgUnitCd,   jdbcType=VARCHAR},
            #{idTotWt,          jdbcType=NUMERIC},
            #{idOrgnCertYn,     jdbcType=CHAR},
            #{idStlmAmt,        jdbcType=NUMERIC},
            #{idDlvrCndtnCd,    jdbcType=VARCHAR},
            <!-- 공통사항2: 세액 -->
            #{idTotTaxtPrcKrw,  jdbcType=NUMERIC},
            #{idTotTaxtPrcUsd,  jdbcType=NUMERIC},
            #{idTotCstmsAmt,    jdbcType=NUMERIC},
            #{idVatBaseAmt,     jdbcType=NUMERIC},
            #{idTotVatAmt,      jdbcType=NUMERIC},
            #{idTotTaxAmt,      jdbcType=NUMERIC}
        )
    </insert>

    <!--
      수입신고서 1건 상세 조회 (이어쓰기용)
      - 본인(officerId) 것만 조회 가능
      - 모든 컬럼 lowercase alias 로 자동 camelCase 매핑
    -->
    <select id="selectImpDclrById" resultType="kr.or.tacs.vo.broker.declare.ImpDclrVO">
        SELECT
            id_ir_no,
            id_status_cd,
            id_officer_id,
            id_regist_dt,
            id_updt_dt,
            id_dclrnt_nm,
            id_dclrnt_eml,
            id_dclrnt_telno,
            id_impr_nm,
            id_impr_clnc_cd,
			id_taxpyr_nm,
			id_taxpyr_clnc_cd,
			id_taxpyr_telno,
			id_taxpyr_idnt_se,
            id_taxpyr_idnt_no,
            id_taxpyr_zip,
            id_taxpyr_addr,
            id_taxpyr_dtl_addr,
            id_ovrss_nm,
            id_ovrss_cd,
            id_ovrss_cntry_cd,
            id_dclr_se_cd,
            id_trdng_se_cd,
            id_import_clfc_cd,
            id_cgo_mng_no,
            id_insp_plce_cd,
            id_arvl_ymd,
            id_shipout_cntry_cd,
            id_mbl_no,
            id_trnsp_mn_cd,
            id_cntnr_se_cd,
			id_tot_ln_cnt,
			id_tot_pkg_cnt,
            id_tot_pkg_unit_cd,
            id_tot_wt,
            id_orgn_cert_yn,
            id_stlm_amt,
            id_dlvr_cndtn_cd,
            id_tot_taxt_prc_krw,
            id_tot_taxt_prc_usd,
            id_tot_cstms_amt,
            id_vat_base_amt,
            id_tot_vat_amt,
            id_tot_tax_amt
                    FROM imp_dclr d
         WHERE d.id_ir_no = #{idIrNo}
           AND EXISTS (
               SELECT 1
                 FROM imp_rqst r
                WHERE r.ir_no = d.id_ir_no
                  AND (r.ir_broker_id = #{officerId} OR r.ir_broker_id IS NULL)
                  AND (r.ir_use_yn = 'Y' OR r.ir_use_yn IS NULL)
           )
    </select>

    <!--
      수입신고서 UPDATE (이어쓰기 저장)
      - 본인(officerId) 것만 update 가능
      - 'SUBMIT' 으로 전송된 건은 임시저장 흐름에서 더 이상 수정 불가 → status='TEMP' 조건 추가
      - id_updt_dt 자동 갱신
    -->
    <update id="updateImpDclr" parameterType="kr.or.tacs.vo.broker.declare.ImpDclrVO">
        UPDATE imp_dclr
           SET id_updt_dt          = SYSDATE,
               id_dclrnt_nm        = #{idDclrntNm,        jdbcType=VARCHAR},
               id_dclrnt_eml       = #{idDclrntEml,       jdbcType=VARCHAR},
               id_dclrnt_telno     = #{idDclrntTelno,     jdbcType=VARCHAR},
               id_impr_nm          = #{idImprNm,          jdbcType=VARCHAR},
               id_impr_clnc_cd     = #{idImprClncCd,      jdbcType=VARCHAR},
				id_taxpyr_nm        = #{idTaxpyrNm,        jdbcType=VARCHAR},
				id_taxpyr_clnc_cd   = #{idTaxpyrClncCd,    jdbcType=VARCHAR},
				id_taxpyr_telno     = #{idTaxpyrTelno,     jdbcType=VARCHAR},
				id_taxpyr_idnt_se   = #{idTaxpyrIdntSe,    jdbcType=VARCHAR},
               id_taxpyr_idnt_no   = #{idTaxpyrIdntNo,    jdbcType=VARCHAR},
               id_taxpyr_zip       = #{idTaxpyrZip,       jdbcType=VARCHAR},
               id_taxpyr_addr      = #{idTaxpyrAddr,      jdbcType=VARCHAR},
               id_taxpyr_dtl_addr  = #{idTaxpyrDtlAddr,   jdbcType=VARCHAR},
               id_ovrss_nm         = #{idOvrssNm,         jdbcType=VARCHAR},
               id_ovrss_cd         = #{idOvrssCd,         jdbcType=VARCHAR},
               id_ovrss_cntry_cd   = #{idOvrssCntryCd,    jdbcType=VARCHAR},
               id_dclr_se_cd       = #{idDclrSeCd,        jdbcType=VARCHAR},
               id_trdng_se_cd      = #{idTrdngSeCd,       jdbcType=VARCHAR},
               id_import_clfc_cd   = #{idImportClfcCd,    jdbcType=VARCHAR},
               id_cgo_mng_no       = #{idCgoMngNo,        jdbcType=VARCHAR},
               id_insp_plce_cd     = #{idInspPlceCd,      jdbcType=VARCHAR},
               id_arvl_ymd         = #{idArvlYmd,         jdbcType=VARCHAR},
               id_shipout_cntry_cd = #{idShipoutCntryCd,  jdbcType=VARCHAR},
               id_mbl_no           = #{idMblNo,           jdbcType=VARCHAR},
               id_trnsp_mn_cd      = #{idTrnspMnCd,       jdbcType=VARCHAR},
               id_cntnr_se_cd      = #{idCntnrSeCd,       jdbcType=VARCHAR},
			id_tot_ln_cnt       = #{idTotLnCnt,        jdbcType=NUMERIC},
			id_tot_pkg_cnt      = #{idTotPkgCnt,       jdbcType=NUMERIC},
               id_tot_pkg_unit_cd  = #{idTotPkgUnitCd,    jdbcType=VARCHAR},
               id_tot_wt           = #{idTotWt,           jdbcType=NUMERIC},
               id_orgn_cert_yn     = #{idOrgnCertYn,      jdbcType=CHAR},
               id_stlm_amt         = #{idStlmAmt,         jdbcType=NUMERIC},
               id_dlvr_cndtn_cd    = #{idDlvrCndtnCd,     jdbcType=VARCHAR},
               id_tot_taxt_prc_krw = #{idTotTaxtPrcKrw,   jdbcType=NUMERIC},
               id_tot_taxt_prc_usd = #{idTotTaxtPrcUsd,   jdbcType=NUMERIC},
               id_tot_cstms_amt    = #{idTotCstmsAmt,     jdbcType=NUMERIC},
               id_vat_base_amt     = #{idVatBaseAmt,      jdbcType=NUMERIC},
               id_tot_vat_amt      = #{idTotVatAmt,       jdbcType=NUMERIC},
               id_tot_tax_amt      = #{idTotTaxAmt,       jdbcType=NUMERIC}
          WHERE id_ir_no     = #{idIrNo}
           AND id_status_cd  = 'DCLR_TEMP'
    </update>

    <!--
	  8E-STATUS
	  수입신고서 전송
	
	  상태 흐름:
	  - DCLR_TEMP : 임시저장
	  - DCLR_WAIT : 접수대기
	
	  ID_OFFICER_ID는 세관 담당 공무원 ID이므로
	  관세사 전송 단계에서는 NULL 상태를 유지한다.
	-->
	<update id="submitImpDclr">
	    UPDATE imp_dclr
	       SET id_status_cd = 'DCLR_WAIT',
	           id_dclr_dt   = SYSDATE,
	           id_updt_dt   = SYSDATE
	     WHERE id_ir_no     = #{idIrNo}
	       AND id_status_cd = 'DCLR_TEMP'
	       AND EXISTS (
	           SELECT 1
	             FROM imp_rqst r
	            WHERE r.ir_no = imp_dclr.id_ir_no
	              AND (r.ir_broker_id = #{officerId} OR r.ir_broker_id IS NULL)
	              AND (r.ir_use_yn = 'Y' OR r.ir_use_yn IS NULL)
	       )
	</update>
	
	
	<update id="updateImpDclrItemsToItemDclr">
	    UPDATE imp_dclr_item
	       SET idi_status_cd = 'ITEM_DCLR',
	           idi_updt_dt   = SYSDATE
	     WHERE idi_ir_no = #{idIrNo}
	       AND (idi_status_cd IS NULL OR idi_status_cd = 'TEMP')
	</update>
	
	<!--
	  수입신고서 전송 시 통관의뢰 상태 변경
	  - 신고서 전송 완료 후 IMP_RQST.IR_STATUS_CD 를 CSTM_INPRG 로 변경
	  - 본인 관세사 담당 의뢰서만 변경
	-->
	<update id="updateImpRqstStatusCstmInprg">
	    UPDATE imp_rqst
	       SET ir_status_cd = 'CSTM_INPRG'
	     WHERE ir_no        = #{irNo}
	       AND ir_broker_id = #{brokerId}
	       AND ir_use_yn    = 'Y'
	</update>
	
	<!--
		  8E-DELETE
		  수입신고서 임시저장 삭제
		  - 자식 테이블은 ServiceImpl에서 먼저 삭제
		  - 부모는 본인 TEMP 건만 삭제 가능
		-->
		<delete id="deleteImpDclr">
		    DELETE FROM imp_dclr
           WHERE id_ir_no     = #{idIrNo}
           AND id_status_cd = 'DCLR_TEMP'
           AND EXISTS (
               SELECT 1
                 FROM imp_rqst r
                WHERE r.ir_no = imp_dclr.id_ir_no
                  AND (r.ir_broker_id = #{officerId} OR r.ir_broker_id IS NULL)
                  AND (r.ir_use_yn = 'Y' OR r.ir_use_yn IS NULL)
           )
		</delete>
    <!-- ============================================================
         자식 — IMP_DCLR_ITEM (란사항)
         ============================================================ -->

    <!-- 자식 1행 INSERT -->
    <insert id="insertImpDclrItem" parameterType="kr.or.tacs.vo.broker.declare.ImpDclrItemVO">
        INSERT INTO imp_dclr_item (
            idi_sn,
            idi_ir_no,
            IDI_STATUS_CD,
            idi_cstms_dvsn_cd,
            idi_hs_cd,
            idi_taxt_stndrd_cd,
            idi_taxt_rt,
            idi_dclr_gdsnm,
            idi_trdmk_nm,
            idi_trdmk_cd,
            idi_trdng_gdsnm,
            idi_taxt_prc_krw,
            idi_taxt_prc_usd,
            idi_net_wt,
            idi_qty,
            idi_qty_unit_cd,
            idi_orgn_cntry_cd,
            idi_orgn_dtrmn_cd,
            idi_regist_dt,
            idi_updt_dt
        ) VALUES (
            #{idiSn,            jdbcType=NUMERIC},
            #{idiIrNo,          jdbcType=VARCHAR},
             NVL(#{idiStatusCd}, 'ITEM_DCLR'),
            #{idiCstmsDvsnCd,   jdbcType=VARCHAR},
            #{idiHsCd,          jdbcType=VARCHAR},
            #{idiTaxtStndrdCd,  jdbcType=VARCHAR},
            #{idiTaxtRt,        jdbcType=NUMERIC},
            #{idiDclrGdsnm,     jdbcType=VARCHAR},
            #{idiTrdmkNm,       jdbcType=VARCHAR},
            #{idiTrdmkCd,       jdbcType=VARCHAR},
            #{idiTrdngGdsnm,    jdbcType=VARCHAR},
            #{idiTaxtPrcKrw,    jdbcType=NUMERIC},
            #{idiTaxtPrcUsd,    jdbcType=NUMERIC},
            #{idiNetWt,         jdbcType=NUMERIC},
            #{idiQty,           jdbcType=NUMERIC},
            #{idiQtyUnitCd,     jdbcType=VARCHAR},
            #{idiOrgnCntryCd,   jdbcType=VARCHAR},
            #{idiOrgnDtrmnCd,   jdbcType=VARCHAR},
            SYSDATE,
            SYSDATE
        )
    </insert>

    <!-- 부모(idIrNo) 의 모든 자식 행 삭제 (delete-all then insert 패턴용) -->
    <delete id="deleteImpDclrItemsByIrNo" parameterType="String">
        DELETE FROM imp_dclr_item
         WHERE idi_ir_no = #{idIrNo}
    </delete>

    <!-- 부모(idIrNo) 의 자식 목록 조회 — 이어쓰기 시 폼 복원용 -->
    <select id="selectImpDclrItemListByIrNo" parameterType="String"
            resultType="kr.or.tacs.vo.broker.declare.ImpDclrItemVO">
        SELECT
            idi_sn,
            idi_ir_no,
            idi_cstms_dvsn_cd,
            idi_hs_cd,
            idi_taxt_stndrd_cd,
            idi_taxt_rt,
            idi_dclr_gdsnm,
            idi_trdmk_nm,
            idi_trdmk_cd,
            idi_trdng_gdsnm,
            idi_taxt_prc_krw,
            idi_taxt_prc_usd,
            idi_net_wt,
            idi_qty,
            idi_qty_unit_cd,
            idi_orgn_cntry_cd,
            idi_orgn_dtrmn_cd,
            idi_regist_dt,
            idi_updt_dt
          FROM imp_dclr_item
         WHERE idi_ir_no = #{idIrNo}
         ORDER BY idi_sn
    </select>

    <!-- ============================================================
         자식 — IMP_DCLR_ITEM_MDLSPEC (모델/규격) — 4차
         ============================================================ -->

    <!-- 모델/규격 1행 INSERT -->
    <insert id="insertImpDclrItemMdlspec" parameterType="kr.or.tacs.vo.broker.declare.ImpDclrItemMdlspecVO">
        INSERT INTO imp_dclr_item_mdlspec (
            idim_mdlspec_sn,
            idim_sn,
            idim_ir_no,
            idim_mdlspec_no,
            idim_mdlspec_nm,
            idim_net_wt,
            idim_qty1,
            idim_qty1_unit_cd,
            idim_qty2,
            idim_qty2_unit_cd,
            idim_unit_prc,
            idim_amt
        ) VALUES (
            #{idimMdlspecSn,            jdbcType=VARCHAR},
            #{idimSn,         jdbcType=NUMERIC},
            #{idimIrNo,       jdbcType=VARCHAR},
            #{idimMdlspecNo,  jdbcType=VARCHAR},
            #{idimMdlspecNm,  jdbcType=VARCHAR},
            #{idimNetWt,      jdbcType=NUMERIC},
            #{idimQty1,       jdbcType=NUMERIC},
            #{idimQty1UnitCd, jdbcType=VARCHAR},
            #{idimQty2,       jdbcType=NUMERIC},
            #{idimQty2UnitCd, jdbcType=VARCHAR},
            #{idimUnitPrc,    jdbcType=NUMERIC},
            #{idimAmt,        jdbcType=NUMERIC}
        )
    </insert>

    <!-- 부모(idIrNo) 의 모든 모델/규격 행 삭제 -->
    <delete id="deleteImpDclrItemMdlspecsByIrNo" parameterType="String">
        DELETE FROM imp_dclr_item_mdlspec
         WHERE idim_ir_no = #{idIrNo}
    </delete>

    <!-- 부모(idIrNo) 의 모델/규격 목록 조회 (이어쓰기용) -->
    <select id="selectImpDclrItemMdlspecListByIrNo" parameterType="String"
            resultType="kr.or.tacs.vo.broker.declare.ImpDclrItemMdlspecVO">
        SELECT
            "KEY"             AS "key",
            idim_sn,
            idim_ir_no,
            idim_mdlspec_no,
            idim_mdlspec_nm,
            idim_net_wt,
            idim_qty1,
            idim_qty1_unit_cd,
            idim_qty2,
            idim_qty2_unit_cd,
            idim_unit_prc,
            idim_amt
          FROM imp_dclr_item_mdlspec
         WHERE idim_ir_no = #{idIrNo}
         ORDER BY idim_sn
    </select>

    <!-- ============================================================
         IMP_RQST (의뢰서) — 8B [조회] 버튼 / 8C 검색 모달 용도
         ============================================================ -->

    <!--
      의뢰번호 1건 조회 — 본인 담당 의뢰서 또는 미배정(NULL) 의뢰서 허용
      관세사가 자기 담당이거나 아직 미배정인 의뢰서만 신고서 작성 가능
    -->
    <!--
      파일그룹(TFG_NO) 의 PDF 첨부파일 조회 — AI 파싱 대상
      TACS_FILE_MAP ↔ DOCS_FILE_DATA join, pdf 확장자만, 미삭제만
    -->
    <select id="selectPdfFilesByTfgNo" parameterType="long"
            resultType="kr.or.tacs.vo.broker.TfgFileDto">
        SELECT
            d.dfi_file_no  AS dfiFileNo,
            d.dfi_org_nm   AS orgNm,
            d.dfi_str_nm   AS strNm,
            d.dfi_path          AS path,
			d.dfi_ext           AS ext,
			d.dfi_drive_file_id AS driveFileId,
            m.tfm_doc_ty_cd AS docTyCd
          FROM tacs_file_map m
          JOIN docs_file_data d ON d.dfi_file_no = m.tfm_dfi_no
         WHERE m.tfm_tfg_no = #{tfgNo}
           AND (d.dfi_del_yn = 'N' OR d.dfi_del_yn IS NULL)
           AND LOWER(d.dfi_ext) = 'pdf'
         ORDER BY d.dfi_regist_dt
    </select>

    <!-- 로그인 사용자(관세사) BROKER 1건 조회 — 신고인 영역 자동 채움 -->
    <select id="selectBrokerById" parameterType="String" resultType="kr.or.tacs.vo.BrokerVO">
        SELECT
            broker_id,
            broker_nm,
            broker_office_nm,
            broker_reg_no,
            broker_bizrno,
            broker_email,
            broker_telno
          FROM broker
         WHERE broker_id = #{brokerId}
           AND (broker_use_yn = 'Y' OR broker_use_yn IS NULL)
    </select>

    <!--
      의뢰서 검색 (돋보기 모달) — 본인 담당 또는 미배정 의뢰서 중
      의뢰번호 / B/L / 화주ID / 통관고유부호 부분일치
    -->
    <select id="selectImpRqstList" resultType="kr.or.tacs.vo.broker.declare.ImpRqstVO">
    SELECT
        r.ir_no,
        r.ir_owr_id,
        r.ir_broker_id,
        r.ir_arrv_port_cd,
        p.port_nm AS ir_arrv_port_nm,
        r.ir_status_cd,
        r.ir_cstm_idf_no,
        r.ir_corp_reg_no,
        r.ir_arrv_schd_ymd,
        r.ir_bl_awb_no,
        r.ir_cn,
        r.ir_dclr_curr_cd,
        r.ir_invc_amt,
        r.ir_dt,
        r.ir_regist_dt
      FROM imp_rqst r
      LEFT JOIN port p
             ON p.port_cd = r.ir_arrv_port_cd
            AND p.port_use_yn = 'Y'
     WHERE (r.ir_broker_id = #{brokerId} OR r.ir_broker_id IS NULL)
       AND (r.ir_use_yn = 'Y' OR r.ir_use_yn IS NULL)
       AND r.ir_status_cd = 'CSTM_ACPT'
       <if test="keyword != null and keyword != ''">
       AND (
              r.ir_no          LIKE '%' || #{keyword} || '%'
           OR r.ir_cn   LIKE '%' || #{keyword} || '%'
           OR r.ir_owr_id      LIKE '%' || #{keyword} || '%'
           OR r.ir_cstm_idf_no LIKE '%' || #{keyword} || '%'
           OR p.port_nm        LIKE '%' || #{keyword} || '%'
       )
       </if>
     ORDER BY r.ir_regist_dt DESC, r.ir_no DESC
</select>

    <select id="selectImpRqstById" resultType="kr.or.tacs.vo.broker.declare.ImpRqstVO">
        SELECT
            ir_no,
            ir_owr_id,
            ir_broker_id,
            ir_arrv_port_cd,
            ir_tfg_no,
            ir_status_cd,
            ir_cstm_idf_no,
            ir_corp_reg_no,
            ir_arrv_schd_ymd,
            ir_bl_awb_no,
            ir_dclr_curr_cd,
            ir_invc_amt,
            ir_cn,
            ir_dt,
            ir_acpt_dt,
            ir_use_yn,
            ir_regist_dt,
            ir_pay_mthd_cd,
            ir_pay_type_cd,
            ir_instl_pay_cnt,
            ir_comment
          FROM imp_rqst
         WHERE ir_no = #{irNo}
           AND (ir_broker_id = #{brokerId} OR ir_broker_id IS NULL)
           AND (ir_use_yn = 'Y' OR ir_use_yn IS NULL)
    </select>

	    <!--
      8D-ATTACH
      수입의뢰 파일그룹번호 갱신

      사용 시점:
      - 수입신고서 첨부파일 업로드 시
      - IMP_RQST.IR_TFG_NO가 NULL이면 공통 파일서비스에서 새 TFG_NO 생성
      - 생성된 TFG_NO를 해당 IR_NO에 연결
    -->
    <update id="updateImpRqstTfgNo">
        UPDATE IMP_RQST
           SET IR_TFG_NO = #{tfgNo}
         WHERE IR_NO = #{irNo}
    </update>
    <!--
      임시문서함 — 로그인한 broker 의 임시저장 수입신고서 목록
      - 컬럼은 lowercase alias 로 받아 BrokerVO 처럼 자동 camelCase 매핑
      - 화면에 필요한 핵심 컬럼만 SELECT (성능)
    -->
    <select id="selectImpDraftList" parameterType="String" resultType="kr.or.tacs.vo.broker.declare.ImpDclrVO">
        SELECT
            id_ir_no,
            id_status_cd,
            id_impr_nm,
            id_impr_clnc_cd,
            id_dclr_se_cd,
            id_arvl_ymd,
            id_mbl_no,
            id_regist_dt,
            id_updt_dt
          FROM imp_dclr
          WHERE id_status_cd = 'DCLR_TEMP'
           AND EXISTS (
               SELECT 1
                 FROM imp_rqst r
                WHERE r.ir_no = imp_dclr.id_ir_no
                  AND (r.ir_broker_id = #{officerId} OR r.ir_broker_id IS NULL)
                  AND (r.ir_use_yn = 'Y' OR r.ir_use_yn IS NULL)
           )
    </select>




		<select id="selectCountryList"
		        parameterType="string"
		        resultType="map">
		    SELECT
		        COUNTRY_CD AS "countryCd",
		        COUNTRY_NM_KR AS "countryNmKr",
		        COUNTRY_NM_EN AS "countryNmEn"
		    FROM COUNTRY
		    WHERE COUNTRY_USE_YN = 'Y'
		    <if test="_parameter != null and _parameter != ''">
		        AND (
		               UPPER(COUNTRY_CD) LIKE '%' || UPPER(#{_parameter}) || '%'
		            OR COUNTRY_NM_KR LIKE '%' || #{_parameter} || '%'
		            OR UPPER(COUNTRY_NM_EN) LIKE '%' || UPPER(#{_parameter}) || '%'
		        )
		    </if>
		    ORDER BY COUNTRY_CD
		</select>

				<select id="selectOwnerList"
				        parameterType="string"
				        resultType="map">
				    SELECT
				        OWR_ID AS "owrId",
				        OWR_NM AS "owrNm",
				        OWR_BIZRNO AS "owrBizrno",
				        OWR_IDENT_NO AS "owrIdentNo",
				        OWR_CSTM_IDF_NO AS "owrCstmIdfNo",
				        OWR_EMAIL AS "owrEmail",
				        OWR_TELNO AS "owrTelno",
				        OWR_ZIP AS "owrZip",
				        OWR_ADRES AS "owrAdres",
				        OWR_DETAIL_ADRES AS "owrDetailAdres",
				        OWR_CORP_REG_NO AS "owrCorpRegNo"
				    FROM OWNER
				    WHERE OWR_USE_YN = 'Y'
				    <if test="_parameter != null and _parameter != ''">
				        AND (
				               UPPER(OWR_ID) LIKE '%' || UPPER(#{_parameter}) || '%'
				            OR OWR_NM LIKE '%' || #{_parameter} || '%'
				            OR UPPER(OWR_CSTM_IDF_NO) LIKE '%' || UPPER(#{_parameter}) || '%'
				            OR OWR_BIZRNO LIKE '%' || #{_parameter} || '%'
				            OR OWR_IDENT_NO LIKE '%' || #{_parameter} || '%'
				        )
				    </if>
				    ORDER BY OWR_NM
				</select>
				
				
				
				
				
				<select id="selectCommonCodeList"
			        parameterType="map"
			        resultType="map">
			    SELECT
			        CC_CD AS "ccCd",
			        CC_NM AS "ccNm",
			        CC_DESC AS "ccDesc",
			        CC_SORT_SN AS "ccSortSn"
			    FROM COM_CODE
			    WHERE CC_USE_YN = 'Y'
			      AND CC_CCG_ID = #{groupId}
			    <if test="keyword != null and keyword != ''">
			      AND (
			             UPPER(CC_CD) LIKE '%' || UPPER(#{keyword}) || '%'
			          OR UPPER(CC_NM) LIKE '%' || UPPER(#{keyword}) || '%'
			          OR UPPER(CC_DESC) LIKE '%' || UPPER(#{keyword}) || '%'
			      )
			    </if>
			    ORDER BY CC_SORT_SN, CC_CD
			</select>
			
			
			<!-- HS코드 기본정보 조회 -->
				<select id="selectHsCodeInfo"
				        parameterType="string"
				        resultType="map">
				    SELECT
				        HS_CODE AS "hsCode",
				        HS_NAME AS "hsName",
				        HS_TARIFF_RATE AS "basicTariffRate"
				    FROM HS_CODE
				    WHERE HS_CODE = #{_parameter}
				</select>
				
				<!-- FTA/협정세율 조회
				     조건:
				     - HS코드 일치
				     - 원산지국가 일치
				     - 현재일자가 적용기간 안에 있음
				     - 여러 협정세율이 있으면 낮은 세율 우선 -->
				<select id="selectFtaTariffInfo"
				        parameterType="map"
				        resultType="map">
				    SELECT *
				    FROM (
				        SELECT
				            F.HS_CODE AS "hsCode",
				            F.COUNTRY_CD AS "countryCd",
				            F.AGREEMENT_CD AS "agreementCd",
				            F.AGREEMENT_NM AS "agreementNm",
				            F.FTA_TARIFF_RATE AS "ftaTariffRate",
				            F.ORGN_DTRMN_CD AS "orgnDtrmnCd",
				            F.APPLY_START_YMD AS "applyStartYmd",
				            F.APPLY_END_YMD AS "applyEndYmd"
				        FROM FTA_TARIFF F
				        WHERE F.HS_CODE = #{hsCode}
				          AND F.COUNTRY_CD = #{countryCd}
				          AND NVL(F.USE_YN, 'Y') = 'Y'
				          AND (F.APPLY_START_YMD IS NULL OR F.APPLY_START_YMD &lt;= #{baseYmd})
				          AND (F.APPLY_END_YMD IS NULL OR F.APPLY_END_YMD &gt;= #{baseYmd})
				        ORDER BY
				            F.FTA_TARIFF_RATE ASC,
				            F.APPLY_START_YMD DESC,
				            F.AGREEMENT_CD
				    )
				    WHERE ROWNUM = 1
				</select>
				
		<!-- HS코드 목록 검색: HS_CODE + HS_KEYWORD -->
			<!-- HS코드 목록 검색: HS_CODE + HS_KEYWORD + HS_CLASS 계층정보 -->
		<!-- HS코드 목록 검색: HS_CODE + HS_KEYWORD + HS_CLASS 계층정보 -->
		<select id="selectHsCodeList"
		        parameterType="string"
		        resultType="map">
		    SELECT *
		    FROM (
		        SELECT
		            R."hsCode",
		            R."hsName",
		            R."basicTariffRate",
		            R."hsClassNm",
		            R."hsClassDesc",
		            R."hsClassPath",
		            R."sortScore"
		        FROM (
		            SELECT
		                H.HS_CODE AS "hsCode",
		                H.HS_NAME AS "hsName",
		                H.HS_TARIFF_RATE AS "basicTariffRate",
		                C.HS_CLASS_NM AS "hsClassNm",
		                C.HS_CLASS_DESC AS "hsClassDesc",
		                (
		                    NVL2(P4.HS_CLASS_NM, P4.HS_CLASS_NM || ' > ', '') ||
		                    NVL2(P3.HS_CLASS_NM, P3.HS_CLASS_NM || ' > ', '') ||
		                    NVL2(P2.HS_CLASS_NM, P2.HS_CLASS_NM || ' > ', '') ||
		                    NVL2(P1.HS_CLASS_NM, P1.HS_CLASS_NM || ' > ', '') ||
		                    NVL(C.HS_CLASS_NM, H.HS_NAME)
		                ) AS "hsClassPath",
		                MAX(
		                    CASE
		                        WHEN #{_parameter} IS NULL OR #{_parameter} = '' THEN 0
		
		                        WHEN REPLACE(UPPER(H.HS_CODE), '.', '') = REPLACE(UPPER(#{_parameter}), '.', '') THEN 1000
		                        WHEN UPPER(H.HS_CODE) LIKE REPLACE(UPPER(#{_parameter}), '.', '') || '%' THEN 900
		
		                        WHEN UPPER(H.HS_NAME) = UPPER(#{_parameter}) THEN 800
		                        WHEN UPPER(H.HS_NAME) LIKE '%' || UPPER(#{_parameter}) || '%' THEN 700
		
		                        WHEN UPPER(K.KEYWORD) = UPPER(#{_parameter}) THEN 650
		                        WHEN UPPER(K.KEYWORD) LIKE '%' || UPPER(#{_parameter}) || '%' THEN 600
		
		                        WHEN UPPER(C.HS_CLASS_NM) = UPPER(#{_parameter}) THEN 550
		                        WHEN UPPER(C.HS_CLASS_NM) LIKE '%' || UPPER(#{_parameter}) || '%' THEN 500
		                        WHEN UPPER(C.HS_CLASS_DESC) LIKE '%' || UPPER(#{_parameter}) || '%' THEN 450
		
		                        WHEN UPPER(P1.HS_CLASS_NM) LIKE '%' || UPPER(#{_parameter}) || '%' THEN 350
		                        WHEN UPPER(P2.HS_CLASS_NM) LIKE '%' || UPPER(#{_parameter}) || '%' THEN 300
		                        WHEN UPPER(P3.HS_CLASS_NM) LIKE '%' || UPPER(#{_parameter}) || '%' THEN 250
		                        WHEN UPPER(P4.HS_CLASS_NM) LIKE '%' || UPPER(#{_parameter}) || '%' THEN 200
		
		                        ELSE 0
		                    END
		                    + NVL(K.KEYWORD_WEIGHT, 1)
		                ) AS "sortScore"
		            FROM HS_CODE H
		            LEFT JOIN HS_KEYWORD K
		              ON H.HS_CODE = K.HS_CODE
		             AND NVL(K.USE_YN, 'Y') = 'Y'
		            LEFT JOIN HS_CLASS C
		              ON H.HS_CODE = C.HS_CLASS_CD
		             AND NVL(C.USE_YN, 'Y') = 'Y'
		            LEFT JOIN HS_CLASS P1
		              ON C.PARENT_HS_CLASS_CD = P1.HS_CLASS_CD
		             AND NVL(P1.USE_YN, 'Y') = 'Y'
		            LEFT JOIN HS_CLASS P2
		              ON P1.PARENT_HS_CLASS_CD = P2.HS_CLASS_CD
		             AND NVL(P2.USE_YN, 'Y') = 'Y'
		            LEFT JOIN HS_CLASS P3
		              ON P2.PARENT_HS_CLASS_CD = P3.HS_CLASS_CD
		             AND NVL(P3.USE_YN, 'Y') = 'Y'
		            LEFT JOIN HS_CLASS P4
		              ON P3.PARENT_HS_CLASS_CD = P4.HS_CLASS_CD
		             AND NVL(P4.USE_YN, 'Y') = 'Y'
		            WHERE 1 = 1
		            <if test="_parameter != null and _parameter != ''">
		                AND (
		                       UPPER(H.HS_CODE) LIKE '%' || REPLACE(UPPER(#{_parameter}), '.', '') || '%'
		                    OR UPPER(H.HS_NAME) LIKE '%' || UPPER(#{_parameter}) || '%'
		                    OR UPPER(K.KEYWORD) LIKE '%' || UPPER(#{_parameter}) || '%'
		                    OR UPPER(C.HS_CLASS_NM) LIKE '%' || UPPER(#{_parameter}) || '%'
		                    OR UPPER(C.HS_CLASS_DESC) LIKE '%' || UPPER(#{_parameter}) || '%'
		                    OR UPPER(P1.HS_CLASS_NM) LIKE '%' || UPPER(#{_parameter}) || '%'
		                    OR UPPER(P1.HS_CLASS_DESC) LIKE '%' || UPPER(#{_parameter}) || '%'
		                    OR UPPER(P2.HS_CLASS_NM) LIKE '%' || UPPER(#{_parameter}) || '%'
		                    OR UPPER(P2.HS_CLASS_DESC) LIKE '%' || UPPER(#{_parameter}) || '%'
		                    OR UPPER(P3.HS_CLASS_NM) LIKE '%' || UPPER(#{_parameter}) || '%'
		                    OR UPPER(P3.HS_CLASS_DESC) LIKE '%' || UPPER(#{_parameter}) || '%'
		                    OR UPPER(P4.HS_CLASS_NM) LIKE '%' || UPPER(#{_parameter}) || '%'
		                    OR UPPER(P4.HS_CLASS_DESC) LIKE '%' || UPPER(#{_parameter}) || '%'
		                )
		            </if>
		            GROUP BY
		                H.HS_CODE,
		                H.HS_NAME,
		                H.HS_TARIFF_RATE,
		                C.HS_CLASS_NM,
		                C.HS_CLASS_DESC,
		                (
		                    NVL2(P4.HS_CLASS_NM, P4.HS_CLASS_NM || ' > ', '') ||
		                    NVL2(P3.HS_CLASS_NM, P3.HS_CLASS_NM || ' > ', '') ||
		                    NVL2(P2.HS_CLASS_NM, P2.HS_CLASS_NM || ' > ', '') ||
		                    NVL2(P1.HS_CLASS_NM, P1.HS_CLASS_NM || ' > ', '') ||
		                    NVL(C.HS_CLASS_NM, H.HS_NAME)
		                )
		        ) R
		        ORDER BY R."sortScore" DESC, R."hsCode"
		    )
		    WHERE ROWNUM &lt;= 50
		</select>
			
			
			
			
	       <!-- Milvus 검색 결과 doc_id 목록으로 HS 추천 후보 조회 + 사용빈도 -->
			<select id="selectHsRecommendByDocIds"
			        parameterType="map"
			        resultType="map">
			    SELECT
			        HRC.HS_DOC_ID AS "hsDocId",
			        HRC.HS_CODE AS "hsCode",
			        H.HS_NAME AS "hsName",
			        H.HS_TARIFF_RATE AS "basicTariffRate",
			        HRC.HS_CHUNK_INDEX AS "chunkIndex",
			        NVL(U.USE_COUNT, 0) AS "useCount"
			    FROM HS_REF_CHUNK HRC
			    LEFT JOIN HS_CODE H
			      ON HRC.HS_CODE = H.HS_CODE
			    LEFT JOIN (
			        SELECT
			            I.IDI_HS_CD AS HS_CODE,
			            COUNT(*) AS USE_COUNT
			        FROM IMP_DCLR_ITEM I
			        JOIN IMP_DCLR D
			          ON D.ID_IR_NO = I.IDI_IR_NO
			        WHERE I.IDI_HS_CD IS NOT NULL
			          AND D.ID_STATUS_CD != 'DCLR_TEMP'
			        GROUP BY I.IDI_HS_CD
			    ) U
			      ON U.HS_CODE = HRC.HS_CODE
			    WHERE HRC.HS_DOC_ID IN
			    <foreach collection="docIds" item="docId" open="(" separator="," close=")">
			        #{docId}
			    </foreach>
			</select>


			<!-- HS 벡터 적재용 원천 데이터 조회
     - HS_CODE 1건 = Milvus Document 1건
     - HS명, 분류경로, 키워드, 사용빈도를 하나의 검색용 문장으로 만들기 위한 데이터
		-->
		<select id="selectHsVectorSourceList"
		        resultType="map">
		    SELECT
		        R."hsCode",
		        R."hsName",
		        R."basicTariffRate",
		        R."hsClassNm",
		        R."hsClassDesc",
		        R."hsClassPath",
		        R."keywords",
		        NVL(U.USE_COUNT, 0) AS "useCount"
		    FROM (
		        SELECT
		            H.HS_CODE AS "hsCode",
		            H.HS_NAME AS "hsName",
		            H.HS_TARIFF_RATE AS "basicTariffRate",
		            C.HS_CLASS_NM AS "hsClassNm",
		            C.HS_CLASS_DESC AS "hsClassDesc",
		            (
		                NVL2(P4.HS_CLASS_NM, P4.HS_CLASS_NM || ' > ', '') ||
		                NVL2(P3.HS_CLASS_NM, P3.HS_CLASS_NM || ' > ', '') ||
		                NVL2(P2.HS_CLASS_NM, P2.HS_CLASS_NM || ' > ', '') ||
		                NVL2(P1.HS_CLASS_NM, P1.HS_CLASS_NM || ' > ', '') ||
		                NVL(C.HS_CLASS_NM, H.HS_NAME)
		            ) AS "hsClassPath",
		            LISTAGG(K.KEYWORD, ', ') WITHIN GROUP (ORDER BY K.KEYWORD) AS "keywords"
		        FROM HS_CODE H
		        LEFT JOIN HS_KEYWORD K
		          ON H.HS_CODE = K.HS_CODE
		         AND NVL(K.USE_YN, 'Y') = 'Y'
		        LEFT JOIN HS_CLASS C
		          ON H.HS_CODE = C.HS_CLASS_CD
		         AND NVL(C.USE_YN, 'Y') = 'Y'
		        LEFT JOIN HS_CLASS P1
		          ON C.PARENT_HS_CLASS_CD = P1.HS_CLASS_CD
		         AND NVL(P1.USE_YN, 'Y') = 'Y'
		        LEFT JOIN HS_CLASS P2
		          ON P1.PARENT_HS_CLASS_CD = P2.HS_CLASS_CD
		         AND NVL(P2.USE_YN, 'Y') = 'Y'
		        LEFT JOIN HS_CLASS P3
		          ON P2.PARENT_HS_CLASS_CD = P3.HS_CLASS_CD
		         AND NVL(P3.USE_YN, 'Y') = 'Y'
		        LEFT JOIN HS_CLASS P4
		          ON P3.PARENT_HS_CLASS_CD = P4.HS_CLASS_CD
		         AND NVL(P4.USE_YN, 'Y') = 'Y'
		        GROUP BY
		            H.HS_CODE,
		            H.HS_NAME,
		            H.HS_TARIFF_RATE,
		            C.HS_CLASS_NM,
		            C.HS_CLASS_DESC,
		            (
		                NVL2(P4.HS_CLASS_NM, P4.HS_CLASS_NM || ' > ', '') ||
		                NVL2(P3.HS_CLASS_NM, P3.HS_CLASS_NM || ' > ', '') ||
		                NVL2(P2.HS_CLASS_NM, P2.HS_CLASS_NM || ' > ', '') ||
		                NVL2(P1.HS_CLASS_NM, P1.HS_CLASS_NM || ' > ', '') ||
		                NVL(C.HS_CLASS_NM, H.HS_NAME)
		            )
		    ) R
		    LEFT JOIN (
		        SELECT
		            I.IDI_HS_CD AS HS_CODE,
		            COUNT(*) AS USE_COUNT
		        FROM IMP_DCLR_ITEM I
		        JOIN IMP_DCLR D
		          ON D.ID_IR_NO = I.IDI_IR_NO
		        WHERE I.IDI_HS_CD IS NOT NULL
		          AND D.ID_STATUS_CD != 'DCLR_TEMP'
		        GROUP BY I.IDI_HS_CD
		    ) U
		      ON U.HS_CODE = R."hsCode"
		      WHERE ROWNUM &lt;= 5
		    WHERE R."hsCode" IS NOT NULL
		    ORDER BY R."hsCode"
		</select>


			<!-- Milvus metadata hsCode 목록으로 HS 추천 후보 조회 -->
			<select id="selectHsRecommendByHsCodes"
			        parameterType="map"
			        resultType="map">
			    SELECT *
			    FROM (
			        SELECT
			            H.HS_CODE AS "hsCode",
			            H.HS_NAME AS "hsName",
			            H.HS_TARIFF_RATE AS "basicTariffRate"
			        FROM HS_CODE H
			        WHERE H.HS_CODE IN
			        <foreach collection="hsCodes" item="hsCode" open="(" separator="," close=")">
			            #{hsCode}
			        </foreach>
			        ORDER BY H.HS_CODE
			    )
			    WHERE ROWNUM &lt;= 5
			</select>

			<!-- HS코드 목록으로 HS 후보 + 사용빈도 조회 -->
			<select id="selectHsRecommendWithUsageByHsCodes"
			        parameterType="map"
			        resultType="map">
			    SELECT
			        H.HS_CODE AS "hsCode",
			        H.HS_NAME AS "hsName",
			        H.HS_TARIFF_RATE AS "basicTariffRate",
			        NVL(U.USE_COUNT, 0) AS "useCount"
			    FROM HS_CODE H
			    LEFT JOIN (
			        SELECT
			            I.IDI_HS_CD AS HS_CODE,
			            COUNT(*) AS USE_COUNT
			        FROM IMP_DCLR_ITEM I
			        JOIN IMP_DCLR D
			          ON D.ID_IR_NO = I.IDI_IR_NO
			        WHERE I.IDI_HS_CD IS NOT NULL
			          AND D.ID_STATUS_CD != 'DCLR_TEMP'
			        GROUP BY I.IDI_HS_CD
			    ) U
			      ON U.HS_CODE = H.HS_CODE
			    WHERE H.HS_CODE IN
			    <foreach collection="hsCodes" item="hsCode" open="(" separator="," close=")">
			        #{hsCode}
			    </foreach>
			</select>



			<!-- HS분류계층 자식 목록 조회
			     parentCd 없으면 최상위 PART 조회
			     parentCd 있으면 해당 부모의 자식 조회 -->
			<select id="selectHsClassChildren"
			        parameterType="string"
			        resultType="map">
			    SELECT
			        C.HS_CLASS_CD AS "hsClassCd",
			        C.HS_CLASS_LEVEL_CD AS "hsClassLevelCd",
			        C.HS_CLASS_NM AS "hsClassNm",
			        C.HS_CLASS_DESC AS "hsClassDesc",
			        C.PARENT_HS_CLASS_CD AS "parentHsClassCd",
			        C.SELECTABLE_YN AS "selectableYn",
			        C.SORT_SN AS "sortSn",
			        H.HS_CODE AS "hsCode",
			        H.HS_NAME AS "hsName",
			        H.HS_TARIFF_RATE AS "basicTariffRate",
			        (
			            SELECT COUNT(1)
			            FROM HS_CLASS CH
			            WHERE CH.PARENT_HS_CLASS_CD = C.HS_CLASS_CD
			              AND CH.USE_YN = 'Y'
			        ) AS "childCount"
			    FROM HS_CLASS C
			    LEFT JOIN HS_CODE H
			      ON C.HS_CLASS_CD = H.HS_CODE
			    WHERE C.USE_YN = 'Y'
			    <choose>
			        <when test="parentCd == null or parentCd == ''">
					    AND C.PARENT_HS_CLASS_CD IS NULL
					    AND C.HS_CLASS_LEVEL_CD = 'PART'
					</when>
			        <otherwise>
			            AND C.PARENT_HS_CLASS_CD = #{parentCd}
			        </otherwise>
			    </choose>
			    ORDER BY C.SORT_SN, C.HS_CLASS_CD
			</select>

</mapper>
