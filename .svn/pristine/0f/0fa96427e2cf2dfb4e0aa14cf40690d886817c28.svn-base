<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<c:set var="ctx" value="${pageContext.request.contextPath}" />
<!DOCTYPE html>
<html lang="ko">
<head>
    <%@ include file="/WEB-INF/views/broker/common/meta.jsp" %>
    <link rel="stylesheet" href="${ctx}/resources/css/broker/common.css">
    <link rel="stylesheet" href="${ctx}/resources/css/broker/pages/quarantine.css">
    <title>검역 관리 | TACS</title>
</head>
<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/broker/common/sidebar.jsp" %>
    <div class="main-wrap">
        <%@ include file="/WEB-INF/views/broker/common/header.jsp" %>
        <div class="content">
<%-- 검역 관리 페이지 (style은 common.css, script는 pages/quarantine.js) --%>
      <div class="page active" id="pg-quarantine">


        <div class="sub-page">
          <h2><span class="material-symbols-outlined">health_and_safety</span> 검역 관리</h2>
          <div class="sub-tabs" id="tabs-qu">
            <a class="sub-tab ${activeSub eq 'result' ? 'active' : ''}" href="${ctx}/broker/quarantine/result.do">검역결과조회</a>
            <a class="sub-tab ${activeSub eq 'import' ? 'active' : ''}" href="${ctx}/broker/quarantine/import.do">수입검역신청</a>
            <a class="sub-tab ${activeSub eq 'export' ? 'active' : ''}" href="${ctx}/broker/quarantine/export.do">수출검역신청</a>
          </div>


              <!-- ===== 검역결과조회 ===== -->
          <div id="qu-result" style="display:${activeSub eq 'result' ? 'block' : 'none'}">
            <div class="flex-between mb-4">
              <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;"><span
                  class="material-symbols-outlined">assignment_returned</span> 검역결과조회</h3>
              <div class="btn-group">
                <button type="button" class="btn btn-outline" style="font-size:12px;" onclick="window.print()">
                  <span class="material-symbols-outlined" style="font-size:16px;">download</span> 다운로드
                </button>
              </div>
            </div>

            <div class="alert-bar success">
              <span class="material-symbols-outlined" style="font-size:18px">check_circle</span>
              검역신청 조회 및 검역 진행상황, 검역결과를 조회하실 수 있습니다.
            </div>

            <div style="background:#fff; padding:16px 20px; border:1px solid #e2e8f0; border-radius:4px; margin-bottom:16px;">
			  <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:12px 16px; align-items:end;">
			
			    <!-- 1행: 4개 인풋 -->
			    <div>
			      <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">검역신청번호</label>
			      <input type="text" id="quSearchApplyNo" name="searchApplyNo" value="${searchVO.searchApplyNo}" placeholder="Q20260410-XXXXX"
			        style="width:100%; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
			    </div>
			    <div>
			      <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">수입자명</label>
			      <input type="text" id="quSearchImporter" name="searchImporter" value="${searchVO.searchImporter}" placeholder="수입자명 입력"
			        style="width:100%; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
			    </div>
			    <div>
			      <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">상품명</label>
			      <input type="text" id="quSearchProductName" name="searchProductName" value="${searchVO.searchProductName}" placeholder="상품명 입력"
			        style="width:100%; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
			    </div>
			    <div>
			      <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">HS코드</label>
			      <input type="text" id="quSearchHsCode" name="searchHsCode" value="${searchVO.searchHsCode}" placeholder="HS코드 입력"
			        style="width:100%; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
			    </div>
			
			    <!-- 2행: 조회기간 (2칸 차지) + 검역결과 + 버튼 -->
			    <div style="grid-column: span 2;">
			      <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">조회기간</label>
			      <div style="display:flex; gap:8px; align-items:center;">
			        <input type="date" id="quSearchFromDate" name="searchFromDate" value="${searchVO.searchFromDate}"
			          style="flex:1; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
			        <span style="color:#697d8f; font-weight:600;">~</span>
			        <input type="date" id="quSearchToDate" name="searchToDate" value="${searchVO.searchToDate}"
			          style="flex:1; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
			      </div>
			    </div>
			    <div>
			      <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">검역결과</label>
			      <input type="text" id="quSearchResult" name="searchResult" value="${searchVO.searchResult}" placeholder="적합 / 부적합 / 조건부 등"
			        style="width:100%; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
			    </div>
			    <div style="display:flex; gap:6px; justify-content:flex-end; align-items:flex-end;">
			      <button class="btn btn-primary" style="background:#565e74; padding:8px 16px; white-space:nowrap;" onclick="quSearch()">
			        <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle;">search</span>
			        조회
			      </button>
			      <button class="btn btn-secondary" style="padding:8px 16px; white-space:nowrap;" onclick="quReset()">
			        초기화
			      </button>
			    </div>
			
			  </div>
			</div>

            <div style="overflow-x:auto; border:1px solid #e2e8f0; border-top:2px solid #334155;">
			  <table class="data-table" style="width:100%; margin-top:0;">
			    <thead style="background:#ecf4ff;">
			      <tr>
			        <th style="width:50px;"><input type="checkbox"></th>
			        <th style="width:130px;">검역신청번호 <span class="req">*</span></th>
			        <th style="width:100px;">수입자명</th>
			        <th style="width:120px;">상품명</th>
			        <th style="width:100px;">HS코드</th>
			        <th style="width:110px;">신청일</th>
			        <th style="width:110px;">검역완료일</th>
			        <th style="width:90px;">검역수량</th>
			        <th style="width:100px;">검역결과</th>
			        <th style="width:80px;">상세</th>
			      </tr>
			    </thead>
			    <tbody id="quResultTableBody">
			      <c:choose>
			        <c:when test="${empty resultList}">
			          <tr>
			            <td colspan="10" style="text-align:center; color:#697d8f; padding:24px;">조회된 검역 신청 결과가 없습니다.</td>
			          </tr>
			        </c:when>
			        <c:otherwise>
			          <c:forEach var="row" items="${resultList}">
			            <tr>
			              <td><input type="checkbox" value="${row.iirReqNo}"></td>
			              <td class="td-id">${row.iirReqNo}</td>
			              <td>${row.idImprNm}</td>
			              <td>${row.idiDclrGdsnm}</td>
			              <td>${row.idiHsCd}</td>
			              <td>${row.iirDt}</td>
			              <td>${empty row.iirCmplDt ? '—' : row.iirCmplDt}</td>
			              <td><span style="font-weight:700; color:#1d6b4f;">${row.idiQty} ${row.idiQtyUnitCd}</span></td>
			              <td>
			                <c:choose>
			                  <c:when test="${row.iirStatusCd eq 'REQ'}"><span class="badge badge-wait">요청</span></c:when>
			                  <c:when test="${row.iirStatusCd eq 'DONE' or row.iirStatusCd eq 'CMPL'}"><span class="badge badge-ok">검역완료</span></c:when>
			                  <c:otherwise><span class="badge badge-wait">${empty row.iirStatusNm ? row.iirStatusCd : row.iirStatusNm}</span></c:otherwise>
			                </c:choose>
			              </td>
			              <td><a class="mini mini-view" href="${ctx}/broker/quarantine/detail.do?iirReqNo=${row.iirReqNo}">상세</a></td>
			            </tr>
			          </c:forEach>
			        </c:otherwise>
			      </c:choose>
			   </tbody>
              </table>
            </div>

            <div style="margin-top:16px; display:flex; justify-content:space-between; align-items:center;">
              <div style="font-size:12px; color:#697d8f;">
                <strong id="quTotalCount">${empty resultList ? 0 : resultList.size()}</strong>건의 검역신청이 조회되었습니다.
              </div>
              <div class="pagination">
                <button class="page-btn" title="처음" disabled>«</button>
                <button class="page-btn" title="이전" disabled>‹</button>
                <button class="page-btn active">1</button>
                <button class="page-btn">2</button>
                <button class="page-btn">3</button>
                <button class="page-btn">4</button>
                <button class="page-btn">5</button>
                <button class="page-btn" title="다음">›</button>
                <button class="page-btn" title="마지막">»</button>
              </div>
            </div>
          </div>  <%-- /#qu-result --%>

          <!-- ===== 수입검역신청 ===== -->
          <div id="qu-import" style="display:${activeSub eq 'import' ? 'block' : 'none'}">
            <div class="flex-between mb-4">
              <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;"><span
                  class="material-symbols-outlined">assignment_turned_in</span> 농림축산물 검역신청서 작성</h3>
              <div class="btn-group">
                <button type="button" class="btn btn-outline" style="font-size:12px;">
                  <span class="material-symbols-outlined" style="font-size:16px;">print</span> 신청서 인쇄
                </button>
              </div>
            </div>

            <div class="alert-bar info">
              <span class="material-symbols-outlined" style="font-size:18px">fact_check</span>
              본 신청서는 <strong>농림축산검역본부 표준 데이터 규격</strong>을 준수합니다. 수출국/적출국 정보는 B/L과 일치해야 합니다.
            </div>

				<form id="quarantineForm"
      method="post"
      enctype="multipart/form-data"
      action="${ctx}/broker/quarantine/import/insert.do"
      onsubmit="return validateQuarantineForm();">
					<c:if test="${not empty _csrf}">
						<input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}" />
					</c:if>
					<%-- applyVO 필드 안전 추출: getter 누락/EL 예외로 페이지가 잘리는 것 방지 --%>
					<c:catch><c:set var="vIrNo"               value="${applyVO.irNo}" /></c:catch>
					<c:catch><c:set var="vBrokerOfficeNm"     value="${applyVO.brokerOfficeNm}" /></c:catch>
					<c:catch><c:set var="vIrCstmIdfNo"        value="${applyVO.irCstmIdfNo}" /></c:catch>
					<c:catch><c:set var="vBrokerTelno"        value="${applyVO.brokerTelno}" /></c:catch>
					<c:catch><c:set var="vBrokerEmail"        value="${applyVO.brokerEmail}" /></c:catch>
					<c:catch><c:set var="vBrokerZip"          value="${applyVO.brokerZip}" /></c:catch>
					<c:catch><c:set var="vBrokerAdres"        value="${applyVO.brokerAdres}" /></c:catch>
					<c:catch><c:set var="vBrokerDetailAdres"  value="${applyVO.brokerDetailAdres}" /></c:catch>
					<c:catch><c:set var="vImporterNm"         value="${applyVO.importerNm}" /></c:catch>
					<c:catch><c:set var="vImporterCompanyNm"  value="${applyVO.importerCompanyNm}" /></c:catch>
					<c:catch><c:set var="vImporterAdres"      value="${applyVO.importerAdres}" /></c:catch>
					<c:catch><c:set var="vImporterDetailAdres" value="${applyVO.importerDetailAdres}" /></c:catch>
					<c:catch><c:set var="vImporterTelno"      value="${applyVO.importerTelno}" /></c:catch>
					<c:catch><c:set var="vIrBlAwbNo"          value="${applyVO.irBlAwbNo}" /></c:catch>
					<c:catch><c:set var="vImpCgNo"            value="${applyVO.impCgNo}" /></c:catch>
					<c:catch><c:set var="vIrCn"               value="${applyVO.irCn}" /></c:catch>
              <div class="alert-bar warn">
                <span class="material-symbols-outlined" style="font-size:18px">search</span>
                검역신청을 생성할 수입의뢰를 먼저 선택하세요.
              </div>
              <div class="form-grid" style="grid-template-columns: 1fr auto auto; margin-bottom:18px;">
                <div class="form-item">
                  <label>수입의뢰 선택 <span class="req">*</span></label>

                  <input type="hidden" name="irNo" id="selectedIrNo" value="${vIrNo}">

                  <input type="text"
                         id="selectedImportRqstText"
                         value="${empty vIrNo ? '' : vIrNo.concat(' / ').concat(vImporterNm).concat(' / ').concat(vIrCn)}"
                         placeholder="수입의뢰를 조회해서 선택하세요."
                         readonly
                         style="background:#f1f5f9;">
                </div>

                <div class="form-item" style="justify-content:flex-end;">
                  <button type="button"
                          class="btn btn-primary"
                          onclick="openImportRqstModal()"
                          style="height:36px; white-space:nowrap;">
                    <span class="material-symbols-outlined" style="font-size:16px;">search</span>
                    수입의뢰 조회
                  </button>
                </div>

                <div class="form-item" style="justify-content:flex-end;">
                  <a class="btn btn-secondary"
                     href="${ctx}/broker/quarantine/import.do"
                     style="height:36px; white-space:nowrap;">
                    선택 초기화
                  </a>
                </div>
              </div>
              <h3 class="section-h3"
                style="font-size:14px; color:#1e293b; border-bottom:1px solid #e2e8f0; padding-bottom:8px; margin-bottom:15px;">
                [1] 신청인(관세사) 정보</h3>
              <div class="form-grid" style="grid-template-columns: 1fr 1fr;">
                <div class="form-item">
                  <label>신청인(상호) <span class="req">*</span></label>
                  <input type="text" value="${vBrokerOfficeNm}" readonly style="background:#f1f5f9;">
                </div>
                <div class="form-item">
                  <label>통관고유부호 <span class="req">*</span></label>
                  <input type="text" value="${vIrCstmIdfNo}" readonly style="background:#f1f5f9;">
                </div>
                <div class="form-item">
                  <label>신청인 전화번호 <span class="req">*</span></label>
                  <input type="tel" value="${vBrokerTelno}" readonly style="background:#f1f5f9;">
                </div>
                <div class="form-item">
                  <label>신청인 이메일 <span class="req">*</span></label>
                  <input type="email" value="${vBrokerEmail}" readonly style="background:#f1f5f9;">
                </div>
                <div class="form-item" style="grid-column: 1/-1;">
                  <label>신청인 주소 <span class="req">*</span></label>
                  <div style="display:flex; gap:8px;">
                    <input type="text" value="${vBrokerZip}" readonly style="width:100px; background:#f1f5f9;">
                    <button type="button" class="btn btn-secondary" style="padding:8px 12px; font-size:11px;"><span
                        class="material-symbols-outlined" style="font-size:14px;">search</span></button>
                    <input type="text" value="${vBrokerAdres} ${vBrokerDetailAdres}" readonly style="flex:1; background:#f1f5f9;">
                  </div>
                </div>
              </div>

              <h3 class="section-h3"
                style="font-size:14px; color:#1e293b; border-bottom:1px solid #e2e8f0; padding-bottom:8px; margin:25px 0 15px;">
                [2] 수입자 정보 / [3] 수출자·공급자 정보</h3>

              <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                <!-- 수입자 정보 -->
                <div>
                  <div style="font-weight:600; color:#1e293b; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid #cbd5e1;">
                    수입자 정보
                  </div>

                  <div class="form-grid" style="grid-template-columns: 1fr 1fr;">
                    <div class="form-item">
                      <label>수입자명 <span class="req">*</span></label>
                      <input type="text" value="${vImporterNm}" readonly style="background:#f1f5f9;">
                    </div>

                    <div class="form-item">
                      <label>상호 <span class="req">*</span></label>
                      <input type="text" value="${vImporterCompanyNm}" readonly style="background:#f1f5f9;">
                    </div>

                    <div class="form-item" style="grid-column: 1/-1;">
                      <label>주소 <span class="req">*</span></label>
                      <input type="text" value="${vImporterAdres} ${vImporterDetailAdres}" readonly style="background:#f1f5f9;">
                    </div>

                    <div class="form-item">
                      <label>전화번호 <span class="req">*</span></label>
                      <input type="tel" value="${vImporterTelno}" readonly style="background:#f1f5f9;">
                    </div>

                    <div class="form-item">
                      <label>통관고유부호 <span class="req">*</span></label>
                      <input type="text" value="${vIrCstmIdfNo}" readonly style="background:#f1f5f9;">
                    </div>
                  </div>
                </div>

                <!-- 수출자/공급자 정보 -->
                <div>
                  <div style="font-weight:600; color:#1e293b; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid #cbd5e1;">
                    수출자·공급자 정보
                  </div>

                  <div class="form-grid" style="grid-template-columns: 1fr 1fr;">
                    <div class="form-item">
                      <label>수출자명 <span class="req">*</span></label>
                      <input type="text" name="exporterNm" placeholder="수출자 또는 공급자명">
                    </div>

                    <div class="form-item">
                      <label>수출자 상호 <span class="req">*</span></label>
                      <input type="text" name="exporterCompanyNm" placeholder="수출사 명칭">
                    </div>

                    <div class="form-item" style="grid-column: 1/-1;">
                      <label>수출자 주소 <span class="req">*</span></label>
                      <input type="text" name="exporterAdres" placeholder="수출자 주소">
                    </div>

                    <div class="form-item">
                      <label>수출국 <span class="req">*</span></label>
                      <select name="exportCountryCd">
                        <option value="">-- 선택 --</option>
                        <option value="US">미국 (UNITED STATES)</option>
                        <option value="CN">중국 (CHINA)</option>
                        <option value="AU">호주 (AUSTRALIA)</option>
                        <option value="BR">브라질 (BRAZIL)</option>
                        <option value="AR">아르헨티나 (ARGENTINA)</option>
                      </select>
                    </div>

                    <div class="form-item">
                      <label>원산지 <span class="req">*</span></label>
                      <input type="text" name="originCountryCd" placeholder="예: US / CN / AU">
                    </div>

                    <div class="form-item">
                      <label>식물검역증명서번호 <span class="req">*</span></label>
                      <input type="text" name="phytoCertNo" placeholder="예: 20260415-00001">
                    </div>

                    <div class="form-item">
                      <label>식물검역증명서 발급일 <span class="req">*</span></label>
                      <input type="date" name="phytoCertIssueDt">
                    </div>
                  </div>
                </div>
              </div>

              <h3 class="section-h3"
                style="font-size:14px; color:#1e293b; border-bottom:1px solid #e2e8f0; padding-bottom:8px; margin:25px 0 15px;">
                [4] B/L 및 운송 정보</h3>

              <div class="form-grid">
                <div class="form-item">
                  <label>검역소 <span class="req">*</span></label>
                  <select name="iirQrtnInstCd">
                    <option value="">-- 선택 --</option>
                    <option value="020">인천공항지역본부</option>
                    <option value="030">부산지역본부</option>
                    <option value="040">중부지역본부(평택)</option>
                    <option value="050">김포공항지역본부</option>
                    <option value="060">인천항지역본부</option>
                  </select>
                </div>

                <div class="form-item">
                  <label>신청 번호</label>
                  <input type="text" value="자동생성" readonly style="background:#f8fafc; color:#94a3b8;">
                </div>

                <div class="form-item">
                  <label>B/L 또는 AWB 번호 <span class="req">*</span></label>
                  <input type="text" value="${vIrBlAwbNo}" readonly style="background:#f1f5f9;">
                </div>

                <div class="form-item">
                  <label>화물관리번호 <span class="req">*</span></label>
                  <input type="text" value="${vImpCgNo}" readonly style="background:#f1f5f9;">
                </div>

                <div class="form-item">
                  <label>운송수단 종류 <span class="req">*</span></label>
                  <select name="transportTypeCd">
                    <option value="">-- 선택 --</option>
                    <option value="SHIP">선박</option>
                    <option value="AIR">항공기</option>
                    <option value="TRUCK">자동차</option>
                    <option value="TRAIN">철도</option>
                  </select>
                </div>

                <div class="form-item">
                  <label>운송수단 명칭</label>
                  <input type="text" name="transportNm" placeholder="선박명 또는 항공편명">
                </div>

                <div class="form-item">
                  <label>선적항 <span class="req">*</span></label>
                  <input type="text" name="loadPortCd" placeholder="예: Los Angeles / USLAX">
                </div>

                <div class="form-item">
                  <label>선적일</label>
                  <input type="date" name="shipDt">
                </div>

                <div class="form-item">
                  <label>도착항 <span class="req">*</span></label>
                  <input type="text" name="arrvPortCd" placeholder="예: 인천항 / KRINC">
                </div>

                <div class="form-item">
                  <label>도착일</label>
                  <input type="date" name="arrvDt">
                </div>
              </div>

              <h3 class="section-h3"
                style="font-size:14px; color:#1e293b; border-bottom:1px solid #e2e8f0; padding-bottom:8px; margin:25px 0 15px;">
                [5] 물품 요약 정보</h3>

              <div class="form-grid">
                <div class="form-item">
                  <label>대표 품명 <span class="req">*</span></label>
                  <input type="text" name="mainGoodsNm" value="${vIrCn}" placeholder="예: Rice" style="background:#f8fafc;">
                </div>

                <div class="form-item">
                  <label>대표 HS Code</label>
                  <input type="text" name="mainHsCd" placeholder="예: 1006.30">
                </div>

                <div class="form-item">
                  <label>총 포장개수 <span class="req">*</span></label>
                  <input type="number" name="totalPkgCnt" placeholder="0">
                </div>

                <div class="form-item">
                  <label>포장 단위 <span class="req">*</span></label>
                  <select name="pkgUnitCd">
                    <option value="">-- 선택 --</option>
                    <option value="BAG">BAG(포대)</option>
                    <option value="CT">CT(카톤)</option>
                    <option value="PL">PL(팔렛)</option>
                    <option value="KG">KG</option>
                  </select>
                </div>

                <div class="form-item">
                  <label>총 중량(KG) <span class="req">*</span></label>
                  <input type="number" name="totalWeight" placeholder="0.000" step="0.001">
                </div>

                <div class="form-item">
                  <label>포장재질</label>
                  <input type="text" name="pkgMaterial" placeholder="예: PP Bag, Paper Bag, Carton">
                </div>

                <div class="form-item">
                  <label>목재포장재 사용 여부</label>
                  <select name="woodPkgYn">
                    <option value="N">아니오</option>
                    <option value="Y">예</option>
                  </select>
                </div>

                <div class="form-item">
                  <label>목재포장재 표시/인증번호</label>
                  <input type="text" name="woodPkgMarkNo" placeholder="예: HT, MB 표시번호">
                </div>
              </div>

              <h3 class="section-h3" style="font-size:14px; color:#1e293b; margin:25px 0 10px;">[6] 품목 정보</h3>

              <div style="overflow-x:auto; border-top:2px solid #334155;">
                <table class="data-table" style="width:100%;">
                  <thead style="background:#f8fafc;">
                    <tr>
                      <th style="width:40px;">순번</th>
                      <th style="width:100px;">HS Code <span class="req">*</span></th>
                      <th style="width:140px;">품명 <span class="req">*</span></th>
                      <th style="width:130px;">학명</th>
                      <th style="width:80px;">용도</th>
                      <th style="width:110px;">수량/단위</th>
                      <th style="width:90px;">순중량(KG)</th>
                      <th style="width:80px;">포장개수</th>
                      <th style="width:90px;">포장재질</th>
                      <th style="width:80px;">원산지</th>
                      <th style="width:50px;">관리</th>
                    </tr>
                  </thead>

                  <tbody id="quarantineItemList">
                    <tr class="quarantine-item-row">
                      <td class="item-no" style="text-align:center; font-size:12px;">1</td>

                      <td>
                        <input type="text"
                               name="itemList[0].hsCd"
                               class="table-input"
                               placeholder="HS Code"
                               style="font-size:11px;">
                      </td>

                      <td>
                        <input type="text"
                               name="itemList[0].goodsNm"
                               class="table-input"
                               value="${vIrCn}"
                               placeholder="품명"
                               style="font-size:11px;">
                      </td>

                      <td>
                        <input type="text"
                               name="itemList[0].scientificNm"
                               class="table-input"
                               placeholder="예: Oryza sativa"
                               style="font-size:11px;">
                      </td>

                      <td>
                        <select name="itemList[0].useCd" class="table-input" style="font-size:11px;">
                          <option value="SALE">판매용</option>
                          <option value="SELF">자가소비용</option>
                          <option value="TEST">시험연구용</option>
                        </select>
                      </td>

                      <td>
                        <div style="display:flex; gap:2px;">
                          <input type="number"
                                 name="itemList[0].qty"
                                 class="table-input"
                                 style="flex:1; font-size:11px;"
                                 placeholder="수량">

                          <select name="itemList[0].qtyUnitCd" style="width:48px; font-size:10px;">
                            <option value="KG">KG</option>
                            <option value="BAG">BAG</option>
                            <option value="CT">CT</option>
                            <option value="PL">PL</option>
                            <option value="EA">EA</option>
                          </select>
                        </div>
                      </td>

                      <td>
                        <input type="number"
                               name="itemList[0].netWeight"
                               class="table-input"
                               placeholder="0.000"
                               step="0.001"
                               style="font-size:11px;">
                      </td>

                      <td>
                        <input type="number"
                               name="itemList[0].pkgCnt"
                               class="table-input"
                               placeholder="0"
                               style="font-size:11px;">
                      </td>

                      <td>
                        <input type="text"
                               name="itemList[0].pkgMaterial"
                               class="table-input"
                               placeholder="포대/박스"
                               style="font-size:11px;">
                      </td>

                      <td>
                        <input type="text"
                               name="itemList[0].originCountryCd"
                               class="table-input"
                               placeholder="US"
                               style="font-size:11px;">
                      </td>

                      <td style="text-align:center;">
                        <button type="button" class="qu-trash-btn" title="삭제" onclick="removeQuarantineItem(this)">
						  <span class="material-symbols-outlined">delete</span>
						</button>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <button type="button"
                      class="btn"
                      onclick="addQuarantineItem()"
                      style="width:100%; margin-top:10px; border:1px dashed #cbd5e1; background:#fff; height:36px; font-size:12px; color:#64748b;">
                <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle;">add</span>
                품목 추가
              </button>

              <h3 class="section-h3" style="font-size:14px; color:#1e293b; margin-top:30px;">[7] 검역장소 및 요청사항</h3>

              <div class="form-grid">
                <div class="form-item">
                  <label>검역 희망일시</label>
                  <input type="datetime-local" name="iilPlanDt">
                </div>

                <div class="form-item">
                  <label>검역장소 <span class="req">*</span></label>
                  <select name="iilNm">
                    <option value="">-- 선택 --</option>
                    <option value="부산항">부산항</option>
                    <option value="인천항">인천항</option>
                    <option value="인천공항">인천공항</option>
                    <option value="김포공항">김포공항</option>
                  </select>
                </div>

                <div class="form-item" style="grid-column: 1/-1;">
                  <label>신청인 요구사항 및 특별 지시사항</label>
                  <textarea name="iirRsnCn"
                            placeholder="검역 요청 사유, 특이사항, 현장 확인 요청사항 등을 입력하세요."
                            rows="4"
                            style="width:100%; padding:10px; border:1px solid #cbd5e1; font-size:13px; font-family:inherit;"></textarea>
                </div>
              </div>

              <h3 class="section-h3" style="font-size:14px; color:#1e293b; margin-top:30px;">[8] 첨부 문서</h3>

              <div class="form-item" style="grid-column:1/-1; margin-bottom:16px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                  <label style="font-size:12px; font-weight:700; color:#203444;">
                    첨부 문서 <span class="req">*</span>
                  </label>

                  <label for="quAttachFiles"
                         class="btn btn-secondary"
                         style="height:40px; display:inline-flex; align-items:center; cursor:pointer; padding:0 18px; border:1px solid #d9e2ef; background:#fff; color:#203444; font-weight:800;">
                    파일 선택
                  </label>

                  <input type="file"
                         id="quAttachFiles"
                         name="attachFiles"
                         multiple
                         accept=".pdf,.jpg,.jpeg,.png,.xlsx,.xls"
                         style="display:none;"
                         onchange="handleQuAttachFiles(this.files)">
                </div>

                <div id="quAttachDropZone"
                     onclick="document.getElementById('quAttachFiles').click();"
                     ondragover="handleQuAttachDragOver(event)"
                     ondragleave="handleQuAttachDragLeave(event)"
                     ondrop="handleQuAttachDrop(event)"
                     style="height:150px; border:2px dashed #cbd5e1; background:#f8fafc; display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; margin-bottom:18px; transition:background .15s, border-color .15s;">
                  <span class="material-symbols-outlined" style="font-size:34px; color:#cbd5e1; margin-bottom:8px;">upload_file</span>
                  <div style="font-size:13px; color:#94a3b8; margin-bottom:6px;">
                    파일을 이곳에 드래그하거나 <strong style="color:#475569;">클릭하여 선택</strong>하세요
                  </div>
                  <div style="font-size:12px; color:#94a3b8;">
                    PDF · JPG · PNG · XLSX — 최대 20MB
                  </div>
                </div>

                <div style="border:1px solid #e2e8f0; background:#fff;">
                  <table class="data-table" style="width:100%; margin-top:0;">
                    <thead style="background:#f8fafc;">
                      <tr>
                        <th style="width:180px;">문서종류</th>
                        <th>파일명</th>
                        <th style="width:120px;">상태</th>
                        <th style="width:70px; text-align:center;">관리</th>
                      </tr>
                    </thead>
                    <tbody id="quAttachFileList">
                      <tr id="quAttachEmptyRow">
                        <td colspan="4" style="text-align:center; color:#94a3b8; padding:22px;">
                          첨부된 문서가 없습니다.
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>

                <p style="font-size:11px; color:#697d8f; margin-top:8px;">
                  ※ 문서종류는 파일명 기준으로 임시 자동 분류됩니다. 저장 시 파일별 문서유형 코드를 함께 저장하면 됩니다.
                </p>
              </div>

              <div class="btn-row"
                style="margin-top:40px; justify-content:center; gap:12px; border-top:1px solid #e2e8f0; padding-top:30px;">
                <button type="button" class="btn btn-secondary" style="width:160px; background:#f1f5f9; color:#475569; border:none;">임시저장 (Save)</button>
                <button type="submit" class="btn btn-primary" style="width:160px; background:#2c3e50; border:none;">검역신청 전송 (EDI)</button>
              </div>
            </form>
          </div>

          <!-- ===== 수출검역신청 ===== -->
          <div id="qu-export" style="display:${activeSub eq 'export' ? 'block' : 'none'}">
            <div class="flex-between mb-4">
              <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;"><span
                  class="material-symbols-outlined">outbound</span> 수출식물 검역신청서</h3>
              <div class="btn-group">
                <button type="button" class="btn btn-outline" style="font-size:12px;">
                  <span class="material-symbols-outlined" style="font-size:16px;">print</span> 신청서 인쇄
                </button>
              </div>
            </div>

            <div class="alert-bar info">
              <span class="material-symbols-outlined" style="font-size:18px">fact_check</span>
              본 신청서는 <strong>농림축산검역본부 표준 데이터 규격</strong>을 준수합니다.
            </div>

            <form id="exportQuarantineForm">
              <h3 class="section-h3"
                style="font-size:14px; color:#1e293b; border-bottom:1px solid #e2e8f0; padding-bottom:8px; margin-bottom:15px;">
                [1] 수출자(보내는 자) 정보</h3>
              <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                <!-- 수출자 정보 좌측 -->
                <div>
                  <div class="form-grid" style="grid-template-columns: 1fr;">
                    <div class="form-item">
                      <label>성명 <span class="req">*</span></label>
                      <input type="text" placeholder="수출자 성명">
                    </div>
                    <div class="form-item">
                      <label>상호 <span class="req">*</span></label>
                      <input type="text" placeholder="수출사 명칭">
                    </div>
                    <div class="form-item">
                      <label>주소 <span class="req">*</span></label>
                      <input type="text" placeholder="주소 입력">
                    </div>
                  </div>
                </div>
                <!-- 수출자 정보 우측 -->
                <div>
                  <div class="form-grid" style="grid-template-columns: 1fr;">
                    <div class="form-item">
                      <label>생년월일 <span class="req">*</span></label>
                      <input type="date">
                    </div>
                    <div class="form-item">
                      <label>사업자등록번호 <span class="req">*</span></label>
                      <input type="text" placeholder="000-00-00000">
                    </div>
                    <div class="form-item">
                      <label>전화번호 <span class="req">*</span></label>
                      <input type="tel" placeholder="000-0000-0000">
                    </div>
                  </div>
                </div>
              </div>

              <h3 class="section-h3"
                style="font-size:14px; color:#1e293b; border-bottom:1px solid #e2e8f0; padding-bottom:8px; margin:25px 0 15px;">
                [2] 수입자(받는 자) 정보</h3>
              <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                <!-- 수입자 정보 좌측 -->
                <div>
                  <div class="form-grid" style="grid-template-columns: 1fr;">
                    <div class="form-item">
                      <label>성명 <span class="req">*</span></label>
                      <input type="text" value="${vImporterNm}" readonly style="background:#f1f5f9;">
                    </div>
                    <div class="form-item">
                      <label>주소 <span class="req">*</span></label>
                      <input type="text" placeholder="주소 입력">
                    </div>
                  </div>
                </div>
                <!-- 수입자 정보 우측 -->
                <div>
                  <div class="form-grid" style="grid-template-columns: 1fr;">
                    <div class="form-item">
                      <label>상호 <span class="req">*</span></label>
                      <input type="text" placeholder="수입사 명칭">
                    </div>
                  </div>
                </div>
              </div>

              <h3 class="section-h3"
                style="font-size:14px; color:#1e293b; border-bottom:1px solid #e2e8f0; padding-bottom:8px; margin:25px 0 15px;">
                [3] 운송수단 및 선적 품목 주</h3>
              <div class="form-grid" style="grid-template-columns: repeat(4, 1fr);">
                <div class="form-item">
                  <label>운송수단 <span class="req">*</span></label>
                  <input type="text" placeholder="운송수단">
                </div>
                <div class="form-item">
                  <label>선적항 <span class="req">*</span></label>
                  <input type="text" placeholder="선적항">
                </div>
                <div class="form-item">
                  <label>출항일 <span class="req">*</span></label>
                  <input type="date">
                </div>
                <div class="form-item">
                  <label>도착항 <span class="req">*</span></label>
                  <input type="text" placeholder="도착항">
                </div>
              </div>

              <div style="margin-top:12px;">
                <div class="form-grid" style="grid-template-columns: repeat(4, 1fr);">
                  <div class="form-item">
                    <label>품목수 <span class="req">*</span></label>
                    <input type="number" placeholder="품목수">
                  </div>
                  <div class="form-item">
                    <label>품목명 <span class="req">*</span></label>
                    <input type="text" placeholder="품목명">
                  </div>
                  <div class="form-item">
                    <label>단위 <span class="req">*</span></label>
                    <input type="text" placeholder="단위">
                  </div>
                  <div class="form-item">
                    <label>수량 <span class="req">*</span></label>
                    <input type="number" placeholder="수량">
                  </div>
                </div>
              </div>

              <div style="margin-top:12px;">
                <div class="form-grid" style="grid-template-columns: repeat(4, 1fr);">
                  <div class="form-item">
                    <label>학명 <span class="req">*</span></label>
                    <input type="text" placeholder="학명">
                  </div>
                  <div class="form-item">
                    <label>원산지 <span class="req">*</span></label>
                    <input type="text" placeholder="원산지">
                  </div>
                  <div class="form-item">
                    <label>포장의 수와 종류 <span class="req">*</span></label>
                    <input type="text" placeholder="포장 종류">
                  </div>
                  <div class="form-item">
                    <label>수입국 <span class="req">*</span></label>
                    <input type="text" placeholder="수입국">
                  </div>
                </div>
              </div>

              <h3 class="section-h3"
                style="font-size:14px; color:#1e293b; border-bottom:1px solid #e2e8f0; padding-bottom:8px; margin:25px 0 15px;">
                [4] 검역 정보</h3>
              <div class="form-grid" style="grid-template-columns: 1fr 1fr;">
                <div class="form-item">
                  <label>검역 회피일시 <span class="req">*</span></label>
                  <input type="datetime-local">
                </div>
                <div class="form-item">
                  <label>검역장소 <span class="req">*</span></label>
                  <select>
                    <option>-- 선택 --</option>
                    <option>부산항</option>
                    <option>인천항</option>
                    <option>인천공항</option>
                    <option>김포공항</option>
                    <option>여수항</option>
                    <option>울산항</option>
                  </select>
                </div>
              </div>

              <div class="form-grid" style="margin-top:12px;">
                <div class="form-item" style="grid-column: 1/-1;">
                  <label>식별표시(Distinguishing Marks) <span class="req">*</span></label>
                  <input type="text" placeholder="식별표시">
                </div>
              </div>

              <h3 class="section-h3"
                style="font-size:14px; color:#1e293b; border-bottom:1px solid #e2e8f0; padding-bottom:8px; margin:25px 0 15px;">
                [5] 신청인 요구사항</h3>
              <div class="form-grid">
                <div class="form-item" style="grid-column: 1/-1;">
                  <label>특별한 요청사항</label>
                  <textarea placeholder="특별한 요청사항을 입력하세요." rows="4" style="resize:vertical;"></textarea>
                </div>
              </div>

              <div class="btn-row"
                style="margin-top:40px; justify-content:center; gap:12px; border-top:1px solid #e2e8f0; padding-top:30px;">
                <button type="button" class="btn btn-secondary" style="width:160px;">임시저장 (Save)</button>
                <button type="submit" class="btn btn-primary" style="width:160px;">검역신청 전송 (EDI)</button>
              </div>
            </form>
          </div>
        </div>
      </div>
        </div>
        <%@ include file="/WEB-INF/views/broker/common/footer.jsp" %>
    </div>
</div>
   <!-- 수입의뢰 조회 모달 -->
      <div class="modal-bg" id="importRqstSearchModal">
        <div class="modal-box" style="width:860px;">
          <h3>
            <span class="material-symbols-outlined">manage_search</span>
            수입의뢰 조회
          </h3>

          <button type="button"
                  class="modal-close"
                  onclick="closeImportRqstModal()">×</button>

          <div style="margin-top:18px;">
            <div class="alert-bar info" style="margin-bottom:14px;">
              <span class="material-symbols-outlined" style="font-size:18px;">info</span>
              화주명, 수입의뢰번호, B/L 번호, 품명으로 검색 후 검역신청에 사용할 의뢰를 선택하세요.
            </div>

            <div style="background:#f8fafc; border:1px solid #e2e8f0; padding:14px; margin-bottom:14px;">
              <div style="display:grid; grid-template-columns: 1fr 1fr 1fr auto; gap:10px; align-items:end;">
                <div class="form-item">
                  <label>화주명 / 수입자명</label>
                  <input type="text"
                         id="importRqstSearchOwner"
                         placeholder="예: 삼성전자">
                </div>

                <div class="form-item">
                  <label>수입의뢰번호</label>
                  <input type="text"
                         id="importRqstSearchIrNo"
                         placeholder="예: IR-20260508-0001">
                </div>

                <div class="form-item">
                  <label>B/L 번호 / 품명</label>
                  <input type="text"
                         id="importRqstSearchNo"
                         placeholder="B/L 번호 또는 품명">
                </div>

                <div style="display:flex; gap:6px;">
                  <button type="button"
                          class="btn btn-primary"
                          onclick="searchImportRqstInModal()"
                          style="height:36px; white-space:nowrap;">
                    조회
                  </button>

                  <button type="button"
                          class="btn btn-secondary"
                          onclick="resetImportRqstSearch()"
                          style="height:36px; white-space:nowrap;">
                    초기화
                  </button>
                </div>
              </div>
            </div>

            <div style="overflow-x:auto; border:1px solid #e2e8f0; border-top:2px solid #334155; max-height:360px; overflow-y:auto;">
              <table class="data-table" style="width:100%; margin-top:0;">
                <thead style="background:#ecf4ff;">
                  <tr>
                    <th style="width:150px;">수입의뢰번호</th>
                    <th style="width:130px;">화주/수입자</th>
                    <th style="width:150px;">B/L 번호</th>
                    <th>품명</th>
                    <th style="width:100px;">도착예정일</th>
                    <th style="width:80px;">선택</th>
                  </tr>
                </thead>

                <tbody id="importRqstModalBody">
                  <c:choose>
                    <c:when test="${empty candidateList}">
                      <tr>
                        <td colspan="6" style="text-align:center; color:#697d8f; padding:24px;">
                          조회 가능한 수입의뢰가 없습니다.
                        </td>
                      </tr>
                    </c:when>

                    <c:otherwise>
                      <c:forEach var="rq" items="${candidateList}">
                        <tr class="import-rqst-row"
                            data-ir-no="${rq.irNo}"
                            data-owner-nm="${rq.importerNm}"
                            data-bl-no="${rq.irBlAwbNo}"
                            data-goods-nm="${rq.irCn}"
                            data-arrv-ymd="${rq.irArrvSchdYmd}">
                          <td class="td-id">${rq.irNo}</td>
                          <td>${rq.importerNm}</td>
                          <td>${empty rq.irBlAwbNo ? '-' : rq.irBlAwbNo}</td>
                          <td>${rq.irCn}</td>
                          <td>${rq.irArrvSchdYmd}</td>
                          <td>
                            <button type="button"
                                    class="mini mini-view"
                                    onclick="selectImportRqst('${rq.irNo}')">
                              선택
                            </button>
                          </td>
                        </tr>
                      </c:forEach>
                    </c:otherwise>
                  </c:choose>
                </tbody>
              </table>
            </div>

            <div style="margin-top:12px; display:flex; justify-content:space-between; align-items:center;">
              <div style="font-size:12px; color:#697d8f;">
                검색 결과 <strong id="importRqstSearchCount">0</strong>건
              </div>

              <div class="btn-row" style="justify-content:flex-end;">
                <button type="button"
                        class="btn btn-secondary"
                        onclick="closeImportRqstModal()">
                  닫기
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

   <!-- 검역결과 상세 모달 -->
      <div class="modal-bg" id="quDetailModal">
        <div class="modal-box" style="width:620px;">
          <h3><span class="material-symbols-outlined">assignment_turned_in</span> 검역결과 상세조회</h3>
          <button class="modal-close" onclick="this.parentElement.parentElement.classList.remove('show')">×</button>

          <div style="margin-top:20px;">
            <div style="background:#f8fafc; padding:16px; border-left:4px solid #565e74; margin-bottom:16px;">
              <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; font-size:13px;">
                <div>
                  <div style="color:#697d8f; font-size:11px; font-weight:700; margin-bottom:4px;">검역신청번호</div>
                  <div id="quDetailApplyNo" style="font-size:14px; font-weight:700; color:#203444;">Q20260410-00098
                  </div>
                </div>
                <div>
                  <div style="color:#697d8f; font-size:11px; font-weight:700; margin-bottom:4px;">검역진행상태</div>
                  <div id="quDetailStatus" style="font-size:14px; font-weight:700; color:#1d6b4f;">검역완료</div>
                </div>
                <div>
                  <div style="color:#697d8f; font-size:11px; font-weight:700; margin-bottom:4px;">신청인</div>
                  <div id="quDetailApplicant" style="font-size:13px; color:#203444;">노태호 관세사무소</div>
                </div>
                <div>
                  <div style="color:#697d8f; font-size:11px; font-weight:700; margin-bottom:4px;">수입자</div>
                  <div id="quDetailImporter" style="font-size:13px; color:#203444;">삼성전자(주)</div>
                </div>
              </div>
            </div>

            <h4
              style="font-size:12px; font-weight:700; margin-top:20px; margin-bottom:10px; border-bottom:1px solid #e2e8f0; padding-bottom:8px;">
              ■ 검역신청 정보</h4>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px; font-size:12px;">
              <div>
                <div style="color:#697d8f; font-size:10px; margin-bottom:4px;">수출국</div>
                <div style="color:#203444; font-weight:600;">미국 (US)</div>
              </div>
              <div>
                <div style="color:#697d8f; font-size:10px; margin-bottom:4px;">B/L번호</div>
                <div style="color:#203444; font-weight:600;">MSC2024041500123</div>
              </div>
              <div>
                <div style="color:#697d8f; font-size:10px; margin-bottom:4px;">도착항</div>
                <div style="color:#203444; font-weight:600;">인천항 (2026-04-11)</div>
              </div>
              <div>
                <div style="color:#697d8f; font-size:10px; margin-bottom:4px;">접수검역소</div>
                <div style="color:#203444; font-weight:600;">인천공항지역본부</div>
              </div>
            </div>

            <h4
              style="font-size:12px; font-weight:700; margin-top:20px; margin-bottom:10px; border-bottom:1px solid #e2e8f0; padding-bottom:8px;">
              ■ 검역 대상 물품</h4>
            <div style="overflow-x:auto; border:1px solid #e2e8f0; margin-bottom:16px;">
              <table class="data-table" style="font-size:11px;">
                <thead style="background:#f8fafc;">
                  <tr>
                    <th>HS코드</th>
                    <th>상품명</th>
                    <th>신청수량</th>
                    <th>검사수량</th>
                    <th>검역결과</th>
                  </tr>
                </thead>
                <tbody id="quDetailItems">
                  <tr>
                    <td>8542.31</td>
                    <td>반도체 부품</td>
                    <td style="font-weight:700;">345 CT</td>
                    <td style="font-weight:700;">50 CT (표본)</td>
                    <td><span class="badge badge-ok" style="font-size:10px;">적합</span></td>
                  </tr>
                </tbody>
              </table>
            </div>

            <h4
              style="font-size:12px; font-weight:700; margin-top:20px; margin-bottom:10px; border-bottom:1px solid #e2e8f0; padding-bottom:8px;">
              ■ 검역 결과 및 의견</h4>
            <div
              style="background:#f0fdf4; padding:12px; border-radius:4px; border-left:4px solid #1d6b4f; margin-bottom:16px;">
              <div style="font-size:12px; color:#065f46; line-height:1.6;">
                <strong>검역결과:</strong> 검역합격<br>
                <strong>검역일시:</strong> 2026-04-12 14:30<br>
                <strong>담당자:</strong> 김검역 (연락처: 032-1234-5678)<br>
                <strong>의견:</strong> 물품 상태 양호, 관련 증명서류 완비함. 세관에 수리 통보 예정.
              </div>
            </div>

            <h4
              style="font-size:12px; font-weight:700; margin-top:20px; margin-bottom:10px; border-bottom:1px solid #e2e8f0; padding-bottom:8px;">
              ■ 첨부문서</h4>
            <div style="background:#ecf4ff; padding:12px; border-radius:4px; margin-bottom:16px;">
              <div style="font-size:12px;">
                <div style="margin-bottom:8px;">
                  <span class="material-symbols-outlined"
                    style="font-size:16px; vertical-align:middle;">description</span>
                  <a href="#"
                    style="color:#565e74; font-weight:600; text-decoration:none; margin-left:6px;">검역성적서_Q20260410-00098.pdf</a>
                  <span style="color:#697d8f; font-size:10px;">(2.3MB)</span>
                </div>
                <div>
                  <span class="material-symbols-outlined"
                    style="font-size:16px; vertical-align:middle;">description</span>
                  <a href="#"
                    style="color:#565e74; font-weight:600; text-decoration:none; margin-left:6px;">세관에_통보예정.pdf</a>
                  <span style="color:#697d8f; font-size:10px;">(0.8MB)</span>
                </div>
              </div>
            </div>

            <div class="btn-row"
              style="justify-content:flex-end; gap:8px; padding-top:16px; border-top:1px solid #e2e8f0;">
              <button type="button" class="btn btn-secondary" style="width:120px;">인쇄</button>
              <button type="button" class="btn btn-primary" style="width:120px;"
                onclick="this.parentElement.parentElement.parentElement.classList.remove('show')">닫기</button>
            </div>
          </div>
        </div>
      </div>


<%@ include file="/WEB-INF/views/broker/common/modals.jsp" %>
<script>window.contextPath = '${ctx}';</script>

<c:if test="${not empty detailVO}">
<script>
document.addEventListener('DOMContentLoaded', function(){
  document.getElementById('quDetailApplyNo').textContent = '${detailVO.iirReqNo}';
  document.getElementById('quDetailStatus').textContent = '${empty detailVO.iirStatusNm ? detailVO.iirStatusCd : detailVO.iirStatusNm}';
  document.getElementById('quDetailApplicant').textContent = '${detailVO.brokerOfficeNm}';
  document.getElementById('quDetailImporter').textContent = '${detailVO.idImprNm}';
  var tbody = document.getElementById('quDetailItems');
  if (tbody) tbody.innerHTML = '<tr><td>${detailVO.idiHsCd}</td><td>${detailVO.idiDclrGdsnm}</td><td style="font-weight:700;">${detailVO.idiQty} ${detailVO.idiQtyUnitCd}</td><td style="font-weight:700;">${detailVO.iilNm}</td><td><span class="badge badge-ok" style="font-size:10px;">${empty detailVO.iirResultNm ? detailVO.iirStatusNm : detailVO.iirResultNm}</span></td></tr>';
  document.getElementById('quDetailModal').classList.add('show');
});
</script>
</c:if>

<script src="${ctx}/resources/js/broker/common.js"></script>
<script src="${ctx}/resources/js/broker/pages/quarantine.js"></script>
</body>
</html>




