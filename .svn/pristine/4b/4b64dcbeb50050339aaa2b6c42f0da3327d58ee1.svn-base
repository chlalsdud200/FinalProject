<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.officer.basicscreen.mapper.IBasicMapper">

    <!-- =========================================================
         [기본접수목록 조회]

         기준 테이블:
         - 수입: IMP_DCLR
         - 수출: EXP_DCLR

         보조 조인:
         - 화주ID/관세사ID 확인용으로만 IMP_RQST, EXP_RQST 조인
         - 품명은 IMP_DCLR_ITEM / EXP_DCLR_ITEM에서 첫 번째 란사항 1건만 조회
         - 반려사유는 RJCT_MNG에서 조회

         기본접수목록에 보여줄 상태:
         - DCLR_WAIT : 접수대기 (관세사가 전송한 상태)
         - CSTM_REJ  : 반려
         
         DCLR_REVIEW는 접수완료/심사중이라서 기본접수목록에서 빠지고
         기본심사목록 쪽으로 넘어가는 상태로 봄
    ========================================================= -->
    <select id="selectReceiptList" resultType="kr.or.tacs.dto.officer.ReceiptListDTO">
        SELECT
            ROWNUM AS no,
            A.*
        FROM (
            /* =========================
               수입 통관신고 목록
            ========================= */
            SELECT
                ID.ID_IR_NO AS reqNo,
                '수입' AS declareType,
                IR.IR_OWR_ID AS companyName,

                (
                    SELECT II.IDI_DCLR_GDSNM
                    FROM IMP_DCLR_ITEM II
                    WHERE II.IDI_IR_NO = ID.ID_IR_NO
                    ORDER BY II.IDI_SN
                    FETCH FIRST 1 ROWS ONLY
                ) AS itemName,

                TO_CHAR(NVL(ID.ID_DCLR_DT, ID.ID_REGIST_DT), 'YYYY-MM-DD HH24:MI') AS requestDate,
                ID.ID_STATUS_CD AS statusCd,

                NVL(ID.ID_RJCT_RSN_CN, RJ.RM_RJCT_CN) AS rejectReason,
                TO_CHAR(NVL(ID.ID_RJCT_DT, RJ.RM_RJCT_DT), 'YYYY-MM-DD HH24:MI') AS rejectDate,
                '접수반려' AS rejectType,

                ID.ID_DCLR_DT AS sortDate

            FROM IMP_DCLR ID
            JOIN IMP_RQST IR
              ON IR.IR_NO = ID.ID_IR_NO
            LEFT JOIN RJCT_MNG RJ
              ON RJ.RM_REF_NO = ID.ID_IR_NO
             AND RJ.RM_REF_BIZ_CD = 'IMP_DCLR'

            WHERE IR.IR_USE_YN = 'Y'
              AND ID.ID_STATUS_CD IN ('DCLR_WAIT', 'CSTM_REJ')

              <if test="reqNo != null and reqNo != ''">
                  AND ID.ID_IR_NO LIKE '%' || #{reqNo} || '%'
              </if>

              <if test="statusCd != null and statusCd != ''">
                  AND ID.ID_STATUS_CD = #{statusCd}
              </if>

              <if test="declareType != null and declareType != ''">
                  AND '수입' = #{declareType}
              </if>

              <if test="companyName != null and companyName != ''">
                  AND IR.IR_OWR_ID LIKE '%' || #{companyName} || '%'
              </if>

              <if test="itemName != null and itemName != ''">
                  AND EXISTS (
                      SELECT 1
                        FROM IMP_DCLR_ITEM II2
                       WHERE II2.IDI_IR_NO = ID.ID_IR_NO
                         AND II2.IDI_DCLR_GDSNM LIKE '%' || #{itemName} || '%'
                  )
              </if>

              <if test="startDate != null and startDate != ''">
                  AND TRUNC(NVL(ID.ID_DCLR_DT, ID.ID_REGIST_DT)) &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
              </if>

              <if test="endDate != null and endDate != ''">
                  AND TRUNC(NVL(ID.ID_DCLR_DT, ID.ID_REGIST_DT)) &lt;= TO_DATE(#{endDate}, 'YYYY-MM-DD')
              </if>

            UNION ALL

            /* =========================
               수출 통관신고 목록
            ========================= */
            SELECT
                ED.ED_ER_NO AS reqNo,
                '수출' AS declareType,
                ER.ER_OWR_ID AS companyName,

                (
                    SELECT EI.EDI_EXPT_GDS_NM
                    FROM EXP_DCLR_ITEM EI
                    WHERE EI.EDI_ER_NO = ED.ED_ER_NO
                    ORDER BY EI.EDI_SN
                    FETCH FIRST 1 ROWS ONLY
                ) AS itemName,

                TO_CHAR(NVL(ED.ED_DCLR_DT, ER.ER_REGIST_DT), 'YYYY-MM-DD HH24:MI') AS requestDate,
                ED.ED_STATUS_CD AS statusCd,

                RJ.RM_RJCT_CN AS rejectReason,
                TO_CHAR(RJ.RM_RJCT_DT, 'YYYY-MM-DD HH24:MI') AS rejectDate,
                '접수반려' AS rejectType,

                ED.ED_DCLR_DT AS sortDate

            FROM EXP_DCLR ED
            JOIN EXP_RQST ER
              ON ER.ER_NO = ED.ED_ER_NO
            LEFT JOIN RJCT_MNG RJ
              ON RJ.RM_REF_NO = ED.ED_ER_NO
             AND RJ.RM_REF_BIZ_CD = 'EXP_DCLR'

            WHERE ER.ER_USE_YN = 'Y'
              AND ED.ED_STATUS_CD IN ('DCLR_WAIT', 'CSTM_REJ')

              <if test="reqNo != null and reqNo != ''">
                  AND ED.ED_ER_NO LIKE '%' || #{reqNo} || '%'
              </if>

              <if test="statusCd != null and statusCd != ''">
                  AND ED.ED_STATUS_CD = #{statusCd}
              </if>

              <if test="declareType != null and declareType != ''">
                  AND '수출' = #{declareType}
              </if>

              <if test="companyName != null and companyName != ''">
                  AND ER.ER_OWR_ID LIKE '%' || #{companyName} || '%'
              </if>

              <if test="itemName != null and itemName != ''">
                  AND EXISTS (
                      SELECT 1
                        FROM EXP_DCLR_ITEM EI2
                       WHERE EI2.EDI_ER_NO = ED.ED_ER_NO
                         AND EI2.EDI_EXPT_GDS_NM LIKE '%' || #{itemName} || '%'
                  )
              </if>

              <if test="startDate != null and startDate != ''">
                  AND TRUNC(NVL(ED.ED_DCLR_DT, ER.ER_REGIST_DT)) &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
              </if>

              <if test="endDate != null and endDate != ''">
                  AND TRUNC(NVL(ED.ED_DCLR_DT, ER.ER_REGIST_DT)) &lt;= TO_DATE(#{endDate}, 'YYYY-MM-DD')
              </if>

            ORDER BY sortDate DESC
        ) A
    </select>


    <!-- =========================================================
         [수입 접수 처리]

         DCLR_WAIT -> DCLR_REVIEW
         IMP_RQST가 아니라 IMP_DCLR 상태를 바꿔야 함
    ========================================================= -->
    <update id="updateImportReceiptAccept">
        UPDATE IMP_DCLR
           SET ID_STATUS_CD  = 'DCLR_REVIEW',
               ID_RCEPT_DT   = SYSDATE,
               ID_UPDT_DT    = SYSDATE,
               ID_OFFICER_ID = #{officerId}
         WHERE ID_IR_NO = #{reqNo}
           AND ID_STATUS_CD = 'DCLR_WAIT'
    </update>


    <!-- =========================================================
         [수입 담당자 저장]

         기존 service에서 이 메서드를 호출하고 있을 수 있어서 남겨둠.
         상태는 절대 DCLR_REVIEW로 바꾸지 않음.
    ========================================================= -->
    <update id="updateImportOfficer">
        UPDATE IMP_DCLR
           SET ID_OFFICER_ID = #{officerId},
               ID_UPDT_DT    = SYSDATE
         WHERE ID_IR_NO = #{reqNo}
    </update>


    <!-- =========================================================
         [수출 접수 처리]

         DCLR_WAIT -> DCLR_REVIEW
         EXP_RQST가 아니라 EXP_DCLR 상태를 바꿔야 함
    ========================================================= -->
    <update id="updateExportReceiptAccept">
        UPDATE EXP_DCLR
           SET ED_STATUS_CD = 'DCLR_REVIEW',
               ED_RECEPT_DT = SYSDATE,
               OFFICER_ID   = #{officerId}
         WHERE ED_ER_NO = #{reqNo}
           AND ED_STATUS_CD = 'DCLR_WAIT'
    </update>


    <!-- =========================================================
         [수출 담당자 저장]

         기존 service에서 이 메서드를 호출하고 있을 수 있어서 남겨둠.
         상태는 절대 DCLR_REVIEW로 바꾸지 않음.
    ========================================================= -->
    <update id="updateExportOfficer">
        UPDATE EXP_DCLR
           SET OFFICER_ID = #{officerId}
         WHERE ED_ER_NO = #{reqNo}
    </update>


    <!-- =========================================================
         [수입 반려 처리]

         DCLR_WAIT -> CSTM_REJ
         수입은 IMP_DCLR 안에 반려사유 컬럼이 있으므로 같이 저장
    ========================================================= -->
   <update id="updateImportReject">
	    UPDATE IMP_DCLR
	       SET ID_STATUS_CD    = 'CSTM_REJ',
	           ID_RJCT_RSN_CN  = #{rejectReason},
	           ID_RJCT_DT      = SYSDATE,
	           ID_UPDT_DT      = SYSDATE,
	           ID_OFFICER_ID   = #{officerId}
	     WHERE ID_IR_NO = #{reqNo}
	       AND ID_STATUS_CD = 'DCLR_WAIT'
	</update>


    <!-- =========================================================
         [수출 반려 처리]

         DCLR_WAIT -> CSTM_REJ
         수출 EXP_DCLR에는 반려사유 컬럼이 없으므로
         상태만 CSTM_REJ로 변경하고,
         반려사유는 아래 insertRejectMng에서 RJCT_MNG에 저장
    ========================================================= -->
   <update id="updateExportReject">
    UPDATE EXP_DCLR
       SET ED_STATUS_CD = 'CSTM_REJ',
           OFFICER_ID = #{officerId}
     WHERE ED_ER_NO = #{reqNo}
       AND ED_STATUS_CD = 'DCLR_WAIT'
	</update>


    <!-- =========================================================
         [반려사유 저장]

         중요:
         refBizCd는 이제 IMP_RQST / EXP_RQST가 아니라
         IMP_DCLR / EXP_DCLR 로 넣어야 함

         수입: refBizCd = IMP_DCLR
         수출: refBizCd = EXP_DCLR
    ========================================================= -->
    <insert id="insertRejectMng">
        MERGE INTO RJCT_MNG RJ
        USING DUAL
           ON (
               RJ.RM_REF_BIZ_CD = #{refBizCd}
           AND RJ.RM_REF_NO     = #{refNo}
           )
        WHEN MATCHED THEN
            UPDATE SET
                RJ.RM_RJCT_DT   = SYSDATE,
                RJ.RM_RJCT_CN   = #{rejectReason},
                RJ.RM_RJCTR_ID  = #{rejecterId},
                RJ.RM_TARGET_ID = #{targetId}
        WHEN NOT MATCHED THEN
            INSERT (
                RM_NO,
                RM_REF_BIZ_CD,
                RM_REF_NO,
                RM_RJCT_DT,
                RM_RJCT_CN,
                RM_RJCTR_ID,
                RM_TARGET_ID
            ) VALUES (
                'RM-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' || LPAD(SEQ_RJCT_MNG_NO.NEXTVAL, 5, '0'),
                #{refBizCd},
                #{refNo},
                SYSDATE,
                #{rejectReason},
                #{rejecterId},
                #{targetId}
            )
    </insert>


    <!-- =========================================================
         [수입 화주ID 조회]

         화주ID는 IMP_DCLR이 아니라 IMP_RQST에 있음
    ========================================================= -->
    <select id="selectImportOwnerId" resultType="string">
        SELECT IR_OWR_ID
          FROM IMP_RQST
         WHERE IR_NO = #{reqNo}
    </select>


    <!-- =========================================================
         [수출 화주ID 조회]

         화주ID는 EXP_DCLR이 아니라 EXP_RQST에 있음
    ========================================================= -->
    <select id="selectExportOwnerId" resultType="string">
        SELECT ER_OWR_ID
          FROM EXP_RQST
         WHERE ER_NO = #{reqNo}
    </select>


    <!-- =========================================================
         [반려사유 조회]

         refBizCd를 안 받는 구조라면 신고번호만으로 최신 1건 조회
         가능하면 나중에는 refBizCd까지 받아서 조회하는 게 더 정확함
    ========================================================= -->
    <select id="selectRejectReason" resultType="kr.or.tacs.dto.officer.ReceiptListDTO">
        SELECT
            RM_RJCT_CN AS rejectReason,
            TO_CHAR(RM_RJCT_DT, 'YYYY-MM-DD HH24:MI') AS rejectDate,
            '접수반려' AS rejectType
        FROM RJCT_MNG
        WHERE RM_REF_NO = #{reqNo}
        ORDER BY RM_RJCT_DT DESC
        FETCH FIRST 1 ROWS ONLY
    </select>

</mapper>