function buildImportBLCorrectionRequestPanel() {
  return `
    <div class="section-card border border-slate-300">
      <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
        <h4 class="text-sm font-bold text-slate-900">B/L 정정 신청</h4>
      </div>
      <div class="p-6 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="md:col-span-2"><label class="field-label">B/L번호</label><input class="field-input" type="text" placeholder="B/L번호 입력" /></div>
          <div><label class="field-label">정정 항목</label><input class="field-input" type="text" placeholder="정정 항목 입력" /></div>
          <div><label class="field-label">신청일</label><input class="field-input" type="datetime-local" /></div>
          <div class="md:col-span-2"><label class="field-label">정정 사유</label><textarea class="field-textarea h-28" placeholder="정정 사유 입력"></textarea></div>
        </div>
        <div>
          <label class="field-label">상세 내용</label>
          <textarea class="field-textarea h-32" placeholder="세부 내용을 입력하세요."></textarea>
        </div>
      </div>
      <div class="section-card-action-footer flex justify-end gap-2 px-6 py-4 border-t border-slate-200">
        <button class="px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">처리</button>
      </div>
    </div>
  `;
}


function buildImportManifestWorkflowPanel() {
  return `
    <div class="section-card border border-slate-300">
      <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
        <div>
          <h4 class="text-sm font-bold text-slate-900">적하목록 작성 및 제출</h4>
          <p class="text-xs text-slate-500 mt-1">입항 적하목록 대상 목록을 먼저 조회한 뒤 작성대기 건을 선택해 세관원에게 제출합니다.</p>
        </div>
        <button class="px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">조회</button>
      </div>

      <div class="p-6 space-y-6">
        <div class="overflow-hidden border border-slate-200">
          <table class="w-full tbl table-fixed">
            <colgroup>
              <col style="width:13%"><col style="width:12%"><col style="width:12%"><col style="width:10%"><col style="width:12%"><col style="width:9%"><col style="width:10%"><col style="width:8%"><col style="width:8%"><col style="width:6%">
            </colgroup>
            <thead>
              <tr>
                <th>의뢰번호</th>
                <th>Master B/L</th>
                <th>House B/L</th>
                <th>화주</th>
                <th>선박명/항차</th>
                <th>품명</th>
                <th>입항예정일</th>
                <th>상태</th>
                <th>심사결과</th>
                <th>처리</th>
              </tr>
            </thead>
            <tbody class="text-sm text-slate-700">
              <tr><td colspan="10" class="text-center text-slate-500 py-6">조회된 적하목록 대상이 없습니다.</td></tr>
            </tbody>
          </table>
        </div>

        <div class="border border-slate-200">
          <div class="px-4 py-3 bg-slate-50 border-b border-slate-200 text-sm font-bold text-slate-900">선택 적하목록 입력정보</div>
          <div class="p-4 space-y-6">
            <div>
              <h5 class="text-[11px] font-black uppercase tracking-widest mb-4 border-l-4 border-slate-700 pl-3 text-slate-700">적하목록 기본정보</h5>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div><label class="field-label">의뢰번호(REQUEST NO)</label><input id="manifestAutoNo" class="field-input bg-slate-50" type="text" readonly></div>
                <div><label class="field-label">Master B/L(MASTER BILL OF LADING)</label><input id="manifestMasterBl" class="field-input" type="text" placeholder="Master B/L 입력"></div>
                <div><label class="field-label">House B/L(HOUSE BILL OF LADING)</label><input id="manifestHouseBl" class="field-input" type="text" placeholder="House B/L 입력"></div>
                <div><label class="field-label">화주(SHIPPER)</label><input id="manifestShipper" class="field-input" type="text" placeholder="화주 입력"></div>
                <div class="md:col-span-2"><label class="field-label">선박명/항차(VESSEL / VOYAGE)</label><input id="manifestVessel" class="field-input" type="text" placeholder="선박명/항차 입력"></div>
              </div>
            </div>
            <div>
              <h5 class="text-[11px] font-black uppercase tracking-widest mb-4 border-l-4 border-slate-700 pl-3 text-slate-700">화물 정보</h5>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div><label class="field-label">품명(DESCRIPTION OF GOODS)</label><input id="manifestItemName" class="field-input" type="text" placeholder="품명 입력"></div>
                <div><label class="field-label">수량(QUANTITY)</label><input id="manifestQuantity" class="field-input" type="number" placeholder="수량 입력"></div>
                <div><label class="field-label">중량(WEIGHT)</label><input id="manifestWeightInput" class="field-input" type="number" placeholder="중량 입력"></div>
                <div><label class="field-label">비고(REMARKS)</label><textarea id="manifestNote" class="field-textarea h-28" placeholder="비고 입력"></textarea></div>
              </div>
            </div>
            <div>
              <h5 class="text-[11px] font-black uppercase tracking-widest mb-4 border-l-4 border-slate-700 pl-3 text-slate-700">제출 정보</h5>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div><label class="field-label">제출일(SUBMIT DATE)</label><input id="manifestSubmitDate" class="field-input" type="datetime-local"></div>
                <div><label class="field-label">제출대상(SUBMIT TARGET)</label><input id="manifestSubmitTarget" class="field-input bg-slate-50" type="text" value="행정공무원(세관)" readonly></div>
                <div class="md:col-span-2"><label class="field-label">반려사유(REJECT REASON)</label><textarea id="importManifestRejectReason" class="field-textarea bg-slate-50" placeholder="행정공무원이 반려한 경우 사유가 표시됩니다." readonly></textarea></div>
              </div>
            </div>
          </div>
          <div id="importManifestFooter" class="section-card-action-footer flex justify-end gap-2 px-6 py-4 border-t border-slate-200">
            <button id="openManifestCustomsModalBtn" class="px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">제출</button>
          </div>
        </div>
      </div>

      <div id="manifestCustomsModal" class="hidden fixed inset-0 z-[9999] items-center justify-center bg-slate-900/50 p-4">
        <div class="w-full max-w-3xl bg-white border border-slate-200 shadow-2xl">
          <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 bg-slate-50">
            <h4 class="text-sm font-bold text-slate-900">행정공무원 발송 폼</h4>
            <button type="button" id="manifestCustomsModalClose" class="text-slate-500 hover:text-slate-800 text-xl leading-none">×</button>
          </div>
          <div class="p-6 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div><label class="field-label">의뢰번호(REQUEST NO)</label><input id="customsManifestNo" class="field-input bg-slate-50" type="text" readonly></div>
              <div><label class="field-label">수신자(RECEIVER)</label><input class="field-input bg-slate-50" type="text" value="행정공무원(세관)" readonly></div>
              <div><label class="field-label">Master B/L(MASTER BILL OF LADING)</label><input id="customsMasterBl" class="field-input bg-slate-50" type="text" readonly></div>
              <div><label class="field-label">House B/L(HOUSE BILL OF LADING)</label><input id="customsHouseBl" class="field-input bg-slate-50" type="text" readonly></div>
              <div><label class="field-label">화주(SHIPPER)</label><input id="customsShipper" class="field-input bg-slate-50" type="text" readonly></div>
              <div><label class="field-label">발송일시(SEND DATE)</label><input id="customsSendAt" class="field-input bg-slate-50" type="text" readonly></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
              <div><label class="field-label">품명(DESCRIPTION OF GOODS)</label><input id="customsItemName" class="field-input bg-slate-50" type="text" readonly></div>
              <div><label class="field-label">수량(QUANTITY)</label><input id="customsQuantity" class="field-input bg-slate-50" type="text" readonly></div>
              <div><label class="field-label">중량(WEIGHT)</label><input id="customsWeight" class="field-input bg-slate-50" type="text" readonly></div>
            </div>
            <div>
              <label class="field-label">전달메시지(MESSAGE)</label>
              <textarea id="customsMessage" class="field-textarea h-28" placeholder="행정공무원에게 전달할 내용을 입력하세요.">입항 적하목록 검토 요청드립니다.</textarea>
            </div>
          </div>
          <div class="flex justify-end gap-2 px-6 py-4 border-t border-slate-200 bg-slate-50">
            <button type="button" id="manifestCustomsModalCancel" class="px-4 py-2 border border-slate-300 bg-white text-slate-700 text-xs font-bold">닫기</button>
            <button type="button" id="manifestCustomsSendBtn" class="px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">행정공무원 발송</button>
          </div>
        </div>
      </div>
    </div>
  `;
}

function bindImportManifestWorkflowActions(groupKey, itemId) {
  if (groupKey !== 'import' || itemId !== 'TACS-FW-023') return;

  const openButtons = detailBody.querySelectorAll('.import-manifest-open-btn');
  const footer = document.getElementById('importManifestFooter');
  const openBtn = document.getElementById('openManifestCustomsModalBtn');
  const modal = document.getElementById('manifestCustomsModal');
  const closeBtn = document.getElementById('manifestCustomsModalClose');
  const cancelBtn = document.getElementById('manifestCustomsModalCancel');
  const sendBtn = document.getElementById('manifestCustomsSendBtn');

  let activeRow = null;
  let activeMode = 'write';

  const fields = {
    manifestNo: document.getElementById('manifestAutoNo'),
    masterBl: document.getElementById('manifestMasterBl'),
    houseBl: document.getElementById('manifestHouseBl'),
    shipper: document.getElementById('manifestShipper'),
    vessel: document.getElementById('manifestVessel'),
    item: document.getElementById('manifestItemName'),
    quantity: document.getElementById('manifestQuantity'),
    weight: document.getElementById('manifestWeightInput'),
    note: document.getElementById('manifestNote'),
    submitDate: document.getElementById('manifestSubmitDate'),
    submitStatus: document.getElementById('importManifestSubmitStatus'),
    reviewResult: document.getElementById('importManifestReviewResult'),
    rejectReason: document.getElementById('importManifestRejectReason')
  };

  const copyValue = (fromId, toId) => {
    const from = document.getElementById(fromId);
    const to = document.getElementById(toId);
    if (from && to) to.value = from.value || '';
  };

  function setReadonly(readonly) {
    [fields.masterBl, fields.houseBl, fields.shipper, fields.vessel, fields.item, fields.quantity, fields.weight, fields.note, fields.submitDate].forEach(el => {
      if (!el) return;
      el.readOnly = readonly;
      el.classList.toggle('bg-slate-50', readonly);
    });
  }

  function applyData(btn) {
    activeRow = btn.closest('.import-manifest-row');
    activeMode = btn.dataset.mode || 'write';

    fields.manifestNo.value = btn.dataset.manifestNo || '';
    fields.masterBl.value = btn.dataset.masterBl || '';
    fields.houseBl.value = btn.dataset.houseBl || '';
    fields.shipper.value = btn.dataset.shipper || '';
    fields.vessel.value = btn.dataset.vessel || '';
    fields.item.value = btn.dataset.item || '';
    fields.quantity.value = btn.dataset.quantity || '';
    fields.weight.value = btn.dataset.weight || '';
    fields.note.value = btn.dataset.note || '';
    fields.submitDate.value = btn.dataset.eta ? `${btn.dataset.eta}T09:00` : '';
    if (fields.submitStatus) fields.submitStatus.value = activeRow?.dataset.status || '작성대기';
    if (fields.reviewResult) fields.reviewResult.value = activeRow?.dataset.reviewResult || '심사대기';
    if (fields.rejectReason) fields.rejectReason.value = activeRow?.dataset.rejectReason || '';

    const isView = activeMode === 'view' || (activeRow && activeRow.dataset.status === '제출완료');
    footer.classList.toggle('hidden', isView);
    setReadonly(isView);
  }

  const closeModal = () => {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  };

  if (openButtons.length) applyData(openButtons[0]);
  openButtons.forEach(btn => btn.addEventListener('click', function() { applyData(this); }));

  if (openBtn) {
    openBtn.addEventListener('click', () => {
      copyValue('manifestAutoNo', 'customsManifestNo');
      copyValue('manifestMasterBl', 'customsMasterBl');
      copyValue('manifestHouseBl', 'customsHouseBl');
      copyValue('manifestShipper', 'customsShipper');
      copyValue('manifestItemName', 'customsItemName');
      copyValue('manifestQuantity', 'customsQuantity');
      copyValue('manifestWeightInput', 'customsWeight');
      const sendAt = document.getElementById('customsSendAt');
      const submitDate = document.getElementById('manifestSubmitDate');
      if (sendAt) sendAt.value = submitDate?.value || new Date().toISOString().slice(0,16).replace('T',' ');
      if (modal) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
      }
    });
  }

  [closeBtn, cancelBtn].forEach(btn => {
    if (btn) btn.addEventListener('click', closeModal);
  });

  if (modal) {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  }

  if (sendBtn) {
    sendBtn.addEventListener('click', () => {
      if (activeRow) {
        const statusCell = activeRow.querySelector('.import-manifest-status-cell');
        const actionCell = activeRow.querySelector('.import-manifest-action-cell');
        if (statusCell) statusCell.innerHTML = buildStatusChip('제출완료');
        const reviewCell = activeRow.querySelector('.import-manifest-review-cell');
        if (reviewCell) reviewCell.innerHTML = buildStatusChip('심사대기');
        activeRow.dataset.status = '제출완료';
        activeRow.dataset.reviewResult = '심사대기';
        activeRow.dataset.rejectReason = '';
        if (fields.submitStatus) fields.submitStatus.value = '제출완료';
        if (fields.reviewResult) fields.reviewResult.value = '심사대기';
        if (fields.rejectReason) fields.rejectReason.value = '';
        if (actionCell) {
          actionCell.innerHTML = `<button type="button" class="import-manifest-open-btn px-3 py-1 border border-slate-300 bg-white text-slate-700 text-xs font-bold"
            data-mode="view"
            data-manifest-no="${fields.manifestNo.value}"
            data-master-bl="${fields.masterBl.value}"
            data-house-bl="${fields.houseBl.value}"
            data-shipper="${fields.shipper.value}"
            data-vessel="${fields.vessel.value}"
            data-item="${fields.item.value}"
            data-quantity="${fields.quantity.value}"
            data-weight="${fields.weight.value}"
            data-eta="${(fields.submitDate.value || '').slice(0,10)}"
            data-note="${fields.note.value}">상세</button>`;
        }
      }
      alert('입항 적하목록이 행정공무원에게 발송되었습니다.');
      closeModal();
      const newBtn = activeRow ? activeRow.querySelector('.import-manifest-open-btn') : null;
      if (newBtn) {
        newBtn.addEventListener('click', function() { applyData(this); });
        applyData(newBtn);
      }
    });
  }
}

/* ===== script block 3 from original HTML ===== */
(function(){
  const modal = document.getElementById('importDocRejectModal');
  if(!modal) return;
  const titleEl = modal.querySelector('div[style*="font-weight:800"]');
  const fields = {
    requestNo: document.getElementById('importRejectRequestNo'),
    owner: document.getElementById('importRejectOwner'),
    docName: document.getElementById('importRejectDocName'),
    receivedAt: document.getElementById('importRejectReceivedAt'),
    reason: document.getElementById('importRejectReason')
  };
  let activeRow = null;
  let activeGroupKey = '';
  let activeDocKey = '';

  function applyRejectedState(){
    if(activeDocKey && typeof shippingDocStatusOverrides !== 'undefined'){
      shippingDocStatusOverrides[activeDocKey] = {
        status: '반려',
        reason: fields.reason.value.trim(),
        sentTo: fields.owner.value || '화주'
      };
    }

    if(activeRow){
      const statusCell = activeRow.querySelector('.receive-status-cell');
      const actionCell = activeRow.lastElementChild;
      const chip = typeof buildStatusChip === 'function'
          ? buildStatusChip('반려')
          : '<span style="display:inline-flex; align-items:center; justify-content:center; min-width:58px; height:30px; padding:0 12px; background:#fff1f2; color:#be123c; border:1px solid #fecdd3; font-size:12px; font-weight:700;">반려</span>';
      if(statusCell) statusCell.innerHTML = chip;
      if(actionCell) actionCell.innerHTML = chip;
    }
  }

  window.openShippingDocRejectModal = function(btn, groupKey){
    activeRow = btn.closest('tr');
    activeGroupKey = groupKey || ((btn.dataset.requestNo || '').startsWith('IMP') ? 'import' : 'export');
    activeDocKey = typeof getShippingDocKey === 'function'
        ? getShippingDocKey(activeGroupKey, btn.dataset.requestNo, btn.dataset.docName)
        : `${activeGroupKey}:${btn.dataset.requestNo || ''}:${btn.dataset.docName || ''}`;

    if (typeof selectedShippingDoc !== 'undefined') {
      selectedShippingDoc = {
        groupKey: activeGroupKey,
        requestNo: btn.dataset.requestNo || '',
        owner: btn.dataset.owner || '',
        docName: btn.dataset.docName || '',
        receivedAt: btn.dataset.receivedAt || '',
        sender: btn.dataset.sender || '',
        receiveStatus: btn.dataset.receiveStatus || '',
        key: activeDocKey
      };
    }

    if(titleEl) titleEl.textContent = activeGroupKey === 'import' ? '수입 선적서류 반려' : '수출 선적서류 반려';
    fields.requestNo.value = btn.dataset.requestNo || '';
    fields.owner.value = btn.dataset.owner || '';
    fields.docName.value = btn.dataset.docName || '';
    fields.receivedAt.value = btn.dataset.receivedAt || '';
    fields.reason.value = '';
    modal.style.display = 'flex';
  };

  function closeModal(){
    modal.style.display = 'none';
    activeRow = null;
    activeGroupKey = '';
    activeDocKey = '';
  }

  document.addEventListener('click', function(e){
    const rejectBtn = e.target.closest('.receive-doc-reject-btn');
    if(rejectBtn && !e.defaultPrevented){
      e.preventDefault();
      e.stopPropagation();
      window.openShippingDocRejectModal(rejectBtn);
      return;
    }

    if(e.target.id === 'importRejectCancelBtn'){
      e.preventDefault();
      closeModal();
      return;
    }

    if(e.target.id === 'importRejectSubmitBtn'){
      e.preventDefault();
      if(!fields.reason.value.trim()){
        alert('반려 사유를 입력해주세요.');
        return;
      }
      applyRejectedState();
      const owner = fields.owner.value || '화주';
      closeModal();
      alert(`${owner}에게 선적서류 반려 및 보완 요청이 발송되었습니다.`);
      return;
    }

    if(e.target === modal){
      closeModal();
    }
  });
})();
