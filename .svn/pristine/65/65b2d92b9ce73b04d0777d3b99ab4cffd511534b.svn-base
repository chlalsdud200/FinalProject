/* ===== 보완수정: 모델/규격 테이블 input 정리 ===== */
#supp-mdlspec-table input {
  width: 100%;
  height: 32px;
  padding: 6px 8px;
  border: 1px solid #cbd5e1;
  border-radius: 4px;
  background: #ffffff;
  color: #203444;
  font-size: 12px;
  font-weight: 500;
  box-sizing: border-box;
  outline: none;
}

#supp-mdlspec-table input::placeholder {
  color: #94a3b8;
  font-weight: 400;
}

#supp-mdlspec-table input:focus {
  border-color: #7b8da8;
  box-shadow: 0 0 0 2px rgba(86, 94, 116, 0.12);
}

#supp-mdlspec-table td {
  vertical-align: middle;
  padding: 8px 10px;
}

#supp-mdlspec-table .mini-reject {
  border: 0;
  border-radius: 6px;
  background: #fee2e2;
  color: #b91c1c;
  font-size: 11px;
  font-weight: 800;
  padding: 6px 10px;
  cursor: pointer;
}

#supp-mdlspec-table .mini-reject:hover {
  background: #fecaca;
}
/* ===== 보완수정: a 태그 버튼 밑줄 제거 ===== */
a.btn,
a.btn-secondary,
a.btn-outline,
a.item-action-btn,
a.mini {
  text-decoration: none;
}

a.btn:hover,
a.btn-secondary:hover,
a.btn-outline:hover,
a.item-action-btn:hover,
a.mini:hover {
  text-decoration: none;
}
#st-supp-form .btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 58px;
  height: 34px;
  padding: 0 14px;
  border-radius: 4px;
  border: 1px solid #9fb3ca;
  background: #eef4fb;
  color: #334155;
  font-size: 12px;
  font-weight: 800;
}

#st-supp-form .btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 78px;
  height: 34px;
  padding: 0 16px;
  border-radius: 4px;
  border: 1px solid #565e74;
  background: #565e74;
  color: #ffffff;
  font-size: 12px;
  font-weight: 800;
}
/* ===== 세금납부 · 화주청구 수수료 계산 상세 모달 ===== */
.charge-calc-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(15, 23, 42, 0.45);
  align-items: center;
  justify-content: center;
  padding: 24px;
}

.charge-calc-overlay.show {
  display: flex;
}

.charge-calc-modal {
  width: 720px;
  max-width: 95vw;
  max-height: 90vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 10px;
  box-shadow: 0 24px 70px rgba(15, 23, 42, 0.25);
}

.charge-calc-modal .modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 22px;
  border-bottom: 1px solid #e5edf5;
}

.charge-calc-modal .modal-header h3 {
  display: flex;
  align-items: center;
  gap: 6px;
  margin: 0;
  font-size: 17px;
  font-weight: 900;
  color: #16283a;
}

.charge-calc-modal .modal-close {
  border: 0;
  background: transparent;
  font-size: 24px;
  cursor: pointer;
  color: #64748b;
}

.charge-calc-body {
  padding: 20px 22px;
}

.charge-calc-summary {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  padding: 14px;
  background: #f8fafc;
  border: 1px solid #dbe7f1;
  border-radius: 8px;
  margin-bottom: 18px;
}

.calc-label {
  display: block;
  font-size: 11px;
  color: #64748b;
  margin-bottom: 4px;
}

.charge-calc-section {
  margin-top: 16px;
}

.charge-calc-section h4 {
  margin: 0 0 8px;
  font-size: 14px;
  font-weight: 900;
  color: #16283a;
}

.calc-table {
  width: 100%;
  border-collapse: collapse;
  border-top: 1px solid #dbe7f1;
}

.calc-table th {
  width: 180px;
  background: #f5f8fb;
  color: #334155;
  text-align: left;
  font-size: 12px;
  padding: 10px 12px;
  border-bottom: 1px solid #dbe7f1;
}

.calc-table td {
  font-size: 12px;
  color: #16283a;
  padding: 10px 12px;
  border-bottom: 1px solid #dbe7f1;
}

.calc-table.result .total-row th,
.calc-table.result .total-row td {
  font-size: 14px;
  font-weight: 900;
  color: #9f403d;
  background: #fff7f7;
}

.charge-calc-formula {
  margin-top: 16px;
  padding: 12px;
  background: #f8fafc;
  border-left: 4px solid #565e74;
  font-size: 12px;
  color: #334155;
}

.charge-calc-modal .modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  padding: 14px 22px;
  border-top: 1px solid #e5edf5;
}