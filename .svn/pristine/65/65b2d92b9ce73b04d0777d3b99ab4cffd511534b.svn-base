@charset "UTF-8";

.pagination a.page-btn {
  text-decoration: none;
}

.pagination span.page-btn.disabled {
  opacity: 0.4;
  cursor: not-allowed;
  background: #fff;
  color: #4d6172;
  border: 1px solid #cbd5e1;
}

.page-info {
  margin-left: 8px;
  font-size: 11px;
  color: #697d8f;
}
