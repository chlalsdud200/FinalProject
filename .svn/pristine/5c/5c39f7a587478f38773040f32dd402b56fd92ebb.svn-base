package kr.or.tacs.officer.basicscreen.mapper;

import java.util.List;
import java.util.Map;

import org.apache.ibatis.annotations.Mapper;

import kr.or.tacs.dto.officer.BasicScreenDetailDTO;

@Mapper
public interface IScreenDetailMapper {

    // ── 상세 조회 ──────────────────────────────────────
    BasicScreenDetailDTO selectImportDetail(String reqNo);
    BasicScreenDetailDTO selectExportDetail(String reqNo);

    // ── 품목 목록 ──────────────────────────────────────
    List<BasicScreenDetailDTO> selectImportItems(String reqNo);
    List<BasicScreenDetailDTO> selectExportItems(String reqNo);

    // ── 세금납부 탭 ────────────────────────────────────────
    /** 세금정보 전달 처리 (CT_CRT_DT 기준, CT_PAY_STATUS_CD = TAX_UNPAID) */
    int updateTaxSendDate(String reqNo);

    /** 세금탭 품목별 최신 세율·세액 조회 (AJAX용) */
    List<Map<String, Object>> selectTaxItems(String reqNo);

    /** 세율 재조회 후 IDI_TAXT_RT DB 저장 */
    int updateItemTaxRate(Map<String, Object> param);

    /** 세율 변경 후 CUSTOMS_TAX 세액 재계산 */
    int recalcCustomsTax(String reqNo);

    /** CUSTOMS_TAX 레코드 존재 여부 확인 */
    int selectTaxCount(String reqNo);

    /** CUSTOMS_TAX 자동 생성 (IMP_DCLR_ITEM 집계 계산) */
    int insertCustomsTaxAuto(String reqNo);

    /** CUSTOMS_TAX + IMP_DCLR 조인으로 세금 정보 조회 */
    kr.or.tacs.dto.officer.TaxDTO selectImportTax(String reqNo);

    /** 납부완료: CUSTOMS_TAX 상태 TAX_PAID 갱신 */
    int updateTaxPayStatus(String reqNo);

    /** 납부완료: CUSTOMS_TAX_PAY 이력 INSERT */
    int insertTaxPay(String reqNo);

    // ── 승인/필증 처리 ───────────────────────────────────────
    /** 수입 신고 상태 업데이트 */
    int updateImpDclrStatus(Map<String, Object> param);

    /** 수입 의뢰 상태 업데이트 */
    int updateImpRqstStatus(Map<String, Object> param);

    /** 수출 신고 상태 업데이트 */
    int updateExpDclrStatus(Map<String, Object> param);

    /** 수출 의뢰 상태 업데이트 */
    int updateExpRqstStatus(Map<String, Object> param);

    /** 신고필증 중복 발급 여부 확인 */
    int selectCertificateCount(Map<String, Object> param);

    /** 신고필증 발급 INSERT */
    int insertCertificate(Map<String, Object> param);

    // ── 란사항 처리 ────────────────────────────────────────
    String selectTargetBrokerId(String reqNo);

    /** 보완요청 → SUPP_RQST INSERT */
    int insertItemSupplement(Map<String, Object> param);

    /** 반려 → RJCT_MNG INSERT */
    int insertItemReject(Map<String, Object> param);

    /** 수입 란사항 상태 직접 UPDATE (보완요청 / 반려 / 수리 공통) */
    int updateImpDclrItemStatus(Map<String, Object> param);
    
    int updateCertificateTfgNo(Map<String, Object> param);
    
}