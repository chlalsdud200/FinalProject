<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.officer.fulfillmentandexport.mapper.ILoadedCargoListMapper">

    <!--
        실제 테이블 기준
        - 적재화물목록: EXP_CARGO_MANIFEST + EXP_DCLR + EXP_RQST
        - 혼재화물 적하목록: IMP_CARGO_MANIFEST + IMP_DCLR + IMP_RQST
    -->

    <select id="selectLoadedCargoList" resultType="kr.or.tacs.dto.officer.LoadedCargoListDTO">
        SELECT
            ROWNUM AS "no",
            X."listNo",
            X."goodsGroupNo",
            X."blNo",
            X."mblNo",
            X."hblNo",
            X."reqNo",
            X."declareType",
            X."declareStatusCd",
            X."declareStatus",
            X."ownerName",
            X."itemName",
            X."vesselName",
            X."submitStatusCd",
            X."submitStatus",
            X."submitDate",
            X."remark"
        FROM (
            SELECT
                TO_CHAR(ECM.ECM_NO) AS "listNo",
                TO_CHAR(ECM.ECM_GG_NO) AS "goodsGroupNo",
                ECM.ECM_BL_NO AS "blNo",
                NULL AS "mblNo",
                NULL AS "hblNo",
                ED.ED_ER_NO AS "reqNo",
                'EXPORT' AS "declareType",
                ED.ED_STATUS_CD AS "declareStatusCd",
                CASE ED.ED_STATUS_CD
                    WHEN 'CSTM_REQ' THEN '접수대기'
                    WHEN 'BASIC_WAIT' THEN '기본심사대기'
                    WHEN 'DCLR_REVIEW' THEN '심사중'
                    WHEN 'REVIEWING' THEN '심사중'
                    WHEN 'APRV_DONE' THEN '승인완료'
                    WHEN 'APPROVED' THEN '승인완료'
                    WHEN 'CSTM_COMPLETE' THEN '통관완료'
                    WHEN 'CLR_CMPT' THEN '통관완료'
                    WHEN 'RCP_REJECT' THEN '반려'
                    WHEN 'REJECTED' THEN '반려'
                    ELSE NVL(ED.ED_STATUS_CD, '-')
                END AS "declareStatus",
                NVL(OW.OWR_NM, ECM.ECM_OWR_ID) AS "ownerName",
                NVL(EI.ITEM_NM, ER.ER_COMMENT) AS "itemName",
                NVL(SH.SHIP_CP_NM, '-') AS "vesselName",
                CASE WHEN ECM.ECM_SBMSN_DT IS NULL THEN 'MISSING' ELSE 'SUBMITTED' END AS "submitStatusCd",
                CASE WHEN ECM.ECM_SBMSN_DT IS NULL THEN '미제출' ELSE '제출완료' END AS "submitStatus",
                TO_CHAR(ECM.ECM_SBMSN_DT, 'YYYY-MM-DD') AS "submitDate",
                NVL(ECM.ECM_RMRK_CN,
                    CASE WHEN ECM.ECM_SBMSN_DT IS NULL THEN '적재화물목록 미제출' ELSE '적재화물목록 제출 확인' END
                ) AS "remark"
            FROM EXP_CARGO_MANIFEST ECM
            LEFT JOIN EXP_DCLR ED
                ON ED.ED_GG_NO = ECM.ECM_GG_NO
            LEFT JOIN EXP_RQST ER
                ON ER.ER_NO = ED.ED_ER_NO
            LEFT JOIN OWNER OW
                ON OW.OWR_ID = ECM.ECM_OWR_ID
            LEFT JOIN (
                SELECT
                    EDI_ER_NO,
                    MIN(EDI_EXPT_GDS_NM) AS ITEM_NM
                FROM EXP_DCLR_ITEM
                GROUP BY EDI_ER_NO
            ) EI
                ON EI.EDI_ER_NO = ED.ED_ER_NO
            LEFT JOIN SHIP_INST_SUBMIT SIS
                ON SIS.SIS_GG_NO = ECM.ECM_GG_NO
            LEFT JOIN SHIP SH
                ON SH.SHIP_NO = SIS.SIS_SHIP_NO
            WHERE 1 = 1
            <if test="reqNo != null and reqNo != ''">
                AND ED.ED_ER_NO LIKE '%' || #{reqNo} || '%'
            </if>
            <if test="submitStatusCd != null and submitStatusCd != '' and submitStatusCd != 'ALL'">
                AND (CASE WHEN ECM.ECM_SBMSN_DT IS NULL THEN 'MISSING' ELSE 'SUBMITTED' END) = #{submitStatusCd}
            </if>
            <if test="startDate != null and startDate != ''">
                AND ECM.ECM_SBMSN_DT <![CDATA[>=]]> TO_DATE(#{startDate}, 'YYYY-MM-DD')
            </if>
            <if test="endDate != null and endDate != ''">
                AND ECM.ECM_SBMSN_DT <![CDATA[<]]> TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
            </if>
            <if test="keyword != null and keyword != ''">
                AND (
                    ECM.ECM_BL_NO LIKE '%' || #{keyword} || '%'
                    OR ECM.ECM_OWR_ID LIKE '%' || #{keyword} || '%'
                    OR OW.OWR_NM LIKE '%' || #{keyword} || '%'
                    OR NVL(EI.ITEM_NM, ER.ER_COMMENT) LIKE '%' || #{keyword} || '%'
                )
            </if>
            ORDER BY ECM.ECM_SBMSN_DT DESC NULLS LAST, ECM.ECM_NO DESC
        ) X
    </select>

    <select id="selectMixedCargoList" resultType="kr.or.tacs.dto.officer.LoadedCargoListDTO">
        SELECT
            ROWNUM AS "no",
            X."listNo",
            X."goodsGroupNo",
            X."blNo",
            X."mblNo",
            X."hblNo",
            X."reqNo",
            X."declareType",
            X."declareStatusCd",
            X."declareStatus",
            X."ownerName",
            X."itemName",
            X."vesselName",
            X."submitStatusCd",
            X."submitStatus",
            X."submitDate",
            X."remark"
        FROM (
            SELECT
                TO_CHAR(ICM.ICM_NO) AS "listNo",
                TO_CHAR(ICM.ICM_GG_NO) AS "goodsGroupNo",
                NVL(ICM.ICM_HBL_NO, ICM.ICM_MBL_NO) AS "blNo",
                ICM.ICM_MBL_NO AS "mblNo",
                ICM.ICM_HBL_NO AS "hblNo",
                ID.ID_IR_NO AS "reqNo",
                'IMPORT' AS "declareType",
                ID.ID_STATUS_CD AS "declareStatusCd",
                CASE ID.ID_STATUS_CD
                    WHEN 'CSTM_REQ' THEN '접수대기'
                    WHEN 'BASIC_WAIT' THEN '기본심사대기'
                    WHEN 'DCLR_REVIEW' THEN '심사중'
                    WHEN 'REVIEWING' THEN '심사중'
                    WHEN 'APRV_DONE' THEN '승인완료'
                    WHEN 'APPROVED' THEN '승인완료'
                    WHEN 'CSTM_COMPLETE' THEN '통관완료'
                    WHEN 'CLR_CMPT' THEN '통관완료'
                    WHEN 'RCP_REJECT' THEN '반려'
                    WHEN 'REJECTED' THEN '반려'
                    ELSE NVL(ID.ID_STATUS_CD, '-')
                END AS "declareStatus",
                NVL(OW.OWR_NM, ICM.ICM_OWR_ID) AS "ownerName",
                NVL(II.ITEM_NM, IR.IR_COMMENT) AS "itemName",
                '-' AS "vesselName",
                CASE WHEN ICM.ICM_SBMSN_DT IS NULL THEN 'MISSING' ELSE 'SUBMITTED' END AS "submitStatusCd",
                CASE WHEN ICM.ICM_SBMSN_DT IS NULL THEN '미제출' ELSE '제출완료' END AS "submitStatus",
                TO_CHAR(ICM.ICM_SBMSN_DT, 'YYYY-MM-DD') AS "submitDate",
                NVL(ICM.ICM_RMRK_CN,
                    CASE WHEN ICM.ICM_SBMSN_DT IS NULL THEN '혼재화물 적하목록 미제출' ELSE '혼재화물 적하목록 제출 확인' END
                ) AS "remark"
            FROM IMP_CARGO_MANIFEST ICM
            LEFT JOIN IMP_DCLR ID
                ON ID.ID_GG_NO = ICM.ICM_GG_NO
            LEFT JOIN IMP_RQST IR
                ON IR.IR_NO = ID.ID_IR_NO
            LEFT JOIN OWNER OW
                ON OW.OWR_ID = ICM.ICM_OWR_ID
            LEFT JOIN (
                SELECT
                    IDI_IR_NO,
                    MIN(IDI_DCLR_GDSNM) AS ITEM_NM
                FROM IMP_DCLR_ITEM
                GROUP BY IDI_IR_NO
            ) II
                ON II.IDI_IR_NO = ID.ID_IR_NO
            WHERE 1 = 1
            <if test="reqNo != null and reqNo != ''">
                AND ID.ID_IR_NO LIKE '%' || #{reqNo} || '%'
            </if>
            <if test="submitStatusCd != null and submitStatusCd != '' and submitStatusCd != 'ALL'">
                AND (CASE WHEN ICM.ICM_SBMSN_DT IS NULL THEN 'MISSING' ELSE 'SUBMITTED' END) = #{submitStatusCd}
            </if>
            <if test="startDate != null and startDate != ''">
                AND ICM.ICM_SBMSN_DT <![CDATA[>=]]> TO_DATE(#{startDate}, 'YYYY-MM-DD')
            </if>
            <if test="endDate != null and endDate != ''">
                AND ICM.ICM_SBMSN_DT <![CDATA[<]]> TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
            </if>
            <if test="keyword != null and keyword != ''">
                AND (
                    ICM.ICM_MBL_NO LIKE '%' || #{keyword} || '%'
                    OR ICM.ICM_HBL_NO LIKE '%' || #{keyword} || '%'
                    OR ICM.ICM_OWR_ID LIKE '%' || #{keyword} || '%'
                    OR OW.OWR_NM LIKE '%' || #{keyword} || '%'
                    OR NVL(II.ITEM_NM, IR.IR_COMMENT) LIKE '%' || #{keyword} || '%'
                )
            </if>
            ORDER BY ICM.ICM_SBMSN_DT DESC NULLS LAST, ICM.ICM_NO DESC
        ) X
    </select>

</mapper>
