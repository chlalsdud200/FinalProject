<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.fieldofficer.mypage.mapper.IMypageMapper">

	<!-- 공무원 정보 조회 결과 매핑 -->
    <resultMap id="officerMap" type="kr.or.tacs.vo.OfficerVO">
        <id property="officerId" column="OFFICER_ID" />

        <result property="officerPassword" column="OFFICER_PASSWORD" />
        <result property="officerTyCd" column="OFFICER_TY_CD" />

        <!-- OFFICER_NAME: 행정기관명 -->
        <result property="officerName" column="OFFICER_NAME" />

        <!-- OFFICER_NM: 실제 공무원명 -->
        <result property="officerNm" column="OFFICER_NM" />

        <result property="officerInstCd" column="OFFICER_INST_CD" />
        <result property="officerDeptCd" column="OFFICER_DEPT_CD" />
        <result property="officerClsfCd" column="OFFICER_CLSF_CD" />
        <result property="officerFieldCd" column="OFFICER_FIELD_CD" />

        <result property="officerEmail" column="OFFICER_EMAIL" />
        <result property="officerTelno" column="OFFICER_TELNO" />
        <result property="officerZip" column="OFFICER_ZIP" />
        <result property="officerAdres" column="OFFICER_ADRES" />
        <result property="officerDetailAdres" column="OFFICER_DETAIL_ADRES" />

        <result property="officerUseYn" column="OFFICER_USE_YN" />
        <result property="officerRegistDt" column="OFFICER_REGIST_DT" />
        <result property="officerUpdtDt" column="OFFICER_UPDT_DT" />
    </resultMap>


    <!-- 마이페이지에 보여줄 공무원 정보 조회 -->
    <select id="selectOfficer" parameterType="string" resultMap="officerMap">
        SELECT
            OFFICER_ID,
            OFFICER_PASSWORD,
            OFFICER_TY_CD,
            OFFICER_NAME,
            OFFICER_NM,
            OFFICER_INST_CD,
            OFFICER_DEPT_CD,
            OFFICER_CLSF_CD,
            OFFICER_FIELD_CD,
            OFFICER_EMAIL,
            OFFICER_TELNO,
            OFFICER_ZIP,
            OFFICER_ADRES,
            OFFICER_DETAIL_ADRES,
            OFFICER_USE_YN,
            OFFICER_REGIST_DT,
            OFFICER_UPDT_DT
        FROM OFFICER
        WHERE OFFICER_ID = #{officerId}
    </select>


    <!-- 마이페이지 개인정보 수정 -->
    <update id="updateOfficer" parameterType="kr.or.tacs.vo.OfficerVO">
        UPDATE OFFICER
        SET
            OFFICER_NM = #{officerNm},
            OFFICER_EMAIL = #{officerEmail},
            OFFICER_TELNO = #{officerTelno},
            OFFICER_ZIP = #{officerZip},
            OFFICER_ADRES = #{officerAdres},
            OFFICER_DETAIL_ADRES = #{officerDetailAdres},
            OFFICER_UPDT_DT = SYSDATE
        WHERE OFFICER_ID = #{officerId}
    </update>


	<!-- 기존 알림 설정 삭제 -->
	<delete id="deleteAlarmSettingByOfficerId" parameterType="string">
	    DELETE FROM ALRM_STNG
	    WHERE AS_RCV_ACTR_ID = #{officerId}
	</delete>
	
	
	<!-- 알림유형코드로 알림 설정 등록 -->
	<insert id="insertAlarmSettingByTyCd">
	    INSERT INTO ALRM_STNG (
	        AS_NO,
	        AS_AR_NO,
	        AS_RCV_ACTR_ID,
	        AS_WEB_YN,
	        AS_REGIST_DT,
	        AS_UPDT_DT
	    )
	    SELECT
	        (SELECT NVL(MAX(AS_NO), 0) + 1 FROM ALRM_STNG),
	        AR_NO,
	        #{officerId},
	        #{webAlarmYn},
	        SYSDATE,
	        SYSDATE
	    FROM ALRM_RULE
	    WHERE AR_TY_CD = #{alarmRuleTyCd}
	      AND AR_USE_YN = 'Y'
	      AND ROWNUM = 1
	</insert>

	<!-- 저장된 알림 유형 코드 목록 조회 -->
	<select id="selectAlarmRuleTyCdList" resultType="java.lang.String">
		SELECT
			R.AR_TY_CD
		FROM ALRM_STNG S
		JOIN ALRM_RULE R
		  ON S.AS_AR_NO = R.AR_NO
		WHERE S.AS_RCV_ACTR_ID = #{officerId}
		ORDER BY R.AR_SORT_SN
	</select>
	
	<!-- 시스템 알림 사용 여부 조회 -->
	<select id="selectWebAlarmYn" resultType="java.lang.String">
		SELECT
			NVL(MAX(S.AS_WEB_YN), 'N')
		FROM ALRM_STNG S
		WHERE S.AS_RCV_ACTR_ID = #{officerId}
	</select>


</mapper>
