<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.warehouse.outbound.mapper.OutboundMapper">

	<!--
		반출서류 수령관리 목록 조회

		기준:
		- 입고완료(IN_DONE)된 입고의뢰건
		- 운송업체가 D/O + 신고필증을 전달했는지 확인
	-->
	<select id="selectOutboundDocList"
			parameterType="string"
			resultType="kr.or.tacs.dto.warehouse.WarehouseOutboundDocDTO">

		SELECT
			WIR.WIR_NO wirNo,
			WIR.WIR_IO_SE_CD wirIoSeCd,

			CASE
				WHEN WIR.WIR_IO_SE_CD = 'IMP' THEN '수입'
				WHEN WIR.WIR_IO_SE_CD = 'EXP' THEN '수출'
				ELSE WIR.WIR_IO_SE_CD
			END wirIoSeNm,

			WIR.WIR_OWR_NM wirOwrNm,

			NVL(GOODS_SUM.FIRST_ITEM_NAME, WIR.WIR_RQST_CN) firstItemName,
			NVL(GOODS_SUM.ITEM_CNT, 0) itemCnt,

			TO_CHAR(DI.DI_DLVRY_DT, 'YYYY-MM-DD') wirCompleteDt,

			DI.DI_STATUS_CD diStatusCd,

			CASE
				WHEN DI.DI_STATUS_CD IN ('TRC_DO_REQ', 'DELIVERED') THEN '수령완료'
				ELSE '수령전'
			END docStatusNm,

			DI.DI_TFG_NO diTfgNo,
			NVL(FILE_SUM.FILE_CNT, 0) fileCnt

		FROM WH_IN_RPT WIR

		/*
			DO_ISSUANCE.DI_TRC_NO는 입고의뢰번호가 아니라
			TRAN_RCP.TRC_NO를 참조한다.

			연결 흐름:
			WH_IN_RPT.WIR_GG_NO
			-> TRAN_RCP.TRC_TFG_NO
			-> TRAN_RCP.TRC_NO
			-> DO_ISSUANCE.DI_TRC_NO
		*/
		LEFT JOIN TRAN_RCP T
			   ON T.TRC_TFG_NO = WIR.WIR_GG_NO
			  AND T.TRC_SE_CD = WIR.WIR_IO_SE_CD
			  AND T.TRC_STATUS_CD = 'TRC_DONE'

		LEFT JOIN DO_ISSUANCE DI
			   ON DI.DI_TRC_NO = T.TRC_NO
			  AND NVL(DI.DI_TRDE_SE_CD, WIR.WIR_IO_SE_CD) = WIR.WIR_IO_SE_CD

		/*
			대표 품명 / 품목 수
		*/
		LEFT JOIN (
			SELECT
				CG.GG_NO GG_NO,
				MIN(G.GOODS_NAME) FIRST_ITEM_NAME,
				COUNT(*) ITEM_CNT
			FROM CUSTOMS_GOODS CG
			JOIN GOODS G
			  ON G.GOODS_NO = CG.GOODS_NO
			GROUP BY CG.GG_NO
		) GOODS_SUM
		  ON GOODS_SUM.GG_NO = WIR.WIR_GG_NO

		/*
			D/O + 신고필증 파일 개수
		*/
		LEFT JOIN (
			SELECT
				TFM.TFM_TFG_NO TFG_NO,
				COUNT(*) FILE_CNT
			FROM TACS_FILE_MAP TFM
			JOIN DOCS_FILE_DATA DFI
			  ON DFI.DFI_FILE_NO = TFM.TFM_DFI_NO
			WHERE NVL(DFI.DFI_DEL_YN, 'N') = 'N'
			GROUP BY TFM.TFM_TFG_NO
		) FILE_SUM
		  ON FILE_SUM.TFG_NO = DI.DI_TFG_NO

		WHERE WIR.WIR_WM_ID = #{wmId}
		  AND WIR.WIR_STATUS_CD = 'IN_DONE'

		ORDER BY DI.DI_DLVRY_DT DESC NULLS LAST, WIR.WIR_NO DESC

	</select>


	<!--
		반출처리관리 목록 / 상세 조회

		변경된 기준:
		- 기존 CARGO_RELEASE.CR_STATUS_CD 사용 X
		- 이제 CARGO_RELEASE_REQ.CRR_STATUS_CD 사용

		조회 목적:
		- 반출요청 목록 출력
		- 상세보기 모달에 필요한 운송업체 / 창고위치 / 물품 / 첨부서류 정보까지 같이 조회
	-->
	<select id="selectOutboundProcessList"
	        parameterType="string"
	        resultType="kr.or.tacs.dto.warehouse.WarehouseOutboundProcessDTO">

		SELECT
			/*
				1. 반출요청 기본 정보
			*/
			CRR.CRR_NO crrNo,
			CRR.CRR_TRE_ID crrTreId,
			CRR.CRR_OWR_ID crrOwrId,
			CRR.CRR_NM crrNm,
			CRR.CRR_CERT_NO crrCertNo,
			CRR.CRR_REQ_CN crrReqCn,
			TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD HH24:MI') crrCrDt,

			/*
				2. 반출 상태 정보

				기존:
				CARGO_RELEASE.CR_STATUS_CD

				변경:
				CARGO_RELEASE_REQ.CRR_STATUS_CD
			*/
			CRR.CRR_STATUS_CD crStatusCd,

			CASE
				WHEN CRR.CRR_STATUS_CD = 'REL_WAIT' THEN '반출대기'
				WHEN CRR.CRR_STATUS_CD = 'REL_FIX' THEN '보완요청'
				WHEN CRR.CRR_STATUS_CD = 'REL_SENT' THEN '보완제출완료'
				WHEN CRR.CRR_STATUS_CD = 'REL_DONE' THEN '반출완료'
				ELSE CRR.CRR_STATUS_CD
			END crStatusNm,

			CRR.DI_TRDE_SE_CD diTrdeSeCd,

			CASE
				WHEN CRR.DI_TRDE_SE_CD = 'IMP' THEN '수입'
				WHEN CRR.DI_TRDE_SE_CD = 'EXP' THEN '수출'
				ELSE CRR.DI_TRDE_SE_CD
			END diTrdeSeNm,

			TO_CHAR(CRR.CRR_RELEASE_DT, 'YYYY-MM-DD HH24:MI') crDt,

			/*
				3. 운송업체 정보

				연결 흐름:
				CARGO_RELEASE_REQ.CRR_TRE_ID
				-> TRAN_RCP.TRC_NO
				-> TRAN_RCP.TRC_TM_NO
				-> TRANSPORT_MANAGER.TM_NO
			*/
			TM.TM_ID tmId,
			TM.TM_CP_NM tmCpNm,
			TM.TM_NAME tmName,
			TM.TM_CP_TELNO tmCpTelno,

			/*
				4. 창고 / 보관 위치 정보
			*/
			CRR.CRR_WH_NO crWhNo,
			WH.WH_NM whNm,

			CRR.CRR_WZ_NO crrWzNo,
			NVL(WZ.WZ_DESC_CN, CRR.CRR_WZ_NO) wzNm,

			WI_POS.LOCATION_CODE locationCode,

			CASE
				WHEN WI_POS.LOCATION_CODE IS NOT NULL
				 AND CRR.CRR_WH_NO IS NOT NULL
				THEN REPLACE(WI_POS.LOCATION_CODE, CRR.CRR_WH_NO || '-', '')
				ELSE WI_POS.LOCATION_CODE
			END locationNm,

			/*
				5. 물품 정보

				대표 물품명 + 품목 수 + 총 수량 + 총 중량 + 원산지 요약
			*/
			GOODS_SUM.GOODS_NAME goodsName,
			NVL(GOODS_SUM.ITEM_CNT, 0) itemCnt,

			CASE
				WHEN NVL(GOODS_SUM.ITEM_CNT, 0) > 1
				THEN GOODS_SUM.GOODS_NAME || ' 외 ' || (GOODS_SUM.ITEM_CNT - 1) || '건'
				ELSE GOODS_SUM.GOODS_NAME
			END goodsSummary,

			GOODS_SUM.TOTAL_QTY totalQty,
			GOODS_SUM.TOTAL_WEIGHT totalWeight,
			GOODS_SUM.ORIGIN_SUMMARY originSummary,

			/*
				6. 첨부서류 정보

				D/O + 신고필증 파일그룹번호와 파일 개수
			*/
			DI.DI_TFG_NO diTfgNo,
			NVL(FILE_SUM.FILE_CNT, 0) fileCnt,

			CASE
				WHEN DI.DI_STATUS_CD IN ('TRC_DO_REQ', 'DELIVERED') THEN '수령완료'
				ELSE '수령전'
			END docStatusNm,

			/*
				D/O 수령상태

				FILE_SUM.DO_CNT가 1 이상이면 D/O 파일이 있다고 판단한다.
			*/
			CASE
			    WHEN NVL(FILE_SUM.FILE_CNT, 0) >= 2 THEN '수령완료'
			    WHEN DI.DI_STATUS_CD IN ('TRC_DO_REQ', 'DELIVERED') THEN '수령완료'
			    WHEN NVL(FILE_SUM.DO_CNT, 0) > 0 THEN '수령완료'
			    ELSE '수령전'
			END doStatusNm,
			
			CASE
			    WHEN NVL(FILE_SUM.FILE_CNT, 0) >= 2 THEN '수령완료'
			    WHEN NVL(FILE_SUM.DECLARATION_CNT, 0) > 0 THEN '수령완료'
			    ELSE '수령전'
			END declarationStatusNm

		FROM CARGO_RELEASE_REQ CRR

		/*
			운송접수 연결
		*/
		LEFT JOIN TRAN_RCP T
		  ON T.TRC_NO = CRR.CRR_TRE_ID

		/*
			운송업체 담당자 연결
		*/
		LEFT JOIN TRANSPORT_MANAGER TM
		  ON TM.TM_NO = T.TRC_TM_NO

		/*
			입고의뢰 연결

			반출요청은 WIR_NO를 직접 들고 있지 않으므로
			운송접수의 물품그룹번호로 입고의뢰를 찾는다.
		*/
		LEFT JOIN WH_IN_RPT WIR
		  ON WIR.WIR_GG_NO = T.TRC_TFG_NO
		 AND WIR.WIR_IO_SE_CD = T.TRC_SE_CD

		/*
			창고 정보

			CARGO_RELEASE_REQ.CRR_WH_NO
			-> WAREHOUSE.WH_NO
			-> WAREHOUSE.WH_NM
		*/
		LEFT JOIN WAREHOUSE WH
		  ON WH.WH_NO = CRR.CRR_WH_NO

		/*
			창고구역 정보
		*/
		LEFT JOIN WAREHOUSE_ZONE WZ
		  ON WZ.WZ_NO = CRR.CRR_WZ_NO

		/*
			실제 보관위치 정보

			WAREHOUSE_ITEM.WIL_CL_NO가 실제 위치 코드다.
			같은 입고의뢰에 여러 물품이 있을 수 있으므로
			대표 위치 하나만 MIN으로 가져온다.
		*/
		LEFT JOIN (
			SELECT
				WI.WI_WIR_NO WI_WIR_NO,
				WI.WI_GG_NO WI_GG_NO,
				MIN(WI.WIL_CL_NO) LOCATION_CODE
			FROM WAREHOUSE_ITEM WI
			WHERE WI.WIL_CL_NO IS NOT NULL
			GROUP BY
				WI.WI_WIR_NO,
				WI.WI_GG_NO
		) WI_POS
		  ON WI_POS.WI_WIR_NO = WIR.WIR_NO
		 AND WI_POS.WI_GG_NO = WIR.WIR_GG_NO

		/*
			물품 정보 집계

			GG_NO 기준으로 대표 물품명, 품목 수,
			총 수량, 총 중량, 원산지 요약을 만든다.
		*/
		LEFT JOIN (
			SELECT
				CG.GG_NO GG_NO,
				MIN(G.GOODS_NAME) GOODS_NAME,
				COUNT(*) ITEM_CNT,
				TO_CHAR(SUM(NVL(CG.CG_QTY, 0))) TOTAL_QTY,
				TO_CHAR(SUM(NVL(CG.CG_WEIGHT, 0))) TOTAL_WEIGHT,
				MIN(CG.CG_ORIGIN) ORIGIN_SUMMARY
			FROM CUSTOMS_GOODS CG
			LEFT JOIN GOODS G
			  ON G.GOODS_NO = CG.GOODS_NO
			GROUP BY CG.GG_NO
		) GOODS_SUM
		  ON GOODS_SUM.GG_NO = T.TRC_TFG_NO

		/*
			D/O + 신고필증 파일 연결
		*/
		LEFT JOIN DO_ISSUANCE DI
		  ON DI.DI_TRC_NO = T.TRC_NO
		 AND NVL(DI.DI_TRDE_SE_CD, CRR.DI_TRDE_SE_CD) = CRR.DI_TRDE_SE_CD

		/*
			파일그룹별 파일 개수 / D/O 개수 / 신고필증 개수 집계

			주의:
			현재는 파일 종류 코드가 따로 없으므로 파일명 기준으로 구분한다.

			D/O 판단:
			- 파일명에 D/O, DO-, DELIVERY, ORDER 포함

			신고필증 판단:
			- 파일명에 신고, 필증, DECLARATION, IMPORT, EXPORT 포함
		*/
		LEFT JOIN (
			SELECT
				TFM.TFM_TFG_NO TFG_NO,

				COUNT(*) FILE_CNT,

				SUM(
					CASE
						  WHEN UPPER(DFI.DFI_ORG_NM) LIKE '%D/O%'
						  OR UPPER(DFI.DFI_ORG_NM) LIKE '%DO-%'
						  OR UPPER(DFI.DFI_ORG_NM) LIKE '%DO_%'
						  OR UPPER(DFI.DFI_ORG_NM) LIKE '%DELIVERY%'
						  OR UPPER(DFI.DFI_ORG_NM) LIKE '%ORDER%'
						  OR DFI.DFI_ORG_NM LIKE '%인도%'
						  OR DFI.DFI_ORG_NM LIKE '%지시서%'
						THEN 1
						ELSE 0
					END
				) DO_CNT,

				SUM(
					CASE
						WHEN DFI.DFI_ORG_NM LIKE '%신고%'
						  OR DFI.DFI_ORG_NM LIKE '%필증%'
						  OR UPPER(DFI.DFI_ORG_NM) LIKE '%DECLARATION%'
						  OR UPPER(DFI.DFI_ORG_NM) LIKE '%IMPORT%'
						  OR UPPER(DFI.DFI_ORG_NM) LIKE '%EXPORT%'
						THEN 1
						ELSE 0
					END
				) DECLARATION_CNT

			FROM TACS_FILE_MAP TFM
			JOIN DOCS_FILE_DATA DFI
			  ON DFI.DFI_FILE_NO = TFM.TFM_DFI_NO
			WHERE NVL(DFI.DFI_DEL_YN, 'N') = 'N'
			GROUP BY TFM.TFM_TFG_NO
		) FILE_SUM
		  ON FILE_SUM.TFG_NO = DI.DI_TFG_NO

		WHERE CRR.CRR_WM_ID = #{wmId}

		ORDER BY CRR.CRR_CR_DT DESC, CRR.CRR_NO DESC

	</select>


	<!--
		반출요청번호 기준 운송업체 ID 조회

		목적:
		- SUPP_RQST.RECEIVER_ID에 넣을 운송업체 ID 조회

		연결 흐름:
		CARGO_RELEASE_REQ.CRR_NO
		-> CARGO_RELEASE_REQ.CRR_TRE_ID
		-> TRAN_RCP.TRC_NO
		-> TRAN_RCP.TRC_TM_NO
		-> TRANSPORT_MANAGER.TM_NO
		-> TRANSPORT_MANAGER.TM_ID
	-->
	<select id="selectTransportManagerIdByCrrNo"
	        parameterType="string"
	        resultType="string">

		SELECT
			TM.TM_ID
		FROM CARGO_RELEASE_REQ CRR
		JOIN TRAN_RCP T
		  ON T.TRC_NO = CRR.CRR_TRE_ID
		JOIN TRANSPORT_MANAGER TM
		  ON TM.TM_NO = T.TRC_TM_NO
		WHERE CRR.CRR_NO = #{crrNo}

	</select>
	
	<!--
    반출승인 상태 변경

    CARGO_RELEASE_REQ 기준으로 반출요청 상태를 REL_DONE으로 변경한다.
    현재 로그인한 창고관리자 담당 건만 처리한다.
	-->
	<update id="updateCargoReleaseReqToDone">
	    UPDATE CARGO_RELEASE_REQ CRR
	    SET
	        CRR.CRR_STATUS_CD = 'REL_DONE',
	        CRR.CRR_PROC_MEM_ID = #{wmId},
	        CRR.CRR_RELEASE_DT = SYSDATE
	    WHERE CRR.CRR_NO = #{crrNo}
	      AND CRR.CRR_WM_ID = #{wmId}
	      AND CRR.CRR_STATUS_CD IN ('REL_WAIT', 'REL_SENT')
	</update>
	
	
	<!--
	    반출이력 저장
	
	    반출요청 1건에 여러 물품이 있을 수 있으므로
	    WAREHOUSE_ITEM 기준으로 물품 개수만큼 WH_OUT_HIS에 INSERT한다.
	
	    같은 반출요청 건은 WOH_CRR_NO로 묶어서 조회한다.
	-->
	<insert id="insertWarehouseOutboundHistory">
	    INSERT INTO WH_OUT_HIS (
	        WOH_NO,
	        WOH_CRR_NO,
	        WOH_WI_NO,
	        WOH_GG_NO,
	        WOH_GOODS_NO,
	        WOH_GOODS_NM,
	        WOH_QTY,
	        WOH_WEIGHT,
	        WOH_ORIGIN,
	        WOH_WH_NO,
	        WOH_WH_NM,
	        WOH_WZ_NO,
	        WOH_WZ_NM,
	        WOH_LOCATION_CD,
	        WOH_WM_ID,
	        WOH_WM_NM,
	        WOH_OWR_ID,
	        WOH_OWR_NM,
	        WOH_TM_ID,
	        WOH_TM_NM,
	        WOH_OUT_DT,
	        WOH_REG_DT
	    )
	    SELECT
	        SEQ_WH_OUT_HIS.NEXTVAL,
	        CRR.CRR_NO,
	        WI.WI_NO,
	        WI.WI_GG_NO,
	        CG.GOODS_NO,
	        G.GOODS_NAME,
	        CG.CG_QTY,
	        CG.CG_WEIGHT,
	        CG.CG_ORIGIN,
	        CRR.CRR_WH_NO,
	        WH.WH_NM,
	        WIL.WIL_WH_ZONE_NO,
			NVL(WZ.WZ_NM, WIL.WIL_WH_ZONE_NO),
			WI.WIL_CL_NO,
	        #{wmId},
	        WM.WM_NM,
	        CRR.CRR_OWR_ID,
	        CRR.CRR_NM,
	        TM.TM_ID,
	        TM.TM_CP_NM,
	        SYSDATE,
	        SYSDATE
	    FROM CARGO_RELEASE_REQ CRR
	    INNER JOIN TRAN_RCP T
	      ON T.TRC_NO = CRR.CRR_TRE_ID
	    INNER JOIN WH_IN_RPT WIR
	      ON WIR.WIR_GG_NO = T.TRC_TFG_NO
	     AND WIR.WIR_IO_SE_CD = T.TRC_SE_CD
	    INNER JOIN WAREHOUSE_ITEM WI
	      ON WI.WI_WIR_NO = WIR.WIR_NO
	     AND WI.WI_GG_NO = WIR.WIR_GG_NO
	     AND NVL(WI.WI_USE_YN, 'Y') = 'Y'
	    INNER JOIN CUSTOMS_GOODS CG
	      ON CG.CG_NO = WI.WI_CG_NO
	    LEFT JOIN GOODS G
	      ON G.GOODS_NO = CG.GOODS_NO
	    LEFT JOIN WAREHOUSE WH
	      ON WH.WH_NO = CRR.CRR_WH_NO
	    LEFT JOIN WAREHOUSE_ITEM_LOCATION WIL
	      ON WIL.WIL_NO = WI.WIL_CL_NO
	    LEFT JOIN WAREHOUSE_ZONE WZ
	      ON WZ.WZ_NO = WIL.WIL_WH_ZONE_NO
	    LEFT JOIN WAREHOUSE_MANAGER WM
	      ON WM.WM_ID = #{wmId}
	    LEFT JOIN TRANSPORT_MANAGER TM
	      ON TM.TM_NO = T.TRC_TM_NO
	    WHERE CRR.CRR_NO = #{crrNo}
	      AND CRR.CRR_WM_ID = #{wmId}
	</insert>
	
	
	<!--
	    반출승인된 창고 물품 비활성화
	
	    DELETE가 아니라 WI_USE_YN = 'N' 처리한다.
	    현재 재고/3D 조회에서는 빠지고, 기존 입고/보관 위치 기록은 남긴다.
	-->
	<update id="updateWarehouseItemUseYnToN">
	    UPDATE WAREHOUSE_ITEM WI
	    SET
	        WI.WI_USE_YN = 'N',
	        WI.WI_UPDT_DT = SYSDATE
	    WHERE EXISTS (
	        SELECT 1
	        FROM CARGO_RELEASE_REQ CRR
	        INNER JOIN TRAN_RCP T
	          ON T.TRC_NO = CRR.CRR_TRE_ID
	        INNER JOIN WH_IN_RPT WIR
	          ON WIR.WIR_GG_NO = T.TRC_TFG_NO
	         AND WIR.WIR_IO_SE_CD = T.TRC_SE_CD
	        WHERE CRR.CRR_NO = #{crrNo}
	          AND WI.WI_WIR_NO = WIR.WIR_NO
	          AND WI.WI_GG_NO = WIR.WIR_GG_NO
	    )
	      AND NVL(WI.WI_USE_YN, 'Y') = 'Y'
	</update>
	
	
	<!--
    반출승인된 물품의 위치 반출일시 기록

    목적:
    - 반출승인 시 WAREHOUSE_ITEM은 WI_USE_YN = 'N'으로 현재 재고에서 제외된다.
    - 동시에 WAREHOUSE_ITEM_LOCATION.WIL_OUT_DT에 반출시각을 찍어야
      보세재고 통합조회에서 위치반출일시를 표시할 수 있다.

    기준:
    - CARGO_RELEASE_REQ.CRR_NO 기준으로 반출요청을 찾는다.
    - CRR_TRE_ID -> TRAN_RCP.TRC_NO
    - TRAN_RCP.TRC_TFG_NO -> WH_IN_RPT.WIR_GG_NO
    - WH_IN_RPT.WIR_NO / WIR_GG_NO -> WAREHOUSE_ITEM
    - WAREHOUSE_ITEM.WIL_CL_NO -> WAREHOUSE_ITEM_LOCATION.WIL_NO
	-->
	<update id="updateWarehouseItemLocationOutDtByCrrNo" parameterType="string">
    UPDATE WAREHOUSE_ITEM_LOCATION WIL
    SET WIL.WIL_OUT_DT = SYSDATE
    WHERE EXISTS (
        SELECT 1
        FROM CARGO_RELEASE_REQ CRR
        INNER JOIN TRAN_RCP T
                ON T.TRC_NO = CRR.CRR_TRE_ID
        INNER JOIN WH_IN_RPT WIR
                ON WIR.WIR_GG_NO = T.TRC_TFG_NO
               AND WIR.WIR_IO_SE_CD = T.TRC_SE_CD
        INNER JOIN WAREHOUSE_ITEM WI
                ON WI.WI_WIR_NO = WIR.WIR_NO
               AND WI.WI_GG_NO = WIR.WIR_GG_NO
               AND NVL(WI.WI_USE_YN, 'Y') = 'Y'
        WHERE CRR.CRR_NO = #{crrNo}
          AND WI.WIL_CL_NO = WIL.WIL_NO
    )
</update>
	
	
	
	<!--
	    창고구역 사용량/사용률 재계산
	
	    반출 후 해당 구역의 현재 사용 물품 수를 기준으로 다시 계산한다.
	    위치의 구역은 WAREHOUSE_ITEM.WIL_CL_NO -> WAREHOUSE_ITEM_LOCATION.WIL_NO
	    -> WAREHOUSE_ITEM_LOCATION.WIL_WH_ZONE_NO 기준으로 찾는다.
	-->
	<update id="updateWarehouseZoneUsageByCrrNo">
	    UPDATE WAREHOUSE_ZONE WZ
	    SET
	        WZ.WZ_USE_CAPA = (
	            SELECT COUNT(*)
	            FROM WAREHOUSE_ITEM WI
	            INNER JOIN WAREHOUSE_ITEM_LOCATION WIL
	              ON WIL.WIL_NO = WI.WIL_CL_NO
	            WHERE WIL.WIL_WH_ZONE_NO = WZ.WZ_NO
	              AND NVL(WI.WI_USE_YN, 'Y') = 'Y'
	        ),
	        WZ.WZ_USE_RT = ROUND(
	            (
	                SELECT COUNT(*)
	                FROM WAREHOUSE_ITEM WI
	                INNER JOIN WAREHOUSE_ITEM_LOCATION WIL
	                  ON WIL.WIL_NO = WI.WIL_CL_NO
	                WHERE WIL.WIL_WH_ZONE_NO = WZ.WZ_NO
	                  AND NVL(WI.WI_USE_YN, 'Y') = 'Y'
	            ) / NULLIF(WZ.WZ_TTL_CAPA, 0) * 100,
	            2
	        )
	    WHERE WZ.WZ_NO IN (
	        SELECT DISTINCT WIL.WIL_WH_ZONE_NO
	        FROM CARGO_RELEASE_REQ CRR
	        INNER JOIN TRAN_RCP T
	          ON T.TRC_NO = CRR.CRR_TRE_ID
	        INNER JOIN WH_IN_RPT WIR
	          ON WIR.WIR_GG_NO = T.TRC_TFG_NO
	         AND WIR.WIR_IO_SE_CD = T.TRC_SE_CD
	        INNER JOIN WAREHOUSE_ITEM WI
	          ON WI.WI_WIR_NO = WIR.WIR_NO
	         AND WI.WI_GG_NO = WIR.WIR_GG_NO
	        INNER JOIN WAREHOUSE_ITEM_LOCATION WIL
	          ON WIL.WIL_NO = WI.WIL_CL_NO
	        WHERE CRR.CRR_NO = #{crrNo}
	    )
	</update>


	<!--
		반출 보완요청 상태 변경

		기존:
		- CARGO_RELEASE.CR_STATUS_CD 변경

		변경:
		- CARGO_RELEASE_REQ.CRR_STATUS_CD 변경

		처리:
		- REL_WAIT 상태인 반출요청만 REL_FIX로 변경
		- 로그인 창고관리자 담당 건만 변경
	-->
	<update id="updateCargoReleaseReqStatusToRelFix"
	        parameterType="map">

		UPDATE CARGO_RELEASE_REQ CRR
		SET
			CRR.CRR_STATUS_CD = 'REL_FIX',
			CRR.CRR_PROC_MEM_ID = #{senderId}
		WHERE CRR.CRR_NO = #{crrNo}
		  AND CRR.CRR_WM_ID = #{senderId}
		  AND CRR.CRR_STATUS_CD = 'REL_WAIT'

	</update>


	<!--
		반출 보완요청 이력 등록

		SUPP_RQST 방향:
		창고관리자 -> 운송업체

		SR_REF_BIZ_CD  = CARGO_RELEASE_REQ
		SR_REF_NO      = CRR_NO
		SENDER_ID      = 창고관리자 ID
		SENDER_TY_CD   = WAREHOUSE_MANAGER
		RECEIVER_ID    = 운송업체 ID
		RECEIVER_TY_CD = TRANSPORT_MANAGER
		SR_STATUS_CD   = REQ
		SR_REQ_CN      = 보완요청 사유
	-->
	<insert id="insertOutboundSupplementRequest"
	        parameterType="map">

		<selectKey keyProperty="srNo"
		           resultType="string"
		           order="BEFORE">
			SELECT
				'SR-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' ||
				LPAD(
					NVL(
						MAX(TO_NUMBER(SUBSTR(SR_NO, 13))),
						0
					) + 1,
					4,
					'0'
				)
			FROM SUPP_RQST
			WHERE SR_NO LIKE 'SR-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
		</selectKey>

		INSERT INTO SUPP_RQST (
			SR_NO,
			SR_REF_BIZ_CD,
			SR_REF_NO,
			SENDER_ID,
			SENDER_TY_CD,
			RECEIVER_ID,
			RECEIVER_TY_CD,
			SR_STATUS_CD,
			SR_REQ_DT,
			SR_REQ_CN
		) VALUES (
			#{srNo},
			#{srRefBizCd},
			#{srRefNo},
			#{senderId},
			#{senderTyCd},
			#{receiverId},
			#{receiverTyCd},
			#{srStatusCd},
			SYSDATE,
			#{srReqCn}
		)

	</insert>
	
		<!--
		보세반출 처리 목록 전체 개수 조회

		PageDTO 페이징 처리를 위해
		현재 검색조건에 해당하는 전체 반출요청 건수를 먼저 구한다.
	-->
	<select id="selectOutboundProcessCount" resultType="int">

		SELECT COUNT(*)
		FROM CARGO_RELEASE_REQ CRR

		LEFT JOIN TRAN_RCP T
		  ON T.TRC_NO = CRR.CRR_TRE_ID

		LEFT JOIN TRANSPORT_MANAGER TM
		  ON TM.TM_NO = T.TRC_TM_NO

		LEFT JOIN WH_IN_RPT WIR
		  ON WIR.WIR_GG_NO = T.TRC_TFG_NO
		 AND WIR.WIR_IO_SE_CD = T.TRC_SE_CD

		LEFT JOIN WAREHOUSE WH
		  ON WH.WH_NO = CRR.CRR_WH_NO

		LEFT JOIN WAREHOUSE_ZONE WZ
		  ON WZ.WZ_NO = CRR.CRR_WZ_NO

		LEFT JOIN (
			SELECT
				WI.WI_WIR_NO WI_WIR_NO,
				WI.WI_GG_NO WI_GG_NO,
				MIN(WI.WIL_CL_NO) LOCATION_CODE
			FROM WAREHOUSE_ITEM WI
			WHERE WI.WIL_CL_NO IS NOT NULL
			GROUP BY
				WI.WI_WIR_NO,
				WI.WI_GG_NO
		) WI_POS
		  ON WI_POS.WI_WIR_NO = WIR.WIR_NO
		 AND WI_POS.WI_GG_NO = WIR.WIR_GG_NO

		LEFT JOIN (
			SELECT
				CG.GG_NO GG_NO,
				MIN(G.GOODS_NAME) GOODS_NAME,
				COUNT(*) ITEM_CNT,
				TO_CHAR(SUM(NVL(CG.CG_QTY, 0))) TOTAL_QTY,
				TO_CHAR(SUM(NVL(CG.CG_WEIGHT, 0))) TOTAL_WEIGHT,
				MIN(CG.CG_ORIGIN) ORIGIN_SUMMARY
			FROM CUSTOMS_GOODS CG
			LEFT JOIN GOODS G
			  ON G.GOODS_NO = CG.GOODS_NO
			GROUP BY CG.GG_NO
		) GOODS_SUM
		  ON GOODS_SUM.GG_NO = T.TRC_TFG_NO

		WHERE CRR.CRR_WM_ID = #{wmId}

		<!-- 반출요청일 시작일 검색 -->
		<if test="searchDTO.startDate != null and searchDTO.startDate != ''">
			AND TRUNC(CRR.CRR_CR_DT) &gt;= TO_DATE(#{searchDTO.startDate}, 'YYYY-MM-DD')
		</if>

		<!-- 반출요청일 종료일 검색 -->
		<if test="searchDTO.endDate != null and searchDTO.endDate != ''">
			AND TRUNC(CRR.CRR_CR_DT) &lt;= TO_DATE(#{searchDTO.endDate}, 'YYYY-MM-DD')
		</if>

		<!-- 수입/수출 검색 -->
		<if test="searchDTO.diTrdeSeCd != null and searchDTO.diTrdeSeCd != ''">
			AND CRR.DI_TRDE_SE_CD = #{searchDTO.diTrdeSeCd}
		</if>

		<!-- 반출상태 검색 -->
		<if test="searchDTO.crStatusCd != null and searchDTO.crStatusCd != ''">
			AND CRR.CRR_STATUS_CD = #{searchDTO.crStatusCd}
		</if>

		<!-- 검색어 검색 -->
		<if test="searchDTO.keyword != null and searchDTO.keyword != ''">
			AND (
				   CRR.CRR_NO LIKE '%' || #{searchDTO.keyword} || '%'
				OR CRR.CRR_NM LIKE '%' || #{searchDTO.keyword} || '%'
				OR CRR.CRR_CERT_NO LIKE '%' || #{searchDTO.keyword} || '%'
				OR GOODS_SUM.GOODS_NAME LIKE '%' || #{searchDTO.keyword} || '%'
				OR CRR.CRR_WZ_NO LIKE '%' || #{searchDTO.keyword} || '%'
				OR WI_POS.LOCATION_CODE LIKE '%' || #{searchDTO.keyword} || '%'
				OR TM.TM_CP_NM LIKE '%' || #{searchDTO.keyword} || '%'
				OR TM.TM_NAME LIKE '%' || #{searchDTO.keyword} || '%'
			)
		</if>

	</select>
	
		<!--
		보세반출 처리 목록 페이징 조회

		기존 selectOutboundProcessList와 같은 컬럼을 내려주되,
		searchDTO 조건과 ROWNUM 페이징만 추가한다.
	-->
	<select id="selectOutboundProcessPagingList"
	        resultType="kr.or.tacs.dto.warehouse.WarehouseOutboundProcessDTO">

		SELECT *
		FROM (
			SELECT ROWNUM AS rnum, B.*
			FROM (
				SELECT
					/*
						1. 반출요청 기본 정보
					*/
					CRR.CRR_NO crrNo,
					CRR.CRR_TRE_ID crrTreId,
					CRR.CRR_OWR_ID crrOwrId,
					CRR.CRR_NM crrNm,
					CRR.CRR_CERT_NO crrCertNo,
					CRR.CRR_REQ_CN crrReqCn,
					TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD HH24:MI') crrCrDt,

					/*
						2. 반출 상태 정보
					*/
					CRR.CRR_STATUS_CD crStatusCd,

					CASE
						WHEN CRR.CRR_STATUS_CD = 'REL_WAIT' THEN '반출대기'
						WHEN CRR.CRR_STATUS_CD = 'REL_FIX' THEN '보완요청'
						WHEN CRR.CRR_STATUS_CD = 'REL_SENT' THEN '보완제출완료'
						WHEN CRR.CRR_STATUS_CD = 'REL_DONE' THEN '반출완료'
						ELSE CRR.CRR_STATUS_CD
					END crStatusNm,

					CRR.DI_TRDE_SE_CD diTrdeSeCd,

					CASE
						WHEN CRR.DI_TRDE_SE_CD = 'IMP' THEN '수입'
						WHEN CRR.DI_TRDE_SE_CD = 'EXP' THEN '수출'
						ELSE CRR.DI_TRDE_SE_CD
					END diTrdeSeNm,

					TO_CHAR(CRR.CRR_RELEASE_DT, 'YYYY-MM-DD HH24:MI') crDt,

					/*
						3. 운송업체 정보
					*/
					TM.TM_ID tmId,
					TM.TM_CP_NM tmCpNm,
					TM.TM_NAME tmName,
					TM.TM_CP_TELNO tmCpTelno,

					/*
						4. 창고 / 보관 위치 정보
					*/
					CRR.CRR_WH_NO crWhNo,
					WH.WH_NM whNm,

					CRR.CRR_WZ_NO crrWzNo,
					NVL(WZ.WZ_DESC_CN, CRR.CRR_WZ_NO) wzNm,

					WI_POS.LOCATION_CODE locationCode,

					CASE
						WHEN WI_POS.LOCATION_CODE IS NOT NULL
						 AND CRR.CRR_WH_NO IS NOT NULL
						THEN REPLACE(WI_POS.LOCATION_CODE, CRR.CRR_WH_NO || '-', '')
						ELSE WI_POS.LOCATION_CODE
					END locationNm,

					/*
						5. 물품 정보
					*/
					GOODS_SUM.GOODS_NAME goodsName,
					NVL(GOODS_SUM.ITEM_CNT, 0) itemCnt,

					CASE
						WHEN NVL(GOODS_SUM.ITEM_CNT, 0) > 1
						THEN GOODS_SUM.GOODS_NAME || ' 외 ' || (GOODS_SUM.ITEM_CNT - 1) || '건'
						ELSE GOODS_SUM.GOODS_NAME
					END goodsSummary,

					GOODS_SUM.TOTAL_QTY totalQty,
					GOODS_SUM.TOTAL_WEIGHT totalWeight,
					GOODS_SUM.ORIGIN_SUMMARY originSummary,

					/*
						6. 첨부서류 정보
					*/
					DI.DI_TFG_NO diTfgNo,
					NVL(FILE_SUM.FILE_CNT, 0) fileCnt,

					CASE
						WHEN DI.DI_STATUS_CD IN ('TRC_DO_REQ', 'DELIVERED') THEN '수령완료'
						ELSE '수령전'
					END docStatusNm,

					CASE
					    WHEN NVL(FILE_SUM.FILE_CNT, 0) >= 2 THEN '수령완료'
					    WHEN DI.DI_STATUS_CD IN ('TRC_DO_REQ', 'DELIVERED') THEN '수령완료'
					    WHEN NVL(FILE_SUM.DO_CNT, 0) > 0 THEN '수령완료'
					    ELSE '수령전'
					END doStatusNm,
					
					CASE
					    WHEN NVL(FILE_SUM.FILE_CNT, 0) >= 2 THEN '수령완료'
					    WHEN NVL(FILE_SUM.DECLARATION_CNT, 0) > 0 THEN '수령완료'
					    ELSE '수령전'
					END declarationStatusNm

				FROM CARGO_RELEASE_REQ CRR

				LEFT JOIN TRAN_RCP T
				  ON T.TRC_NO = CRR.CRR_TRE_ID

				LEFT JOIN TRANSPORT_MANAGER TM
				  ON TM.TM_NO = T.TRC_TM_NO

				LEFT JOIN WH_IN_RPT WIR
				  ON WIR.WIR_GG_NO = T.TRC_TFG_NO
				 AND WIR.WIR_IO_SE_CD = T.TRC_SE_CD

				LEFT JOIN WAREHOUSE WH
				  ON WH.WH_NO = CRR.CRR_WH_NO

				LEFT JOIN WAREHOUSE_ZONE WZ
				  ON WZ.WZ_NO = CRR.CRR_WZ_NO

				LEFT JOIN (
					SELECT
						WI.WI_WIR_NO WI_WIR_NO,
						WI.WI_GG_NO WI_GG_NO,
						MIN(WI.WIL_CL_NO) LOCATION_CODE
					FROM WAREHOUSE_ITEM WI
					WHERE WI.WIL_CL_NO IS NOT NULL
					GROUP BY
						WI.WI_WIR_NO,
						WI.WI_GG_NO
				) WI_POS
				  ON WI_POS.WI_WIR_NO = WIR.WIR_NO
				 AND WI_POS.WI_GG_NO = WIR.WIR_GG_NO

				LEFT JOIN (
					SELECT
						CG.GG_NO GG_NO,
						MIN(G.GOODS_NAME) GOODS_NAME,
						COUNT(*) ITEM_CNT,
						TO_CHAR(SUM(NVL(CG.CG_QTY, 0))) TOTAL_QTY,
						TO_CHAR(SUM(NVL(CG.CG_WEIGHT, 0))) TOTAL_WEIGHT,
						MIN(CG.CG_ORIGIN) ORIGIN_SUMMARY
					FROM CUSTOMS_GOODS CG
					LEFT JOIN GOODS G
					  ON G.GOODS_NO = CG.GOODS_NO
					GROUP BY CG.GG_NO
				) GOODS_SUM
				  ON GOODS_SUM.GG_NO = T.TRC_TFG_NO

				LEFT JOIN DO_ISSUANCE DI
				  ON DI.DI_TRC_NO = T.TRC_NO
				 AND NVL(DI.DI_TRDE_SE_CD, CRR.DI_TRDE_SE_CD) = CRR.DI_TRDE_SE_CD

				LEFT JOIN (
					SELECT
						TFM.TFM_TFG_NO TFG_NO,

						COUNT(*) FILE_CNT,

						SUM(
							CASE
								  WHEN UPPER(DFI.DFI_ORG_NM) LIKE '%D/O%'
								  OR UPPER(DFI.DFI_ORG_NM) LIKE '%DO-%'
								  OR UPPER(DFI.DFI_ORG_NM) LIKE '%DO_%'
								  OR UPPER(DFI.DFI_ORG_NM) LIKE '%DELIVERY%'
								  OR UPPER(DFI.DFI_ORG_NM) LIKE '%ORDER%'
								  OR DFI.DFI_ORG_NM LIKE '%인도%'
								  OR DFI.DFI_ORG_NM LIKE '%지시서%'
								THEN 1
								ELSE 0
							END
						) DO_CNT,

						SUM(
							CASE
								WHEN DFI.DFI_ORG_NM LIKE '%신고%'
								  OR DFI.DFI_ORG_NM LIKE '%필증%'
								  OR UPPER(DFI.DFI_ORG_NM) LIKE '%DECLARATION%'
								  OR UPPER(DFI.DFI_ORG_NM) LIKE '%IMPORT%'
								  OR UPPER(DFI.DFI_ORG_NM) LIKE '%EXPORT%'
								THEN 1
								ELSE 0
							END
						) DECLARATION_CNT

					FROM TACS_FILE_MAP TFM
					JOIN DOCS_FILE_DATA DFI
					  ON DFI.DFI_FILE_NO = TFM.TFM_DFI_NO
					WHERE NVL(DFI.DFI_DEL_YN, 'N') = 'N'
					GROUP BY TFM.TFM_TFG_NO
				) FILE_SUM
				  ON FILE_SUM.TFG_NO = DI.DI_TFG_NO

				WHERE CRR.CRR_WM_ID = #{wmId}

				<!-- 반출요청일 시작일 검색 -->
				<if test="searchDTO.startDate != null and searchDTO.startDate != ''">
					AND TRUNC(CRR.CRR_CR_DT) &gt;= TO_DATE(#{searchDTO.startDate}, 'YYYY-MM-DD')
				</if>

				<!-- 반출요청일 종료일 검색 -->
				<if test="searchDTO.endDate != null and searchDTO.endDate != ''">
					AND TRUNC(CRR.CRR_CR_DT) &lt;= TO_DATE(#{searchDTO.endDate}, 'YYYY-MM-DD')
				</if>

				<!-- 수입/수출 검색 -->
				<if test="searchDTO.diTrdeSeCd != null and searchDTO.diTrdeSeCd != ''">
					AND CRR.DI_TRDE_SE_CD = #{searchDTO.diTrdeSeCd}
				</if>

				<!-- 반출상태 검색 -->
				<if test="searchDTO.crStatusCd != null and searchDTO.crStatusCd != ''">
					AND CRR.CRR_STATUS_CD = #{searchDTO.crStatusCd}
				</if>

				<!-- 검색어 검색 -->
				<if test="searchDTO.keyword != null and searchDTO.keyword != ''">
					AND (
						   CRR.CRR_NO LIKE '%' || #{searchDTO.keyword} || '%'
						OR CRR.CRR_NM LIKE '%' || #{searchDTO.keyword} || '%'
						OR CRR.CRR_CERT_NO LIKE '%' || #{searchDTO.keyword} || '%'
						OR GOODS_SUM.GOODS_NAME LIKE '%' || #{searchDTO.keyword} || '%'
						OR CRR.CRR_WZ_NO LIKE '%' || #{searchDTO.keyword} || '%'
						OR WI_POS.LOCATION_CODE LIKE '%' || #{searchDTO.keyword} || '%'
						OR TM.TM_CP_NM LIKE '%' || #{searchDTO.keyword} || '%'
						OR TM.TM_NAME LIKE '%' || #{searchDTO.keyword} || '%'
					)
				</if>

				ORDER BY CRR.CRR_CR_DT DESC, CRR.CRR_NO DESC
			) B
			WHERE ROWNUM &lt;= #{searchDTO.endRow}
		)
		WHERE rnum &gt;= #{searchDTO.startRow}

	</select>

</mapper>