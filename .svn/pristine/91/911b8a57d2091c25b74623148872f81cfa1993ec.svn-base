package kr.or.tacs.dto.officer;

import lombok.Data;

@Data
public class LoadedCargoListDTO {

    private int no;

    // 목록 식별값
    private String listNo;
    private String goodsGroupNo;
    private String cargoManageNo;

    // 화물 구분
    private String cargoType;      // 적재화물 / 혼재화물
    private String cargoTypeCd;    // LOADED / MIXED

    // B/L 정보
    private String blNo;
    private String mblNo;
    private String hblNo;
    private String blStatusCd;
    private String blStatus;

    // 신고 정보
    private String reqNo;
    private String declareType;
    private String declareStatusCd;
    private String declareStatus;

    // 화면 표시 정보
    private String ownerName;
    private String itemName;
    private String vesselName;

    // 목록 제출 정보
    private String submitStatusCd;
    private String submitStatus;
    private String submitDate;

    // 운송 정보
    private String transportNo;
    private String departurePort;
    private String arrivalPort;
    private String transportStatusCd;
    private String transportStatus;
    private String traderName;

    // 창고/보관 정보
    private String warehouseName;
    private String warehouseZoneName;
    private String warehouseStatusCd;
    private String warehouseStatus;
    private String warehouseItemStatusCd;
    private String warehouseItemStatus;
    private String sealNo;

    private String remark;

    // 품목 정보
    private String quantity;
    private String weight;
}