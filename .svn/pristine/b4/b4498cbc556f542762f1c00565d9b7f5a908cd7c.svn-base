@charset "UTF-8";

/* ── Settings form ── */
.settings-section { background: #fff; border: 1px solid #e2e8f0; margin-bottom: 20px; overflow: hidden; }
.settings-section-title { font-size: 13px; font-weight: 800; color: #0f172a; padding: 14px 20px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; gap: 8px; }
.settings-section-title .material-symbols-outlined { font-size: 17px; color: #565e74; }
.settings-body { padding: 20px; }
.settings-row { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #f1f5f9; }
.settings-row:last-child { border-bottom: none; }
.settings-row-left { flex: 1; }
.settings-row-left .s-title { font-size: 13px; font-weight: 600; color: #203444; }
.settings-row-left .s-desc { font-size: 11px; color: #94a3b8; margin-top: 2px; }
.settings-row-right { flex-shrink: 0; margin-left: 20px; }
.settings-row-right select, .settings-row-right input { padding: 6px 10px; border: 1px solid #e2e8f0; font-size: 12px; background: #fff; color: #203444; outline: none; font-family: inherit; min-width: 160px; }
.toggle { display: flex; align-items: center; }
.toggle input[type="checkbox"] { width: 36px; height: 20px; cursor: pointer; accent-color: #565e74; }
