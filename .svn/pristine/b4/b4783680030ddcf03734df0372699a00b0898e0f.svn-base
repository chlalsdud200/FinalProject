<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.officer.basicscreen.mapper.IScreenDetailMapper">

    <!-- 수입 상세 -->
    <select id="selectImportDetail"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.BasicScreenDetailDTO">
        SELECT
            IR.IR_NO AS reqNo,
            '수입' AS declareType,
            TO_CHAR(IR.IR_DT, 'YYYY-MM-DD HH24:MI') AS requestDate,
            ID.ID_STATUS_CD AS statusCd,
            IR.IR_TFG_NO AS tfgNo,

            ARR.ARR_SCORE AS riskScore,
            ARR.ARR_GRADE_CD AS riskGradeCd,
            ARR.ARR_STATUS_CD AS riskStatusCd,
            ARR.ARR_RESULT_CN AS riskResultCn,

            IR.IR_OWR_ID AS companyName,
            OWR.OWR_TELNO AS companyTel,
            IR.IR_CORP_REG_NO AS corpRegNo,
            IR.IR_CSTM_IDF_NO AS customsIdNo,
            B.BROKER_OFFICE_NM AS brokerName,

            NVL(ID.ID_OFFICER_ID, IRC.IRC_OFFICER_ID) AS officerId,
            O.OFFICER_NM AS officerName,

            IR.IR_BL_AWB_NO AS blNo,
            IR.IR_ARRV_PORT_CD AS arrivalPort,
            CASE
                WHEN REGEXP_LIKE(IR.IR_ARRV_SCHD_YMD, '^[0-9]{8}$')
                THEN TO_CHAR(TO_DATE(IR.IR_ARRV_SCHD_YMD, 'YYYYMMDD'), 'YYYY-MM-DD')
                ELSE IR.IR_ARRV_SCHD_YMD
            END AS arrivalDate,
            TO_CHAR(NULL) AS cargoNo,

            TO_CHAR(IR.IR_INVC_AMT, 'FM999,999,999,999') AS amount,
            IR.IR_DCLR_CURR_CD AS currencyCode,
            TO_CHAR(NULL) AS payMethod,

            NVL(ITEM.IDI_DCLR_GDSNM, IR.IR_COMMENT) AS itemName,
            ITEM.IDI_HS_CD AS hsCode,
            TO_CHAR(ITEM.IDI_QTY, 'FM999,999,999') AS qty,
            ITEM.IDI_ORGN_CNTRY_CD AS origin,

            TO_CHAR(NULL) AS reviewMemo,
            TO_CHAR(NULL) AS reviewStartDate,
            TO_CHAR(NULL) AS acceptDate,

            IR.IR_COMMENT AS requestContent
        FROM IMP_RQST IR
        LEFT JOIN (
            SELECT *
            FROM (
                SELECT D.*,
                       ROW_NUMBER() OVER (
                           PARTITION BY D.ID_IR_NO
                           ORDER BY NVL(D.ID_RCEPT_DT, D.ID_DCLR_DT) DESC
                       ) AS RN
                FROM IMP_DCLR D
            )
            WHERE RN = 1
        ) ID ON ID.ID_IR_NO = IR.IR_NO
        LEFT JOIN BROKER B
            ON IR.IR_BROKER_ID = B.BROKER_ID
        LEFT JOIN OWNER OWR
            ON IR.IR_OWR_ID = OWR.OWR_ID
        LEFT JOIN IMP_DCLR_ITEM ITEM
            ON IR.IR_NO = ITEM.IDI_IR_NO
           AND ITEM.IDI_SN = (
                SELECT MIN(IDI_SN)
                FROM IMP_DCLR_ITEM
                WHERE IDI_IR_NO = IR.IR_NO
           )
        LEFT JOIN IMP_REQ_CNFM IRC
            ON IR.IR_NO = IRC.IRC_IR_NO
        LEFT JOIN OFFICER O
            ON NVL(ID.ID_OFFICER_ID, IRC.IRC_OFFICER_ID) = O.OFFICER_ID
        LEFT JOIN (
            SELECT *
            FROM (
                SELECT
                    A.*,
                    ROW_NUMBER() OVER (
                        PARTITION BY A.ARR_BIZ_TYPE_CD, A.ARR_REF_NO
                        ORDER BY A.ARR_REGIST_DT DESC
                    ) AS RN
                FROM AI_RISK_RESULT A
                WHERE A.ARR_BIZ_TYPE_CD = 'IMPORT'
            )
            WHERE RN = 1
        ) ARR
            ON ARR.ARR_REF_NO = IR.IR_NO
        WHERE IR.IR_NO = #{reqNo}
    </select>


    <!-- 수출 상세 -->
    <select id="selectExportDetail"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.BasicScreenDetailDTO">
        SELECT
            ER.ER_NO AS reqNo,
            '수출' AS declareType,
            TO_CHAR(ER.ER_RQST_DT, 'YYYY-MM-DD HH24:MI') AS requestDate,
            NVL(ED.ED_STATUS_CD, ER.ER_STATUS_CD) AS statusCd,
            ER.ER_TFG_NO AS tfgNo,

            ARR.ARR_SCORE AS riskScore,
            ARR.ARR_GRADE_CD AS riskGradeCd,
            ARR.ARR_STATUS_CD AS riskStatusCd,
            ARR.ARR_RESULT_CN AS riskResultCn,

            NVL(ER.ER_ONER_NM, ER.ER_OWR_ID) AS companyName,
            OWR.OWR_TELNO AS companyTel,
            ER.ER_CORP_REG_NO AS corpRegNo,
            ER.ER_CSTM_IDF_NO AS customsIdNo,
            B.BROKER_OFFICE_NM AS brokerName,

            ED.OFFICER_ID AS officerId,
            O.OFFICER_NM AS officerName,

            TO_CHAR(NULL) AS blNo,
            ER.ER_LOAD_PORT_CD AS arrivalPort,
            TO_CHAR(NULL) AS arrivalDate,
            TO_CHAR(NULL) AS cargoNo,

            TO_CHAR(ED.ED_DCLR_TOT_AMT_KRW, 'FM999,999,999,999') AS amount,
            ED.ED_CURR_CD AS currencyCode,
            TO_CHAR(NULL) AS payMethod,

            NVL(ITEM.EDI_EXPT_GDS_NM, ER.ER_COMMENT) AS itemName,
            ITEM.EDI_HS_CD AS hsCode,
            TO_CHAR(ITEM.EDI_DCLR_QTY, 'FM999,999,999') AS qty,
            ED.ED_PRPS_COUNTRY_CD AS origin,

            TO_CHAR(NULL) AS reviewMemo,
            TO_CHAR(NULL) AS reviewStartDate,
            TO_CHAR(NULL) AS acceptDate,

            ER.ER_COMMENT AS requestContent
        FROM EXP_RQST ER
        LEFT JOIN BROKER B
            ON ER.ER_BROKER_ID = B.BROKER_ID
        LEFT JOIN OWNER OWR
            ON ER.ER_OWR_ID = OWR.OWR_ID
        LEFT JOIN EXP_DCLR ED
            ON ER.ER_NO = ED.ED_ER_NO
        LEFT JOIN EXP_DCLR_ITEM ITEM
            ON ER.ER_NO = ITEM.EDI_ER_NO
           AND ITEM.EDI_SN = (
                SELECT MIN(EDI_SN)
                FROM EXP_DCLR_ITEM
                WHERE EDI_ER_NO = ER.ER_NO
           )
        LEFT JOIN OFFICER O
            ON ED.OFFICER_ID = O.OFFICER_ID
        LEFT JOIN (
            SELECT *
            FROM (
                SELECT
                    A.*,
                    ROW_NUMBER() OVER (
                        PARTITION BY A.ARR_BIZ_TYPE_CD, A.ARR_REF_NO
                        ORDER BY A.ARR_REGIST_DT DESC
                    ) AS RN
                FROM AI_RISK_RESULT A
                WHERE A.ARR_BIZ_TYPE_CD = 'EXPORT'
            )
            WHERE RN = 1
        ) ARR
            ON ARR.ARR_REF_NO = ER.ER_NO
        WHERE ER.ER_NO = #{reqNo}
    </select>


    <!-- 수입 품목 목록 -->
    <select id="selectImportItems"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.BasicScreenDetailDTO">
        SELECT
            IDI_SN                                                      AS itemNo,
            IDI_DCLR_GDSNM                                              AS itemName,
            IDI_TRDNG_GDSNM                                             AS tradeItemName,
            IDI_HS_CD                                                   AS hsCode,
            IDI_ORGN_CNTRY_CD                                           AS origin,
            TO_CHAR(IDI_QTY,          'FM999,999,999')                  AS qty,
            TO_CHAR(IDI_NET_WT,       'FM999,999,999.000')              AS weight,
            CASE WHEN ITEM.IDI_TAXT_RT IS NULL THEN '-' ELSE TO_CHAR(ITEM.IDI_TAXT_RT, 'FM990.00') || '%' END AS taxRate,
            TO_CHAR(NVL(NULLIF(ITEM.IDI_TAXT_PRC_KRW, 0),
                   NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                          FROM IMP_DCLR_ITEM_MDLSPEC M
                         WHERE M.IDIM_IR_NO = ITEM.IDI_IR_NO
                           AND M.IDIM_SN    = ITEM.IDI_SN), 0)), 'FM999,999,999,999')             AS amount,
            TO_CHAR(ROUND(NVL(NULLIF(ITEM.IDI_TAXT_PRC_KRW, 0),
                   NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                          FROM IMP_DCLR_ITEM_MDLSPEC M
                         WHERE M.IDIM_IR_NO = ITEM.IDI_IR_NO
                           AND M.IDIM_SN    = ITEM.IDI_SN), 0)) * NVL(ITEM.IDI_TAXT_RT, 0) / 100),
                         'FM999,999,999,999')                           AS taxAmount,
            '미분석'                                                      AS riskGrade,
            '-'                                                         AS reqTarget,
            ITEM.IDI_STATUS_CD                                          AS itemStatusCd,
            NVL(
                (
                    SELECT RM_RJCT_CN
                    FROM (
                        SELECT R.RM_RJCT_CN
                        FROM RJCT_MNG R
                        WHERE R.RM_REF_BIZ_CD = 'IMPORT_ITEM'
                          AND R.RM_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                        ORDER BY R.RM_RJCT_DT DESC
                    )
                    WHERE ROWNUM = 1
                ),
                NVL(
                    (
                        SELECT SR_SUBMIT_CN
                        FROM (
                            SELECT S.SR_SUBMIT_CN
                            FROM SUPP_RQST S
                            WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                              AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                              AND S.SR_STATUS_CD = 'SUB'
                            ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                        )
                        WHERE ROWNUM = 1
                    ),
                    NVL(
                        (
                            SELECT SR_REQ_CN
                            FROM (
                                SELECT S.SR_REQ_CN
                                FROM SUPP_RQST S
                                WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                                  AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                                  AND S.SR_STATUS_CD = 'REQ'
                                ORDER BY S.SR_REQ_DT DESC
                            )
                            WHERE ROWNUM = 1
                        ),
                        (
                            SELECT CSH_MSG
                            FROM (
                                SELECT H.CSH_MSG
                                FROM CUSTOMS_STATUS_HISTORY H
                                WHERE H.CSH_SCOPE_CD = 'IMPORT_ITEM'
                                  AND H.CSH_SRC_PK_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                                  AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                                ORDER BY H.CSH_DT DESC
                            )
                            WHERE ROWNUM = 1
                        )
                    )
                )
            )                                                           AS itemRemark,
            CASE
                WHEN EXISTS (
                    SELECT 1
                    FROM RJCT_MNG R
                    WHERE R.RM_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND R.RM_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                ) THEN (
                    SELECT TO_CHAR(RM_RJCT_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT R.RM_RJCT_DT
                        FROM RJCT_MNG R
                        WHERE R.RM_REF_BIZ_CD = 'IMPORT_ITEM'
                          AND R.RM_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                        ORDER BY R.RM_RJCT_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM CUSTOMS_STATUS_HISTORY H
                    WHERE H.CSH_SCOPE_CD = 'IMPORT_ITEM'
                      AND H.CSH_SRC_PK_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                ) THEN (
                    SELECT TO_CHAR(CSH_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT H.CSH_DT
                        FROM CUSTOMS_STATUS_HISTORY H
                        WHERE H.CSH_SCOPE_CD = 'IMPORT_ITEM'
                          AND H.CSH_SRC_PK_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                          AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                        ORDER BY H.CSH_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                ) THEN (
                    SELECT TO_CHAR(NVL(SR_SUBMIT_DT, SR_REQ_DT), 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT S.SR_SUBMIT_DT, S.SR_REQ_DT
                        FROM SUPP_RQST S
                        WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                          AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                          AND S.SR_STATUS_CD = 'SUB'
                        ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD = 'REQ'
                ) THEN (
                    SELECT TO_CHAR(SR_REQ_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT S.SR_REQ_DT
                        FROM SUPP_RQST S
                        WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                          AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                          AND S.SR_STATUS_CD = 'REQ'
                        ORDER BY S.SR_REQ_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                ELSE NULL
            END                                                         AS itemHistoryDate,

            (
                SELECT TO_CHAR(SR_REQ_DT, 'YYYY-MM-DD HH24:MI')
                FROM (
                    SELECT S.SR_REQ_DT
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD != 'CANCEL'
                    ORDER BY S.SR_REQ_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppReqDate,

            (
                SELECT SR_REQ_CN
                FROM (
                    SELECT S.SR_REQ_CN
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD != 'CANCEL'
                    ORDER BY S.SR_REQ_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppReqCn,

            (
                SELECT TO_CHAR(SR_SUBMIT_DT, 'YYYY-MM-DD HH24:MI')
                FROM (
                    SELECT S.SR_SUBMIT_DT
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                      AND S.SR_SUBMIT_DT IS NOT NULL
                    ORDER BY S.SR_SUBMIT_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppSubmitDate,

            (
                SELECT SR_SUBMIT_CN
                FROM (
                    SELECT S.SR_SUBMIT_CN
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                      AND S.SR_SUBMIT_CN IS NOT NULL
                    ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppSubmitCn,
            /* ── 세금·허가 심사 필수 추가 컬럼 ──────────────────────────
               아래 컬럼명은 추정값입니다. IMP_DCLR_ITEM 실제 DDL 확인 후 수정하세요.
               IDI_TAXT_TP_CD      → 관세구분 (일반/협정/잠정세율 등)
               IDI_ORGN_DTN_STD_CD → 원산지결정기준 (WO/CTH/RVC 등)
               IDI_TAX_RDCT_CD     → 관세감면구분
               IDI_TAXT_AMT        → 관세액 (순수 관세액)
               IDI_VAT_AMT         → 부가세액
               컬럼이 없다면 해당 줄을 TO_CHAR(NULL) AS ... 로 유지하세요. */
            TO_CHAR(NULL)                                               AS customsDutyType,
            TO_CHAR(NULL)                                               AS originCriteria,
            TO_CHAR(NULL)                                               AS taxExemption,
            TO_CHAR(ROUND(NVL(NULLIF(ITEM.IDI_TAXT_PRC_KRW, 0),
                   NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                          FROM IMP_DCLR_ITEM_MDLSPEC M
                         WHERE M.IDIM_IR_NO = ITEM.IDI_IR_NO
                           AND M.IDIM_SN    = ITEM.IDI_SN), 0)) * NVL(ITEM.IDI_TAXT_RT, 0) / 100),
                         'FM999,999,999,999')                           AS taxAmt,
            TO_CHAR(ROUND((NVL(NULLIF(ITEM.IDI_TAXT_PRC_KRW, 0),
                   NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                          FROM IMP_DCLR_ITEM_MDLSPEC M
                         WHERE M.IDIM_IR_NO = ITEM.IDI_IR_NO
                           AND M.IDIM_SN    = ITEM.IDI_SN), 0)) + ROUND(NVL(NULLIF(ITEM.IDI_TAXT_PRC_KRW, 0),
                   NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                          FROM IMP_DCLR_ITEM_MDLSPEC M
                         WHERE M.IDIM_IR_NO = ITEM.IDI_IR_NO
                           AND M.IDIM_SN    = ITEM.IDI_SN), 0)) * NVL(ITEM.IDI_TAXT_RT, 0) / 100)) * 0.1),
                         'FM999,999,999,999')                           AS vatAmount
        FROM IMP_DCLR_ITEM ITEM
        WHERE ITEM.IDI_IR_NO = #{reqNo}
        ORDER BY IDI_SN
    </select>


    <!-- 수출 품목 목록 -->
    <select id="selectExportItems"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.BasicScreenDetailDTO">
        SELECT
            EDI_SN                                                      AS itemNo,
            EDI_EXPT_GDS_NM                                             AS itemName,
            EDI_TRDNG_GDS_NM                                            AS tradeItemName,
            EDI_HS_CD                                                   AS hsCode,
            TO_CHAR(NULL)                                               AS origin,
            TO_CHAR(EDI_DCLR_QTY,    'FM999,999,999')                  AS qty,
            TO_CHAR(EDI_NET_WT,      'FM999,999,999.000')               AS weight,
            TO_CHAR(NULL)                                               AS taxRate,
            TO_CHAR(EDI_DCLR_PRC_KRW,'FM999,999,999,999')              AS amount,
            TO_CHAR(NULL)                                               AS taxAmount,
            '미분석'                                                      AS riskGrade,
            '-'                                                         AS reqTarget,
            CASE
                WHEN EXISTS (
                    SELECT 1
                    FROM RJCT_MNG R
                    WHERE R.RM_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND R.RM_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                ) THEN 'ITEM_REJ'
                WHEN EXISTS (
                    SELECT 1
                    FROM CUSTOMS_STATUS_HISTORY H
                    WHERE H.CSH_SCOPE_CD = 'EXPORT_ITEM'
                      AND H.CSH_SRC_PK_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                ) THEN 'ITEM_ACPT'
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                ) THEN 'ITEM_SUPP_SUB'
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'REQ'
                ) THEN 'ITEM_SUPP_REQ'
                ELSE 'ITEM_REVIEW'
            END                                                         AS itemStatusCd,
            NVL(
                (
                    SELECT RM_RJCT_CN
                    FROM (
                        SELECT R.RM_RJCT_CN
                        FROM RJCT_MNG R
                        WHERE R.RM_REF_BIZ_CD = 'EXPORT_ITEM'
                          AND R.RM_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                        ORDER BY R.RM_RJCT_DT DESC
                    )
                    WHERE ROWNUM = 1
                ),
                NVL(
                    (
                        SELECT SR_SUBMIT_CN
                        FROM (
                            SELECT S.SR_SUBMIT_CN
                            FROM SUPP_RQST S
                            WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                              AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                              AND S.SR_STATUS_CD = 'SUB'
                            ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                        )
                        WHERE ROWNUM = 1
                    ),
                    NVL(
                        (
                            SELECT SR_REQ_CN
                            FROM (
                                SELECT S.SR_REQ_CN
                                FROM SUPP_RQST S
                                WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                                  AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                                  AND S.SR_STATUS_CD = 'REQ'
                                ORDER BY S.SR_REQ_DT DESC
                            )
                            WHERE ROWNUM = 1
                        ),
                        (
                            SELECT CSH_MSG
                            FROM (
                                SELECT H.CSH_MSG
                                FROM CUSTOMS_STATUS_HISTORY H
                                WHERE H.CSH_SCOPE_CD = 'EXPORT_ITEM'
                                  AND H.CSH_SRC_PK_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                                  AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                                ORDER BY H.CSH_DT DESC
                            )
                            WHERE ROWNUM = 1
                        )
                    )
                )
            )                                                           AS itemRemark,
            CASE
                WHEN EXISTS (
                    SELECT 1
                    FROM RJCT_MNG R
                    WHERE R.RM_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND R.RM_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                ) THEN (
                    SELECT TO_CHAR(RM_RJCT_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT R.RM_RJCT_DT
                        FROM RJCT_MNG R
                        WHERE R.RM_REF_BIZ_CD = 'EXPORT_ITEM'
                          AND R.RM_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                        ORDER BY R.RM_RJCT_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM CUSTOMS_STATUS_HISTORY H
                    WHERE H.CSH_SCOPE_CD = 'EXPORT_ITEM'
                      AND H.CSH_SRC_PK_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                ) THEN (
                    SELECT TO_CHAR(CSH_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT H.CSH_DT
                        FROM CUSTOMS_STATUS_HISTORY H
                        WHERE H.CSH_SCOPE_CD = 'EXPORT_ITEM'
                          AND H.CSH_SRC_PK_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                          AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                        ORDER BY H.CSH_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                ) THEN (
                    SELECT TO_CHAR(NVL(SR_SUBMIT_DT, SR_REQ_DT), 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT S.SR_SUBMIT_DT, S.SR_REQ_DT
                        FROM SUPP_RQST S
                        WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                          AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                          AND S.SR_STATUS_CD = 'SUB'
                        ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'REQ'
                ) THEN (
                    SELECT TO_CHAR(SR_REQ_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT S.SR_REQ_DT
                        FROM SUPP_RQST S
                        WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                          AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                          AND S.SR_STATUS_CD = 'REQ'
                        ORDER BY S.SR_REQ_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                ELSE NULL
            END                                                         AS itemHistoryDate,

            (
                SELECT TO_CHAR(SR_REQ_DT, 'YYYY-MM-DD HH24:MI')
                FROM (
                    SELECT S.SR_REQ_DT
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD != 'CANCEL'
                    ORDER BY S.SR_REQ_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppReqDate,

            (
                SELECT SR_REQ_CN
                FROM (
                    SELECT S.SR_REQ_CN
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD != 'CANCEL'
                    ORDER BY S.SR_REQ_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppReqCn,

            (
                SELECT TO_CHAR(SR_SUBMIT_DT, 'YYYY-MM-DD HH24:MI')
                FROM (
                    SELECT S.SR_SUBMIT_DT
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                      AND S.SR_SUBMIT_DT IS NOT NULL
                    ORDER BY S.SR_SUBMIT_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppSubmitDate,

            (
                SELECT SR_SUBMIT_CN
                FROM (
                    SELECT S.SR_SUBMIT_CN
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                      AND S.SR_SUBMIT_CN IS NOT NULL
                    ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppSubmitCn,
            /* ── 세금·허가 심사 필수 추가 컬럼 ──────────────────────────
               아래 컬럼명은 추정값입니다. EXP_DCLR_ITEM 실제 DDL 확인 후 수정하세요.
               EDI_TAXT_TP_CD      → 관세구분
               EDI_ORGN_DTN_STD_CD → 원산지결정기준
               EDI_TAX_RDCT_CD     → 관세감면구분
               EDI_TAXT_AMT        → 관세액
               EDI_VAT_AMT         → 부가세액 */
            TO_CHAR(NULL)                                               AS customsDutyType,
            TO_CHAR(NULL)                                               AS originCriteria,
            TO_CHAR(NULL)                                               AS taxExemption,
            TO_CHAR(NULL)                                               AS taxAmt,
            TO_CHAR(NULL)                                               AS vatAmount
        FROM EXP_DCLR_ITEM ITEM
        WHERE ITEM.EDI_ER_NO = #{reqNo}
        ORDER BY EDI_SN
    </select>


    <!-- 품목 처리 대상 관세사 조회 -->
    <select id="selectTargetBrokerId" parameterType="string" resultType="string">
        SELECT brokerId
        FROM (
            SELECT IR_BROKER_ID AS brokerId
            FROM IMP_RQST
            WHERE IR_NO = #{reqNo}
            UNION ALL
            SELECT ER_BROKER_ID AS brokerId
            FROM EXP_RQST
            WHERE ER_NO = #{reqNo}
        )
        WHERE ROWNUM = 1
    </select>

    <!-- 란사항 보완요청 저장: SUPP_RQST 사용 -->
    <insert id="insertItemSupplement" parameterType="map">
        INSERT INTO SUPP_RQST (
            SR_NO,
            SR_REF_BIZ_CD,
            SR_REF_NO,
            SENDER_ID,
            SENDER_TY_CD,
            RECEIVER_ID,
            RECEIVER_TY_CD,
            SR_STATUS_CD,
            SR_REQ_DT,
            SR_REQ_CN
        ) VALUES (
            'SR' || SUBSTR(RAWTOHEX(SYS_GUID()), 1, 28),
            #{refBizCd},
            #{refNo},
            #{officerId},
            'OFFICER',
            #{targetId},
            'BROKER',
            'REQ',
            SYSDATE,
            #{reason}
        )
    </insert>

    <!-- 란사항 반려 저장: RJCT_MNG 사용 -->
    <insert id="insertItemReject" parameterType="map">
        INSERT INTO RJCT_MNG (
            RM_NO,
            RM_REF_BIZ_CD,
            RM_REF_NO,
            RM_RJCT_DT,
            RM_RJCT_CN,
            RM_RJCTR_ID,
            RM_TARGET_ID
        ) VALUES (
            'RM' || SUBSTR(RAWTOHEX(SYS_GUID()), 1, 28),
            #{refBizCd},
            #{refNo},
            SYSDATE,
            #{reason},
            #{officerId},
            #{targetId}
        )
    </insert>

    <!-- 관세사에게 세금정보 전달 처리
         ※ CUSTOMS_TAX 테이블에 별도 전달일시 컬럼이 없으므로 CT_CRT_DT를 세금정보 생성/전달시각으로 사용한다.
         ※ 상태값은 공통코드에 존재하는 TAX_UNPAID / TAX_PAID / TAX_OVERDUE만 사용한다. -->
    <update id="updateTaxSendDate" parameterType="string">
        UPDATE CUSTOMS_TAX
           SET CT_PAY_STATUS_CD = 'TAX_UNPAID',
               CT_PAY_DONE_YN   = 'N',
               CT_CRT_DT        = SYSDATE
         WHERE CT_STTEMNT_ID = #{reqNo}
           AND CT_TYPE_CD    = 'IMPORT'
    </update>

    <!-- 세금탭 품목별 최신 세율·세액 조회 (AJAX용)
         품목정보 탭과 같은 과세가격 기준을 사용한다.
    -->
    <select id="selectTaxItems" parameterType="string" resultType="map">
        SELECT
            ITEM.IDI_SN AS "itemNo",
            ITEM.IDI_DCLR_GDSNM AS "itemName",
            ITEM.IDI_HS_CD AS "hsCode",

            TO_CHAR(
                NVL(NULLIF(ITEM.IDI_TAXT_PRC_KRW, 0),
                    NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                           FROM IMP_DCLR_ITEM_MDLSPEC M
                          WHERE M.IDIM_IR_NO = ITEM.IDI_IR_NO
                            AND M.IDIM_SN    = ITEM.IDI_SN), 0)
                ),
                'FM999,999,999,999'
            ) AS "amount",

            TO_CHAR(NVL(ITEM.IDI_TAXT_RT, 0), 'FM990.00') || '%' AS "taxRate",

            TO_CHAR(
                ROUND(
                    NVL(NULLIF(ITEM.IDI_TAXT_PRC_KRW, 0),
                        NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                               FROM IMP_DCLR_ITEM_MDLSPEC M
                              WHERE M.IDIM_IR_NO = ITEM.IDI_IR_NO
                                AND M.IDIM_SN    = ITEM.IDI_SN), 0)
                    ) * NVL(ITEM.IDI_TAXT_RT, 0) / 100
                ),
                'FM999,999,999,999'
            ) AS "taxAmt",

            TO_CHAR(
                ROUND(
                    (
                        NVL(NULLIF(ITEM.IDI_TAXT_PRC_KRW, 0),
                            NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                                   FROM IMP_DCLR_ITEM_MDLSPEC M
                                  WHERE M.IDIM_IR_NO = ITEM.IDI_IR_NO
                                    AND M.IDIM_SN    = ITEM.IDI_SN), 0)
                        )
                      + ROUND(
                            NVL(NULLIF(ITEM.IDI_TAXT_PRC_KRW, 0),
                                NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                                       FROM IMP_DCLR_ITEM_MDLSPEC M
                                      WHERE M.IDIM_IR_NO = ITEM.IDI_IR_NO
                                        AND M.IDIM_SN    = ITEM.IDI_SN), 0)
                            ) * NVL(ITEM.IDI_TAXT_RT, 0) / 100
                        )
                    ) * 0.1
                ),
                'FM999,999,999,999'
            ) AS "vatAmount"
        FROM IMP_DCLR_ITEM ITEM
        WHERE ITEM.IDI_IR_NO = #{reqNo}
        ORDER BY ITEM.IDI_SN
    </select>

    <!-- 품목 관세율 DB 저장 (세율 재조회 버튼 클릭 시) -->

    <!-- 세율 저장 후 CUSTOMS_TAX 세액 재계산 UPDATE
         계산식:
         - 관세액          = SUM(과세가격 × 관세율 / 100)
         - 부가세 과세표준 = 과세가격합계 + 관세액
         - 부가세액        = 부가세 과세표준 × 10%
         - 총납부세액      = 관세액 + 부가세액
         - 납부기한        = 최초 생성 시 값 유지, 없으면 오늘 + 15일
    -->


    <!-- 품목 관세율 DB 저장 (세율 재조회 버튼/자동조회 후 저장) -->
    <update id="updateItemTaxRate" parameterType="map">
        UPDATE IMP_DCLR_ITEM
           SET IDI_TAXT_RT = #{taxRate},
               IDI_UPDT_DT = SYSDATE
         WHERE IDI_IR_NO = #{reqNo}
           AND IDI_SN    = #{itemNo}
    </update>

    <!-- 세율 저장 후 CUSTOMS_TAX 세액 재계산 UPDATE
         계산 기준은 화면의 품목 과세가격과 동일하게 맞춘다.
         과세가격 = IDI_TAXT_PRC_KRW 값이 있으면 사용, 0/NULL이면 IMP_DCLR_ITEM_MDLSPEC.IDIM_AMT 합계 사용
         관세액 = SUM(과세가격 × 관세율 / 100)
         부가세 과세표준 = 과세가격합계 + 관세액
         부가세액 = 부가세 과세표준 × 10%
         총납부세액 = 관세액 + 부가세액
         납부기한 = 없으면 오늘 + 15일
    -->
    <update id="recalcCustomsTax" parameterType="string">
        UPDATE CUSTOMS_TAX CT
           SET CT_DUTY_AMT = (
                   SELECT NVL(SUM(ROUND(TAX_PRICE * NVL(I.IDI_TAXT_RT, 0) / 100)), 0)
                     FROM (
                           SELECT I.IDI_IR_NO,
                                  I.IDI_SN,
                                  I.IDI_TAXT_RT,
                                  NVL(NULLIF(I.IDI_TAXT_PRC_KRW, 0),
                                      NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                                             FROM IMP_DCLR_ITEM_MDLSPEC M
                                            WHERE M.IDIM_IR_NO = I.IDI_IR_NO
                                              AND M.IDIM_SN    = I.IDI_SN), 0)
                                  ) AS TAX_PRICE
                             FROM IMP_DCLR_ITEM I
                            WHERE I.IDI_IR_NO = #{reqNo}
                          ) I
               ),
               CT_VAT_AMT = (
                   SELECT ROUND(
                              (
                                  NVL(SUM(TAX_PRICE), 0)
                                + NVL(SUM(ROUND(TAX_PRICE * NVL(I.IDI_TAXT_RT, 0) / 100)), 0)
                              ) * 0.1
                          )
                     FROM (
                           SELECT I.IDI_IR_NO,
                                  I.IDI_SN,
                                  I.IDI_TAXT_RT,
                                  NVL(NULLIF(I.IDI_TAXT_PRC_KRW, 0),
                                      NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                                             FROM IMP_DCLR_ITEM_MDLSPEC M
                                            WHERE M.IDIM_IR_NO = I.IDI_IR_NO
                                              AND M.IDIM_SN    = I.IDI_SN), 0)
                                  ) AS TAX_PRICE
                             FROM IMP_DCLR_ITEM I
                            WHERE I.IDI_IR_NO = #{reqNo}
                          ) I
               ),
               CT_TOTAL_TAX_AMT = (
                   SELECT NVL(SUM(ROUND(TAX_PRICE * NVL(I.IDI_TAXT_RT, 0) / 100)), 0)
                        + ROUND(
                              (
                                  NVL(SUM(TAX_PRICE), 0)
                                + NVL(SUM(ROUND(TAX_PRICE * NVL(I.IDI_TAXT_RT, 0) / 100)), 0)
                              ) * 0.1
                          )
                     FROM (
                           SELECT I.IDI_IR_NO,
                                  I.IDI_SN,
                                  I.IDI_TAXT_RT,
                                  NVL(NULLIF(I.IDI_TAXT_PRC_KRW, 0),
                                      NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                                             FROM IMP_DCLR_ITEM_MDLSPEC M
                                            WHERE M.IDIM_IR_NO = I.IDI_IR_NO
                                              AND M.IDIM_SN    = I.IDI_SN), 0)
                                  ) AS TAX_PRICE
                             FROM IMP_DCLR_ITEM I
                            WHERE I.IDI_IR_NO = #{reqNo}
                          ) I
               ),
               CT_PAY_DDLINE_DT = NVL(CT_PAY_DDLINE_DT, TRUNC(SYSDATE) + 15)
         WHERE CT.CT_STTEMNT_ID = #{reqNo}
           AND CT.CT_TYPE_CD    = 'IMPORT'
    </update>

    <!-- =====================================================
         세금납부 탭: CUSTOMS_TAX + IMP_DCLR + CUSTOMS_TAX_PAY 조회
         ===================================================== -->

    <!-- CUSTOMS_TAX 레코드 존재 여부 확인 -->
    <select id="selectTaxCount" parameterType="string" resultType="int">
        SELECT COUNT(*)
          FROM CUSTOMS_TAX
         WHERE CT_STTEMNT_ID = #{reqNo}
           AND CT_TYPE_CD    = 'IMPORT'
    </select>

    <!--
        CUSTOMS_TAX 자동 생성:
        IMP_DCLR_ITEM 집계로 관세액·부가세액 계산 후 INSERT
        - 관세액          = SUM(과세가격 × 관세율 / 100)
        - 부가세 과세표준 = 과세가격합계 + 관세액
        - 부가세액        = 부가세 과세표준 × 10%
        - 총납부세액      = 관세액 + 부가세액
        - 납부기한        = 오늘 + 15일
    -->
    <insert id="insertCustomsTaxAuto" parameterType="string">
        INSERT INTO CUSTOMS_TAX (
            CT_NO,
            CT_OWR_ID,
            CT_STTEMNT_ID,
            CT_TYPE_CD,
            CT_DUTY_AMT,
            CT_VAT_AMT,
            CT_TOTAL_TAX_AMT,
            CT_PAY_DDLINE_DT,
            CT_PAY_STATUS_CD,
            CT_PAY_DONE_YN,
            CT_CRT_DT
        )
        SELECT
            (SELECT NVL(MAX(CT_NO), 0) + 1 FROM CUSTOMS_TAX),
            IR.IR_OWR_ID,
            IR.IR_NO,
            'IMPORT',
            TAX.DUTY_AMT,
            TAX.VAT_AMT,
            TAX.DUTY_AMT + TAX.VAT_AMT,
            TRUNC(SYSDATE) + 15,
            'TAX_UNPAID',
            'N',
            SYSDATE
        FROM IMP_RQST IR
        CROSS JOIN (
            SELECT
                NVL(SUM(ROUND(TAX_PRICE * NVL(IDI_TAXT_RT, 0) / 100)), 0) AS DUTY_AMT,
                ROUND(
                    (
                        NVL(SUM(TAX_PRICE), 0)
                      + NVL(SUM(ROUND(TAX_PRICE * NVL(IDI_TAXT_RT, 0) / 100)), 0)
                    ) * 0.1
                ) AS VAT_AMT
            FROM (
                SELECT I.IDI_TAXT_RT,
                       NVL(NULLIF(I.IDI_TAXT_PRC_KRW, 0),
                           NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                                  FROM IMP_DCLR_ITEM_MDLSPEC M
                                 WHERE M.IDIM_IR_NO = I.IDI_IR_NO
                                   AND M.IDIM_SN    = I.IDI_SN), 0)
                       ) AS TAX_PRICE
                  FROM IMP_DCLR_ITEM I
                 WHERE I.IDI_IR_NO = #{reqNo}
            )
        ) TAX
        WHERE IR.IR_NO = #{reqNo}
    </insert>
    <select id="selectImportTax" parameterType="string"
            resultType="kr.or.tacs.dto.officer.TaxDTO">
        SELECT
            CT.CT_NO AS ctNo,
            TO_CHAR(CT.CT_PAY_DDLINE_DT, 'YYYY-MM-DD') AS payDueDate,
            'TAX-' || LPAD(TO_CHAR(CT.CT_NO), 10, '0') AS taxNoticeNo,

            /* 관세 과세표준 = 품목별 과세가격 합계 */
            TO_CHAR(TAX.TAX_BASE_AMT, 'FM999,999,999,999') AS customsBase,
            '-' AS customsRate,

            /* 관세액 = SUM(과세가격 × 관세율 / 100) */
            TO_CHAR(CT.CT_DUTY_AMT, 'FM999,999,999,999') AS customsAmount,

            CASE
                WHEN NVL(CT.CT_PAY_STATUS_CD, 'TAX_UNPAID') = 'TAX_PAID' THEN '납부완료'
                WHEN NVL(CT.CT_PAY_STATUS_CD, 'TAX_UNPAID') = 'TAX_OVERDUE'
                     OR (NVL(CT.CT_PAY_DONE_YN, 'N') = 'N' AND CT.CT_PAY_DDLINE_DT &lt; TRUNC(SYSDATE)) THEN '기한초과'
                WHEN NVL(CT.CT_DUTY_AMT, 0) = 0 THEN '해당없음'
                ELSE '납부대기'
            END AS customsStatus,

            (SELECT TO_CHAR(MAX(CTP.CTP_DT), 'YYYY-MM-DD HH24:MI')
               FROM CUSTOMS_TAX_PAY CTP
              WHERE CTP.CTP_TAX_NO = CT.CT_NO
                AND CTP.CTP_STATUS_CD = 'TAX_PAID') AS customsPaidDate,

            /* 부가세 과세표준 = 과세가격합계 + 관세액 */
            TO_CHAR(TAX.TAX_BASE_AMT + NVL(CT.CT_DUTY_AMT, 0), 'FM999,999,999,999') AS vatBase,

            /* 부가세액 = 부가세 과세표준 × 10% */
            TO_CHAR(CT.CT_VAT_AMT, 'FM999,999,999,999') AS vatAmount,

            (SELECT TO_CHAR(MAX(CTP.CTP_DT), 'YYYY-MM-DD HH24:MI')
               FROM CUSTOMS_TAX_PAY CTP
              WHERE CTP.CTP_TAX_NO = CT.CT_NO
                AND CTP.CTP_STATUS_CD = 'TAX_PAID') AS vatPaidDate,

            /* 총납부세액 = 관세액 + 부가세액 */
            TO_CHAR(CT.CT_TOTAL_TAX_AMT, 'FM999,999,999,999') AS totalAmount,

            CASE
                WHEN NVL(CT.CT_PAY_STATUS_CD, 'TAX_UNPAID') = 'TAX_PAID' THEN '납부완료'
                WHEN NVL(CT.CT_PAY_STATUS_CD, 'TAX_UNPAID') = 'TAX_OVERDUE'
                     OR (NVL(CT.CT_PAY_DONE_YN, 'N') = 'N' AND CT.CT_PAY_DDLINE_DT &lt; TRUNC(SYSDATE)) THEN '기한초과'
                ELSE '납부대기'
            END AS taxStatus,

            TO_CHAR(CT.CT_CRT_DT, 'YYYY-MM-DD HH24:MI') AS sendDate

        FROM CUSTOMS_TAX CT
        CROSS JOIN (
            SELECT NVL(SUM(TAX_PRICE), 0) AS TAX_BASE_AMT
            FROM (
                SELECT NVL(NULLIF(I.IDI_TAXT_PRC_KRW, 0),
                           NVL((SELECT SUM(NVL(M.IDIM_AMT, 0))
                                  FROM IMP_DCLR_ITEM_MDLSPEC M
                                 WHERE M.IDIM_IR_NO = I.IDI_IR_NO
                                   AND M.IDIM_SN    = I.IDI_SN), 0)
                       ) AS TAX_PRICE
                  FROM IMP_DCLR_ITEM I
                 WHERE I.IDI_IR_NO = #{reqNo}
            )
        ) TAX
        WHERE CT.CT_STTEMNT_ID = #{reqNo}
          AND CT.CT_TYPE_CD    = 'IMPORT'
        ORDER BY CT.CT_NO DESC
        FETCH FIRST 1 ROWS ONLY
    </select>

    <!-- 납부완료 처리: CUSTOMS_TAX 상태 갱신 -->
    <update id="updateTaxPayStatus" parameterType="string">
        UPDATE CUSTOMS_TAX
           SET CT_PAY_STATUS_CD = 'TAX_PAID',
               CT_PAY_DONE_YN   = 'Y'
         WHERE CT_STTEMNT_ID = #{reqNo}
           AND CT_TYPE_CD    = 'IMPORT'
    </update>

    <!-- 납부완료 처리: CUSTOMS_TAX_PAY 납부이력 INSERT -->
    <insert id="insertTaxPay" parameterType="string">
        INSERT INTO CUSTOMS_TAX_PAY (
            CTP_NO,
            CTP_TAX_NO,
            CTP_AMT,
            CTP_DT,
            CTP_STATUS_CD,
            CTP_RCPT_ISSU_YN
        )
        SELECT
            'CTP' || SUBSTR(RAWTOHEX(SYS_GUID()), 1, 27),
            CT.CT_NO,
            CT.CT_TOTAL_TAX_AMT,
            SYSDATE,
            'TAX_PAID',
            'N'
        FROM CUSTOMS_TAX CT
        WHERE CT.CT_STTEMNT_ID = #{reqNo}
          AND CT.CT_TYPE_CD    = 'IMPORT'
          AND ROWNUM = 1
    </insert>

    <!-- =====================================================
         승인 및 필증발급 처리
         ===================================================== -->
    <update id="updateImpDclrStatus" parameterType="map">
	    UPDATE IMP_DCLR
	       SET ID_STATUS_CD = #{statusCd}
	     WHERE ID_IR_NO = #{reqNo}
	</update>

    <update id="updateImpRqstStatus" parameterType="map">
        UPDATE IMP_RQST
           SET IR_STATUS_CD = #{statusCd}
         WHERE IR_NO = #{reqNo}
    </update>

    <update id="updateExpDclrStatus" parameterType="map">
	    UPDATE EXP_DCLR
	       SET ED_STATUS_CD = #{statusCd}
	     WHERE ED_ER_NO = #{reqNo}
	</update>	

    <update id="updateExpRqstStatus" parameterType="map">
        UPDATE EXP_RQST
           SET ER_STATUS_CD = #{statusCd}
         WHERE ER_NO = #{reqNo}
    </update>

    <select id="selectCertificateCount" parameterType="map" resultType="int">
        SELECT COUNT(*)
          FROM CERT_INSURANCE
         WHERE CI_DCLR_TYPE_CD = #{dclrTypeCd}
           AND CI_DCLR_NO      = #{dclrNo}
    </select>

    <insert id="insertCertificate" parameterType="map">
        INSERT INTO CERT_INSURANCE (
            CI_NO,
            CI_DCLR_TYPE_CD,
            CI_DCLR_NO,
            TFG_NO,
            CI_STATUS_CD,
            CI_ISSUE_DT,
            CI_REGIST_DT
        ) VALUES (
            'CI' || TO_CHAR(SYSDATE, 'YYYYMMDD') || LPAD(SEQ_CERT_INSURANCE.NEXTVAL, 6, '0'),
            #{dclrTypeCd},
            #{dclrNo},
            NULL,
            'CERT_ISSUED',
            SYSDATE,
            SYSDATE
        )
    </insert>

    <!-- 수입 란사항 IDI_STATUS_CD 업데이트 (보완요청/반려/수리 공통) -->
    <update id="updateImpDclrItemStatus" parameterType="map">
        UPDATE IMP_DCLR_ITEM
           SET IDI_STATUS_CD = #{statusCd},
               IDI_UPDT_DT   = SYSDATE
         WHERE IDI_IR_NO = #{reqNo}
           AND IDI_SN    = #{itemNo}
    </update>

    <!-- 보완요청완료: 해당 신고건의 미완료(REQ/SUB) 보완요청을 DONE 처리 -->
    <update id="updateSuppRqstDone" parameterType="string">
        UPDATE SUPP_RQST
           SET SR_STATUS_CD = 'DONE',
               SR_UPDT_DT   = SYSDATE
         WHERE SR_REF_NO LIKE #{reqNo} || '%'
           AND SR_STATUS_CD IN ('REQ', 'SUB')
    </update>
    
   <update id="updateCertificateTfgNo" parameterType="map">
	    UPDATE CERT_INSURANCE
	       SET TFG_NO = #{tfgNo},
	           CI_UPDT_DT = SYSDATE
	     WHERE CI_DCLR_TYPE_CD = #{dclrTypeCd}
	       AND CI_DCLR_NO = #{dclrNo}
	</update>
	
	<select id="selectReviewMemo" parameterType="string" resultType="string">
    SELECT RM_MEMO_CN
    FROM REVIEW_MEMO
    WHERE RM_REQ_NO = #{reqNo}
</select>

	<!-- 심사 메모  -->
	<insert id="mergeReviewMemo" parameterType="map">
	    MERGE INTO REVIEW_MEMO RM
	    USING (
	        SELECT
	            #{reqNo} AS RM_REQ_NO,
	            #{reviewMemo} AS RM_MEMO_CN,
	            #{officerId} AS RM_OFFICER_ID
	        FROM DUAL
	    ) SRC
	    ON (RM.RM_REQ_NO = SRC.RM_REQ_NO)
	    WHEN MATCHED THEN
	        UPDATE SET
	            RM.RM_MEMO_CN = SRC.RM_MEMO_CN,
	            RM.RM_OFFICER_ID = SRC.RM_OFFICER_ID,
	            RM.RM_UPDT_DT = SYSDATE
	    WHEN NOT MATCHED THEN
	        INSERT (
	            RM_NO,
	            RM_REQ_NO,
	            RM_MEMO_CN,
	            RM_OFFICER_ID,
	            RM_REG_DT
	        )
	        VALUES (
	            SEQ_REVIEW_MEMO_NO.NEXTVAL,
	            SRC.RM_REQ_NO,
	            SRC.RM_MEMO_CN,
	            SRC.RM_OFFICER_ID,
	            SYSDATE
	        )
	</insert>

</mapper>