package kr.or.tacs.broker.declare.mapper;

import java.util.List;
import java.util.Map;

import org.apache.ibatis.annotations.Mapper;
import org.apache.ibatis.annotations.Param;

import kr.or.tacs.vo.BrokerVO;
import kr.or.tacs.vo.broker.declare.ImpDclrItemMdlspecVO;
import kr.or.tacs.vo.broker.declare.ImpDclrItemVO;
import kr.or.tacs.vo.broker.declare.ImpDclrVO;
import kr.or.tacs.vo.broker.declare.ImpRqstVO;
import kr.or.tacs.vo.broker.TfgFileDto;
import org.apache.ibatis.annotations.Param;
/**
 * 신고서 작성 Mapper
 *  · 1차: insertImpDclr
 *  · 5차: selectImpDclrById, updateImpDclr
 *  · 6차: selectImpDraftList
 *  · 7차: submitImpDclr
 *  · 3차: 자식 IMP_DCLR_ITEM CRUD
 */
@Mapper
public interface IBrokerDeclareMapper {

    // ===== 부모 IMP_DCLR =====
    int insertImpDclr(ImpDclrVO vo);

    ImpDclrVO selectImpDclrById(@Param("idIrNo")    String idIrNo,
                                @Param("officerId") String officerId);

    int updateImpDclr(ImpDclrVO vo);

    int submitImpDclr(@Param("idIrNo")    String idIrNo,
                      @Param("officerId") String officerId);

    List<ImpDclrVO> selectImpDraftList(String officerId);

    /*
     * 8E-DELETE
     * 수입신고서 부모 삭제
     * - 본인 임시저장 TEMP 건만 삭제
     */
    int deleteImpDclr(@Param("idIrNo") String idIrNo,
                      @Param("officerId") String officerId);
    /*
     * 8D-ATTACH
     * 수입의뢰에 파일그룹번호 연결
     *
     * 신고서 화면에서 첨부파일을 새로 올렸는데
     * 기존 IMP_RQST.IR_TFG_NO가 없을 때 새로 생성된 tfgNo를 저장한다.
     */
    int updateImpRqstTfgNo(@Param("irNo") String irNo,
                           @Param("tfgNo") Long tfgNo);
    
    
    // ===== 자식 IMP_DCLR_ITEM =====

    /** 1건 INSERT — bulk insert 시 forEach 로 호출하기보다는 매퍼에서 multi-row insert 가 효율적이지만,
     *  Oracle 의 다행 INSERT 문법(MERGE/INSERT ALL)이 까다로워 단행 INSERT 반복 방식을 사용 */
    int insertImpDclrItem(ImpDclrItemVO item);

    /** 부모(idIrNo) 의 모든 자식 행 삭제 — UPDATE 시 delete-all then insert 패턴 */
    int deleteImpDclrItemsByIrNo(String idIrNo);

    /** 부모(idIrNo) 의 자식 목록 조회 — 이어쓰기 시 폼에 채울 용도 */
    List<ImpDclrItemVO> selectImpDclrItemListByIrNo(String idIrNo);

    // ===== 자식 IMP_DCLR_ITEM_MDLSPEC (모델/규격) — 4차 =====

    /** 모델/규격 1행 INSERT */
    int insertImpDclrItemMdlspec(ImpDclrItemMdlspecVO mdlspec);

    /** 부모(idIrNo) 의 모든 모델/규격 행 삭제 */
    int deleteImpDclrItemMdlspecsByIrNo(String idIrNo);

    /** 부모(idIrNo) 의 모델/규격 목록 조회 */
    List<ImpDclrItemMdlspecVO> selectImpDclrItemMdlspecListByIrNo(String idIrNo);

    // ===== IMP_RQST (의뢰서) — 8B [조회] 버튼 =====

    /**
     * 의뢰번호 1건 조회 — 본인(broker) 의뢰서만
     * @param irNo     의뢰번호 (IMP-YYYYMMDD-NNN)
     * @param brokerId 로그인 broker_id
     * @return 의뢰서 VO 또는 null
     */
    ImpRqstVO selectImpRqstById(@Param("irNo")     String irNo,
                                @Param("brokerId") String brokerId);

    /**
     * 의뢰서 검색 (돋보기 모달) — 본인 담당 또는 미배정 의뢰서 중에서
     * 의뢰번호 / B/L번호 / 화주ID / 통관고유부호 LIKE 검색
     */
    List<ImpRqstVO> selectImpRqstList(@Param("brokerId") String brokerId,
                                      @Param("keyword")  String keyword);

    /**
     * 로그인 사용자(관세사) BROKER 1건 조회 — 신고서 신고인 영역 자동 채움용
     */
    BrokerVO selectBrokerById(String brokerId);

    /**
     * 파일그룹(TFG_NO) 의 PDF 파일 목록 — AI 파싱 대상
     *  · TACS_FILE_MAP ↔ DOCS_FILE_DATA join
     *  · 확장자 'pdf' + 미삭제 파일만
     */
    List<TfgFileDto> selectPdfFilesByTfgNo(Long tfgNo);
    
    
    /**
     * 국가코드조회
     */
    List<Map<String, Object>> selectCountryList(String keyword);
    
    
    /**
     * 상호조회
     */
    List<Map<String, Object>> selectOwnerList(String keyword);
    
    
    /**
     * 수량코드
     */
    List<Map<String, Object>> selectCommonCodeList(Map<String, Object> param);

    /** HS코드 목록 검색 */
    List<Map<String, Object>> selectHsCodeList(String keyword);
    
    /** HS분류계층 자식 목록 조회 */
    List<Map<String, Object>> selectHsClassChildren(@Param("parentCd") String parentCd);

    /** HS코드 기본정보 조회 */
    Map<String, Object> selectHsCodeInfo(String hsCode);

    /** FTA 협정세율 조회 */
    Map<String, Object> selectFtaTariffInfo(Map<String, Object> param);
    
    /** Milvus doc_id 목록으로 HS 추천 후보 조회 */
    List<Map<String, Object>> selectHsRecommendByDocIds(@Param("docIds") List<String> docIds);
}
