@Service
@RequiredArgsConstructor
public class ImportTransportServiceImpl implements ImportTransportService {

    private final ImportTransportMapper importTransportMapper;
    private final IFileService fileService;
    private static final String TRANSPORT_ACTOR_TYPE = "TRANSPORT_MANAGER";

    @Override
    public List<TransportRequestVO> retriveImpTransportReqList() {
        return importTransportMapper.retriveImpTransportReqList(currentTmId());
    }

    @Override
    @Transactional
    public boolean modifyImpTransportReqStatus(String trcNo, String statusCd, String rejectType, String rejectMemo, String actorId) {
        String normalizedStatus = normalizeRequestStatus(statusCd);
        String rejectReason = buildRejectReason(rejectType, rejectMemo);

        int updated = importTransportMapper.updateImpTransportReqStatus(
                trcNo,
                normalizedStatus,
                rejectType,
                rejectMemo,
                rejectReason,
                normalizeActorId(actorId)
        );

        /*
         * 운송의뢰 접수완료는 후속 탭을 열 수 있게 하는 상태 변경까지만 처리한다.
         * WH_IN_RPT의 WIR_NO/row는 입고관리 화면에서 운송담당자가 실제 입고요청 발송 버튼을
         * 눌렀을 때 updateImpUnloadingInDelivered()에서만 생성되어야 한다.
         */

        if (updated > 0 && "TRC_REJECT".equals(normalizedStatus)) {
            importTransportMapper.insertImportTransportReject(trcNo, rejectReason, normalizeActorId(actorId));
        }

        // 접수완료 시 BL_ISSU가 없으면 의뢰번호 기반으로 자동 생성 (TRC- → MBL- 치환)
        if (updated > 0 && "TRC_DONE".equals(normalizedStatus) && trcNo != null && trcNo.startsWith("TRC-")) {
            String autoMblNo = "MBL-" + trcNo.substring(4);
            importTransportMapper.updateImpTransportReqMasterBl(trcNo, autoMblNo);
        }

        return updated > 0;
    }

    @Override
    @Transactional
    public boolean modifyImpTransportReqDetail(String trcNo,
                                               String buyerNm,
                                               String buyerCountryCd,
                                               String transportMeanCd,
                                               String transportTypeCd,
                                               String incoTermsCd,
                                               String deptPortCd,
                                               String arvlPortCd,
                                               String itemCategory,
                                               String goodsName,
                                               Integer qty,
                                               Integer weight,
                                               String mblNo,
                                               String requestCn) {
        int updated = importTransportMapper.updateImpTransportReqDetail(
                trcNo,
                buyerNm,
                buyerCountryCd,
                transportMeanCd,
                transportTypeCd,
                incoTermsCd,
                deptPortCd,
                arvlPortCd,
                itemCategory,
                requestCn
        );
        saveImpTransportReqDetailGoods(trcNo, goodsName, qty, weight);
        // Master B/L이 입력된 경우 BL_ISSU에 저장한다. GOODS_GROUP 부모행은 mapper에서 자동 보장한다.
        if (mblNo != null && !mblNo.trim().isEmpty()) {
            try {
                importTransportMapper.updateImpTransportReqMasterBl(trcNo, mblNo);
            } catch (RuntimeException e) {
                // 상세정보 저장과 B/L 동기화는 분리한다. B/L 기반 자료가 없어도 의뢰 상세 저장은 성공해야 한다.
            }
        }
        return updated > 0;
    }

    private void saveImpTransportReqDetailGoods(String trcNo, String goodsName, Integer qty, Integer weight) {
        if (trcNo == null || trcNo.isBlank()
                || (blankToNull(goodsName) == null && qty == null && weight == null)) {
            return;
        }
        TransportRequestVO goods = new TransportRequestVO();
        goods.setGoodsName(goodsName);
        goods.setItemNm(goodsName);
        goods.setQty(qty);
        goods.setWeight(weight);
        goods.setOrigin("KR");
        normalizeGoodsPayload(goods);
        if (blankToNull(goods.getGoodsName()) == null && blankToNull(goods.getItemNm()) == null) {
            throw new IllegalArgumentException("품명을 입력하세요.");
        }

        Integer existingGoodsNo = importTransportMapper.selectExistingImpGoodsNo(goods);
        if (existingGoodsNo != null) {
            goods.setGoodsNo(existingGoodsNo);
        } else {
            goods.setGoodsNo(importTransportMapper.selectNextImpGoodsNo());
            importTransportMapper.insertImpGoodsMaster(goods);
        }

        goods.setCgNo(importTransportMapper.selectNextImpCustomsGoodsNo());
        importTransportMapper.deleteImpTransportReqDetailGoods(trcNo);
        importTransportMapper.insertImpTransportReqDetailGoods(trcNo, goods);
    }

    @Override
    @Transactional
    public boolean modifyImpUnloadingInSupplement(String wirNo,
                                                  String receiverId,
                                                  String wmId,
                                                  String wzNo,
                                                  String inPlanDt,
                                                  String cargoMgmtNo,
                                                  String invoiceNo,
                                                  String incoTermsCd,
                                                  String remark,
                                                  List<TransportRequestVO> goodsList,
                                                  String actorId) {
        int updated = importTransportMapper.updateImpUnloadingInSupplementData(
                wirNo,
                blankToNull(wmId),
                blankToNull(wzNo),
                blankToNull(inPlanDt),
                blankToNull(cargoMgmtNo),
                blankToNull(invoiceNo),
                blankToNull(incoTermsCd),
                blankToNull(remark)
        );

        saveImpUnloadingInGoods(wirNo, goodsList);

        int submitted = importTransportMapper.updateImpUnloadingInSupplementSubmitted(
                wirNo,
                normalizeActorId(actorId),
                blankToNull(receiverId)
        );

        return updated != 0 || submitted != 0;
    }

    @Override
    @Transactional
    public boolean modifyImpReleaseSupplement(String releaseReqNo,
                                              String trcNo,
                                              String receiverId,
                                              String wmId,
                                              String wzNo,
                                              String releaseReqDt,
                                              String itemNm,
                                              String remark,
                                              List<TransportRequestVO> goodsList,
                                              String suppTypeCd,
                                              String suppReqCn,
                                              String actorId) {
        int updated = importTransportMapper.updateImpReleaseReqData(
                blankToNull(releaseReqNo),
                blankToNull(trcNo),
                blankToNull(wmId),
                blankToNull(wzNo),
                blankToNull(releaseReqDt),
                blankToNull(itemNm),
                blankToNull(remark)
        );
        saveImpReleaseGoods(trcNo, goodsList);

        String reason = normalizeSupplementReason(suppReqCn);
        int inserted = 0;
        int requested = 0;
        if (reason != null && blankToNull(releaseReqNo) != null) {
            inserted = importTransportMapper.insertImportSupplementRequest(
                    "CARGO_RELEASE_REQ",
                    releaseReqNo,
                    normalizeActorId(actorId),
                    "WAREHOUSE",
                    normalizeReceiverId(receiverId),
                    "TRANSPORT",
                    normalizeSupplementType(suppTypeCd),
                    reason
            );
            requested = importTransportMapper.updateImpReleaseSupplementRequested(releaseReqNo);
        }

        int submitted = importTransportMapper.updateImpReleaseSupplementSubmitted(
                blankToNull(releaseReqNo),
                blankToNull(trcNo),
                normalizeActorId(actorId),
                blankToNull(receiverId)
        );
        return updated != 0 || inserted > 0 || requested > 0 || submitted > 0;
    }

    private void saveImpReleaseGoods(String trcNo, List<TransportRequestVO> goodsList) {
        if (trcNo == null || trcNo.isBlank() || goodsList == null) {
            return;
        }
        String wirNo = importTransportMapper.selectImpUnloadingInWirNoByTrcNo(trcNo);
        if (wirNo == null || wirNo.isBlank()) {
            return;
        }
        for (TransportRequestVO goods : goodsList) {
            normalizeGoodsPayload(goods);
            if (!hasImpGoodsValue(goods)) {
                continue;
            }
            if (goods.getGoodsNo() == null) {
                if (blankToNull(goods.getGoodsName()) == null && blankToNull(goods.getItemNm()) == null) {
                    throw new IllegalArgumentException("품목명은 필수 입력값입니다.");
                }

                Integer existingGoodsNo = importTransportMapper.selectExistingImpGoodsNo(goods);
                if (existingGoodsNo != null) {
                    goods.setGoodsNo(existingGoodsNo);
                } else {
                    goods.setGoodsNo(importTransportMapper.selectNextImpGoodsNo());
                    importTransportMapper.insertImpGoodsMaster(goods);
                }
            } else {
                importTransportMapper.updateImpUnloadingInSupplementGoodsName(goods);
            }

            if (goods.getCgNo() != null) {
                importTransportMapper.updateImpUnloadingInSupplementGoods(goods);
            } else {
                goods.setCgNo(importTransportMapper.selectNextImpCustomsGoodsNo());
                importTransportMapper.insertImpUnloadingInGoods(wirNo, goods);
            }
        }
    }

    private String normalizeRequestStatus(String statusCd) {
        if (statusCd == null) {
            return null;
        }
        return switch (statusCd) {
            case "ACC", "ACCEPTED", "TRC_DONE", "접수완료" -> "TRC_DONE";
            case "REJ", "REJECTED", "TRC_REJECT", "접수반려" -> "TRC_REJECT";
            default -> statusCd;
        };
    }

    private String buildRejectReason(String rejectType, String rejectMemo) {
        if (rejectType != null && !rejectType.isBlank()
                && rejectMemo != null && !rejectMemo.isBlank()) {
            return rejectType + " / " + rejectMemo;
        }
        if (rejectType != null && !rejectType.isBlank()) {
            return rejectType;
        }
        if (rejectMemo != null && !rejectMemo.isBlank()) {
            return rejectMemo;
        }
        return "운송의뢰 반려";
    }


    private void saveImpUnloadingInGoods(String wirNo, List<TransportRequestVO> goodsList) {
        if (wirNo == null || wirNo.isBlank() || goodsList == null) {
            return;
        }

        /*
         * 화면의 품목사항 그리드는 행추가/삭제가 가능한 전체 편집 방식이다.
         * 따라서 저장 시 현재 화면 행을 정답으로 보고 기존 CUSTOMS_GOODS를 지운 뒤 다시 넣는다.
         * 이렇게 해야 화면에서 삭제한 행이 DB에도 삭제되고, 여러 행 추가도 1건으로 합쳐지지 않는다.
         */
        importTransportMapper.deleteImpUnloadingInGoodsByWirNo(wirNo);

        for (TransportRequestVO goods : goodsList) {
            normalizeGoodsPayload(goods);
            if (!hasImpGoodsValue(goods)) {
                continue;
            }
            if (goods.getGoodsNo() == null) {
                if (blankToNull(goods.getGoodsName()) == null && blankToNull(goods.getItemNm()) == null) {
                    throw new IllegalArgumentException("품목명은 필수 입력값입니다.");
                }

                /*
                 * 같은 품목명/HS코드가 GOODS 마스터에 이미 있으면 기존 GOODS_NO를 재사용한다.
                 * 화면에서 행추가를 여러 번 할 때마다 GOODS 마스터에 전자기기/식품이 계속 중복 생성되면
                 * 자동완성/조회가 지저분해지고, PK 채번 충돌 가능성도 커진다.
                 */
                Integer existingGoodsNo = importTransportMapper.selectExistingImpGoodsNo(goods);
                if (existingGoodsNo != null) {
                    goods.setGoodsNo(existingGoodsNo);
                } else {
                    goods.setGoodsNo(importTransportMapper.selectNextImpGoodsNo());
                    importTransportMapper.insertImpGoodsMaster(goods);
                }
            } else {
                importTransportMapper.updateImpUnloadingInSupplementGoodsName(goods);
            }

            goods.setCgNo(importTransportMapper.selectNextImpCustomsGoodsNo());
            importTransportMapper.insertImpUnloadingInGoods(wirNo, goods);
        }
    }

    private boolean hasImpGoodsValue(TransportRequestVO goods) {
        if (goods == null) {
            return false;
        }
        return goods.getCgNo() != null
                || goods.getGoodsNo() != null
                || blankToNull(goods.getGoodsName()) != null
                || blankToNull(goods.getItemNm()) != null
                || blankToNull(goods.getHsCode()) != null
                || blankToNull(goods.getGoodsHsCode()) != null
                || goods.getQty() != null
                || goods.getPrice() != null
                || goods.getGoodsTotalPrice() != null
                || goods.getWeight() != null
                || blankToNull(goods.getOrigin()) != null;
    }

    private void normalizeGoodsPayload(TransportRequestVO goods) {
        if (goods == null) {
            return;
        }
        if (blankToNull(goods.getHsCode()) == null && blankToNull(goods.getGoodsHsCode()) != null) {
            goods.setHsCode(goods.getGoodsHsCode().trim());
        }
        if (blankToNull(goods.getGoodsHsCode()) == null && blankToNull(goods.getHsCode()) != null) {
            goods.setGoodsHsCode(goods.getHsCode().trim());
        }
        if (blankToNull(goods.getItemNm()) == null && blankToNull(goods.getGoodsName()) != null) {
            goods.setItemNm(goods.getGoodsName().trim());
        }
    }

    private String normalizeActorId(String actorId) {
        if (actorId == null || actorId.isBlank()) {
            String tmId = currentTmId();
            if (tmId != null && !tmId.isBlank()) {
                return tmId;
            }
            return "TRANSPORT";
        }
        return actorId;
    }

    private String normalizeReceiverId(String receiverId) {
        if (receiverId == null || receiverId.isBlank()) {
            return "WAREHOUSE";
        }
        return receiverId;
    }

    private String blankToNull(String value) {
        if (value == null || value.isBlank() || "-".equals(value.trim())) {
            return null;
        }
        return value.trim();
    }

    private String normalizeSupplementType(String suppTypeCd) {
        if (suppTypeCd == null || suppTypeCd.isBlank()) {
            return "DATA";
        }
        return suppTypeCd;
    }

    private String normalizeSupplementReason(String suppReqCn) {
        if (suppReqCn == null || suppReqCn.isBlank()) {
            return null;
        }
        return suppReqCn.trim();
    }

    @Override
    public List<TransportRequestVO> retriveImpArrivalTrackingList() {
        return importTransportMapper.retriveImpArrivalTrackingList(currentTmId());
    }

    @Override
    @Transactional
    public String modifyImpArrivalNoticeSent(String reqNo) {
        String targetNo = importTransportMapper.selectImpArrivalNoticeTargetNo(reqNo);
        if (targetNo == null || targetNo.isBlank()) {
            targetNo = reqNo;
        }
        /*
         * 도착통지서 발송완료는 입고관리 0단계다.
         * 여기서 ensureImpTransportFlowBase()를 호출하면 WH_IN_RPT skeleton row와 WIR_NO가
         * 미리 생성되어 창고 화면에 입고요청 전 찌꺼기가 노출된다.
         * 따라서 도착통지서 상태만 발송완료로 바꾸고, WH_IN_RPT 생성은 입고요청 발송 API에만 맡긴다.
         */
        importTransportMapper.updateImpArrivalNoticeSent(targetNo);

        /*
         * 도착통지서 발송은 "입고관리 탭을 열 수 있게 하는 단계"까지만 처리한다.
         * WH_IN_RPT 행은 운송담당자가 입고관리 화면에서 실제로 발송 버튼을 눌렀을 때
         * updateImpUnloadingInDelivered()에서 생성/WAIT 처리해야 한다.
         * 여기서 WH_IN_RPT를 미리 만들면 창고담당자 화면에 입고요청 전 찌꺼기가 노출된다.
         */
        String noticeNo = importTransportMapper.selectImpArrivalNoticeNo(targetNo);
        if ((noticeNo == null || noticeNo.isBlank()) && !targetNo.equals(reqNo)) {
            noticeNo = importTransportMapper.selectImpArrivalNoticeNo(reqNo);
        }
        // 이미 발송 UPDATE/INSERT가 예외 없이 끝났는데 기존 데이터의 번호 형식이 달라
        // IAN_NO 재조회만 실패하는 경우 프론트에서 success=false로 떨어지는 것을 막는다.
        return (noticeNo == null || noticeNo.isBlank()) ? targetNo : noticeNo;
    }

    @Override
    public boolean modifyImpArrivalTrackingStatus(String reqNo, String currentLoc, String arrivalStatusCd) {
        return importTransportMapper.updateImpArrivalTrackingStatus(reqNo, currentLoc, arrivalStatusCd) > 0;
    }

