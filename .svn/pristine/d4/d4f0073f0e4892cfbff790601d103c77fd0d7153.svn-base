/* ── D/O 수령 확인 / 화물 인수 완료 ── */
document.addEventListener('click', function(e) {
  if (e.target && e.target.textContent === 'D/O 수령 확인') {
    showToast('D/O 수령이 확인되었습니다.', 'success');
  }
  if (e.target && e.target.textContent === '화물 인수 완료 처리') {
    showToast('화물 인수 완료가 처리되었습니다.', 'success');
  }
  if (e.target && e.target.textContent === 'B/L 승인') {
    showToast('B/L 초안을 승인하였습니다. 선사에서 B/L 원본을 발행합니다.', 'success');
  }
});

