/* ─────────────────────────────
   Owner Transport Contract
───────────────────────────── */

.contract-panel {
    border: 1px solid #e2e8f0;
    background: #fff;
    padding: 0;
    margin-bottom: 0;
}

.contract-form {
    padding: 24px;
}

.contract-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
}

.contract-back-btn {
    padding: 6px 12px;
    font-size: 11px;
    text-decoration: none;
    height: 32px;
}

.contract-back-btn .material-symbols-outlined {
    font-size: 14px;
}

.contract-title {
    font-size: 15px;
    font-weight: 800;
    color: #0f172a;
}

/* 수출/수입 선택 */

.contract-type-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 24px;
}

.contract-type-option {
    cursor: pointer;
    position: relative;
}

.contract-type-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
}

.contract-type-card {
    border: 1px solid #e2e8f0;
    background: #fff;
    min-height: 86px;
    padding: 18px 16px;
    text-align: center;
    transition: border-color .15s, background .15s, opacity .15s;
    opacity: .55;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.contract-type-card .material-symbols-outlined {
    display: block;
    font-size: 28px;
    color: #94a3b8;
    margin-bottom: 8px;
}

.contract-type-card span:last-child {
    font-size: 13px;
    font-weight: 800;
    color: #94a3b8;
}

.contract-type-card.active {
    border: 2px solid #3b82f6;
    background: #eff6ff;
    opacity: 1;
}

.contract-type-card.active .material-symbols-outlined {
    color: #3b82f6;
}

.contract-type-card.active span:last-child {
    color: #1d4ed8;
}

/* 발신 → 수신 */

.contract-flow {
    display: grid;
    grid-template-columns: 1fr 56px 1fr;
    align-items: stretch;
    margin-bottom: 24px;
    border: 1px solid #e2e8f0;
    background: #fff;
}

.contract-flow-box {
    padding: 18px 20px;
    min-height: 86px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.contract-flow-box.sender {
    background: #f8faff;
    border-right: 1px solid #e2e8f0;
}

.contract-flow-box.receiver {
    background: #fff;
    border-left: 1px solid #e2e8f0;
}

.contract-flow-label {
    font-size: 10px;
    color: #94a3b8;
    font-weight: 800;
    margin-bottom: 7px;
}

.contract-flow-value {
    font-size: 13px;
    font-weight: 800;
    color: #0f172a;
}

.contract-flow-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94a3b8;
    font-size: 20px;
    background: #fff;
}

.contract-flow-help {
    font-size: 10px;
    color: #94a3b8;
    margin-top: 6px;
}

/* 운송업체 선택 input */

.contract-forwarder-pick {
    width: 100%;
}

.contract-pick-wrap {
    display: flex;
    gap: 8px;
    align-items: stretch;
}

.contract-pick-input {
    flex: 1;
    height: 40px;
    padding: 0 12px;
    border: 1px solid #cbd5e1;
    border-bottom: 2px solid #94a3b8;
    background: #fff;
    color: #203444;
    font-size: 13px;
    font-family: inherit;
    outline: none;
}

.contract-pick-input::placeholder {
    color: #94a3b8;
}

.contract-pick-btn {
    height: 40px;
    min-width: 72px;
}

/* 운송업체 / 담당자 선택 모달 */

.contract-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 3000;
}

.contract-modal.open {
    display: block;
}

.contract-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, .45);
}

.contract-modal-panel {
    position: relative;
    width: 860px;
    max-width: calc(100vw - 48px);
    max-height: calc(100vh - 96px);
    margin: 48px auto;
    background: #fff;
    border: 1px solid #cbd5e1;
    box-shadow: 0 20px 60px rgba(15, 23, 42, .24);
    display: flex;
    flex-direction: column;
}

.contract-modal-head {
    background: #373f54;
    color: #f7f7ff;
    padding: 16px 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.contract-modal-kicker {
    font-size: 10px;
    font-weight: 800;
    color: #cbd5e1;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: 3px;
}

.contract-modal-head h3 {
    font-size: 15px;
    font-weight: 800;
}

.contract-modal-close {
    background: none;
    border: none;
    color: #f7f7ff;
    cursor: pointer;
}

.contract-modal-close .material-symbols-outlined {
    font-size: 22px;
}

.contract-modal-body {
    padding: 22px;
    overflow-y: auto;
}

.contract-modal-search {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
}

.contract-modal-search-input-wrap {
    position: relative;
    flex: 1;
}

.contract-modal-search-input-wrap .material-symbols-outlined {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 18px;
    color: #94a3b8;
    pointer-events: none;
}

.contract-modal-search-input {
    width: 100%;
    height: 40px;
    padding: 0 12px 0 38px;
    border: 1px solid #cbd5e1;
    border-bottom: 2px solid #94a3b8;
    font-size: 13px;
    color: #203444;
    outline: none;
    font-family: inherit;
}

.contract-modal-search-input:focus {
    border-color: #565e74;
    background: #f8fafc;
}

.contract-modal-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
}

.contract-modal-col {
    border: 1px solid #e2e8f0;
    background: #fff;
    min-height: 320px;
}

.contract-modal-col-title {
    padding: 12px 14px;
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    font-size: 12px;
    font-weight: 800;
    color: #203444;
}

.contract-modal-list {
    max-height: 320px;
    overflow-y: auto;
}

.contract-modal-empty {
    padding: 18px;
    font-size: 12px;
    color: #94a3b8;
}

.contract-company-item,
.contract-manager-pick-item {
    width: 100%;
    border: none;
    border-bottom: 1px solid #f1f5f9;
    background: #fff;
    padding: 13px 14px;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
}

.contract-company-item:hover,
.contract-manager-pick-item:hover {
    background: #f8faff;
}

.contract-company-item:last-child,
.contract-manager-pick-item:last-child {
    border-bottom: none;
}

.contract-company-name,
.contract-manager-name {
    font-size: 13px;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 4px;
}

.contract-company-meta,
.contract-manager-meta,
.contract-manager-email {
    font-size: 11px;
    color: #94a3b8;
}

.contract-manager-email {
    margin-top: 2px;
}

/* 통관형 첨부 업로드 */

.contract-upload-block {
    border: 1px solid #e2e8f0;
    background: #fff;
    padding: 22px 24px 24px;
    margin-bottom: 22px;
}

.contract-upload-step {
    font-size: 12px;
    font-weight: 800;
    color: #64748b;
    margin-bottom: 12px;
}

.contract-upload-guide {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #eef4ff;
    border-left: 4px solid #565e74;
    color: #1e3a8a;
    padding: 12px 16px;
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 20px;
}

.contract-upload-guide .material-symbols-outlined {
    font-size: 18px;
    color: #1d4ed8;
}

.contract-upload-top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
}

.contract-upload-required {
    font-size: 12px;
    font-weight: 800;
    color: #203444;
}

.contract-upload-required span {
    color: #9f403d;
}

.contract-upload-actions {
    display: flex;
    align-items: center;
    gap: 8px;
}

.contract-file-trigger,
.contract-file-add {
    height: 36px;
    padding: 0 16px;
    font-size: 12px;
}

.contract-dropzone {
    border: 2px dashed #d7e2f0;
    background: #f8faff;
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    margin-bottom: 16px;
    transition: border-color .15s, background .15s;
}

.contract-dropzone:hover {
    border-color: #94a3b8;
    background: #f1f7ff;
}

.contract-dropzone-inner {
    text-align: center;
    color: #94a3b8;
}

.contract-dropzone-icon {
    display: block;
    font-size: 34px;
    color: #cbd5e1;
    margin-bottom: 8px;
}

.contract-dropzone-main {
    font-size: 12px;
    color: #64748b;
    margin-bottom: 5px;
}

.contract-dropzone-main strong {
    color: #1d4ed8;
    font-weight: 800;
}

.contract-dropzone-sub {
    font-size: 11px;
    color: #94a3b8;
}

.contract-doc-table-wrap {
    margin-top: 12px;
}

.contract-doc-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
}

.contract-doc-table thead tr {
    background: #f8fafc;
}

.contract-doc-table thead th {
    padding: 12px 16px;
    text-align: left;
    font-size: 10px;
    font-weight: 800;
    color: #64748b;
    border-bottom: 2px solid #e2e8f0;
}

.contract-doc-table tbody td {
    padding: 12px 16px;
    border-bottom: 1px solid #f1f5f9;
}

.contract-empty-cell {
    text-align: center;
    color: #94a3b8;
    padding: 20px 16px !important;
}

/* 요청사항 */

.contract-section {
    border: 1px solid #e2e8f0;
    background: #fff;
    padding: 24px;
    margin-bottom: 22px;
}

.contract-memo-section {
    padding: 22px 24px;
    margin-bottom: 20px;
}

.contract-field-title {
    font-size: 12px;
    font-weight: 800;
    color: #203444;
    margin-bottom: 10px;
}

.contract-memo-wrap {
    margin-bottom: 0;
}

.contract-memo {
    width: 100%;
    min-height: 88px;
    border: 1px solid #cbd5e1;
    padding: 14px;
    font-size: 13px;
    font-family: inherit;
    color: #203444;
    outline: none;
    resize: vertical;
}

.contract-memo:focus {
    border-color: #565e74;
    background: #f8fafc;
}

/* 하단 버튼 */

.contract-actions {
    display: flex;
    gap: 10px;
    align-items: center;
}

.contract-actions .btn {
    min-width: 150px;
    height: 38px;
}

.contract-actions .material-symbols-outlined {
    font-size: 15px;
    margin-right: 4px;
}

/* 반응형 */

@media (max-width: 900px) {
    .contract-type-grid {
        grid-template-columns: 1fr;
    }

    .contract-flow {
        grid-template-columns: 1fr;
    }

    .contract-flow-arrow {
        height: 42px;
        transform: rotate(90deg);
        border-top: 1px solid #e2e8f0;
        border-bottom: 1px solid #e2e8f0;
    }

    .contract-flow-box.sender,
    .contract-flow-box.receiver {
        border-left: none;
        border-right: none;
    }

    .contract-pick-wrap,
    .contract-upload-top,
    .contract-modal-search {
        flex-direction: column;
        align-items: stretch;
    }

    .contract-pick-btn,
    .contract-file-trigger,
    .contract-file-add,
    .contract-modal-search .btn {
        width: 100%;
    }

    .contract-modal-layout {
        grid-template-columns: 1fr;
    }

    .contract-modal-panel {
        margin: 24px auto;
        max-height: calc(100vh - 48px);
    }
}

.forwarder-list-filter {
    margin-bottom: 20px;
    border-left: 3px solid #565e74;
}

.forwarder-search-wrap {
    flex: 1;
}

.forwarder-search-input {
    width: 100%;
}

.forwarder-filter-select {
    min-width: 120px;
}

.forwarder-date-input {
    padding: 6px 8px;
    border: 1px solid #e2e8f0;
    font-size: 12px;
}

.forwarder-date-sep {
    font-size: 11px;
    color: #94a3b8;
}

.forwarder-contract-btn {
    text-decoration: none;
}

.forwarder-contract-btn .material-symbols-outlined {
    font-size: 14px;
    vertical-align: middle;
    margin-right: 4px;
}

.forwarder-list-title {
    font-size: 12px;
    font-weight: 700;
    color: #475569;
    margin-bottom: 10px;
}

.forwarder-manage-col {
    width: 160px;
}

.forwarder-empty-cell {
    padding: 40px 16px !important;
    text-align: center;
    color: #94a3b8;
}