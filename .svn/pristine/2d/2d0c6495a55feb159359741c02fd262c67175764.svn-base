package kr.or.tacs.common.file.service;

import kr.or.tacs.common.file.mapper.IFileMapper;
import kr.or.tacs.dto.FileAccessContextDTO;
import kr.or.tacs.dto.FileInfoDTO;
import kr.or.tacs.vo.common.CustomUser;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.security.access.AccessDeniedException;
import org.springframework.stereotype.Component;

/**
 * 파일 다운로드/미리보기 권한 검증기.
 *
 * <p>기존에는 로그인만 되어 있으면 누구나 fileNo 만으로 임의의 파일을 받을 수 있어
 * IDOR(다른 사용자 파일 무단 조회) 위험이 있었다. 이 검증기는 파일이 속한
 * 수입/수출 신고건의 참여자(소유 화주, 담당 관세사)와 검토 역할(세관)을 기준으로
 * 접근을 인스턴스 단위로 통제한다.</p>
 *
 * <p>단계적 적용(Phase 1): 아직 업무객체 매핑 규칙이 정의되지 않은 파일유형
 * (자료실/문서함/검역 등)은 차단하지 않고 감사 로그만 남긴 뒤 통과시킨다.
 * 후속 단계에서 해당 도메인의 참여자 규칙을 추가하면서 차단 범위를 넓힌다.</p>
 */
@Slf4j
@Component
@RequiredArgsConstructor
public class FileAccessAuthorizer {

    private static final String ROLE_SYSTEM_ADMIN = "SYSTEM_ADMIN";
    private static final String ROLE_OFFICER = "OFFICER";

    private final IFileMapper fileMapper;

    /**
     * 현재 로그인 사용자가 해당 파일을 다운로드/미리보기 할 수 있는지 검증한다.
     * 권한이 없으면 {@link AccessDeniedException} 을 던진다.
     */
    public void checkDownloadable(FileInfoDTO file, CustomUser user) {
        if (file == null) {
            throw new AccessDeniedException("파일 정보가 없습니다.");
        }
        if (user == null) {
            throw new AccessDeniedException("로그인이 필요합니다.");
        }

        String userId = user.getLoginId();
        String roleCd = user.getRoleCd();

        // 1. 시스템 관리자는 전체 허용
        if (ROLE_SYSTEM_ADMIN.equals(roleCd)) {
            return;
        }

        // 2. 업로더 본인
        if (userId != null && userId.equals(file.getDfiActorId())) {
            return;
        }

        // 3. 수입/수출 신고건 참여자 검증
        FileAccessContextDTO ctx = fileMapper.selectFileAccessContext(file.getDfiFileNo());
        if (ctx != null && ctx.isBusinessMapped()) {
            if (userId != null && userId.equals(ctx.getOwnerId())) {
                return; // 소유 화주 본인
            }
            if (userId != null && userId.equals(ctx.getBrokerId())) {
                return; // 담당 관세사
            }
            if (ROLE_OFFICER.equals(roleCd)) {
                return; // 세관/공무원 검토자
            }

            log.info("[FileAccess] 신고건 파일 접근 거부. fileNo={}, userId={}, roleCd={}, ownerId={}, brokerId={}",
                    file.getDfiFileNo(), userId, roleCd, ctx.getOwnerId(), ctx.getBrokerId());
            throw new AccessDeniedException("해당 파일에 접근할 권한이 없습니다.");
        }

        // 4. 업무객체 매핑이 아직 적용되지 않은 파일유형 - Phase 1: 감사 로그 후 통과
        log.warn("[FileAccess][PHASE1] 업무 매핑 미적용 파일유형 통과. fileNo={}, userId={}, roleCd={}, bizTyCd={}",
                file.getDfiFileNo(), userId, roleCd, file.getDfiBizTyCd());
    }
}
