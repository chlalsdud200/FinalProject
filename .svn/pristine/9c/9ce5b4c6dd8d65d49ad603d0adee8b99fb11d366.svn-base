/*
 * 현장공무원(검역기관) - 검역 합격 증명서 발급 Service 구현체
 *
 * 역할:
 * 1. 검역 합격 증명서 발급 대상 목록 조회
 * 2. 검역 합격 증명서 상세 조회
 * 3. 검역 합격 증명서 발급 처리
 * 4. 보완요청 등록 처리
 *
 * Controller는 요청을 받고,
 * Service는 실제 업무 규칙과 DB 처리 순서를 담당한다.
 */
@Service
public class CertsServiceImpl implements ICertsService {
	
	// 검역 합격 증명서 관련 SQL을 실행하는 Mapper
	private final ICertsMapper certsMapper;
	private final CertPdfGenerator certPdfGenerator;
	private final IFileService fileService;
	
	// 공통 문서함 Mapper
	private final DocsMapper docsMapper;
	
	// Google Drive 업로드 서비스
	private final GoogleDriveService googleDriveService;
	
	// 서버 파일 저장 기본 경로
	@Value("${kr.or.tacs.upload.path}")
	private String uploadPath;
	
	// 생성자 주입 방식으로 Mapper 객체를 주입받음
	public CertsServiceImpl(ICertsMapper certsMapper, CertPdfGenerator certPdfGenerator, DocsMapper docsMapper, GoogleDriveService googleDriveService, IFileService fileService) {
		this.certsMapper = certsMapper;
		this.certPdfGenerator = certPdfGenerator;
		this.docsMapper = docsMapper;
		this.googleDriveService = googleDriveService;
		this.fileService = fileService;
	}
	
	
	/*
	 * 처리 흐름:
	 * 1. Controller에서 전달받은 reqNo를 Mapper로 넘긴다.
	 * 2. Mapper에서 검역요청, 검역결과, 검역위치 정보를 조회한다.
	 * 3. 조회된 상세 정보를 Controller로 반환한다.
	 */
	// 검역 합격 증명서 상세 조회
	@Override
	public CertsDTO retriveCerts(String reqNo) {
		
		// reqNo에 해당하는 검역 합격 증명서 상세 정보 조회
		return certsMapper.selectCerts(reqNo);
	}

	/*
	 * @Transactional 사용 이유:
	 * - 증명서 발급 저장 중 오류가 발생하면 DB 작업을 취소하기 위해 사용한다.
	 *
	 * 처리 흐름:
	 * 1. 화면에서 선택한 최종 판정 결과를 확인한다.
	 * 2. 판정 결과가 합격 또는 적합인 경우에만 발급을 허용한다.
	 * 3. 발급 가능하면 Mapper를 통해 증명서 발급 정보를 저장한다.
	 * 4. 저장된 행 수를 Controller로 반환한다.
	 */
	// 검역 합격 증명서 발급
	@Override
	@Transactional
	public int registCertIssue(CertsDTO certsDTO) {
		
		// 화면에서 선택한 최종 판정 결과
		String judgeResult = certsDTO.getJudgeResult();
		
		// 합격 또는 적합이 아닌 경우 증명서 발급을 막음
		if(!"합격".equals(judgeResult) && !"적합".equals(judgeResult)) {
			throw new IllegalStateException("합격 건만 검역 합격 증명서를 발급할 수 있습니다.");
		}
		
		// 검역 합격 증명서 발급 정보 저장
		return certsMapper.insertCertIssue(certsDTO);
	}

	/*
	 * @Transactional 사용 이유:
	 * - 보완요청은 여러 DB 작업이 한 번에 처리된다.
	 *   1) SUPP_RQST 등록
	 *   2) IMP_INS_RESULT 후속조치 수정
	 *   3) IMP_INS_RESULT 판정 결과 저장 또는 수정
	 *
	 * - 셋 중 하나라도 실패하면 전체 작업이 취소되어야 하므로 트랜잭션을 사용한다.
	 *
	 * 처리 흐름:
	 * 1. 보완 유형이 없으면 기본값 DATA로 설정한다.
	 * 2. 보완 요청 사유가 비어 있으면 예외를 발생시킨다.
	 * 3. SUPP_RQST 테이블에 보완요청 정보와 요청내용을 등록한다.
	 * 4. IMP_INS_RESULT 테이블의 결과/후속조치 내용을 보완요청 상태로 수정한다.
	 * 5. IMP_INS_RESULT 테이블에 최종 판정 결과를 저장 또는 수정한다.
	 * 6. 처리된 전체 행 수를 반환한다.
	 */
	// 보완요청 등록
	@Override
	@Transactional
	public int registSupplementRequest(CertsDTO certsDTO) {
		
		// 보완요청 등록 처리 확인용 로그
		// 개발 완료 후에는 삭제하거나 log.debug로 변경하는 것이 좋음
		System.out.println("===== 보완요청 Service 진입 =====");
	    System.out.println("reqNo = " + certsDTO.getReqNo());
	    System.out.println("srNo insert 전 = " + certsDTO.getSrNo());
		
		// 보완 요청 사유가 없으면 등록하지 않음
		if(certsDTO.getSuppReqCn() == null || certsDTO.getSuppReqCn().trim().isEmpty()) {
			throw new IllegalStateException("보완 요청 사유를 입력해야 합니다.");
		}
		
		// 1. 보완요청 기본정보 등록
		// selectKey를 통새 srNo가 먼저 생성되고, certsDTO에 자동 세팅됨
		int result1 = certsMapper.insertSuppRqst(certsDTO);
	    System.out.println("SUPP_RQST insert 결과 = " + result1);
	    System.out.println("srNo insert 후 = " + certsDTO.getSrNo());
	    
	    // 2. 검역 결과 테이블 후속조치 수정
	    int result2 = certsMapper.updateResultForSupplement(certsDTO);

	    // 보완요청도 검역 판정 결과로 저장해야 함
	    certsDTO.setJudgeResult("보완요청");
	    certsDTO.setIirResultCn(certsDTO.getSuppReqCn());
	    
	    // 상세 정보를 다시 조회해서 iilNo 보정
	    CertsDTO detail = certsMapper.selectCerts(certsDTO.getReqNo());
	    
	    if (detail == null) {
			throw new IllegalStateException("검역요청 상세정보를 찾을 수 없습니다.");
		}
	    
	    if (certsDTO.getIilNo() == null || certsDTO.getIilNo().trim().isEmpty()) {
			certsDTO.setIilNo(detail.getIilNo());
		}
	    
	    // IMP_INS_RESULT 없으면 INSERT, 있으면 UPDATE
	    int result0 = certsMapper.mergeResultJudge(certsDTO);

	    // 처리된 전체 행 수 반환
	    return result1 + result2;
	
	}

	/*
	 * 발급 버튼과 다르게 실제 발급 완료 처리를 하지 않고,
	 * IMP_INS_CERT 테이블에 발급 대기 상태로 저장한다.
	 */
	// 검역 합격 증명서 발급정보 저장
	@Override
	@Transactional
	public int saveCertIssue(CertsDTO certsDTO) {
		
		// 증명서 번호가 없으면 저장 불가
		if (certsDTO.getCertIssueNo() == null || certsDTO.getCertIssueNo().trim().isEmpty()) {
			throw new IllegalStateException("증명서 번호가 없습니다.");
		}
		
		// 요청번호가 없으면 저장 불가
		if(certsDTO.getReqNo() == null || certsDTO.getReqNo().trim().isEmpty()) {
			throw new IllegalStateException("검역요청번호가 없습니다.");
		}
		
		// 최종 판정값이 없으면 저장 불가
		if (certsDTO.getJudgeResult() == null || certsDTO.getJudgeResult().trim().isEmpty()) {
			throw new IllegalStateException("최종 판정값이 없습니다.");
		}
		
		// 상세정보를 다시 조회해서 iilNo 등 누락값 보정
		CertsDTO detail = certsMapper.selectCerts(certsDTO.getReqNo());
		
		if (detail == null) {
			throw new IllegalStateException("검역요청 상세정보를 찾을 수 없습니다.");
		}
		
		if (certsDTO.getIilNo() == null || certsDTO.getIilNo().trim().isEmpty()) {
			certsDTO.setIilNo(detail.getIilNo());
		}
		
		if (certsDTO.getIirResultCn() == null || certsDTO.getIirResultCn().trim().isEmpty()) {
			certsDTO.setIirResultCn(detail.getIirResultCn());
		}
		
		// 1. IMP_INS_RESULT 없으면 INSERT, 있으면 UPDATE
		int result1 = certsMapper.mergeResultJudge(certsDTO);
		
		// mergeResultJudge의 selectKey에서 iirNo가 세팅됨
		if (certsDTO.getIirNo() == null || certsDTO.getIirNo().trim().isEmpty()) {
			throw new IllegalStateException("검역결과번호 생성에 실패했습니다.");
		}
		
		// 2. IMP_INS_RESULT에 발급정보 저장
		int result2 = certsMapper.saveCertIssue(certsDTO);
		
		
		return result1 + result2;
	}

	/*
	 * 처리 흐름:
	 * 1. Controller에서 생성한 PaginationinfoVO를 전달받는다.
	 * 2. PaginationInfoVO 안에는 현재 페이지 정보와 검색 조건이 들어 있다.
	 *    - currentPage
	 *    - startRow
	 *    - endRow
	 *    - searchVO
	 * 3. Mapper를 통해 검색 조건에 맞는 전체 발급 대상 건수를 조회한다.
	 * 4. 조회된 전체 건수는 Controller에서 totalRecord로 세팅되어
	 *    totalPage 계산과 페이지 버튼 생성에 사용된다.
	 */
	// 검역 합격 증명서 발급 대상 전체 건수 조회
	@Override
	public int retriveCertsCount(PaginationInfoVO<CertsDTO> pagingVO) {
		
		// 검색 조건에 맞는 전체 데이터 갯수 조회
		return certsMapper.selectCertsCount(pagingVO);
	}

	/*
	 * 처리 흐름:
	 * 1. Controller에서 현재 페이지 정보가 담긴 PaginationInfoVO를 전달받는다.
	 * 2. PaginationInfoVO에는 startRow, endRow가 계산되어 있다.
	 * 3. Mapper XML에서는 startRow, endRow를 이용해 현재 페이지에 해당하는 데이터만 조회한다.
	 * 4. 조회된 목록은 Controller로 반환되고,
	 *    Controller에서 pagingVO.dataList와 certsList에 담아 JSP로 전달한다.
	 */
	// 검역 합격 증명서 발급 대상 목록 조회
	@Override
	public List<CertsDTO> retriveCertsList(PaginationInfoVO<CertsDTO> pagingVO) {
		
		// 현재 페이지에 해당하는 검역 합격 증명서 발급 대상 목록 조회
		return certsMapper.retriveCertsList(pagingVO);
	}

	/*
	 * 처리 흐름:
	 * 1. Controller에서 상세 화면 요청번호 reqNo를 전달받는다.
	 * 2. Mapper를 통해 해당 검역요청번호에 연결된 수입신고 품목 목록을 조회한다.
	 * 3. 품목은 여러 건이 나올 수 있으므로 List<CertsItemDTO>로 반환한다.
	 * 4. Controller는 이 목록을 certsItemList라는 이름으로 JSP에 전달한다.
	 * 5. JSP에서는 c:forEach를 이용해 품목 개수만큼 상세 내역을 반복 출력한다.
	 */
	// 검역 합격 증명서 품목 상세 내역 조회
	@Override
	public List<CertsItemDTO> retriveCertsItemList(String reqNo) {
		
		// 검역요청번호 기준으로 품목 상세 내역 목록 조회
		return certsMapper.selectCertsItemList(reqNo);
	}


	/**
	 * 검역 합격 증명서 PDF 발급
	 * 
	 * 처리 흐름:
	 * 1. 검역요청번호로 증명서 상세 정보 조회
	 * 2. 로그인한 공무원 ID 세팅
	 * 3. PDF byte[] 생성
	 * 4. Controller로 반환
	 */
	@Override
	@Transactional
	public CertPdfIssueResultDTO issueCertPdf(String reqNo, String officerId) throws Exception {
		
		// 1. 증명서 상세 정보 조회
		CertsDTO cert = certsMapper.selectCerts(reqNo);
		
		if (cert == null) {
			throw new RuntimeException("검역 합격 증명서 대상 정보를 찾을 수 없습니다. reqNo=" + reqNo);
		}
		
		String issueStatus = cert.getCertIssueStatus();

		if (!"발급 대기".equals(issueStatus) && !"발급 완료".equals(issueStatus)) {
		    throw new IllegalStateException("검역 합격 증명서를 발급하기 전에 발급정보 저장을 먼저 진행해야 합니다.");
		}
		
		// 2. 품목 상세 목록 조회
		List<CertsItemDTO> itemList = certsMapper.selectCertsItemList(reqNo);
		cert.setItemList(itemList);
		
		// 3. 발급 담당 공무원 ID 세팅
		cert.setOfficerId(officerId);
		
		// 4. PDF 생성
		CertPdfIssueResultDTO pdfResult = certPdfGenerator.generate(cert);
		
		// 5. 공통 파일 모듈로 PDF 업로드 후 파일그룹번호 반환
		Long certTfgNo = fileService.uploadGeneratedFile(
		        "CERT",
		        pdfResult.getPdfBytes(),
		        pdfResult.getFileName(),
		        "application/pdf",
		        "QRTN_PASS_CERT",
		        officerId,
		        "FIELD_OFFICER"
		);

		// 6. PDF 발급 완료 상태로 변경
		cert.setOfficerId(officerId);
		cert.setCertTfgNo(certTfgNo);

		int updateCnt = certsMapper.insertCertIssue(cert);
		
		if (updateCnt <= 0) {
			throw new IllegalStateException("검역 합격 증명서 발급 완료 처리에 실패했습니다.");
		}		
		
		// 7. 브라우저 다운로드용으로 반환
		return pdfResult;
		
	}


	/**
	 * 생성된 검역 합격 증명서 PDF를 공유문서함에 저장
	 * 
	 * 처리 흐름:
	 * 1. PDF byte[]를 서버 파일로 저장
	 * 2. Google Drive에 업로드
	 * 3. DOCS_FILE_DATE 등록
	 * 4. DOCS_BOX_FILE 등록
	 * 5. DOCS_STORAGE 사용량 증가
	 */
	private void saveCertPdfDocs(CertPdfIssueResultDTO pdfResult, String officerId) throws Exception {
		
		// 현장 공무원 문서함 기준
		String actorId = officerId;
		String actorType = "FIELD_OFFICER";
		
		// 파일명 안전 처리
		String originalFileName = pdfResult.getFileName();
		String safeFileName = originalFileName.replace("\\","_").replace("/", "_");
		String saveName = UUID.randomUUID() + "_" + safeFileName; 
		
		// 날짜별 경로 생성
		String datePath = LocalDate.now().format(DateTimeFormatter.ofPattern("/yyyy/MM/dd"));
		
		// DB에 저장할 상대 경로
		String relativePath = "/cloud/" + actorId + datePath;
		
		// 실제 서버 저장 경로
		String saveDirPath = uploadPath + relativePath.replace("/", File.separator);
		File saveDir = new File(saveDirPath);
		
		if(!saveDir.exists()) {
			saveDir.mkdirs();
		}
		
		// 1. 서버 파일 저장
		File saveFile = new File(saveDir, saveName);
		try (FileOutputStream fos = new FileOutputStream(saveFile)) {
			fos.write(pdfResult.getPdfBytes());
		}
		
		// 2. Google Drive 업로드
		String driveFileId = null;
		String driveLogicalPath = "/CERTS/FIELD_OFFICER" + datePath;
		
		String driveFolderId = googleDriveService.getOrCreateFolderPath(driveLogicalPath);
		Map<String, Object> driveResult = googleDriveService.uploadBytes(pdfResult.getPdfBytes(), originalFileName, "application/pdf", driveFolderId);
		
		if (driveResult != null && driveResult.get("id") != null) {
			driveFileId = String.valueOf(driveResult.get("id"));
		}
		
		// 3. 문서함 ROOT 폴더 확인
		Long rootFolderNo = docsMapper.selectRootFolderNo(actorId, actorType);
		
		if (rootFolderNo == null) {
			rootFolderNo = docsMapper.selectDocsFolderNo();
			docsMapper.insertRootFolder(rootFolderNo, actorId, actorType);
		}
		
		// 4. 저장공간 정보 확인
		DocsStorageDTO storage = docsMapper.selectStorage(actorId, actorType);
		
		if (storage == null) {
			docsMapper.insertStorage(actorId, actorType);
		}
		
		// 5. DOCS_FILE_DATA 등록
		Long dfiNo = docsMapper.selectDocsFileNo();
		
		FileInfoDTO fileInfo = new FileInfoDTO();
		fileInfo.setDfiFileNo(dfiNo);
		fileInfo.setDfiActorId(actorId);
		fileInfo.setDfiActorType(actorType);
		fileInfo.setDfiOrgNm(originalFileName);
		fileInfo.setDfiStrNm(saveName);
		fileInfo.setDfiSize((long) pdfResult.getPdfBytes().length);
		fileInfo.setDfiPath(relativePath);
		fileInfo.setDfiExt("pdf");
		fileInfo.setDfiMimeTy("application/pdf");
		fileInfo.setDfiDelYn("N");
		fileInfo.setDfiBizTyCd("CLOUD");
		fileInfo.setDfiDriveFileId(driveFileId);
		
		docsMapper.insertFileData(fileInfo);
		
		// 6. DOCS_BOX_FILE 등록
		Long dbfNo = docsMapper.selectDocsBoxFileNo();
		
		docsMapper.insertBoxFile(dbfNo, rootFolderNo, dfiNo, originalFileName);
		
		// 7. 저장공간 사용량 증가
		docsMapper.updateStorageUsed(actorId, actorType, (long) pdfResult.getPdfBytes().length);
	}


	/**
	 * 보완요청/보완제출 정보 조회
	 *
	 * Controller에서 검역요청번호(reqNo)를 넘기면
	 * Mapper를 통해 SUPP_RQST 테이블에서 해당 검역요청의 보완요청 정보를 조회한다.
	 */
	@Override
	public CertsDTO retriveSupplementRequest(String reqNo) {
		return certsMapper.selectSupplementRequest(reqNo);
	}


	/**
	 * 보완제출 확인완료 처리
	 *
	 * 처리 내용:
	 * - SUPP_RQST.SR_STATUS_CD = 'APR'
	 * - SUPP_RQST.SR_APPR_DT = SYSDATE
	 */
	@Override
	@Transactional
	public int modifySupplementApprove(String srNo) {

		if (srNo == null || srNo.trim().isEmpty()) {
			throw new IllegalStateException("보완요청번호가 없습니다.");
		}
		
		return certsMapper.updateSupplementApprove(srNo);
		
	}


	/**
	 * 검역 합격 증명서 발급 목록 엑셀 다운로드
	 *
	 * 화면에서 입력한 검색 조건을 기준으로
	 * 페이지네이션 없이 전체 목록을 조회한 뒤 xlsx 파일 byte[]로 생성한다.
	 *
	 * @param searchDTO 검색 조건
	 * @return 엑셀 파일 byte[]
	 */
	@Override
	public byte[] downloadCertsExcel(CertsDTO searchDTO) throws Exception {

	    // 1. 엑셀 다운로드용 전체 목록 조회
	    List<CertsDTO> certsList = certsMapper.selectCertsExcelList(searchDTO);

	    try (Workbook workbook = new XSSFWorkbook();
	         ByteArrayOutputStream out = new ByteArrayOutputStream()) {

	        Sheet sheet = workbook.createSheet("검역합격증명서 발급목록");

	        // 2. 헤더 스타일
	        CellStyle headerStyle = workbook.createCellStyle();
	        Font headerFont = workbook.createFont();
	        headerFont.setBold(true);
	        headerStyle.setFont(headerFont);
	        headerStyle.setAlignment(HorizontalAlignment.CENTER);

	        // 3. 헤더 생성
	        String[] headers = {
	            "No.",
	            "검역요청번호",
	            "업체명",
	            "품목명",
	            "HS CODE",
	            "판정상태",
	            "발급상태",
	            "회신기한"
	        };

	        Row headerRow = sheet.createRow(0);

	        for (int i = 0; i < headers.length; i++) {
	            Cell cell = headerRow.createCell(i);
	            cell.setCellValue(headers[i]);
	            cell.setCellStyle(headerStyle);
	        }

	        // 4. 데이터 생성
	        int rowIdx = 1;

	        for (int i = 0; i < certsList.size(); i++) {
	            CertsDTO cert = certsList.get(i);
	            Row row = sheet.createRow(rowIdx++);

	            row.createCell(0).setCellValue(i + 1);
	            row.createCell(1).setCellValue(nvl(cert.getReqNo()));
	            row.createCell(2).setCellValue(nvl(cert.getBizNm()));
	            row.createCell(3).setCellValue(nvl(cert.getItemNm()));
	            row.createCell(4).setCellValue(nvl(cert.getHsCode()));
	            row.createCell(5).setCellValue(nvl(cert.getIirResultCd()));
	            row.createCell(6).setCellValue(nvl(cert.getCertIssueStatus()));
	            row.createCell(7).setCellValue(nvl(cert.getRplyDdlineDt()));
	        }

	        // 5. 컬럼 너비 자동 조정
	        for (int i = 0; i < headers.length; i++) {
	            sheet.autoSizeColumn(i);
	        }

	        // 6. byte[]로 변환
	        workbook.write(out);
	        return out.toByteArray();
	    }
	}

	/**
	 * 엑셀 셀에 null이 들어가지 않도록 빈 문자열로 변환
	 */
	private String nvl(String value) {
	    return value == null ? "" : value;
	}

}






















