@charset "UTF-8";

/* main.css — 행정공무원 공통 스타일
   역할:
   - 전체 배경
   - 공통 레이아웃
   - 공통 버튼
   - 공통 폼
   - 공통 카드
   - 공통 테이블
   - 공통 모달

   금지:
   - 페이지 전용 스타일
   - sidebar/header/footer 전용 스타일
*/

:root {
  --officer-bg: #f4f6fa;
  --officer-surface: #ffffff;
  --officer-text: #203444;
  --officer-title: #0f172a;
  --officer-muted: #64748b;
  --officer-line: #d9eafc;
  --officer-line-dark: #a0b4c8;

  --officer-primary: #1e3054;
  --officer-primary-hover: #152540;

  --officer-danger: #991b1b;
  --officer-danger-bg: #fef2f2;
  --officer-danger-line: #fca5a5;
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  min-height: 100%;
  background: var(--officer-bg);
  color: var(--officer-text);
  font-family: 'Inter', 'Noto Sans KR', Arial, sans-serif;
}

body {
  overflow-x: hidden;
}

.material-symbols-outlined {
  font-family: 'Material Symbols Outlined';
  font-weight: normal;
  font-style: normal;
  font-size: 24px;
  line-height: 1;
  letter-spacing: normal;
  text-transform: none;
  display: inline-block;
  white-space: nowrap;
  word-wrap: normal;
  direction: ltr;
  -webkit-font-feature-settings: 'liga';
  -webkit-font-smoothing: antialiased;
  font-variation-settings:
    'FILL' 0,
    'wght' 400,
    'GRAD' 0,
    'opsz' 24;
}

/* =========================
   공통 레이아웃
========================= */

.main-content,
.officer-main,
main.main-content,
main.officer-main {
  margin-left: 240px;
  padding-top : 64px;
  min-height: 100vh;
  background: var(--officer-bg);
}

.page-wrap,
.page-inner {
  width: 100%;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18px;
}

.page-title {
  margin: 0;
  color: var(--officer-title);
  font-size: 24px;
  font-weight: 900;
}

.page-desc {
  margin-top: 4px;
  color: var(--officer-muted);
  font-size: 13px;
}

/* =========================
   기본 요소
========================= */

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
select,
textarea {
  font-family: inherit;
}

/* =========================
   공통 폼
========================= */

.form-input,
.form-select,
.form-textarea {
  width: 100%;
  background: #fff;
  border: 1px solid #d1d9e6;
  color: #0f172a;
  font-size: 12px;
  outline: none;
}

.form-input,
.form-select {
  height: 33px;
  padding: 0 10px;
}

.form-textarea {
  min-height: 90px;
  padding: 10px;
  resize: vertical;
}

.form-input:focus,
.form-select:focus,
.form-textarea:focus {
  border-color: #3b5bdb;
}

.form-label {
  display: block;
  margin-bottom: 6px;
  font-size: 11px;
  font-weight: 800;
  color: #475569;
}

/* =========================
   공통 버튼
========================= */

.btn-primary,
.btn-secondary,
.btn-danger,
.btn-success {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  height: 33px;
  padding: 0 14px;

  border: 1px solid transparent;

  font-size: 12px;
  font-weight: 800;

  cursor: pointer;
  white-space: nowrap;
}

.btn-primary {
  background: var(--officer-primary);
  border-color: var(--officer-primary);
  color: #fff;
}

.btn-primary:hover {
  background: var(--officer-primary-hover);
}

.btn-secondary {
  background: #fff;
  border-color: #cbd8e8;
  color: #334155;
}

.btn-secondary:hover {
  background: #f1f5f9;
}

.btn-danger {
  background: var(--officer-danger-bg);
  border-color: var(--officer-danger-line);
  color: var(--officer-danger);
}

.btn-danger:hover {
  background: #fee2e2;
}

.btn-success {
  background: #2e7d32;
  border-color: #2e7d32;
  color: #fff;
}

.btn-sm {
  height: 28px;
  padding: 0 10px;
  font-size: 11px;
}

/* =========================
   공통 카드
========================= */

.info-card {
  background: #fff;
  border: 1px solid var(--officer-line);
  border-left: 4px solid #565e74;
  padding: 18px 20px;
  margin-bottom: 14px;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8px;

  margin: 0 0 14px;

  color: #4d6172;
  font-size: 12px;
  font-weight: 900;
}

.section-title::before {
  content: '';
  width: 4px;
  height: 14px;
  background: #565e74;
}

/* =========================
   공통 테이블
========================= */

.data-table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
}

.data-table thead tr {
  background: #ecf4ff;
}

.data-table th {
  padding: 10px 12px;

  border-bottom: 1px solid var(--officer-line);

  color: #4d6172;
  font-size: 11px;
  font-weight: 900;

  text-align: center;
  white-space: nowrap;
}

.data-table td {
  padding: 11px 12px;

  border-bottom: 1px solid var(--officer-line);

  color: var(--officer-text);
  font-size: 12px;

  text-align: center;
  white-space: nowrap;
}

.data-table tbody tr:hover td {
  background: #f8fbff;
}

/* =========================
   공통 배지
========================= */

.badge-done,
.badge-progress,
.badge-wait,
.badge-new,
.badge-pass,
.badge-fail {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  padding: 2px 7px;

  font-size: 10px;
  font-weight: 900;
}

.badge-done,
.badge-progress,
.badge-new {
  background: #e8edf5;
  color: #4a5872;
}

.badge-wait,
.badge-fail {
  background: #f7e3e1;
  color: #8b433d;
}

.badge-pass {
  background: #e4f1e7;
  color: #2f6a3b;
}

/* =========================
   공통 모달
========================= */

.modal-overlay,
.modal {
  display: none;

  position: fixed;
  inset: 0;
  z-index: 2000;

  background: rgba(15, 23, 42, .5);

  align-items: center;
  justify-content: center;
}

.modal-overlay.open,
.modal.open {
  display: flex;
}

.modal-box {
  width: 760px;
  max-width: 94vw;
  max-height: 88vh;

  overflow-y: auto;

  background: #fff;
  border: 1px solid #dde4ef;

  box-shadow: 0 24px 80px rgba(15, 23, 42, .25);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;

  padding: 12px 16px;

  background: #373f54;
  color: #fff;
}

.modal-body {
  padding: 15px;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;

  padding: 12px 16px;

  border-top: 1px solid #e2e8f0;
}

.modal-close {
  border: 0;
  background: transparent;

  color: inherit;
  font-size: 22px;

  cursor: pointer;
}

.hidden {
  display: none !important;
}

/* =========================
   반응형
========================= */

@media (max-width: 900px) {

  .main-content,
  .officer-main,
  main.main-content,
  main.officer-main {
    margin-left: 0;
    padding: 76px 16px 24px;
  }

}

/* =========================
   공통 헤더
   header.jsp 전용 스타일은 main.css에서 관리
========================= */

.topbar {
  position: fixed;
  top: 0;
  left: 240px;
  right: 0;
  height: 64px;
  width: calc(100% - 240px);
  z-index: 900;
  background: #f8fbff;
  border-bottom: 1px solid #dce6f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
}

.tb-left,
.tb-right {
  display: flex;
  align-items: center;
}

.tb-left {
  gap: 20px;
  min-width: 0;
}

.tb-right {
  gap: 10px;
  flex-shrink: 0;
}

.tb-brand {
  font-size: 20px;
  font-weight: 900;
  color: #0f172a;
  letter-spacing: -0.02em;
}

.search-wrap {
  display: flex;
  align-items: center;
  width: 320px;
  height: 34px;
  background: #fff;
  border: 1px solid #cbd8e8;
  padding: 0 10px;
}

.search-wrap .material-symbols-outlined {
  font-size: 18px;
  color: #60748a;
  margin-right: 6px;
}

.search-wrap input {
  width: 100%;
  border: 0;
  outline: 0;
  background: transparent;
  color: #1f3347;
  font-size: 12px;
}

.tb-btn {
  position: relative;
  width: 34px;
  height: 34px;
  border: 0;
  background: transparent;
  color: #1e3054;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  padding: 0;
  box-shadow: none;
}

.tb-btn:hover {
  background: transparent;
  color: #0f172a;
}

.tb-btn .material-symbols-outlined {
  font-size: 23px;
  font-weight: 400;
  line-height: 1;
}

.tb-btn .dot,
.dot {
  display: none;
}

.tb-sep {
  width: 1px;
  height: 26px;
  background: #d8e3ef;
  margin: 0 4px;
}

.tb-user {
  display: flex;
  align-items: center;
  gap: 10px;
}

.tb-user-info {
  text-align: right;
  line-height: 1.2;
}

.tb-user-info .name {
  font-size: 12px;
  font-weight: 900;
  color: #0f172a;
}

.tb-user-info .role {
  margin-top: 3px;
  font-size: 10px;
  font-weight: 600;
  color: #64748b;
}

.tb-avatar {
  width: 34px;
  height: 34px;
  background: #1e3054;
  color: #fff;
  font-size: 13px;
  font-weight: 900;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* =========================
   공통 푸터
   footer.jsp 전용 스타일은 main.css에서 관리
========================= */

.footer {
  margin-left: 240px;
  min-height: 54px;
  padding: 14px 32px;
  background: #f8fbff;
  border-top: 1px solid #dce6f0;
  color: #64748b;
  font-size: 11px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.footer a {
  margin-left: 12px;
  color: #475569;
  text-decoration: none;
  font-weight: 700;
}

.footer a:hover {
  color: #1e3054;
}

.footer-right {
  display: flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
}

.footer-dot {
  width: 7px;
  height: 7px;
  background: #22c55e;
  border-radius: 50%;
}

@media (max-width: 900px) {
  .topbar {
    left: 0;
    width: 100%;
    padding: 0 16px;
  }

  .search-wrap {
    width: 210px;
  }

  .tb-user-info {
    display: none;
  }

  .footer {
    margin-left: 0;
    padding: 14px 16px;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }
}

