    @GetMapping({"/import/manifest/packing-text", "/import/manifest/packing-text.do"})
    @ResponseBody
    public Map<String, Object> retriveImpPackingListText(@RequestParam Long fileNo) {
        FileInfoDTO fileInfo = fileService.getFileInfo(fileNo);
        if (fileInfo == null || fileInfo.getDfiDriveFileId() == null || fileInfo.getDfiDriveFileId().isBlank()) {
            return Map.of("success", false, "text", "", "message", "포장명세서 파일 정보가 없습니다.");
        }

        try (PDDocument document = Loader.loadPDF(googleDriveService.downloadFile(fileInfo.getDfiDriveFileId()))) {
            String text = new PDFTextStripper().getText(document);
            return Map.of("success", true, "text", enrichPackingListExtractedText(text));
        } catch (Exception e) {
            return Map.of("success", false, "text", "", "message", "포장명세서 PDF 텍스트 추출에 실패했습니다.");
        }
    }

    /**
     * 업로드한 포장명세서 PDF 텍스트 추출
     *
     * DB에 저장하지 않고, 적하목록 조회 화면에서 임시 업로드한 PDF를
     * PDFBox로 텍스트 추출하여 화면 대조용으로만 사용한다.
     */
    @PostMapping({"/import/manifest/upload-packing-text", "/import/manifest/upload-packing-text.do"})
    @ResponseBody
    public Map<String, Object> retriveUploadedImpPackingListText(@RequestParam("file") MultipartFile file) {
        if (file == null || file.isEmpty()) {
            return Map.of("success", false, "text", "", "message", "업로드된 PDF 파일이 없습니다.");
        }

        try (PDDocument document = Loader.loadPDF(file.getBytes())) {
            String text = new PDFTextStripper().getText(document);
            return Map.of(
                    "success", true,
                    "text", enrichPackingListExtractedText(text),
                    "fileName", file.getOriginalFilename() == null ? "" : file.getOriginalFilename()
            );
        } catch (Exception e) {
            return Map.of("success", false, "text", "", "message", "업로드한 포장명세서 PDF 텍스트 추출에 실패했습니다.");
        }
    }


    /**
     * 포장명세서 PDF 텍스트에서 품목별 수량/중량을 합산해 텍스트 맨 앞에 붙인다.
     *
     * 기존 화면 JS가 PDF 안의 첫 번째 "4 BAGS", "40 KG"만 잡는 경우가 있어서
     * 서버에서 PDFBox 추출 텍스트를 반환하기 전에 실제 합계값을 먼저 보이도록 만든다.
     * - TOTAL 라인이 있으면 마지막 패키지/중량 값을 합계로 사용
     * - TOTAL 라인이 없으면 품목별 수량/중량을 전부 합산
     * - 마지막 값이 앞선 품목들의 합과 같으면 마지막 값을 TOTAL로 판단하여 중복 합산 방지
     */
    private String enrichPackingListExtractedText(String text) {
        String safeText = text == null ? "" : text;
        PackingListTotal total = parsePackingListTotal(safeText);
        if (total == null || (isBlankText(total.quantityText) && isBlankText(total.weightText))) {
            return safeText;
        }

        StringBuilder prefix = new StringBuilder();
        prefix.append("TACS_PDF_TOTAL\n");
        if (!isBlankText(total.goodsText)) {
            prefix.append("GOODS=").append(total.goodsText).append("\n");
        }
        if (!isBlankText(total.quantityText)) {
            prefix.append(total.quantityText).append("\n");
        }
        if (!isBlankText(total.weightText)) {
            prefix.append(total.weightText).append("\n");
        }
        prefix.append("END_TACS_PDF_TOTAL\n");
        prefix.append(safeText);
        return prefix.toString();
    }

    private PackingListTotal parsePackingListTotal(String text) {
        if (isBlankText(text)) return null;

        List<PackingToken> packages = collectPackingTokens(PACKING_PACKAGE_PATTERN, text);
        List<PackingToken> weights = collectPackingTokens(PACKING_WEIGHT_PATTERN, text);
        if (packages.isEmpty() && weights.isEmpty()) return null;

        boolean hasTotalText = PACKING_TOTAL_PATTERN.matcher(text).find();
        boolean lastPackageLooksTotal = looksLikeLastTokenIsTotal(packages);
        boolean lastWeightLooksTotal = looksLikeLastTokenIsTotal(weights);

        PackingListTotal total = new PackingListTotal();
        total.goodsText = parsePackingGoodsSummary(text);
        if (!packages.isEmpty()) {
            PackingToken quantityToken;
            if (hasTotalText || lastPackageLooksTotal) {
                quantityToken = packages.get(packages.size() - 1);
            } else {
                quantityToken = new PackingToken(sumTokens(packages), packages.get(0).unit);
            }
            total.quantityText = formatDecimal(quantityToken.number) + " " + quantityToken.unit.toUpperCase();
        }

        if (!weights.isEmpty()) {
            PackingToken weightToken;
            if (hasTotalText || lastWeightLooksTotal) {
                weightToken = weights.get(weights.size() - 1);
            } else {
                weightToken = new PackingToken(sumTokens(weights), weights.get(0).unit);
            }
            total.weightText = formatDecimal(weightToken.number) + " " + normalizeWeightUnit(weightToken.unit);
        }

        return total;
    }

    private String parsePackingGoodsSummary(String text) {
        if (isBlankText(text)) return "";

        String[] rawLines = text.split("\\R+");
        List<String> lines = new ArrayList<>();
        for (String rawLine : rawLines) {
            String line = rawLine == null ? "" : rawLine.replaceAll("\\s+", " ").trim();
            if (!line.isEmpty()) lines.add(line);
        }
        if (lines.isEmpty()) return "";

        int totalLineIndex = lines.size();
        for (int i = 0; i < lines.size(); i++) {
            if ("TOTAL".equalsIgnoreCase(lines.get(i).trim())) {
                totalLineIndex = i;
                break;
            }
        }

        List<Integer> packageIndexes = new ArrayList<>();
        List<Integer> weightIndexes = new ArrayList<>();
        for (int i = 0; i < totalLineIndex; i++) {
            String line = lines.get(i);
            if (PACKING_PACKAGE_PATTERN.matcher(line).find()) packageIndexes.add(i);
            if (PACKING_WEIGHT_PATTERN.matcher(line).find()) weightIndexes.add(i);
        }
        if (packageIndexes.isEmpty() || weightIndexes.isEmpty()) return "";

        List<String> goods = new ArrayList<>();

        int lastPackageIndex = packageIndexes.get(packageIndexes.size() - 1);
        int firstWeightAfterPackage = -1;
        for (Integer weightIndex : weightIndexes) {
            if (weightIndex > lastPackageIndex) {
                firstWeightAfterPackage = weightIndex;
                break;
            }
        }
        if (firstWeightAfterPackage > lastPackageIndex) {
            for (int i = lastPackageIndex + 1; i < firstWeightAfterPackage; i++) {
                addPackingGoodsCandidate(goods, lines.get(i));
            }
        }

        int goodsHeaderIndex = -1;
        for (int i = 0; i < totalLineIndex; i++) {
            if (lines.get(i).toUpperCase().contains("GOODS")) {
                goodsHeaderIndex = i;
                break;
            }
        }
        if (goodsHeaderIndex >= 0) {
            for (int i = goodsHeaderIndex + 1; i < totalLineIndex; i++) {
                addPackingGoodsCandidate(goods, lines.get(i));
            }
        }

        for (Integer packageIndex : packageIndexes) {
            for (int i = packageIndex + 1; i < totalLineIndex; i++) {
                String line = lines.get(i);
                if (PACKING_PACKAGE_PATTERN.matcher(line).find() || PACKING_WEIGHT_PATTERN.matcher(line).find()) break;
                addPackingGoodsCandidate(goods, line);
            }
        }

        if (goods.isEmpty()) return "";
        // 품목 전체 이름을 콤마로 나열 (적하목록 DB 값과 동일 형식 → 대조 '일치')
        return String.join(", ", goods);
    }

    private void addPackingGoodsCandidate(List<String> goods, String value) {
        String candidate = value == null ? "" : value.replaceAll("\\s+", " ").trim();
        if (!isLikelyPackingGoodsName(candidate)) return;
        for (String exists : goods) {
            if (exists.equalsIgnoreCase(candidate)) return;
        }
        goods.add(candidate);
    }

    private boolean isLikelyPackingGoodsName(String value) {
        if (isBlankText(value)) return false;
        String upper = value.trim().toUpperCase();
        if (!upper.matches(".*[A-Z].*")) return false;
        if (upper.matches("^\\d+\\).*")) return false;
        if (PACKING_PACKAGE_PATTERN.matcher(upper).find()) return false;
        if (PACKING_WEIGHT_PATTERN.matcher(upper).find()) return false;
        if (upper.matches(".*\\d{1,2}[./-]\\d{1,2}.*")) return false;
        if (upper.contains("PACKING LIST") || upper.contains("GOODS DESCRIPTION") || upper.contains("QUANTITY")) return false;
        if (upper.contains("DESCRIPTION") || upper.contains("NET WEIGHT") || upper.contains("NO. & KIND")) return false;
        if (upper.contains("GROSS") || upper.equals("WEIGHT") || upper.contains("GROSS WEIGHT")) return false;
        if (upper.contains("MEASUREMENT") || upper.contains("SHIPPING MARK")) return false;
        if (upper.matches("^(OF PACKAGES|DESCRIPTION|OR NET WEIGHT|WEIGHT|MEASURE-?|MENT)$")) return false;
        if (upper.contains("TOTAL") || upper.contains("SIGNED") || upper.contains("COUNTRY OF ORIGIN")) return false;
        if (upper.contains("SHIPPER") || upper.contains("SELLER") || upper.contains("CONSIGNEE") || upper.contains("BUYER")) return false;
        if (upper.contains("BANGKOK") || upper.contains("BUSAN") || upper.contains("THAILAND") || upper.contains("KOREA")) return false;
        if (upper.contains("C/NO") || upper.contains("MADE IN") || upper.contains("HANSOL AGRI")) return false;
        if (upper.contains("TEL:") || upper.contains("INVOICE") || upper.contains("HS CODE") || upper.contains("T/T")) return false;
        return true;
    }

    private List<PackingToken> collectPackingTokens(Pattern pattern, String text) {
        List<PackingToken> tokens = new ArrayList<>();
        Matcher matcher = pattern.matcher(text == null ? "" : text);
        while (matcher.find()) {
            BigDecimal number = parseDecimal(matcher.group(1));
            String unit = matcher.group(2) == null ? "" : matcher.group(2).trim();
            if (number != null && !unit.isBlank()) {
                tokens.add(new PackingToken(number, unit));
            }
        }
        return tokens;
    }

    private boolean looksLikeLastTokenIsTotal(List<PackingToken> tokens) {
        if (tokens == null || tokens.size() < 2) return false;
        BigDecimal beforeLastSum = BigDecimal.ZERO;
        for (int i = 0; i < tokens.size() - 1; i++) {
            beforeLastSum = beforeLastSum.add(tokens.get(i).number);
        }
        return beforeLastSum.compareTo(tokens.get(tokens.size() - 1).number) == 0;
    }

    private BigDecimal sumTokens(List<PackingToken> tokens) {
        BigDecimal sum = BigDecimal.ZERO;
        if (tokens == null) return sum;
        for (PackingToken token : tokens) {
            if (token != null && token.number != null) {
                sum = sum.add(token.number);
            }
        }
        return sum;
    }

    private BigDecimal parseDecimal(String value) {
        if (value == null) return null;
        String normalized = value.trim().replace(",", ".");
        if (normalized.isBlank()) return null;
        try {
            return new BigDecimal(normalized);
        } catch (Exception e) {
            return null;
        }
    }

    private String formatDecimal(BigDecimal value) {
        if (value == null) return "";
        return value.stripTrailingZeros().toPlainString();
    }

    private String normalizeWeightUnit(String unit) {
        String normalized = unit == null ? "" : unit.trim().toUpperCase();
        if ("KGS".equals(normalized) || normalized.startsWith("KILOGRAM")) return "KG";
        return normalized;
    }

    private boolean isBlankText(String value) {
        return value == null || value.trim().isEmpty();
    }

    private static class PackingToken {
        private final BigDecimal number;
        private final String unit;

        private PackingToken(BigDecimal number, String unit) {
            this.number = number;
            this.unit = unit == null ? "" : unit.trim();
        }
    }

    private static class PackingListTotal {
        private String goodsText;
        private String quantityText;
        private String weightText;
    }

