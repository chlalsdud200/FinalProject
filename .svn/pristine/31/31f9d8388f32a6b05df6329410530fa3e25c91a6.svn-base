    private static final Pattern PACKING_PACKAGE_PATTERN = Pattern.compile(
            "(?i)(\\d+(?:[.,]\\d+)?)\\s*(BAGS?|PCS|PIECES|CTNS?|CARTONS?|BOX(?:ES)?|PKGS?|PACKAGES?)\\b"
    );
    private static final Pattern PACKING_WEIGHT_PATTERN = Pattern.compile(
            "(?i)(\\d+(?:[.,]\\d+)?)\\s*(KG|KGS|KILOGRAMS?|TONS?|T)\\b"
    );
    private static final Pattern PACKING_TOTAL_PATTERN = Pattern.compile("(?i)\\bTOTAL\\b");

    @GetMapping("/import.do")
    public String retriveImportPage(Model model) {
        List<TransportRequestVO> importRequestList = importTransportService.retriveImpTransportReqList();
        List<TransportRequestVO> importArrivalTrackingList = importTransportService.retriveImpArrivalTrackingList();
        List<TransportRequestVO> importUnloadingInList = importTransportService.retriveImpUnloadingInList();
        List<TransportRequestVO> importDoList = importTransportService.retriveImpDoList();
        List<TransportRequestVO> importReleaseReqList = importTransportService.retriveImpReleaseReqList();
        List<TransportRequestVO> importInlandDispatchList = importTransportService.retriveImpInlandDispatchList();
        List<TransportRequestVO> importInlandCarList = importTransportService.retriveImpAvailableCarList();

        model.addAttribute("importRequestList", importRequestList);
        model.addAttribute("importRequestJson", toJson(importRequestList));

        model.addAttribute("importArrivalTrackingList", importArrivalTrackingList);
        model.addAttribute("importArrivalTrackingJson", toJson(importArrivalTrackingList));

        model.addAttribute("importUnloadingInList", importUnloadingInList);
        model.addAttribute("importUnloadingInJson", toJson(importUnloadingInList));

        model.addAttribute("importDoList", importDoList);
        model.addAttribute("importDoJson", toJson(importDoList));

        model.addAttribute("importReleaseList", importReleaseReqList);
        model.addAttribute("importReleaseJson", toJson(importReleaseReqList));

        model.addAttribute("importInlandDispatchList", importInlandDispatchList);
        model.addAttribute("importInlandDispatchJson", toJson(importInlandDispatchList));
        model.addAttribute("importInlandCarList", importInlandCarList);
        model.addAttribute("importInlandCarJson", toJson(importInlandCarList));

        return "transport/pages/import";
    }

