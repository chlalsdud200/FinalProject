    // 수입 보세구역 반출요청 처리
    @PostMapping({"/import/release-request/request.do", "/import/release/request.do", "/import/release-request/request", "/import/release/request"})
    @ResponseBody
    public Map<String, Object> registImpReleaseReq(@RequestParam String trcNo,
                                                   @RequestParam(required = false) String wmId,
                                                   @RequestParam(required = false) String wzNo,
                                                   @RequestParam(required = false) String releaseReqDt,
                                                   @RequestParam(required = false) String releaseDt,
                                                   @RequestParam(required = false) String itemNm,
                                                   @RequestParam(required = false) String remark,
                                                   @RequestParam(required = false) String goodsJson) {
        List<TransportRequestVO> goodsList = parseTransportGoodsList(goodsJson);
        boolean success = importTransportService.registImpReleaseReq(
                trcNo,
                wmId,
                wzNo,
                releaseReqDt,
                releaseDt,
                itemNm,
                remark,
                goodsList
        );

        return Map.of(
                "success", success,
                "message", success ? "반출요청이 완료되었습니다." : "반출요청 대상이 없습니다."
        );
    }



    @PostMapping({"/import/release-request/supplement.do", "/import/release-request/supplement"})
    @ResponseBody
    public Map<String, Object> registImpReleaseSupplement(
            @RequestParam(required = false) String releaseReqNo,
            @RequestParam(required = false) String trcNo,
            @RequestParam(required = false) String receiverId,
            @RequestParam(required = false) String wmId,
            @RequestParam(required = false) String wzNo,
            @RequestParam(required = false) String releaseReqDt,
            @RequestParam(required = false) String releaseDt,
            @RequestParam(required = false) String itemNm,
            @RequestParam(required = false) String remark,
            @RequestParam(required = false) String goodsJson,
            @RequestParam(required = false) String suppTypeCd,
            @RequestParam(required = false) String suppReqCn,
            Authentication authentication
    ) {
        List<TransportRequestVO> goodsList = parseTransportGoodsList(goodsJson);
        boolean success = importTransportService.modifyImpReleaseSupplement(
                releaseReqNo,
                trcNo,
                receiverId,
                wmId,
                wzNo,
                releaseReqDt,
                releaseDt,
                itemNm,
                remark,
                goodsList,
                suppTypeCd,
                suppReqCn,
                resolveActorId(authentication, receiverId)
        );
        return Map.of(
                "success", success,
                "message", success ? "보세구역 반출요청 보완요청이 등록되었습니다." : "보완요청 등록 대상이 없습니다."
        );
    }

