    @PostMapping({"/import/unloading-in/supplement.do", "/import/unloading-in/supplement"})
    @ResponseBody
    public Map<String, Object> modifyImpUnloadingInSupplement(
            @RequestParam String wirNo,
            @RequestParam(required = false) String receiverId,
            @RequestParam(required = false) String wmId,
            @RequestParam(required = false) String wzNo,
            @RequestParam(required = false) String inPlanDt,
            @RequestParam(required = false) String cargoMgmtNo,
            @RequestParam(required = false) String invoiceNo,
            @RequestParam(required = false) String incoTermsCd,
            @RequestParam(required = false) String remark,
            @RequestParam(required = false) String goodsJson,
            Authentication authentication
    ) {
        List<TransportRequestVO> goodsList = parseTransportGoodsList(goodsJson);
        boolean success = importTransportService.modifyImpUnloadingInSupplement(
                wirNo,
                receiverId,
                wmId,
                wzNo,
                inPlanDt,
                cargoMgmtNo,
                invoiceNo,
                incoTermsCd,
                remark,
                goodsList,
                resolveActorId(authentication, receiverId)

        );
        return Map.of(
                "success", success,
                "message", success ? "보세구역 입고신청 보완제출이 완료되었습니다." : "보완제출 대상이 없습니다."
        );
    }

    private List<TransportRequestVO> parseTransportGoodsList(String goodsJson) {
        if (goodsJson == null || goodsJson.isBlank()) {
            return List.of();
        }
        try {
            return objectMapper.copy()
                    .configure(DeserializationFeature.FAIL_ON_UNKNOWN_PROPERTIES, false)
                    .readValue(goodsJson, new TypeReference<List<TransportRequestVO>>() {});
        } catch (JsonProcessingException e) {
            /*
             * 화면 품목 JSON에 VO에 없는 보조 필드가 섞이면 Jackson이 전체 품목을 버릴 수 있다.
             * 그 경우에도 화면에서 입력한 품목명/단가/수량/총금액/중량/원산지는 DB에 저장되어야 하므로
             * Map으로 한 번 더 읽어서 VO에 필요한 필드만 직접 옮긴다.
             */
            try {
                List<Map<String, Object>> rawList = objectMapper.readValue(goodsJson, new TypeReference<List<Map<String, Object>>>() {});
                List<TransportRequestVO> goodsList = new ArrayList<>();
                for (Map<String, Object> raw : rawList) {
                    if (raw == null) {
                        continue;
                    }
                    TransportRequestVO goods = new TransportRequestVO();
                    goods.setCgNo(toInteger(raw.get("cgNo")));
                    goods.setGoodsNo(toInteger(raw.get("goodsNo")));
                    goods.setGoodsName(toStringValue(raw.get("goodsName")));
                    goods.setItemNm(toStringValue(raw.get("itemNm")));
                    String hsCode = toStringValue(raw.get("hsCode"));
                    if (hsCode == null) {
                        hsCode = toStringValue(raw.get("goodsHsCode"));
                    }
                    goods.setHsCode(hsCode);
                    goods.setGoodsHsCode(hsCode);
                    goods.setPrice(toBigDecimal(raw.get("price")));
                    goods.setQty(toBigDecimal(raw.get("qty")));
                    goods.setGoodsTotalPrice(toBigDecimal(raw.get("goodsTotalPrice")));
                    goods.setWeight(toBigDecimal(raw.get("weight")));
                    goods.setOrigin(toStringValue(raw.get("origin")));
                    goodsList.add(goods);
                }
                return goodsList;
            } catch (Exception ignored) {
                return List.of();
            }
        }
    }

    private Integer toInteger(Object value) {
        if (value == null) {
            return null;
        }
        String text = String.valueOf(value).replace(",", "").trim();
        if (text.isBlank() || "null".equalsIgnoreCase(text)) {
            return null;
        }
        try {
            return (int) Math.round(Double.parseDouble(text));
        } catch (NumberFormatException e) {
            return null;
        }
    }

    private BigDecimal toBigDecimal(Object value) {
        if (value == null) {
            return null;
        }
        String text = String.valueOf(value).replace(",", "").trim();
        if (text.isBlank() || "null".equalsIgnoreCase(text)) {
            return null;
        }
        try {
            return new BigDecimal(text);
        } catch (NumberFormatException e) {
            return null;
        }
    }

    private Long toLong(Object value) {
        if (value == null) {
            return null;
        }
        String text = String.valueOf(value).replace(",", "").trim();
        if (text.isBlank() || "null".equalsIgnoreCase(text) || "-".equals(text)) {
            return null;
        }
        try {
            return Long.parseLong(text);
        } catch (NumberFormatException e) {
            return null;
        }
    }

    private String toStringValue(Object value) {
        if (value == null) {
            return null;
        }
        String text = String.valueOf(value).trim();
        return text.isBlank() || "-".equals(text) || "null".equalsIgnoreCase(text) ? null : text;
    }

    @PostMapping({"/import/unloading-in/deliver.do", "/import/unloading-in/request.do", "/import/unloading-in/deliver", "/import/unloading-in/request"})
    @ResponseBody
    public Map<String, Object> modifyImpUnloadingInDelivered(@RequestParam String trcNo,
                                                             @RequestParam(required = false) String wirNo,
                                                             @RequestParam String wmId,
                                                             @RequestParam(required = false) String wzNo,
                                                             @RequestParam(required = false) String inPlanDt,
                                                             @RequestParam(required = false) String cargoMgmtNo,
                                                             @RequestParam(required = false) String invoiceNo,
                                                             @RequestParam(required = false) String incoTermsCd,
                                                             @RequestParam(required = false) String remark,
                                                             @RequestParam(required = false) String goodsJson) {
        return doModifyImpUnloadingInDelivered(trcNo, wirNo, wmId, wzNo, inPlanDt, cargoMgmtNo, invoiceNo, incoTermsCd, remark, goodsJson);
    }

    /**
     * 과거 JS/캐시가 호출하던 입고요청 URL 호환용 엔드포인트.
     * 실제 처리는 /import/unloading-in/deliver.do 와 동일하게 수행한다.
     */
    @RequestMapping(value = {"/import/inbound/request.do", "/import/inbound/request"},
            method = {RequestMethod.GET, RequestMethod.POST})
    @ResponseBody
    public Map<String, Object> modifyImpInboundRequestLegacy(@RequestParam Map<String, String> params) {
        String trcNo = firstNonBlank(params, "trcNo", "requestNo", "trcNoValue");
        String wirNo = firstNonBlank(params, "wirNo", "inboundRequestNo", "WIR_NO");
        String wmId = firstNonBlank(params, "wmId", "warehouseManagerId", "bondedManagerId", "wirWmId", "WM_ID");
        String wzNo = firstNonBlank(params, "wzNo", "warehouseZoneNo", "bondedZoneNo", "wirWzNo", "WZ_NO");

        if (trcNo == null || trcNo.isBlank()) {
            return Map.of("success", false, "message", "운송의뢰번호를 찾을 수 없습니다.");
        }
        if (wmId == null || wmId.isBlank()) {
            return Map.of("success", false, "message", "창고담당자를 선택해주세요.");
        }

        return doModifyImpUnloadingInDelivered(
                trcNo,
                wirNo,
                wmId,
                wzNo,
                firstNonBlank(params, "inPlanDt", "inboundPlanDt", "wirInPlanDt"),
                firstNonBlank(params, "cargoMgmtNo", "cargoManagementNo", "wirCargoMgmtNo"),
                firstNonBlank(params, "invoiceNo", "wirInvoiceNo"),
                firstNonBlank(params, "incoTermsCd", "incoterms", "incoTerms"),
                firstNonBlank(params, "remark", "memo", "wirRmrk"),
                firstNonBlank(params, "goodsJson", "goodsListJson")
        );
    }

    private Map<String, Object> doModifyImpUnloadingInDelivered(String trcNo,
                                                               String wirNo,
                                                               String wmId,
                                                               String wzNo,
                                                               String inPlanDt,
                                                               String cargoMgmtNo,
                                                               String invoiceNo,
                                                               String incoTermsCd,
                                                               String remark,
                                                               String goodsJson) {
        List<TransportRequestVO> goodsList = parseTransportGoodsList(goodsJson);
        String resolvedCargoMgmtNo = resolveImpCargoMgmtNo(trcNo, cargoMgmtNo);
        String validationMessage = validateImpUnloadingInRequest(
                trcNo,
                wmId,
                wzNo,
                inPlanDt,
                resolvedCargoMgmtNo,
                invoiceNo,
                incoTermsCd,
                goodsList
        );
        if (validationMessage != null) {
            return Map.of("success", false, "message", validationMessage);
        }

        String savedWirNo = importTransportService.modifyImpUnloadingInDelivered(
                cleanRequestValue(trcNo),
                cleanRequestValue(wirNo),
                cleanRequestValue(wmId),
                cleanRequestValue(wzNo),
                cleanRequestValue(inPlanDt),
                resolvedCargoMgmtNo,
                cleanRequestValue(invoiceNo),
                cleanRequestValue(incoTermsCd),
                cleanRequestValue(remark),
                goodsList
        );
        if (savedWirNo == null || savedWirNo.isBlank()) {
            return Map.of("success", false);
        }
        return Map.of(
                "success", true,
                "wirNo", savedWirNo,
                "cargoMgmtNo", resolvedCargoMgmtNo,
                "wirCargoMgmtNo", resolvedCargoMgmtNo
        );
    }

    private String resolveImpCargoMgmtNo(String trcNo, String cargoMgmtNo) {
        String value = cleanRequestValue(cargoMgmtNo);
        if (value != null) {
            return value;
        }
        String reqNo = cleanRequestValue(trcNo);
        if (reqNo == null) {
            return null;
        }
        return "CARGO-" + reqNo;
    }

    private String validateImpUnloadingInRequest(String trcNo,
                                                 String wmId,
                                                 String wzNo,
                                                 String inPlanDt,
                                                 String cargoMgmtNo,
                                                 String invoiceNo,
                                                 String incoTermsCd,
                                                 List<TransportRequestVO> goodsList) {
        if (isBlankRequestValue(trcNo)) {
            return "운송의뢰번호를 찾을 수 없습니다.";
        }
        if (isBlankRequestValue(wmId)) {
            return "창고담당자를 선택하세요.";
        }
        if (isBlankRequestValue(wzNo)) {
            return "보세구역을 선택하세요.";
        }
        if (isBlankRequestValue(inPlanDt)) {
            return "입고요청일을 입력하세요.";
        }
        if (isBlankRequestValue(cargoMgmtNo)) {
            return "화물관리번호를 입력하세요.";
        }
        if (isBlankRequestValue(invoiceNo)) {
            return "송장번호를 입력하세요.";
        }
        if (isBlankRequestValue(incoTermsCd)) {
            return "인코텀즈를 입력하세요.";
        }
        if (goodsList == null || goodsList.isEmpty()) {
            return "품목 정보를 입력하세요.";
        }
        for (TransportRequestVO goods : goodsList) {
            if (goods == null) {
                return "품목 정보를 입력하세요.";
            }
            if (isBlankRequestValue(goods.getGoodsName()) && isBlankRequestValue(goods.getItemNm())) {
                return "품목명을 입력하세요.";
            }
            if (isBlankRequestValue(goods.getGoodsHsCode()) && isBlankRequestValue(goods.getHsCode())) {
                return "HS코드를 입력하세요.";
            }
            if (!isPositive(goods.getPrice())) {
                return "단가를 입력하세요.";
            }
            if (!isPositive(goods.getQty())) {
                return "수량을 입력하세요.";
            }
            if (!isPositive(goods.getGoodsTotalPrice())) {
                return "총금액을 입력하세요.";
            }
            if (!isPositive(goods.getWeight())) {
                return "중량을 입력하세요.";
            }
            if (isBlankRequestValue(goods.getOrigin())) {
                return "원산지를 입력하세요.";
            }
        }
        return null;
    }

    private boolean isPositive(BigDecimal value) {
        return value != null && value.compareTo(BigDecimal.ZERO) > 0;
    }

    private boolean isBlankRequestValue(String value) {
        return cleanRequestValue(value) == null;
    }

    private String cleanRequestValue(String value) {
        if (value == null) {
            return null;
        }
        String text = value.trim();
        return text.isBlank() || "-".equals(text) || "null".equalsIgnoreCase(text) ? null : text;
    }

    private String firstNonBlank(Map<String, String> params, String... keys) {
        if (params == null || keys == null) {
            return null;
        }
        for (String key : keys) {
            String value = params.get(key);
            if (value != null && !value.trim().isBlank() && !"null".equalsIgnoreCase(value.trim())) {
                return value.trim();
            }
        }
        return null;
    }

