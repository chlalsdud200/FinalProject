    @PostMapping("/import/request/detail/save.do")
    @ResponseBody
    public Map<String, Object> modifyImpTransportReqDetail(
            @RequestParam String trcNo,
            @RequestParam(required = false) String buyerNm,
            @RequestParam(required = false) String buyerCountryCd,
            @RequestParam(required = false) String transportMeanCd,
            @RequestParam(required = false) String transportTypeCd,
            @RequestParam(required = false) String incoTermsCd,
            @RequestParam(required = false) String deptPortCd,
            @RequestParam(required = false) String arvlPortCd,
            @RequestParam(required = false) String itemCategory,
            @RequestParam(required = false) String goodsName,
            @RequestParam(required = false) String qty,
            @RequestParam(required = false) String weight,
            @RequestParam(required = false) String mblNo,
            @RequestParam(required = false) String requestCn
    ) {
        try {
            boolean success = importTransportService.modifyImpTransportReqDetail(
                    trcNo,
                    buyerNm,
                    buyerCountryCd,
                    transportMeanCd,
                    transportTypeCd,
                    incoTermsCd,
                    deptPortCd,
                    arvlPortCd,
                    itemCategory,
                    cleanRequestValue(goodsName),
                    toBigDecimal(qty),
                    toBigDecimal(weight),
                    mblNo,
                    cleanRequestValue(requestCn)
            );
            return Map.of("success", success, "message", success ? "운송의뢰 상세정보가 저장되었습니다." : "저장 대상 운송의뢰가 없습니다.");
        } catch (RuntimeException e) {
            return Map.of("success", false, "message", "운송의뢰 상세정보 저장 중 오류가 발생했습니다: " + e.getMessage());
        }
    }

    private String toJson(Object value) {
        try {
            return objectMapper.writeValueAsString(value);
        } catch (JsonProcessingException e) {
            return "[]";
        }
    }

    @PostMapping({
            "/import/arrival-notice/send.do",
            "/import/arrival-tracking/notice/send.do",
            "/import/arrival/send.do"
    })
    @ResponseBody
    public Map<String, Object> modifyImpArrivalNoticeSent(
            @RequestParam(required = false) String reqNo,
            @RequestParam(required = false) String trcNo
    ) {
        // 화면의 도착통지서 번호가 '-' 이거나 IAN_NO/IAN_IR_NO가 섞일 수 있어서
        // 발송 기준은 운송의뢰번호(TRC_NO)를 우선 사용한다.
        String targetNo = (trcNo != null && !trcNo.isBlank()) ? trcNo : reqNo;
        if (targetNo == null || targetNo.isBlank() || "-".equals(targetNo.trim())) {
            return Map.of("success", false, "message", "도착통지 발송 대상 번호가 없습니다.");
        }
        try {
            String noticeNo = importTransportService.modifyImpArrivalNoticeSent(targetNo);
            boolean success = noticeNo != null && !noticeNo.isBlank();
            return Map.of(
                    "success", success,
                    "message", success ? "도착통지서가 발송되었습니다." : "도착통지 발송 대상이 없습니다.",
                    "noticeNo", success ? noticeNo : ""
            );
        } catch (Exception e) {
            return Map.of(
                    "success", false,
                    "message", "도착통지 발송 처리 중 오류: " + e.getMessage()
            );
        }
    }

