    @PostMapping({"/import/do/settle.do", "/import/do/settle"})
    @ResponseBody
    public Map<String, Object> modifyImpDoSettlementPaid(
            @RequestParam String trcNo,
            @RequestParam(required = false, defaultValue = "0") Integer freightAmt,
            @RequestParam(required = false, defaultValue = "0") Integer warehouseAmt,
            @RequestParam(required = false, defaultValue = "0") Integer totalBillAmt,
            @RequestParam(required = false) String settlementExpln,
            @RequestParam(required = false) String settlementMemo,
            @RequestParam(required = false) String tcsStlExpln
    ) {
        String expln = settlementExpln;
        if (expln == null || expln.isBlank()) expln = settlementMemo;
        if (expln == null || expln.isBlank()) expln = tcsStlExpln;
        if ((freightAmt == null || freightAmt <= 0)
                && (warehouseAmt == null || warehouseAmt <= 0)
                && (expln == null || expln.isBlank())) {
            return Map.of("success", false, "message", "운임비, 창고비 또는 정산 설명 중 하나 이상을 입력하세요.");
        }
        boolean success = importTransportService.modifyImpDoSettlementPaid(trcNo, freightAmt, warehouseAmt, totalBillAmt, expln);
        return Map.of("success", success, "message", success ? "정산요청을 화주에게 보냈습니다." : "정산요청 대상이 없습니다.");
    }


    @PostMapping({"/import/do/upload-files.do", "/import/do/upload-files"})
    @ResponseBody
    public Map<String, Object> modifyImpDoFilesUploaded(
            @RequestParam String trcNo,
            @RequestParam(required = false) List<MultipartFile> docFiles,
            @RequestParam(required = false) MultipartFile doPdfFile,
            @RequestParam(required = false) MultipartFile importDeclarationCertFile,
            Authentication authentication
    ) {
        try {
            boolean success = importTransportService.modifyImpDoFilesUploaded(
                    trcNo,
                    resolveActorId(authentication, trcNo),
                    mergeDoDocFiles(docFiles, doPdfFile, importDeclarationCertFile)
            );
            return Map.of(
                    "success", success,
                    "message", success ? "D/O 첨부문서가 업로드되었습니다." : "업로드할 첨부문서가 없거나 업로드 대상이 없습니다."
            );
        } catch (IllegalArgumentException | IllegalStateException e) {
            return Map.of("success", false, "message", e.getMessage());
        }
    }

