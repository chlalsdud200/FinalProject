    @GetMapping("/import/request/common-option/list.do")
    @ResponseBody
    public List<Map<String, Object>> retriveImportCommonOptionList(@RequestParam String type) {
        String optionType = type == null ? "" : type.trim().toUpperCase();
        return switch (optionType) {
            case "TRANSPORT_MEAN", "TRANSPORT_MEAN_CD", "TRANSPORT_MEAN_CD_LIST" -> List.of(
                    Map.of("value", "SEA", "label", "SEA / 해상 / Sea", "code", "SEA", "name", "해상"),
                    Map.of("value", "AIR", "label", "AIR / 항공 / Air", "code", "AIR", "name", "항공")
            );
            case "TRANSPORT_TYPE", "TRANSPORT_TYPE_CD", "TRANSPORT_TYPE_CD_LIST" -> List.of(
                    Map.of("value", "LCL", "label", "LCL / Less than Container Load", "code", "LCL", "name", "Less than Container Load"),
                    Map.of("value", "FCL", "label", "FCL / Full Container Load", "code", "FCL", "name", "Full Container Load")
            );
            case "INCO_TERMS", "INCO_TERMS_CD", "INCOTERMS" -> List.of(
                    Map.of("value", "FOB", "label", "FOB / Free On Board", "code", "FOB", "name", "Free On Board"),
                    Map.of("value", "CIF", "label", "CIF / Cost Insurance and Freight", "code", "CIF", "name", "Cost Insurance and Freight")
            );
            case "ITEM_CATEGORY", "ITEM_CTGRY", "CARGO_ITEM_CATEGORY" -> List.of(
                    Map.of("value", "전자기기", "label", "전자기기 / Electronics", "code", "ELECTRONICS", "name", "전자기기"),
                    Map.of("value", "식품", "label", "식품 / Food", "code", "FOOD", "name", "식품")
            );
            default -> List.of();
        };
    }

