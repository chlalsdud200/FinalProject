    @PostMapping({"/import/do/issue.do", "/import/do/issue"})
    @ResponseBody
    public Map<String, Object> modifyImpDoIssued(
            @RequestParam String trcNo,
            @RequestParam(value = "doNo", required = false, defaultValue = "") String inputDoNo,
            @RequestParam(required = false) String hblNo,
            @RequestParam String receiveDt,
            @RequestParam(required = false) String validDt,
            @RequestParam(required = false) List<MultipartFile> docFiles,
            @RequestParam(required = false) MultipartFile doPdfFile,
            @RequestParam(required = false) MultipartFile importDeclarationCertFile,
            Authentication authentication
    ) {
        String issuedDoNo;
        try {
            issuedDoNo = importTransportService.modifyImpDoIssued(
                    trcNo,
                    inputDoNo,
                    receiveDt,
                    resolveActorId(authentication, trcNo),
                    mergeDoDocFiles(docFiles, doPdfFile, importDeclarationCertFile)
            );
        } catch (IllegalArgumentException | IllegalStateException e) {
            return Map.of("success", false, "doNo", "", "message", e.getMessage());
        }
        boolean success = issuedDoNo != null && !issuedDoNo.isBlank();
        return Map.of(
                "success", success,
                "doNo", success ? issuedDoNo : "",
                "message", success ? "D/O가 발급되었습니다." : "D/O 발급 대상이 없습니다."
        );
    }

    private List<MultipartFile> mergeDoDocFiles(List<MultipartFile> docFiles,
                                                MultipartFile doPdfFile,
                                                MultipartFile importDeclarationCertFile) {
        List<MultipartFile> merged = new ArrayList<>();

        if (docFiles != null) {
            for (MultipartFile file : docFiles) {
                if (file != null && !file.isEmpty()) {
                    merged.add(file);
                }
            }
        }

        if (doPdfFile != null && !doPdfFile.isEmpty()) {
            merged.add(doPdfFile);
        }

        if (importDeclarationCertFile != null && !importDeclarationCertFile.isEmpty()) {
            merged.add(importDeclarationCertFile);
        }

        return merged;
    }

    private String resolveActorId(Authentication authentication, String fallbackId) {
        if (authentication != null && authentication.getName() != null && !authentication.getName().isBlank()) {
            return authentication.getName();
        }
        return fallbackId;
    }

    @PostMapping({"/import/do/deliver.do", "/import/do/deliver"})
    @ResponseBody
    public Map<String, Object> modifyImpDoDelivered(
            @RequestParam String trcNo,
            @RequestParam String deliveryDt,
            @RequestParam(required = false) String deliveryTargetNm,
            @RequestParam(required = false) String deliveryMethodCd
    ) {
        try {
            boolean success = importTransportService.modifyImpDoDelivered(trcNo, deliveryDt, deliveryTargetNm, deliveryMethodCd);
            return Map.of("success", success, "message", success ? "D/O가 전달되었습니다." : "D/O 전달 대상이 없습니다.");
        } catch (IllegalArgumentException | IllegalStateException e) {
            return Map.of("success", false, "message", e.getMessage());
        }
    }

