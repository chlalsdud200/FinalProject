/* ===== 상세 펼침 행 깨짐 방지 =====
   신고인 컬럼 제거 후 목록 컬럼은 11개이므로 JSP colspan도 11로 맞춰야 한다.
   상세 영역 안쪽 테이블은 목록 테이블의 fixed/nowrap 영향을 받지 않게 분리한다.
*/
.warehouseCargoTracking-page .warehouse-detail-row > td {
  padding: 0 !important;
  white-space: normal !important;
  background: #fff !important;
}

.warehouseCargoTracking-page .warehouse-detail-row:hover > td {
  background: #fff !important;
}

.warehouseCargoTracking-page .warehouse-detail-row .detail-content {
  width: 100% !important;
  padding: 18px !important;
  background: #fff !important;
  border-top: 1px solid #e2e8f0 !important;
}

.warehouseCargoTracking-page .warehouse-detail-row .info-card .data-table {
  table-layout: auto !important;
  width: 100% !important;
}

.warehouseCargoTracking-page .warehouse-detail-row .info-card .data-table td {
  white-space: normal !important;
  text-align: left !important;
  vertical-align: middle !important;
}

.warehouseCargoTracking-page .warehouse-detail-row .info-card .data-table td.td-bold {
  width: 110px !important;
  color: #0f2537 !important;
  font-weight: 800 !important;
  background: #f8fbff !important;
}
