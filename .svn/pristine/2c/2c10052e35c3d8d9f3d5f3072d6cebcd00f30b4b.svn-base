/* ── Layout ── */
.app { display: flex; min-height: 100vh; background: #f6f9ff; }

/* ── Main wrapper ── */
.main-wrap { flex: 1; display: flex; flex-direction: column; min-width: 0; }

/* ── Content area ── */
.content { flex: 1; padding: 32px; background: #f6f9ff; }
.page { display: none; }
.page.active { display: block; }

/* ── Two-column split ── */
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.two-col-wide { display: grid; grid-template-columns: 3fr 2fr; gap: 20px; }
