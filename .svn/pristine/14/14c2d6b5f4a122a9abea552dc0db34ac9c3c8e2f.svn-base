package kr.or.tacs.common.notification.service;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.Collections;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

import org.springframework.dao.DuplicateKeyException;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import kr.or.tacs.common.notification.mapper.INotificationMapper;
import kr.or.tacs.vo.common.notification.NotificationPolicyVO;
import kr.or.tacs.vo.common.notification.NotificationVO;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

@Service
@Transactional
@RequiredArgsConstructor
@Slf4j
public class NotificationServiceImpl implements INotificationService {

    private static final Pattern TEMPLATE_PATTERN = Pattern.compile("\\$\\{([a-zA-Z0-9_]+)\\}");

    private final INotificationMapper notificationMapper;

    @Override
    public void registNotification(String eventCd, String refKey, String senderId, Map<String, String> bindings) {
        NotificationPolicyVO policy = notificationMapper.selectNotificationPolicy(eventCd);
        if (policy == null || !"Y".equals(policy.getNpUseYn())) {
            return;
        }

        Map<String, String> ctx = new HashMap<>(bindings == null ? Collections.emptyMap() : bindings);
        ctx.put("refKey", refKey);
        ctx.putIfAbsent("irNo", extractIrNo(refKey));
        String irNo = ctx.get("irNo");

        List<NotificationTarget> receivers = resolveReceivers(policy.getNpReceiverUserType(), eventCd, irNo, refKey);
        if (receivers.isEmpty()) {
            return;
        }

        String title = renderTemplate(policy.getNpTitleTpl(), ctx);
        String body = renderTemplate(policy.getNpBodyTpl(), ctx);

        for (NotificationTarget receiver : receivers) {
            // 사용자가 마이페이지에서 해당 알림을 껐으면(N) 발송 스킵. 행이 없으면 기본 수신.
            if ("N".equals(notificationMapper.selectUserNotiUseYn(receiver.receiverId, eventCd))) {
                continue;
            }

            Map<String, String> receiverCtx = new HashMap<>(ctx);
            receiverCtx.putIfAbsent("linkUrl", resolveLinkUrl(receiver.receiverUserType, irNo, refKey));
            String linkUrl = renderTemplate(policy.getNpLinkTpl(), receiverCtx);

            NotificationVO vo = new NotificationVO();
            vo.setNotiEventCd(eventCd);
            vo.setNotiRefKey(refKey);
            vo.setNotiReceiverId(receiver.receiverId);
            vo.setNotiSenderId(senderId);
            vo.setNotiTitle(title);
            vo.setNotiBody(body);
            vo.setNotiLinkUrl(linkUrl);
            vo.setNotiSendStatus("SENT");

            try {
                notificationMapper.insertNotification(vo);
            } catch (DuplicateKeyException ignored) {
                // 동일 업무 상태 알림은 유니크 제약으로 1회만 남긴다.
            }
        }
    }

    private String renderTemplate(String template, Map<String, String> ctx) {
        if (template == null) {
            return "";
        }

        Matcher matcher = TEMPLATE_PATTERN.matcher(template);
        StringBuffer result = new StringBuffer();
        while (matcher.find()) {
            String value = ctx.getOrDefault(matcher.group(1), "");
            matcher.appendReplacement(result, Matcher.quoteReplacement(value));
        }
        matcher.appendTail(result);
        return result.toString();
    }

    private List<NotificationTarget> resolveReceivers(String receiverUserTypes, String eventCd, String irNo, String refKey) {
        List<NotificationTarget> receivers = new ArrayList<>();
        for (String receiverUserType : Arrays.asList(receiverUserTypes.split(","))) {
            String trimmedType = receiverUserType.trim();
            String receiverId = resolveReceiver(trimmedType, eventCd, irNo, refKey);
            if (receiverId != null && !receiverId.trim().isEmpty() && !containsReceiver(receivers, receiverId)) {
                receivers.add(new NotificationTarget(trimmedType, receiverId));
            }
        }
        return receivers;
    }

    private String resolveReceiver(String receiverUserType, String eventCd, String irNo, String refKey) {
        switch (receiverUserType) {
            case "OWNER":
                if (refKey != null && refKey.startsWith("WIR-")) {
                    return notificationMapper.selectOwnerIdByWirNo(refKey.substring(4));
                }
                if (refKey != null && refKey.startsWith("TRC-")) {
                    return notificationMapper.selectOwnerIdByTrcNo(refKey);
                }
                if (refKey != null && refKey.startsWith("EXP-")) {
                    return notificationMapper.selectOwnerIdByErNo(irNo);
                }
                return notificationMapper.selectOwnerIdByIrNo(irNo);
            case "BROKER":
                if (refKey != null && refKey.startsWith("EXP-")) {
                    return notificationMapper.selectBrokerIdByErNo(irNo);
                }
                return notificationMapper.selectBrokerIdByIrNo(irNo);
            case "OFFICER":
                String officerId = notificationMapper.selectOfficerIdByIrNo(irNo);
                if (officerId == null) {
                    log.debug("공무원 미배정 신고건 알림 스킵: eventCd={}, irNo={}", eventCd, irNo);
                }
                return officerId;
            case "FIELD_OFFICER":
                // 검역신청에 배정된 현장공무원(검역관). refKey = 검역신청번호(IIR_REQ_NO)
                String fieldOfficerId = notificationMapper.selectFieldOfficerIdByReqNo(refKey);
                if (fieldOfficerId == null) {
                    log.debug("검역관 미배정 검역신청 알림 스킵: eventCd={}, refKey={}", eventCd, refKey);
                }
                return fieldOfficerId;
            case "WAREHOUSE_MANAGER":
                String warehouseManagerId;
                if (refKey != null && refKey.startsWith("WIR-")) {
                    warehouseManagerId = notificationMapper.selectWarehouseManagerIdByWirNo(refKey.substring(4));
                } else if (refKey != null && refKey.startsWith("CRR-")) {
                    warehouseManagerId = notificationMapper.selectWarehouseManagerIdByCrrNo(refKey.substring(4));
                } else {
                    warehouseManagerId = notificationMapper.selectWarehouseManagerIdByIrNo(irNo);
                }
                if (warehouseManagerId == null) {
                    log.debug("창고관리자 미배정 알림 스킵: eventCd={}, refKey={}", eventCd, refKey);
                }
                return warehouseManagerId;
            case "TRANSPORT_MANAGER":
                String transportManagerId;
                if (refKey != null && refKey.startsWith("WIR-")) {
                    transportManagerId = notificationMapper.selectTransportManagerIdByWirNo(refKey.substring(4));
                } else if (refKey != null && refKey.startsWith("CRR-")) {
                    transportManagerId = notificationMapper.selectTransportManagerIdByCrrNo(refKey.substring(4));
                } else if (refKey != null && refKey.startsWith("TRC-")) {
                    transportManagerId = notificationMapper.selectTransportManagerIdByTrcNo(refKey);
                } else {
                    transportManagerId = notificationMapper.selectTransportManagerIdByIrNo(irNo);
                }
                if (transportManagerId == null) {
                    log.debug("운송담당자 미배정 알림 스킵: eventCd={}, refKey={}", eventCd, refKey);
                }
                return transportManagerId;
            default:
                throw new IllegalArgumentException("지원하지 않는 수신자 유형: " + receiverUserType);
        }
    }

    private boolean containsReceiver(List<NotificationTarget> receivers, String receiverId) {
        for (NotificationTarget receiver : receivers) {
            if (receiver.receiverId.equals(receiverId)) {
                return true;
            }
        }
        return false;
    }

    private String resolveLinkUrl(String receiverUserType, String irNo, String refKey) {
        switch (receiverUserType) {
            case "OWNER":
                if (refKey != null && refKey.startsWith("WIR-")) {
                    return "/owner/import/list.do";
                }
                return "/owner/import/detail.do/" + irNo;
            case "BROKER":
                return "/broker/status/detail.do?idIrNo=" + irNo;
            case "OFFICER":
                return "/officer/basicScreenDetail.do?reqNo=" + irNo + "&mode=edit";
            case "FIELD_OFFICER":
                return "/fieldofficer/inspectionRequest/detail.do?reqNo=" + refKey;
            case "WAREHOUSE_MANAGER":
                if (refKey != null && refKey.startsWith("WIR-")) {
                    return "/warehouse/inbound.do?wirNo=" + refKey.substring(4);
                }
                if (refKey != null && refKey.startsWith("CRR-")) {
                    return "/warehouse/outbound.do?crrNo=" + refKey.substring(4);
                }
                return "/warehouse/inventory.do";
            case "TRANSPORT_MANAGER":
                // 알림 클릭 시 해당 운송의뢰 상세(프로세스)뷰를 그 건+작업단계로 직접 연다.
                // ?page=는 딥링크 실패 시 폴백 탭, ?work=는 상세 내부 작업탭, ?trcNo=는 대상 건.
                if (refKey != null && refKey.startsWith("WIR-")) {
                    String trcNo = notificationMapper.selectTrcNoByWirNo(refKey.substring(4));
                    if (trcNo != null && !trcNo.isBlank()) {
                        return "/transport/import.do?page=TACS-FW-025&work=inbound&trcNo=" + trcNo;
                    }
                    return "/transport/import.do?page=TACS-FW-025&wirNo=" + refKey.substring(4); // 폴백: 입고관리 탭
                }
                if (refKey != null && refKey.startsWith("CRR-")) {
                    String trcNo = notificationMapper.selectTrcNoByCrrNo(refKey.substring(4));
                    if (trcNo != null && !trcNo.isBlank()) {
                        return "/transport/import.do?page=TACS-FW-033&work=release&trcNo=" + trcNo;
                    }
                    return "/transport/import.do?page=TACS-FW-033&crrNo=" + refKey.substring(4); // 폴백: 반출관리 탭
                }
                if (refKey != null && refKey.startsWith("TRC-")) {
                    return "/transport/import.do?page=TACS-FW-015&work=request&trcNo=" + refKey; // 운송의뢰 상세
                }
                return "/transport/import.do";
            default:
                return "";
        }
    }

    private String extractIrNo(String refKey) {
        if (refKey == null) {
            return null;
        }
        if (refKey.startsWith("IMP-") || refKey.startsWith("EXP-")) {
            return countHyphen(refKey) >= 3 ? refKey.substring(0, refKey.lastIndexOf('-')) : refKey;
        }
        int separatorIndex = refKey.indexOf('-');
        return separatorIndex > 0 ? refKey.substring(0, separatorIndex) : refKey;
    }

    private int countHyphen(String value) {
        int count = 0;
        for (int i = 0; i < value.length(); i++) {
            if (value.charAt(i) == '-') {
                count++;
            }
        }
        return count;
    }

    private static class NotificationTarget {
        private final String receiverUserType;
        private final String receiverId;

        private NotificationTarget(String receiverUserType, String receiverId) {
            this.receiverUserType = receiverUserType;
            this.receiverId = receiverId;
        }
    }
}
