<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%
    request.setAttribute("activeMenu", "transport");
    request.setAttribute("activeGroup", "transport");
    request.setAttribute("activeSub", "forwarder");
%>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="ctx-path" content="${pageContext.request.contextPath}">
    <title>TACS 운송 계약 요청</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
          rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
          rel="stylesheet">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/owner.css">
</head>
<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/owner/sidebar.jsp" %>

    <div class="main-wrap">
        <%@ include file="/WEB-INF/views/common/header.jsp" %>

        <main class="content">
            <div class="page active" id="pg-transport">
                <div class="page-title-row">
                    <h2>운송 계약 요청</h2>
                </div>

                <%@ include file="/WEB-INF/views/owner/transport/fragments/transportTabs.jsp" %>

                <div id="trans-fwd-contract-view" class="contract-panel">
                    <form id="transportContractForm"
                          class="contract-form"
                          action="${pageContext.request.contextPath}/owner/transport/contract/insert.do"
                          method="post"
                          enctype="multipart/form-data">

                        <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}">

                        <div class="contract-head">
                            <a class="btn btn-outline contract-back-btn"
                               href="${pageContext.request.contextPath}/owner/transport/forwarder/list.do">
                                <span class="material-symbols-outlined">arrow_back</span>
                                목록으로
                            </a>

                            <h3 id="contract-target-fwd" class="contract-title">
                                운송업체 계약 요청
                            </h3>
                        </div>

                        <!-- 수출/수입 구분 -->
                        <div class="contract-type-grid">
                            <label class="contract-type-option" onclick="updateContractTypeUI('export')">
                                <input checked name="trcSeCd" type="radio" value="export">
                                <div id="type-card-export" class="contract-type-card active">
                                    <span class="material-symbols-outlined">directions_boat</span>
                                    <span>수출(Export) 운송 의뢰</span>
                                </div>
                            </label>

                            <label class="contract-type-option" onclick="updateContractTypeUI('import')">
                                <input name="trcSeCd" type="radio" value="import">
                                <div id="type-card-import" class="contract-type-card">
                                    <span class="material-symbols-outlined">directions_boat</span>
                                    <span>수입(Import) 운송 의뢰</span>
                                </div>
                            </label>
                        </div>

                        <!-- 발신 → 수신 -->
                        <div class="contract-flow">
                            <div class="contract-flow-box sender">
                                <div class="contract-flow-label">보내는 사람</div>
                                <div class="contract-flow-value">${ownerVO.owrNm}</div>
                            </div>

                            <div class="contract-flow-arrow">→</div>

                            <div class="contract-flow-box receiver">
                                <div class="contract-flow-label">운송업체 선택</div>

                                <div class="contract-forwarder-pick">
                                    <input type="hidden" id="trcTmNo" name="trcTmNo">

                                    <div class="contract-pick-wrap">
                                        <input type="text"
                                               id="selectedForwarderInput"
                                               class="contract-pick-input"
                                               placeholder="운송업체와 담당자를 검색하여 선택하세요"
                                               readonly>

                                        <button type="button"
                                                class="btn btn-primary contract-pick-btn"
                                                onclick="openTransportManagerModal()">
                                            검색
                                        </button>
                                    </div>

                                    <div class="contract-flow-help">
                                        검색 버튼을 눌러 운송업체와 소속 운송담당자를 선택하세요.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 관련 문서 업로드 -->
                        <div class="contract-upload-block">
                            <div class="contract-upload-step">⑥ 관련 문서 업로드</div>

                            <div class="contract-upload-guide">
                                <span class="material-symbols-outlined">description</span>
                                <span>
                                    송장, 패킹리스트, B/L, 계약서, 원산지증명서 등
                                    수출통관과 운송계약에 필요한 문서를 첨부하세요.
                                </span>
                            </div>

                            <div class="contract-upload-top">
                                <div class="contract-upload-required">첨부 문서 <span>*</span></div>

                                <div class="contract-upload-actions">
                                    <input type="file"
                                           id="contractDocFile"
                                           name="docFiles"
                                           multiple
                                           accept=".pdf,.jpg,.jpeg,.png,.xlsx,.xls,.doc,.docx"
                                           onchange="handleContractDocFiles(this)"
                                           style="display:none;">

                                    <button type="button"
                                            class="btn btn-outline contract-file-trigger"
                                            onclick="document.getElementById('contractDocFile').click();">
                                        파일 선택
                                    </button>

                                    <button type="button"
                                            class="btn btn-primary contract-file-add"
                                            onclick="document.getElementById('contractDocFile').click();">
                                        업로드 목록 추가
                                    </button>
                                </div>
                            </div>

                            <div class="contract-dropzone"
                                 onclick="document.getElementById('contractDocFile').click();">
                                <div class="contract-dropzone-inner">
                                    <span class="material-symbols-outlined contract-dropzone-icon">upload_file</span>
                                    <div class="contract-dropzone-main">
                                        파일을 이곳에 드래그하거나 <strong>클릭</strong>하여 선택하세요
                                    </div>
                                    <div class="contract-dropzone-sub" id="contractDocFileName">
                                        PDF · JPG · PNG · XLSX · DOCX — 최대 20MB
                                    </div>
                                </div>
                            </div>

                            <div class="contract-doc-table-wrap">
                                <table class="data-table doc-table contract-doc-table">
                                    <thead>
                                    <tr>
                                        <th>문서종류</th>
                                        <th>파일명</th>
                                        <th>상태</th>
                                        <th>관리</th>
                                    </tr>
                                    </thead>
                                    <tbody id="contractDocUploadTbody">
                                    <tr class="empty-row">
                                        <td colspan="4" class="contract-empty-cell">
                                            첨부된 문서가 없습니다.
                                        </td>
                                    </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- 운송 요청 상세 사항 -->
                        <div class="contract-section contract-memo-section">
                            <div class="contract-field-title">운송 요청 상세 사항</div>

                            <div class="contract-memo-wrap">
                                <textarea id="contract-transport-memo"
                                          name="trcRqstCn"
                                          class="contract-memo"
                                          placeholder="운송 일정, 특수 화물 취급 주의사항, 배차 요청 등 세부 사항을 입력하세요."></textarea>
                            </div>
                        </div>

                        <div class="contract-actions">
                            <button class="btn btn-primary" type="submit">
                                <span class="material-symbols-outlined">send</span>
                                계약 요청 + 서류 전송
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </main>

        <%@ include file="/WEB-INF/views/common/ownerModals.jsp" %>
        <%@ include file="/WEB-INF/views/common/footer.jsp" %>
    </div>
</div>

<!-- 운송업체 / 운송담당자 선택 모달 -->
<div id="transportManagerModal" class="contract-modal">
    <div class="contract-modal-backdrop" onclick="closeTransportManagerModal()"></div>

    <div class="contract-modal-panel">
        <div class="contract-modal-head">
            <div>
                <div class="contract-modal-kicker">Transport Manager Search</div>
                <h3>운송업체 / 담당자 선택</h3>
            </div>

            <button type="button"
                    class="contract-modal-close"
                    onclick="closeTransportManagerModal()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div class="contract-modal-body">
            <div class="contract-modal-search">
                <div class="contract-modal-search-input-wrap">
                    <span class="material-symbols-outlined">search</span>
                    <input type="text"
                           id="transportManagerSearchKeyword"
                           class="contract-modal-search-input"
                           placeholder="회사명, 담당자명, 연락처로 검색하세요"
                           autocomplete="off"
                           onkeydown="if(event.key === 'Enter'){ searchTransportCompanyList(); }">
                </div>

                <button type="button"
                        class="btn btn-primary"
                        onclick="searchTransportCompanyList()">
                    검색
                </button>
            </div>

            <div class="contract-modal-layout">
                <div class="contract-modal-col">
                    <div class="contract-modal-col-title">운송업체</div>

                    <div id="transportCompanyList" class="contract-modal-list">
                        <div class="contract-modal-empty">
                            검색어를 입력하고 검색하세요.
                        </div>
                    </div>
                </div>

                <div class="contract-modal-col">
                    <div class="contract-modal-col-title">
                        <span id="transportManagerTitle">운송담당자</span>
                    </div>

                    <div id="transportManagerList" class="contract-modal-list">
                        <div class="contract-modal-empty">
                            먼저 운송업체를 선택하세요.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%@ include file="/WEB-INF/views/common/ownerScripts.jsp" %>

<script>
    window.tranManagerList = [
        <c:forEach var="tm" items="${tranManagerList}" varStatus="st">
        {
            tmNo: "<c:out value='${tm.tmNo}'/>",
            companyName: "<c:out value='${tm.tmCpNm}'/>",
            companyTelNo: "<c:out value='${tm.tmCpTelno}'/>",
            managerName: "<c:out value='${tm.tmName}'/>",
            tranMnCd: "<c:out value='${tm.tmMnCd}'/>",
            useYn: "<c:out value='${tm.tmUse}'/>"
        }<c:if test="${!st.last}">,</c:if>
        </c:forEach>
    ];
</script>

<script src="${pageContext.request.contextPath}/resources/js/owner/transport-contract.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (typeof updateContractTypeUI === 'function') {
            updateContractTypeUI('export');
        }
    });
</script>

</body>
</html>