package kr.or.tacs.common.docs.controller;

import kr.or.tacs.common.docs.service.DocsService;
import kr.or.tacs.dto.FileInfoDTO;
import kr.or.tacs.dto.common.docs.DocsListResponseDTO;
import kr.or.tacs.dto.common.docs.DocsTrashItemDTO;
import kr.or.tacs.vo.common.CustomUser;
import kr.or.tacs.vo.common.PaginationInfoVO;
import kr.or.tacs.vo.common.docs.DocsCreateFolderRequestVO;
import kr.or.tacs.vo.common.docs.DocsDeleteRequestVO;
import kr.or.tacs.vo.common.docs.DocsRenameRequestVO;
import lombok.RequiredArgsConstructor;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.core.io.Resource;
import org.springframework.core.io.UrlResource;
import org.springframework.http.HttpHeaders;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.security.core.annotation.AuthenticationPrincipal;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;

import java.io.File;
import java.net.URLEncoder;
import java.nio.charset.StandardCharsets;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.List;
import java.util.Map;

@RestController
@RequiredArgsConstructor
@RequestMapping("/api/docs")
public class DocsApiController {

    private final DocsService docsService;

    @Value("${kr.or.tacs.upload.path}")
    private String uploadPath;

    @GetMapping("/list.do")
    public ResponseEntity<DocsListResponseDTO> retriveDocsList(
            @RequestParam(required = false) String folderId,
            @AuthenticationPrincipal CustomUser user
    ) {
        DocsListResponseDTO response = docsService.retriveDocsList(folderId, user);
        return ResponseEntity.ok(response);
    }

    @GetMapping("/trash/list.do")
    public ResponseEntity<PaginationInfoVO<DocsTrashItemDTO>> retriveTrashList(
            @RequestParam(defaultValue = "1") int page,
            @AuthenticationPrincipal CustomUser user
    ) {
        PaginationInfoVO<DocsTrashItemDTO> response = docsService.retriveTrashList(page, user);
        return ResponseEntity.ok(response);
    }

    @DeleteMapping("/trash/items.do")
    public ResponseEntity<Map<String, Object>> deleteTrashItemsPerm(
            @RequestBody DocsDeleteRequestVO request,
            @AuthenticationPrincipal CustomUser user
    ) {
        docsService.deleteTrashItemsPerm(request.getIds(), user);
        return ResponseEntity.ok(Map.of("success", true));
    }

    @DeleteMapping("/trash/all.do")
    public ResponseEntity<Map<String, Object>> emptyTrashAll(
            @AuthenticationPrincipal CustomUser user
    ) {
        docsService.emptyTrashAll(user);
        return ResponseEntity.ok(Map.of("success", true));
    }

    @PostMapping("/folder/create.do")
    public ResponseEntity<Map<String, Object>> registFolder(
            @RequestBody DocsCreateFolderRequestVO request,
            @AuthenticationPrincipal CustomUser user
    ) {
        docsService.registFolder(request.getName(), request.getParentId(), user);
        return ResponseEntity.ok(Map.of("success", true));
    }

    @PostMapping("/upload.do")
    public ResponseEntity<Map<String, Object>> registFiles(
            @RequestPart("files") List<MultipartFile> files,
            @RequestParam(required = false) String folderId,
            @AuthenticationPrincipal CustomUser user
    ) throws Exception {
        docsService.registFiles(files, folderId, user);
        return ResponseEntity.ok(Map.of("success", true));
    }

    @PostMapping("/rename.do")
    public ResponseEntity<Map<String, Object>> modifyName(
            @RequestBody DocsRenameRequestVO request,
            @AuthenticationPrincipal CustomUser user
    ) {
        docsService.modifyName(request.getId(), request.getName(), user);
        return ResponseEntity.ok(Map.of("success", true));
    }

    @PostMapping("/delete.do")
    public ResponseEntity<Map<String, Object>> deleteDocsItems(
            @RequestBody DocsDeleteRequestVO request,
            @AuthenticationPrincipal CustomUser user
    ) {
        docsService.deleteDocsItems(request.getIds(), user);
        return ResponseEntity.ok(Map.of("success", true));
    }

    @GetMapping("/download.do")
    public ResponseEntity<Resource> downloadFile(
            @RequestParam String id,
            @AuthenticationPrincipal CustomUser user
    ) throws Exception {
        FileInfoDTO fileInfo = docsService.retriveDownloadFile(id, user);

        String basePath = uploadPath.replace("\\", File.separator);
        String relativePath = fileInfo.getDfiPath() == null ? "" : fileInfo.getDfiPath().replace("/", File.separator);
        if (relativePath.startsWith(File.separator)) {
            relativePath = relativePath.substring(1);
        }

        Path filePath = Paths.get(basePath, relativePath, fileInfo.getDfiStrNm()).normalize();
        Resource resource = new UrlResource(filePath.toUri());

        if (!resource.exists() || !resource.isReadable()) {
            throw new IllegalArgumentException("파일을 찾을 수 없습니다.");
        }

        String downloadName = fileInfo.getDfiOrgNm() == null ? fileInfo.getDfiStrNm() : fileInfo.getDfiOrgNm();
        String encodedName = URLEncoder.encode(downloadName, StandardCharsets.UTF_8).replace("+", "%20");

        return ResponseEntity.ok()
                .contentType(MediaType.APPLICATION_OCTET_STREAM)
                .header(HttpHeaders.CONTENT_DISPOSITION, "attachment; filename*=UTF-8''" + encodedName)
                .body(resource);
    }
}
