@charset "UTF-8";

/* ── Topbar ── */
.topbar { 
  height: 60px; 
  background: #fff; 
  border-bottom: 2px solid #0f172a; 
  display: flex; 
  align-items: center; 
  justify-content: space-between; 
  padding: 0 28px; 
  position: sticky; 
  top: 0; 
  z-index: 10; 
}

.tb-left { 
  display: flex; 
  align-items: center; 
  gap: 20px; 
}

.tb-brand { 
  font-size: 18px; 
  font-weight: 900; 
  color: #0f172a; 
  letter-spacing: -1px; 
}

.tb-right { 
  display: flex; 
  align-items: center; 
  gap: 4px; 
}

.tb-btn { 
  padding: 8px; 
  color: #475569; 
  cursor: pointer; 
  background: none; 
  border: none; 
  transition: background .15s; 
  position: relative; 
}

.tb-btn:hover { background: #f1f5f9; }

.tb-btn .material-symbols-outlined { font-size: 20px; }

.tb-btn .dot { 
  position: absolute; 
  top: 7px; 
  right: 7px; 
  width: 6px; 
  height: 6px; 
  background: #9f403d; 
}

.tb-sep { 
  width: 1px; 
  height: 28px; 
  background: #e2e8f0; 
  margin: 0 6px; 
}

.tb-user { 
  display: flex; 
  align-items: center; 
  gap: 10px; 
}

.tb-user-info { text-align: right; }

.tb-user-info .name { 
  font-size: 12px; 
  font-weight: 700; 
  color: #0f172a; 
}

.tb-user-info .role { 
  font-size: 10px; 
  color: #64748b; 
}

.tb-avatar { 
  width: 36px; 
  height: 36px; 
  background: #565e74; 
  color: #f7f7ff; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  font-weight: 700; 
  font-size: 13px; 
  flex-shrink: 0; 
}
