package kr.or.tacs.warehouse.inventory.service;

import java.util.Collections;
import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import kr.or.tacs.dto.warehouse.WarehouseInventory3DDTO;
import kr.or.tacs.dto.warehouse.WarehouseZoneDTO;
import kr.or.tacs.warehouse.inventory.mapper.Inventory3DMapper;
import lombok.extern.slf4j.Slf4j;

@Slf4j
@Service
public class Inventory3DServiceImpl implements Inventory3DService {

	@Autowired
	private Inventory3DMapper inventory3DMapper;
	
	@Override
	public List<WarehouseInventory3DDTO> selectInventory3DList(String wmId) {
		log.info("3D 재고 위치 목록 조회 시작");
		
		List<WarehouseInventory3DDTO> inventoryList = inventory3DMapper.selectInventory3DList(wmId);
		if(inventoryList == null) {
			log.info("3D 재고 위치 목록 조회 결과 없음");
			return Collections.emptyList();
		}
		
		log.info("3D 재고 위치 목록 조회 완료 - 건수 : {} ", inventoryList.size());
		return inventoryList;
	}

	@Override
	public List<WarehouseZoneDTO> selectZoneStatusList(String wmId) {
		
		log.info("창고 구역별 적재율 목록 조회");
		List<WarehouseZoneDTO> zoneStatusList = inventory3DMapper.selectZoneStatusList(wmId);
		if(zoneStatusList == null) {
			log.info("창고 구역별 적재율 목록 조회 결과 없음");
			return Collections.emptyList();
		}
		
		log.info("창고 구역별 적재율 목록 조회 완료 - 건수 : {} ", zoneStatusList.size());
		return zoneStatusList;
	}

	
	// 보세재고 목록 전체 개수 조회
	@Override
	public int selectInventoryCount(WarehouseInventory3DDTO searchDTO, String wmId) {
		
		return inventory3DMapper.selectInventoryCount(searchDTO,wmId);
	}

	
	// 보세재고 목록 페이징 조회
	@Override
	public List<WarehouseInventory3DDTO> selectInventoryList(WarehouseInventory3DDTO searchDTO, String wmId) {
		
		List<WarehouseInventory3DDTO> inventoryList = inventory3DMapper.selectInventoryList(searchDTO,wmId);
		
		if(inventoryList == null) {
			return Collections.emptyList(); // 조회결과가 없으면 빈 배열로 나타냄
		}
		return inventoryList;
	}

	@Override
	public List<WarehouseInventory3DDTO> selectInventory3DSearchList(WarehouseInventory3DDTO searchDTO, String wmId) {

	    log.info("3D 재고 검색 목록 조회 시작 - zone: {}, keyword: {}",
	            searchDTO.getZone(),
	            searchDTO.getKeyword());

	    /*
	     * 3D 검색 전용 조회
	     *
	     * 기존 selectInventory3DList(String wmId)는 전체 3D 재고 조회용으로 그대로 둔다.
	     * 이 메서드는 React 3D 검색창에서 zone, q 검색조건을 보낼 때만 사용한다.
	     */
	    List<WarehouseInventory3DDTO> inventoryList =
	            inventory3DMapper.selectInventory3DSearchList(searchDTO, wmId);

	    if (inventoryList == null) {
	        log.info("3D 재고 검색 목록 조회 결과 없음");
	        return Collections.emptyList();
	    }

	    log.info("3D 재고 검색 목록 조회 완료 - 건수 : {}", inventoryList.size());
	    return inventoryList;
	}
}














