package kr.or.tacs.common.file.service;

import kr.or.tacs.common.file.mapper.IFileMapper;
import kr.or.tacs.dto.FileAccessContextDTO;
import kr.or.tacs.dto.FileInfoDTO;
import kr.or.tacs.vo.common.CustomUser;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.security.access.AccessDeniedException;
import org.springframework.stereotype.Component;

/**
 * 파일 다운로드/미리보기 권한 검증기.
 *
 * <p>기존에는 로그인만 되어 있으면 누구나 fileNo 만으로 임의의 파일을 받을 수 있어
 * IDOR(다른 사용자 파일 무단 조회) 위험이 있었다. 이 검증기는 파일이 속한
 * 수입/수출 신고건의 참여자(소유 화주, 담당 관세사)와 검토 역할(세관)을 기준으로
 * 접근을 인스턴스 단위로 통제한다.</p>
 *
 * <p>보안 정책(Deny by Default): 소유자, 참여자, 관리자가 아니며 업무 매핑이 확인되지 않은 파일은
 * 원칙적으로 접근을 차단한다. 단, 자료실(RES)과 같이 명시적으로 전체 공개가 허용된 유형은
 * 화이트리스트 방식으로 통과시킨다.</p>
 */
@Slf4j
@Component
@RequiredArgsConstructor
public class FileAccessAuthorizer {

    private static final String ROLE_SYSTEM_ADMIN = "SYSTEM_ADMIN";
    private static final String ROLE_OFFICER = "OFFICER";
    private static final String ROLE_TRANSPORT_MANAGER = "TRANSPORT_MANAGER";
    private static final String ROLE_WAREHOUSE_MANAGER = "WAREHOUSE_MANAGER";
    private static final String ROLE_FIELD_OFFICER = "FIELD_OFFICER";
    private static final String ROLE_FIELD_OFFICER_WITH_PREFIX = "ROLE_FIELD_OFFICER";

    /** 개인 문서함(클라우드) 파일 업무유형 코드. */
    private static final String BIZ_TY_DOCS_CLOUD = "CLOUD";

    /** 자료실(전체공개) 파일 업무유형 코드. */
    private static final String BIZ_TY_RESOURCE = "RES";

    private final IFileMapper fileMapper;
    
    /** 수입검역신청 첨부파일 업무유형 코드 */
    private static final String BIZ_TY_IMP_INS_REQ = "IMP_INS_REQ";

    /**
     * 현재 로그인 사용자가 해당 파일을 다운로드/미리보기 할 수 있는지 검증한다.
     * 권한이 없으면 {@link AccessDeniedException} 을 던진다.
     */
    public void checkDownloadable(FileInfoDTO file, CustomUser user) {
        if (file == null) {
            throw new AccessDeniedException("파일 정보가 없습니다.");
        }
        if (user == null) {
            throw new AccessDeniedException("로그인이 필요합니다.");
        }

        String userId = user.getLoginId();
        String roleCd = user.getRoleCd();

        // 1. 시스템 관리자는 전체 허용
        if (ROLE_SYSTEM_ADMIN.equals(roleCd)) {
            return;
        }

        // 2. 업로더 본인
        if (userId != null && userId.equals(file.getDfiActorId())) {
            return;
        }
        
        /*
         * 2-1. 수입검역신청 첨부파일 현장공무원 접근 허용
         *
         * 관세사가 수입검역신청 시 업로드한 첨부파일은
         * DOCS_FILE_DATA 기준으로 업로더가 BROKER로 저장된다.
         *
         * 하지만 해당 검역요청을 배정받은 현장공무원은
         * 검역 업무 수행을 위해 첨부서류를 다운로드할 수 있어야 한다.
         *
         * 허용 조건:
         * - 파일 업무유형이 IMP_INS_REQ
         * - 현재 사용자가 현장공무원 권한
         * - TACS_FILE_MAP을 통해 연결된 IMP_INS_REQ의
         *   IIR_QRTN_OFFICER_ID가 현재 로그인 ID와 일치
         */
        if (BIZ_TY_IMP_INS_REQ.equals(file.getDfiBizTyCd())
                && isFieldOfficer(roleCd)
                && userId != null) {

            int allowedCount = fileMapper.selectImportInspectionFileAccessCount(
                    file.getDfiFileNo(),
                    userId
            );

            if (allowedCount > 0) {
                return;
            }
        }

        // 3. 수입/수출 신고건 참여자 검증
        FileAccessContextDTO ctx = fileMapper.selectFileAccessContext(file.getDfiFileNo());
        if (ctx != null && ctx.isBusinessMapped()) {
            if (userId != null && userId.equals(ctx.getOwnerId())) {
                return; // 소유 화주 본인
            }
            if (userId != null && userId.equals(ctx.getBrokerId())) {
                return; // 담당 관세사
            }
            if (ROLE_TRANSPORT_MANAGER.equals(roleCd) && userId != null && userId.equals(ctx.getTransportManagerId())) {
                return; // 담당 운송관리자
            }
            if (ROLE_TRANSPORT_MANAGER.equals(roleCd) && "Y".equals(ctx.getTransportRequestYn())) {
                return; // 접수 전 운송의뢰 첨부문서
            }
            if (ROLE_WAREHOUSE_MANAGER.equals(roleCd) && userId != null && userId.equals(ctx.getWarehouseManagerId())) {
                return; // 보세반출 요청 담당 창고관리자
            }
            if (ROLE_OFFICER.equals(roleCd)) {
                return; // 세관/공무원 검토자
            }

            log.info("[FileAccess] 업무건 파일 접근 거부. fileNo={}, userId={}, roleCd={}, ownerId={}, brokerId={}, transportManagerId={}, warehouseManagerId={}",
                    file.getDfiFileNo(), userId, roleCd, ctx.getOwnerId(), ctx.getBrokerId(),
                    ctx.getTransportManagerId(), ctx.getWarehouseManagerId());
            throw new AccessDeniedException("해당 파일에 접근할 권한이 없습니다.");
        }

        // 4. 개인 문서함(CLOUD) 파일은 업로더 본인/관리자 전용.
        //    위 1~2단계(관리자/업로더)에서 허용되지 못하고 여기까지 왔다면 타인의 개인 파일이므로 거부한다.
        if (BIZ_TY_DOCS_CLOUD.equals(file.getDfiBizTyCd())) {
            log.info("[FileAccess] 개인 문서함 파일 접근 거부. fileNo={}, userId={}, roleCd={}, ownerId={}",
                    file.getDfiFileNo(), userId, roleCd, file.getDfiActorId());
            throw new AccessDeniedException("해당 파일에 접근할 권한이 없습니다.");
        }

        // 5. 전체 공개 파일유형 허용 (화이트리스트)
        // 자료실(RES) 등 모든 사용자가 다운로드 가능한 특정 업무 코드는 허용한다.
        if (BIZ_TY_RESOURCE.equals(file.getDfiBizTyCd())) {
            return;
        }

        // 6. 그 외 업무객체 매핑이 없거나 화이트리스트에 없는 파일은 차단 (Deny by Default)
        log.warn("[FileAccess][DENY] 접근 권한이 없거나 매핑되지 않은 파일 접근 차단. fileNo={}, userId={}, roleCd={}, bizTyCd={}",
                file.getDfiFileNo(), userId, roleCd, file.getDfiBizTyCd());
        throw new AccessDeniedException("해당 파일에 접근할 권한이 없습니다.");
    }
    
    /*
     * 현장공무원 권한 여부 확인
     *
     * 프로젝트에서 roleCd가 FIELD_OFFICER 또는 ROLE_FIELD_OFFICER 형태로
     * 들어올 수 있으므로 둘 다 허용한다.
     */
    private boolean isFieldOfficer(String roleCd) {
        return ROLE_FIELD_OFFICER.equals(roleCd)
                || ROLE_FIELD_OFFICER_WITH_PREFIX.equals(roleCd)
                || ROLE_OFFICER.equals(roleCd);
    }
}
