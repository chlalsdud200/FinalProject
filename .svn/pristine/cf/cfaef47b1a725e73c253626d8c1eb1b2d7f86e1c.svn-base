/* ===== 신고서 작성 페이지 전용 JS =====
 * - switchDeclare, impTab : 폼/탭 전환
 * - openDeclareSearch, runDeclareSearch, dsKeyEnter, selectDeclareNo, loadDeclareByNo, declareSearchStore
 *   → 기존 신고서 조회 (모달 + 직접 조회)
 * - 페이지 로드 시 window.declareActiveSub ('imp' / 'exp') 값에 따라
 *   업무구분 selector-bar 숨기고 해당 폼 표시 (기존 goDeclare 로직 대체)
 */

/* ===== 폼 전환 ===== */
function switchDeclare(v) {
  var empty = document.getElementById('declare-empty');
  var formExp = document.getElementById('declare-form');      // 수출신고서
  var formImp = document.getElementById('declare-form-imp');  // 수입신고서
  var formPrep = document.getElementById('declare-prep');     // 준비중
  
  // 전부 숨기기
  if (empty) empty.style.display = 'none';
  if (formExp) formExp.style.display = 'none';
  if (formImp) formImp.style.display = 'none';
  if (formPrep) formPrep.style.display = 'none';

  if (!v) { if (empty) empty.style.display = 'block'; return; }

  if (v === 'exp-general') {
    formExp.style.display = 'block';
    var t = document.getElementById('declare-form-title');
    if (t) t.textContent = '수출신고서';
  } else if (v === 'imp-general') {
    formImp.style.display = 'block';
  } else {
    // 나머지 모든 업무 → 준비중 페이지
    formPrep.style.display = 'block';
    var names = {
      'imp-correct': '수입신고 정정/취하 신청서'
    };
    document.getElementById('declare-prep-title').textContent = names[v] || '해당 서식';
  }
}

/* ===== 수입신고서 탭 전환 ===== */
function impTab(tab) {
  ['c1', 'c2', 'items', 'attach'].forEach(function (t) {
    var el = document.getElementById('imp-' + t);
    if (el) el.style.display = (t === tab) ? 'block' : 'none';
  });
  var cont = document.getElementById('tabs-imp');
  if (cont) cont.querySelectorAll('.sub-tab').forEach(function (s) { s.classList.remove('active'); });
  if (event && event.target) event.target.classList.add('active');
}



/* ===== 신고서조회 모달 열기 ===== */
function openDeclareSearch(formType) {
  document.getElementById('ds-form-type').value = formType;
  document.getElementById('ds-keyword').value = '';
  var typeFilter = document.getElementById('ds-type-filter');
  if (typeFilter) typeFilter.value = 'all';
  document.getElementById('ds-result-area').style.display = 'none';
  document.getElementById('ds-empty-msg').style.display = 'block';
  document.getElementById('ds-count').textContent = '0';
  document.getElementById('ds-list-body').innerHTML = '';
  showModal('declare-search');

  setTimeout(function () {
    document.getElementById('ds-keyword').focus();
    // 모달 열리자마자 본인 의뢰서 전체 목록 자동 로드 (수입만)
    if (formType === 'imp') runDeclareSearch();
  }, 200);
}

/* ===== 검색 실행 — IMP_RQST 검색 (8C 실제 연동) ===== */
function runDeclareSearch() {
  var formType = document.getElementById('ds-form-type').value || 'imp';
  var keyword  = document.getElementById('ds-keyword').value.trim();

  // 수출은 8C 범위 밖
  if (formType !== 'imp') {
    alert('수출신고서 의뢰서 검색은 추후 지원됩니다.');
    return;
  }

  var ctx = window.contextPath || '';
  var url = ctx + '/broker/declare/searchImpRqst.do'
          + '?keyword=' + encodeURIComponent(keyword);

  fetch(url, { method: 'GET', headers: { 'Accept': 'application/json' } })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        alert('❌ ' + (res.message || '검색에 실패했습니다.'));
        return;
      }
      renderImpRqstSearchResults(res.list || []);
    })
    .catch(function (err) {
      console.error(err);
      alert('❌ 통신 오류: ' + err.message);
    });
}
/*
 * 8C-SEARCH
 * 통관의뢰 상태코드 한글 표시
 *
 * COM_CODE 기준:
 * CCG_ID = CSTM_STATUS
 */
function getCstmStatusName(statusCd) {
  var map = {
    'CSTM_REQ':      '접수대기',
    'CSTM_ACPT':     '접수완료',
    'CSTM_INPRG':    '처리중',
    'CSTM_SUPP':     '보완요청',
    'CSTM_SUPP_SUB': '보완제출',
    'CSTM_REJ':      '반려',
    'CSTM_DONE':     '완료',
    'CSTM_CANCEL':   '취소'
  };

  return map[statusCd] || statusCd || '-';
}

/*
 * 8C-SEARCH
 * 통관의뢰 상태별 badge class
 */
function getCstmStatusBadgeClass(statusCd) {
  var map = {
    'CSTM_REQ':      'badge-wait',
    'CSTM_ACPT':     'badge-ok',
    'CSTM_INPRG':    'badge-progress',
    'CSTM_SUPP':     'badge-warn',
    'CSTM_SUPP_SUB': 'badge-new',
    'CSTM_REJ':      'badge-danger',
    'CSTM_DONE':     'badge-ok',
    'CSTM_CANCEL':   'badge-muted'
  };

  return map[statusCd] || 'badge-wait';
}
/** 검색 결과 렌더링 — 모달 테이블 tbody 에 IMP_RQST 행 삽입 */
function renderImpRqstSearchResults(list) {
  var count    = document.getElementById('ds-count');
  var area     = document.getElementById('ds-result-area');
  var emptyMsg = document.getElementById('ds-empty-msg');
  var body     = document.getElementById('ds-list-body');

  if (count)    count.textContent = list.length;
  if (area)     area.style.display = 'block';

  if (!list || list.length === 0) {
    if (emptyMsg) emptyMsg.style.display = 'block';
    if (body) body.innerHTML = '';
    return;
  }

  if (emptyMsg) emptyMsg.style.display = 'none';

  // YYYYMMDD → YYYY-MM-DD 포맷
  function fmtYmd(s) {
    if (!s || s.length !== 8) return s || '-';
    return s.substr(0,4) + '-' + s.substr(4,2) + '-' + s.substr(6,2);
  }
  function escq(s) { return (s == null) ? '' : String(s).replace(/'/g, "\\'"); }

  /*
   * 8C-SEARCH
   * 상태코드 표시는 CSTM_STATUS 공통코드 기준 함수 사용
   */

  body.innerHTML = list.map(function (r) {
	var badgeCls = getCstmStatusBadgeClass(r.irStatusCd);
	var statusNm = getCstmStatusName(r.irStatusCd);
    var amount   = (r.irInvcAmt != null)
      ? (Number(r.irInvcAmt).toLocaleString() + (r.irDclrCurrCd ? ' ' + r.irDclrCurrCd : ''))
      : '-';
    return '<tr style="cursor:pointer" onclick="selectDeclareNo(\'' + escq(r.irNo) + '\')">'
      + '<td class="td-id" style="font-family:monospace;font-size:11px">' + (r.irNo || '-') + '</td>'
      + '<td style="font-weight:700;color:#203444">' + (r.irOwrId || '-') + '</td>'
      + '<td>수입</td>'
      + '<td>' + (r.irCn || '-') + '</td>'
      + '<td class="td-muted">' + fmtYmd(r.irArrvSchdYmd) + '</td>'
      + '<td><span class="badge ' + badgeCls + '">' + statusNm + '</span></td>'
      + '<td class="td-muted">' + ((r.irArrvPortNm || '-') + (r.irArrvPortCd ? ' (' + r.irArrvPortCd + ')' : '')) + '</td>'
      + '<td><button class="mini mini-view" onclick="event.stopPropagation();selectDeclareNo(\'' + escq(r.irNo) + '\')">'
      + '<span class="material-symbols-outlined" style="font-size:12px;vertical-align:middle">check_circle</span> 선택</button>'
      + ' <span style="font-size:10px;color:#697d8f">' + amount + '</span></td>'
      + '</tr>';
  }).join('');
}

/* ===== Enter 키 검색 ===== */
function dsKeyEnter(e) {
  if (e.key === 'Enter') runDeclareSearch();
}

/* ===== 모달에서 의뢰번호 선택 — 입력란 채움 + 자동으로 [조회] 호출 ===== */
function selectDeclareNo(no) {
  var formType = document.getElementById('ds-form-type').value || 'imp';
  var inputId  = formType === 'imp' ? 'imp-declare-input' : 'exp-declare-input';
  var el = document.getElementById(inputId);
  if (el) el.value = no;

  hideModal('declare-search');

  // 자동으로 [조회] 호출 → 신고서 폼 자동 채움 (8B 흐름)
  setTimeout(function () { loadDeclareByNo(formType); }, 100);
}

/* ===== [조회] 버튼 — 의뢰번호로 IMP_RQST 조회 후 신고서 폼 자동 채움 (8B 실제 연동) ===== */
function loadDeclareByNo(formType) {
  var inputId = formType === 'imp' ? 'imp-declare-input' : 'exp-declare-input';
  var input = document.getElementById(inputId);
  if (!input) return;

  var keyword = input.value.trim();
  if (!keyword) {
    alert('통관의뢰번호를 입력해주세요.\n\n번호를 모르시면 돋보기(🔍) 버튼을 눌러 검색하세요.');
    input.focus();
    return;
  }

  // 수출(exp) 은 8B 범위 밖 — mock 메시지 유지
  if (formType !== 'imp') {
    alert('수출신고서 의뢰서 조회는 추후 지원됩니다.');
    return;
  }

  var ctx = window.contextPath || '';
  fetch(ctx + '/broker/declare/loadImpRqst.do?irNo=' + encodeURIComponent(keyword), {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        alert('❌ ' + (res.message || '조회에 실패했습니다.'));
        return;
      }
      // 의뢰서 데이터를 신고서 폼에 자동 채움
      applyImpRqstToForm(res.rqst);
	  /*
	   * 8D-ATTACH
	   * 의뢰번호 조회가 성공하면 해당 IR_NO의 첨부파일 목록도 함께 조회한다.
	   */
	  loadImpDocs();
	  
      alert(res.message + '\n\n의뢰번호: ' + res.rqst.irNo +
            (res.rqst.irBlAwbNo ? '\nB/L: ' + res.rqst.irBlAwbNo : ''));
    })
    .catch(function (err) {
      console.error(err);
      alert('❌ 통신 오류: ' + err.message);
    });
}

/* ============================================================
 * 10F — AI 자동 채움 (첨부 PDF → Gemini → 폼 전체 자동 입력)
 *  · 의뢰번호 기준 첨부 PDF 들을 서버에서 종합 파싱
 *  · 응답받은 ImportDeclarationParsedDto 를 폼 input 에 매핑
 *  · DB 저장은 사용자 검토 후 [임시저장] 흐름 그대로
 * ============================================================ */
function aiParseFromPdf(formType) {
  if (formType !== 'imp') {
    alert('수출신고서 AI 파싱은 추후 지원됩니다.');
    return;
  }

  var input = document.getElementById('imp-declare-input');
  if (!input) return;
  var irNo = input.value.trim();
  if (!irNo) {
    alert('통관의뢰번호를 먼저 입력하거나 [조회] / 돋보기 검색으로 선택해주세요.');
    input.focus();
    return;
  }

  if (!confirm('첨부된 PDF (Invoice / Packing List / B/L 등) 를 AI 가 분석해서\n신고서 폼을 자동 채웁니다.\n\n잠시 (5~15초) 기다려주세요. 진행할까요?')) return;

  var ctx = window.contextPath || '';
  var btn = event && event.currentTarget;
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:14px">hourglass_top</span> AI 분석중...'; }

  fetch(ctx + '/broker/declare/aiParseImpRqst.do?irNo=' + encodeURIComponent(irNo), {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        alert('❌ ' + (res.message || 'AI 파싱에 실패했습니다.'));
        return;
      }
      applyParsedDtoToForm(res.parsed);
      alert(res.message);
    })
    .catch(function (err) {
      console.error(err);
      alert('❌ 통신 오류: ' + err.message);
    })
    .finally(function () {
      if (btn) { btn.disabled = false; btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:14px">auto_awesome</span> AI 자동 채움'; }
    });
}

/** AI 파싱 결과 DTO 를 IMP_DCLR / IMP_DCLR_ITEM 폼에 채움 */
function applyParsedDtoToForm(p) {
  if (!p) return;
  function setVal(id, value) {
    var el = document.getElementById(id);
    if (!el) return;
    el.value = (value === null || value === undefined) ? '' : value;
  }

  // 운송수단 매핑: Sea → 10, Air → 40, Land → 30
  function convTransport(s) {
    if (!s) return '';
    var v = String(s).toLowerCase();
    if (v.indexOf('sea') >= 0) return '10';
    if (v.indexOf('air') >= 0) return '40';
    if (v.indexOf('land') >= 0 || v.indexOf('road') >= 0) return '30';
    return '';
  }

  // 입항일자 'YYYY-MM-DD' 그대로 input type=date 에 사용
  // (또는 YYYYMMDD 면 변환)
  function normalizeDate(s) {
    if (!s) return '';
    if (s.length === 8 && /^\d+$/.test(s)) {
      return s.substr(0,4) + '-' + s.substr(4,2) + '-' + s.substr(6,2);
    }
    return s;
  }

  // ===== 수입자 =====
  setVal('imp-impr-nm',          p.importerName);
  setVal('imp-impr-clnc-cd',     p.importerCustomsCode);
  setVal('imp-taxpyr-idnt-no',   p.importerBizNo);
  if (p.importerBizNo) {
    var sel = document.getElementById('imp-taxpyr-idnt-se');
    if (sel && !sel.value) sel.value = '사업자등록번호';
  }

  // ===== 해외공급자 =====
  setVal('imp-ovrss-nm',         p.exporterName);
  setVal('imp-ovrss-cntry-cd',   p.exporterCountryCode);
  findCountryNameFromDb(p.exporterCountryCode, 'imp-ovrss-cntry-nm');

  // ===== 기본신고사항 =====
  setVal('imp-shipout-cntry-cd', p.originCountryCode || p.exporterCountryCode);
  findCountryNameFromDb(p.originCountryCode || p.exporterCountryCode, 'imp-shipout-cntry-nm');
  setVal('imp-mbl-no',           p.blNumber);
  setVal('imp-arvl-ymd',         normalizeDate(p.arrivalDate));
  setVal('imp-trnsp-mn-cd',      convTransport(p.meansOfTransport));
  setVal('imp-cntnr-se-cd',      p.containerType);

  // ===== 공통사항2 - 포장/가격/결제 =====
  setVal('imp-tot-pkg-cnt',      p.totalPackageCount);
  setVal('imp-tot-wt',           p.totalNetWeight);
  setVal('imp-orgn-cert-yn',     p.originCertificateYn);
  setVal('imp-stlm-amt',         p.totalInvoiceAmount);
  setVal('imp-dlvr-cndtn-cd',    p.incoterms);
  if (p.paymentCurrency) {
      setVal('imp-stlm-curr-cd', p.paymentCurrency);
  }
  // ===== 란사항 (items) — 기존 row 비우고 AI 결과로 채움 =====
  if (p.items && p.items.length > 0) {
    var container = document.getElementById('imp-items-container');
    if (container) container.innerHTML = '';
    p.items.forEach(function (it) {
      addItemRow({
        idiHsCd:         it.hsCode,
        idiDclrGdsnm:    it.productName,
        idiTrdngGdsnm:   it.botanicalName,
        idiQty:          it.quantity,
        idiQtyUnitCd:    it.quantityUnit,
        idiNetWt:        it.netWeight,
        idiTrdmkNm:      it.brandName,
        idiOrgnCntryCd:  it.originCountryCode || p.originCountryCode,
        idiTaxtPrcUsd:   it.amount
      });
    });
  }

  // 적출국 코드만 있고 입력란이 비었으면 채움 보장
  if (p.originCountryCode) {
    var shipout = document.getElementById('imp-shipout-cntry-cd');
    if (shipout && !shipout.value) shipout.value = p.originCountryCode;
  }
}

/** 의뢰서(IMP_RQST) 데이터를 신고서(IMP_DCLR) 폼의 매칭 필드에 채움 */
function applyImpRqstToForm(r) {
  if (!r) return;
  function setVal(id, value) {
    var el = document.getElementById(id);
    if (!el) return;
    el.value = (value === null || value === undefined) ? '' : value;
  }

  // 통관의뢰번호 (PK 매핑) — 입력란 정규화
  setVal('imp-declare-input', r.irNo);

  // 수입자 통관고유부호
  setVal('imp-impr-clnc-cd', r.irCstmIdfNo);

  // 납세의무자 사업자번호 (식별부호 구분도 '사업자등록번호' 로 설정)
  if (r.irCorpRegNo) {
    setVal('imp-taxpyr-idnt-no', r.irCorpRegNo);
    var idntSe = document.getElementById('imp-taxpyr-idnt-se');
    if (idntSe && !idntSe.value) idntSe.value = '사업자등록번호';
  }

  // 입항일자 (YYYYMMDD → YYYY-MM-DD)
  if (r.irArrvSchdYmd && r.irArrvSchdYmd.length === 8) {
    setVal('imp-arvl-ymd',
      r.irArrvSchdYmd.substr(0,4) + '-' + r.irArrvSchdYmd.substr(4,2) + '-' + r.irArrvSchdYmd.substr(6,2));
  }

  // Master B/L 번호
  setVal('imp-mbl-no', r.irBlAwbNo);

  // 결제금액
  setVal('imp-stlm-amt', r.irInvcAmt);
}

/* ===== 페이지 진입 시 imp/exp 자동 진입 처리 (기존 goDeclare 로직 대체) ===== */
document.addEventListener('DOMContentLoaded', function () {
  var sub = window.declareActiveSub;
  if (sub !== 'imp' && sub !== 'exp') return;

  var page = document.getElementById('pg-declare');
  if (!page) return;

  // 1) 업무구분 selector-bar 숨김
  var selBar = page.querySelector('.selector-bar');
  if (selBar) selBar.style.display = 'none';

  // 2) 화면 제목 변경
  var h2 = page.querySelector('h2');
  if (h2) {
    h2.innerHTML = '<span class="material-symbols-outlined">edit_note</span> '
                 + (sub === 'imp' ? '수입신고서 작성' : '수출신고서 작성');
  }

  // 3) 해당 신고서 폼 표시
  switchDeclare(sub === 'imp' ? 'imp-general' : 'exp-general');

  // 4) declareType select 값도 동기화
  var sel = document.getElementById('declareType');
  if (sel) sel.value = (sub === 'imp' ? 'imp-general' : 'exp-general');
});

/* ============================================================
 * 수입신고서 임시저장 (1차 MVP)
 *  - 핵심 8개 필드만 수집해서 서버로 전송
 *  - 서버가 통관의뢰번호 자동 채번 후 응답
 * ============================================================ */




function lookupExchangeRate() {
  var currEl = document.getElementById('imp-stlm-curr-cd');
  var rateEl = document.getElementById('imp-exrt');

  if (!currEl) {
    alert('결제통화 입력 영역을 찾을 수 없습니다.');
    return;
  }

  var currency = (currEl.value || 'USD').trim().toUpperCase();
  var ctx = window.contextPath || '';
  var url = ctx + '/broker/declare/exchangeRate.do?currency=' + encodeURIComponent(currency);

  console.log('[환율조회 요청]', url);

  if (rateEl) {
    rateEl.value = '조회중...';
  }

  fetch(url, {
    method: 'GET',
    headers: { 'Accept': 'application/json' },
    credentials: 'same-origin'
  })
    .then(function (r) {
      console.log('[환율조회 HTTP]', r.status, r.url);

      if (!r.ok) {
        throw new Error('HTTP ' + r.status);
      }

      return r.text();
    })
    .then(function (text) {
      console.log('[환율조회 원본응답]', text);

      var res = null;

      try {
        res = JSON.parse(text);
      } catch (e) {
        if (rateEl) rateEl.value = '';
        alert(
          '환율조회 응답이 JSON이 아닙니다.\n\n'
          + '대부분 로그인 페이지 HTML이 반환되었거나 서버 오류 페이지가 반환된 경우입니다.\n'
          + 'Console의 [환율조회 원본응답]을 확인하세요.'
        );
        return;
      }

      if (!res.success) {
        if (rateEl) rateEl.value = '';
        alert(res.message || '환율 조회에 실패했습니다.');
        return;
      }

      if (!res.rate) {
        if (rateEl) rateEl.value = '';
        alert('환율 조회 응답에 rate 데이터가 없습니다.');
        return;
      }

      var rate = res.rate.rate;
      var dealBasR = res.rate.dealBasR;
      var searchDate = res.rate.searchDate;

      if (rate === null || rate === undefined || rate === '') {
        if (rateEl) rateEl.value = '';
        alert('환율 숫자(rate)가 비어 있습니다.');
        return;
      }

      if (rateEl) {
        rateEl.value = dealBasR || rate;
        rateEl.setAttribute('data-rate', rate);
        rateEl.setAttribute('data-search-date', searchDate || '');
      }

      calcImportTaxBasePreview();
    })
    .catch(function (err) {
      console.error('[환율조회 오류]', err);
      if (rateEl) rateEl.value = '';
      alert('환율 조회 통신 오류: ' + err.message);
    });
}

function enforceUsdCifMvp() {
  var currEl = document.getElementById('imp-stlm-curr-cd');
  var dlvrEl = document.getElementById('imp-dlvr-cndtn-cd');

  if (currEl) {
    currEl.value = 'USD';
  }

  if (dlvrEl) {
    dlvrEl.value = 'CIF';
  }
}

function calcImportTaxBasePreview() {
	
  var amtEl = document.getElementById('imp-stlm-amt');
  var currEl = document.getElementById('imp-stlm-curr-cd');
  var rateEl = document.getElementById('imp-exrt');
  var krwEl = document.getElementById('imp-tot-taxt-prc-krw');
  var usdEl = document.getElementById('imp-tot-taxt-prc-usd');

  if (!amtEl || !rateEl || !krwEl) {
    return;
  }

  function parseNum(value) {
    if (value === null || value === undefined) {
      return 0;
    }

    var cleaned = String(value)
      .replace(/,/g, '')
      .replace(/%/g, '')
      .trim();

    if (cleaned === '') {
      return 0;
    }

    var n = Number(cleaned);
    return isNaN(n) ? 0 : n;
  }

  function formatNum(value) {
    var n = Math.round(Number(value || 0));
    return n.toLocaleString();
  }

  function formatDecimal(value) {
    var n = Number(value || 0);
    if (isNaN(n)) return '';

    return n.toLocaleString(undefined, {
      maximumFractionDigits: 2
    });
  }

  var amt = parseNum(amtEl.value);
  var rate = parseNum(rateEl.getAttribute('data-rate') || rateEl.value);
  var curr = currEl ? (currEl.value || '').toUpperCase() : '';

  if (!amt || !rate) {
    return;
  }

  var krw = Math.round(amt * rate);
  var usd = 0;

  if (curr === 'USD') {
    usd = amt;
  } else if (curr === 'KRW') {
    usd = amt / rate;
  }

  krwEl.value = formatNum(krw);

  if (usdEl) {
    usdEl.value = usd ? formatDecimal(usd) : '';
  }

  /*
   * 현재 입력 중인 란의 USD 과세가격이 있으면
   * 환율조회 후 KRW 과세가격을 자동 계산한다.
   */
  recalcCurrentItemKrwFromUsd();
}

function recalcCurrentItemKrwFromUsd() {
  var rateEl = document.getElementById('imp-exrt');

  if (!rateEl) {
    return;
  }

  var rate = taxCalcParseNumber(rateEl.getAttribute('data-rate') || rateEl.value);

  if (rate <= 0) {
    return;
  }

  var row = null;

  if (typeof getCurrentItemRow === 'function') {
    row = getCurrentItemRow();
  }

  if (!row) {
    return;
  }

  var usdEl = row.querySelector('.item-taxt-prc-usd');
  var krwEl = row.querySelector('.item-taxt-prc-krw');

  if (!usdEl || !krwEl) {
    return;
  }

  var usd = taxCalcParseNumber(usdEl.value);

  if (usd <= 0) {
    krwEl.value = '';
    recalcCurrentItemTaxDisplay();
    return;
  }

  krwEl.value = taxCalcFormatNumber(Math.round(usd * rate));
  recalcCurrentItemTaxDisplay();
}

function recalcCurrentItemTaxDisplay() {
  var row = null;

  if (typeof getCurrentItemRow === 'function') {
    row = getCurrentItemRow();
  }

  /*
   * 세액사항 블록이 .imp-item-row 내부에 있으면 row.querySelector로 찾고,
   * JSP 구조상 바깥에 있으면 document.querySelector로 다시 찾는다.
   */
  function findInRowOrDoc(selector) {
    var el = row ? row.querySelector(selector) : null;
    if (!el) {
      el = document.querySelector(selector);
    }
    return el;
  }

  var krwEl = findInRowOrDoc('.item-taxt-prc-krw');
  var rateEl = findInRowOrDoc('.item-taxt-rt');

  var cstmsSeEl = findInRowOrDoc('.item-cstms-rdcn-se-cd');
  var cstmsAmtEl = findInRowOrDoc('.item-cstms-display-amt');
  var vatSeEl = findInRowOrDoc('.item-vat-se-cd');
  var vatAmtEl = findInRowOrDoc('.item-vat-display-amt');

  /*
   * 예전 id 방식으로 넣어둔 경우까지 방어
   */
  if (!cstmsSeEl) cstmsSeEl = document.getElementById('imp-cstms-rdcn-se-cd');
  if (!cstmsAmtEl) cstmsAmtEl = document.getElementById('imp-cstms-display-amt');
  if (!vatSeEl) vatSeEl = document.getElementById('imp-vat-se-cd');
  if (!vatAmtEl) vatAmtEl = document.getElementById('imp-vat-display-amt');

  var itemTaxPriceKrw = taxCalcParseNumber(krwEl ? krwEl.value : '');
  var itemRate = taxCalcParseNumber(rateEl ? rateEl.value : '');

  var itemCustomsAmt = 0;
  var itemVatAmt = 0;

  if (itemTaxPriceKrw > 0) {
    itemCustomsAmt = Math.round(itemTaxPriceKrw * itemRate / 100);
    itemVatAmt = Math.round((itemTaxPriceKrw + itemCustomsAmt) * 0.1);
  }

  if (cstmsSeEl) {
    cstmsSeEl.value = 'NONE';
  }

  if (cstmsAmtEl) {
    cstmsAmtEl.value = taxCalcFormatNumber(itemCustomsAmt);
  }

  if (vatSeEl) {
    vatSeEl.value = 'GENERAL';
  }

  if (vatAmtEl) {
    vatAmtEl.value = taxCalcFormatNumber(itemVatAmt);
  }

  console.log('[란 세액 계산]', {
    krw: itemTaxPriceKrw,
    rate: itemRate,
    customs: itemCustomsAmt,
    vat: itemVatAmt,
    cstmsAmtEl: cstmsAmtEl,
    vatAmtEl: vatAmtEl
  });
}

function taxCalcParseNumber(value) {
  if (value === null || value === undefined) {
    return 0;
  }

  var cleaned = String(value)
    .replace(/,/g, '')
    .replace(/%/g, '')
    .trim();

  if (cleaned === '') {
    return 0;
  }

  var n = Number(cleaned);
  return isNaN(n) ? 0 : n;
}

function taxCalcFormatNumber(value) {
  var n = Math.round(Number(value || 0));
  return n.toLocaleString();
}

document.addEventListener('change', function (e) {
  if (!e || !e.target) return;

  /*
   * 공통사항2 원산지증명서 유무가 Y로 바뀌면
   * 현재 란의 HS코드/원산지코드 상태를 보고 협정세율 재확인 안내
   */
  if (e.target.id === 'imp-orgn-cert-yn') {
    notifyOriginCertificateChange();
  }
});

function taxCalcHasTargetItem(item) {
  if (!item) return false;

  return !!(
    item.idiHsCd ||
    item.idiDclrGdsnm ||
    item.idiTrdngGdsnm ||
    item.idiTaxtPrcKrw ||
    item.idiTaxtRt
  );
}

/**
 * 수입신고세액 자동계산
 *
 * A안:
 * - 란별 과세가격(KRW)을 직접 입력
 * - 각 란의 과세가격 × 각 란의 세율로 관세 계산
 * - 공통사항2에는 합계만 표시
 */


function escapeDeclareNoticeText(value) {
  return String(value == null ? '' : value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;')
    .replace(/\n/g, '<br>');
}

function showDeclareNotice(type, title, message) {
  var old = document.getElementById('declare-notice-backdrop');
  if (old) {
    old.remove();
  }

  var safeTitle = escapeDeclareNoticeText(title || '알림');
  var safeMessage = escapeDeclareNoticeText(message || '');

  var icon = 'info';
  if (type === 'warning') icon = 'warning';
  if (type === 'success') icon = 'check_circle';
  if (type === 'error') icon = 'error';

  var backdrop = document.createElement('div');
  backdrop.id = 'declare-notice-backdrop';
  backdrop.className = 'declare-notice-backdrop';

  backdrop.innerHTML =
    '<div class="declare-notice-box declare-notice-' + (type || 'info') + '">' +
      '<div class="declare-notice-head">' +
        '<span class="material-symbols-outlined declare-notice-icon">' + icon + '</span>' +
        '<div>' +
          '<div class="declare-notice-title">' + safeTitle + '</div>' +
          '<div class="declare-notice-subtitle">수입신고서 작성 알림</div>' +
        '</div>' +
      '</div>' +
      '<div class="declare-notice-body">' + safeMessage + '</div>' +
      '<div class="declare-notice-actions">' +
        '<button type="button" class="declare-notice-btn" onclick="closeDeclareNotice()">확인</button>' +
      '</div>' +
    '</div>';

  document.body.appendChild(backdrop);
}

function closeDeclareNotice() {
  var el = document.getElementById('declare-notice-backdrop');
  if (el) {
    el.remove();
  }
}



function calcImportTaxAmountPreview() {
  var currEl = document.getElementById('imp-stlm-curr-cd');
  var dlvrEl = document.getElementById('imp-dlvr-cndtn-cd');

  var curr = currEl ? (currEl.value || '').toUpperCase() : 'USD';
  var dlvr = dlvrEl ? (dlvrEl.value || '').toUpperCase() : 'CIF';

  if (curr !== 'USD' || dlvr !== 'CIF') {
    showDeclareNotice(
      'warning',
      '세액계산 기준 확인',
      '현재 MVP 세액계산은 USD + CIF 기준만 지원합니다.\n\n'
      + '현재 결제통화: ' + (curr || '-') + '\n'
      + '현재 인도조건: ' + (dlvr || '-') + '\n\n'
      + '환율조회는 다른 통화도 가능하지만, 관세/부가세 자동계산은 USD + CIF 기준에서만 실행됩니다.'
    );
    return;
  }

  var totalTaxPriceKrwEl = document.getElementById('imp-tot-taxt-prc-krw');
  var totalCustomsEl = document.getElementById('imp-tot-cstms-amt');
  var vatBaseEl = document.getElementById('imp-vat-base-amt');
  var vatEl = document.getElementById('imp-tot-vat-amt');
  var totalTaxEl = document.getElementById('imp-tot-tax-amt');

  if (!totalTaxPriceKrwEl || !totalCustomsEl || !vatBaseEl || !vatEl || !totalTaxEl) {
    alert('세액 계산 영역을 찾을 수 없습니다.');
    return;
  }

  var commonTotalKrw = taxCalcParseNumber(totalTaxPriceKrwEl.value);

  if (commonTotalKrw <= 0) {
    alert('총과세가격 KRW가 없습니다.\n\n먼저 공통사항2에서 결제금액을 입력하고 환율조회를 해주세요.');
    return;
  }

  var calcItems = [];

  /*
   * 1. 이미 [추가]된 란사항 반영
   */
  if (typeof impItems !== 'undefined' && impItems && impItems.length > 0) {
    calcItems = impItems.slice();
  }

  /*
   * 2. 현재 작성 중인 란사항 반영
   */
  var currentItem = null;

  if (typeof readImpItemFromEditor === 'function') {
    currentItem = readImpItemFromEditor();
  }

  if (taxCalcHasTargetItem(currentItem)) {
    if (typeof selectedImpItemIndex !== 'undefined'
        && selectedImpItemIndex >= 0
        && selectedImpItemIndex < calcItems.length) {
      calcItems[selectedImpItemIndex] = currentItem;
    } else {
      calcItems.push(currentItem);
    }
  }

  if (!calcItems || calcItems.length === 0) {
    alert('계산할 란사항이 없습니다.\n\nHS코드, 과세가격, 세율을 입력해주세요.');
    return;
  }


  var itemTotalKrw = 0;
  var totalCustomsAmt = 0;
  var missingTaxPriceRows = [];
  var missingRateRows = [];

  for (var i = 0; i < calcItems.length; i++) {
    var item = calcItems[i];

    var itemTaxPrice = taxCalcParseNumber(item.idiTaxtPrcKrw);
    var itemRate = taxCalcParseNumber(item.idiTaxtRt);

    if (itemTaxPrice <= 0) {
      missingTaxPriceRows.push(i + 1);
      continue;
    }

    if (item.idiTaxtRt === null || item.idiTaxtRt === undefined || item.idiTaxtRt === '') {
      missingRateRows.push(i + 1);
    }

    itemTotalKrw += itemTaxPrice;
    totalCustomsAmt += Math.round(itemTaxPrice * itemRate / 100);
  }

  if (missingTaxPriceRows.length > 0) {
    alert(
      '란별 과세가격 KRW가 없는 항목이 있습니다.\n\n'
      + '여러 란 계산에서는 각 란의 과세가격 KRW가 필요합니다.\n'
      + '누락 란: ' + missingTaxPriceRows.join(', ')
    );
    return;
  }

  /*
   * 공통 총과세가격과 란사항 배분 합계 검증
   * 1원 단위 반올림 차이는 허용
   */
  var diff = Math.abs(Math.round(commonTotalKrw) - Math.round(itemTotalKrw));

  if (diff > 1) {
    showDeclareNotice(
      'warning',
      '총과세가격 검증 실패',
      '총과세가격과 란사항 과세가격 합계가 일치하지 않습니다.\n\n'
      + '공통사항2 총과세가격 KRW: ' + taxCalcFormatNumber(commonTotalKrw) + '원\n'
      + '란사항 과세가격 합계: ' + taxCalcFormatNumber(itemTotalKrw) + '원\n'
      + '차이: ' + taxCalcFormatNumber(diff) + '원\n\n'
      + '란사항 과세가격을 총과세가격에 맞게 배분한 뒤 다시 계산해주세요.'
    );
    return;
  }

  var vatBaseAmt = commonTotalKrw + totalCustomsAmt;
  var vatAmt = Math.round(vatBaseAmt * 0.1);
  var totalTaxAmt = totalCustomsAmt + vatAmt;

  /*
   * 총과세가격은 결제금액 × 환율로 산출된 기준값이므로 여기서 덮어쓰지 않는다.
   */
  totalCustomsEl.value = taxCalcFormatNumber(totalCustomsAmt);
  vatBaseEl.value = taxCalcFormatNumber(vatBaseAmt);
  vatEl.value = taxCalcFormatNumber(vatAmt);
  totalTaxEl.value = taxCalcFormatNumber(totalTaxAmt);



  var msg =
    '수입신고세액이 자동 계산되었습니다.\n\n'
    + '계산 란 수: ' + calcItems.length + '건\n'
    + '총과세가격: ' + taxCalcFormatNumber(commonTotalKrw) + '원\n'
    + '란사항 배분합계: ' + taxCalcFormatNumber(itemTotalKrw) + '원\n'
    + '총관세: ' + taxCalcFormatNumber(totalCustomsAmt) + '원\n'
    + '부가세과세표준: ' + taxCalcFormatNumber(vatBaseAmt) + '원\n'
    + '총부가세: ' + taxCalcFormatNumber(vatAmt) + '원\n'
    + '총세액합계: ' + taxCalcFormatNumber(totalTaxAmt) + '원';

  if (missingRateRows.length > 0) {
    msg += '\n\n※ 세율이 비어 있는 란 ' + missingRateRows.join(', ') + '은 0%로 계산되었습니다.';
  }

  showDeclareNotice('success', '세액계산 완료', msg);
}
/** 수입신고서 폼 데이터 수집 (2차 — 33 필드) */
function collectImpForm() {
  function val(id) {
    var el = document.getElementById(id);
    return el ? (el.value || '').trim() : '';
  }
  /** 빈 문자열은 null 로 (DB NULL 저장 위해) */
  function nullIfEmpty(s) { return s === '' ? null : s; }
  /** 숫자 필드: '' → null, 그 외 → 숫자 (콤마 제거) */
  function num(s) {
    if (!s) return null;
    var n = Number(String(s).replace(/,/g, ''));
    return isNaN(n) ? null : n;
  }

  // 이메일: local + '@' + (select 우선, 없으면 domain input)
  var emlLocal  = val('imp-dclrnt-eml-local');
  var emlDomain = val('imp-dclrnt-eml-select') || val('imp-dclrnt-eml-domain');
  var email = (emlLocal && emlDomain) ? (emlLocal + '@' + emlDomain) : '';

  // 전화: 번호(내선)
  var tel    = val('imp-dclrnt-tel');
  var telExt = val('imp-dclrnt-tel-ext');
  var phone  = tel ? (telExt ? (tel + '(' + telExt + ')') : tel) : '';

  // 입항일자: 'YYYY-MM-DD' → 'YYYYMMDD'
  var arvl = val('imp-arvl-ymd').replace(/-/g, '');

  // 코드 정규화 (대문자)
  var shipoutCntry = val('imp-shipout-cntry-cd').toUpperCase();
  var ovrssCntry   = val('imp-ovrss-cntry-cd').toUpperCase();

  // 통관의뢰번호 (IMP_RQST.IR_NO = IMP_DCLR.ID_IR_NO)
  //  - imp-declare-input 값을 1순위
  //  - 이어쓰기 모드면 window.impDclrData.idIrNo 도 fallback (페이지 진입 시 input 채워줌)
  var idIrNo = val('imp-declare-input');
  if (!idIrNo && window.impDclrData && window.impDclrData.idIrNo) {
    idIrNo = window.impDclrData.idIrNo;
  }

  return {
    idIrNo:            nullIfEmpty(idIrNo),
    // 신고인
    idDclrntNm:        nullIfEmpty(val('imp-dclrnt-nm')),
    idDclrntEml:       nullIfEmpty(email),
    idDclrntTelno:     nullIfEmpty(phone),
    // 수입자
    idImprNm:          nullIfEmpty(val('imp-impr-nm')),
    idImprClncCd:      nullIfEmpty(val('imp-impr-clnc-cd')),
	// 납세의무자
	idTaxpyrNm:        nullIfEmpty(val('imp-taxpyr-nm')),
	idTaxpyrClncCd:    nullIfEmpty(val('imp-taxpyr-clnc-cd')),
	idTaxpyrTelno:     nullIfEmpty(val('imp-taxpyr-tel')),
	idTaxpyrIdntSe:    nullIfEmpty(val('imp-taxpyr-idnt-se')),
    idTaxpyrIdntNo:    nullIfEmpty(val('imp-taxpyr-idnt-no')),
    idTaxpyrZip:       nullIfEmpty(val('imp-taxpyr-zip')),
    idTaxpyrAddr:      nullIfEmpty(val('imp-taxpyr-addr')),
    idTaxpyrDtlAddr:   nullIfEmpty(val('imp-taxpyr-dtl-addr')),
    // 해외공급자
    idOvrssNm:         nullIfEmpty(val('imp-ovrss-nm')),
    idOvrssCd:         nullIfEmpty(val('imp-ovrss-cd')),
    idOvrssCntryCd:    nullIfEmpty(ovrssCntry),
    // 기본신고사항
    idDclrSeCd:        nullIfEmpty(val('imp-dclr-se-cd')),
    idTrdngSeCd:       nullIfEmpty(val('imp-trdng-se-cd')),
    idImportClfcCd:    nullIfEmpty(val('imp-import-clfc-cd')),
    idCgoMngNo:        nullIfEmpty(val('imp-cgo-mng-no')),
    idInspPlceCd:      nullIfEmpty(val('imp-insp-plce-cd')),
    idArvlYmd:         nullIfEmpty(arvl),
    idShipoutCntryCd:  nullIfEmpty(shipoutCntry),
    idMblNo:           nullIfEmpty(val('imp-mbl-no')),
    idTrnspMnCd:       nullIfEmpty(val('imp-trnsp-mn-cd')),
    idCntnrSeCd:       nullIfEmpty(val('imp-cntnr-se-cd')),
    // 공통사항2 - 포장/가격/결제
    idTotPkgCnt:       num(val('imp-tot-pkg-cnt')),
	idTotPkgUnitCd:    nullIfEmpty(val('imp-tot-pkg-unit-cd')),
    idTotWt:           num(val('imp-tot-wt')),
    idOrgnCertYn:      nullIfEmpty(val('imp-orgn-cert-yn')),
	idStlmAmt:         num(val('imp-stlm-amt')),
	idDlvrCndtnCd:     'CIF',
    // 공통사항2 - 세액
    idTotTaxtPrcKrw:   num(val('imp-tot-taxt-prc-krw')),
    idTotTaxtPrcUsd:   num(val('imp-tot-taxt-prc-usd')),
    idTotCstmsAmt:     num(val('imp-tot-cstms-amt')),
    idVatBaseAmt:      num(val('imp-vat-base-amt')),
    idTotVatAmt:       num(val('imp-tot-vat-amt')),
    idTotTaxAmt:       num(val('imp-tot-tax-amt')),

    // 자식 — 란사항 목록 (3차)
    items: collectImpItems(),
    // 자식 — 모델/규격 목록 (4차)
   mdlspecs: buildMdlspecsForSubmit()
    // idIrNo, idStatusCd, idOfficerId, idRegistDt, idUpdtDt 는 서버에서 자동 처리
  };
}
/* ============================================================
 * 8E-PREVIEW — 수입신고서 미리보기 모달
 * ============================================================ */

function impPreviewEsc(value) {
  return String(value == null ? '' : value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function impPreviewVal(value) {
  if (value === null || value === undefined || value === '') {
    return '-';
  }
  return impPreviewEsc(value);
}

function impPreviewMoney(value) {
  if (value === null || value === undefined || value === '') {
    return '-';
  }

  var n = Number(String(value).replace(/,/g, ''));
  if (isNaN(n)) return impPreviewEsc(value);

  return n.toLocaleString();
}

function impPreviewRow(label, value) {
  return ''
    + '<div class="imp-preview-item">'
    + '  <div class="imp-preview-label">' + impPreviewEsc(label) + '</div>'
    + '  <div class="imp-preview-value">' + impPreviewVal(value) + '</div>'
    + '</div>';
}

function openImpPreviewModal() {
  var modal = document.getElementById('imp-preview-modal');
  var body = document.getElementById('imp-preview-body');

  if (!modal || !body) {
    alert('미리보기 모달 영역을 찾을 수 없습니다.');
    return;
  }

  var data = collectImpForm();

  var items = data.items || [];
  var mdlspecs = data.mdlspecs || [];

  var html = '';

  html += '<div class="imp-preview-section">';
  html += '<h4>기본 정보</h4>';
  html += '<div class="imp-preview-grid">';
  html += impPreviewRow('통관의뢰번호', data.idIrNo);
  html += impPreviewRow('신고인', data.idDclrntNm);
  html += impPreviewRow('신고인 이메일', data.idDclrntEml);
  html += impPreviewRow('신고인 전화번호', data.idDclrntTelno);
  html += impPreviewRow('수입자 상호', data.idImprNm);
  html += impPreviewRow('수입자 통관고유부호', data.idImprClncCd);
  html += impPreviewRow('납세의무자 상호', data.idTaxpyrNm);
  html += impPreviewRow('납세의무자 식별번호', data.idTaxpyrIdntNo);
  html += impPreviewRow('해외공급자', data.idOvrssNm);
  html += impPreviewRow('해외공급자 국적', data.idOvrssCntryCd);
  html += '</div>';
  html += '</div>';

  html += '<div class="imp-preview-section">';
  html += '<h4>신고 / 운송 정보</h4>';
  html += '<div class="imp-preview-grid">';
  html += impPreviewRow('신고구분', data.idDclrSeCd);
  html += impPreviewRow('거래구분', data.idTrdngSeCd);
  html += impPreviewRow('수입종류', data.idImportClfcCd);
  html += impPreviewRow('입항일자', data.idArvlYmd);
  html += impPreviewRow('적출국', data.idShipoutCntryCd);
  html += impPreviewRow('Master B/L', data.idMblNo);
  html += impPreviewRow('운송수단', data.idTrnspMnCd);
  html += impPreviewRow('컨테이너 구분', data.idCntnrSeCd);
  html += '</div>';
  html += '</div>';

  html += '<div class="imp-preview-section">';
  html += '<h4>공통사항2 / 세액</h4>';
  html += '<div class="imp-preview-grid">';
  html += impPreviewRow('총포장개수', data.idTotPkgCnt);
  html += impPreviewRow('총포장단위', data.idTotPkgUnitCd);
  html += impPreviewRow('총중량', data.idTotWt);
  html += impPreviewRow('원산지증명서', data.idOrgnCertYn);
  html += impPreviewRow('결제금액', impPreviewMoney(data.idStlmAmt));
  html += impPreviewRow('인도조건', data.idDlvrCndtnCd);
  html += impPreviewRow('총과세가격 KRW', impPreviewMoney(data.idTotTaxtPrcKrw));
  html += impPreviewRow('총과세가격 USD', impPreviewMoney(data.idTotTaxtPrcUsd));
  html += impPreviewRow('총관세', impPreviewMoney(data.idTotCstmsAmt));
  html += impPreviewRow('부가세 과세표준', impPreviewMoney(data.idVatBaseAmt));
  html += impPreviewRow('총부가세', impPreviewMoney(data.idTotVatAmt));
  html += impPreviewRow('총세액합계', impPreviewMoney(data.idTotTaxAmt));
  html += '</div>';
  html += '</div>';

  html += '<div class="imp-preview-section">';
  html += '<h4>란사항 ' + items.length + '건</h4>';

  if (items.length === 0) {
    html += '<div class="imp-preview-empty">등록된 란사항이 없습니다.</div>';
  } else {
    html += '<table class="imp-preview-table">';
    html += '<thead><tr>'
      + '<th>란</th>'
      + '<th>HS코드</th>'
      + '<th>신고품명</th>'
      + '<th>거래품명</th>'
      + '<th>세율</th>'
      + '<th>과세가격 KRW</th>'
      + '<th>과세가격 USD</th>'
      + '<th>원산지</th>'
      + '</tr></thead><tbody>';

    items.forEach(function (item, idx) {
      html += '<tr>'
        + '<td>' + (idx + 1) + '</td>'
        + '<td>' + impPreviewVal(item.idiHsCd) + '</td>'
        + '<td>' + impPreviewVal(item.idiDclrGdsnm) + '</td>'
        + '<td>' + impPreviewVal(item.idiTrdngGdsnm) + '</td>'
        + '<td>' + impPreviewVal(item.idiTaxtRt) + '%</td>'
        + '<td style="text-align:right">' + impPreviewMoney(item.idiTaxtPrcKrw) + '</td>'
        + '<td style="text-align:right">' + impPreviewMoney(item.idiTaxtPrcUsd) + '</td>'
        + '<td>' + impPreviewVal(item.idiOrgnCntryCd) + '</td>'
        + '</tr>';
    });

    html += '</tbody></table>';
  }

  html += '</div>';

  html += '<div class="imp-preview-section">';
  html += '<h4>모델/규격 ' + mdlspecs.length + '건</h4>';

  if (mdlspecs.length === 0) {
    html += '<div class="imp-preview-empty">등록된 모델/규격이 없습니다.</div>';
  } else {
    html += '<table class="imp-preview-table">';
    html += '<thead><tr>'
      + '<th>소속 란</th>'
      + '<th>규격번호</th>'
      + '<th>규격명</th>'
      + '<th>수량</th>'
      + '<th>단위</th>'
      + '<th>단가</th>'
      + '<th>금액</th>'
      + '</tr></thead><tbody>';

    mdlspecs.forEach(function (m) {
      html += '<tr>'
        + '<td>' + impPreviewVal(m.idimSn) + '</td>'
        + '<td>' + impPreviewVal(m.idimMdlspecNo) + '</td>'
        + '<td>' + impPreviewVal(m.idimMdlspecNm) + '</td>'
        + '<td style="text-align:right">' + impPreviewMoney(m.idimQty1) + '</td>'
        + '<td>' + impPreviewVal(m.idimQty1UnitCd) + '</td>'
        + '<td style="text-align:right">' + impPreviewMoney(m.idimUnitPrc) + '</td>'
        + '<td style="text-align:right">' + impPreviewMoney(m.idimAmt) + '</td>'
        + '</tr>';
    });

    html += '</tbody></table>';
  }

  html += '</div>';

  body.innerHTML = html;
  modal.style.display = 'flex';
}

function closeImpPreviewModal() {
  var modal = document.getElementById('imp-preview-modal');
  if (modal) {
    modal.style.display = 'none';
  }
}
/* ============================================================
 * 3차 — 란사항 실무형 관리
 *  - 입력폼은 1개만 사용
 *  - [추가] 클릭 시 impItems 배열에 저장
 *  - 아래 란 목록은 impItems 요약 표시
 *  - 목록 클릭 시 입력폼에 다시 로드
 * ============================================================ */

var impItems = [];
var selectedImpItemIndex = -1;

function itemNum(s) {
  if (s === null || s === undefined || s === '') return null;
  var n = Number(String(s).replace(/,/g, ''));
  return isNaN(n) ? null : n;
}

function itemStr(s) {
  s = (s || '').trim();
  return s === '' ? null : s;
}

function getCurrentItemRow() {
  var container = document.getElementById('imp-items-container');
  if (!container) return null;
  return container.querySelector('.imp-item-row');
}

/**
 * 기존 addItemRow 이름 유지
 * - 기존 페이지 로드 코드/AI 코드가 addItemRow()를 호출하고 있어서 함수명은 유지한다.
 * - data가 없으면 입력폼 1개만 새로 그림
 * - data가 있으면 란 목록 배열에 추가한다.
 */
function addItemRow(data) {
  if (data) {
    var item = normalizeImpItem(data);
    item.idiSn = impItems.length + 1;
    impItems.push(item);
    selectedImpItemIndex = impItems.length - 1;
    renderImpItemList();
    renderImpItemEditor(null);
    return null;
  }

  renderImpItemEditor(null);
  renderImpItemList();
  return getCurrentItemRow();
}

/** 입력폼 1개 렌더링 */
function renderImpItemEditor(data) {
  var tmpl = document.getElementById('imp-item-template');
  var container = document.getElementById('imp-items-container');
  if (!tmpl || !container) return null;

  container.innerHTML = '';

  var clone = tmpl.content.firstElementChild.cloneNode(true);
  container.appendChild(clone);

  var snEl = clone.querySelector('.item-sn-display');
  if (snEl) {
    snEl.textContent = selectedImpItemIndex >= 0 ? (selectedImpItemIndex + 1) : '신규';
  }

  var delBtn = clone.querySelector('button[onclick^="removeItemRow"]');
  if (delBtn) {
    delBtn.style.display = 'none';
  }

  if (data) {
    fillItemRow(clone, data);
  }

  refreshItemSnDisplay();
  refreshHsAiRecommendButtons();
  recalcCurrentItemTaxDisplay();
  return clone;
}

/** 기존 삭제 버튼 호환용 — 실무형에서는 입력폼 초기화로 처리 */
function removeItemRow(btn) {
  clearImpItemEditor();
}

/** 란 건수 표시 갱신 */
function refreshItemSnDisplay() {
  var cnt = document.getElementById('imp-items-count');
  if (cnt) cnt.textContent = impItems.length;
}

/** 서버/AI 데이터 정규화 */
function normalizeImpItem(d) {
  d = d || {};
  return {
    idiSn:            d.idiSn || null,
    idiCstmsDvsnCd:   d.idiCstmsDvsnCd || null,
    idiHsCd:          d.idiHsCd || null,
    idiTaxtStndrdCd:  d.idiTaxtStndrdCd || null,
    idiTaxtRt:        itemNum(d.idiTaxtRt),

    idiDclrGdsnm:     d.idiDclrGdsnm || null,
    idiTrdmkNm:       d.idiTrdmkNm || null,
    idiTrdmkCd:       d.idiTrdmkCd || null,
    idiTrdngGdsnm:    d.idiTrdngGdsnm || null,

    idiTaxtPrcKrw:    itemNum(d.idiTaxtPrcKrw),
    idiTaxtPrcUsd:    itemNum(d.idiTaxtPrcUsd),
    idiNetWt:         itemNum(d.idiNetWt),
    idiQty:           itemNum(d.idiQty),
    idiQtyUnitCd:     d.idiQtyUnitCd || null,

    idiOrgnCntryCd:   d.idiOrgnCntryCd || null,
    idiOrgnDtrmnCd:   d.idiOrgnDtrmnCd || null,

    // 2단계에서 모델/규격을 이 안에 붙일 예정
    mdlspecs:         d.mdlspecs || []
  };
}

/** 입력폼에 ItemVO 데이터 채우기 */
function fillItemRow(row, d) {
  function set(cls, value) {
    var el = row.querySelector('.' + cls);
    if (!el) return;
    el.value = (value === null || value === undefined) ? '' : value;
  }

  set('item-cstms-dvsn-cd',  d.idiCstmsDvsnCd);
  set('item-hs-cd',          d.idiHsCd);
  set('item-taxt-stndrd-cd', d.idiTaxtStndrdCd);
  set('item-taxt-rt',        d.idiTaxtRt);
  set('item-dclr-gdsnm',     d.idiDclrGdsnm);
  set('item-trdmk-nm',       d.idiTrdmkNm);
  set('item-trdmk-cd',       d.idiTrdmkCd);
  set('item-trdng-gdsnm',    d.idiTrdngGdsnm);
  set('item-taxt-prc-krw',   d.idiTaxtPrcKrw);
  set('item-taxt-prc-usd',   d.idiTaxtPrcUsd);
  set('item-net-wt',         d.idiNetWt);
  set('item-qty',            d.idiQty);
  set('item-qty-unit-cd',    d.idiQtyUnitCd);
  set('item-orgn-cntry-cd',  d.idiOrgnCntryCd);
  set('item-orgn-dtrmn-cd',  d.idiOrgnDtrmnCd);
  
  if (d.idiOrgnCntryCd) {
    findCountryNameFromDb(d.idiOrgnCntryCd, 'imp-item-orgn-cntry-nm');
  }
}

/** 현재 입력폼 값 읽기 */
function readImpItemFromEditor() {
  var row = getCurrentItemRow();
  if (!row) return null;

  function v(cls) {
    var el = row.querySelector('.' + cls);
    return el ? (el.value || '').trim() : '';
  }

  return normalizeImpItem({
    idiSn:            selectedImpItemIndex >= 0 ? selectedImpItemIndex + 1 : impItems.length + 1,
    idiCstmsDvsnCd:   itemStr(v('item-cstms-dvsn-cd')),
    idiHsCd:          itemStr(v('item-hs-cd')),
    idiTaxtStndrdCd:  itemStr(v('item-taxt-stndrd-cd')),
    idiTaxtRt:        itemNum(v('item-taxt-rt')),

    idiDclrGdsnm:     itemStr(v('item-dclr-gdsnm')),
    idiTrdmkNm:       itemStr(v('item-trdmk-nm')),
    idiTrdmkCd:       itemStr(v('item-trdmk-cd')),
    idiTrdngGdsnm:    itemStr(v('item-trdng-gdsnm')),

    idiTaxtPrcKrw:    itemNum(v('item-taxt-prc-krw')),
    idiTaxtPrcUsd:    itemNum(v('item-taxt-prc-usd')),
    idiNetWt:         itemNum(v('item-net-wt')),
    idiQty:           itemNum(v('item-qty')),
    idiQtyUnitCd:     itemStr(v('item-qty-unit-cd')),

    idiOrgnCntryCd:   itemStr(v('item-orgn-cntry-cd')),
    idiOrgnDtrmnCd:   itemStr(v('item-orgn-dtrmn-cd'))
  });
}


function getCommonTotalTaxPriceKrw() {
  var el = document.getElementById('imp-tot-taxt-prc-krw');
  if (!el) return 0;

  var n = Number(String(el.value || '0').replace(/,/g, '').trim());
  return isNaN(n) ? 0 : n;
}

function getCurrentImpItemTotalKrw(excludeIndex) {
  var total = 0;

  if (typeof impItems !== 'undefined' && impItems && impItems.length > 0) {
    impItems.forEach(function (item, idx) {
      if (excludeIndex !== undefined && excludeIndex !== null && idx === excludeIndex) {
        return;
      }

      var n = Number(String(item.idiTaxtPrcKrw || '0').replace(/,/g, '').trim());
      if (!isNaN(n)) {
        total += n;
      }
    });
  }

  return total;
}

function validateItemTaxPriceLimit(item, excludeIndex) {
  var commonTotalKrw = getCommonTotalTaxPriceKrw();

  /*
   * 환율조회 전이면 총과세가격이 없으므로 여기서는 막지 않는다.
   * 단, 세액계산 버튼에서는 총과세가격 필수로 다시 검증한다.
   */
  if (commonTotalKrw <= 0) {
    return true;
  }

  var itemKrw = Number(String(item && item.idiTaxtPrcKrw || '0').replace(/,/g, '').trim());
  if (isNaN(itemKrw)) itemKrw = 0;

  var currentTotalKrw = getCurrentImpItemTotalKrw(excludeIndex);
  var nextTotalKrw = currentTotalKrw + itemKrw;

  if (nextTotalKrw > commonTotalKrw) {
    alert(
      '란사항 과세가격 합계가 공통사항2 총과세가격을 초과합니다.\n\n'
      + '공통사항2 총과세가격 KRW: ' + commonTotalKrw.toLocaleString() + '원\n'
      + '기존 란사항 합계: ' + currentTotalKrw.toLocaleString() + '원\n'
      + '현재 입력 란 과세가격: ' + itemKrw.toLocaleString() + '원\n'
      + '초과 후 합계: ' + nextTotalKrw.toLocaleString() + '원\n\n'
      + '란사항 과세가격은 총과세가격을 품목별로 배분한 금액이어야 합니다.'
    );
    return false;
  }

  return true;
}

/** 란사항 필수값 검증 */
function validateImpItem(item) {
  if (!item) return false;

  if (!item.idiHsCd) {
    alert('HS부호를 입력해주세요.');
    var row = getCurrentItemRow();
    var el = row && row.querySelector('.item-hs-cd');
    if (el) el.focus();
    return false;
  }

  if (!item.idiDclrGdsnm) {
    alert('신고품명을 입력해주세요.');
    var row2 = getCurrentItemRow();
    var el2 = row2 && row2.querySelector('.item-dclr-gdsnm');
    if (el2) el2.focus();
    return false;
  }
  if (!item.idiTaxtPrcUsd || item.idiTaxtPrcUsd <= 0) {
    showDeclareNotice(
      'warning',
      '란사항 과세가격 누락',
      '란사항 과세가격 USD를 입력해주세요.\n\n'
      + '현재 구조에서는 USD 과세가격을 입력하면 환율을 기준으로 KRW 과세가격이 자동 계산됩니다.'
    );

    var row3 = getCurrentItemRow();
    var el3 = row3 && row3.querySelector('.item-taxt-prc-usd');
    if (el3) el3.focus();
    return false;
  }
  return true;
}

/** [추가] — 현재 입력폼 값을 란 목록에 추가 */
function addImpItemFromForm() {
  recalcCurrentItemKrwFromUsd();

  var item = readImpItemFromEditor();
  if (!validateImpItem(item)) return;
  if (!validateItemTaxPriceLimit(item, null)) return;

  // 현재 화면에 입력된 모델/규격을 새 란에 붙임

  // 현재 화면에 입력된 모델/규격을 새 란에 붙임
  item.mdlspecs = collectMdlspecs();

  item.idiSn = impItems.length + 1;
  impItems.push(item);

  selectedImpItemIndex = -1;

  renderImpItemList();
  renderImpItemEditor(null);
  clearMdlspecEditor();

  alert('란사항이 추가되었습니다.');
}

/** [수정] — 선택된 란을 현재 입력폼 값으로 갱신 */
function updateSelectedImpItem() {
  if (selectedImpItemIndex < 0 || selectedImpItemIndex >= impItems.length) {
    alert('수정할 란을 아래 란 목록에서 먼저 선택해주세요.');
    return;
  }

  recalcCurrentItemKrwFromUsd();

  var item = readImpItemFromEditor();
  if (!validateImpItem(item)) return;
  if (!validateItemTaxPriceLimit(item, selectedImpItemIndex)) return;

  item.idiSn = selectedImpItemIndex + 1;

  // 현재 화면의 모델/규격을 선택된 란에 저장
  item.mdlspecs = collectMdlspecs();

  impItems[selectedImpItemIndex] = item;

  renderImpItemList();

  alert('란사항과 모델/규격이 수정되었습니다.');
}

/** [삭제] — 선택된 란 삭제 */
function deleteSelectedImpItem() {
  if (selectedImpItemIndex < 0 || selectedImpItemIndex >= impItems.length) {
    alert('삭제할 란을 아래 란 목록에서 먼저 선택해주세요.');
    return;
  }

  if (!confirm('선택한 란사항과 해당 모델/규격을 삭제하시겠습니까?')) {
    return;
  }

  impItems.splice(selectedImpItemIndex, 1);

  impItems.forEach(function (item, idx) {
    item.idiSn = idx + 1;
  });

  selectedImpItemIndex = -1;

  renderImpItemList();
  renderImpItemEditor(null);
  clearMdlspecEditor();
}

/** [초기화] — 입력폼만 비움 */
function clearImpItemEditor() {
  selectedImpItemIndex = -1;
  renderImpItemEditor(null);
  clearMdlspecEditor();
  renderImpItemList();
}

/** 란 목록 클릭 → 입력폼에 로드 */
function loadImpItemToEditor(index) {
  if (index < 0 || index >= impItems.length) return;

  // 다른 란으로 이동하기 전에 현재 선택된 란의 모델/규격 변경분 저장
  syncCurrentMdlspecsToSelectedItem();

  selectedImpItemIndex = index;

  renderImpItemEditor(impItems[index]);
  fillMdlspecs(impItems[index].mdlspecs || []);
  renderImpItemList();
}


function updateMdlspecCurrentItemLabel() {
  var label = document.getElementById('mdlspec-current-item-label');
  if (!label) return;

  if (selectedImpItemIndex < 0 || selectedImpItemIndex >= impItems.length) {
    label.textContent = '현재 작성 중인 란';
    return;
  }

  var item = impItems[selectedImpItemIndex];
  label.textContent =
    (selectedImpItemIndex + 1) + '란'
    + (item.idiHsCd ? ' / HS ' + item.idiHsCd : '')
    + (item.idiDclrGdsnm ? ' / ' + item.idiDclrGdsnm : '');
	
}

/** 란 목록 렌더링 */
function renderImpItemList() {
  var tbody = document.getElementById('imp-item-list-tbody');
  if (!tbody) {
    refreshItemSnDisplay();
	updateMdlspecCurrentItemLabel();
    return;
  }

  if (!impItems || impItems.length === 0) {
    tbody.innerHTML =
      '<tr style="color:#a0b4c8;text-align:center">' +
        '<td colspan="9" style="padding:20px;font-size:12px">란사항을 입력 후 [추가] 버튼을 클릭하세요</td>' +
      '</tr>';
    refreshItemSnDisplay();
	updateMdlspecCurrentItemLabel();
    return;
  }

  function esc(s) {
    return (s == null) ? '' : String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function money(v) {
    if (v == null || v === '') return '';
    var n = Number(String(v).replace(/,/g, ''));
    return isNaN(n) ? esc(v) : n.toLocaleString();
  }

  var html = '';

  impItems.forEach(function (item, idx) {
    var selected = selectedImpItemIndex === idx;
    var bg = selected ? 'background:#eef4ff;' : '';
    var mdlspecCnt = item.mdlspecs ? item.mdlspecs.length : 0;

    html +=
      '<tr style="cursor:pointer;' + bg + '" onclick="loadImpItemToEditor(' + idx + ')">' +
        '<td style="text-align:center">' +
          '<input type="radio" name="impItemSelect" ' + (selected ? 'checked' : '') + ' onclick="event.stopPropagation();loadImpItemToEditor(' + idx + ')">' +
        '</td>' +
        '<td style="text-align:center;font-weight:700">' + (idx + 1) + '</td>' +
        '<td style="font-family:monospace">' + esc(item.idiHsCd) + '</td>' +
        '<td>' + esc(item.idiDclrGdsnm) + '</td>' +
        '<td>' + esc(item.idiTrdngGdsnm) + '</td>' +
        '<td style="text-align:right">' + (item.idiTaxtRt != null ? esc(item.idiTaxtRt) + '%' : '') + '</td>' +
        '<td style="text-align:right">' + money(item.idiQty) + ' ' + esc(item.idiQtyUnitCd) + '</td>' +
        '<td style="text-align:right">' + money(item.idiTaxtPrcKrw) + '</td>' +
        '<td style="text-align:center">' + mdlspecCnt + '건</td>' +
      '</tr>';
  });

  tbody.innerHTML = html;
  refreshItemSnDisplay();
  updateMdlspecCurrentItemLabel();
}

/** 저장용 — ImpDclrItemVO 배열 반환 */
function collectImpItems() {
  return impItems.map(function (item, idx) {
    return {
      idiSn:            idx + 1,
      idiCstmsDvsnCd:   item.idiCstmsDvsnCd,
      idiHsCd:          item.idiHsCd,
      idiTaxtStndrdCd:  item.idiTaxtStndrdCd,
      idiTaxtRt:        item.idiTaxtRt,
      idiDclrGdsnm:     item.idiDclrGdsnm,
      idiTrdmkNm:       item.idiTrdmkNm,
      idiTrdmkCd:       item.idiTrdmkCd,
      idiTrdngGdsnm:    item.idiTrdngGdsnm,
      idiTaxtPrcKrw:    item.idiTaxtPrcKrw,
      idiTaxtPrcUsd:    item.idiTaxtPrcUsd,
      idiNetWt:         item.idiNetWt,
      idiQty:           item.idiQty,
      idiQtyUnitCd:     item.idiQtyUnitCd,
      idiOrgnCntryCd:   item.idiOrgnCntryCd,
      idiOrgnDtrmnCd:   item.idiOrgnDtrmnCd
    };
  });
}

/** 이어쓰기 — 서버에서 받은 items 배열을 실무형 목록으로 복원 */
function fillImpItems(items) {
  impItems = [];

  if (items && items.length > 0) {
    items.forEach(function (it, idx) {
      var item = normalizeImpItem(it);
      item.idiSn = idx + 1;
      impItems.push(item);
    });
  }

  selectedImpItemIndex = -1;

  renderImpItemList();
  renderImpItemEditor(null);
}

/* ============================================================
 * 4차 — 모델/규격 실무형 관리
 *  - 모델/규격은 신고서 전체가 아니라 선택된 란사항에 종속
 *  - 화면에는 현재 선택/작성 중인 란의 모델/규격만 표시
 *  - 저장 직전 impItems[].mdlspecs 를 펼쳐서 vo.mdlspecs 로 전송
 * ============================================================ */

/** 빈 mdlspec row 1개 추가 */
function addMdlspecRow(data) {
  var tmpl = document.getElementById('mdlspec-row-template');
  var tbody = document.getElementById('mdlspec-tbody');
  if (!tmpl || !tbody) return null;

  var clone = tmpl.content.firstElementChild.cloneNode(true);
  tbody.appendChild(clone);

  if (data) fillMdlspecRow(clone, data);

  refreshMdlspecNoDisplay();
  return clone;
}
function ensureMdlspecRow() {
  var tbody = document.getElementById('mdlspec-tbody');
  if (!tbody) return;

  if (tbody.querySelectorAll('.mdlspec-row').length === 0) {
    addMdlspecRow();
	
  }
}

/** mdlspec row 삭제 */
function removeMdlspecRow(btn) {
  var tbody = document.getElementById('mdlspec-tbody');
  if (!tbody) return;

  var row = btn.closest('.mdlspec-row');
  if (!row) return;

  var rows = tbody.querySelectorAll('.mdlspec-row');

  // 마지막 1개 남았을 때는 삭제하지 않고 비움
  if (rows.length <= 1) {
    clearMdlspecRow(row);
    syncCurrentMdlspecsToSelectedItem();
    return;
  }

  row.remove();
  refreshMdlspecNoDisplay();
  syncCurrentMdlspecsToSelectedItem();
}

/** 모델/규격 행 비우기 */
function clearMdlspecRow(row) {
  if (!row) return;

  row.querySelectorAll('input, textarea').forEach(function (el) {
    el.value = '';
  });

  var firstNo = row.querySelector('.mdlspec-mdlspec-no');
  if (firstNo) firstNo.value = '01';
}

function refreshMdlspecNoDisplay() {
  var rows = document.querySelectorAll('#mdlspec-tbody .mdlspec-row');

  rows.forEach(function (row, idx) {
    var noInput = row.querySelector('.mdlspec-mdlspec-no');
    if (!noInput) return;

    // 사용자가 이미 값을 직접 입력한 경우도 화면 정렬을 위해 01, 02, 03으로 맞춤
    noInput.value = String(idx + 1).padStart(2, '0');
  });
}
/** mdlspec 1행에 데이터 채우기 */
function fillMdlspecRow(row, d) {
  d = d || {};

  function set(cls, value) {
    var el = row.querySelector('.' + cls);
    if (!el) return;
    el.value = (value === null || value === undefined) ? '' : value;
  }

  set('mdlspec-mdlspec-no',    d.idimMdlspecNo);
  set('mdlspec-mdlspec-nm',    d.idimMdlspecNm);
  set('mdlspec-qty1',          d.idimQty1);
  set('mdlspec-qty1-unit-cd',  d.idimQty1UnitCd);
  set('mdlspec-unit-prc',      d.idimUnitPrc);
  set('mdlspec-amt',           d.idimAmt);
}

/** 현재 화면의 모델/규격 row들을 수집 */
function collectMdlspecs() {
  function num(s) {
    if (!s) return null;
    var n = Number(String(s).replace(/,/g, ''));
    return isNaN(n) ? null : n;
  }

  function str(s) {
    s = (s || '').trim();
    return s === '' ? null : s;
  }

  var rows = document.querySelectorAll('#mdlspec-tbody .mdlspec-row');
  var arr = [];

  rows.forEach(function (row) {
    function v(cls) {
      var el = row.querySelector('.' + cls);
      return el ? (el.value || '').trim() : '';
    }

    var allEmpty =
      !v('mdlspec-mdlspec-no') &&
      !v('mdlspec-mdlspec-nm') &&
      !v('mdlspec-qty1') &&
      !v('mdlspec-qty1-unit-cd') &&
      !v('mdlspec-unit-prc') &&
      !v('mdlspec-amt');

    if (allEmpty) return;

    arr.push({
      // idimSn은 여기서 넣지 않음.
      // 저장 직전 buildMdlspecsForSubmit()에서 소속 란번호로 세팅함.
      idimMdlspecNo:  str(v('mdlspec-mdlspec-no')),
      idimMdlspecNm:  str(v('mdlspec-mdlspec-nm')),
      idimQty1:       num(v('mdlspec-qty1')),
      idimQty1UnitCd: str(v('mdlspec-qty1-unit-cd')),
      idimUnitPrc:    num(v('mdlspec-unit-prc')),
      idimAmt:        num(v('mdlspec-amt'))
    });
  });

  return arr;
}

/** 현재 선택된 란에 화면의 모델/규격을 저장 */
function syncCurrentMdlspecsToSelectedItem() {
  if (selectedImpItemIndex < 0 || selectedImpItemIndex >= impItems.length) {
    return;
  }

  impItems[selectedImpItemIndex].mdlspecs = collectMdlspecs();
}

/** 현재 선택/작성 중인 란의 모델/규격을 화면에 출력 */
function fillMdlspecs(mdlspecs) {
  var tbody = document.getElementById('mdlspec-tbody');
  if (!tbody) return;

  tbody.innerHTML = '';

  if (!mdlspecs || mdlspecs.length === 0) {
    ensureMdlspecRow();
    updateMdlspecCurrentItemLabel();
    return;
  }

  mdlspecs.forEach(function (m) {
    addMdlspecRow(m);
  });

  ensureMdlspecRow();
  updateMdlspecCurrentItemLabel();
}

/** 모델/규격 화면 초기화 */
function clearMdlspecEditor() {
  fillMdlspecs([]);
}

/**
 * 저장 전 모델/규격 flatten
 * impItems[0].mdlspecs → idimSn = 1
 * impItems[1].mdlspecs → idimSn = 2
 */
function buildMdlspecsForSubmit() {
  // 현재 선택된 란을 편집 중이었다면 최신 모델/규격 반영
  syncCurrentMdlspecsToSelectedItem();

  var result = [];

  impItems.forEach(function (item, itemIndex) {
    var itemSn = itemIndex + 1;

    (item.mdlspecs || []).forEach(function (m) {
      result.push({
        idimSn:         itemSn, // 핵심: 소속 란번호
        idimMdlspecNo:  m.idimMdlspecNo || null,
        idimMdlspecNm:  m.idimMdlspecNm || null,
        idimQty1:       m.idimQty1 == null ? null : m.idimQty1,
        idimQty1UnitCd: m.idimQty1UnitCd || null,
        idimUnitPrc:    m.idimUnitPrc == null ? null : m.idimUnitPrc,
        idimAmt:        m.idimAmt == null ? null : m.idimAmt
      });
    });
  });

  return result;
}

/**
 * 이어쓰기용
 * 서버에서 받은 mdlspecs를 idimSn 기준으로 impItems에 다시 묶음
 */
function attachMdlspecsToItems(mdlspecs) {
  if (!impItems || impItems.length === 0) return;

  impItems.forEach(function (item) {
    item.mdlspecs = [];
  });

  if (!mdlspecs || mdlspecs.length === 0) return;

  mdlspecs.forEach(function (m) {
    var sn = Number(m.idimSn || 0);
    if (!sn || sn < 1 || sn > impItems.length) return;

    impItems[sn - 1].mdlspecs.push({
      idimMdlspecNo:  m.idimMdlspecNo,
      idimMdlspecNm:  m.idimMdlspecNm,
      idimQty1:       m.idimQty1,
      idimQty1UnitCd: m.idimQty1UnitCd,
      idimUnitPrc:    m.idimUnitPrc,
      idimAmt:        m.idimAmt
    });
  });
}

/** 수입신고서 임시저장 (신규 INSERT 또는 이어쓰기 UPDATE) */
function saveImpDraft() {
  var data = collectImpForm();

  // 클라이언트 검증 — 통관의뢰번호 필수
  if (!data.idIrNo) {
    alert('통관의뢰번호가 없습니다.\n[기존 신고서 조회] 영역에서 의뢰번호를 입력하고 [조회] 버튼을 눌러주세요.');
    var elNo = document.getElementById('imp-declare-input');
    if (elNo) elNo.focus();
    return;
  }
  // 수입자 상호 필수
  if (!data.idImprNm) {
    alert('수입자 상호는 필수 입력값입니다.');
    var el = document.getElementById('imp-impr-nm');
    if (el) el.focus();
    return;
  }

  var ctx = window.contextPath || '';
  var btn = event && event.currentTarget;
  if (btn) btn.disabled = true;

  fetch(ctx + '/broker/declare/saveImpDraft.do', {
    method: 'POST',
	headers: Object.assign({
	  'Content-Type': 'application/json'
	}, getCsrfHeaders()),
    body: JSON.stringify(data)
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (res.success) {
        alert('✅ ' + res.message + '\n\n임시문서함에서 조회 가능합니다.');
        // 신규 저장 후엔 응답받은 idIrNo 를 window 에 주입 → 다음 저장은 UPDATE 가 됨
        if (res.idIrNo) {
          window.impDclrData = window.impDclrData || {};
          window.impDclrData.idIrNo = res.idIrNo;
        }
      } else {
        alert('❌ ' + (res.message || '저장에 실패했습니다.'));
      }
    })
    .catch(function (err) {
      console.error(err);
      alert('❌ 통신 오류: ' + err.message);
    })
    .finally(function () {
      if (btn) btn.disabled = false;
    });
}

/*
 * 8E-DELETE
 * 현재 수입신고서 임시저장 삭제
 */
function deleteImpDraft() {
  var data = collectImpForm();
  var idIrNo = data.idIrNo;

  if (!idIrNo) {
    alert('삭제할 통관의뢰번호가 없습니다.');
    return;
  }

  if (!confirm('현재 임시저장 신고서를 삭제하시겠습니까?\n\n전송된 신고서는 삭제할 수 없습니다.')) {
    return;
  }

  var formData = new FormData();
  formData.append('idIrNo', idIrNo);

  var ctx = window.contextPath || '';

  fetch(ctx + '/broker/declare/deleteImpDraft.do', {
    method: 'POST',
    headers: getCsrfHeaders(),
    body: formData
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        alert('❌ ' + (res.message || '삭제에 실패했습니다.'));
        return;
      }

      alert('✅ ' + res.message);
      location.href = ctx + '/broker/declare/imp.do';
    })
    .catch(function (err) {
      console.error(err);
      alert('❌ 삭제 통신 오류: ' + err.message);
    });
}


/** 수입신고서 전송 (TEMP → SUBMIT)
 *  · 마지막 저장 + status 변경을 서버에서 일괄 처리
 *  · 전송 후 임시저장 흐름에서는 수정 불가
 */
function sendImp() {
  var data = collectImpForm();

  // 클라이언트 검증 — 통관의뢰번호 필수
  if (!data.idIrNo) {
    alert('통관의뢰번호가 없습니다.\n[기존 신고서 조회] 영역에서 의뢰번호를 입력하고 [조회] 버튼을 눌러주세요.');
    var elNo = document.getElementById('imp-declare-input');
    if (elNo) elNo.focus();
    return;
  }
  // 수입자 상호 필수
  if (!data.idImprNm) {
    alert('수입자 상호는 필수 입력값입니다.');
    var el = document.getElementById('imp-impr-nm');
    if (el) el.focus();
    return;
  }

  // 전송 확인
  if (!confirm('신고서를 전송하시겠습니까?\n전송 후에는 수정할 수 없습니다.')) {
    return;
  }

  var ctx = window.contextPath || '';
  var btn = event && event.currentTarget;
  if (btn) btn.disabled = true;

  fetch(ctx + '/broker/declare/sendImp.do', {
    method: 'POST',
	headers: Object.assign({
	  'Content-Type': 'application/json'
	}, getCsrfHeaders()),
    body: JSON.stringify(data)
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (res.success) {
        alert(res.message);
        // 전송 완료 후엔 임시저장 흐름 종료 → 대시보드로 이동
        // (필요시 발신문서함으로 변경: ctx + '/broker/docs/sent.do')
        location.href = ctx + '/broker/dashboard.do';
      } else {
        alert('❌ ' + (res.message || '전송에 실패했습니다.'));
      }
    })
    .catch(function (err) {
      console.error(err);
      alert('❌ 통신 오류: ' + err.message);
    })
    .finally(function () {
      if (btn) btn.disabled = false;
    });
}

/* ============================================================
 * 이어쓰기 — 서버에서 받은 데이터로 폼 채우기
 * ============================================================ */

function fillImpForm(d) {
  if (!d) return;

  function setVal(id, value) {
    var el = document.getElementById(id);
    if (!el) return;
    if (value === null || value === undefined) { el.value = ''; return; }
    el.value = value;
  }

  // 통관의뢰번호 — "기존 신고서 조회" input 에도 표시 (재저장 시 사용)
  setVal('imp-declare-input', d.idIrNo);

  // 신고인
  setVal('imp-dclrnt-nm', d.idDclrntNm);
  // 이메일은 'local@domain' 으로 들어옴 → split
  if (d.idDclrntEml && d.idDclrntEml.indexOf('@') > -1) {
    var parts = d.idDclrntEml.split('@');
    setVal('imp-dclrnt-eml-local',  parts[0]);
    setVal('imp-dclrnt-eml-domain', parts[1]);
    // select 가 일치하는 도메인이면 함께 세팅
    var sel = document.getElementById('imp-dclrnt-eml-select');
    if (sel) {
      var match = false;
      for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value === parts[1]) { sel.selectedIndex = i; match = true; break; }
      }
      if (!match) sel.selectedIndex = 0;
    }
  }
  // 전화는 '010-1234-5678(101)' 형식 → split
  if (d.idDclrntTelno) {
    var m = d.idDclrntTelno.match(/^(.+?)(?:\((.*)\))?$/);
    if (m) {
      setVal('imp-dclrnt-tel',     m[1] || '');
      setVal('imp-dclrnt-tel-ext', m[2] || '');
    }
  }

  // 수입자
  setVal('imp-impr-nm',       d.idImprNm);
  setVal('imp-impr-clnc-cd',  d.idImprClncCd);

  // 납세의무자
  setVal('imp-taxpyr-nm', d.idTaxpyrNm);
  setVal('imp-taxpyr-clnc-cd', d.idTaxpyrClncCd);
  setVal('imp-taxpyr-tel', d.idTaxpyrTelno);
  setVal('imp-taxpyr-idnt-se', d.idTaxpyrIdntSe);
  setVal('imp-taxpyr-idnt-no', d.idTaxpyrIdntNo);
  setVal('imp-taxpyr-zip',     d.idTaxpyrZip);
  setVal('imp-taxpyr-addr',    d.idTaxpyrAddr);
  setVal('imp-taxpyr-dtl-addr',d.idTaxpyrDtlAddr);

  // 해외공급자
  setVal('imp-ovrss-nm',       d.idOvrssNm);
  setVal('imp-ovrss-cd',       d.idOvrssCd);
  setVal('imp-ovrss-cntry-cd', d.idOvrssCntryCd);
  findCountryNameFromDb(d.idOvrssCntryCd, 'imp-ovrss-cntry-nm');

  // 기본신고사항
  setVal('imp-dclr-se-cd',       d.idDclrSeCd);
  setVal('imp-trdng-se-cd',      d.idTrdngSeCd);
  setVal('imp-import-clfc-cd',   d.idImportClfcCd);
  setVal('imp-cgo-mng-no',       d.idCgoMngNo);
  setVal('imp-insp-plce-cd',     d.idInspPlceCd);
  // 입항일자: 'YYYYMMDD' → 'YYYY-MM-DD' (input type=date 형식)
  if (d.idArvlYmd && d.idArvlYmd.length === 8) {
    setVal('imp-arvl-ymd',
      d.idArvlYmd.substr(0,4) + '-' + d.idArvlYmd.substr(4,2) + '-' + d.idArvlYmd.substr(6,2));
  }
  setVal('imp-shipout-cntry-cd', d.idShipoutCntryCd);
  findCountryNameFromDb(d.idShipoutCntryCd, 'imp-shipout-cntry-nm');
  setVal('imp-mbl-no',           d.idMblNo);
  setVal('imp-trnsp-mn-cd',      d.idTrnspMnCd);
  setVal('imp-cntnr-se-cd',      d.idCntnrSeCd);

  // 공통사항2 - 포장/가격/결제
  setVal('imp-tot-pkg-cnt',  d.idTotPkgCnt);
  setVal('imp-tot-pkg-unit-cd',  d.idTotPkgUnitCd);
  findCommonCodeName('PKG_UNIT', d.idTotPkgUnitCd, 'imp-tot-pkg-unit-nm');
  setVal('imp-tot-wt',       d.idTotWt);
  setVal('imp-orgn-cert-yn', d.idOrgnCertYn);
  setVal('imp-stlm-amt',     d.idStlmAmt);
  setVal('imp-stlm-curr-cd', 'USD');
  setVal('imp-dlvr-cndtn-cd','CIF');

  // 공통사항2 - 세액
  setVal('imp-tot-taxt-prc-krw', d.idTotTaxtPrcKrw);
  setVal('imp-tot-taxt-prc-usd', d.idTotTaxtPrcUsd);
  setVal('imp-tot-cstms-amt',    d.idTotCstmsAmt);
  setVal('imp-vat-base-amt',     d.idVatBaseAmt);
  setVal('imp-tot-vat-amt',      d.idTotVatAmt);
  setVal('imp-tot-tax-amt',      d.idTotTaxAmt);

  // 자식 — 란사항/모델규격
  fillImpItems(d.items || []);
  attachMdlspecsToItems(d.mdlspecs || []);
  clearMdlspecEditor();
  renderImpItemList();
}

/** 로그인 사용자(BROKER) 정보로 신고인 영역 자동 채움
 *  · 이메일은 'local@domain' 으로 들어있으면 split
 *  · 전화는 '010-1234-5678(101)' 형식 처리
 */
function fillDclrntFromBroker(broker) {
  if (!broker) return;

  function setVal(id, value) {
    var el = document.getElementById(id);
    if (!el) return;
    el.value = (value === null || value === undefined) ? '' : value;
  }

  // 상호/성명
  setVal('imp-dclrnt-nm', broker.brokerNm);

  // 이메일 split
  if (broker.brokerEmail && broker.brokerEmail.indexOf('@') > -1) {
    var parts = broker.brokerEmail.split('@');
    setVal('imp-dclrnt-eml-local',  parts[0]);
    setVal('imp-dclrnt-eml-domain', parts[1]);
    // 자주 쓰는 도메인이면 select 도 맞춤
    var sel = document.getElementById('imp-dclrnt-eml-select');
    if (sel) {
      var matched = false;
      for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value === parts[1]) { sel.selectedIndex = i; matched = true; break; }
      }
      if (!matched) sel.selectedIndex = 0;
    }
  }

  // 전화 split: "010-1234-5678(101)" 또는 "010-1234-5678"
  if (broker.brokerTelno) {
    var m = broker.brokerTelno.match(/^(.+?)(?:\((.*)\))?$/);
    if (m) {
      setVal('imp-dclrnt-tel',     m[1] || '');
      setVal('imp-dclrnt-tel-ext', m[2] || '');
    }
  }
}

function syncDclrntEmailDomainFromSelect() {
  var select = document.getElementById('imp-dclrnt-eml-select');
  var domainInput = document.getElementById('imp-dclrnt-eml-domain');

  if (!select || !domainInput) {
    return;
  }

  domainInput.value = select.value || '';
}

function openImpTaxpayerPostcode() {
  var zipEl = document.getElementById('imp-taxpyr-zip');
  var addrEl = document.getElementById('imp-taxpyr-addr');
  var detailEl = document.getElementById('imp-taxpyr-dtl-addr');

  if (!window.daum || !window.daum.Postcode) {
    alert('주소 검색 스크립트를 불러오지 못했습니다.\n우편번호와 주소를 직접 입력해 주세요.');
    return;
  }

  new window.daum.Postcode({
    oncomplete: function (data) {
      var address = data.roadAddress || data.jibunAddress || '';
      var extraAddress = '';

      /*
       * 마이페이지 주소검색과 동일한 방식:
       * 도로명 주소 선택 시 법정동/건물명 보조주소 조합
       */
      if (data.userSelectedType === 'R') {
        if (data.bname && /[동로가]$/g.test(data.bname)) {
          extraAddress += data.bname;
        }

        if (data.buildingName && data.apartment === 'Y') {
          extraAddress += extraAddress ? ', ' + data.buildingName : data.buildingName;
        }

        if (extraAddress) {
          address += ' (' + extraAddress + ')';
        }
      }

      if (zipEl) {
        zipEl.value = data.zonecode || '';
      }

      if (addrEl) {
        addrEl.value = address;
      }

      if (detailEl) {
        detailEl.focus();
      }
    }
  }).open();
}
/* ============================================================
 * 국가 검색 모달
 *  - COUNTRY 테이블 조회
 *  - 해외공급자 국적, 적출국 등 2자리 국가코드 선택용
 * ============================================================ */

var countryModalTargetCdId = null;
var countryModalTargetNmId = null;

function openCountryModal(targetCdId, targetNmId, initialKeyword) {
  countryModalTargetCdId = targetCdId;
  countryModalTargetNmId = targetNmId;

  var keyword = document.getElementById('country-search-keyword');
  if (keyword) {
    keyword.value = initialKeyword || '';
  }

  searchCountryList();

  var modal = document.getElementById('country-modal');
  if (modal) {
    modal.style.display = 'block';
  }

  setTimeout(function () {
    var input = document.getElementById('country-search-keyword');
    if (input) input.focus();
  }, 100);
}

function closeCountryModal() {
  var modal = document.getElementById('country-modal');
  if (modal) {
    modal.style.display = 'none';
  }
}

function countryKeyEnter(e) {
  if (e.key === 'Enter') {
    searchCountryList();
  }
}

function searchCountryList() {
  var tbody = document.getElementById('country-modal-tbody');
  var keywordEl = document.getElementById('country-search-keyword');

  if (!tbody) {
    return;
  }

  var keyword = keywordEl ? keywordEl.value.trim() : '';
  var ctx = window.contextPath || '';

  tbody.innerHTML =
    '<tr>' +
      '<td colspan="3" style="padding:12px; text-align:center; color:#697d8f;">조회 중입니다...</td>' +
    '</tr>';

  fetch(ctx + '/broker/declare/countryList.do?keyword=' + encodeURIComponent(keyword), {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        tbody.innerHTML =
          '<tr>' +
            '<td colspan="3" style="padding:12px; text-align:center; color:#dc2626;">' +
              (res.message || '국가 조회에 실패했습니다.') +
            '</td>' +
          '</tr>';
        return;
      }

      renderCountryRows(res.list || []);
    })
    .catch(function (err) {
      console.error(err);
      tbody.innerHTML =
        '<tr>' +
          '<td colspan="3" style="padding:12px; text-align:center; color:#dc2626;">통신 오류: ' + err.message + '</td>' +
        '</tr>';
    });
}

function renderCountryRows(list) {
  var tbody = document.getElementById('country-modal-tbody');
  if (!tbody) {
    return;
  }

  if (!list || list.length === 0) {
    tbody.innerHTML =
      '<tr>' +
        '<td colspan="3" style="padding:12px; text-align:center; color:#697d8f;">검색 결과가 없습니다.</td>' +
      '</tr>';
    return;
  }

  function escq(s) {
    return (s == null) ? '' : String(s).replace(/'/g, "\\'");
  }

  var html = '';

  list.forEach(function (country) {
    var cd = country.countryCd || country.COUNTRYCD || country.COUNTRY_CD || '';
    var nm = country.countryNmKr || country.COUNTRYNMKR || country.COUNTRY_NM_KR || '';
    var en = country.countryNmEn || country.COUNTRYNMEN || country.COUNTRY_NM_EN || '';

    html +=
      '<tr style="cursor:pointer;" onclick="selectCountry(\'' + escq(cd) + '\', \'' + escq(nm) + '\')">' +
        '<td style="border-bottom:1px solid #edf1f5; padding:8px; text-align:center;">' + cd + '</td>' +
        '<td style="border-bottom:1px solid #edf1f5; padding:8px;">' + nm + '</td>' +
        '<td style="border-bottom:1px solid #edf1f5; padding:8px;">' + en + '</td>' +
      '</tr>';
  });

  tbody.innerHTML = html;
}

function selectCountry(countryCd, countryNm) {
  if (countryModalTargetCdId) {
    var cdInput = document.getElementById(countryModalTargetCdId);
    if (cdInput) {
      cdInput.value = countryCd;
    }
  }

  if (countryModalTargetNmId) {
    var nmInput = document.getElementById(countryModalTargetNmId);
    if (nmInput) {
      nmInput.value = countryNm;
    }
  }

  closeCountryModal();
}

function resolveCountryByCodeOrOpenModal(countryCdInputId, targetNmId) {
  var cdInput = document.getElementById(countryCdInputId);
  var nmInput = document.getElementById(targetNmId);

  if (!cdInput) {
    return;
  }

  var countryCd = (cdInput.value || '').trim().toUpperCase();
  cdInput.value = countryCd;

  if (!countryCd) {
    if (nmInput) {
      nmInput.value = '';
    }
    openCountryModal(countryCdInputId, targetNmId);
    return;
  }

  if (countryCd.length !== 2) {
    if (nmInput) {
      nmInput.value = '';
    }
    openCountryModal(countryCdInputId, targetNmId, countryCd);
    return;
  }

  var ctx = window.contextPath || '';

  fetch(ctx + '/broker/declare/countryList.do?keyword=' + encodeURIComponent(countryCd), {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success || !res.list || res.list.length === 0) {
        if (nmInput) {
          nmInput.value = '';
        }
        openCountryModal(countryCdInputId, targetNmId, countryCd);
        return;
      }

      var found = null;

      res.list.forEach(function (country) {
        var cd = country.countryCd || country.COUNTRYCD || country.COUNTRY_CD || '';
        if (String(cd).toUpperCase() === countryCd) {
          found = country;
        }
      });

      if (!found) {
        if (nmInput) {
          nmInput.value = '';
        }
        openCountryModal(countryCdInputId, targetNmId, countryCd);
        return;
      }

      var nm = found.countryNmKr || found.COUNTRYNMKR || found.COUNTRY_NM_KR || '';

      if (nmInput) {
        nmInput.value = nm;
      }
    })
    .catch(function (err) {
      console.error(err);
      if (nmInput) {
        nmInput.value = '';
      }
      openCountryModal(countryCdInputId, targetNmId, countryCd);
    });
}

function findCountryNameFromDb(countryCd, targetNmId) {
  if (!countryCd || !targetNmId) {
    return;
  }

  var ctx = window.contextPath || '';

  fetch(ctx + '/broker/declare/countryList.do?keyword=' + encodeURIComponent(countryCd), {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success || !res.list || res.list.length === 0) {
        return;
      }

      var upperCd = String(countryCd).toUpperCase();
      var found = null;

      res.list.forEach(function (country) {
        var cd = country.countryCd || country.COUNTRYCD || country.COUNTRY_CD || '';
        if (String(cd).toUpperCase() === upperCd) {
          found = country;
        }
      });

      if (!found) return;

      var nm = found.countryNmKr || found.COUNTRYNMKR || found.COUNTRY_NM_KR || '';
      var nmInput = document.getElementById(targetNmId);
      if (nmInput) {
        nmInput.value = nm;
      }
    })
    .catch(function (err) {
      console.error(err);
    });
}


/* ============================================================
 * 화주 검색 모달
 *  - OWNER 테이블 조회
 *  - 수입자 / 납세의무자 선택용
 * ============================================================ */

var ownerModalTargetType = null;

function openOwnerModal(targetType, initialKeyword) {
  ownerModalTargetType = targetType || 'imp';

  var target = document.getElementById('owner-modal-target-type');
  if (target) {
    target.value = ownerModalTargetType;
  }

  var keywordInput = document.getElementById('owner-search-keyword');
  if (keywordInput) {
    keywordInput.value = (initialKeyword || '').trim();
  }

  searchOwnerList();

  var modal = document.getElementById('owner-modal');
  if (modal) {
    modal.style.display = 'block';
  }

  setTimeout(function () {
    var input = document.getElementById('owner-search-keyword');
    if (input) input.focus();
  }, 100);
}

function closeOwnerModal() {
  var modal = document.getElementById('owner-modal');
  if (modal) {
    modal.style.display = 'none';
  }
}

function ownerKeyEnter(e) {
  if (e.key === 'Enter') {
    searchOwnerList();
  }
}

function searchOwnerList() {
  var tbody = document.getElementById('owner-modal-tbody');
  var keywordEl = document.getElementById('owner-search-keyword');

  if (!tbody) {
    return;
  }

  var keyword = keywordEl ? keywordEl.value.trim() : '';
  var ctx = window.contextPath || '';

  tbody.innerHTML =
    '<tr>' +
      '<td colspan="5" style="padding:12px; text-align:center; color:#697d8f;">조회 중입니다...</td>' +
    '</tr>';

  fetch(ctx + '/broker/declare/ownerList.do?keyword=' + encodeURIComponent(keyword), {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        tbody.innerHTML =
          '<tr>' +
            '<td colspan="5" style="padding:12px; text-align:center; color:#dc2626;">' +
              (res.message || '화주 조회에 실패했습니다.') +
            '</td>' +
          '</tr>';
        return;
      }

      renderOwnerRows(res.list || []);
    })
    .catch(function (err) {
      console.error(err);
      tbody.innerHTML =
        '<tr>' +
          '<td colspan="5" style="padding:12px; text-align:center; color:#dc2626;">통신 오류: ' + err.message + '</td>' +
        '</tr>';
    });
}

function renderOwnerRows(list) {
  var tbody = document.getElementById('owner-modal-tbody');
  if (!tbody) {
    return;
  }

  if (!list || list.length === 0) {
    tbody.innerHTML =
      '<tr>' +
        '<td colspan="5" style="padding:12px; text-align:center; color:#697d8f;">검색 결과가 없습니다.</td>' +
      '</tr>';
    return;
  }

  function escq(s) {
    return (s == null) ? '' : String(s).replace(/\\/g, '\\\\').replace(/'/g, "\\'");
  }

  var html = '';

  list.forEach(function (owner) {
    var owrId       = owner.owrId       || owner.OWRID       || owner.OWR_ID       || '';
    var owrNm       = owner.owrNm       || owner.OWRNM       || owner.OWR_NM       || '';
    var cstmIdfNo   = owner.owrCstmIdfNo|| owner.OWRCSTMIDFNO|| owner.OWR_CSTM_IDF_NO || '';
    var bizrno      = owner.owrBizrno   || owner.OWRBIZRNO   || owner.OWR_BIZRNO   || '';
    var identNo     = owner.owrIdentNo  || owner.OWRIDENTNO  || owner.OWR_IDENT_NO || '';
    var telno       = owner.owrTelno    || owner.OWRTELNO    || owner.OWR_TELNO    || '';
    var zip         = owner.owrZip      || owner.OWRZIP      || owner.OWR_ZIP      || '';
    var adres       = owner.owrAdres    || owner.OWRADRES    || owner.OWR_ADRES    || '';
    var detailAdres = owner.owrDetailAdres || owner.OWRDETAILADRES || owner.OWR_DETAIL_ADRES || '';
    var corpRegNo   = owner.owrCorpRegNo || owner.OWRCORPREGNO || owner.OWR_CORP_REG_NO || '';

    html +=
      '<tr style="cursor:pointer;" onclick="selectOwner(\'' +
        escq(owrId) + '\', \'' +
        escq(owrNm) + '\', \'' +
        escq(cstmIdfNo) + '\', \'' +
        escq(bizrno) + '\', \'' +
        escq(identNo) + '\', \'' +
        escq(telno) + '\', \'' +
        escq(zip) + '\', \'' +
        escq(adres) + '\', \'' +
        escq(detailAdres) + '\', \'' +
        escq(corpRegNo) + '\')">' +
        '<td style="border-bottom:1px solid #edf1f5; padding:8px; text-align:center;">' + owrId + '</td>' +
        '<td style="border-bottom:1px solid #edf1f5; padding:8px;">' + owrNm + '</td>' +
        '<td style="border-bottom:1px solid #edf1f5; padding:8px;">' + cstmIdfNo + '</td>' +
        '<td style="border-bottom:1px solid #edf1f5; padding:8px;">' + bizrno + '</td>' +
        '<td style="border-bottom:1px solid #edf1f5; padding:8px;">' + telno + '</td>' +
      '</tr>';
  });

  tbody.innerHTML = html;
}

function selectOwner(owrId, owrNm, cstmIdfNo, bizrno, identNo, telno, zip, adres, detailAdres, corpRegNo) {
  var targetType = ownerModalTargetType || 'imp';

  // 수입자 선택이면 수입자 + 납세의무자 같이 세팅
  if (targetType === 'imp') {
    setOwnerToImporter(owrNm, cstmIdfNo);
    setOwnerToTaxpayer(owrNm, cstmIdfNo, bizrno, identNo, telno, zip, adres, detailAdres, corpRegNo);
  }

  // 납세의무자 선택이면 납세의무자만 세팅
  if (targetType === 'taxpyr') {
    setOwnerToTaxpayer(owrNm, cstmIdfNo, bizrno, identNo, telno, zip, adres, detailAdres, corpRegNo);
  }

  closeOwnerModal();
}

function setOwnerToImporter(owrNm, cstmIdfNo) {
  var imprNm = document.getElementById('imp-impr-nm');
  var imprClnc = document.getElementById('imp-impr-clnc-cd');

  if (imprNm) imprNm.value = owrNm || '';
  if (imprClnc) imprClnc.value = cstmIdfNo || '';
}

function setOwnerToTaxpayer(owrNm, cstmIdfNo, bizrno, identNo, telno, zip, adres, detailAdres, corpRegNo) {
  var taxpyrNm = document.getElementById('imp-taxpyr-nm');
  var taxpyrClnc = document.getElementById('imp-taxpyr-clnc-cd');
  var tel = document.getElementById('imp-taxpyr-tel');
  var idntSe = document.getElementById('imp-taxpyr-idnt-se');
  var idntNo = document.getElementById('imp-taxpyr-idnt-no');
  var zipEl = document.getElementById('imp-taxpyr-zip');
  var addrEl = document.getElementById('imp-taxpyr-addr');
  var dtlAddrEl = document.getElementById('imp-taxpyr-dtl-addr');

  if (taxpyrNm) taxpyrNm.value = owrNm || '';
  if (taxpyrClnc) taxpyrClnc.value = cstmIdfNo || '';
  if (tel) tel.value = telno || '';

  if (idntSe && idntNo) {
    if (bizrno) {
      idntSe.value = '사업자등록번호';
      idntNo.value = bizrno;
    } else if (corpRegNo) {
      idntSe.value = '법인등록번호';
      idntNo.value = corpRegNo;
    } else if (identNo) {
      idntSe.value = '주민등록번호';
      idntNo.value = identNo;
    }
  }

  if (zipEl) zipEl.value = zip || '';
  if (addrEl) addrEl.value = adres || '';
  if (dtlAddrEl) dtlAddrEl.value = detailAdres || '';
}



function findCommonCodeName(groupId, code, targetNmId) {
  if (!groupId || !code || !targetNmId) {
    return;
  }

  var ctx = window.contextPath || '';

  fetch(ctx + '/broker/declare/commonCodeList.do?groupId='
      + encodeURIComponent(groupId)
      + '&keyword=' + encodeURIComponent(code), {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success || !res.list || res.list.length === 0) {
        return;
      }

      var upperCode = String(code).toUpperCase();
      var found = null;

      res.list.forEach(function (item) {
        var cd = item.ccCd || item.CCCD || item.CC_CD || '';
        if (String(cd).toUpperCase() === upperCode) {
          found = item;
        }
      });

      if (!found) return;

      var nm = found.ccNm || found.CCNM || found.CC_NM || '';
      var nmInput = document.getElementById(targetNmId);
      if (nmInput) {
        nmInput.value = nm;
      }
    })
    .catch(function (err) {
      console.error(err);
    });
}


function notifyOriginCertificateChange() {
  var certEl = document.getElementById('imp-orgn-cert-yn');
  var certYn = certEl ? (certEl.value || '').trim().toUpperCase() : '';

  if (certYn !== 'Y') {
    return;
  }

  var row = null;

  if (typeof getCurrentItemRow === 'function') {
    row = getCurrentItemRow();
  }

  if (!row) {
    return;
  }

  var hsEl = row.querySelector('.item-hs-cd');
  var countryEl = row.querySelector('.item-orgn-cntry-cd');

  var hsCode = hsEl ? (hsEl.value || '').trim() : '';
  var countryCd = countryEl ? (countryEl.value || '').trim() : '';

  if (!hsCode || !countryCd) {
    showDeclareNotice(
      'warning',
      '원산지증명서 확인',
      '원산지증명서 유무가 Y로 선택되었습니다.\n\n'
      + '협정세율 적용 여부를 확인하려면 란사항의 HS코드와 원산지코드를 먼저 입력한 뒤 [HS/세율확인]을 눌러주세요.'
    );
    return;
  }

  showDeclareNotice(
    'warning',
    '협정세율 재확인 필요',
    '원산지증명서 유무가 Y로 선택되었습니다.\n\n'
    + '현재 란에 HS코드와 원산지코드가 입력되어 있으므로 협정세율 적용 대상인지 확인할 수 있습니다.\n'
    + '[HS/세율확인] 버튼을 눌러 기본세율 또는 협정세율을 최종 확정해주세요.'
  );
}

/* ============================================================
 * HS코드 직접 조회
 * - 외부 API 사용 X
 * - Oracle DB의 HS_CODE / FTA_TARIFF 조회
 * - 원산지증명서 Y + 원산지코드 있음 + FTA세율 있음 → FTA세율 적용
 * - 그 외 → HS_CODE 기본세율 적용
 * ============================================================ */
function resolveHsCodeFromDb(btn) {
  var row = btn ? btn.closest('.imp-item-row') : null;

  if (!row && typeof getCurrentItemRow === 'function') {
    row = getCurrentItemRow();
  }

  if (!row) {
    alert('란사항 입력 영역을 찾을 수 없습니다.');
    return;
  }

  function get(cls) {
    var el = row.querySelector('.' + cls);
    return el ? (el.value || '').trim() : '';
  }

  function set(cls, value) {
    var el = row.querySelector('.' + cls);
    if (!el) return;
    el.value = (value === null || value === undefined) ? '' : value;
  }

  var hsCode = get('item-hs-cd').replace(/[.\-\s]/g, '').toUpperCase();
  var countryCd = get('item-orgn-cntry-cd').toUpperCase();

  var orgnCertEl = document.getElementById('imp-orgn-cert-yn');
  var orgnCertYn = orgnCertEl ? (orgnCertEl.value || '').trim().toUpperCase() : '';

  if (!hsCode) {
    alert('HS부호를 입력해주세요.');
    var hsEl = row.querySelector('.item-hs-cd');
    if (hsEl) hsEl.focus();
    return;
  }

  var ctx = window.contextPath || '';
  var url = ctx + '/broker/declare/hsCodeInfo.do'
          + '?hsCode=' + encodeURIComponent(hsCode)
          + '&countryCd=' + encodeURIComponent(countryCd)
          + '&orgnCertYn=' + encodeURIComponent(orgnCertYn);

  if (btn) {
    btn.disabled = true;
    btn.textContent = '조회중';
  }

  fetch(url, {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        alert(res.message || 'HS코드 조회에 실패했습니다.');
        return;
      }

      var data = res.data || {};

      if (data.hsCode) {
        set('item-hs-cd', data.hsCode);
      }

      // 신고품명이 비어 있을 때만 HS 품명으로 채움
      var dclrNm = row.querySelector('.item-dclr-gdsnm');
      if (dclrNm && !dclrNm.value && data.hsName) {
        dclrNm.value = data.hsName;
      }

      // MVP 기준 관세액기준은 종가 기본
      var taxtStd = row.querySelector('.item-taxt-stndrd-cd');
      if (taxtStd && !taxtStd.value) {
        taxtStd.value = '종가';
      }

	  if (data.appliedTariffRate !== null && data.appliedTariffRate !== undefined) {
	    set('item-taxt-rt', data.appliedTariffRate);
	    recalcCurrentItemTaxDisplay();
	  }

	  var tariffInfo = row.querySelector('.item-tariff-applied-info');
	  if (tariffInfo) {
	    if (data.appliedType === 'FTA') {
	      tariffInfo.textContent =
	        '협정세율 적용: '
	        + (data.agreementNm || data.agreementCd || '-')
	        + ' / 기본세율 '
	        + (data.basicTariffRate === null || data.basicTariffRate === undefined ? '-' : data.basicTariffRate + '%')
	        + ' → 적용세율 '
	        + (data.appliedTariffRate === null || data.appliedTariffRate === undefined ? '-' : data.appliedTariffRate + '%');

	      tariffInfo.style.color = '#2563eb';
	    } else {
	      tariffInfo.textContent =
	        '기본세율 적용: '
	        + (data.appliedTariffRate === null || data.appliedTariffRate === undefined ? '-' : data.appliedTariffRate + '%');

	      tariffInfo.style.color = '#64748b';
	    }
	  }

      if (data.orgnDtrmnCd) {
        set('item-orgn-dtrmn-cd', data.orgnDtrmnCd);
      }

      if (data.appliedType === 'FTA') {
        alert(
          'FTA 협정세율 후보가 적용되었습니다.\n'
          + '협정: ' + (data.agreementNm || data.agreementCd || '-') + '\n'
          + '기본세율: ' + data.basicTariffRate + '%\n'
          + '적용세율: ' + data.appliedTariffRate + '%\n\n'
          + '※ 원산지증명서 및 원산지결정기준 충족 여부를 확인 후 최종 세율을 확정하세요.'
        );
      } else {
        alert(
          '기본세율이 적용되었습니다.\n'
          + 'HS품명: ' + (data.hsName || '-') + '\n'
          + '기본세율: ' + data.appliedTariffRate + '%'
        );
      }
    })
    .catch(function (err) {
      console.error(err);
      alert('HS코드 조회 통신 오류: ' + err.message);
    })
    .finally(function () {
      if (btn) {
        btn.disabled = false;
        btn.textContent = 'HS/세율확인';
      }
    });
}



/* ============================================================
 * HS코드 AI추천 상태 관리
 * - Milvus가 꺼져 있으면 버튼 비활성화
 * - Spring은 Docker를 직접 켜지 않고 연결 가능 여부만 확인
 * ============================================================ */
var hsAiRecommendEnabled = false;

function initHsAiRecommendStatus() {
  var ctx = window.contextPath || '';

  fetch(ctx + '/broker/declare/hsAiStatus.do', {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      hsAiRecommendEnabled = !!(res && res.success && res.enabled);
      refreshHsAiRecommendButtons(res.message);
    })
    .catch(function (err) {
      console.error(err);
      hsAiRecommendEnabled = false;
      refreshHsAiRecommendButtons('HS AI추천 상태 확인 실패');
    });
}

function refreshHsAiRecommendButtons(message) {
  document.querySelectorAll('.hs-ai-recommend-btn').forEach(function (btn) {
    btn.disabled = !hsAiRecommendEnabled;
    btn.title = hsAiRecommendEnabled
      ? '현재 란사항의 품명/규격으로 HS코드 후보를 추천합니다.'
      : (message || 'HS AI추천 기능이 비활성화되어 있습니다.');

    if (hsAiRecommendEnabled) {
      btn.classList.remove('hs-ai-disabled');
    } else {
      btn.classList.add('hs-ai-disabled');
    }
  });
}

/**
 * 1차 동작:
 * - 버튼 활성/비활성 구조만 연결
 * - 실제 Milvus 추천 API는 다음 단계에서 /recommendHsCode.do로 연결
 */
function recommendHsCodeByAi(btn) {
  if (!hsAiRecommendEnabled) {
    alert('HS AI추천 기능을 사용할 수 없습니다.\n\nMilvus Docker 실행 상태와 application.properties 설정을 확인하세요.');
    return;
  }

  var row = btn ? btn.closest('.imp-item-row') : null;

  if (!row && typeof getCurrentItemRow === 'function') {
    row = getCurrentItemRow();
  }

  if (!row) {
    alert('란사항 입력 영역을 찾을 수 없습니다.');
    return;
  }

  function get(cls) {
    var el = row.querySelector('.' + cls);
    return el ? (el.value || '').trim() : '';
  }

  var keyword = [
    get('item-dclr-gdsnm'),
    get('item-trdng-gdsnm'),
    get('item-trdmk-nm')
  ].filter(Boolean).join(' ');

  if (!keyword) {
    alert('AI추천에 사용할 신고품명, 거래품명 또는 상표명을 먼저 입력해주세요.');
    return;
  }

  /*
   * 다음 단계에서 여기를 Milvus 추천 API로 교체한다.
   * 지금은 사용자가 흐름을 확인할 수 있게 기존 HS검색 모달을 연다.
   */
  hsSearchTargetRow = row;

  var modal = document.getElementById('hs-code-modal');
  var input = document.getElementById('hs-code-search-keyword');

  if (input) input.value = keyword;
  if (modal) modal.style.display = 'block';

  searchHsCodeList();
}

/* ============================================================
 * HS코드 검색 모달
 * - HS코드를 모를 때 품명/코드 일부로 HS_CODE 후보 목록 조회
 * - 선택 시 란사항 HS코드/신고품명/기본세율 세팅
 * ============================================================ */
var hsSearchTargetRow = null;

function openHsSearchModal(btn) {
  hsSearchTargetRow = btn ? btn.closest('.imp-item-row') : null;

  if (!hsSearchTargetRow && typeof getCurrentItemRow === 'function') {
    hsSearchTargetRow = getCurrentItemRow();
  }

  if (!hsSearchTargetRow) {
    alert('란사항 입력 영역을 찾을 수 없습니다.');
    return;
  }

  function get(cls) {
    var el = hsSearchTargetRow.querySelector('.' + cls);
    return el ? (el.value || '').trim() : '';
  }

  var keyword = get('item-dclr-gdsnm') || get('item-trdng-gdsnm') || get('item-hs-cd') || '';

  var modal = document.getElementById('hs-code-modal');
  var input = document.getElementById('hs-code-search-keyword');
  var tbody = document.getElementById('hs-code-modal-tbody');

  if (input) input.value = keyword;
  if (tbody) {
    tbody.innerHTML =
      '<tr><td colspan="4" style="padding:24px;text-align:center;color:#94a3b8;">검색어를 입력 후 검색하세요.</td></tr>';
  }

  switchHsSearchMode('search');

  if (modal) modal.style.display = 'block';

  setTimeout(function () {
    if (input) {
      input.focus();
      if (keyword) searchHsCodeList();
    }
  }, 100);
}

function closeHsSearchModal() {
  var modal = document.getElementById('hs-code-modal');
  if (modal) modal.style.display = 'none';
}

var hsClassPathStack = [];

function switchHsSearchMode(mode) {
  var searchBtn = document.getElementById('hs-mode-search-btn');
  var classBtn = document.getElementById('hs-mode-class-btn');
  var searchPanel = document.getElementById('hs-search-panel');
  var classPanel = document.getElementById('hs-class-panel');
  var tbody = document.getElementById('hs-code-modal-tbody');

  if (searchBtn) searchBtn.classList.toggle('active', mode === 'search');
  if (classBtn) classBtn.classList.toggle('active', mode === 'class');

  if (searchPanel) searchPanel.style.display = (mode === 'search') ? 'block' : 'none';
  if (classPanel) classPanel.style.display = (mode === 'class') ? 'block' : 'none';

  if (mode === 'search') {
    if (tbody) {
      tbody.innerHTML =
        '<tr><td colspan="4" style="padding:24px;text-align:center;color:#94a3b8;">검색어를 입력 후 검색하세요.</td></tr>';
    }
  } else {
    hsClassPathStack = [];
    renderHsClassPath();
    loadHsClassChildren('', false);
  }
}

function renderHsClassPath() {
  var path = document.getElementById('hs-class-path');
  if (!path) return;

  path.innerHTML = '';

  var rootBtn = document.createElement('button');
  rootBtn.type = 'button';
  rootBtn.className = 'hs-path-btn';
  rootBtn.textContent = '최상위';
  rootBtn.onclick = function () {
    loadHsClassChildren('', true);
  };
  path.appendChild(rootBtn);

  hsClassPathStack.forEach(function (p, idx) {
    var sep = document.createElement('span');
    sep.className = 'hs-path-sep';
    sep.textContent = '›';
    path.appendChild(sep);

    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'hs-path-btn';
    btn.textContent = p.name || p.cd;
    btn.onclick = function () {
      goHsClassPath(idx);
    };
    path.appendChild(btn);
  });
}

function goHsClassPath(index) {
  if (index < 0) {
    hsClassPathStack = [];
    loadHsClassChildren('', true);
    return;
  }

  var target = hsClassPathStack[index];
  hsClassPathStack = hsClassPathStack.slice(0, index + 1);
  renderHsClassPath();
  loadHsClassChildren(target.cd, false);
}

function loadHsClassChildren(parentCd, resetPath) {
  var tbody = document.getElementById('hs-code-modal-tbody');
  if (!tbody) return;

  if (resetPath) {
    hsClassPathStack = [];
    renderHsClassPath();
  }

  var ctx = window.contextPath || '';
  var url = ctx + '/broker/declare/hsClassChildren.do';

  if (parentCd) {
    url += '?parentCd=' + encodeURIComponent(parentCd);
  }

  tbody.innerHTML =
    '<tr><td colspan="4" style="padding:24px;text-align:center;color:#94a3b8;">HS분류를 조회 중입니다...</td></tr>';

  fetch(url, {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        tbody.innerHTML =
          '<tr><td colspan="4" style="padding:24px;text-align:center;color:#dc2626;">'
          + (res.message || 'HS분류 조회에 실패했습니다.')
          + '</td></tr>';
        return;
      }

      renderHsClassChildren(res.list || []);
    })
    .catch(function (err) {
      console.error(err);
      tbody.innerHTML =
        '<tr><td colspan="4" style="padding:24px;text-align:center;color:#dc2626;">'
        + 'HS분류 조회 통신 오류: ' + err.message
        + '</td></tr>';
    });
}

function renderHsClassChildren(list) {
  var tbody = document.getElementById('hs-code-modal-tbody');
  if (!tbody) return;

  tbody.innerHTML = '';

  if (!list || list.length === 0) {
    var emptyTr = document.createElement('tr');
    var emptyTd = document.createElement('td');
    emptyTd.colSpan = 4;
    emptyTd.className = 'hs-empty-row';
    emptyTd.textContent = '하위 HS분류가 없습니다.';
    emptyTr.appendChild(emptyTd);
    tbody.appendChild(emptyTr);
    return;
  }

  list.forEach(function (h) {
    var cd = h.hsClassCd || '';
    var nm = h.hsClassNm || '';
    var desc = h.hsClassDesc || '';
    var level = h.hsClassLevelCd || '';
    var selectable = h.selectableYn === 'Y';
    var childCount = Number(h.childCount || 0);
    var hsCode = h.hsCode || cd;
    var hsName = h.hsName || nm;
    var rate = h.basicTariffRate;

    var tr = document.createElement('tr');
    tr.style.cursor = 'pointer';

    tr.onclick = function () {
      if (selectable && hsCode) {
        selectHsCodeFromModal(hsCode, hsName, rate);
      } else if (childCount > 0) {
        enterHsClassNode(cd, nm);
      }
    };

    var tdCode = document.createElement('td');
    tdCode.className = 'hs-code-cell';
    tdCode.appendChild(document.createTextNode(cd));

    var levelDiv = document.createElement('div');
    levelDiv.className = 'hs-class-level';
    levelDiv.textContent = level;
    tdCode.appendChild(levelDiv);

    var tdName = document.createElement('td');
    tdName.appendChild(document.createTextNode(nm));

    var descDiv = document.createElement('div');
    descDiv.className = 'hs-class-desc';
    descDiv.textContent = desc;
    tdName.appendChild(descDiv);

    var tdRate = document.createElement('td');
    tdRate.className = 'hs-rate-cell';
    if (rate === null || rate === undefined || rate === '') {
      tdRate.textContent = '-';
    } else {
      tdRate.textContent = rate + '%';
    }

    var tdSelect = document.createElement('td');
    tdSelect.className = 'hs-select-cell';

    if (selectable && hsCode) {
      var selectBtn = document.createElement('button');
      selectBtn.type = 'button';
      selectBtn.className = 'hs-select-btn';
      selectBtn.textContent = '선택';
      selectBtn.onclick = function (e) {
        e.stopPropagation();
        selectHsCodeFromModal(hsCode, hsName, rate);
      };
      tdSelect.appendChild(selectBtn);
    } else if (childCount > 0) {
      var childBtn = document.createElement('button');
      childBtn.type = 'button';
      childBtn.className = 'hs-select-btn';
      childBtn.textContent = '하위';
      childBtn.onclick = function (e) {
        e.stopPropagation();
        enterHsClassNode(cd, nm);
      };
      tdSelect.appendChild(childBtn);
    } else {
      var span = document.createElement('span');
      span.style.fontSize = '10px';
      span.style.color = '#94a3b8';
      span.textContent = '선택불가';
      tdSelect.appendChild(span);
    }

    tr.appendChild(tdCode);
    tr.appendChild(tdName);
    tr.appendChild(tdRate);
    tr.appendChild(tdSelect);

    tbody.appendChild(tr);
  });
}

function enterHsClassNode(cd, nm) {
  if (!cd) return;

  hsClassPathStack.push({
    cd: cd,
    name: nm || cd
  });

  renderHsClassPath();
  loadHsClassChildren(cd, false);
}




function hsCodeSearchKeyEnter(e) {
  if (e && e.key === 'Enter') {
    searchHsCodeList();
  }
}

function searchHsCodeList() {
  var input = document.getElementById('hs-code-search-keyword');
  var tbody = document.getElementById('hs-code-modal-tbody');
  var keyword = input ? (input.value || '').trim() : '';

  if (!tbody) {
    return;
  }

  var ctx = window.contextPath || '';
  var url = ctx + '/broker/declare/hsCodeList.do?keyword=' + encodeURIComponent(keyword);

  tbody.innerHTML =
    '<tr><td colspan="4" style="padding:24px;text-align:center;color:#94a3b8;">조회 중입니다...</td></tr>';

  fetch(url, {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        tbody.innerHTML =
          '<tr><td colspan="4" style="padding:24px;text-align:center;color:#dc2626;">'
          + (res.message || 'HS코드 검색에 실패했습니다.')
          + '</td></tr>';
        return;
      }

      renderHsCodeSearchList(res.list || []);
    })
    .catch(function (err) {
      console.error(err);
      tbody.innerHTML =
        '<tr><td colspan="4" style="padding:24px;text-align:center;color:#dc2626;">'
        + 'HS코드 검색 통신 오류: ' + err.message
        + '</td></tr>';
    });
}

function renderHsCodeSearchList(list) {
  var tbody = document.getElementById('hs-code-modal-tbody');
  if (!tbody) return;

  tbody.innerHTML = '';

  if (!list || list.length === 0) {
    var emptyTr = document.createElement('tr');
    var emptyTd = document.createElement('td');
    emptyTd.colSpan = 4;
    emptyTd.className = 'hs-empty-row';
    emptyTd.textContent = '검색 결과가 없습니다.';
    emptyTr.appendChild(emptyTd);
    tbody.appendChild(emptyTr);
    return;
  }

  list.forEach(function (h) {
    var hsCode = h.hsCode || '';
    var hsName = h.hsName || '';
    var rate = h.basicTariffRate;
    var path = h.hsClassPath || '';
    var desc = h.hsClassDesc || '';

    var tr = document.createElement('tr');
    tr.style.cursor = 'pointer';

    tr.onclick = function () {
      selectHsCodeFromModal(hsCode, hsName, rate);
    };

    var tdCode = document.createElement('td');
    tdCode.className = 'hs-code-cell';
    tdCode.textContent = hsCode;

    var tdName = document.createElement('td');

    var nameDiv = document.createElement('div');
    nameDiv.className = 'hs-search-name-main';
    nameDiv.textContent = hsName;
    tdName.appendChild(nameDiv);

    if (path) {
      var pathDiv = document.createElement('div');
      pathDiv.className = 'hs-search-path';
      pathDiv.textContent = path;
      tdName.appendChild(pathDiv);
    }

    if (desc && desc !== hsName) {
      var descDiv = document.createElement('div');
      descDiv.className = 'hs-search-desc';
      descDiv.textContent = desc;
      tdName.appendChild(descDiv);
    }

    var tdRate = document.createElement('td');
    tdRate.className = 'hs-rate-cell';

	if (rate === null || rate === undefined || rate === '') {
	  tdRate.textContent = '-';
	} else {
	  tdRate.textContent = rate + '%';
	}

    var tdSelect = document.createElement('td');
    tdSelect.className = 'hs-select-cell';

    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'hs-select-btn';
    btn.textContent = '선택';
    btn.onclick = function (e) {
      e.stopPropagation();
      selectHsCodeFromModal(hsCode, hsName, rate);
    };

    tdSelect.appendChild(btn);

    tr.appendChild(tdCode);
    tr.appendChild(tdName);
    tr.appendChild(tdRate);
    tr.appendChild(tdSelect);

    tbody.appendChild(tr);
  });
}

function selectHsCodeFromModal(hsCode, hsName, basicTariffRate) {
  var row = hsSearchTargetRow;

  if (!row) {
    alert('적용할 란사항 영역을 찾을 수 없습니다.');
    return;
  }

  function set(cls, value) {
    var el = row.querySelector('.' + cls);
    if (!el) return;
    el.value = (value === null || value === undefined) ? '' : value;
  }

  var hsEl = row.querySelector('.item-hs-cd');
  var dclrEl = row.querySelector('.item-dclr-gdsnm');
  var trdngEl = row.querySelector('.item-trdng-gdsnm');
  var rateEl = row.querySelector('.item-taxt-rt');
  var taxtStdEl = row.querySelector('.item-taxt-stndrd-cd');

  if (hsEl) hsEl.value = hsCode || '';

  // 신고품명이 비어 있을 때만 검색한 HS명으로 채움
  if (dclrEl && !dclrEl.value && hsName) {
    dclrEl.value = hsName;
  }
  
  if (trdngEl && !trdngEl.value && hsName) {
    trdngEl.value = hsName;
  }

  // 기본세율 우선 세팅. FTA는 필요 시 HS코드조회 버튼으로 재확인
  if (rateEl && basicTariffRate !== null && basicTariffRate !== undefined && basicTariffRate !== '') {
    rateEl.value = basicTariffRate;
    recalcCurrentItemTaxDisplay();
  }
  
  var tariffInfo = row.querySelector('.item-tariff-applied-info');
  if (tariffInfo) {
    tariffInfo.textContent =
      '기본세율 적용: '
      + (basicTariffRate === null || basicTariffRate === undefined || basicTariffRate === '' ? '-' : basicTariffRate + '%')
      + ' / 협정세율은 원산지코드와 원산지증명서 확인 후 [HS/세율확인]으로 적용';

    tariffInfo.style.color = '#64748b';
  }

  if (taxtStdEl && !taxtStdEl.value) {
    taxtStdEl.value = '종가';
  }

  closeHsSearchModal();

  alert(
    'HS코드 후보가 선택되었습니다.\n\n'
    + 'HS코드: ' + hsCode + '\n'
    + '품명: ' + hsName + '\n\n'
    + '기본세율이 임시 적용되었습니다.\n'
    + '원산지코드와 원산지증명서 유무를 확인한 뒤 [HS/세율확인]으로 최종 적용세율을 확정하세요.'
  );
}

function resolvePkgUnitByCodeOrOpenModal() {
  var cdInput = document.getElementById('imp-tot-pkg-unit-cd');
  var nmInput = document.getElementById('imp-tot-pkg-unit-nm');

  if (!cdInput) return;

  var unitCd = (cdInput.value || '').trim().toUpperCase();
  cdInput.value = unitCd;

  if (!unitCd) {
    if (nmInput) nmInput.value = '';
    openCommonCodeModal('PKG_UNIT', 'imp-tot-pkg-unit-cd', 'imp-tot-pkg-unit-nm');
    return;
  }

  var ctx = window.contextPath || '';

  fetch(ctx + '/broker/declare/commonCodeList.do?groupId=PKG_UNIT&keyword=' + encodeURIComponent(unitCd), {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success || !res.list || res.list.length === 0) {
        if (nmInput) nmInput.value = '';
        openCommonCodeModal('PKG_UNIT', 'imp-tot-pkg-unit-cd', 'imp-tot-pkg-unit-nm', unitCd);
        return;
      }

      var found = null;

      res.list.forEach(function (item) {
        var cd = item.ccCd || item.CCCD || item.CC_CD || '';
        if (String(cd).toUpperCase() === unitCd) {
          found = item;
        }
      });

      if (!found) {
        if (nmInput) nmInput.value = '';
        openCommonCodeModal('PKG_UNIT', 'imp-tot-pkg-unit-cd', 'imp-tot-pkg-unit-nm', unitCd);
        return;
      }

      var nm = found.ccNm || found.CCNM || found.CC_NM || '';

      if (nmInput) {
        nmInput.value = nm;
      }

      // 핵심: 정확한 코드가 있으면 여기서 끝. 모달 열지 않음.
    })
    .catch(function (err) {
      console.error(err);
      if (nmInput) nmInput.value = '';
      openCommonCodeModal('PKG_UNIT', 'imp-tot-pkg-unit-cd', 'imp-tot-pkg-unit-nm', unitCd);
    });
}


var commonCodeModalGroupId = null;
var commonCodeModalTargetCdId = null;
var commonCodeModalTargetNmId = null;

function openCommonCodeModal(groupId, targetCdId, targetNmId, initialKeyword) {
  commonCodeModalGroupId = groupId;
  commonCodeModalTargetCdId = targetCdId;
  commonCodeModalTargetNmId = targetNmId;

  var keyword = document.getElementById('common-code-search-keyword');
  if (keyword) {
    keyword.value = initialKeyword || '';
  }

  searchCommonCodeList();

  var modal = document.getElementById('common-code-modal');
  if (modal) {
    modal.style.display = 'block';
  }

  setTimeout(function () {
    var input = document.getElementById('common-code-search-keyword');
    if (input) input.focus();
  }, 100);
}

function closeCommonCodeModal() {
  var modal = document.getElementById('common-code-modal');
  if (modal) {
    modal.style.display = 'none';
  }
}

function commonCodeKeyEnter(e) {
  if (e.key === 'Enter') {
    searchCommonCodeList();
  }
}

function searchCommonCodeList() {
  var tbody = document.getElementById('common-code-modal-tbody');
  var keywordEl = document.getElementById('common-code-search-keyword');

  if (!tbody || !commonCodeModalGroupId) {
    return;
  }

  var keyword = keywordEl ? keywordEl.value.trim() : '';
  var ctx = window.contextPath || '';

  tbody.innerHTML =
    '<tr>' +
      '<td colspan="3" style="padding:12px; text-align:center; color:#697d8f;">조회 중입니다...</td>' +
    '</tr>';

  fetch(ctx + '/broker/declare/commonCodeList.do?groupId='
      + encodeURIComponent(commonCodeModalGroupId)
      + '&keyword=' + encodeURIComponent(keyword), {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        tbody.innerHTML =
          '<tr>' +
            '<td colspan="3" style="padding:12px; text-align:center; color:#dc2626;">' +
              (res.message || '공통코드 조회에 실패했습니다.') +
            '</td>' +
          '</tr>';
        return;
      }

      renderCommonCodeRows(res.list || []);
    })
    .catch(function (err) {
      console.error(err);
      tbody.innerHTML =
        '<tr>' +
          '<td colspan="3" style="padding:12px; text-align:center; color:#dc2626;">통신 오류: ' + err.message + '</td>' +
        '</tr>';
    });
}

function renderCommonCodeRows(list) {
  var tbody = document.getElementById('common-code-modal-tbody');
  if (!tbody) return;

  if (!list || list.length === 0) {
    tbody.innerHTML =
      '<tr>' +
        '<td colspan="3" style="padding:12px; text-align:center; color:#697d8f;">검색 결과가 없습니다.</td>' +
      '</tr>';
    return;
  }

  function escq(s) {
    return (s == null) ? '' : String(s).replace(/\\/g, '\\\\').replace(/'/g, "\\'");
  }

  var html = '';

  list.forEach(function (item) {
    var cd = item.ccCd || item.CCCD || item.CC_CD || '';
    var nm = item.ccNm || item.CCNM || item.CC_NM || '';
    var desc = item.ccDesc || item.CCDESC || item.CC_DESC || '';

    html +=
      '<tr style="cursor:pointer;" onclick="selectCommonCode(\'' + escq(cd) + '\', \'' + escq(nm) + '\')">' +
        '<td style="border-bottom:1px solid #edf1f5; padding:8px; text-align:center; width:90px;">' + cd + '</td>' +
        '<td style="border-bottom:1px solid #edf1f5; padding:8px;">' + nm + '</td>' +
        '<td style="border-bottom:1px solid #edf1f5; padding:8px;">' + desc + '</td>' +
      '</tr>';
  });

  tbody.innerHTML = html;
}

function selectCommonCode(code, name) {
  if (commonCodeModalTargetCdId) {
    var cdInput = document.getElementById(commonCodeModalTargetCdId);
    if (cdInput) cdInput.value = code;
  }

  if (commonCodeModalTargetNmId) {
    var nmInput = document.getElementById(commonCodeModalTargetNmId);
    if (nmInput) nmInput.value = name;
  }

  closeCommonCodeModal();
}





/* 페이지 로드 시 이어쓰기 데이터 있으면 폼 채우기 (DOMContentLoaded 후)
 * + 이어쓰기가 아니더라도 신고인은 로그인 사용자 정보로 자동 채움
 * + 란사항/모델규격은 빈 row 1개 자동 추가 (3차/4차) */
document.addEventListener('DOMContentLoaded', function () {
  // declareActiveSub 자동 진입 처리(switchDeclare) 이후에 폼이 보이게 됨
  // → setTimeout 으로 약간 지연시켜 form 이 display:block 된 다음 처리
  setTimeout(function () {
    if (window.impDclrData) {
      // ===== 이어쓰기 모드 =====
      // 저장된 신고서 데이터로 폼 전체 채움 (신고인도 저장된 값 사용)
      fillImpForm(window.impDclrData);
    } else {
      // ===== 신규 작성 모드 =====
      // 신고인 영역만 로그인 사용자 BROKER 정보로 자동 채움
      fillDclrntFromBroker(window.currentBroker);
      // 란사항/모델규격 빈 row 1개씩
	  addItemRow();
	  ensureMdlspecRow();
    }
	initHsAiRecommendStatus();
  }, 50);
});

/*
 * 8D-ATTACH-CSRF
 * Spring Security CSRF 헤더 생성
 *
 * FormData 요청에서는 Content-Type을 직접 넣으면 안 된다.
 * CSRF 헤더만 추가한다.
 */
function getCsrfHeaders() {
  var tokenEl = document.querySelector('meta[name="_csrf"]');
  var headerEl = document.querySelector('meta[name="_csrf_header"]');

  var headers = {};

  if (tokenEl && headerEl && tokenEl.content && headerEl.content) {
    headers[headerEl.content] = tokenEl.content;
  }

  return headers;
}
/* ============================================================
 * 8D-ATTACH — 수입신고서 첨부파일 관리
 *
 * 구조:
 * - 수입신고서는 imp-declare-input의 IR_NO를 기준으로 첨부파일을 관리한다.
 * - 파일그룹번호는 IMP_DCLR이 아니라 IMP_RQST.IR_TFG_NO를 사용한다.
 *
 * API:
 * - GET  /broker/declare/impDocs.do?irNo=...
 * - POST /broker/declare/uploadImpDocs.do
 * - POST /broker/declare/deleteImpDoc.do
 *
 * 다운로드:
 * - /common/file/download.do?fileNo=...
 * ============================================================ */

/*
 * 8D-ATTACH
 * 현재 화면의 통관의뢰번호 조회
 */
function getCurrentImpIrNo() {
  var irNoEl = document.getElementById('imp-declare-input');
  return irNoEl ? (irNoEl.value || '').trim() : '';
}
/*
 * 8D-ATTACH
 * FileInfoDTO의 파일명을 안전하게 추출
 *
 * 주의:
 * - DB 원본파일명 컬럼은 DOCS_FILE_DATA.DFI_ORG_NM
 * - JSON 필드명은 보통 dfiOrgNm 으로 내려옴
 * - 기존 fallback도 함께 유지
 */
function formatImpDocFileName(file) {
  return file.dfiOrgNm
      || file.dfiOrgnlFileNm
      || file.dfiOriginalFileNm
      || file.originalFileName
      || file.fileName
      || file.dfiStrNm
      || '-';
}

/*
 * 8D-ATTACH
 * 파일 업로드 상태 표시값 변환
 */
function formatImpDocStatus(file) {
  var status = file.dfiUploadSttsCd
            || file.uploadSttsCd
            || '';

  if (status === 'DONE') return '업로드완료';
  if (status === 'UPLOADING') return '업로드중';
  if (status === 'FAIL') return '실패';

  return status || '-';
}

/*
 * 8D-ATTACH
 * 다운로드/삭제에 사용할 파일번호 추출
 */
function getImpDocFileNo(file) {
  return file.dfiFileNo
      || file.fileNo
      || file.dfiNo
      || '';
}

/*
 * 8D-ATTACH
 * 수입의뢰번호 기준 첨부파일 목록 조회
 */
function loadImpDocs() {
  var irNo = getCurrentImpIrNo();
  var tbody = document.getElementById('imp-doc-list-body');
  var msgEl = document.getElementById('imp-doc-upload-msg');

  if (!tbody) {
    return;
  }

  if (!irNo) {
    tbody.innerHTML =
      '<tr><td colspan="4" class="imp-doc-empty">통관의뢰번호 조회 후 첨부파일 목록이 표시됩니다.</td></tr>';
    return;
  }

  var ctx = window.contextPath || '';

  tbody.innerHTML =
    '<tr><td colspan="4" class="imp-doc-empty">첨부파일 목록을 조회 중입니다...</td></tr>';

  fetch(ctx + '/broker/declare/impDocs.do?irNo=' + encodeURIComponent(irNo), {
    method: 'GET',
    headers: { 'Accept': 'application/json' }
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        tbody.innerHTML =
          '<tr><td colspan="4" class="imp-doc-empty error">'
          + (res.message || '첨부파일 조회에 실패했습니다.')
          + '</td></tr>';
        return;
      }

      renderImpDocs(res.list || []);

      if (msgEl) {
        msgEl.textContent = '첨부파일 ' + (res.list || []).length + '건이 조회되었습니다.';
        msgEl.style.color = '#64748b';
      }
    })
    .catch(function (err) {
      console.error(err);
      tbody.innerHTML =
        '<tr><td colspan="4" class="imp-doc-empty error">첨부파일 조회 통신 오류: '
        + err.message
        + '</td></tr>';
    });
}

/*
 * 8D-ATTACH
 * 첨부파일 목록 HTML 렌더링
 */
function renderImpDocs(list) {
  var tbody = document.getElementById('imp-doc-list-body');
  if (!tbody) return;

  if (!list || list.length === 0) {
    tbody.innerHTML =
      '<tr><td colspan="4" class="imp-doc-empty">등록된 첨부파일이 없습니다.</td></tr>';
    return;
  }

  function esc(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  var ctx = window.contextPath || '';

  tbody.innerHTML = list.map(function (file, idx) {
    var fileNo = getImpDocFileNo(file);
    var fileName = formatImpDocFileName(file);
    var status = formatImpDocStatus(file);

    return ''
      + '<tr>'
      + '  <td style="text-align:center">' + (idx + 1) + '</td>'
      + '  <td>' + esc(fileName) + '</td>'
      + '  <td style="text-align:center">' + esc(status) + '</td>'
      + '  <td style="text-align:center">'
      + '    <a class="mini mini-view" href="' + ctx + '/common/file/download.do?fileNo=' + encodeURIComponent(fileNo) + '">다운로드</a>'
      + '    <button type="button" class="mini mini-del" onclick="deleteImpDoc(' + fileNo + ')">삭제</button>'
      + '  </td>'
      + '</tr>';
  }).join('');
}



/*
 * 8D-ATTACH
 * 업로드 전 선택된 파일 초기화
 *
 * 실제 서버에 올라간 파일을 삭제하는 것이 아니라,
 * 아직 업로드하지 않은 input 선택값만 비운다.
 */
function clearSelectedImpDocs() {
  var fileEl = document.getElementById('imp-doc-files');
  var msgEl = document.getElementById('imp-doc-upload-msg');

  if (fileEl) {
    fileEl.value = '';
  }

  if (msgEl) {
    msgEl.textContent = '선택된 파일을 초기화했습니다. 다시 파일을 선택할 수 있습니다.';
    msgEl.style.color = '#64748b';
  }
}

/*
 * 8D-ATTACH
 * 업로드 전 선택 파일 임시 보관 배열
 *
 * 기본 input[type=file]은 다시 선택하면 기존 선택이 교체될 수 있으므로,
 * 사용자가 파일 선택을 여러 번 눌러도 이 배열에 누적해서 관리한다.
 */
var selectedImpDocFiles = [];

/*
 * 8D-ATTACH
 * 숨겨진 파일 input 열기
 */
function openImpDocFilePicker() {
  var fileEl = document.getElementById('imp-doc-files');
  if (fileEl) {
    fileEl.click();
  }
}

/*
 * 8D-ATTACH
 * 파일 선택창에서 고른 파일을 selectedImpDocFiles 배열에 누적한다.
 * 같은 파일을 중복 선택하면 name + size + lastModified 기준으로 한 번만 유지한다.
 */
function appendSelectedImpDocFiles() {
  var fileEl = document.getElementById('imp-doc-files');

  if (!fileEl || !fileEl.files || fileEl.files.length === 0) {
    return;
  }

  Array.prototype.forEach.call(fileEl.files, function (file) {
    var exists = selectedImpDocFiles.some(function (saved) {
      return saved.name === file.name
          && saved.size === file.size
          && saved.lastModified === file.lastModified;
    });

    if (!exists) {
      selectedImpDocFiles.push(file);
    }
  });

  /*
   * 같은 파일을 다시 선택해도 change 이벤트가 다시 발생할 수 있게 input 값 초기화
   */
  fileEl.value = '';

  renderSelectedImpDocFiles();
}

/*
 * 8D-ATTACH
 * 업로드 전 선택 파일 목록 표시
 */
function renderSelectedImpDocFiles() {
  var summaryEl = document.getElementById('imp-doc-selected-summary');
  var listEl = document.getElementById('imp-doc-selected-list');

  if (!summaryEl || !listEl) {
    return;
  }

  if (!selectedImpDocFiles || selectedImpDocFiles.length === 0) {
    summaryEl.textContent = '선택된 파일이 없습니다.';
    listEl.innerHTML = '';
    return;
  }

  summaryEl.textContent = '선택된 파일 ' + selectedImpDocFiles.length + '개';

  listEl.innerHTML = selectedImpDocFiles.map(function (file, idx) {
    return ''
      + '<span class="imp-doc-selected-chip">'
      + escapeImpDocText(file.name)
      + '<button type="button" onclick="removeSelectedImpDocFile(' + idx + ')">×</button>'
      + '</span>';
  }).join('');
}

/*
 * 8D-ATTACH
 * 선택 파일 중 1개만 제거
 */
function removeSelectedImpDocFile(index) {
  if (index < 0 || index >= selectedImpDocFiles.length) {
    return;
  }

  selectedImpDocFiles.splice(index, 1);
  renderSelectedImpDocFiles();
}

/*
 * 8D-ATTACH
 * HTML escape
 */
function escapeImpDocText(value) {
  return String(value == null ? '' : value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

/*
 * 8D-ATTACH
 * 업로드 전 선택된 파일 전체 초기화
 *
 * 실제 서버에 올라간 파일을 삭제하는 것이 아니라,
 * 아직 업로드하지 않은 선택 목록만 비운다.
 */
function clearSelectedImpDocs() {
  var fileEl = document.getElementById('imp-doc-files');
  var msgEl = document.getElementById('imp-doc-upload-msg');

  selectedImpDocFiles = [];

  if (fileEl) {
    fileEl.value = '';
  }

  renderSelectedImpDocFiles();

  if (msgEl) {
    msgEl.textContent = '선택된 파일을 초기화했습니다. 다시 파일을 선택할 수 있습니다.';
    msgEl.style.color = '#64748b';
  }
}
/*
 * 8D-ATTACH
 * 수입신고서 첨부파일 업로드
 *
 * 서버 처리:
 * - IR_TFG_NO 있음  → 기존 파일그룹에 추가
 * - IR_TFG_NO 없음  → 새 파일그룹 생성 후 IMP_RQST.IR_TFG_NO 업데이트
 */
function uploadImpDocs() {
  var irNo = getCurrentImpIrNo();
  var fileEl = document.getElementById('imp-doc-files');
  var msgEl = document.getElementById('imp-doc-upload-msg');

  if (!irNo) {
    alert('통관의뢰번호를 먼저 조회해주세요.');
    var irNoEl = document.getElementById('imp-declare-input');
    if (irNoEl) irNoEl.focus();
    return;
  }

  if (!selectedImpDocFiles || selectedImpDocFiles.length === 0) {
    alert('업로드할 파일을 선택해주세요.');
    return;
  }

  var formData = new FormData();
  formData.append('irNo', irNo);

  selectedImpDocFiles.forEach(function (file) {
    formData.append('files', file);
  });

  var ctx = window.contextPath || '';

  if (msgEl) {
    msgEl.textContent = '첨부서류를 업로드 중입니다...';
    msgEl.style.color = '#64748b';
  }

  fetch(ctx + '/broker/declare/uploadImpDocs.do', {
    method: 'POST',
    headers: getCsrfHeaders(),
    body: formData
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        if (msgEl) {
          msgEl.textContent = res.message || '업로드에 실패했습니다.';
          msgEl.style.color = '#dc2626';
        }
        alert(res.message || '업로드에 실패했습니다.');
        return;
      }

      if (msgEl) {
        msgEl.textContent = '첨부서류가 업로드되었습니다.';
        msgEl.style.color = '#059669';
      }

	  selectedImpDocFiles = [];
	  if (fileEl) {
	    fileEl.value = '';
	  }
	  renderSelectedImpDocFiles();
	  
      /*
       * 8D-ATTACH
       * 업로드 후 목록 즉시 갱신
       */
      loadImpDocs();
    })
    .catch(function (err) {
      console.error(err);

      if (msgEl) {
        msgEl.textContent = '업로드 통신 오류: ' + err.message;
        msgEl.style.color = '#dc2626';
      }

      alert('업로드 통신 오류: ' + err.message);
    });
}

/*
 * 8D-ATTACH
 * 수입신고서 첨부파일 삭제
 */
function deleteImpDoc(fileNo) {
  var irNo = getCurrentImpIrNo();

  if (!irNo) {
    alert('통관의뢰번호를 먼저 조회해주세요.');
    return;
  }

  if (!fileNo) {
    alert('삭제할 파일번호가 없습니다.');
    return;
  }

  if (!confirm('선택한 첨부파일을 삭제하시겠습니까?')) {
    return;
  }

  var formData = new FormData();
  formData.append('irNo', irNo);
  formData.append('fileNo', fileNo);

  var ctx = window.contextPath || '';

  fetch(ctx + '/broker/declare/deleteImpDoc.do', {
    method: 'POST',
    headers: getCsrfHeaders(),
    body: formData
  })
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function (res) {
      if (!res.success) {
        alert(res.message || '삭제에 실패했습니다.');
        return;
      }

      /*
       * 8D-ATTACH
       * 삭제 후 목록 즉시 갱신
       */
      loadImpDocs();
    })
    .catch(function (err) {
      console.error(err);
      alert('삭제 통신 오류: ' + err.message);
    });
}
