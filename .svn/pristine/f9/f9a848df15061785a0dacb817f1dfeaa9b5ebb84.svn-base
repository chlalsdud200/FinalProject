@charset "UTF-8";

/* =========================================================
   TACS 검역기관 통합검색 전용 스타일
   - 통합검색 검색창
   - 검색 결과 요약
   - 검색 결과 목록
   - 결과 없음 화면
========================================================= */

/* ===== 통합검색 상단 영역 ===== */
#pg-search .search-page-header {
  background: #fff;
  border: 1px solid #dbe5ef;
  padding: 24px;
  margin-bottom: 20px;
}

#pg-search .search-page-header h3 {
  font-size: 18px;
  font-weight: 900;
  color: #0f172a;
  margin-bottom: 6px;
}

#pg-search .search-page-header p {
  font-size: 12px;
  color: #697d8f;
}

/* ===== 통합검색 입력 영역 ===== */
#pg-search .search-main-box {
  display: flex;
  gap: 8px;
  background: #ecf4ff;
  border-left: 4px solid #565e74;
  padding: 16px;
  margin-bottom: 20px;
}

#pg-search .search-main-box input {
  flex: 1;
  height: 38px;
  padding: 8px 12px;
  border: 1px solid #a0b4c8;
  background: #fff;
  color: #203444;
  font-size: 13px;
  outline: none;
}

#pg-search .search-main-box input:focus {
  border-color: #565e74;
  background: #f8fbff;
}

#pg-search .search-main-box button {
  height: 38px;
  padding: 0 18px;
  border: none;
  background: #565e74;
  color: #fff;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
}

#pg-search .search-main-box button:hover {
  background: #4a5268;
}

/* ===== 검색 필터 ===== */
#pg-search .search-filter-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 18px;
}

#pg-search .search-filter-chip {
  padding: 6px 14px;
  border: 1px solid #cbd5e1;
  background: #fff;
  color: #64748b;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
}

#pg-search .search-filter-chip:hover {
  background: #f1f5f9;
  color: #334155;
}

#pg-search .search-filter-chip.active {
  background: #0f172a;
  border-color: #0f172a;
  color: #fff;
}

/* ===== 검색 결과 요약 ===== */
#pg-search .search-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border: 1px solid #dbe5ef;
  padding: 14px 18px;
  margin-bottom: 12px;
}

#pg-search .search-summary .summary-left {
  font-size: 13px;
  color: #334155;
}

#pg-search .search-summary .summary-left strong {
  color: #0f172a;
  font-weight: 900;
}

#pg-search .search-summary .summary-right {
  font-size: 11px;
  color: #697d8f;
}

/* ===== 검색 결과 목록 ===== */
#pg-search .search-result-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

#pg-search .search-result-item {
  background: #fff;
  border: 1px solid #dbe5ef;
  padding: 18px 20px;
  cursor: pointer;
  transition: all .12s;
}

#pg-search .search-result-item:hover {
  background: #f8fbff;
  border-color: #cbdcf0;
}

#pg-search .search-result-top {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

#pg-search .search-result-type {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 52px;
  padding: 3px 8px;
  background: #ecf4ff;
  color: #565e74;
  font-size: 10px;
  font-weight: 800;
}

#pg-search .search-result-title {
  font-size: 14px;
  font-weight: 900;
  color: #0f172a;
}

#pg-search .search-result-desc {
  font-size: 12px;
  color: #4d6172;
  line-height: 1.6;
  margin-bottom: 8px;
}

#pg-search .search-result-meta {
  display: flex;
  gap: 12px;
  font-size: 11px;
  color: #94a3b8;
}

#pg-search .search-result-meta span {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

/* ===== 검색어 강조 ===== */
#pg-search mark {
  background: #fef3c7;
  color: #92400e;
  font-weight: 800;
  padding: 0 2px;
}

/* ===== 결과 없음 ===== */
#pg-search .search-empty {
  background: #fff;
  border: 1px dashed #cbd5e1;
  padding: 48px 24px;
  text-align: center;
  color: #697d8f;
}

#pg-search .search-empty .material-symbols-outlined {
  font-size: 42px;
  color: #94a3b8;
  margin-bottom: 10px;
}

#pg-search .search-empty h4 {
  font-size: 15px;
  font-weight: 900;
  color: #334155;
  margin-bottom: 6px;
}

#pg-search .search-empty p {
  font-size: 12px;
  color: #697d8f;
}

/* ===== 반응형 ===== */
@media (max-width: 900px) {
  #pg-search .search-main-box {
    flex-direction: column;
  }

  #pg-search .search-main-box button {
    width: 100%;
  }

  #pg-search .search-summary {
    align-items: flex-start;
    flex-direction: column;
    gap: 6px;
  }

  #pg-search .search-result-top {
    align-items: flex-start;
    flex-direction: column;
  }

  #pg-search .search-result-meta {
    flex-direction: column;
    gap: 4px;
  }
}