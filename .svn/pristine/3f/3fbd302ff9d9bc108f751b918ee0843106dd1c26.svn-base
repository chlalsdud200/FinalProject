spring.application.name=TACS

server.port=8077

server.servlet.encoding.charset=UTF-8
server.servlet.encoding.enabled=true
server.servlet.encoding.force=true

#jsp 설정
spring.mvc.view.prefix=/WEB-INF/views/
spring.mvc.view.suffix=.jsp

#로깅 레벨 설정
logging.level.kr.or.tacs=debug
logging.level.org.springframework.security =debug

mybatis.configuration.map-underscore-to-camel-case=true
mybatis.configuration.jdbc-type-for-null=null



mybatis.mapper-locations=classpath*:mybatis/mapper/**/*.xml
# Mapper XML location:
#   src/main/resources/mybatis/mapper/**/*.xml
# Actor/common mapper XML files should be placed under this folder.



# 세션 유지 설정: 서버 재시작 시 세션 정보를 파일에 저장하여 유지할지 여부
server.servlet.session.persistent=false

# 개별 파일 당 업로드 최대 크기 설정
spring.servlet.multipart.max-file-size=20MB

# 한 번의 요청 당 전체 업로드 최대 크기 설정
spring.servlet.multipart.max-request-size=50MB

# 파일 업로드 경로 설정
kr.or.tacs.upload.path=C:/upload/



# Secret properties
spring.config.import=optional:classpath:application-secret.properties

# Google Drive OAuth
google.drive.redirect-uri=http://localhost:8077/google/drive/callback
google.drive.scope=https://www.googleapis.com/auth/drive



# ============================================================
# HS코드 AI추천 기능 스위치
# - false: Milvus가 꺼져 있어도 프로젝트 전체 정상 기동
# - true : HS AI추천 버튼 활성화
# ============================================================
hs.ai-recommend.enabled=true
hs.ai-recommend.health-url=http://127.0.0.1:9091/healthz
hs.ai-recommend.timeout-ms=1500
hs.ai-recommend.attu-url=http://localhost:8000



# ============================================================
# HS AI추천 - Milvus VectorStore
# 팀원이 Milvus 없이 개발할 때는 아래 type을 none으로 둔다.
# 실제 Milvus 검색 테스트할 때만 milvus로 변경한다.
# ============================================================

# Milvus 미사용 기본값
# spring.ai.vectorstore.type=none

# Milvus 실제 검색 테스트 시 사용
spring.ai.vectorstore.type=milvus
#milvus

spring.ai.vectorstore.milvus.client.host=localhost
spring.ai.vectorstore.milvus.client.port=19530
spring.ai.vectorstore.milvus.database-name=default
spring.ai.vectorstore.milvus.collection-name=hs_reference_chunks
spring.ai.vectorstore.milvus.initialize-schema=true
spring.ai.vectorstore.milvus.embedding-dimension=768
spring.ai.vectorstore.milvus.index-type=IVF_FLAT
spring.ai.vectorstore.milvus.metric-type=COSINE
spring.ai.vectorstore.milvus.id-field-name=doc_id
spring.ai.vectorstore.milvus.content-field-name=content
spring.ai.vectorstore.milvus.metadata-field-name=metadata
spring.ai.vectorstore.milvus.embedding-field-name=embedding

