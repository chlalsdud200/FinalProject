#dashboard-view .bg-primary-container{padding:16px 24px !important;background:#dae2fd !important;border-left:8px solid #565e74 !important;margin-bottom:24px !important}
#dashboard-view .bg-primary-container h2{font-size:16px !important;font-weight:700 !important;color:#4a5167 !important}
#dashboard-view .bg-primary-container h2 span{font-weight:900 !important;color:#565e74 !important}
#dashboard-view .bg-primary-container p{font-size:10px !important;color:#4a5167 !important;opacity:.7 !important;margin-top:2px !important}
.kpi{background:#fff !important;padding:20px 24px !important;border-bottom:4px solid #565e74 !important;cursor:pointer;transition:transform .1s}
.kpi:hover{transform:translateY(-2px)}
#dashboard-view .bg-surface-container-low,
#dashboard-view .bg-surface-container-lowest{background:#ecf4ff !important;border:none !important;padding:20px !important}
#dashboard-view .bg-surface-container-lowest.border-2{background:#fff !important;border:2px solid #d0e5fa !important}
#dashboard-view .bg-surface-container-low button{background:#fff !important;border:none !important;border-bottom:2px solid #e2e8f0 !important;color:#203444 !important}
#dashboard-view .bg-surface-container-low button:hover{background:#dae2fd !important;color:#203444 !important}
