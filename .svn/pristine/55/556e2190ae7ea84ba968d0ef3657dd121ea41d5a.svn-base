@charset "UTF-8";

/* Customs specific styles */
.customs-header {
  background: #fff;
  padding: 20px;
  border: 1px solid #e2e8f0;
  margin-bottom: 20px;
}

.customs-header h2 {
  font-size: 16px;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8px;
}

.customs-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 20px;
}

.customs-stat-item {
  background: #fff;
  padding: 16px;
  border: 1px solid #e2e8f0;
  text-align: center;
}

.customs-stat-label {
  font-size: 11px;
  font-weight: 700;
  color: #64748b;
  text-transform: uppercase;
}

.customs-stat-value {
  font-size: 28px;
  font-weight: 900;
  color: #0f172a;
  margin: 8px 0;
}
