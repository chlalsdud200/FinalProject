package kr.or.tacs.officer.basicscreen.mapper;

import java.util.List;
import java.util.Map;

import org.apache.ibatis.annotations.Mapper;

import kr.or.tacs.dto.officer.BasicScreenDetailDTO;

@Mapper
public interface IScreenDetailMapper {
	
	BasicScreenDetailDTO selectImportDetail(String reqNo);
    BasicScreenDetailDTO selectExportDetail(String reqNo);

	List<BasicScreenDetailDTO> selectImportItems(String reqNo);
	List<BasicScreenDetailDTO> selectExportItems(String reqNo);


    String selectTargetBrokerId(String reqNo);

    int insertItemSupplement(Map<String, Object> param);
    int insertItemReject(Map<String, Object> param);
    int insertItemAcceptHistory(Map<String, Object> param);

}
