<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.broker.quarantine.mapper.IQuarantineMapper">

    <!-- 검역결과조회 목록 -->
    <select id="selectImportQuarantineResultList" parameterType="kr.or.tacs.vo.broker.quarantine.QuarantineVO" resultType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">

        SELECT
            REQ.IIR_REQ_NO AS iirReqNo,
            REQ.IR_NO AS iirAplyNo,
            REQ.IR_NO AS irNo,
            REQ.IIR_QRTN_INST_CD AS iirQrtnInstCd,
            REQ.IIR_RSN_CN AS iirRsnCn,
            REQ.IIR_STATUS_CD AS iirStatusCd,

            CASE REQ.IIR_STATUS_CD
                WHEN '요청' THEN '요청'
                WHEN '배정' THEN '배정'
                WHEN '진행중' THEN '진행중'
                WHEN '완료' THEN '완료'
                WHEN '취소' THEN '취소'
                WHEN 'REQ' THEN '요청'
                WHEN 'ASSIGN' THEN '배정'
                WHEN 'INPRG' THEN '진행중'
                WHEN 'CMPL' THEN '완료'
                WHEN 'CANCEL' THEN '취소'
                ELSE REQ.IIR_STATUS_CD
            END AS iirStatusNm,

            TO_CHAR(REQ.IIR_DT, 'YYYY-MM-DD') AS iirDt,
            TO_CHAR(NVL(REQ.IIR_CMPL_DT, RES.IIR_RESULT_DT), 'YYYY-MM-DD') AS iirCmplDt,

            RES.IIR_RESULT_STATUS_CD AS iirResultStatusCd,
            RES.IIR_RESULT_CD AS iirResultCd,

            CASE RES.IIR_RESULT_CD
                WHEN 'PASS' THEN '합격'
                WHEN 'FAIL' THEN '불합격'
                WHEN 'SUPP' THEN '보완요청'
                WHEN 'COND' THEN '조건부합격'
                WHEN '합격' THEN '합격'
                WHEN '불합격' THEN '불합격'
                WHEN '보완요청' THEN '보완요청'
                ELSE RES.IIR_RESULT_CD
            END AS iirResultNm,

            TO_CHAR(RES.IIR_RESULT_DT, 'YYYY-MM-DD') AS iirResultDt,

            IR.IR_OWR_ID AS irOwrId,
            IR.IR_BROKER_ID AS irBrokerId,
            IR.IR_BL_AWB_NO AS irBlAwbNo,

            NVL(ID.ID_IMPR_NM, IR.IR_OWR_ID) AS idImprNm,

            /*
             * 목록 품목 정보
             * 1순위: IMP_INS_REQ 대표 컬럼
             * 2순위: IMP_INS_REQ_ITEM 검역신청 품목
             * 3순위: IMP_DCLR_ITEM 수입신고 품목
             */
            NVL(REQ.IIR_MAIN_GOODS_NM, NVL(QITEM.IIRI_GOODS_NM, ITEM.IDI_DCLR_GDSNM)) AS idiDclrGdsnm,
            NVL(REQ.IIR_MAIN_HS_CD, NVL(QITEM.IIRI_HS_CD, ITEM.IDI_HS_CD)) AS idiHsCd,
            NVL(TO_CHAR(QITEM.IIRI_QTY), TO_CHAR(ITEM.IDI_QTY)) AS idiQty,
            NVL(QITEM.IIRI_QTY_UNIT_CD, ITEM.IDI_QTY_UNIT_CD) AS idiQtyUnitCd,
            NVL(QITEM.ITEM_COUNT, ITEM.ITEM_COUNT) AS itemCount

        FROM IMP_INS_REQ REQ
             LEFT JOIN IMP_INS_RESULT RES
                    ON RES.IIR_IMP_INS_REQ_NO = REQ.IIR_REQ_NO

             LEFT JOIN IMP_RQST IR
                    ON IR.IR_NO = REQ.IR_NO

             LEFT JOIN IMP_DCLR ID
                    ON ID.ID_IR_NO = IR.IR_NO

             <!-- 수입신고 품목 fallback -->
             LEFT JOIN (
                SELECT
                    IDI_IR_NO,
                    MIN(IDI_HS_CD) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_HS_CD,
                    MIN(IDI_DCLR_GDSNM) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_DCLR_GDSNM,
                    MIN(IDI_QTY) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_QTY,
                    MIN(IDI_QTY_UNIT_CD) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_QTY_UNIT_CD,
                    COUNT(*) AS ITEM_COUNT
                FROM IMP_DCLR_ITEM
                GROUP BY IDI_IR_NO
             ) ITEM
                    ON ITEM.IDI_IR_NO = IR.IR_NO

             <!-- 검역신청 품목 우선 조회 -->
             LEFT JOIN (
                SELECT
                    IIRI_REQ_NO,
                    MIN(IIRI_HS_CD) KEEP (DENSE_RANK FIRST ORDER BY IIRI_SN) AS IIRI_HS_CD,
                    MIN(IIRI_GOODS_NM) KEEP (DENSE_RANK FIRST ORDER BY IIRI_SN) AS IIRI_GOODS_NM,
                    MIN(IIRI_QTY) KEEP (DENSE_RANK FIRST ORDER BY IIRI_SN) AS IIRI_QTY,
                    MIN(IIRI_QTY_UNIT_CD) KEEP (DENSE_RANK FIRST ORDER BY IIRI_SN) AS IIRI_QTY_UNIT_CD,
                    COUNT(*) AS ITEM_COUNT
                FROM IMP_INS_REQ_ITEM
                GROUP BY IIRI_REQ_NO
             ) QITEM
                    ON QITEM.IIRI_REQ_NO = REQ.IIR_REQ_NO

        WHERE 1 = 1

        <if test="loginBrokerId != null and loginBrokerId != ''">
            AND IR.IR_BROKER_ID = #{loginBrokerId}
        </if>

        <if test="searchApplyNo != null and searchApplyNo != ''">
            AND (
                REQ.IIR_REQ_NO LIKE '%' || #{searchApplyNo} || '%'
                OR REQ.IR_NO LIKE '%' || #{searchApplyNo} || '%'
            )
        </if>

        <if test="searchImporter != null and searchImporter != ''">
		    AND NVL(ID.ID_IMPR_NM, IR.IR_OWR_ID) LIKE '%' || #{searchImporter} || '%'
		</if>

        <if test="searchProductName != null and searchProductName != ''">
		    AND NVL(REQ.IIR_MAIN_GOODS_NM, NVL(QITEM.IIRI_GOODS_NM, ITEM.IDI_DCLR_GDSNM))
		        LIKE '%' || #{searchProductName} || '%'
		</if>

        <if test="searchHsCode != null and searchHsCode != ''">
            AND (
                REQ.IIR_MAIN_HS_CD LIKE '%' || #{searchHsCode} || '%'
                OR EXISTS (
                    SELECT 1
                    FROM IMP_INS_REQ_ITEM SI
                    WHERE SI.IIRI_REQ_NO = REQ.IIR_REQ_NO
                      AND SI.IIRI_HS_CD LIKE '%' || #{searchHsCode} || '%'
                )
                OR EXISTS (
                    SELECT 1
                    FROM IMP_DCLR_ITEM DI
                    WHERE DI.IDI_IR_NO = IR.IR_NO
                      AND DI.IDI_HS_CD LIKE '%' || #{searchHsCode} || '%'
                )
            )
        </if>

        <if test="searchResult != null and searchResult != ''">
		    AND CASE RES.IIR_RESULT_CD
		            WHEN 'PASS' THEN '합격'
		            WHEN 'FAIL' THEN '불합격'
		            WHEN 'SUPP' THEN '보완요청'
		            WHEN 'COND' THEN '조건부합격'
		            WHEN '합격' THEN '합격'
		            WHEN '불합격' THEN '불합격'
		            WHEN '보완요청' THEN '보완요청'
		            ELSE RES.IIR_RESULT_CD
		        END = #{searchResult}
		</if>

        <if test="searchFromDate != null and searchFromDate != ''">
		    AND RES.IIR_RESULT_DT &gt;= TO_DATE(#{searchFromDate}, 'YYYY-MM-DD')
		</if>
		
		<if test="searchToDate != null and searchToDate != ''">
		    AND RES.IIR_RESULT_DT &lt; TO_DATE(#{searchToDate}, 'YYYY-MM-DD') + 1
		</if>

        ORDER BY RES.IIR_RESULT_DT DESC NULLS LAST, REQ.IIR_DT DESC, REQ.IIR_REQ_NO DESC
    </select>


    <!-- 검역결과 상세 조회 -->
    <select id="selectImportQuarantineDetail" parameterType="string" resultType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">

        SELECT
            REQ.IIR_REQ_NO AS iirReqNo,
            REQ.IIR_TFG_NO AS iirTfgNo,            
            NULL AS iirReqOfficerId,
            REQ.IIR_QRTN_OFFICER_ID AS iirQrtnOfficerId,
            REQ.IR_NO AS iirAplyNo,
            REQ.IR_NO AS irNo,
            REQ.IIR_JRSD_RGN_AG_CD AS iirJrsdRgnAgCd,
            REQ.IIR_QRTN_INST_CD AS iirQrtnInstCd,
            REQ.IIR_RSN_CN AS iirRsnCn,
            REQ.IIR_STATUS_CD AS iirStatusCd,

            CASE REQ.IIR_STATUS_CD
                WHEN '요청' THEN '검역요청'
                WHEN '배정' THEN '담당배정'
                WHEN '진행중' THEN '검역진행중'
                WHEN '완료' THEN '검역완료'
                WHEN '취소' THEN '취소'
                WHEN 'REQ' THEN '검역요청'
                WHEN 'ASSIGN' THEN '담당배정'
                WHEN 'INPRG' THEN '검역진행중'
                WHEN 'CMPL' THEN '검역완료'
                WHEN 'CANCEL' THEN '취소'
                ELSE REQ.IIR_STATUS_CD
            END AS iirStatusNm,

            TO_CHAR(REQ.IIR_DT, 'YYYY-MM-DD HH24:MI') AS iirDt,
            TO_CHAR(REQ.IIR_RPLY_DDLINE_DT, 'YYYY-MM-DD') AS iirRplyDdlineDt,
            TO_CHAR(REQ.IIR_CMPL_DT, 'YYYY-MM-DD HH24:MI') AS iirCmplDt,

            REQ.IIR_EXPORTER_NM AS iirExporterNm,
            REQ.IIR_EXPORTER_COMPANY_NM AS iirExporterCompanyNm,
            REQ.IIR_EXPORTER_ADRES AS iirExporterAdres,
            REQ.IIR_EXPORT_COUNTRY_CD AS iirExportCountryCd,
            REQ.IIR_ORIGIN_COUNTRY_CD AS iirOriginCountryCd,
            REQ.IIR_PHYTO_CERT_NO AS iirPhytoCertNo,
            TO_CHAR(REQ.IIR_PHYTO_CERT_ISSUE_DT, 'YYYY-MM-DD') AS iirPhytoCertIssueDt,
            REQ.IIR_TRANSPORT_TYPE_CD AS iirTransportTypeCd,
            REQ.IIR_TRANSPORT_NM AS iirTransportNm,
            REQ.IIR_LOAD_PORT_CD AS iirLoadPortCd,
            TO_CHAR(REQ.IIR_SHIP_DT, 'YYYY-MM-DD') AS iirShipDt,
            REQ.IIR_ARRV_PORT_CD AS iirArrvPortCd,
            TO_CHAR(REQ.IIR_ARRV_DT, 'YYYY-MM-DD') AS iirArrvDt,
            REQ.IIR_MAIN_GOODS_NM AS iirMainGoodsNm,
            REQ.IIR_MAIN_HS_CD AS iirMainHsCd,
            REQ.IIR_TOTAL_PKG_CNT AS iirTotalPkgCnt,
            REQ.IIR_PKG_UNIT_CD AS iirPkgUnitCd,
            REQ.IIR_TOTAL_WEIGHT AS iirTotalWeight,
            REQ.IIR_PKG_MATERIAL AS iirPkgMaterial,
            REQ.IIR_WOOD_PKG_YN AS iirWoodPkgYn,
            REQ.IIR_WOOD_PKG_MARK_NO AS iirWoodPkgMarkNo,

            LOC.IIL_NO AS iilNo,
            LOC.IIL_TY_CD AS iilTyCd,
            LOC.IIL_NM AS iilNm,
            LOC.IIL_ZIP AS iilZip,
            LOC.IIL_ADRES AS iilAdres,
            LOC.IIL_DETAIL_ADRES AS iilDetailAdres,
            TO_CHAR(LOC.IIL_PLAN_DT, 'YYYY-MM-DD HH24:MI') AS iilPlanDt,

            RES.IIR_NO AS iirNo,
            RES.IIR_RSLT_OFFICER_ID AS iirRsltOfficerId,
            OFCR.OFFICER_NM AS iirRsltOfficerNm,
            RES.IIR_RESULT_STATUS_CD AS iirResultStatusCd,

            CASE RES.IIR_RESULT_STATUS_CD
                WHEN '검역진행중' THEN '검역진행중'
                WHEN '검역반려' THEN '검역반려'
                WHEN '검역완료' THEN '검역완료'
                WHEN 'INPRG' THEN '검역진행중'
                WHEN 'RJCT' THEN '검역반려'
                WHEN 'CMPL' THEN '검역완료'
                ELSE RES.IIR_RESULT_STATUS_CD
            END AS iirResultStatusNm,

            RES.IIR_RESULT_CD AS iirResultCd,

            CASE RES.IIR_RESULT_CD
                WHEN 'PASS' THEN '합격'
                WHEN 'FAIL' THEN '불합격'
                WHEN 'SUPP' THEN '보완요청'
                WHEN 'COND' THEN '조건부합격'
                WHEN '합격' THEN '합격'
                WHEN '불합격' THEN '불합격'
                WHEN '보완요청' THEN '보완요청'
                ELSE RES.IIR_RESULT_CD
            END AS iirResultNm,

            RES.IIR_RESULT_FOLLOWUP_CD AS iirResultFollowupCd,
            RES.IIR_RESULT_CN AS iirResultCn,
            TO_CHAR(RES.IIR_RESULT_DT, 'YYYY-MM-DD HH24:MI') AS iirResultDt,

            IR.IR_OWR_ID AS irOwrId,
            IR.IR_BROKER_ID AS irBrokerId,
            IR.IR_BL_AWB_NO AS irBlAwbNo,
            IR.IR_CSTM_IDF_NO AS irCstmIdfNo,
            IR.IR_ARRV_PORT_CD AS irArrvPortCd,

            CASE
                WHEN LENGTH(IR.IR_ARRV_SCHD_YMD) = 8
                    THEN SUBSTR(IR.IR_ARRV_SCHD_YMD, 1, 4) || '-' ||
                         SUBSTR(IR.IR_ARRV_SCHD_YMD, 5, 2) || '-' ||
                         SUBSTR(IR.IR_ARRV_SCHD_YMD, 7, 2)
                ELSE IR.IR_ARRV_SCHD_YMD
            END AS irArrvSchdYmd,

            IR.IR_DCLR_CURR_CD AS irDclrCurrCd,
            IR.IR_INVC_AMT AS irInvcAmt,
            IR.IR_CN AS irCn,
            IR.IR_GG_NO AS impCgNo,
            IR.IR_COMMENT AS irComment,

            NVL(ID.ID_IMPR_NM, IR.IR_OWR_ID) AS idImprNm,
            ID.ID_OVRSS_NM AS idOvrssNm,
            ID.ID_OVRSS_CNTRY_CD AS idOvrssCntryCd,
            ID.ID_CGO_MNG_NO AS idCgoMngNo,
            ID.ID_MBL_NO AS idMblNo,
            ID.ID_TOT_PKG_CNT AS idTotPkgCnt,
            ID.ID_TOT_WT AS idTotWt,
            ID.ID_INSP_PLCE_CD AS idInspPlceCd,
            ID.ID_ARVL_YMD AS idArvlYmd,

            /*
             * 상세 모달 수출국
             * 검역신청서에 저장된 수출국을 우선 표시하고,
             * 없으면 수입신고의 선적국가를 표시한다.
             */
            NVL(REQ.IIR_EXPORT_COUNTRY_CD, ID.ID_SHIPOUT_CNTRY_CD) AS idShipoutCntryCd,

            /*
             * 상세 모달 품목 정보
             * 1순위: IMP_INS_REQ_ITEM 검역신청 품목
             * 2순위: IMP_DCLR_ITEM 수입신고 품목
             * 3순위: IMP_INS_REQ 대표 품목
             */
            NVL(QITEM.IIRI_HS_CD, NVL(ITEM.IDI_HS_CD, REQ.IIR_MAIN_HS_CD)) AS idiHsCd,
            NVL(QITEM.IIRI_GOODS_NM, NVL(ITEM.IDI_DCLR_GDSNM, REQ.IIR_MAIN_GOODS_NM)) AS idiDclrGdsnm,
            ITEM.IDI_TRDNG_GDSNM AS idiTrdngGdsnm,
            NVL(TO_CHAR(QITEM.IIRI_QTY), TO_CHAR(ITEM.IDI_QTY)) AS idiQty,
            NVL(QITEM.IIRI_QTY_UNIT_CD, ITEM.IDI_QTY_UNIT_CD) AS idiQtyUnitCd,
            NVL(TO_CHAR(QITEM.IIRI_NET_WEIGHT), TO_CHAR(ITEM.IDI_NET_WT)) AS idiNetWt,
            NVL(QITEM.IIRI_ORIGIN_COUNTRY_CD, ITEM.IDI_ORGN_CNTRY_CD) AS idiOrgnCntryCd,
            NVL(QITEM.ITEM_COUNT, ITEM.ITEM_COUNT) AS itemCount,

            BR.BROKER_NM AS brokerNm,
			BR.BROKER_OFFICE_NM AS brokerOfficeNm,
			BR.BROKER_TELNO AS brokerTelno,
			BR.BROKER_EMAIL AS brokerEmail,
			
			/*
			 * SUPP_RQST 보완요청/보완제출 정보
			 *
			 * 검역기관이 관세사에게 보낸 최신 보완요청 1건을 조회한다.
			 * 관세사 상세 화면에서 보완요청 내용을 읽고,
			 * 다음 단계에서 보완내용/서류를 제출할 때 사용한다.
			 */
			SUPP.SR_NO AS srNo,
			SUPP.SR_REF_BIZ_CD AS srRefBizCd,
			SUPP.SR_REF_NO AS srRefNo,
			SUPP.SENDER_ID AS senderId,
			SUPP.SENDER_TY_CD AS senderTyCd,
			SUPP.RECEIVER_ID AS receiverId,
			SUPP.RECEIVER_TY_CD AS receiverTyCd,
			SUPP.SR_STATUS_CD AS srStatusCd,
			
			CASE SUPP.SR_STATUS_CD
			    WHEN 'REQ' THEN '보완요청'
			    WHEN 'SUB' THEN '보완제출완료'
			    WHEN 'APR' THEN '보완확인완료'
			    ELSE SUPP.SR_STATUS_CD
			END AS srStatusNm,
			
			TO_CHAR(SUPP.SR_REQ_DT, 'YYYY-MM-DD HH24:MI') AS srReqDt,
			TO_CHAR(SUPP.SR_SUBMIT_DT, 'YYYY-MM-DD HH24:MI') AS srSubmitDt,
			TO_CHAR(SUPP.SR_APPR_DT, 'YYYY-MM-DD HH24:MI') AS srApprDt,
			SUPP.SR_REQ_CN AS srReqCn,
			SUPP.SR_SUBMIT_CN AS srSubmitCn

        FROM IMP_INS_REQ REQ
             LEFT JOIN IMP_INS_LOC LOC
                    ON LOC.IIL_REQ_NO = REQ.IIR_REQ_NO

             LEFT JOIN IMP_INS_RESULT RES
                    ON RES.IIR_IMP_INS_REQ_NO = REQ.IIR_REQ_NO

             LEFT JOIN OFFICER OFCR
                    ON OFCR.OFFICER_ID = RES.IIR_RSLT_OFFICER_ID

             LEFT JOIN IMP_RQST IR
                    ON IR.IR_NO = REQ.IR_NO

             LEFT JOIN IMP_DCLR ID
                    ON ID.ID_IR_NO = IR.IR_NO

             <!-- 수입신고 품목 fallback -->
             LEFT JOIN (
                SELECT
                    IDI_IR_NO,
                    MIN(IDI_HS_CD) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_HS_CD,
                    MIN(IDI_DCLR_GDSNM) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_DCLR_GDSNM,
                    MIN(IDI_TRDNG_GDSNM) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_TRDNG_GDSNM,
                    MIN(IDI_QTY) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_QTY,
                    MIN(IDI_QTY_UNIT_CD) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_QTY_UNIT_CD,
                    MIN(IDI_NET_WT) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_NET_WT,
                    MIN(IDI_ORGN_CNTRY_CD) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_ORGN_CNTRY_CD,
                    COUNT(*) AS ITEM_COUNT
                FROM IMP_DCLR_ITEM
                GROUP BY IDI_IR_NO
             ) ITEM
                    ON ITEM.IDI_IR_NO = IR.IR_NO

             <!-- 검역신청 품목 우선 조회 -->
             LEFT JOIN (
                SELECT
                    IIRI_REQ_NO,
                    MIN(IIRI_HS_CD) KEEP (DENSE_RANK FIRST ORDER BY IIRI_SN) AS IIRI_HS_CD,
                    MIN(IIRI_GOODS_NM) KEEP (DENSE_RANK FIRST ORDER BY IIRI_SN) AS IIRI_GOODS_NM,
                    MIN(IIRI_QTY) KEEP (DENSE_RANK FIRST ORDER BY IIRI_SN) AS IIRI_QTY,
                    MIN(IIRI_QTY_UNIT_CD) KEEP (DENSE_RANK FIRST ORDER BY IIRI_SN) AS IIRI_QTY_UNIT_CD,
                    MIN(IIRI_NET_WEIGHT) KEEP (DENSE_RANK FIRST ORDER BY IIRI_SN) AS IIRI_NET_WEIGHT,
                    MIN(IIRI_ORIGIN_COUNTRY_CD) KEEP (DENSE_RANK FIRST ORDER BY IIRI_SN) AS IIRI_ORIGIN_COUNTRY_CD,
                    COUNT(*) AS ITEM_COUNT
                FROM IMP_INS_REQ_ITEM
                GROUP BY IIRI_REQ_NO
             ) QITEM
                    ON QITEM.IIRI_REQ_NO = REQ.IIR_REQ_NO

             LEFT JOIN BROKER BR
                    ON BR.BROKER_ID = IR.IR_BROKER_ID
                    
             /*
			 * 최신 보완요청 1건 조회
			 *
			 * SUPP_RQST는 보완요청/보완제출을 한 테이블에서 관리한다.
			 * 같은 검역요청에 재보완요청이 여러 번 생길 수 있으므로,
			 * SR_REQ_DT와 SR_NO 기준으로 가장 최근 1건만 가져온다.
			 */
			LEFT JOIN (
			    SELECT
			        SR_NO,
			        SR_REF_BIZ_CD,
			        SR_REF_NO,
			        SENDER_ID,
			        SENDER_TY_CD,
			        RECEIVER_ID,
			        RECEIVER_TY_CD,
			        SR_STATUS_CD,
			        SR_REQ_DT,
			        SR_SUBMIT_DT,
			        SR_APPR_DT,
			        SR_REQ_CN,
			        SR_SUBMIT_CN
			    FROM (
			        SELECT
			            SR.*,
			            ROW_NUMBER() OVER (
			                PARTITION BY SR.SR_REF_NO
			                ORDER BY SR.SR_REQ_DT DESC, SR.SR_NO DESC
			            ) AS RN
			        FROM SUPP_RQST SR
			        WHERE SR.SR_REF_BIZ_CD = 'IMP_INS_REQ'
			          AND SR.RECEIVER_TY_CD = 'BROKER'
			    )
			    WHERE RN = 1
			) SUPP
			       ON SUPP.SR_REF_NO = REQ.IIR_REQ_NO
			      AND SUPP.RECEIVER_ID = IR.IR_BROKER_ID
			
			        WHERE REQ.IIR_REQ_NO = #{iirReqNo}
    </select>
    
    <!-- 검역결과 상세 - 검역대상 품목 목록 조회 -->
	<select id="selectImportQuarantineItemList"
	        parameterType="string"
	        resultType="kr.or.tacs.vo.broker.quarantine.QuarantineItemVO">
	
	    SELECT
	        IIRI_SN AS iiriSn,
	        IIRI_REQ_NO AS iiriReqNo,
	        IIRI_HS_CD AS hsCd,
	        IIRI_GOODS_NM AS goodsNm,
	        IIRI_USE_CD AS useCd,
	        TO_CHAR(IIRI_QTY) AS qty,
	        IIRI_QTY_UNIT_CD AS qtyUnitCd,
	        TO_CHAR(IIRI_NET_WEIGHT) AS netWeight,
	        TO_CHAR(IIRI_PKG_CNT) AS pkgCnt,
	        IIRI_PKG_MATERIAL AS pkgMaterial,
	        IIRI_ORIGIN_COUNTRY_CD AS originCountryCd
	    FROM IMP_INS_REQ_ITEM
	    WHERE IIRI_REQ_NO = #{iirReqNo}
	    ORDER BY IIRI_SN
	
	</select>
    
    <!-- =========================================================
	     현장공무원 선택 목록 조회
	
	     목적:
	     - 수입검역신청 화면에서 관세사가 담당 현장공무원을 선택하기 위한 목록 조회
	     - OFFICER 테이블에서 현장공무원(FIELD_OFFICER)만 조회한다.
	
	     화면 사용:
	     - quarantineImport.jsp
	     - ${fieldOfficerList}
	     - <select name="iirQrtnOfficerId">
	
	     저장 흐름:
	     - 선택된 officerId가 QuarantineVO.iirQrtnOfficerId로 바인딩된다.
	     - IMP_INS_REQ.IIR_QRTN_OFFICER_ID에 저장된다.
	     - Service에서 해당 공무원의 OFFICER_INST_CD를 조회해서
	       IIR_JRSD_RGN_AG_CD에도 세팅한다.
	     ========================================================= -->
	<select id="selectFieldOfficerList" resultType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">
	
	    SELECT
	        OFFICER_ID       AS officerId,
	        OFFICER_NAME     AS officerName,
	        OFFICER_NM       AS officerNm,
	        OFFICER_INST_CD  AS officerInstCd,
	        OFFICER_DEPT_CD  AS officerDeptCd
	
	    FROM OFFICER
	
	    WHERE OFFICER_TY_CD = 'FIELD_OFFICER'
	
	    ORDER BY
	        OFFICER_INST_CD,
	        OFFICER_NM
	
	</select>


    <!-- 수입검역신청 가능한 수입의뢰 목록 조회 -->
    <select id="selectImportRequestCandidateList"
            parameterType="string"
            resultType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">

        SELECT
            IR.IR_NO AS irNo,
            IR.IR_OWR_ID AS irOwrId,
            OW.OWR_NM AS importerNm,
            OW.OWR_NM AS importerCompanyNm,
            OW.OWR_TELNO AS importerTelno,
            OW.OWR_EMAIL AS importerEmail,
            OW.OWR_ADRES AS importerAdres,
            OW.OWR_DETAIL_ADRES AS importerDetailAdres,

            IR.IR_BROKER_ID AS irBrokerId,
            IR.IR_STATUS_CD AS irStatusCd,
            IR.IR_BL_AWB_NO AS irBlAwbNo,
            IR.IR_CSTM_IDF_NO AS irCstmIdfNo,
            IR.IR_ARRV_PORT_CD AS irArrvPortCd,

            CASE
                WHEN LENGTH(IR.IR_ARRV_SCHD_YMD) = 8
                    THEN SUBSTR(IR.IR_ARRV_SCHD_YMD, 1, 4) || '-' ||
                         SUBSTR(IR.IR_ARRV_SCHD_YMD, 5, 2) || '-' ||
                         SUBSTR(IR.IR_ARRV_SCHD_YMD, 7, 2)
                ELSE IR.IR_ARRV_SCHD_YMD
            END AS irArrvSchdYmd,

            TO_CHAR(IR.IR_DT, 'YYYY-MM-DD') AS irDt,

            NVL(ID.ID_IMPR_NM, IR.IR_OWR_ID) AS idImprNm,
            ID.ID_OVRSS_NM AS idOvrssNm,
            ID.ID_OVRSS_CNTRY_CD AS idOvrssCntryCd,
            ID.ID_CGO_MNG_NO AS idCgoMngNo,
            ID.ID_TOT_PKG_CNT AS idTotPkgCnt,
            ID.ID_TOT_WT AS idTotWt,
            ID.ID_SHIPOUT_CNTRY_CD AS idShipoutCntryCd,

            ITEM.IDI_HS_CD AS idiHsCd,
            ITEM.IDI_DCLR_GDSNM AS idiDclrGdsnm,
            ITEM.IDI_QTY AS idiQty,
            ITEM.IDI_QTY_UNIT_CD AS idiQtyUnitCd,
            ITEM.IDI_NET_WT AS idiNetWt,
            ITEM.IDI_ORGN_CNTRY_CD AS idiOrgnCntryCd,
            ITEM.ITEM_COUNT AS itemCount

        FROM IMP_RQST IR
             LEFT JOIN IMP_DCLR ID
                    ON ID.ID_IR_NO = IR.IR_NO

             LEFT JOIN OWNER OW
                    ON OW.OWR_ID = IR.IR_OWR_ID

             LEFT JOIN (
                SELECT
                    IDI_IR_NO,
                    MIN(IDI_HS_CD) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_HS_CD,
                    MIN(IDI_DCLR_GDSNM) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_DCLR_GDSNM,
                    MIN(IDI_QTY) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_QTY,
                    MIN(IDI_QTY_UNIT_CD) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_QTY_UNIT_CD,
                    MIN(IDI_NET_WT) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_NET_WT,
                    MIN(IDI_ORGN_CNTRY_CD) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_ORGN_CNTRY_CD,
                    COUNT(*) AS ITEM_COUNT
                FROM IMP_DCLR_ITEM
                GROUP BY IDI_IR_NO
             ) ITEM
                    ON ITEM.IDI_IR_NO = IR.IR_NO

        WHERE NVL(IR.IR_USE_YN, 'Y') = 'Y'

        <if test="_parameter != null and _parameter != ''">
            AND IR.IR_BROKER_ID = #{_parameter}
        </if>

        AND NOT EXISTS (
            SELECT 1
            FROM IMP_INS_REQ REQ
            WHERE REQ.IR_NO = IR.IR_NO
        )

        ORDER BY IR.IR_DT DESC NULLS LAST, IR.IR_NO DESC
    </select>


    <!-- 수입의뢰 선택 후 수입검역신청 화면 자동 세팅용 단건 조회 -->
    <select id="selectImportRequestForQuarantine"
            parameterType="kr.or.tacs.vo.broker.quarantine.QuarantineVO"
            resultType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">

        SELECT
            IR.IR_NO AS irNo,
            IR.IR_NO AS iirAplyNo,
            IR.IR_OWR_ID AS irOwrId,
            IR.IR_BROKER_ID AS irBrokerId,
            IR.IR_STATUS_CD AS irStatusCd,
            IR.IR_CSTM_IDF_NO AS irCstmIdfNo,
            IR.IR_CORP_REG_NO AS irCorpRegNo,

            CASE
                WHEN LENGTH(IR.IR_ARRV_SCHD_YMD) = 8
                    THEN SUBSTR(IR.IR_ARRV_SCHD_YMD, 1, 4) || '-' ||
                         SUBSTR(IR.IR_ARRV_SCHD_YMD, 5, 2) || '-' ||
                         SUBSTR(IR.IR_ARRV_SCHD_YMD, 7, 2)
                ELSE IR.IR_ARRV_SCHD_YMD
            END AS irArrvSchdYmd,

            IR.IR_BL_AWB_NO AS irBlAwbNo,
            IR.IR_DCLR_CURR_CD AS irDclrCurrCd,
            IR.IR_INVC_AMT AS irInvcAmt,
            IR.IR_CN AS irCn,
            TO_CHAR(IR.IR_DT, 'YYYY-MM-DD') AS irDt,
            IR.IR_COMMENT AS irComment,

            OW.OWR_NM AS importerNm,
            OW.OWR_NM AS importerCompanyNm,
            OW.OWR_TELNO AS importerTelno,
            OW.OWR_EMAIL AS importerEmail,
            OW.OWR_ADRES AS importerAdres,
            OW.OWR_DETAIL_ADRES AS importerDetailAdres,

            BR.BROKER_NM AS brokerNm,
            BR.BROKER_OFFICE_NM AS brokerOfficeNm,
            BR.BROKER_EMAIL AS brokerEmail,
            BR.BROKER_TELNO AS brokerTelno,

            NVL(ID.ID_IMPR_NM, IR.IR_OWR_ID) AS idImprNm,
            ID.ID_OVRSS_NM AS idOvrssNm,
            ID.ID_OVRSS_CNTRY_CD AS idOvrssCntryCd,
            ID.ID_CGO_MNG_NO AS idCgoMngNo,
            ID.ID_MBL_NO AS idMblNo,
            ID.ID_TOT_PKG_CNT AS idTotPkgCnt,
            ID.ID_TOT_WT AS idTotWt,
            ID.ID_TRNSP_MN_CD AS idTrnspMnCd,
            ID.ID_TRNSP_MN_CD AS iirTransportTypeCd,
            ID.ID_TOT_PKG_UNIT_CD AS iirPkgUnitCd,
            ID.ID_INSP_PLCE_CD AS idInspPlceCd,
            ID.ID_ARVL_YMD AS idArvlYmd,
            ID.ID_SHIPOUT_CNTRY_CD AS idShipoutCntryCd,

            IR.IR_ARRV_PORT_CD AS irArrvPortCd,
            IR.IR_ARRV_PORT_CD AS iirArrvPortCd,

            ID.ID_SHIPOUT_CNTRY_CD AS iirExportCountryCd,
            ITEM.IDI_ORGN_CNTRY_CD AS iirOriginCountryCd,

            ITEM.IDI_HS_CD AS idiHsCd,
            ITEM.IDI_HS_CD AS iirMainHsCd,
            ITEM.IDI_DCLR_GDSNM AS idiDclrGdsnm,
            ITEM.IDI_DCLR_GDSNM AS iirMainGoodsNm,
            ITEM.IDI_QTY AS idiQty,
            ITEM.IDI_QTY_UNIT_CD AS idiQtyUnitCd,
            ITEM.IDI_NET_WT AS idiNetWt,
            ITEM.IDI_ORGN_CNTRY_CD AS idiOrgnCntryCd,
            ITEM.ITEM_COUNT AS itemCount,

            ID.ID_TOT_PKG_CNT AS iirTotalPkgCnt,
            ID.ID_TOT_WT AS iirTotalWeight,
            
            NULL AS iilWilNo,
			'BONDED_WH' AS iilTyCd,
			NULL AS iilNm,
			NULL AS iilZip,
			NULL AS iilAdres,
			NULL AS iilDetailAdres

        FROM IMP_RQST IR
             LEFT JOIN IMP_DCLR ID
                    ON ID.ID_IR_NO = IR.IR_NO

             LEFT JOIN OWNER OW
                    ON OW.OWR_ID = IR.IR_OWR_ID

             LEFT JOIN BROKER BR
                    ON BR.BROKER_ID = IR.IR_BROKER_ID

             LEFT JOIN (
                SELECT
                    IDI_IR_NO,
                    MIN(IDI_HS_CD) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_HS_CD,
                    MIN(IDI_DCLR_GDSNM) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_DCLR_GDSNM,
                    MIN(IDI_QTY) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_QTY,
                    MIN(IDI_QTY_UNIT_CD) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_QTY_UNIT_CD,
                    MIN(IDI_NET_WT) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_NET_WT,
                    MIN(IDI_ORGN_CNTRY_CD) KEEP (DENSE_RANK FIRST ORDER BY IDI_SN) AS IDI_ORGN_CNTRY_CD,
                    COUNT(*) AS ITEM_COUNT
                FROM IMP_DCLR_ITEM
                GROUP BY IDI_IR_NO
             ) ITEM
                    ON ITEM.IDI_IR_NO = IR.IR_NO
                    
        WHERE IR.IR_NO = #{irNo}

        <if test="loginBrokerId != null and loginBrokerId != ''">
            AND IR.IR_BROKER_ID = #{loginBrokerId}
        </if>
    </select>


    <!-- 이미 검역신청이 등록된 수입의뢰인지 확인 -->
    <select id="countImportQuarantineRequest"
            parameterType="string"
            resultType="int">
        SELECT COUNT(*)
        FROM IMP_INS_REQ
        WHERE IR_NO = #{_parameter}
    </select>


    <!-- 수입검역요청 기본정보 등록 -->
    <insert id="insertImportQuarantineRequest"
            parameterType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">

        <!--
            검역요청번호 생성 규칙
            예: QI-20260522-0001
        -->
        <selectKey keyProperty="iirReqNo" resultType="string" order="BEFORE">
            SELECT
                'QI-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-' ||
                LPAD(
                    NVL(MAX(TO_NUMBER(SUBSTR(IIR_REQ_NO, 13))), 0) + 1,
                    4,
                    '0'
                )
            FROM IMP_INS_REQ
            WHERE IIR_REQ_NO LIKE 'QI-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
        </selectKey>

        INSERT INTO IMP_INS_REQ (
            IIR_REQ_NO,
            IIR_QRTN_OFFICER_ID,
            IR_NO,
            IIR_JRSD_RGN_AG_CD,
            IIR_QRTN_INST_CD,
            IIR_RSN_CN,
            IIR_STATUS_CD,
            IIR_DT,
            IIR_ASSIGN_DT,
            IIR_RPLY_DDLINE_DT,
            IIR_REGIST_DT,
            IIR_UPDT_DT,

            IIR_EXPORTER_NM,
            IIR_EXPORTER_COMPANY_NM,
            IIR_EXPORTER_ADRES,
            IIR_EXPORT_COUNTRY_CD,
            IIR_ORIGIN_COUNTRY_CD,
            IIR_PHYTO_CERT_NO,
            IIR_PHYTO_CERT_ISSUE_DT,

            IIR_TRANSPORT_TYPE_CD,
            IIR_TRANSPORT_NM,
            IIR_LOAD_PORT_CD,
            IIR_SHIP_DT,
            IIR_ARRV_PORT_CD,
            IIR_ARRV_DT,

            IIR_MAIN_GOODS_NM,
            IIR_MAIN_HS_CD,
            IIR_TOTAL_PKG_CNT,
            IIR_PKG_UNIT_CD,
            IIR_TOTAL_WEIGHT,
            IIR_PKG_MATERIAL,
            IIR_WOOD_PKG_YN,
            IIR_WOOD_PKG_MARK_NO
        ) VALUES (
            #{iirReqNo},
            #{iirQrtnOfficerId},
            #{iirAplyNo},
            #{iirJrsdRgnAgCd},
            #{iirQrtnInstCd},
            #{iirRsnCn},
            '요청',
            SYSDATE,
            SYSDATE,

            <choose>
                <when test="iirRplyDdlineDt != null and iirRplyDdlineDt != ''">
                    TO_DATE(#{iirRplyDdlineDt}, 'YYYY-MM-DD')
                </when>
                <otherwise>
                    SYSDATE + 7
                </otherwise>
            </choose>,

            SYSDATE,
            SYSDATE,

            #{iirExporterNm},
            #{iirExporterCompanyNm},
            #{iirExporterAdres},
            #{iirExportCountryCd},
            #{iirOriginCountryCd},
            #{iirPhytoCertNo},

            <choose>
                <when test="iirPhytoCertIssueDt != null and iirPhytoCertIssueDt != ''">
                    TO_DATE(#{iirPhytoCertIssueDt}, 'YYYY-MM-DD')
                </when>
                <otherwise>
                    NULL
                </otherwise>
            </choose>,

            #{iirTransportTypeCd},
            #{iirTransportNm},
            #{iirLoadPortCd},

            <choose>
                <when test="iirShipDt != null and iirShipDt != ''">
                    TO_DATE(#{iirShipDt}, 'YYYY-MM-DD')
                </when>
                <otherwise>
                    NULL
                </otherwise>
            </choose>,

            #{iirArrvPortCd},

            <choose>
                <when test="iirArrvDt != null and iirArrvDt != ''">
                    TO_DATE(#{iirArrvDt}, 'YYYY-MM-DD')
                </when>
                <otherwise>
                    NULL
                </otherwise>
            </choose>,

            #{iirMainGoodsNm},
            #{iirMainHsCd},

            <choose>
                <when test="iirTotalPkgCnt != null and iirTotalPkgCnt != ''">
                    TO_NUMBER(#{iirTotalPkgCnt})
                </when>
                <otherwise>
                    NULL
                </otherwise>
            </choose>,

            #{iirPkgUnitCd},

            <choose>
                <when test="iirTotalWeight != null and iirTotalWeight != ''">
                    TO_NUMBER(#{iirTotalWeight})
                </when>
                <otherwise>
                    NULL
                </otherwise>
            </choose>,

            #{iirPkgMaterial},
            #{iirWoodPkgYn},
            #{iirWoodPkgMarkNo}
        )
    </insert>


    <!-- 수입검역요청 첨부파일 그룹번호 수정 -->
    <update id="updateImportQuarantineFileGroup"
            parameterType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">

        UPDATE IMP_INS_REQ
        SET
            IIR_TFG_NO = #{iirTfgNo},
            IIR_UPDT_DT = SYSDATE
        WHERE IIR_REQ_NO = #{iirReqNo}

    </update>


    <!-- 수입검역장소 등록 -->
    <insert id="insertImportQuarantineLocation"
            parameterType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">

        <selectKey keyProperty="iilNo" resultType="string" order="BEFORE">
            SELECT 'IIL' || TO_CHAR(SYSTIMESTAMP, 'YYYYMMDDHH24MISSFF3')
            FROM DUAL
        </selectKey>

        INSERT INTO IMP_INS_LOC (
            IIL_NO,
            IIL_REQ_NO,
            IIL_WIL_NO,
            IIL_TY_CD,
            IIL_NM,
            IIL_ZIP,
            IIL_ADRES,
            IIL_DETAIL_ADRES,
            IIL_PLAN_DT,
            IIL_REGIST_DT,
            IIL_UPDT_DT
        ) VALUES (
            #{iilNo},
            #{iirReqNo},
            #{iilWilNo},
            #{iilTyCd},
            #{iilNm},
            #{iilZip},
            #{iilAdres},
            #{iilDetailAdres},

            <choose>
                <when test="iilPlanDt != null and iilPlanDt != ''">
                    TO_DATE(REPLACE(#{iilPlanDt}, 'T', ' '), 'YYYY-MM-DD HH24:MI')
                </when>
                <otherwise>
                    NULL
                </otherwise>
            </choose>,

            SYSDATE,
            SYSDATE
        )
    </insert>


    <!-- 수입검역대상 품목 등록 -->
    <insert id="insertImportQuarantineItem"
            parameterType="kr.or.tacs.vo.broker.quarantine.QuarantineItemVO">

        INSERT INTO IMP_INS_REQ_ITEM (
            IIRI_SN,
            IIRI_REQ_NO,
            IIRI_HS_CD,
            IIRI_GOODS_NM,
            IIRI_SCIENTIFIC_NM,
            IIRI_USE_CD,
            IIRI_QTY,
            IIRI_QTY_UNIT_CD,
            IIRI_NET_WEIGHT,
            IIRI_PKG_CNT,
            IIRI_PKG_MATERIAL,
            IIRI_ORIGIN_COUNTRY_CD,
            IIRI_REGIST_DT,
            IIRI_UPDT_DT
        ) VALUES (
            #{iiriSn},
            #{iiriReqNo},
            #{hsCd},
            #{goodsNm},
            #{scientificNm},
            #{useCd},

            <choose>
                <when test="qty != null and qty != ''">
                    TO_NUMBER(#{qty})
                </when>
                <otherwise>
                    NULL
                </otherwise>
            </choose>,

            #{qtyUnitCd},

            <choose>
                <when test="netWeight != null and netWeight != ''">
                    TO_NUMBER(#{netWeight})
                </when>
                <otherwise>
                    NULL
                </otherwise>
            </choose>,

            <choose>
                <when test="pkgCnt != null and pkgCnt != ''">
                    TO_NUMBER(#{pkgCnt})
                </when>
                <otherwise>
                    NULL
                </otherwise>
            </choose>,

            #{pkgMaterial},
            #{originCountryCd},
            SYSDATE,
            SYSDATE
        )
    </insert>


    <!-- 수입검역요청 생성 이력 등록 -->
    <insert id="insertImportQuarantineHistory"
            parameterType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">

        <selectKey keyProperty="iihNo" resultType="string" order="BEFORE">
            SELECT 'IIH' || TO_CHAR(SYSTIMESTAMP, 'YYYYMMDDHH24MISSFF3')
            FROM DUAL
        </selectKey>

        INSERT INTO IMP_INS_HIS (
            IIH_NO,
            IIH_REQ_NO,
            IIH_ACTOR_OFFICER_ID,
            IIL_NO,
            IIH_EVT_CD,
            IIH_BF_STATUS_CD,
            IIH_AF_STATUS_CD,
            IIH_CN,
            IIH_OCCR_DT,
            IIH_REGIST_DT,
            IIH_UPDT_DT
        ) VALUES (
            #{iihNo},
            #{iirReqNo},
            #{iirQrtnOfficerId},
            #{iilNo},
            'CREATE',
            NULL,
            '요청',
            #{iirRsnCn},
            SYSDATE,
            SYSDATE,
            SYSDATE
        )
    </insert>


    <!-- 검역 담당 공무원의 소속기관 코드 조회 -->
    <select id="selectOfficerInstCd"
            parameterType="string"
            resultType="string">
        SELECT OFFICER_INST_CD
        FROM OFFICER
        WHERE OFFICER_ID = #{_parameter}
    </select>


    <!-- 관세사 - 검역 합격 증명서 다운로드용 파일번호 조회 -->
    <select id="selectIssuedCertFileNo" parameterType="kr.or.tacs.vo.broker.quarantine.QuarantineVO" resultType="long">

        SELECT
            DFI.DFI_FILE_NO

        FROM IMP_INS_REQ REQ
             JOIN IMP_RQST IR
               ON IR.IR_NO = REQ.IR_NO

             JOIN IMP_INS_CERT CERT
               ON CERT.IIC_REQ_NO = REQ.IIR_REQ_NO

             JOIN TACS_FILE_MAP TFM
               ON TFM.TFM_TFG_NO = CERT.IIC_TFG_NO

             JOIN DOCS_FILE_DATA DFI
               ON DFI.DFI_FILE_NO = TFM.TFM_DFI_NO

        WHERE REQ.IIR_REQ_NO = #{iirReqNo}

          <!-- 로그인한 관세사의 수입의뢰 건만 다운로드 허용 -->
          <if test="loginBrokerId != null and loginBrokerId != ''">
              AND IR.IR_BROKER_ID = #{loginBrokerId}
          </if>

          <!-- 검역 합격 증명서 문서 타입 -->
          AND CERT.IIC_DOC_TYPE_CD = 'QRTN_PASS_CERT'
          AND TFM.TFM_DOC_TY_CD = 'QRTN_PASS_CERT'

          <!-- 발급 완료된 증명서만 -->
		  AND CERT.IIC_ISSUE_STATUS_CD IN ('발급 완료', 'CERT_DONE')
          
          <!-- 삭제되지 않은 파일만 -->
          AND NVL(DFI.DFI_DEL_YN, 'N') = 'N'
          AND DFI.DFI_UPLOAD_STTS_CD = 'DONE'

        ORDER BY DFI.DFI_REGIST_DT DESC, DFI.DFI_FILE_NO DESC

        FETCH FIRST 1 ROW ONLY

    </select>
    
    <!-- =========================================================
	     관세사 보완완료 제출
	
	     처리:
	     - 검역기관이 등록한 SUPP_RQST를 관세사가 보완 제출한다.
	     - 새로 INSERT하지 않고 기존 요청을 UPDATE한다.
	
	     상태 흐름:
	     REQ: 보완요청
	     SUB: 보완제출완료
	     APR: 검역기관 확인완료
	     ========================================================= -->
	<update id="updateSupplementSubmit"
	        parameterType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">
	
	    UPDATE SUPP_RQST
	    SET
	        SR_STATUS_CD = 'SUB',
	        SR_SUBMIT_DT = SYSDATE,
	        SR_SUBMIT_CN = #{srSubmitCn}
	    WHERE SR_NO = #{srNo}
	      AND SR_REF_BIZ_CD = 'IMP_INS_REQ'
	      AND SR_REF_NO = #{iirReqNo}
	      AND RECEIVER_ID = #{loginBrokerId}
	      AND RECEIVER_TY_CD = 'BROKER'
	      AND SR_STATUS_CD = 'REQ'
	
	</update>
	
	
	<!-- =========================================================
	     보완제출 후 검역결과 후속조치 수정
	
	     관세사가 보완자료를 제출하면
	     현장공무원이 상세 화면에서 보완제출 상태를 알 수 있도록
	     IMP_INS_RESULT 후속조치값을 변경한다.
	
	     최종 판정 결과 자체는 여전히 '보완요청'으로 둔다.
	     현장공무원이 보완자료 확인 후 합격/불합격을 다시 판정한다.
	     ========================================================= -->
	<update id="updateResultAfterSupplementSubmit"
	        parameterType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">
	
	    UPDATE IMP_INS_RESULT
	    SET
	        IIR_RESULT_FOLLOWUP_CD = '보완제출완료',
	        IIR_UPDT_DT = SYSDATE
	    WHERE IIR_IMP_INS_REQ_NO = #{iirReqNo}
	
	</update>
	
	<!-- =========================================================
	     검역장소 선택 목록 조회
	
	     목적:
	     - 수입검역신청 화면에서 검역장소명을 선택하기 위한 목록 조회
	     - 수입의뢰 물품 입고 여부와 상관없이 등록된 창고 위치 목록을 조회한다.
	
	     저장 기준:
	     - 화면에는 창고명/보세구역명까지만 보여준다.
	     - 같은 보세구역 안의 세부 위치번호(WIL_NO)는 하나의 검역장소로 묶는다.
	     - IMP_INS_LOC.IIL_WIL_NO에는 기존 FK 유지를 위해 대표 WAREHOUSE_ITEM_LOCATION.WIL_NO를 저장한다.
	     ========================================================= -->
	<select id="selectWarehouseLocationListByImportRequest" parameterType="kr.or.tacs.vo.broker.quarantine.QuarantineVO" resultType="kr.or.tacs.vo.broker.quarantine.QuarantineVO">
	
	    SELECT
	        MIN(WIL.WIL_NO) AS iilWilNo,
	        'BONDED_WH' AS iilTyCd,
	
	        WH.WH_NM ||
	        CASE
	            WHEN WZ.WZ_NM IS NOT NULL THEN ' / ' || WZ.WZ_NM
	            ELSE ''
	        END AS iilNm,
	
	        WH.WH_ZIP AS iilZip,
	        WH.WH_ADRES AS iilAdres,
	        WH.WH_DETAIL_ADRES AS iilDetailAdres
	
	    FROM WAREHOUSE WH
	         JOIN WAREHOUSE_ZONE WZ
	           ON WZ.WZ_WH_NO = WH.WH_NO
	
	         JOIN WAREHOUSE_ITEM_LOCATION WIL
	           ON WIL.WIL_WH_ZONE_NO = WZ.WZ_NO
	
	    WHERE EXISTS (
	        SELECT 1
	        FROM IMP_RQST IR
	        WHERE IR.IR_NO = #{irNo}
	
	        <if test="loginBrokerId != null and loginBrokerId != ''">
	            AND IR.IR_BROKER_ID = #{loginBrokerId}
	        </if>
	    )
	
	    GROUP BY
	        WH.WH_NO,
	        WH.WH_NM,
	        WZ.WZ_NO,
	        WZ.WZ_NM,
	        WH.WH_ZIP,
	        WH.WH_ADRES,
	        WH.WH_DETAIL_ADRES
	
	    ORDER BY WH.WH_NM, WZ.WZ_NM
	
	</select>
	

</mapper>