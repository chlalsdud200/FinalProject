@charset "UTF-8";

.content {
  margin-left: 256px !important;
  padding: 88px 32px 32px !important;
  min-height: calc(100vh - 49px) !important;
  background: #f6f9ff !important;
}

.content .tacs-mypage {
  max-width: 1180px;
}

.content .tacs-mypage-shell {
  border: 1px solid #d9eafc;
  box-shadow: none;
  background: #fff;
}

.content .tacs-mypage-header {
  padding: 18px 24px;
  background: #ecf4ff;
  border-bottom: 1px solid #d0e5fa;
}

.content .tacs-mypage-header h1 {
  margin: 2px 0 4px;
  font-size: 20px;
  line-height: 1.25;
}

.content .tacs-mypage-header p {
  font-size: 12px;
  line-height: 1.5;
}

.content .tacs-mypage-header-icon {
  width: 42px;
  height: 42px;
  font-size: 24px;
  background: #565e74;
}

.content .tacs-mypage-tabs {
  padding: 6px 18px 0;
}

.content .tacs-mypage-tab {
  padding: 8px 13px;
  font-size: 12px;
}

.content .tacs-mypage-panels {
  padding: 22px 28px 28px;
}

.content .tacs-password-card {
  max-width: 680px;
  grid-template-columns: 155px minmax(0, 1fr);
  border: 1px solid #d9eafc;
  box-shadow: none;
}

.content .tacs-password-visual {
  min-height: 230px;
  background: #565e74;
}

.content .tacs-password-visual .material-symbols-outlined {
  width: 58px;
  height: 58px;
  font-size: 32px;
  border-radius: 0;
}

.content .tacs-password-body {
  padding: 30px 32px;
}

.content .tacs-password-body h2,
.content .tacs-ready-card h2 {
  margin: 6px 0 8px;
  font-size: 19px;
}

.content .tacs-password-desc,
.content .tacs-ready-card p {
  margin-bottom: 18px;
  font-size: 12px;
  line-height: 1.6;
}

.content .tacs-field-input {
  height: 40px;
  padding: 0 11px;
  border-color: #a0b4c8;
  font-size: 13px;
}

.content .tacs-form-help {
  margin-top: 8px;
  font-size: 11px;
}

.content .tacs-button-row {
  margin-top: 18px;
}

.content .tacs-btn {
  height: 38px;
  min-width: 84px;
  padding: 0 13px;
  font-size: 12px;
}

.content .tacs-actor-profile-form {
  max-width: 1040px;
}

.content .tacs-actor-form-section {
  margin-bottom: 18px;
  padding-bottom: 6px;
}

.content .tacs-actor-grid {
  gap: 12px 22px;
}

.content .tacs-actor-field-label {
  font-size: 11px;
}

.content .tacs-actor-input-box,
.content .tacs-actor-password-wrap {
  height: 36px;
}

.content .tacs-actor-input-box,
.content .tacs-actor-password-input {
  font-size: 12px;
}

.content .tacs-actor-icon-box {
  width: 24px;
  height: 24px;
}

.content .tacs-actor-icon-box .material-symbols-outlined {
  font-size: 17px;
}

.content .tacs-actor-side-btn {
  height: 36px;
  font-size: 10px;
}

.content .tacs-actor-info-box {
  min-height: 50px;
  padding: 8px 10px;
}

.content .tacs-actor-button-row {
  margin-top: 8px;
}

@media (max-width: 900px) {
  .content {
    margin-left: 0 !important;
    padding: 84px 18px 24px !important;
  }

  .content .tacs-password-card {
    grid-template-columns: 1fr;
  }

  .content .tacs-password-visual {
    min-height: 82px;
  }
}
