package kr.or.tacs.dto.officer;

import lombok.Data;

@Data
public class WarehouseCargoTrackingDTO {

    private int no;

    private String reqNo;              // 신고번호
    private String declareType;        // 수입/수출
    private Integer goodsGroupNo;      // 물품그룹번호

    private String warehouseName;      // 창고명
    private String bondedAreaCode;     // 보세구역코드
    private String storageLocation;    // 보관위치

    private String cargoMgmtNo;        // 화물관리번호
    private String itemName;           // 품명
    private String qtyWeight;          // 수량/중량

    private String declarantName;      // 신고인/화주명

    private String cargoStatusCd;      // 상태코드
    private String cargoStatus;        // 화면표시 상태명

    private String inboundDate;        // 반입일
    private String releaseDate;        // 반출일
}
