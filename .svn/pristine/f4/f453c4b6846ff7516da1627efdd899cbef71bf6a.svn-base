    // 수입 내륙운송 배차 - DISPATCH / CAR
    private Integer dispatchNo;          // DISPATCH_NO 배차번호
    private String dispatchStatusCd;     // DISPATCH_STATUS_CD 배차상태코드
    private String dispatchStatusNm;     // 배차상태명
    private Integer carNo;               // CAR_NO 차량번호 PK
    private String carNm;                // CAR_NM 차량명
    private String driverNm;             // 기사명
    private String driverTelno;          // 기사 연락처
