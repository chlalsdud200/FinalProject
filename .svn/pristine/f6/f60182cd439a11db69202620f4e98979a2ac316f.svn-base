<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%
    request.setAttribute("activeMenu", "export");
    request.setAttribute("activeGroup", "");
    request.setAttribute("activeSub", "");
%>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="jakarta.tags.fmt" %>

<c:set var="editable"
       value="${expDTO.erStatusCd eq 'CSTM_REQ'
            or expDTO.erStatusCd eq 'CSTM_SUPP'}" />

<fmt:formatDate value="${expDTO.erRqstDt}" pattern="yyyy-MM-dd" var="erRqstDtFmt" />
<fmt:formatDate value="${expDTO.erLoadSchdYmdAsDate}" pattern="yyyy-MM-dd" var="erLoadSchdYmdFmt" />

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="ctx-path" content="${pageContext.request.contextPath}">
    <title>TACS 수출통관 의뢰 상세</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/owner.css">
</head>

<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/owner/sidebar.jsp" %>

    <div class="main-wrap">
        <%@ include file="/WEB-INF/views/common/header.jsp" %>

        <main class="content">
            <div class="page active" id="pg-export-detail">

                <div class="page-title-row">
                    <div>
                        <div style="font-size:11px;color:#94a3b8;font-weight:600;letter-spacing:.5px;margin-bottom:4px;text-transform:uppercase">
                            통관관리
                        </div>
                        <h2>수출통관 의뢰 상세</h2>
                    </div>

                    <div class="btn-row">
                        <a class="btn btn-outline"
                           href="/owner/export/list.do">
                            <span class="material-symbols-outlined" style="font-size:16px">arrow_back</span>
                            목록으로
                        </a>
                    </div>
                </div>

                <c:choose>
                    <c:when test="${expDTO.erStatusCd eq 'CSTM_SUPP'}">
                        <div class="alert-bar error">
                            <span class="material-symbols-outlined">priority_high</span>
                            <strong>보완요청 상태입니다.</strong>
                            요청 내용을 확인하고 수정사항 또는 보완자료를 제출하세요.
                        </div>
                    </c:when>

                    <c:when test="${editable}">
                        <div class="alert-bar info">
                            <span class="material-symbols-outlined">edit_note</span>
                            <strong>수정 가능한 상태입니다.</strong>
                            회원정보와 담당 관세사는 변경할 수 없으며, 의뢰 정보만 수정할 수 있습니다.
                        </div>
                    </c:when>

                    <c:otherwise>
                        <div class="alert-bar info">
                            <span class="material-symbols-outlined">lock</span>
                            <strong>조회 전용 상태입니다.</strong>
                            접수 이후 진행 중이거나 완료된 의뢰는 수정할 수 없습니다.
                        </div>
                    </c:otherwise>
                </c:choose>

                <form id="exportDetailForm"
                      class="form-doc"
                      method="post"
                      enctype="multipart/form-data"
                      action="/owner/export/update.do"
                      onsubmit="return validateExportRequestForm();">

                    <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}">
                    <input type="hidden" name="erNo" value="${expDTO.erNo}">
                    <input type="hidden" name="erBrokerId" value="${expDTO.erBrokerId}">
                    <input type="hidden" name="erTfgNo" value="${expDTO.erTfgNo}">
                    <input type="hidden" name="erStatusCd" value="${expDTO.erStatusCd}">

                    <div class="form-doc-head">
                        <div class="form-doc-head-left">
                            <div class="form-doc-type">TACS · Export Customs</div>
                            <div class="form-doc-title">수출신고의뢰서</div>
                        </div>

                        <div class="form-doc-head-right">
                            <div class="form-doc-meta">
                                <strong>의뢰번호</strong> ${expDTO.erNo}
                            </div>
                            <div class="form-doc-meta">
                                <strong>진행상태</strong>
                                <c:choose>
                                    <c:when test="${expDTO.erStatusCd eq 'CSTM_REQ'}">접수대기</c:when>
                                    <c:when test="${expDTO.erStatusCd eq 'CSTM_ACPT'}">접수완료</c:when>
                                    <c:when test="${expDTO.erStatusCd eq 'CSTM_INPRG'}">진행중</c:when>
                                    <c:when test="${expDTO.erStatusCd eq 'CSTM_SUPP'}">보완요청</c:when>
                                    <c:when test="${expDTO.erStatusCd eq 'CSTM_SUPP_SUB'}">보완제출</c:when>
                                    <c:when test="${expDTO.erStatusCd eq 'CSTM_REJ'}">반려</c:when>
                                    <c:when test="${expDTO.erStatusCd eq 'CSTM_DONE'}">신고수리</c:when>
                                    <c:when test="${expDTO.erStatusCd eq 'CSTM_CANCEL'}">취소</c:when>
                                    <c:otherwise>${expDTO.erStatusCd}</c:otherwise>
                                </c:choose>
                            </div>
                            <div class="form-doc-meta">
                                <strong>요청일자</strong> ${erRqstDtFmt}
                            </div>
                        </div>
                    </div>

                    <div class="form-doc-body">

                        <!-- ① 담당 관세사 -->
                        <div class="form-group">
                            <div class="form-group-title">① 담당 관세사</div>

                            <div class="broker-selector-row">
                                <label>담당 관세사</label>

                                <div class="broker-display" id="exportBrokerDisplay">
                                    <c:choose>
                                        <c:when test="${not empty expDTO.brokerNm}">
                                            ${expDTO.brokerNm}
                                        </c:when>
                                        <c:otherwise>
                                            담당 관세사 정보가 없습니다.
                                        </c:otherwise>
                                    </c:choose>
                                </div>

                                <button type="button"
                                        class="btn btn-secondary"
                                        disabled>
                                    변경 불가
                                </button>
                            </div>
                        </div>

                        <div class="form-doc-divider"></div>

                        <!-- ② 수출자 기본 정보 -->
                        <div class="form-group">
                            <div class="form-group-title">② 수출자 기본 정보</div>

                            <div class="form-grid-2">
                                <div class="fi">
                                    <label>수출자명</label>
                                    <input type="text"
                                           name="erOnerNm"
                                           id="erOnerNm"
                                           value="${ownerVO.owrNm}"
                                           readonly>
                                </div>

                                <c:choose>
                                    <c:when test="${ownerVO.owrTyCd eq 'INDV'}">
                                        <div class="fi">
                                            <label>주민등록번호</label>
                                            <input type="text"
                                                   value="${ownerVO.maskedOwrIdentNo}"
                                                   readonly>
                                            <input type="hidden"
                                                   name="erCorpRegNo"
                                                   id="erCorpRegNo"
                                                   value="${ownerVO.owrIdentNo}">
                                        </div>
                                    </c:when>

                                    <c:when test="${ownerVO.owrTyCd eq 'OPERATOR'}">
                                        <div class="fi">
                                            <label>사업자등록번호</label>
                                            <input type="text"
                                                   name="erCorpRegNo"
                                                   id="erBizrno"
                                                   value="${ownerVO.owrBizrno}"
                                                   readonly>
                                        </div>
                                    </c:when>

                                    <c:when test="${ownerVO.owrTyCd eq 'CORP'}">
                                        <div class="fi">
                                            <label>법인등록번호</label>
                                            <input type="text"
                                                   name="erCorpRegNo"
                                                   id="erCorpRegNo"
                                                   value="${ownerVO.owrCorpRegNo}"
                                                   readonly>
                                        </div>
                                    </c:when>

                                    <c:otherwise>
                                        <div class="fi">
                                            <label>등록번호</label>
                                            <input type="text"
                                                   name="erCorpRegNo"
                                                   id="erCorpRegNo"
                                                   value="${expDTO.erCorpRegNo}"
                                                   readonly>
                                        </div>
                                    </c:otherwise>
                                </c:choose>

                                <div class="fi">
                                    <label>통관고유부호</label>
                                    <input type="text"
                                           name="erCstmIdfNo"
                                           id="erCstmIdfNo"
                                           value="${ownerVO.owrCstmIdfNo}"
                                           readonly>
                                </div>
                            </div>
                        </div>

                        <div class="form-doc-divider"></div>

                        <!-- ③ 선적 · 거래 조건 -->
                        <div class="form-group">
                            <div class="form-group-title">③ 선적 · 거래 조건</div>

                            <div class="form-grid-3">
                                <div class="fi">
                                    <label>선적예정일 <span class="req">*</span></label>
                                    <input type="date"
                                           name="erLoadSchdYmd"
                                           id="erLoadSchdYmd"
                                           value="${erLoadSchdYmdFmt}"
                                    ${editable ? '' : 'readonly'}>
                                </div>

                                <div class="fi">
                                    <label>Incoterms <span class="req">*</span></label>
                                    <select name="erIncoTermsCd"
                                            id="erIncoTermsCd"
                                    ${editable ? '' : 'disabled'}>
                                        <option value="">-- 선택 --</option>
                                        <option value="FOB" ${expDTO.erIncoTermsCd eq 'FOB' ? 'selected' : ''}>FOB — 본선인도</option>
                                        <option value="CIF" ${expDTO.erIncoTermsCd eq 'CIF' ? 'selected' : ''}>CIF — 운임보험료포함</option>
                                        <option value="CFR" ${expDTO.erIncoTermsCd eq 'CFR' ? 'selected' : ''}>CFR — 운임포함</option>
                                        <option value="EXW" ${expDTO.erIncoTermsCd eq 'EXW' ? 'selected' : ''}>EXW — 공장인도</option>
                                        <option value="DAP" ${expDTO.erIncoTermsCd eq 'DAP' ? 'selected' : ''}>DAP — 목적지인도</option>
                                    </select>

                                    <c:if test="${not editable}">
                                        <input type="hidden" name="erIncoTermsCd" value="${expDTO.erIncoTermsCd}">
                                    </c:if>
                                </div>

                                <div class="fi">
                                    <label>선적항</label>
                                    <input type="text"
                                           name="erLoadPortCd"
                                           id="erLoadPortCd"
                                           placeholder="예: KRPTK"
                                           value="${expDTO.erLoadPortCd}"
                                    ${editable ? '' : 'readonly'}>
                                </div>

                                <div class="fi">
                                    <label>도착항</label>
                                    <input type="text"
                                           name="erArrvPortCd"
                                           id="erArrvPortCd"
                                           placeholder="예: USLAX"
                                           value="${expDTO.erArrvPortCd}"
                                    ${editable ? '' : 'readonly'}>
                                </div>
                            </div>
                        </div>

                        <div class="form-doc-divider"></div>

                        <!-- ④ 부가 신청 사항 -->
                        <div class="form-group">
                            <div class="form-group-title">④ 부가 신청 사항</div>

                            <div class="form-grid-2">
                                <div class="fi">
                                    <label>원산지증명서 발급대행</label>
                                    <select name="erCoIssueTyCd"
                                            id="erCoIssueTyCd"
                                    ${editable ? '' : 'disabled'}>
                                        <option value="">-- 원산지증명서 발급대행 --</option>
                                        <option value="FTA" ${expDTO.erCoIssueTyCd eq 'FTA' ? 'selected' : ''}>신청 (FTA 원산지증명)</option>
                                        <option value="N" ${expDTO.erCoIssueTyCd eq 'N' ? 'selected' : ''}>미신청</option>
                                    </select>

                                    <c:if test="${not editable}">
                                        <input type="hidden" name="erCoIssueTyCd" value="${expDTO.erCoIssueTyCd}">
                                    </c:if>
                                </div>

                                <div class="fi">
                                    <label>관세 환급 신청 여부</label>
                                    <select name="erRefundReqYn"
                                            id="erRefundReqYn"
                                    ${editable ? '' : 'disabled'}>
                                        <option value="">-- 환급 신청 여부 --</option>
                                        <option value="Y" ${expDTO.erRefundReqYn eq 'Y' ? 'selected' : ''}>신청</option>
                                        <option value="N" ${expDTO.erRefundReqYn eq 'N' ? 'selected' : ''}>미신청</option>
                                    </select>

                                    <c:if test="${not editable}">
                                        <input type="hidden" name="erRefundReqYn" value="${expDTO.erRefundReqYn}">
                                    </c:if>
                                </div>

                                <div class="fi full">
                                    <label>특이사항 / 비고</label>
                                    <textarea name="erComment"
                                              id="erComment"
                                              placeholder="수출 관련 특이사항, 세관 신고 시 주의사항 등을 입력하세요"
                                    ${editable ? '' : 'readonly'}>${expDTO.erComment}</textarea>
                                </div>
                            </div>
                        </div>

                        <div class="form-doc-divider"></div>

                        <!-- ⑤ 첨부서류 -->
                        <div class="form-group">
                            <div class="form-group-title">⑤ 첨부서류</div>

                            <div class="alert-bar info">
                                <span class="material-symbols-outlined">description</span>
                                송장, 패킹리스트, B/L, 계약서, 원산지증명서 등 수출통관과 운송계약에 필요한 문서를 확인하거나 추가 첨부하세요.
                            </div>

                            <c:if test="${editable}">
                                <input id="exportDocFile"
                                       name="docFiles"
                                       type="file"
                                       multiple
                                       style="display:none"
                                       onchange="handleExportDocFiles(this)">
                            </c:if>

                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
                                <label style="font-size:11px;font-weight:700;color:#475569">
                                    첨부 문서 <span class="req">*</span>
                                </label>

                                <c:if test="${editable}">
                                    <div style="display:flex;gap:8px">
                                        <button type="button"
                                                class="btn btn-secondary"
                                                style="padding:9px 16px;font-size:12px;white-space:nowrap"
                                                onclick="document.getElementById('exportDocFile').click()">
                                            파일 선택
                                        </button>
                                    </div>
                                </c:if>
                            </div>

                            <c:choose>
                                <c:when test="${editable}">
                                    <div class="upload-drop"
                                         style="margin-bottom:16px"
                                         onclick="document.getElementById('exportDocFile').click()">
                                        <span class="material-symbols-outlined">upload_file</span>
                                        <p>파일을 이곳에 드래그하거나 <strong>클릭하여 선택</strong>하세요</p>
                                        <p id="exportDocFileName" style="margin-top:4px;font-size:11px;color:#94a3b8">
                                            PDF · JPG · PNG · XLSX — 최대 20MB
                                        </p>
                                    </div>
                                </c:when>

                                <c:otherwise>
                                    <div class="upload-drop"
                                         style="margin-bottom:16px;cursor:default">
                                        <span class="material-symbols-outlined">folder</span>
                                        <p>제출된 첨부 문서를 확인할 수 있습니다.</p>
                                        <p style="margin-top:4px;font-size:11px;color:#94a3b8">
                                            현재 상태에서는 첨부문서를 추가할 수 없습니다.
                                        </p>
                                    </div>
                                </c:otherwise>
                            </c:choose>

                            <table class="doc-table" id="exportDocUploadTable">
                                <thead>
                                <tr>
                                    <th style="width:18%;">문서종류</th>
                                    <th>파일명</th>
                                    <th style="width:16%;">상태</th>
                                    <th style="width:18%;text-align:right;">관리</th>
                                </tr>
                                </thead>

                                <tbody id="exportDocUploadTbody">
                                <c:choose>
                                    <c:when test="${not empty fileList}">
                                        <c:forEach var="file" items="${fileList}">
                                            <tr class="saved-file-row" data-file-no="${file.dfiFileNo}">
                                                <td>
                                                    <span class="doc-type-pill">첨부문서</span>
                                                </td>

                                                <td class="td-id">
                                                    <a href="${pageContext.request.contextPath}/file/download.do?fileNo=${file.dfiFileNo}"
                                                       class="doc-file-link">
                                                            ${file.dfiOrgNm}
                                                    </a>
                                                </td>

                                                <td>
                                                    <span class="doc-status done">기존첨부</span>
                                                </td>

                                                <td class="doc-actions">
                                                    <c:choose>
                                                        <c:when test="${file.dfiUploadSttsCd eq 'DONE'}">
                                                            <a href="/common/file/download.do?fileNo=${file.dfiFileNo}"
                                                               class="mini mini-view">
                                                                다운로드
                                                            </a>
                                                        </c:when>

                                                        <c:when test="${file.dfiUploadSttsCd eq 'UPLOADING'}">
                                                            <span class="badge badge-wait">업로드중</span>
                                                        </c:when>

                                                        <c:when test="${file.dfiUploadSttsCd eq 'FAIL'}">
                                                            <span class="badge badge-urgent">업로드실패</span>
                                                        </c:when>
                                                    </c:choose>

                                                    <c:if test="${editable}">
                                                        <button type="button"
                                                                class="mini mini-reject"
                                                                onclick="markDeleteExportFile(this, '${file.dfiFileNo}')">
                                                            삭제
                                                        </button>
                                                    </c:if>
                                                </td>
                                            </tr>
                                        </c:forEach>
                                    </c:when>

                                    <c:otherwise>
                                        <tr class="empty-row">
                                            <td colspan="4" style="text-align:center;color:#94a3b8;padding:18px;">
                                                첨부된 문서가 없습니다.
                                            </td>
                                        </tr>
                                    </c:otherwise>
                                </c:choose>
                                </tbody>
                            </table>

                            <div id="deleteExportFileArea"></div>
                        </div>

                        <!-- ⑥ 보완요청 대응 -->
                        <c:choose>
                            <c:when test="${expDTO.erStatusCd eq 'CSTM_SUPP'}">
                                <div class="form-doc-divider"></div>

                                <div class="form-group">
                                    <div class="form-group-title">⑥ 보완요청 대응</div>

                                    <div class="alert-bar error">
                                        <span class="material-symbols-outlined">priority_high</span>
                                        관세사가 요청한 보완사항을 확인하고 대응 및 답변하세요.
                                    </div>

                                    <div class="form-grid-2">
                                        <div class="fi">
                                            <label>보완요청자</label>
                                            <input type="text"
                                                   value="${expDTO.brokerNm}"
                                                   readonly>
                                        </div>

                                        <div class="fi">
                                            <label>보완요청 상태</label>
                                            <input type="text"
                                                   value="보완요청"
                                                   readonly>
                                        </div>

                                        <div class="fi full">
                                            <label>보완요청 내용</label>
                                            <textarea readonly>${expDTO.srReqCn}</textarea>
                                        </div>

                                        <div class="fi full">
                                            <label>보완 답변 내용</label>
                                            <textarea name="srSubmitCn"
                                                      id="suppAnswerCn"
                                                      placeholder="보완 요청에 대한 답변 내용을 입력하세요"></textarea>
                                        </div>

                                    </div>
                                </div>
                            </c:when>

                            <c:when test="${expDTO.erStatusCd eq 'CSTM_SUPP_SUB'}">
                                <div class="form-doc-divider"></div>

                                <div class="form-group">
                                    <div class="form-group-title">⑥ 보완요청 대응</div>

                                    <div class="alert-bar success">
                                        <span class="material-symbols-outlined">priority_high</span>
                                        관세사가 요청한 보완사항을 확인하고 답변한 내역입니다.
                                    </div>

                                    <div class="form-grid-2">
                                        <div class="fi">
                                            <label>보완요청자</label>
                                            <input type="text"
                                                   value="${expDTO.brokerNm}"
                                                   readonly>
                                        </div>

                                        <div class="fi">
                                            <label>보완요청 상태</label>
                                            <input type="text"
                                                   value="보완요청"
                                                   readonly>
                                        </div>

                                        <div class="fi full">
                                            <label>보완요청 내용</label>
                                            <textarea readonly>${supp.srReqCn}</textarea>
                                        </div>

                                        <div class="fi full">
                                            <label>보완 답변 내용</label>
                                            <textarea name="srSubmitCn"
                                                      id="suppAnswerCn"
                                                      placeholder="보완 요청에 대한 답변 내용을 입력하세요"
                                                      readonly>${supp.srSubmitCn}
                                            </textarea>
                                        </div>
                                    </div>
                                </div>
                            </c:when>
                        </c:choose>
                    </div>

                    <div class="btn-row" style="padding:20px 28px;border-top:1px solid #f1f5f9;">
                        <input type="hidden" name="submitType" id="submitType" value="">
                        <c:choose>
                            <c:when test="${expDTO.erStatusCd eq 'CSTM_SUPP'}">
                                <button type="button"
                                        class="btn btn-primary"
                                        id="exportSuppSubmitBtn">
                                    보완 제출
                                </button>
                            </c:when>

                            <c:when test="${editable}">
                                <button type="button"
                                        id="exportUpdateBtn"
                                        class="btn btn-primary">
                                    수정 저장
                                </button>
                            </c:when>
                        </c:choose>

                        <a class="btn btn-outline"
                           href="${pageContext.request.contextPath}/owner/export/list.do">
                            취소
                        </a>
                    </div>
                </form>
            </div>
        </main>

        <%@ include file="/WEB-INF/views/common/ownerModals.jsp" %>
        <%@ include file="/WEB-INF/views/common/footer.jsp" %>
    </div>
</div>

<%@ include file="/WEB-INF/views/common/ownerScripts.jsp" %>
<script src="${pageContext.request.contextPath}/resources/js/owner/export-request.js"></script>
</body>
</html>