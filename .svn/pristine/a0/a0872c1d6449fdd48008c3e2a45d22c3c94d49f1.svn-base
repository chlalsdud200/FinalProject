package kr.or.tacs.common.config;

import org.springframework.context.annotation.Configuration;
import org.springframework.web.servlet.config.annotation.InterceptorRegistry;
import org.springframework.web.servlet.config.annotation.WebMvcConfigurer;

import kr.or.tacs.common.interceptor.ApiMenuPermissionInterceptor;
import kr.or.tacs.common.interceptor.MenuAuthInterceptor;
import lombok.RequiredArgsConstructor;

@Configuration
@RequiredArgsConstructor
public class WebMvcConfig implements WebMvcConfigurer {

    private final MenuAuthInterceptor menuAuthInterceptor;
    private final ApiMenuPermissionInterceptor apiMenuPermissionInterceptor;

    @Override
    public void addInterceptors(InterceptorRegistry registry) {
        registry.addInterceptor(apiMenuPermissionInterceptor)
                .addPathPatterns("/api/tacs/**");

        registry.addInterceptor(menuAuthInterceptor)
        .addPathPatterns(
                "/owner/**",
                "/orders/customs/**",
                "/broker/**",
                "/officer/**",
                "/fieldofficer/**",
                "/transport/**",
                "/warehouse/**"
        );   		
    }
}
