/* ===== 보완수정: 모델/규격 테이블 input 정리 ===== */
#supp-mdlspec-table input {
  width: 100%;
  height: 32px;
  padding: 6px 8px;
  border: 1px solid #cbd5e1;
  border-radius: 4px;
  background: #ffffff;
  color: #203444;
  font-size: 12px;
  font-weight: 500;
  box-sizing: border-box;
  outline: none;
}

#supp-mdlspec-table input::placeholder {
  color: #94a3b8;
  font-weight: 400;
}

#supp-mdlspec-table input:focus {
  border-color: #7b8da8;
  box-shadow: 0 0 0 2px rgba(86, 94, 116, 0.12);
}

#supp-mdlspec-table td {
  vertical-align: middle;
  padding: 8px 10px;
}

#supp-mdlspec-table .mini-reject {
  border: 0;
  border-radius: 6px;
  background: #fee2e2;
  color: #b91c1c;
  font-size: 11px;
  font-weight: 800;
  padding: 6px 10px;
  cursor: pointer;
}

#supp-mdlspec-table .mini-reject:hover {
  background: #fecaca;
}
/* ===== 보완수정: a 태그 버튼 밑줄 제거 ===== */
a.btn,
a.btn-secondary,
a.btn-outline,
a.item-action-btn,
a.mini {
  text-decoration: none;
}

a.btn:hover,
a.btn-secondary:hover,
a.btn-outline:hover,
a.item-action-btn:hover,
a.mini:hover {
  text-decoration: none;
}
#st-supp-form .btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 58px;
  height: 34px;
  padding: 0 14px;
  border-radius: 4px;
  border: 1px solid #9fb3ca;
  background: #eef4fb;
  color: #334155;
  font-size: 12px;
  font-weight: 800;
}

#st-supp-form .btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 78px;
  height: 34px;
  padding: 0 16px;
  border-radius: 4px;
  border: 1px solid #565e74;
  background: #565e74;
  color: #ffffff;
  font-size: 12px;
  font-weight: 800;
}