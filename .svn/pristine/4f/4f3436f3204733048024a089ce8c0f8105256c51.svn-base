@charset "UTF-8";

.pagination a.page-btn {
  text-decoration: none;
}

.pagination span.page-btn.disabled {
  opacity: 0.4;
  cursor: not-allowed;
  background: #fff;
  color: #4d6172;
  border: 1px solid #cbd5e1;
}

.page-info {
  margin-left: 8px;
  font-size: 11px;
  color: #697d8f;
}
.pagination a.page-btn {
  text-decoration: none;
}

.pagination span.page-btn.disabled {
  opacity: 0.4;
  cursor: not-allowed;
  background: #fff;
  color: #4d6172;
  border: 1px solid #cbd5e1;
}

.page-info {
  margin-left: 8px;
  font-size: 11px;
  color: #697d8f;
}

/* ===== 통합조회 상세: 란사항 상태 badge ===== */
.item-status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 72px;
  height: 24px;
  padding: 0 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: -0.2px;
  border: 1px solid transparent;
  white-space: nowrap;
}

.item-dclr {
  background: #eef2ff;
  color: #4338ca;
  border-color: #c7d2fe;
}

.item-review {
  background: #eff6ff;
  color: #1d4ed8;
  border-color: #bfdbfe;
}

.item-supp-req {
  background: #fff7ed;
  color: #c2410c;
  border-color: #fed7aa;
}

.item-supp-sub {
  background: #ecfdf5;
  color: #047857;
  border-color: #a7f3d0;
}

.item-acpt {
  background: #f0fdf4;
  color: #15803d;
  border-color: #bbf7d0;
}

.item-rej {
  background: #fef2f2;
  color: #b91c1c;
  border-color: #fecaca;
}

.item-unknown {
  background: #f8fafc;
  color: #475569;
  border-color: #cbd5e1;
}

/* ===== 통합조회 상세: 처리 칸 ===== */
.action-muted {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 74px;
  height: 26px;
  padding: 0 10px;
  border-radius: 8px;
  background: #f8fafc;
  color: #64748b;
  font-size: 11px;
  font-weight: 700;
  border: 1px solid #e2e8f0;
}

.action-reject {
  color: #b91c1c;
  background: #fef2f2;
  border-color: #fecaca;
}

.item-action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 28px;
  padding: 0 12px;
  border-radius: 8px;
  background: #565e74;
  color: #fff;
  font-size: 11px;
  font-weight: 800;
  text-decoration: none;
  box-shadow: 0 2px 6px rgba(15, 23, 42, 0.12);
}

.item-action-btn:hover {
  background: #424a5f;
  transform: translateY(-1px);
}

.status-field {
  min-height: 34px;
  display: flex;
  align-items: center;
  padding: 5px 0;
}

/* ===== 통합조회 페이지네이션 보정 ===== */
