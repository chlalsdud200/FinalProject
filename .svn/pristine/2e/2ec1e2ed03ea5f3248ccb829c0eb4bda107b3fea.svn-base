<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%
    request.setAttribute("activeMenu", "community");
    request.setAttribute("activeGroup", "community");
    request.setAttribute("activeSub", "support");
%>
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="ctx-path" content="${pageContext.request.contextPath}">
  <title>TACS 커뮤니티 고객센터</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/owner.css">
</head>
<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/owner/sidebar.jsp" %>

  <div class="main-wrap">
    <%@ include file="/WEB-INF/views/common/header.jsp" %>

    <main class="content">
<div class="page active" id="pg-community">
<div class="page-title-row">
<h2><span class="material-symbols-outlined">forum</span> 커뮤니티</h2>
</div>
<div class="prog-tab-bar" style="margin-bottom:24px">
<button class="prog-tab active" onclick="switchCommunityTab('notice')">공지사항</button>
<button class="prog-tab" onclick="switchCommunityTab('archive')">자료실</button>
<button class="prog-tab" onclick="switchCommunityTab('support')">고객센터</button>
</div>
<div id="comm-notice">
<div class="card-section">
<div class="filter-bar" style="margin:12px 0 16px; border-left:3px solid #565e74;">
<select id="notice-type-filter" onchange="renderNoticeList()">
<option value="all">전체 분류</option>
<option value="URGENT">긴급</option>
<option value="UPDATE">업데이트</option>
<option value="NOTICE">공지</option>
</select>
<input id="notice-date-from" onchange="renderNoticeList()" style="padding:6px 8px;border:1px solid #e2e8f0;font-size:12px" type="date"/>
<span style="font-size:11px;color:#94a3b8">~</span>
<input id="notice-date-to" onchange="renderNoticeList()" style="padding:6px 8px;border:1px solid #e2e8f0;font-size:12px" type="date"/>
<div class="search-wrap" style="flex:1">
<span class="material-symbols-outlined">search</span>
<input id="notice-search" placeholder="공지 제목 검색"/>
</div>
<button class="btn btn-dark" onclick="renderNoticeList()">조회</button>
</div>
<table class="data-table">
<thead><tr><th style="width:70px">NO</th><th>제목</th><th style="width:150px">등록일시</th><th style="width:90px">조회수</th></tr></thead>
<tbody id="notice-table-body"></tbody>
</table>
</div>
<div id="notice-detail-view" style="display:none"></div>
</div>
<div id="comm-archive" style="display:none">
  <%@ include file="/WEB-INF/views/common/community/resourceArchive.jsp" %>
</div>
<div id="comm-support" style="display:none">
  <%@ include file="/WEB-INF/views/common/community/faq.jsp" %>
</div>
</div>
    </main>

    <%@ include file="/WEB-INF/views/common/ownerModals.jsp" %>
    <%@ include file="/WEB-INF/views/common/footer.jsp" %>
  </div>
</div>

<%@ include file="/WEB-INF/views/common/ownerScripts.jsp" %>

<script>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof switchCommunityTab === 'function') switchCommunityTab('support');
});
</script>
</body>
</html>