<%@ page pageEncoding="UTF-8" %>

<header class="topbar">
    <div class="tb-left">
        <span class="tb-brand">TACS</span>

        <div class="search-wrap">
            <span class="material-symbols-outlined">search</span>
            <input id="gSearch"
                   placeholder="신고번호 · 업체명 · HS코드 통합 검색..."
                   onkeydown="if(event.key === 'Enter') doSearch()">
        </div>
    </div>

    <div class="tb-right">
    
	    <button class="tb-btn" title="액터 목록" onclick="location.href='${ctx}/systemadmin/dashboard.do'">
			<span class="material-symbols-outlined">list</span>
		</button>
        
        <button class="tb-btn" onclick="alert('알림\\n\\n1. 신규 신고 접수 대기\\n2. 보완요청 처리 대기\\n3. 검역결과 확인 필요')">
            <span class="material-symbols-outlined">notifications</span>
            <span class="dot"></span>
        </button>

        <button class="tb-btn" onclick="alert('행정공무원 도움말\\n\\n• 신고 접수 및 기본심사\\n• 요건 결과 확인\\n• 과세가격·세율·FTA 검토\\n• 통관보류 등록·해지\\n• 신고수리 처리')">
            <span class="material-symbols-outlined">help</span>
        </button>

        <div class="tb-sep"></div>

        <div class="tb-user">
            <div class="tb-user-info">
                <div class="name">행정공무원</div>
                <div class="role">세관 심사 담당자</div>
            </div>

            <div class="tb-avatar"
                 onclick="if(confirm('로그아웃 하시겠습니까?')) location.href='${ctx}/logout'"
                 style="cursor:pointer">
                행
            </div>
        </div>
    </div>
</header>