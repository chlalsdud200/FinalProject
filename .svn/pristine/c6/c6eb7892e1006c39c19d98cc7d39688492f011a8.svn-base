<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.broker.dash.mapper.IBrokerDashboardMapper">

   
<!-- 대시보드 상단 요약 -->
<select id="selectDashboardSummary" parameterType="string" resultType="map">
    SELECT
        NVL((
            SELECT COUNT(*)
              FROM IMP_RQST R
             WHERE (R.IR_BROKER_ID = #{brokerId} OR R.IR_BROKER_ID IS NULL)
               AND NVL(R.IR_USE_YN, 'Y') = 'Y'
               AND TRUNC(NVL(R.IR_DT, R.IR_REGIST_DT)) = TRUNC(SYSDATE)
        ), 0) AS "todayReceivedCnt",

    NVL((
    SELECT COUNT(*)
      FROM IMP_RQST R
     WHERE (R.IR_BROKER_ID = #{brokerId} OR R.IR_BROKER_ID IS NULL)
       AND NVL(R.IR_USE_YN, 'Y') = 'Y'
       AND R.IR_STATUS_CD = 'CSTM_REQ'
), 0) AS "newRequestCnt",

        NVL((
            SELECT COUNT(*)
              FROM IMP_RQST R
             WHERE R.IR_BROKER_ID = #{brokerId}
               AND NVL(R.IR_USE_YN, 'Y') = 'Y'
               AND R.IR_STATUS_CD IN ('CSTM_SUPP', 'CSTM_SUPP_SUB')
        ), 0) AS "suppPendingCnt",

        NVL((
            SELECT COUNT(*)
              FROM IMP_DCLR D
              JOIN IMP_RQST R
                ON R.IR_NO = D.ID_IR_NO
             WHERE R.IR_BROKER_ID = #{brokerId}
               AND TRUNC(NVL(D.ID_APRV_DT, D.ID_UPDT_DT)) = TRUNC(SYSDATE)
               AND D.ID_STATUS_CD IN ('DCLR_ACPT', 'CSTM_ACPT', 'ACPT', 'ITEM_ACPT')
        ), 0) AS "todayDoneCnt",

        NVL((
            SELECT COUNT(DISTINCT R.IR_OWR_ID)
              FROM IMP_RQST R
             WHERE R.IR_BROKER_ID = #{brokerId}
               AND NVL(R.IR_USE_YN, 'Y') = 'Y'
        ), 0) AS "assignedOwnerCnt"
    FROM DUAL
</select>

   <!-- 화주 신규 요청 목록: 최근 접수된 수입통관의뢰 기준 -->
<select id="selectNewRequestList" parameterType="string" resultType="map">
    SELECT *
      FROM (
            SELECT
                R.IR_NO AS "irNo",
                R.IR_OWR_ID AS "ownerId",
                NVL(O.OWR_NM, R.IR_OWR_ID) AS "ownerNm",
                '수입신고 의뢰' AS "requestTypeNm",
                R.IR_BL_AWB_NO AS "blAwbNo",
                R.IR_INVC_AMT AS "invoiceAmt",
                R.IR_DCLR_CURR_CD AS "currencyCd",
                R.IR_STATUS_CD AS "statusCd",
                TO_CHAR(NVL(R.IR_DT, R.IR_REGIST_DT), 'YYYY-MM-DD HH24:MI') AS "requestDt",
                CASE
                    WHEN NVL(R.IR_DT, R.IR_REGIST_DT) >= SYSDATE - (1 / 24) THEN 'NEW'
                    ELSE ''
                END AS "newYn"
              FROM IMP_RQST R
              LEFT JOIN OWNER O
                ON O.OWR_ID = R.IR_OWR_ID
             WHERE R.IR_BROKER_ID = #{brokerId} 
               AND NVL(R.IR_USE_YN, 'Y') = 'Y'
               AND NVL(R.IR_DT, R.IR_REGIST_DT) IS NOT NULL
              AND R.IR_STATUS_CD = 'CSTM_REQ'
             ORDER BY NVL(R.IR_DT, R.IR_REGIST_DT) DESC
      )
     WHERE ROWNUM &lt;= 5
</select>


    <!-- 서류 보완 현황: SUPP_RQST 테이블 없이 IMP_RQST 상태값 기준으로 조회 -->
<select id="selectSupplementList" parameterType="string" resultType="map">
    SELECT *
      FROM (
            SELECT
                R.IR_NO AS "srNo",
                'IMP_RQST' AS "refBizCd",
                R.IR_NO AS "refNo",
                R.IR_STATUS_CD AS "statusCd",
                TO_CHAR(NVL(R.IR_DT, R.IR_REGIST_DT), 'YYYY-MM-DD HH24:MI') AS "requestDt",
                NVL(O.OWR_NM, R.IR_OWR_ID) AS "ownerNm",
                CASE
                    WHEN R.IR_STATUS_CD = 'CSTM_SUPP' THEN '보완 요청 상태입니다.'
                    WHEN R.IR_STATUS_CD = 'CSTM_SUPP_SUB' THEN '화주가 보완자료를 제출했습니다.'
                    ELSE '보완 상태 확인 필요'
                END AS "requestCn",
                TRUNC(NVL(R.IR_DT, R.IR_REGIST_DT) + 7) - TRUNC(SYSDATE) AS "dDay"
              FROM IMP_RQST R
              LEFT JOIN OWNER O
                ON O.OWR_ID = R.IR_OWR_ID
             WHERE R.IR_BROKER_ID = #{brokerId}
               AND NVL(R.IR_USE_YN, 'Y') = 'Y'
               AND R.IR_STATUS_CD IN ('CSTM_SUPP', 'CSTM_SUPP_SUB')
             ORDER BY NVL(R.IR_DT, R.IR_REGIST_DT) DESC
      )
     WHERE ROWNUM &lt;= 4
</select>

    <!-- 담당 화주 TOP 5 -->
    <select id="selectTopOwnerList" parameterType="string" resultType="map">
        SELECT *
          FROM (
                SELECT
                    R.IR_OWR_ID AS "ownerId",
                    NVL(O.OWR_NM, R.IR_OWR_ID) AS "ownerNm",
                    COUNT(*) AS "monthCnt",
                    SUM(CASE
                            WHEN R.IR_STATUS_CD NOT IN ('RQST_CMPT', 'DCLR_ACPT', 'CSTM_ACPT', 'ACPT')
                            THEN 1
                            ELSE 0
                        END) AS "inProgressCnt"
                  FROM IMP_RQST R
                  LEFT JOIN OWNER O
                    ON O.OWR_ID = R.IR_OWR_ID
                 WHERE R.IR_BROKER_ID = #{brokerId}
                   AND NVL(R.IR_USE_YN, 'Y') = 'Y'
                   AND NVL(R.IR_DT, R.IR_REGIST_DT) >= TRUNC(SYSDATE, 'MM')
                 GROUP BY R.IR_OWR_ID, NVL(O.OWR_NM, R.IR_OWR_ID)
                 ORDER BY COUNT(*) DESC
          )
         WHERE ROWNUM &lt;= 5
    </select>


    <!-- 금월 실적 요약 -->
    <select id="selectMonthSummary" parameterType="string" resultType="map">
        SELECT
            NVL((
                SELECT COUNT(*)
                  FROM IMP_DCLR D
                  JOIN IMP_RQST R
                    ON R.IR_NO = D.ID_IR_NO
                 WHERE R.IR_BROKER_ID = #{brokerId}
                   AND NVL(D.ID_DCLR_DT, D.ID_REGIST_DT) >= TRUNC(SYSDATE, 'MM')
            ), 0) AS "importDclrCnt",

            0 AS "exportDclrCnt",

            NVL((
                SELECT SUM(CT.CT_TOTAL_TAX_AMT)
                  FROM CUSTOMS_TAX CT
                  JOIN IMP_RQST R
                    ON R.IR_NO = CT.CT_STTEMNT_ID
                 WHERE R.IR_BROKER_ID = #{brokerId}
                   AND CT.CT_CRT_DT >= TRUNC(SYSDATE, 'MM')
            ), 0) AS "taxTotalAmt",

            NVL((
    SELECT COUNT(*)
      FROM IMP_RQST R
     WHERE R.IR_BROKER_ID = #{brokerId}
       AND NVL(R.IR_USE_YN, 'Y') = 'Y'
       AND R.IR_STATUS_CD IN ('CSTM_SUPP', 'CSTM_SUPP_SUB')
       AND NVL(R.IR_DT, R.IR_REGIST_DT) >= TRUNC(SYSDATE, 'MM')
), 0) AS "suppCnt"
        FROM DUAL
    </select>


    <!-- 다가오는 기한: 도착예정일 기준 -->
    <select id="selectDeadlineList" parameterType="string" resultType="map">
        SELECT *
          FROM (
                SELECT
                    R.IR_NO AS "refNo",
                    NVL(O.OWR_NM, R.IR_OWR_ID) AS "ownerNm",
                    '도착예정일' AS "deadlineTypeNm",
                    R.IR_ARRV_SCHD_YMD AS "deadlineYmd",
                    TO_DATE(R.IR_ARRV_SCHD_YMD, 'YYYYMMDD') - TRUNC(SYSDATE) AS "dDay"
                  FROM IMP_RQST R
                  LEFT JOIN OWNER O
                    ON O.OWR_ID = R.IR_OWR_ID
                 WHERE R.IR_BROKER_ID = #{brokerId}
                   AND NVL(R.IR_USE_YN, 'Y') = 'Y'
                   AND R.IR_ARRV_SCHD_YMD IS NOT NULL
                   AND REGEXP_LIKE(R.IR_ARRV_SCHD_YMD, '^[0-9]{8}$')
                   AND TO_DATE(R.IR_ARRV_SCHD_YMD, 'YYYYMMDD') >= TRUNC(SYSDATE)
                 ORDER BY TO_DATE(R.IR_ARRV_SCHD_YMD, 'YYYYMMDD') ASC
          )
         WHERE ROWNUM &lt;= 4
    </select>

</mapper>