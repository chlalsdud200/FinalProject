package kr.or.tacs.dto.owner;

import lombok.Data;

@Data
public class OwnerForwarderDetailDTO {

    // 운송업체 기본 정보
    private Long tmNo;              // 운송담당자번호
    private String tmCpNm;          // 운송업체명
    private String tmName;          // 담당자명
    private String tmCpTelno;       // 업체 연락처
    private String tmUseYn;         // 사용여부

    // 운송업체 요약 지표
    private Integer completeCount;  // 계약완료건수
    private Integer activeCount;    // 진행중계약건수
    private Integer employeeCount;  // 사원수

    // 운송수단
    private String transportMethodCd; // SEA
    private String transportMethodNm; // 해상
}
