@charset "UTF-8";

/* ===== 커뮤니티 ===== */
.community-card{background:#fff;padding:20px;margin-bottom:12px;border-left:4px solid #565e74;cursor:pointer;transition:all .12s}
.community-card:hover{background:#f6f9ff;transform:translateX(4px)}
.community-card .cc-title{font-size:14px;font-weight:700;color:#203444;margin-bottom:4px}
.community-card .cc-meta{font-size:11px;color:#697d8f}
.community-card .cc-badge{font-size:10px;font-weight:700;padding:2px 8px;margin-right:6px}
.cs-category{display:inline-block;padding:6px 14px;font-size:12px;font-weight:700;cursor:pointer;border:1px solid #cbd5e1;background:#fff;color:#697d8f;margin-right:4px;margin-bottom:8px}
.cs-category.active{background:#565e74;color:#fff;border-color:#565e74}
.faq-item{border-bottom:1px solid #e2e8f0;padding:0}
.faq-q{display:flex;justify-content:space-between;align-items:center;padding:16px;cursor:pointer;font-size:13px;font-weight:700;color:#203444}
.faq-q:hover{background:#f6f9ff}
.faq-a{display:none;padding:0 16px 16px;font-size:13px;color:#4d6172;line-height:1.7;background:#f8fafc}
.faq-a.open{display:block}
.file-item{display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid #e2e8f0}
.file-item:hover{background:#f6f9ff}
.file-left{display:flex;align-items:center;gap:12px}
.file-icon{width:36px;height:36px;background:#ecf4ff;display:flex;align-items:center;justify-content:center}
.file-icon .material-symbols-outlined{font-size:20px;color:#565e74}
.file-name{font-size:13px;font-weight:700;color:#203444}
.file-meta{font-size:10px;color:#697d8f;margin-top:2px}
.file-dl{padding:6px 12px;font-size:11px;font-weight:700;background:#ecf4ff;color:#565e74;border:1px solid #a0b4c8;cursor:pointer}
.file-dl:hover{background:#d9eafc}

/* ===== 커뮤니티 상세 ===== */
.notice-detail{background:#fff;padding:32px}
.notice-detail .nd-header{border-bottom:2px solid #0f172a;padding-bottom:16px;margin-bottom:24px}
.notice-detail .nd-title{font-size:18px;font-weight:800;color:#0f172a;margin-bottom:8px;display:flex;align-items:center;gap:8px}
.notice-detail .nd-meta{display:flex;gap:20px;font-size:12px;color:#697d8f}
.notice-detail .nd-meta span{font-weight:700;color:#4d6172}
.notice-detail .nd-body{font-size:14px;line-height:1.9;color:#334155;min-height:200px;padding:20px 0}
.inquiry-form{background:#fff;padding:24px}
.inquiry-form h4{font-size:14px;font-weight:700;color:#1e293b;border-bottom:1px solid #e2e8f0;padding-bottom:10px;margin-bottom:16px;display:flex;align-items:center;gap:8px}
.inquiry-history{background:#fff;margin-top:16px}
.inquiry-row{display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid #e2e8f0;cursor:pointer}
.inquiry-row:hover{background:#f6f9ff}
.iq-left{flex:1}
.iq-title{font-size:13px;font-weight:700;color:#203444}
.iq-meta{font-size:11px;color:#697d8f;margin-top:2px}
.iq-status{font-size:11px;font-weight:700;padding:4px 10px}
.iq-status.waiting{background:#fef3c7;color:#92400e}
.iq-status.answered{background:#d1fae5;color:#065f46}
.iq-status.closed{background:#e2e8f0;color:#64748b}
.inquiry-detail{background:#fff;padding:24px;display:none}
.iq-thread{margin-top:20px}
.iq-msg{padding:16px;margin-bottom:12px}
.iq-msg.user{background:#ecf4ff;border-left:4px solid #565e74}
.iq-msg.admin{background:#f0fdf4;border-left:4px solid #1d6b4f}
.iq-msg .iq-msg-header{display:flex;justify-content:space-between;margin-bottom:8px;font-size:12px}
.iq-msg .iq-msg-author{font-weight:700;color:#203444}
.iq-msg .iq-msg-date{color:#697d8f}
.iq-msg .iq-msg-body{font-size:13px;line-height:1.7;color:#334155}
.file-detail{background:#fff;padding:24px}
.file-detail-header{display:flex;gap:20px;align-items:flex-start;padding-bottom:20px;border-bottom:1px solid #e2e8f0;margin-bottom:20px}
.file-detail-info h3{font-size:16px;font-weight:800;color:#0f172a;margin-bottom:6px}
.file-detail-meta{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;font-size:12px;color:#697d8f;margin-top:8px}
.file-detail-meta span{font-weight:700;color:#4d6172}
.file-detail-desc{font-size:13px;line-height:1.8;color:#334155;padding:16px 0}
