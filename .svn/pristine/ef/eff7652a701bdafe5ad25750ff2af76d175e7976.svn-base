<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.systemadmin.menu.mapper.IAdminMenuMapper">

    <resultMap id="menuMap" type="kr.or.tacs.vo.systemadmin.menu.MenuVO">
        <id property="menuId" column="MENU_ID"/>
        <result property="menuNm" column="MENU_NM"/>
        <result property="menuUrl" column="MENU_URL"/>
        <result property="parentMenuId" column="PARENT_MENU_ID"/>
        <result property="sortOrder" column="SORT_ORDER"/>
        <result property="menuIcon" column="MENU_ICON"/>
        <result property="useYn" column="USE_YN"/>
    </resultMap>

    <resultMap id="roleMenuMap" type="kr.or.tacs.vo.systemadmin.menu.RoleMenuVO">
        <id property="rmNo" column="RM_NO"/>
        <result property="roleCd" column="ROLE_CD"/>
        <result property="menuId" column="MENU_ID"/>
        <result property="readYn" column="READ_YN"/>
        <result property="writeYn" column="WRITE_YN"/>
        <result property="deleteYn" column="DELETE_YN"/>
        <result property="menuNm" column="MENU_NM"/>
        <result property="menuUrl" column="MENU_URL"/>
    </resultMap>

    <select id="selectAllMenus" parameterType="string" resultMap="menuMap">
        SELECT
              menu_id
            , menu_nm
            , menu_url
            , parent_menu_id
            , sort_order
            , menu_icon
            , use_yn
        FROM menu
        WHERE use_yn = 'Y'
        <if test="roleCd != null and roleCd != ''">
          AND EXISTS (
              SELECT 1
              FROM role_menu
              WHERE role_menu.menu_id = menu.menu_id
                AND role_menu.role_cd = #{roleCd}
          )
        </if>
        ORDER BY sort_order ASC, menu_id ASC
    </select>

    <select id="selectRoleMenuList" resultMap="roleMenuMap">
        SELECT
              RM.rm_no
            , RM.role_cd
            , RM.menu_id
            , RM.read_yn
            , RM.write_yn
            , RM.delete_yn
            , M.menu_nm
            , M.menu_url
        FROM role_menu RM
        JOIN menu M
          ON M.menu_id = RM.menu_id
        WHERE RM.role_cd = #{roleCd}
          AND M.use_yn = 'Y'
        ORDER BY M.sort_order ASC, M.menu_id ASC
    </select>

    <select id="selectMenuIdsByRoleCd" resultType="long">
        SELECT
              menu_id
        FROM role_menu
        WHERE role_cd = #{roleCd}
    </select>

    <delete id="deleteRoleMenuByRoleCd">
        DELETE FROM role_menu
        WHERE role_cd = #{roleCd}
    </delete>

    <insert id="insertRoleMenu" parameterType="kr.or.tacs.vo.systemadmin.menu.RoleMenuVO">
        <selectKey keyProperty="rmNo" resultType="long" order="BEFORE">
            SELECT seq_role_menu.NEXTVAL FROM dual
        </selectKey>
        INSERT INTO role_menu (
              rm_no
            , role_cd
            , menu_id
            , read_yn
            , write_yn
            , delete_yn
        ) VALUES (
              #{rmNo}
            , #{roleCd}
            , #{menuId}
            , #{readYn}
            , #{writeYn}
            , #{deleteYn}
        )
    </insert>
</mapper>
