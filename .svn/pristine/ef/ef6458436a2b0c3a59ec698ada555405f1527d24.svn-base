/* import-arrival.js
 * 수입 도착예정 및 입항추적 화면 정리본.
 *
 * 정리 기준
 * - D/O 첨부 업로드가 정상 동작하는 import-ui.js는 건드리지 않음.
 * - 도착/입항 화면에 직접 필요한 함수만 유지.
 * - 사용하지 않는 중복 화면 함수 제거:
 *   buildRealtimeTrackingPanel, buildCargoStatusSharePanel,
 *   buildStatusNotificationPanel, bindShareStatusActions.
 */

/* 2026-06-03 hotfix: global escape helper used by DOM patch functions outside buildImportEtaTrackingListPanel. */
function safeEscape(value) {
    if (typeof escapeHtml === 'function') return escapeHtml(value);
    return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\"/g, '&quot;')
        .replace(/'/g, '&#39;');
}
if (typeof window !== 'undefined') {
    window.safeEscape = window.safeEscape || safeEscape;
}

function buildImportEtaTrackingListPanel() {
    var arrivalList = Array.isArray(window.TRANSPORT_IMPORT_ARRIVAL_TRACKING)
        ? window.TRANSPORT_IMPORT_ARRIVAL_TRACKING
        : [];

    // JSP를 거치지 않고 비동기로 화면을 열면 초기 배열이 비어 있을 수 있어서 JSON API로 보강 조회한다.
    if (arrivalList.length === 0 && !window.__TACS_IMPORT_ARRIVAL_LOADING && !window.__TACS_IMPORT_ARRIVAL_LOADED) {
        window.__TACS_IMPORT_ARRIVAL_LOADING = true;
        const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';

        fetch(contextPath + '/transport/import/arrival-tracking/list.do', {
            method: 'GET',
            headers: {'X-Requested-With': 'XMLHttpRequest'}
        })
            .then(function (res) {
                if (!res.ok) throw new Error('HTTP ' + res.status);
                return res.json();
            })
            .then(function (list) {
                window.TRANSPORT_IMPORT_ARRIVAL_TRACKING = Array.isArray(list) ? list : [];
                window.__TACS_IMPORT_ARRIVAL_LOADED = true;

                const body = document.getElementById('detail-body');
                if (!body) return;

                const currentItem = body.dataset ? (body.dataset.currentItem || '') : '';
                const isEtaScreen = currentItem === 'TACS-FW-020' || (body.textContent || '').includes('도착예정 및 입항추적');
                if (isEtaScreen) {
                    body.innerHTML = '<div class="space-y-6">' + buildImportEtaTrackingListPanel() + '</div>';
                    body.dataset.currentGroup = 'import';
                    body.dataset.currentItem = 'TACS-FW-020';
                    if (typeof normalizeDetailActionButtons === 'function') normalizeDetailActionButtons();
                }
            })
            .catch(function (err) {
                console.error('[도착예정 및 입항추적 목록 조회 실패]', err);
                window.__TACS_IMPORT_ARRIVAL_LOADED = true;
            })
            .finally(function () {
                window.__TACS_IMPORT_ARRIVAL_LOADING = false;
            });
    }

    function normalizeArrivalStatus(row, fallbackStatus, etaValue) {
        /*
         * 2026-05-28 fix
         * 화면 요구사항: 도착/입항 화면의 도착상태는 DB의 PENDING/IN_TRANSIT 등
         * 원본 값을 그대로 보여주지 않고 무조건 '도착'으로 표시한다.
         */
        return '도착';
    }

    function formatArrivalDate(value) {
        const raw = (value == null ? '' : String(value)).trim();
        if (!raw || raw === '-') return '-';
        const digits = raw.replace(/[^0-9]/g, '');
        if (digits.length === 8) {
            return `${digits.slice(0, 4)}-${digits.slice(4, 6)}-${digits.slice(6, 8)}`;
        }
        return raw;
    }

    function safeEscape(value) {
        if (typeof escapeHtml === 'function') return escapeHtml(value);
        return String(value == null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function arrivalStatusChip(value) {
        const label = String(value || '').trim();
        if (!label) return '';
        if (typeof buildStatusChip === 'function') return buildStatusChip(label);
        return `<span class="status-chip status-confirmed">${safeEscape(label)}</span>`;
    }

    const rows = arrivalList.length > 0
        ? arrivalList.map(row => {
            const trcNo = row.trcNo || row.TRC_NO || row.transportRequestNo || row.requestNo || row.tcsTrcNo || row.ianTrcNo || row.IAN_TRC_NO || '';
            const noticeNo = row.arrivalNoticeNo || row.arrivalNoticeReqNo || row.noticeNo || row.ntcNo || row.ianNo || row.IAN_NO || row.reqNo || '';
            const mblNo = row.mblNo || '-';
            const hblNo = row.hblNo || '-';
            const ownerNm = row.ownerNm || row.owner || row.owrNm || '-';
            const carrierNm = row.carrierNm || '-';
            const cargoMgmtNo = row.cargoMgmtNo || row.wirCargoMgmtNo || row.WIR_CARGO_MGMT_NO || '';
            const deptPortNm = row.deptPortNm || row.deptPortCd || '-';
            const arvlPortNm = row.currentLoc || row.arvlPortNm || row.arvlPortCd || '-';
            const statusNm = row.statusNm || row.statusCd || '-';

            const vessel = row.shipNo || carrierNm || '-';
            const location = arvlPortNm || '-';
            const eta = formatArrivalDate(row.eta || row.arrivalEta || row.arrivalExpectedDate || row.arrivalExpectedDt || row.arrivalScheduledDate || row.arrvDt || row.arrvSchdYmd || row.ianArrvDt || row.ianArrvSchdYmd || row.IAN_ARRV_DT || row.IAN_ARRV_SCHD_YMD || row.irArrvSchdYmd || row.desiredDeliveryAt || row.requestDt || '-');
            const arrivalStatus = normalizeArrivalStatus(row, statusNm, eta);
            const rawNoticeStatus = row.noticeStatusNm || row.noticeStatus || row.arrivalNoticeStatus || row.arrivalNoticeStatusCd || row.ianSendSttsCd || row.IAN_SEND_STTS_CD || row.sendStatusCd || row.sendSttsCd || 'TRC_NTC_NSENT';
            const noticeStatusRaw = (rawNoticeStatus || '').toString().trim().toUpperCase();
            const isNoticeSent = ['발송완료', 'TRC_NTC_SENT', 'SENT', 'Y', 'SEND', 'DONE'].includes(noticeStatusRaw) || (rawNoticeStatus || '').toString().trim() === '발송완료';
            const noticeStatus = isNoticeSent ? '발송완료' : '발송대기';

            const route = `${deptPortNm} 출항 → ${location} 입항 예정`;
            const terminal = `${arvlPortNm} 터미널`;

            const noticeBtn = !isNoticeSent
                ? `<button type="button"
                    onclick="window.openImportArrivalNoticeIssueModalFromButton(this); return false;"
                    class="arrival-notice-send-btn px-4 py-2 bg-slate-600 text-white text-xs font-bold"
                    style="min-width:52px; white-space:nowrap; display:inline-flex; align-items:center; justify-content:center;"
                    data-request-no="${safeEscape(noticeNo || trcNo)}"
                    data-notice-no="${safeEscape(noticeNo)}"
                    data-display-request-no="${safeEscape(noticeNo || trcNo)}"
                    data-transport-request-no="${safeEscape(trcNo)}"
                    data-trc-no="${safeEscape(trcNo)}"
                    data-owner-id="${safeEscape(row.ownerId || row.owrId || '')}"
                    data-owner-nm="${safeEscape(ownerNm)}"
                    data-mbl-no="${safeEscape(mblNo)}"
                    data-hbl-no="${safeEscape(hblNo)}"
                    data-cargo-mgmt-no="${safeEscape(cargoMgmtNo)}"
                    data-vessel="${safeEscape(vessel)}"
                    data-location="${safeEscape(location)}"
                    data-status="${safeEscape(arrivalStatus)}"
                    data-eta="${safeEscape(eta)}"
                    data-arrival-status="${safeEscape(arrivalStatus)}"
                    data-notice-status="${safeEscape(noticeStatus)}"
                    data-route="${safeEscape(route)}"
                    data-terminal="${safeEscape(terminal)}">도착통지서 발급</button>`
                : '<button type="button" onclick="window.openImportArrivalNoticeIssueModalFromButton(this); return false;" class="arrival-notice-send-btn import-arrival-issue-modal-btn px-4 py-2 bg-slate-100 text-slate-700 text-xs font-bold" data-trc-no="' + safeEscape(trcNo) + '" data-transport-request-no="' + safeEscape(trcNo) + '" data-notice-no="' + safeEscape(noticeNo) + '" data-request-no="' + safeEscape(noticeNo || trcNo) + '" data-owner-nm="' + safeEscape(ownerNm) + '" data-mbl-no="' + safeEscape(mblNo) + '" data-hbl-no="' + safeEscape(hblNo) + '" data-location="' + safeEscape(location) + '" data-status="' + safeEscape(arrivalStatus) + '" data-eta="' + safeEscape(eta) + '" data-notice-status="발송완료">도착통지서 발급</button>';

            return `
                <tr>
                    <td class="font-bold">${safeEscape(noticeNo || '-')}</td>
                    <td>${safeEscape(mblNo)}</td>
                    <td>${safeEscape(hblNo)}</td>
                    <td>${safeEscape(location)}</td>
                    <td class="arrival-status-cell">${arrivalStatusChip(arrivalStatus)}</td>
                    <td>${safeEscape(eta)}</td>
                    <td class="arrival-notice-status-cell">${safeEscape(noticeStatus)}</td>
                    <td>${noticeBtn}</td>
                </tr>
            `;
        }).join('')
        : `
            <tr>
                <td colspan="8" class="text-center text-slate-500 py-6">
                    ${window.__TACS_IMPORT_ARRIVAL_LOADING ? '도착예정 및 입항추적 데이터를 불러오는 중입니다.' : '도착예정 및 입항추적 데이터가 없습니다.'}
                </td>
            </tr>
        `;

    return `
        <div class="section-card">
            <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
                <div>
                    <h4 class="text-sm font-bold text-slate-900">도착예정 및 입항추적</h4>
                </div>
            </div>
            <div class="p-6 space-y-6">
                <div class="list-search-grid">
                    <div><label class="field-label">Master B/L</label><input class="field-input" type="text" placeholder="Master B/L 검색" /></div>
                    <div><label class="field-label">House B/L</label><input class="field-input" type="text" placeholder="House B/L 검색" /></div>
                    <div><label class="field-label">도착상태</label><select class="field-select"><option>전체</option><option>입항전</option><option>운항중</option><option>도착</option></select></div>
                    <div><label class="field-label">도착예정일</label><input class="field-input" type="date" /></div>
                    <button type="button" id="importArrivalSearchBtn">조회</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full tbl">
                        <thead>
                            <tr>
                                <th>도착통지서 번호</th>
                                <th>Master B/L</th>
                                <th>House B/L</th>
                                <th>현재 위치</th>
                                <th>도착상태</th>
                                <th>도착예정일</th>
                                <th>통지상태</th>
                                <th>처리</th>
                            </tr>
                        </thead>
                        <tbody class="text-[11px] text-slate-700">
                            ${rows}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    `;
}


function importArrivalRequestNoKeys(value) {
    const raw = String(value == null ? '' : value).trim().toUpperCase();
    if (!raw || raw === '-') return [];
    const noTrc = raw.replace(/^TRC-/, '');
    const compact = noTrc.replace(/-/g, '');
    const compactNoPrefix = compact.replace(/^TRC/, '');
    const nums = noTrc.match(/^(IMP|EXP)-?(\d{4})-?(\d{2})-?(\d{2})-?(\d+)$/);
    const canonical = nums ? (nums[1] + nums[2] + nums[3] + nums[4] + String(parseInt(nums[5], 10))) : '';
    return [raw, noTrc, compact, compactNoPrefix, canonical].filter(function (item, index, arr) {
        return item && arr.indexOf(item) === index;
    });
}

function importArrivalRowValues(row) {
    row = row || {};
    return [
        row.trcNo, row.TRC_NO, row.transportRequestNo, row.requestNo, row.tcsTrcNo,
        row.reqNo, row.arrivalNoticeNo, row.arrivalNoticeReqNo, row.noticeNo, row.ntcNo,
        row.ianNo, row.IAN_NO, row.ianTrcNo, row.IAN_TRC_NO, row.ianIrNo, row.IAN_IR_NO,
        row.irNo, row.IR_NO, row.relatedTrcNo
    ];
}

function importArrivalRowMatches(row, no) {
    const target = importArrivalRequestNoKeys(no);
    if (!target.length || !row) return false;
    const keys = [];
    importArrivalRowValues(row).forEach(function (value) {
        keys.push.apply(keys, importArrivalRequestNoKeys(value));
    });
    return target.some(function (key) { return keys.indexOf(key) >= 0; });
}

function normalizeImportArrivalEta(value) {
    const raw = (value == null ? '' : String(value)).trim();
    if (!raw || raw === '-') return '';
    const dashed = raw.replace(/[./]/g, '-');
    const match = dashed.match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
    if (match) return match[1] + '-' + match[2].padStart(2, '0') + '-' + match[3].padStart(2, '0');
    const digits = raw.replace(/[^0-9]/g, '');
    if (digits.length >= 8) return digits.slice(0, 4) + '-' + digits.slice(4, 6) + '-' + digits.slice(6, 8);
    return '';
}

function markImportArrivalRowSent(row, trcNo, noticeNo, arrivalEta) {
    if (!row) return;
    if (trcNo && trcNo !== '-') {
        row.trcNo = row.trcNo || trcNo;
        row.TRC_NO = row.TRC_NO || trcNo;
        row.transportRequestNo = row.transportRequestNo || trcNo;
        row.requestNo = row.requestNo || trcNo;
    }
    if (noticeNo && noticeNo !== '-') {
        row.reqNo = noticeNo;
        row.arrivalNoticeNo = noticeNo;
        row.arrivalNoticeReqNo = noticeNo;
        row.noticeNo = noticeNo;
        row.ianNo = noticeNo;
        row.IAN_NO = noticeNo;
    }
    row.noticeStatus = 'TRC_NTC_SENT';
    row.noticeStatusCd = 'TRC_NTC_SENT';
    row.noticeStatusNm = '발송완료';
    row.arrivalNoticeStatus = 'TRC_NTC_SENT';
    row.arrivalNoticeStatusCd = 'TRC_NTC_SENT';
    row.arrivalNoticeSendStatusCd = 'TRC_NTC_SENT';
    row.ianSendSttsCd = 'TRC_NTC_SENT';
    row.ianSendSttsNm = '발송완료';
    row.IAN_SEND_STTS_CD = 'TRC_NTC_SENT';
    row.IAN_SEND_STTS_NM = '발송완료';
    row.sendStatusCd = 'TRC_NTC_SENT';
    row.sendSttsCd = 'TRC_NTC_SENT';
    row.sendStatusNm = '발송완료';
    row.statusCd = 'TRC_NTC_SENT';
    row.statusNm = '발송완료';
    const eta = normalizeImportArrivalEta(arrivalEta);
    if (eta) {
        row.eta = eta;
        row.arrivalEta = eta;
        row.arrivalExpectedDate = eta;
        row.arrivalExpectedDt = eta;
        row.arrivalScheduledDate = eta;
        row.arrvDt = eta;
        row.arrvSchdYmd = eta;
        row.ianArrvDt = eta;
        row.ianArrvSchdYmd = eta;
        row.IAN_ARRV_DT = eta;
        row.IAN_ARRV_SCHD_YMD = eta;
    }
}

function markImportArrivalStoresSent(trcNo, noticeNo, arrivalEta) {
    const storeNames = [
        'TRANSPORT_IMPORT_ARRIVAL_TRACKING',
        'TRANSPORT_IMPORT_ARRIVAL_LIST',
        '__TACS_IMPORT_ARRIVAL_TRACKING_ROWS'
    ];
    let matched = false;
    storeNames.forEach(function (name) {
        const list = window[name];
        if (!Array.isArray(list)) return;
        list.forEach(function (row) {
            if (importArrivalRowMatches(row, trcNo) || importArrivalRowMatches(row, noticeNo)) {
                markImportArrivalRowSent(row, trcNo, noticeNo, arrivalEta);
                matched = true;
            }
        });
    });
    if (!matched) {
        window.TRANSPORT_IMPORT_ARRIVAL_TRACKING = Array.isArray(window.TRANSPORT_IMPORT_ARRIVAL_TRACKING) ? window.TRANSPORT_IMPORT_ARRIVAL_TRACKING : [];
        const row = {trcNo: trcNo || '', TRC_NO: trcNo || '', requestNo: trcNo || '', reqNo: noticeNo || trcNo || ''};
        markImportArrivalRowSent(row, trcNo, noticeNo || trcNo, arrivalEta);
        window.TRANSPORT_IMPORT_ARRIVAL_TRACKING.push(row);
    }
    window.__TACS_IMPORT_ARRIVAL_LOADED = true;
    window.__TACS_IMPORT_ARRIVAL_LOADING = false;
}

function patchImportArrivalNoticeSentDom(trcNo, noticeNo) {
    const keys = [];
    [trcNo, noticeNo].forEach(function (no) { keys.push.apply(keys, importArrivalRequestNoKeys(no)); });

    document.querySelectorAll('.arrival-notice-send-btn, .import-ui-arrival-send-btn, .import-arrival-issue-modal-btn').forEach(function (btn) {
        const btnKeys = [];
        const ds = btn.dataset || {};
        [
            ds.trcNo, ds.transportRequestNo, ds.requestNo,
            ds.noticeNo, ds.displayRequestNo, ds.arrivalNoticeNo
        ].forEach(function (no) { btnKeys.push.apply(btnKeys, importArrivalRequestNoKeys(no)); });
        const matched = keys.length === 0 || keys.some(function (key) { return btnKeys.indexOf(key) >= 0; });
        if (!matched) return;

        const rowEl = btn.closest('tr');
        if (rowEl) {
            const noCell = rowEl.querySelector('td:first-child');
            const statusCell = rowEl.querySelector('.arrival-notice-status-cell');
            if (noCell && noticeNo) noCell.textContent = noticeNo;
            if (statusCell) statusCell.textContent = '발송완료';
        }

        const detail = btn.closest('.import-ui-request-detail[data-work-type="arrival"], .import-inline-tabs-0513[data-active-work-id="arrival"]');
        if (detail) {
            detail.querySelectorAll('.import-ui-field-readonly, .info-chip, .status-chip, .import-arrival-notice-status-view, td, span, div').forEach(function (el) {
                const txt = (el.textContent || '').trim();
                if (txt === '발송대기' || txt === '미발송' || txt === '미발급' || txt === '통지완료' || txt === 'TRC_NTC_NSENT') {
                    el.textContent = '발송완료';
                    if (el.classList) el.classList.add('import-arrival-notice-status-view');
                }
            });
        }

        /*
         * 발송 API는 이미 DB 업데이트까지 성공한 상태다.
         * 여기서 outerHTML로 버튼을 갈아끼우면 브라우저에 남은 구버전 스코프 때문에
         * safeEscape/ownerNm/mblNo 같은 미정의 변수 오류가 나고, 화면만 실패처럼 보인다.
         * 버튼은 그대로 두고 data/status/text만 안전하게 갱신한다.
         */
        if (btn.dataset) {
            if (trcNo) {
                btn.dataset.trcNo = trcNo;
                btn.dataset.transportRequestNo = trcNo;
            }
            if (noticeNo) {
                btn.dataset.noticeNo = noticeNo;
                btn.dataset.arrivalNoticeNo = noticeNo;
                btn.dataset.requestNo = noticeNo;
                btn.dataset.displayRequestNo = noticeNo;
            }
            btn.dataset.noticeStatus = '발송완료';
            btn.dataset.status = '발송완료';
        }
        btn.disabled = false;
        btn.textContent = '도착통지서 발급';
        btn.setAttribute('type', 'button');
        btn.setAttribute('onclick', 'window.openImportArrivalNoticeIssueModalFromButton(this); return false;');
        if (btn.classList) {
            btn.classList.add('arrival-notice-send-btn', 'import-arrival-issue-modal-btn');
            btn.classList.remove('import-ui-arrival-send-btn');
        }
    });

    try {
        if (typeof window.patchImportArrivalNoticeIssueArea === 'function') {
            window.patchImportArrivalNoticeIssueArea(document);
        }
    } catch (e) {
        console.warn('[도착통지서 상태 화면 보정 실패]', e);
    }
}

window.patchImportArrivalNoticeSentDom = patchImportArrivalNoticeSentDom;

window.sendImportArrivalNoticeFromButton = function (button) {
    if (!button || button.disabled) return;
    const trcNo = button.dataset.trcNo || button.dataset.transportRequestNo || '';
    const noticeNoFromButton = button.dataset.noticeNo || button.dataset.requestNo || '';
    const reqNo = trcNo || noticeNoFromButton;
    if (!reqNo || reqNo === '-') {
        alert('도착통지 발송 대상 의뢰번호가 없습니다.');
        return;
    }

    const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';
    const oldText = button.textContent;
    button.disabled = true;
    button.textContent = '발송중';
    const arrivalEta = normalizeImportArrivalEta(button.dataset.eta || '');
    let query = 'reqNo=' + encodeURIComponent(reqNo);
    if (arrivalEta) query += '&arrivalEta=' + encodeURIComponent(arrivalEta);

    fetch(contextPath + '/transport/import/arrival-notice/send-get.do?' + query, {
        method: 'GET',
        headers: {'X-Requested-With': 'XMLHttpRequest'}
    })
        .then(function (res) {
            if (!res.ok) throw new Error('HTTP ' + res.status);
            return res.json();
        })
        .then(function (data) {
            if (data && data.success === false) {
                throw new Error(data.message || '도착통지 발송 대상이 없습니다.');
            }

            const savedNoticeNo = data.noticeNo || data.arrivalNoticeNo || data.arrivalNoticeReqNo || data.ianNo || noticeNoFromButton || reqNo;
            const savedTrcNo = data.trcNo || data.transportRequestNo || trcNo || reqNo;

            markImportArrivalStoresSent(savedTrcNo, savedNoticeNo, arrivalEta);
            patchImportArrivalNoticeSentDom(savedTrcNo, savedNoticeNo);

            const sentDetail = {
                trcNo: savedTrcNo,
                reqNo: savedTrcNo,
                noticeNo: savedNoticeNo,
                arrivalNoticeNo: savedNoticeNo,
                arrivalNoticeReqNo: savedNoticeNo,
                eta: arrivalEta,
                arrivalEta: arrivalEta
            };
            if (typeof window.refreshImportArrivalNoticeSentState === 'function') {
                window.refreshImportArrivalNoticeSentState(sentDetail);
            }
            window.dispatchEvent(new CustomEvent('tacs:import-arrival-notice-sent', { detail: sentDetail }));

            setTimeout(function () { patchImportArrivalNoticeSentDom(savedTrcNo, savedNoticeNo); }, 0);
            setTimeout(function () { patchImportArrivalNoticeSentDom(savedTrcNo, savedNoticeNo); }, 80);
            setTimeout(function () { patchImportArrivalNoticeSentDom(savedTrcNo, savedNoticeNo); }, 250);
            setTimeout(function () {
                if (typeof window.syncManifestArrivalNoticeStatus === 'function') window.syncManifestArrivalNoticeStatus(savedTrcNo);
            }, 0);

            alert('도착통지서가 발송되었습니다.');
        })
        .catch(function (err) {
            console.error('[도착통지 발송 실패]', err);
            alert(err.message || '도착통지 발송 중 오류가 발생했습니다.');
            button.disabled = false;
            button.textContent = oldText;
        });
};


function normalizeDetailActionButtons() {
    const root =
        (typeof detailMain !== 'undefined' && detailMain)
            ? detailMain
            : document.getElementById('detail-view');

    if (!root) return;

    root.querySelectorAll('button').forEach((btn) => {
        const label = (btn.textContent || '').replace(/\s+/g, ' ').trim();
        if (label.includes('미리보기')) btn.remove();
    });

    const actionPattern = /(제출|저장|발송|요청|등록|수락|반려|처리|회신|전달)/;
    const keepPattern = /(조회|상세|대시보드|삭제|닫기|이전|다음)/;

    root.querySelectorAll('.section-card').forEach((card) => {
        let footer = card.querySelector('.section-card-action-footer');
        if (!footer) {
            footer = document.createElement('div');
            footer.className = 'section-card-action-footer flex justify-end gap-2 px-6 py-4 border-t border-slate-200';
            card.appendChild(footer);
        }

        const movableButtons = Array.from(card.querySelectorAll('button')).filter((btn) => {
            if (footer.contains(btn)) return false;
            if (btn.closest('table, thead, tbody, tfoot, tr, td, th')) return false;
            const label = (btn.textContent || '').replace(/\s+/g, ' ').trim();
            if (!label) return false;
            if (label.includes('미리보기')) return false;
            if (keepPattern.test(label)) return false;
            return actionPattern.test(label);
        });

        movableButtons.forEach((btn) => footer.appendChild(btn));

        if (!footer.querySelector('button')) {
            footer.remove();
        }
    });
}

function startDetailActionObserver() {
    const root =
        (typeof detailMain !== 'undefined' && detailMain)
            ? detailMain
            : document.getElementById('detail-view');

    if (!root || root.dataset.actionObserverBound === 'true') return;

    const observer = new MutationObserver(() => {
        normalizeDetailActionButtons();
    });
    observer.observe(root, {childList: true, subtree: true});
    root.dataset.actionObserverBound = 'true';
}

function buildRequestListPanel(item) {
    const isImport = item.id === 'TACS-FW-015';
    const rows = isImport
        ? '<tr><td colspan="8" class="text-center py-8 text-slate-500">수입 운송의뢰 목록을 불러오는 중입니다.</td></tr>'
        : '<tr><td colspan="8" class="text-center py-8 text-slate-500">수출 운송의뢰 목록을 불러오는 중입니다.</td></tr>';

    return `
        <div class="section-card">
            <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
                <div>
                    <h4 class="text-sm font-bold text-slate-900">운송의뢰</h4>
                    <p class="text-xs text-slate-500 mt-1">${isImport ? '수입 의뢰 접수 상태와 화주가 보낸 Master B/L 첨부파일 정보를 확인하고 상세 접수 화면으로 이동합니다.' : '수출 운송의뢰 접수 상태와 선적 기본 정보를 확인하고 상세 검토를 진행합니다.'}</p>
                </div>
                <button class="px-4 py-2 bg-primary text-white text-xs font-bold hover:bg-primary-dim">조회</button>
            </div>
            <div class="p-6 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
                    <div><label class="field-label">의뢰번호</label><input class="field-input" type="text" placeholder="의뢰번호 검색" /></div>
                    <div><label class="field-label">화주명</label><input class="field-input js-import-filter-shipper" type="text" placeholder="화주명 검색" /></div>
                    <div><label class="field-label">${isImport ? 'Master B/L / House B/L' : '바이어명'}</label><input class="field-input" type="text" placeholder="${isImport ? 'Master B/L / House B/L 검색' : '바이어명 검색'}" /></div>
                    <div><label class="field-label">상태</label><select class="field-select"><option>전체</option><option>접수대기</option><option>접수반려</option><option>접수완료</option></select></div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full tbl">
                        <thead>
                            <tr>
                                <th>의뢰번호</th>
                                <th>화주명</th>
                                <th>${isImport ? 'Master B/L / House B/L' : '바이어명'}</th>
                                <th>${isImport ? '선사' : '운송수단'}</th>
                                <th>${isImport ? '도착항' : '선적항'}</th>
                                <th>상태</th>
                                <th>등록일시</th>
                                <th>처리</th>
                            </tr>
                        </thead>
                        <tbody class="text-[11px] text-slate-700">
                            ${rows}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    `;
}

var importCargoManifestRows = Array.isArray(window.importCargoManifestRows) ? window.importCargoManifestRows : [];

/* import-ui.js는 수정하지 않고, 운송의뢰 상세 내부 '도착/입항' 요약카드만
 * 원래 도착예정 및 입항추적 목록 화면으로 복구한다.
 */
(function installImportArrivalInlineRestore() {
    if (window.__TACS_IMPORT_ARRIVAL_INLINE_RESTORE_20260516) return;
    window.__TACS_IMPORT_ARRIVAL_INLINE_RESTORE_20260516 = true;

    function isArrivalInlineRoot(root) {
        return root && root.classList && root.classList.contains('import-inline-tabs-0513')
            && root.dataset && root.dataset.activeWorkId === 'arrival';
    }

    function looksLikeSummaryOnly(panel) {
        if (!panel) return false;
        if (panel.querySelector('table.tbl')) return false;
        const text = (panel.textContent || '').replace(/\s+/g, ' ').trim();
        return text.includes('도착예정 및 입항추적')
            && text.includes('상세화면 열기')
            && text.includes('통지상태');
    }

    function restoreInlineArrivalPanel(root) {
        if (!isArrivalInlineRoot(root)) return;
        const panel = root.querySelector('.import-ui-panel');
        if (!panel) return;

        // 이미 목록형 화면이면 다시 건드리지 않는다.
        if (panel.querySelector('table.tbl')) return;

        // import-ui.js가 그린 요약카드 또는 빈 패널만 목록형으로 교체한다.
        if (!looksLikeSummaryOnly(panel) && (panel.textContent || '').trim()) return;

        panel.classList.add('is-active');
        panel.innerHTML = buildImportEtaTrackingListPanel();
        if (typeof normalizeDetailActionButtons === 'function') normalizeDetailActionButtons();
    }

    function restoreAllInlineArrivalPanels() {
        document.querySelectorAll('.import-inline-tabs-0513[data-active-work-id="arrival"]').forEach(restoreInlineArrivalPanel);
    }

    // 탭 클릭 후 import-ui.js가 먼저 요약카드를 그린 다음, 이 파일이 목록형으로 교체한다.
    document.addEventListener('click', function (event) {
        const target = event.target instanceof Element ? event.target : null;
        const tab = target ? target.closest('.import-ui-tab, .import-inline-tab') : null;
        if (!tab || tab.dataset.workId !== 'arrival') return;
        setTimeout(restoreAllInlineArrivalPanels, 0);
        setTimeout(restoreAllInlineArrivalPanels, 80);
    }, true);

    const observer = new MutationObserver(function () {
        restoreAllInlineArrivalPanels();
    });

    function startObserver() {
        const body = document.getElementById('detail-body') || document.body;
        if (!body) return;
        observer.observe(body, {childList: true, subtree: true});
        restoreAllInlineArrivalPanels();
    }

    if (!window.TRANSPORT_DEFER_PAGE_BOOT) {
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', startObserver);
        } else {
            startObserver();
        }
    }
})();


/*
 * 2026-05-28 fix: 기존 렌더러/캐시/비동기 재렌더가 PENDING을 다시 넣어도
 * 도착상태 칸은 최종적으로 '도착'만 보이게 방어한다.
 */
(function forceImportArrivalStatusDone() {
    if (window.__TACS_IMPORT_ARRIVAL_STATUS_ALWAYS_DONE_20260528) return;
    window.__TACS_IMPORT_ARRIVAL_STATUS_ALWAYS_DONE_20260528 = true;

    function patch(root) {
        root = root || document;
        if (!root.querySelectorAll) return;
        root.querySelectorAll('.arrival-status-cell').forEach(function (cell) {
            cell.innerHTML = '<span class="status-chip status-confirmed">도착</span>';
        });
        root.querySelectorAll('[data-arrival-status], [data-status]').forEach(function (el) {
            if (el.dataset) {
                if (el.dataset.arrivalStatus !== undefined) el.dataset.arrivalStatus = '도착';
                if (el.dataset.status !== undefined && /PENDING|입항전|운항중|IN_TRANSIT|BEFORE_ARRIVAL/i.test(el.dataset.status || '')) {
                    el.dataset.status = '도착';
                }
            }
        });
    }

    document.addEventListener('DOMContentLoaded', function () {
        patch(document);
        setTimeout(function () { patch(document); }, 100);
        setTimeout(function () { patch(document); }, 500);
    });

    document.addEventListener('click', function () {
        setTimeout(function () { patch(document); }, 0);
        setTimeout(function () { patch(document); }, 120);
    }, true);

    if (window.MutationObserver) {
        new MutationObserver(function (mutations) {
            mutations.forEach(function (mutation) {
                Array.prototype.slice.call(mutation.addedNodes || []).forEach(function (node) {
                    if (node && node.nodeType === 1) patch(node);
                });
            });
        }).observe(document.documentElement, { childList: true, subtree: true });
    }
})();


/*
 * 2026-06-02 fix
 * - 도착통지서 상태는 발송대기/발송완료만 표시한다.
 * - 상태칩/발급완료 클릭으로 모달이 뜨지 않게 막고,
 *   적하목록 대조값 아래의 "도착통지서 발급" 버튼에서만 모달을 연다.
 */
(function installImportArrivalNoticeIssueModal() {
    if (window.__TACS_IMPORT_ARRIVAL_NOTICE_ISSUE_MODAL_20260602) return;
    window.__TACS_IMPORT_ARRIVAL_NOTICE_ISSUE_MODAL_20260602 = true;

    function htmlEscape(value) {
        if (typeof window !== 'undefined' && typeof window.safeEscape === 'function') return window.safeEscape(value);
        if (typeof safeEscape === 'function') return safeEscape(value);
        return String(value == null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function text(value) {
        return String(value == null ? '' : value).replace(/\s+/g, ' ').trim();
    }

    function normalizeNoticeStatus(value) {
        const raw = text(value);
        const upper = raw.toUpperCase();
        if (upper === 'TRC_NTC_SENT' || upper === 'SENT' || raw === '발송완료' || raw === '통지완료' || raw === '발급완료') return '발송완료';
        return '발송대기';
    }

    function isNoticeSentValue(value) {
        return normalizeNoticeStatus(value) === '발송완료';
    }

    function first() {
        for (let i = 0; i < arguments.length; i += 1) {
            const v = arguments[i];
            if (v != null && String(v).trim() !== '') return String(v).trim();
        }
        return '';
    }

    function routeDisplay(value) {
        const raw = first(value, '-');
        const upper = raw.toUpperCase();
        const map = {
            KRPUS: '부산행', BUSAN: '부산행', PUSAN: '부산행', '부산항': '부산행', '부산': '부산행', KRINC: '인천행', INCHEON: '인천행', '인천항': '인천행', '인천': '인천행',
            THBKK: '방콕행', BANGKOK: '방콕행', '방콕항': '방콕행', '방콕': '방콕행', CNSHA: '상하이행', SHANGHAI: '상하이행', '상하이항': '상하이행', '상하이': '상하이행',
            USLAX: '로스앤젤레스행', LAX: '로스앤젤레스행', LOSANGELES: '로스앤젤레스행', '로스앤젤레스항': '로스앤젤레스행'
        };
        if (map[upper]) return map[upper];
        if (map[raw]) return map[raw];
        if (raw.endsWith('항')) return raw.slice(0, -1) + '행';
        if (raw.endsWith('행')) return raw;
        return raw;
    }

    function requestNoValues(row) {
        row = row || {};
        return [
            row.trcNo, row.TRC_NO, row.transportRequestNo, row.importRequestNo, row.requestNo,
            row.ianTrcNo, row.IAN_TRC_NO, row.tcsTrcNo, row.TCS_TRC_NO,
            row.treId, row.TRE_ID, row.diTrcNo, row.DI_TRC_NO,
            row.relTrcNo, row.CRR_TRE_ID, row.dispatchTreId, row.DISPATCH_TRE_ID
        ].filter(function (v) { return v != null && String(v).trim() !== ''; }).map(function (v) { return String(v).trim(); });
    }

    function noticeNoValues(row) {
        row = row || {};
        return [
            row.arrivalNoticeNo, row.arrivalNoticeReqNo, row.noticeNo, row.ianNo, row.IAN_NO,
            row.reqNo, row.REQ_NO, row.ntcNo, row.arrvNtcNo
        ].filter(function (v) { return v != null && String(v).trim() !== ''; }).map(function (v) { return String(v).trim(); });
    }

    function rowMatches(row, trcNo, noticeNo) {
        const trc = first(trcNo);
        const ntc = first(noticeNo);
        const trcValues = requestNoValues(row);
        const ntcValues = noticeNoValues(row);
        return (!!trc && trcValues.indexOf(trc) >= 0) || (!!ntc && ntcValues.indexOf(ntc) >= 0);
    }

    function mergeUsable() {
        const merged = {};
        Array.prototype.slice.call(arguments).forEach(function (row) {
            Object.keys(row || {}).forEach(function (key) {
                const value = row[key];
                if ((merged[key] == null || String(merged[key]).trim() === '' || String(merged[key]).trim() === '-')
                    && value != null && String(value).trim() !== '' && String(value).trim() !== '-') {
                    merged[key] = value;
                }
            });
        });
        return merged;
    }

    function cachedRows() {
        const names = [
            'TRANSPORT_IMPORT_ARRIVAL_TRACKING',
            'TRANSPORT_IMPORT_ARRIVAL_LIST',
            '__TACS_IMPORT_ARRIVAL_TRACKING_ROWS',
            'TRANSPORT_IMPORT_REQUESTS',
            '__TACS_IMPORT_REQUEST_LIST',
            '__IMPORT_REQUEST_LIST',
            'importTransportRequests',
            'importRequestRows',
            'importRequests'
        ];
        const rows = [];
        names.forEach(function (name) {
            if (Array.isArray(window[name])) rows.push.apply(rows, window[name]);
        });
        if (window.selectedImportRequest) rows.push(window.selectedImportRequest);
        if (window.__TACS_IMPORT_MANIFEST_PENDING_SEARCH) rows.unshift(window.__TACS_IMPORT_MANIFEST_PENDING_SEARCH);
        return rows;
    }

    function findRowByButton(button) {
        const ds = (button && button.dataset) || {};
        const pending = window.__TACS_IMPORT_MANIFEST_PENDING_SEARCH || {};
        const trcNo = first(ds.trcNo, ds.transportRequestNo, ds.requestNo, pending.trcNo, pending.requestNo);
        const noticeNo = first(ds.noticeNo, ds.arrivalNoticeNo, ds.reqNo, pending.noticeNo, pending.arrivalNoticeNo);
        let row = {};
        try {
            if (typeof findImportArrivalRowByNo === 'function') row = findImportArrivalRowByNo(trcNo || noticeNo) || {};
        } catch (e) { row = {}; }
        const matches = cachedRows().filter(function (item) { return rowMatches(item, trcNo, noticeNo); });
        return mergeUsable(row, pending, matches[0], matches[1], matches[2], matches[3]);
    }

    function detailFromButton(button) {
        const ds = (button && button.dataset) || {};
        const pending = window.__TACS_IMPORT_MANIFEST_PENDING_SEARCH || {};
        const row = findRowByButton(button);
        const root = button && button.closest ? button.closest('.import-inline-tabs-0513') : null;
        const rootTrcNo = root && root.dataset ? root.dataset.requestNo : '';
        const trcNo = first(ds.trcNo, ds.transportRequestNo, ds.requestNo, row.trcNo, row.TRC_NO, row.transportRequestNo, row.importRequestNo, row.ianTrcNo, row.IAN_TRC_NO, pending.trcNo, pending.requestNo, rootTrcNo);
        const noticeNo = first(ds.noticeNo, ds.arrivalNoticeNo, ds.reqNo, row.arrivalNoticeNo, row.arrivalNoticeReqNo, row.noticeNo, row.ianNo, row.IAN_NO, row.reqNo, pending.noticeNo, pending.arrivalNoticeNo);
        const rootText = root ? text(root.textContent || '') : '';
        const panelStatus = rootText.indexOf('발송완료') >= 0 || rootText.indexOf('발급완료') >= 0 || rootText.indexOf('통지완료') >= 0 ? '발송완료' : (rootText.indexOf('발송대기') >= 0 || rootText.indexOf('미발급') >= 0 ? '발송대기' : '');
        const status = normalizeNoticeStatus(first(ds.noticeStatus, row.noticeStatusNm, row.arrivalNoticeStatusNm, row.noticeStatus, row.arrivalNoticeStatus, row.arrivalNoticeStatusCd, row.ianSendSttsCd, row.IAN_SEND_STTS_CD, row.sendStatusCd, pending.noticeStatus, panelStatus));
        const rawCurrentLoc = first(ds.location, ds.currentLoc, row.currentLoc, row.currentLocNm, row.currentLocCd, row.currLoc, row.ianCurrLoc, row.IAN_CURR_LOC, pending.currentLoc, pending.currentLocNm, row.arvlPortRouteNm, row.arvlPortNm, row.arvlPortCd, pending.arvlPort);
        const rawDeptPort = first(ds.deptPort, row.deptPortRouteNm, row.deptPortNm, row.deptPortCd, row.departurePort, row.startPort, pending.deptPort, pending.deptPortNm, pending.deptPortCd);
        const rawArvlPort = first(ds.arvlPort, row.arvlPortRouteNm, row.arvlPortNm, row.arvlPortCd, row.arrivalPort, row.destinationPort, pending.arvlPort, pending.arvlPortNm, pending.arvlPortCd, rawCurrentLoc);
        return {
            trcNo: trcNo,
            noticeNo: noticeNo,
            requestNo: noticeNo || trcNo,
            ownerNm: first(ds.ownerNm, row.ownerNm, row.owner, row.owrNm, row.OWR_NM, row.IAN_RCV_ACTR_NM, pending.ownerNm, '-'),
            mblNo: first(ds.mblNo, row.mblNo, row.masterBlNo, row.MBL_NO, row.ICM_MBL_NO, row.BI_MBL_NO, row.TCS_MBL_NO, row.IR_BL_AWB_NO, pending.mblNo, '-'),
            hblNo: first(ds.hblNo, row.hblNo, row.houseBlNo, row.HBL_NO, row.ICM_HBL_NO, row.BI_HBL_NO, row.TCS_HBL_NO, pending.hblNo, '-'),
            currentLoc: routeDisplay(rawCurrentLoc || '-'),
            deptPort: routeDisplay(rawDeptPort || '-'),
            arvlPort: routeDisplay(rawArvlPort || '-'),
            eta: first(ds.eta, row.eta, row.arrivalEta, row.arrivalExpectedDate, row.arrivalExpectedDt, row.arrivalScheduledDate, row.arrvDt, row.arrvSchdYmd, row.ianArrvDt, row.ianArrvSchdYmd, row.irArrvSchdYmd, row.IAN_ARRV_DT, row.IAN_ARRV_SCHD_YMD, pending.eta, pending.arrivalEta, pending.arrivalExpectedDate, pending.arrivalScheduledDate, pending.arrvDt, pending.ianArrvDt, '-'),
            cargoMgmtNo: first(ds.cargoMgmtNo, row.cargoMgmtNo, row.wirCargoMgmtNo, row.WIR_CARGO_MGMT_NO, pending.cargoMgmtNo, '-'),
            status: status,
            rawButton: button
        };
    }

    function closeModal() {
        const old = document.getElementById('import-arrival-issue-modal');
        if (old) old.remove();
    }

    function field(label, value) {
        return '<div style="display:flex; flex-direction:column; gap:4px;">'
            + '<span style="font-size:11px; font-weight:700; color:#64748b;">' + htmlEscape(label) + '</span>'
            + '<div style="min-height:38px; display:flex; align-items:center; padding:8px 10px; border:1px solid #e2e8f0; background:#f8fafc; font-size:12px; color:#0f172a;">' + htmlEscape(value || '-') + '</div>'
            + '</div>';
    }

    function dateInputValue(value) {
        const raw = text(value);
        if (!raw || raw === '-') return '';
        const digits = raw.replace(/[^0-9]/g, '');
        if (digits.length >= 8) return digits.slice(0, 4) + '-' + digits.slice(4, 6) + '-' + digits.slice(6, 8);
        return /^\d{4}-\d{2}-\d{2}$/.test(raw) ? raw : '';
    }

    function dateField(label, value) {
        return '<div style="display:flex; flex-direction:column; gap:4px;">'
            + '<span style="font-size:11px; font-weight:700; color:#64748b;">' + htmlEscape(label) + '</span>'
            + '<input type="date" class="import-arrival-issue-eta-input" value="' + htmlEscape(dateInputValue(value)) + '" style="height:38px; padding:8px 10px; border:1px solid #e2e8f0; background:#fff; font-size:12px; color:#0f172a;">'
            + '</div>';
    }

    function openModal(button) {
        if (!button) return;
        const d = detailFromButton(button);
        closeModal();
        const sent = d.status === '발송완료';
        const modal = document.createElement('div');
        modal.id = 'import-arrival-issue-modal';
        modal.style.cssText = 'position:fixed; inset:0; z-index:99999; display:flex; align-items:center; justify-content:center; background:rgba(15,23,42,.45); padding:24px;';
        modal.innerHTML = '<div style="width:min(760px, 96vw); max-height:88vh; overflow:auto; background:#fff; border:2px solid #0f172a; box-shadow:0 20px 50px rgba(15,23,42,.25);">'
            + '<div style="display:flex; align-items:center; justify-content:space-between; padding:18px 20px; border-bottom:1px solid #e2e8f0; background:#f8fafc;">'
            + '<div><h3 style="margin:0; font-size:18px; font-weight:900; color:#0f172a;">도착통지서 발급</h3><p style="margin:4px 0 0; font-size:12px; color:#64748b;">상태칩은 조회만 하고, 이 모달에서 도착통지서를 전송합니다.</p></div>'
            + '<button type="button" data-arrival-issue-close="Y" style="border:0; background:transparent; font-size:24px; line-height:1; cursor:pointer; color:#334155;">×</button>'
            + '</div>'
            + '<div style="padding:20px; display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:12px;">'
            + field('도착통지서 상태', d.status)
            + field('도착통지서 번호', d.noticeNo || '-')
            + field('운송의뢰번호', d.trcNo || '-')
            + field('화주명', d.ownerNm || '-')
            + field('Master B/L', d.mblNo || '-')
            + field('House B/L', d.hblNo || '-')
            + field('현재위치', d.currentLoc || '-')
            + field('출발항', d.deptPort || '-')
            + field('도착항', d.arvlPort || '-')
            + dateField('도착예정일', d.eta || '')
            + '</div>'
            + '<div style="display:flex; justify-content:flex-end; gap:8px; padding:16px 20px; border-top:1px solid #e2e8f0; background:#fff;">'
            + '<button type="button" data-arrival-issue-close="Y" style="padding:10px 14px; border:1px solid #cbd5e1; background:#fff; font-size:12px; font-weight:800; cursor:pointer;">닫기</button>'
            + (sent
                ? '<button type="button" disabled style="padding:10px 16px; border:1px solid #cbd5e1; background:#e2e8f0; color:#475569; font-size:12px; font-weight:900;">발송완료</button>'
                : '<button type="button" class="import-arrival-issue-send-confirm" style="padding:10px 16px; border:1px solid #0f172a; background:#0f172a; color:#fff; font-size:12px; font-weight:900; cursor:pointer;">전송</button>')
            + '</div>'
            + '</div>';
        document.body.appendChild(modal);
        const confirmBtn = modal.querySelector('.import-arrival-issue-send-confirm');
        if (confirmBtn) {
            confirmBtn.addEventListener('click', function () {
                const etaInput = modal.querySelector('.import-arrival-issue-eta-input');
                if (etaInput && d.rawButton && d.rawButton.dataset) d.rawButton.dataset.eta = etaInput.value || '';
                if (d.rawButton && d.rawButton.dataset) d.rawButton.dataset.confirmSend = 'Y';
                if (typeof window.sendImportArrivalNoticeFromButton === 'function') {
                    window.sendImportArrivalNoticeFromButton(d.rawButton || button);
                    closeModal();
                    setTimeout(function () { window.patchImportArrivalNoticeIssueArea(document); }, 180);
                    return;
                }
                alert('도착통지서 전송 함수를 찾을 수 없습니다.');
            });
        }
    }

    window.openImportArrivalNoticeIssueModalFromButton = openModal;
    window.openImportArrivalNoticeSendModalFromButton = openModal;

    function replaceStatusLeaf(el, status) {
        if (!el || !el.parentNode) return;
        if (/^(BUTTON|A)$/i.test(el.tagName || '')) {
            const span = document.createElement('span');
            span.className = (el.className || 'status-chip') + ' import-arrival-notice-status-view';
            span.textContent = status;
            if (el.dataset) {
                Array.prototype.slice.call(el.attributes || []).forEach(function (attr) {
                    if (attr.name.indexOf('data-') === 0) span.setAttribute(attr.name, attr.value);
                });
            }
            el.parentNode.replaceChild(span, el);
        } else {
            el.textContent = status;
            if (el.classList) el.classList.add('import-arrival-notice-status-view');
        }
    }

    function normalizeStatusChips(root) {
        root = root || document;
        if (!root.querySelectorAll) return;
        root.querySelectorAll('button, a, span, td, div, strong, em').forEach(function (el) {
            if (!el || el.closest('#import-arrival-issue-modal')) return;
            const raw = text(el.textContent || '');
            if (!raw || (el.children && el.children.length && !/^(미발급|발급완료|미발송|통지완료|NOT_SENT|SENT)$/.test(raw))) return;
            if (/^(발급완료|통지완료|SENT)$/.test(raw)) replaceStatusLeaf(el, '발송완료');
            else if (/^(미발급|미발송|NOT_SENT)$/.test(raw)) replaceStatusLeaf(el, '발송대기');
        });
    }

    function rootRequestNo(root) {
        return first(root && root.dataset && root.dataset.requestNo, window.__TACS_IMPORT_MANIFEST_PENDING_SEARCH && window.__TACS_IMPORT_MANIFEST_PENDING_SEARCH.trcNo);
    }

    function ensureIssueButton(root) {
        if (!root || !root.querySelectorAll) return;
        const activeRoot = root.classList && root.classList.contains('import-inline-tabs-0513') ? root : (root.querySelector && root.querySelector('.import-inline-tabs-0513[data-active-work-id="arrival"]'));
        if (!activeRoot || !activeRoot.dataset || activeRoot.dataset.activeWorkId !== 'arrival') return;
        const panel = activeRoot.querySelector('.import-ui-panel') || activeRoot;
        if (panel.querySelector('.import-arrival-issue-modal-btn[data-auto-issue-button="Y"]')) return;
        const panelText = text(panel.textContent || '');
        if (!panelText.includes('적하목록') && !panel.querySelector('table')) return;
        const no = rootRequestNo(activeRoot);
        const pending = window.__TACS_IMPORT_MANIFEST_PENDING_SEARCH || {};
        const d = detailFromButton({dataset: {trcNo: no, requestNo: no}, closest: function () { return activeRoot; }});
        const tables = Array.prototype.slice.call(panel.querySelectorAll('table'));
        const anchor = tables.length ? tables[tables.length - 1] : null;
        const wrap = document.createElement('div');
        wrap.className = 'import-ui-actions import-arrival-issue-action-area';
        wrap.style.cssText = 'display:flex; justify-content:flex-end; gap:8px; margin-top:14px; padding-top:14px; border-top:1px solid #e2e8f0;';
        wrap.innerHTML = '<button type="button" class="import-ui-btn import-ui-arrival-send-btn import-arrival-issue-modal-btn"'
            + ' data-auto-issue-button="Y"'
            + ' data-trc-no="' + htmlEscape(d.trcNo || no) + '"'
            + ' data-request-no="' + htmlEscape(d.trcNo || no) + '"'
            + ' data-notice-no="' + htmlEscape(d.noticeNo || pending.noticeNo || '') + '"'
            + ' data-notice-status="' + htmlEscape(d.status || pending.noticeStatus || '발송대기') + '"'
            + ' data-owner-nm="' + htmlEscape(d.ownerNm || pending.ownerNm || '') + '"'
            + ' data-mbl-no="' + htmlEscape(d.mblNo || pending.mblNo || '') + '"'
            + ' data-hbl-no="' + htmlEscape(d.hblNo || pending.hblNo || '') + '"'
            + ' data-location="' + htmlEscape(d.currentLoc || pending.currentLoc || '') + '"'
            + ' data-dept-port="' + htmlEscape(d.deptPort || pending.deptPort || '') + '"'
            + ' data-arvl-port="' + htmlEscape(d.arvlPort || pending.arvlPort || '') + '"'
            + ' data-eta="' + htmlEscape(d.eta || pending.eta || pending.arrivalEta || pending.arrivalExpectedDate || pending.arrivalScheduledDate || pending.arrvDt || pending.ianArrvDt || '') + '"'
            + '>도착통지서 발급</button>';
        if (anchor && anchor.parentNode) anchor.parentNode.insertBefore(wrap, anchor.nextSibling);
        else panel.appendChild(wrap);
    }

    function patch(root) {
        root = root || document;
        normalizeStatusChips(root);
        if (root.classList && root.classList.contains('import-inline-tabs-0513')) ensureIssueButton(root);
        else root.querySelectorAll && root.querySelectorAll('.import-inline-tabs-0513[data-active-work-id="arrival"]').forEach(ensureIssueButton);
    }

    window.patchImportArrivalNoticeIssueArea = patch;

    document.addEventListener('click', function (event) {
        const target = event.target instanceof Element ? event.target : null;
        if (!target) return;
        if (target.closest('[data-arrival-issue-close="Y"]')) {
            event.preventDefault();
            closeModal();
            return;
        }
        const issueBtn = target.closest('.import-arrival-issue-modal-btn');
        if (issueBtn) {
            event.preventDefault();
            event.stopPropagation();
            openModal(issueBtn);
            return;
        }
    }, false);

    // 예전 구현의 '발급완료/미발급' 상태버튼 클릭은 캡처 단계에서 차단한다.
    document.addEventListener('click', function (event) {
        const target = event.target instanceof Element ? event.target : null;
        if (!target || target.closest('#import-arrival-issue-modal')) return;
        const activeRoot = target.closest('.import-inline-tabs-0513[data-active-work-id="arrival"]');
        if (!activeRoot) return;
        const raw = text(target.textContent || '');
        if (/^(발송대기|발송완료|미발급|발급완료|미발송|통지완료)$/.test(raw) && !target.closest('.import-arrival-issue-modal-btn')) {
            event.preventDefault();
            event.stopImmediatePropagation();
        }
    }, true);

    document.addEventListener('DOMContentLoaded', function () {
        patch(document);
        setTimeout(function () { patch(document); }, 100);
        setTimeout(function () { patch(document); }, 400);
    });

    if (window.MutationObserver) {
        let scheduled = false;
        new MutationObserver(function () {
            if (scheduled) return;
            scheduled = true;
            setTimeout(function () {
                scheduled = false;
                patch(document);
            }, 80);
        }).observe(document.documentElement, {childList: true, subtree: true});
    }
})();
