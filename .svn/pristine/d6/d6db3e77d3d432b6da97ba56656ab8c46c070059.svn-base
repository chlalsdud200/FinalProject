@charset "UTF-8";

:root {
  --navy: #1b2d44;
  --navy-dk: #112340;
  --navy-lt: #254878;
  --blue: #2563eb;
  --green: #16a34a;
  --orange: #d97706;
  --red: #dc2626;
  --cyan: #0891b2;
  --purple: #7c3aed;
  --border: #e2e8f0;
  --txt: #1e293b;
  --txt2: #64748b;
  --txt3: #94a3b8;
  --bg: #f8fafc;
}

* { box-sizing: border-box; }

.modal-label {
    display: block;
    margin-bottom: 6px;
    color: #334155;
    font-size: 12px;
    font-weight: 700;
}

.detail-wrap {
  background: #f4f6fa;
  min-height: calc(100vh - 56px);
}

.det-wrap {
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 56px);
  background: #f4f6fa;
}

.det-hdr {
  background: #fff;
  border-bottom: 1px solid var(--border);
  padding: 14px 24px;
  flex-shrink: 0;
}

.det-hdr-inner {
  display: flex;
  align-items: stretch;
  gap: 16px;
}

.det-hdr-left { flex: 1; min-width: 0; }

.det-hdr-top {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.det-no {
  font-size: 20px;
  font-weight: 900;
  color: var(--navy);
}

.det-meta {
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
  margin-bottom: 6px;
}

.det-m {
  font-size: 12px;
  color: var(--txt2);
}

.det-m span {
  font-weight: 700;
  color: #0f2537;
}

.det-m.hl span { color: var(--blue); }

.det-ai {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
  flex-wrap: wrap;
}

.ai-score-sm {
  background: var(--navy);
  color: #fff;
  border-radius: 4px;
  padding: 3px 10px;
  font-size: 12px;
  font-weight: 700;
}

.ai-tags-sm { display: flex; gap: 4px; flex-wrap: wrap; }

.ai-tag-sm {
  background: #f1f5f9;
  border: 1px solid var(--border);
  color: var(--txt2);
  font-size: 10.5px;
  padding: 2px 7px;
  border-radius: 10px;
}

.status-panel {
  flex-shrink: 0;
  min-width: 165px;
  border-radius: 6px;
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2px solid transparent;
  text-align: center;
}

.status-panel .sp-label {
  font-size: 9.5px;
  font-weight: 900;
  letter-spacing: .7px;
  text-transform: uppercase;
  opacity: .65;
  margin-bottom: 5px;
}

.status-panel .sp-val {
  font-size: 21px;
  font-weight: 900;
  line-height: 1;
}

.status-panel .sp-desc {
  font-size: 11px;
  margin-top: 4px;
  opacity: .72;
}

.sp-접수대기 { background: #fff7ed; border-color: #fcd34d; color: #92400e; }
.sp-접수완료 { background: #eff6ff; border-color: #93c5fd; color: #1e40af; }
.sp-심사중 { background: #faf5ff; border-color: #c4b5fd; color: #5b21b6; }
.sp-보완요청 { background: #fff7ed; border-color: #fdba74; color: #9a3412; }
.sp-소명요청 { background: #e0f2fe; border-color: #67e8f9; color: #164e63; }
.sp-통관보류 { background: #f8fafc; border-color: #94a3b8; color: #334155; }
.sp-승인완료 { background: #f0fdf4; border-color: #86efac; color: #14532d; }
.sp-반려 { background: #fef2f2; border-color: #fca5a5; color: #7f1d1d; }

.det-tab-bar {
  background: #fff;
  border-bottom: 2px solid var(--border);
  display: flex;
  flex-shrink: 0;
  padding: 0 24px;
  overflow-x: auto;
}

.det-tab-bar::-webkit-scrollbar { display: none; }

.det-tab-i {
  border: 0;
  background: #fff;
  padding: 9px 14px;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--txt2);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  white-space: nowrap;
  transition: all .15s;
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: inherit;
}

.det-tab-i .material-symbols-outlined { font-size: 15px; }
.det-tab-i:hover { color: #0f172a; }
.det-tab-i.on { color: var(--blue); border-bottom-color: var(--blue); }
.det-tab-i .tc { background: var(--red); color: #fff; font-size: 10px; padding: 1px 5px; border-radius: 8px; font-weight: 700; }

.tab-body {
  flex: 1;
  overflow-y: auto;
  padding: 18px 24px;
}

.tab-pane { display: none; }
.tab-pane.on { display: block; }

.basic-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 260px;
  gap: 12px;
}

.fs {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 14px 16px;
  margin-bottom: 10px;
}

.fs-t {
  font-size: 11.5px;
  font-weight: 800;
  color: var(--navy);
  padding-bottom: 8px;
  margin-bottom: 10px;
  border-bottom: 1px solid var(--border);
  letter-spacing: .02em;
  text-transform: uppercase;
}

.fg { display: grid; gap: 8px 14px; }
.fg2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.fg3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.fg4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }

.fr, .fr-top {
  display: grid;
  grid-template-columns: 110px minmax(0, 1fr);
  gap: 6px;
  align-items: center;
}

.fr-top { align-items: flex-start; }

.flabel {
  font-size: 11px;
  color: var(--txt2);
  font-weight: 700;
}

.fval {
  font-size: 12.5px;
  color: #0f2537;
  font-weight: 600;
  min-width: 0;
  word-break: keep-all;
}

.fval.officer { color: var(--blue); font-weight: 800; }
.fval.amount { color: var(--red); font-weight: 900; font-size: 14px; }

.finput,
.fselect,
.ftarea {
  width: 100%;
  border: 1px solid #d1d9e6;
  border-radius: 4px;
  font-size: 12px;
  font-family: inherit;
  color: #0f172a;
  background: #fff;
  outline: none;
}

.finput,
.fselect {
  height: 32px;
  padding: 0 10px;
}

.ftarea {
  padding: 7px 10px;
  resize: vertical;
  min-height: 80px;
}

.finput:focus,
.fselect:focus,
.ftarea:focus { border-color: #3b5bdb; }

.ai-box {
  background: linear-gradient(135deg, #112340 0%, #254878 100%);
  border-radius: 6px;
  padding: 14px 16px;
  color: #fff;
  margin-bottom: 10px;
  position: relative;
  overflow: hidden;
}

.ai-box::after {
  content: 'AI';
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 44px;
  font-weight: 900;
  color: rgba(255,255,255,.06);
}

.ai-t {
  font-size: 10px;
  color: rgba(255,255,255,.55);
  margin-bottom: 5px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
}

.ai-num { font-size: 26px; font-weight: 900; margin-bottom: 3px; }
.ai-num span { font-size: 14px; opacity: .7; }
.ai-desc { font-size: 11.5px; color: rgba(255,255,255,.75); }
.ai-tags { display: flex; gap: 5px; margin-top: 7px; flex-wrap: wrap; }
.ai-tag { background: rgba(255,255,255,.12); padding: 2px 8px; border-radius: 10px; font-size: 11px; }
.ai-lo { font-size: 11px; font-weight: 800; color: #15803d; }
.ai-md { font-size: 11px; font-weight: 800; color: #c05621; }
.ai-hi { font-size: 11px; font-weight: 800; color: #b91c1c; }

.save-row { display: flex; justify-content: flex-end; margin-top: 6px; }

.timeline { display: flex; flex-direction: column; }
.tl-item { display: flex; gap: 12px; padding-bottom: 14px; position: relative; }
.tl-item:not(:last-child)::before { content: ''; position: absolute; left: 11px; top: 24px; bottom: 0; width: 1px; background: var(--border); }
.tl-item.disabled { opacity: .35; }
.tl-dot { width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; color: #fff; font-weight: 700; }
.tl-dot.blue { background: var(--blue); }
.tl-dot.green { background: var(--green); }
.tl-dot.orange { background: var(--orange); }
.tl-dot.red { background: var(--red); }
.tl-dot.gray { background: var(--txt3); }
.tl-dot.purple { background: var(--purple); }
.tl-dot.cyan { background: var(--cyan); }
.tl-body { flex: 1; padding-top: 2px; }
.tl-title { font-size: 12.5px; font-weight: 700; }
.tl-time { font-size: 11px; color: var(--txt3); margin-top: 1px; }
.tl-note { font-size: 12px; color: var(--txt2); margin-top: 4px; background: var(--bg); padding: 6px 10px; border-radius: 4px; border: 1px solid var(--border); }

.table-scroll { overflow-x: auto; }
.ptbl { width: 100%; border-collapse: collapse; font-size: 12px; background: #fff; }
.ptbl th { padding: 7px 10px; text-align: left; font-size: 10px; font-weight: 800; color: #4d6172; background: #ecf4ff; border: 1px solid #d9eafc; text-transform: uppercase; letter-spacing: .06em; }
.ptbl td { padding: 8px 10px; border: 1px solid #d9eafc; color: #203444; }
.ptbl tfoot td { background: #ecf4ff; font-weight: 700; }
.item-table { min-width: 760px; }
.total-tax { color: var(--red); font-size: 14px; font-weight: 900; }

.badge { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 3px; font-size: 11px; font-weight: 700; white-space: nowrap; }
.badge-wait { background: #fff7ed; color: #c2410c; border: 1px solid #fed7aa; }
.badge-recv { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
.badge-proc { background: #faf5ff; color: #6d28d9; border: 1px solid #ddd6fe; }
.badge-suppl { background: #fff7ed; color: #c05621; border: 1px solid #fbd38d; }
.badge-stmt { background: #e0f2fe; color: #0369a1; border: 1px solid #bae6fd; }
.badge-ok { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
.badge-ng { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }
.badge-hold { background: #f8fafc; color: #475569; border: 1px solid #cbd5e1; }

.file-list { display: grid; gap: 8px; }
.file-item { display: flex; align-items: center; gap: 10px; padding: 8px 12px; background: var(--bg); border: 1px solid var(--border); border-radius: 4px; }
.file-ico { font-size: 18px; color: var(--blue); }
.file-name { flex: 1; font-size: 12.5px; font-weight: 700; color: #0f2537; min-width: 0; }
.file-meta { font-size: 11px; color: var(--txt3); }

.file-info {
  flex: 1;
  min-width: 0;
}

.file-actions {
  margin-left: auto;
  display: flex;
  gap: 6px;
  align-items: center;
}

.work-type-bar {
  background: #f8fbff;
  border: 1px solid #d9eafc;
  border-radius: 4px;
  padding: 12px 16px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.work-type-label {
  font-size: 12px;
  font-weight: 900;
  color: #203444;
  white-space: nowrap;
}
.work-type-select {
  width: 170px;
  height: 34px;
  border: 2px solid #3b5bdb;
  border-radius: 4px;
  padding: 0 10px;
  background: #fff;
  color: #1d4ed8;
  font-size: 12px;
  font-weight: 800;
  outline: none;
  font-family: inherit;
  cursor: pointer;
}
.work-type-desc {
  font-size: 12px;
  color: #64748b;
  margin-left: 2px;
}
.work-form-card {
  background: #fff;
  border: 1px solid #d9eafc;
  border-radius: 4px;
  overflow: hidden;
  margin-top: 12px;
  margin-bottom: 10px;
}
.wfc-header {
  min-height: 44px;
  padding: 0 16px;
  background: #f8fbff;
  border-bottom: 1px solid #d9eafc;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.wfc-title {
  font-size: 13px;
  font-weight: 900;
  color: #203444;

}
.wfc-body {
  padding: 16px;
}
.wfc-footer {
  padding: 10px 16px;
  background: #f8fbff;
  border-top: 1px solid #d9eafc;
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}
.work-due-row { margin-top: 10px; }


/* 업무처리 탭 - 요청 폼 이미지 기준 보정 */
.wfc-body .fr,
.wfc-body .fr-top {
  display: grid;
  grid-template-columns: 100px minmax(0, 1fr);
  gap: 12px;
  align-items: start;
  margin-bottom: 12px;
}

.wfc-body .flabel {
  padding-top: 7px;
  font-size: 12px;
  font-weight: 800;
  color: #475569;
}

.wfc-body .ftarea {
  min-height: 82px;
  border: 1px solid #cbd8e8;
  border-radius: 4px;
  padding: 10px 12px;
  font-size: 12px;
  resize: vertical;
  background: #fff;
}

.wfc-body .finput {
  width: 160px;
  height: 34px;
  border: 1px solid #cbd8e8;
  border-radius: 4px;
  padding: 0 10px;
  font-size: 12px;
  background: #fff;
}

.wfc-body input[type="file"] {
  width: 100%;
  height: 34px;
  border: 1px solid #cbd8e8;
  border-radius: 4px;
  padding: 5px 8px;
  background: #fff;
  font-size: 12px;
}

.wfc-body .note,
.wfc-body .text-muted {
  margin-left: 112px;
  margin-top: -6px;
  font-size: 11px;
  color: #94a3b8;
  background: transparent;
  border: 0;
  padding: 0;
}

.wfc-footer .btn-secondary,
.wfc-footer .btn-primary,
.wfc-footer .btn-danger {
  height: 32px;
  padding: 0 13px;
  font-size: 12px;
  font-weight: 800;
  border-radius: 4px;
}

.wfc-footer .btn-primary {
  background: #ea580c;
  border-color: #ea580c;
  color: #fff;
}

.wfc-footer .btn-primary:hover {
  background: #c2410c;
}

/* 업무처리 탭 - 처리 요청 이력 표 */
.work-history-card,
.hist-card {
  background: #fff;
  border: 1px solid #d9eafc;
  border-radius: 4px;
  padding: 14px 16px;
  margin-bottom: 12px;
}

.work-history-title,
.hist-card-title {
  margin: 0 0 10px;
  font-size: 12px;
  font-weight: 900;
  color: #203444;
}

.work-history-table,
.request-history-table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
}

.work-history-table th,
.request-history-table th {
  background: #ecf4ff;
  border: 1px solid #d9eafc;
  padding: 9px 12px;
  font-size: 11px;
  font-weight: 900;
  color: #4d6172;
  text-align: left;
}

.work-history-table td,
.request-history-table td {
  border: 1px solid #d9eafc;
  padding: 10px 12px;
  font-size: 12px;
  color: #203444;
}

.work-badge-orange {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border: 1px solid #fdba74;
  background: #fff7ed;
  color: #ea580c;
  font-size: 11px;
  font-weight: 800;
  border-radius: 3px;
}

.work-badge-green {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border: 1px solid #86efac;
  background: #f0fdf4;
  color: #15803d;
  font-size: 11px;
  font-weight: 800;
  border-radius: 3px;
}

.tax-locked { display: flex; align-items: center; gap: 10px; padding: 18px; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; color: var(--txt2); font-size: 12.5px; }
.tax-locked .material-symbols-outlined { font-size: 20px; color: var(--txt3); }
.tax-locked {
  display: none;
}
.tax-content {
  display: block;
}
.note { font-size: 11.5px; color: var(--txt2); padding: 7px 12px; background: var(--bg); border: 1px solid var(--border); border-radius: 4px; margin-bottom: 10px; }
.tax-agent-info { margin-bottom: 12px; }
.tax-btn-row { display: flex; gap: 8px; align-items: center; }

.act-bar { background: #fff; border-top: 2px solid var(--border); padding: 12px 24px; display: flex; align-items: center; gap: 8px; flex-shrink: 0; flex-wrap: wrap; }
.act-bar-main { display: flex; align-items: center; gap: 8px; flex: 1; flex-wrap: wrap; }
.act-bar-side { display: flex; align-items: center; gap: 6px; }
.act-sep { width: 1px; height: 24px; background: var(--border); margin: 0 4px; }

.btn-primary,
.btn-secondary,
.btn-danger,
.btn-approve {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  height: 32px;
  padding: 0 14px;
  border-radius: 4px;
  border: 1px solid transparent;
  font-size: 12px;
  font-weight: 700;
  font-family: inherit;
  cursor: pointer;
  white-space: nowrap;
  text-decoration: none;
}

.btn-primary { background: var(--navy); border-color: var(--navy); color: #fff; }
.btn-primary:hover { background: #152540; }
.btn-secondary { background: #fff; border-color: #cbd8e8; color: #334155; }
.btn-secondary:hover { background: #f1f5f9; }
.btn-danger { height: 34px; width:70px; background: #fff; color: #991b1b; border-color: #fca5a5; }
.btn-danger:hover { background: #fee2e2; }
.btn-approve { height: 34px; width:70px; background: #1e3054;  color: #fff; font-size: 13px; }
.btn-approve:hover { background: #1e3054; }
.btn-sm { height: 28px; padding: 0 10px; font-size: 11px; }
.btn-sm .material-symbols-outlined,
.btn-secondary .material-symbols-outlined,
.btn-primary .material-symbols-outlined { font-size: 14px; }

.mov { display: none; position: fixed; inset: 0; background: rgba(15,23,42,.5); z-index: 2000; align-items: center; justify-content: center; }
.mov.on { display: flex; }
.mbox { background: #fff; border-radius: 8px; max-width: 95vw; max-height: 90vh; overflow-y: auto; }
.approve-modal-box { width: 660px; }
.sms-modal-box { width: 480px; }
.mhdr { padding: 14px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; background: #fff; z-index: 1; }
.mtitle { font-size: 15px; font-weight: 800; display: flex; align-items: center; gap: 4px; }
.mclose { cursor: pointer; font-size: 18px; color: var(--txt2); background: none; border: none; line-height: 1; }
.mbody { padding: 18px 20px; }
.mfoot { padding: 12px 20px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 8px; position: sticky; bottom: 0; background: #fff; }

.approve-flow { display: flex; flex-direction: column; gap: 0; margin: 12px 0; }
.af-item { display: flex; align-items: flex-start; gap: 12px; padding: 10px 12px; border-radius: 6px; background: #f0fdf4; margin-bottom: 2px; border: 1px solid #bbf7d0; }
.af-num { width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; color: #fff; }
.af-num.g { background: var(--green); }
.af-num.b { background: var(--blue); }
.af-body .af-title { font-size: 12.5px; font-weight: 700; }
.af-body .af-desc { font-size: 11.5px; color: var(--txt2); margin-top: 2px; }
.af-arrow { text-align: center; color: var(--txt3); font-size: 18px; margin: 2px 0; }
.sms-opt { display: flex; align-items: flex-start; gap: 10px; padding: 8px 12px; background: #fff; border: 1px solid var(--border); border-radius: 4px; cursor: pointer; margin-bottom: 6px; }
.sms-opt:hover { border-color: #3b5bdb; }
.sms-opt-t { font-size: 12.5px; font-weight: 700; }
.sms-opt-p { font-size: 11px; color: var(--txt2); margin-top: 2px; }

.toast { position: fixed; bottom: 80px; right: 24px; background: #0f172a; color: #fff; padding: 10px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; z-index: 3000; transform: translateY(20px); opacity: 0; transition: all .3s; max-width: 360px; }
.toast.on { transform: translateY(0); opacity: 1; }
.toast.g { background: var(--green); }
.toast.b { background: var(--blue); }
.toast.o { background: var(--orange); }
.toast.r { background: var(--red); }

.empty-box,
.empty-cell { padding: 18px; text-align: center; color: var(--txt2); font-size: 12px; background: var(--bg); }

@media (max-width: 1100px) {
  .det-hdr-inner,
  .basic-layout { grid-template-columns: 1fr; flex-direction: column; }
  .status-panel { width: 100%; }
  .fg2, .fg3, .fg4 { grid-template-columns: 1fr; }
  .work-type-bar { align-items: flex-start; flex-direction: column; }
}

/* 업무처리 요청이력/버튼 정리 */
.work-file-row {
  margin-top: 10px;
}

.work-file-field {
  width: 100%;
}

.work-file-input {
  width: 100%;
  max-width: none;
}

.work-file-help {
  margin: 5px 0 0;
  font-size: 11px;
  color: var(--txt3);
}

.work-file-help.required {
  color: #dc2626;
  font-weight: 800;
}

.wfc-footer .work-action-btn,
.work-action-btn {
  min-width: 112px;
  height: 34px;
  padding: 0 16px;
  font-size: 12px;
  font-weight: 800;
  border-radius: 4px;
}

.wfc-footer .btn-primary.work-action-btn {
  background: #1e3054;
  border-color: #1e3054;
  color: #fff;
}

.wfc-footer .btn-primary.work-action-btn:hover {
  background: #32497a;
  border-color: #314f8c;
}

.work-history-table th,
.work-history-table td {
  vertical-align: middle;
}

.work-history-table th:nth-child(1),
.work-history-table td:nth-child(1) { width: 120px; }
.work-history-table th:nth-child(2),
.work-history-table td:nth-child(2) { width: 180px; }
.work-history-table th:nth-child(4),
.work-history-table td:nth-child(4) { width: 130px; }
.work-history-table th:nth-child(5),
.work-history-table td:nth-child(5) { width: 110px; }
.work-history-table th:nth-child(6),
.work-history-table td:nth-child(6) { width: 90px; text-align: center; }

.hidden { display: none !important; }

/* 업무처리 유형별 첨부파일 표시 제어 */
.work-file-row.hidden {
  display: none !important;
}

.work-file-help.required {
  color: #dc2626;
  font-weight: 800;
}

.work-action-btn {
  min-width: 118px;
  height: 32px;
  justify-content: center;
}

.readonly-notice {
  font-size: 13px;
  font-weight: 700;
  color: #64748b;
}

/* =============================================================
   공통 — 처리상태 뱃지
   ============================================================= */
.line-status-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: 3px;
  font-size: 11.5px;
  font-weight: 700;
  border: 1px solid transparent;
  white-space: nowrap;
}
.ls-ITEM_REVIEW   { background: #faf5ff; color: #5b21b6; border-color: #c4b5fd; }
.ls-ITEM_SUPP_REQ { background: #fff7ed; color: #c2410c; border-color: #fed7aa; }
.ls-ITEM_SUPP_SUB { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
.ls-ITEM_ACPT     { background: #f0fdf4; color: #15803d; border-color: #bbf7d0; }
.ls-ITEM_REJ      { background: #fef2f2; color: #b91c1c; border-color: #fecaca; }

/* =============================================================
   처리 버튼 / 완료 텍스트
   ============================================================= */
.btn-action-open {
  display: inline-flex;
  align-items: center;
  height: 28px;
  padding: 0 12px;
  border-radius: 4px;
  border: 1px solid #cbd5e1;
  background: #fff;
  color: #334155;
  font-size: 11.5px;
  font-weight: 700;
  font-family: inherit;
  cursor: pointer;
  white-space: nowrap;
  transition: all .15s;
}
.btn-action-open:hover { background: #1b2d44; border-color: #1b2d44; color: #fff; }
.action-done { font-size: 12px; color: #94a3b8; font-weight: 600; }

/* =============================================================
   항번 카드
   ============================================================= */
.item-card {
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
}

/* 카드 헤더 */
.ic-hdr {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #f8fafc;
  border-bottom: 1px solid #e2e8f0;
  gap: 12px;
}
.ic-hdr-left  { display: flex; align-items: center; gap: 10px; min-width: 0; }
.ic-hdr-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

.ic-no {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #1b2d44;
  color: #fff;
  font-size: 12px;
  font-weight: 800;
  flex-shrink: 0;
}
.ic-hs   { font-size: 12px; color: #64748b; font-weight: 600; white-space: nowrap; }
.ic-name { font-size: 14px; color: #0f2537; font-weight: 800; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 카드 바디 — 좌우 2열 */
.ic-body {
  display: grid;
  grid-template-columns: 1fr 2px 1fr;
  gap: 0;
  padding: 16px;
}
.ic-divider {
  background: #e2e8f0;
  margin: 0 16px;
  border-radius: 2px;
}
.ic-col { display: flex; flex-direction: column; gap: 0; }

.ic-section-title {
  font-size: 10.5px;
  font-weight: 800;
  color: #94a3b8;
  letter-spacing: .06em;
  text-transform: uppercase;
  margin-bottom: 10px;
}
.ic-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 8px;
  padding: 5px 0;
  border-bottom: 1px solid #f1f5f9;
  font-size: 12.5px;
}
.ic-row:last-child { border-bottom: none; }
.ic-row > span  { color: #64748b; flex-shrink: 0; }
.ic-row > strong { color: #0f2537; font-weight: 700; text-align: right; word-break: keep-all; }

.ic-rate   { color: #1e3054 !important; }
.ic-amount { color: #1e3054 !important; }
.ic-remark { color: #64748b !important; font-weight: 400 !important; }

/* 카드 푸터 — 세액 */
.ic-footer {
  display: flex;
  align-items: stretch;
  border-top: 1px solid #e2e8f0;
  background: #f8fafc;
}
.ic-tax-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10px 8px;
  gap: 4px;
  text-align: center;
}
.ic-tax-item > span   { font-size: 10px; color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
.ic-tax-item > strong { font-size: 13px; color: #334155; font-weight: 700; }
.ic-tax-sep {
  width: 1px;
  background: #e2e8f0;
  flex-shrink: 0;
  margin: 8px 0;
}
.ic-tax-total {
  background: #eff6ff;
}
.ic-tax-total > span   { color: #1d4ed8; }
.ic-tax-total > strong { color: #1e3054; font-size: 14px; }

/* =============================================================
   카드 헤더 — 처리 버튼 3개
   ============================================================= */
.btn-item-supp,
.btn-item-acpt,
.btn-item-rej {
  display: inline-flex;
  align-items: center;
  height: 28px;
  padding: 0 11px;
  border-radius: 4px;
  font-size: 11.5px;
  font-weight: 700;
  font-family: inherit;
  cursor: pointer;
  white-space: nowrap;
  border: 1px solid transparent;
  transition: all .15s;
}
.btn-item-supp { background: #fff7ed; color: #c2410c; border-color: #fed7aa; }
.btn-item-supp:hover { background: #ffedd5; border-color: #fb923c; }

.btn-item-acpt { background: #f0fdf4; color: #15803d; border-color: #86efac; }
.btn-item-acpt:hover { background: #dcfce7; border-color: #4ade80; }

.btn-item-rej  { background: #fef2f2; color: #b91c1c; border-color: #fecaca; }
.btn-item-rej:hover  { background: #fee2e2; border-color: #f87171; }

.action-done { font-size: 12px; color: #94a3b8; font-weight: 600; }

@media (max-width: 768px) {
  .ic-body { grid-template-columns: 1fr; }
  .ic-divider { width: 100%; height: 1px; margin: 12px 0; }
  .ic-footer { flex-wrap: wrap; }
  .ic-tax-item { min-width: 40%; }
  .ic-hdr { flex-wrap: wrap; gap: 8px; }
}