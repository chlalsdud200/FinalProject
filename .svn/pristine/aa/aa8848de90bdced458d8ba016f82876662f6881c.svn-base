<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.systemadmin.stats.mapper.IAdminStatsMapper">

    <!-- ============================================================
         A. 상단 KPI 카드
         ============================================================ -->
    <select id="selectSummary"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSummaryVO">
        SELECT
            imp.import_cnt                                        AS importCnt
          , exp.export_cnt                                        AS exportCnt
          , imp.import_cnt + exp.export_cnt                       AS totalDeclarationCnt
          , imp.accepted_cnt                                      AS acceptedCnt
          , NVL(ROUND(imp.accepted_cnt / NULLIF(imp.import_cnt, 0) * 100, 1), 0) AS acceptRate
          , NVL(imp.avg_process_days, 0)                          AS avgProcessDays
          , mem.active_member_cnt                                 AS activeMemberCnt
          , today.today_import_cnt                                AS todayImportCnt
        FROM
            (
                SELECT
                    COUNT(*)                                                   AS import_cnt
                  , COUNT(ir.ir_acpt_dt)                                       AS accepted_cnt
                  , ROUND(AVG(ir.ir_acpt_dt - ir.ir_regist_dt), 1)            AS avg_process_days
                FROM imp_rqst ir
                WHERE ir.ir_use_yn = 'Y'
                <if test="startDate != null">
                    AND ir.ir_regist_dt &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
                </if>
                <if test="endDate != null">
                    AND ir.ir_regist_dt &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
                </if>
            ) imp
          , (
                SELECT COUNT(*) AS export_cnt
                FROM exp_rqst er
                WHERE NVL(er.er_use_yn, 'Y') = 'Y'
                <if test="startDate != null">
                    AND er.er_rqst_dt &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
                </if>
                <if test="endDate != null">
                    AND er.er_rqst_dt &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
                </if>
            ) exp
          , (
                SELECT COUNT(*) AS active_member_cnt
                FROM vw_actor_login
                WHERE use_yn = 'Y'
            ) mem
          , (
                SELECT COUNT(*) AS today_import_cnt
                FROM imp_rqst ir
                WHERE ir.ir_use_yn = 'Y'
                  AND TRUNC(ir.ir_regist_dt) = TRUNC(SYSDATE)
            ) today
    </select>

    <!-- A. 수입신고 상태별 분포 -->
    <select id="selectDeclarationStatus"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="java.util.LinkedHashMap">
        SELECT
            ir.ir_status_cd AS "code"
          , NVL(cc.cc_nm,
                CASE ir.ir_status_cd
                    WHEN 'REQ'           THEN '신고요청'
                    WHEN 'CSTM_REQ'      THEN '통관심사요청'
                    WHEN 'CSTM_INPRG'    THEN '세관심사중'
                    WHEN 'CSTM_SUPP'     THEN '보완요청'
                    WHEN 'CSTM_SUPP_SUB' THEN '보완제출'
                    WHEN 'CSTM_ACPT'     THEN '수리완료'
                    WHEN 'CSTM_ACCEPT'   THEN '수리완료'
                    WHEN 'ACCEPTED'      THEN '수리완료'
                    WHEN 'CSTM_REJ'      THEN '반려'
                    WHEN 'CSTM_REJECT'   THEN '반려'
                    WHEN 'CSTM_TAX_REQ'  THEN '관부가세 청구'
                    WHEN 'CSTM_TAX_PAID' THEN '관부가세 납부'
                    WHEN 'CSTM_DONE'     THEN '통관완료'
                    WHEN 'CSTM_CANCEL'   THEN '취소'
                    ELSE ir.ir_status_cd
                END
            ) AS "label"
          , COUNT(*) AS "cnt"
        FROM imp_rqst ir
        LEFT JOIN com_code cc
               ON cc.cc_ccg_id = 'CSTM_STATUS'
              AND cc.cc_cd = ir.ir_status_cd
              AND cc.cc_use_yn = 'Y'
        WHERE ir.ir_use_yn = 'Y'
        <if test="startDate != null">
            AND ir.ir_regist_dt &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
        </if>
        <if test="endDate != null">
            AND ir.ir_regist_dt &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
        </if>
        GROUP BY ir.ir_status_cd, cc.cc_nm
        ORDER BY COUNT(*) DESC
    </select>

    <!-- ============================================================
         B. 물품·무역 통계
         ============================================================ -->

    <!-- B. 최근 12개월(또는 지정 기간) 신고 건수/금액 추이 -->
    <select id="selectMonthlyTrend"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="java.util.LinkedHashMap">
        SELECT
            TO_CHAR(ir.ir_regist_dt, 'YYYY-MM')   AS "ym"
          , COUNT(*)                              AS "cnt"
          , NVL(SUM(ir.ir_invc_amt), 0)           AS "amt"
        FROM imp_rqst ir
        WHERE ir.ir_use_yn = 'Y'
        <choose>
            <when test="startDate != null or endDate != null">
                <if test="startDate != null">
                    AND ir.ir_regist_dt &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
                </if>
                <if test="endDate != null">
                    AND ir.ir_regist_dt &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
                </if>
            </when>
            <otherwise>
                AND ir.ir_regist_dt &gt;= ADD_MONTHS(TRUNC(SYSDATE, 'MM'), -11)
            </otherwise>
        </choose>
        GROUP BY TO_CHAR(ir.ir_regist_dt, 'YYYY-MM')
        ORDER BY "ym"
    </select>

    <!-- B. 품목(HS코드)별 수입 TOP -->
    <select id="selectTopItems"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="java.util.LinkedHashMap">
        SELECT *
        FROM (
            SELECT
                di.idi_hs_cd                AS "hsCd"
              , MAX(di.idi_dclr_gdsnm)      AS "goodsNm"
              , COUNT(*)                    AS "cnt"
              , NVL(SUM(di.idi_qty), 0)     AS "qty"
            FROM imp_dclr_item di
            WHERE di.idi_hs_cd IS NOT NULL
            <if test="startDate != null">
                AND di.idi_regist_dt &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
            </if>
            <if test="endDate != null">
                AND di.idi_regist_dt &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
            </if>
            GROUP BY di.idi_hs_cd
            ORDER BY COUNT(*) DESC, "qty" DESC
        )
        WHERE ROWNUM &lt;= #{topN}
    </select>

    <!-- B. 원산지(국가)별 수입 분포 -->
    <select id="selectOriginDistribution"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="java.util.LinkedHashMap">
        SELECT *
        FROM (
            SELECT
                di.idi_orgn_cntry_cd                          AS "countryCd"
              , NVL(c.country_nm_kr, di.idi_orgn_cntry_cd)    AS "country"
              , COUNT(*)                                      AS "cnt"
            FROM imp_dclr_item di
            LEFT JOIN country c
              ON c.country_cd = di.idi_orgn_cntry_cd
            WHERE di.idi_orgn_cntry_cd IS NOT NULL
            <if test="startDate != null">
                AND di.idi_regist_dt &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
            </if>
            <if test="endDate != null">
                AND di.idi_regist_dt &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
            </if>
            GROUP BY di.idi_orgn_cntry_cd, c.country_nm_kr
            ORDER BY COUNT(*) DESC
        )
        WHERE ROWNUM &lt;= #{topN}
    </select>

    <!-- ============================================================
         C. 액터별 이용 순위
         ============================================================ -->

    <!-- C. 관세사별 처리 건수 TOP -->
    <select id="selectTopBrokers"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="java.util.LinkedHashMap">
        SELECT *
        FROM (
            SELECT
                NVL(b.broker_nm, ir.ir_broker_id)   AS "brokerNm"
              , COUNT(*)                            AS "cnt"
            FROM imp_rqst ir
            JOIN broker b
              ON b.broker_id = ir.ir_broker_id
            WHERE ir.ir_use_yn = 'Y'
              AND ir.ir_broker_id IS NOT NULL
            <if test="startDate != null">
                AND ir.ir_regist_dt &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
            </if>
            <if test="endDate != null">
                AND ir.ir_regist_dt &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
            </if>
            GROUP BY NVL(b.broker_nm, ir.ir_broker_id)
            ORDER BY COUNT(*) DESC
        )
        WHERE ROWNUM &lt;= #{topN}
    </select>

    <!-- C. 운송담당자별 처리 건수 TOP -->
    <select id="selectTopTransportManagers"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="java.util.LinkedHashMap">
        SELECT *
        FROM (
            SELECT
                NVL(tm.tm_name, tm.tm_id)   AS "tmNm"
              , COUNT(*)                    AS "cnt"
            FROM tran_rcp t
            JOIN transport_manager tm
              ON tm.tm_no = t.trc_tm_no
            WHERE t.trc_tm_no IS NOT NULL
            <if test="startDate != null">
                AND t.trc_rqst_dt &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
            </if>
            <if test="endDate != null">
                AND t.trc_rqst_dt &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
            </if>
            GROUP BY NVL(tm.tm_name, tm.tm_id)
            ORDER BY COUNT(*) DESC
        )
        WHERE ROWNUM &lt;= #{topN}
    </select>

    <!-- ============================================================
         D. 창고 현황
         ============================================================ -->

    <!-- D. 창고 구역별 적재 현황 -->
    <select id="selectWarehouseUsage"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="java.util.LinkedHashMap">
        SELECT
            NVL(wh.wh_nm, '-')          AS "whNm"
          , wz.wz_nm                    AS "wzNm"
          , NVL(wz.wz_ttl_capa, 0)      AS "ttl"
          , NVL(wz.wz_use_capa, 0)      AS "used"
          , NVL(
                wz.wz_use_rt,
                CASE
                    WHEN NVL(wz.wz_ttl_capa, 0) &gt; 0
                    THEN ROUND(NVL(wz.wz_use_capa, 0) / wz.wz_ttl_capa * 100, 1)
                    ELSE 0
                END
            )                           AS "useRt"
        FROM warehouse_zone wz
        LEFT JOIN warehouse wh
          ON wh.wh_no = wz.wz_wh_no
        WHERE NVL(wz.wz_use_yn, 'Y') = 'Y'
        ORDER BY "useRt" DESC, wz.wz_nm
    </select>

    <!-- D. 창고 입출고 흐름 요약 -->
    <select id="selectWarehouseFlow"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="java.util.LinkedHashMap">
        SELECT "sortOrder", "label", "cnt"
        FROM (
            SELECT 1 AS "sortOrder", '입고대기' AS "label",
                   (SELECT COUNT(*) FROM wh_in_rpt WHERE WIR_STATUS_CD = 'WAIT') AS "cnt"
            FROM DUAL
            UNION ALL
            SELECT 2, '입고완료',
                   (SELECT COUNT(*) FROM wh_in_rpt WHERE WIR_STATUS_CD = 'IN_DONE')
            FROM DUAL
            UNION ALL
            SELECT 3, '보관중',
                   (SELECT COUNT(*)
                      FROM warehouse_item wi
                      JOIN warehouse_item_location wil
                        ON wi.wil_cl_no = wil.wil_no
                     WHERE wi.wi_use_yn = 'Y'
                       AND wil.wil_out_dt IS NULL)
            FROM DUAL
            UNION ALL
            SELECT 4, '반출대기',
                   (SELECT COUNT(*) FROM cargo_release_req WHERE CRR_STATUS_CD = 'REL_WAIT')
            FROM DUAL
            UNION ALL
            SELECT 5, '반출완료',
                   (SELECT COUNT(*) FROM cargo_release_req WHERE CRR_STATUS_CD = 'REL_DONE')
            FROM DUAL
        )
        ORDER BY "sortOrder"
    </select>

    <!-- ============================================================
         A/E. 회원 분포
         ============================================================ -->
    <select id="selectMemberDistribution"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="java.util.LinkedHashMap">
        SELECT
            actor_type_cd                                       AS "code"
          , MAX(role_nm)                                        AS "label"
          , COUNT(*)                                            AS "totalCnt"
          , SUM(CASE WHEN use_yn = 'Y' THEN 1 ELSE 0 END)       AS "activeCnt"
        FROM vw_actor_login
        GROUP BY actor_type_cd
        ORDER BY COUNT(*) DESC
    </select>

    <!-- ============================================================
         E. 검역 / 알림 통계
         ============================================================ -->

    <!-- E. 검역 판정 결과 분포 -->
    <select id="selectQuarantineStats"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="java.util.LinkedHashMap">
        SELECT
            NVL(res.iir_result_cd, '미판정')   AS "result"
          , COUNT(*)                          AS "cnt"
        FROM imp_ins_result res
        GROUP BY NVL(res.iir_result_cd, '미판정')
        ORDER BY COUNT(*) DESC
    </select>

    <!-- E. 알림 이벤트별 발송/읽음 TOP -->
    <select id="selectNotificationStats"
            parameterType="kr.or.tacs.vo.systemadmin.stats.AdminStatsSearchVO"
            resultType="java.util.LinkedHashMap">
        SELECT *
        FROM (
            SELECT
                n.noti_event_cd                                       AS "eventCd"
              , NVL(p.np_biz_nm, n.noti_event_cd)                     AS "label"
              , COUNT(*)                                              AS "cnt"
              , SUM(CASE WHEN n.noti_read_yn = 'Y' THEN 1 ELSE 0 END) AS "readCnt"
            FROM notification n
            LEFT JOIN noti_policy p
              ON p.np_event_cd = n.noti_event_cd
            WHERE 1 = 1
            <if test="startDate != null">
                AND n.noti_send_dt &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
            </if>
            <if test="endDate != null">
                AND n.noti_send_dt &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
            </if>
            GROUP BY n.noti_event_cd, p.np_biz_nm
            ORDER BY COUNT(*) DESC
        )
        WHERE ROWNUM &lt;= #{topN}
    </select>

</mapper>
