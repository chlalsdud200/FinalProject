<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="ko" class="light">
<head>
<%@ include file="/WEB-INF/views/transport/common/head.jsp" %>
<link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/transport/pages/community.css">
</head>
<body class="bg-background text-on-surface">
<%@ include file="/WEB-INF/views/transport/common/sidebar.jsp" %>
<%@ include file="/WEB-INF/views/transport/common/topbar.jsp" %>
<%@ include file="/WEB-INF/views/transport/common/main-content.jsp" %>
<%@ include file="/WEB-INF/views/transport/common/footer.jsp" %>
<%@ include file="/WEB-INF/views/transport/common/modals.jsp" %>

<!-- Hidden template for Resource Archive to be used in community.js -->
<div id="transport-resource-archive-template" style="display:none">
  <div class="section-card overflow-hidden bg-white">
    <div class="p-6">
      <%@ include file="/WEB-INF/views/common/community/resourceArchive.jsp" %>
    </div>
  </div>
</div>

<!-- Hidden template for FAQ to be used in community.js -->
<div id="transport-faq-template" style="display:none">
  <div class="section-card overflow-hidden bg-white">
    <div class="p-6">
      <%@ include file="/WEB-INF/views/common/community/faq.jsp" %>
    </div>
  </div>
</div>

<script>
  window.contextPath = '${pageContext.request.contextPath}';
  (function(){
    function legacyPageToTab(page) {
      if (page === 'TACS-CM-003') return 'data';
      if (page === 'TACS-CM-004' || page === 'TACS-CM-002') return 'cs';
      if (page === 'TACS-CM-001') return 'notice';
      return '';
    }
    function itemByTab(tab) {
      if (tab === 'data') return 'TACS-CM-003';
      if (tab === 'cs') return 'TACS-CM-004';
      return 'TACS-CM-001';
    }

    var modelTab = '${communityTab}';
    var modelItem = '${transportInitialItem}';
    var tab = modelTab || 'notice';
    var item = modelItem || 'TACS-CM-001';

    try {
      var params = new URLSearchParams(window.location.search);
      var urlTab = params.get('tab');
      var legacyTab = legacyPageToTab(params.get('page'));
      if (legacyTab) {
        params.delete('page');
        params.delete('tab');
        var ordered = new URLSearchParams();
        ordered.set('tab', legacyTab);
        params.forEach(function(value, key){ ordered.append(key, value); });
        window.history.replaceState(null, '', window.location.pathname + '?' + ordered.toString() + window.location.hash);
        tab = legacyTab;
        item = itemByTab(legacyTab);
      } else if (urlTab) {
        tab = (urlTab === 'data' || urlTab === 'cs') ? urlTab : 'notice';
        item = itemByTab(tab);
      }
    } catch(e) {}

    window.TRANSPORT_INITIAL_COMMUNITY_TAB = tab;
    window.TRANSPORT_INITIAL_VIEW = {
      group: 'community',
      item: item
    };
  })();
</script>
<script src="${pageContext.request.contextPath}/resources/js/transport/common.js?v=20260529-dashboard-async-route6"></script>
<script src="${pageContext.request.contextPath}/resources/js/transport/pages/community.js?v=20260531-community-tab-url-fix2"></script>
</body>
</html>
