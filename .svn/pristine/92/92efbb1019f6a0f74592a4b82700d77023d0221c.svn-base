package kr.or.tacs.fieldofficer.mypage.service;

import java.util.List;

import kr.or.tacs.vo.OfficerVO;

public interface IMypageService {

	// 마이페이지 공무원 정보 조회
    public OfficerVO selectOfficer(String officerId);

    // 마이페이지 개인정보 수정
    public int updateOfficer(OfficerVO officerVO);

    // 알림 설정 저장
    public void updateAlarmSettings(String officerId, String[] alarmRuleTyCd, String webAlarmYn);

    // 저장된 알림유형코드 목록 조회
    public List<String> selectAlarmRuleTyCdList(String officerId);

    // 시스템 알림 사용 여부 조회
    public String selectWebAlarmYn(String officerId);
    
}
