<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.systemadmin.member.mapper.IAdminMemberMapper">

    <resultMap id="adminMemberListMap"
               type="kr.or.tacs.vo.systemadmin.member.AdminMemberListVO">
        <result property="loginId" column="LOGIN_ID"/>
        <result property="loginNm" column="LOGIN_NM"/>
        <result property="roleCd" column="ROLE_CD"/>
        <result property="roleNm" column="ROLE_NM"/>
        <result property="actorTypeCd" column="ACTOR_TYPE_CD"/>
        <result property="actorTableNm" column="ACTOR_TABLE_NM"/>
        <result property="orgNm" column="ORG_NM"/>
        <result property="email" column="EMAIL"/>
        <result property="telno" column="TELNO"/>
        <result property="useYn" column="USE_YN"/>
        <result property="officerTyCd" column="OFFICER_TY_CD"/>
        <result property="officerTyNm" column="OFFICER_TY_NM"/>
    </resultMap>

    <!-- 회원관리 검색 조건 공통 WHERE -->
    <sql id="adminMemberSearchWhere">
        <if test="searchVO.actorTypeCd != null and searchVO.actorTypeCd != ''">
            AND val.actor_type_cd = #{searchVO.actorTypeCd}
        </if>

        <if test="searchVO.useYn != null and searchVO.useYn != ''">
            AND val.use_yn = #{searchVO.useYn}
        </if>

        <if test="searchVO.keyword != null and searchVO.keyword != ''">
            AND (
                UPPER(val.login_id) LIKE '%' || UPPER(#{searchVO.keyword}) || '%'
                OR UPPER(val.login_nm) LIKE '%' || UPPER(#{searchVO.keyword}) || '%'
                OR UPPER(val.org_nm) LIKE '%' || UPPER(#{searchVO.keyword}) || '%'
            )
        </if>

        <if test="searchVO.officerTyCd != null and searchVO.officerTyCd != ''">
            AND o.officer_ty_cd = #{searchVO.officerTyCd}
        </if>
        
        <if test="searchVO.startDate != null and searchVO.startDate != '' and searchVO.endDate != null and searchVO.endDate != ''">
            AND val.actor_type_cd != 'TRANSPORT_MANAGER'
            AND (
                (val.actor_type_cd = 'OWNER' AND EXISTS (SELECT 1 FROM owner WHERE owr_id = val.login_id AND owr_regist_dt BETWEEN TO_DATE(#{searchVO.startDate}, 'YYYY-MM-DD') AND TO_DATE(#{searchVO.endDate} || ' 23:59:59', 'YYYY-MM-DD HH24:MI:SS')))
                OR (val.actor_type_cd = 'BROKER' AND EXISTS (SELECT 1 FROM broker WHERE broker_id = val.login_id AND broker_regist_dt BETWEEN TO_DATE(#{searchVO.startDate}, 'YYYY-MM-DD') AND TO_DATE(#{searchVO.endDate} || ' 23:59:59', 'YYYY-MM-DD HH24:MI:SS')))
                OR (val.actor_type_cd = 'OFFICER' AND EXISTS (SELECT 1 FROM officer WHERE officer_id = val.login_id AND officer_regist_dt BETWEEN TO_DATE(#{searchVO.startDate}, 'YYYY-MM-DD') AND TO_DATE(#{searchVO.endDate} || ' 23:59:59', 'YYYY-MM-DD HH24:MI:SS')))
                OR (val.actor_type_cd = 'WAREHOUSE_MANAGER' AND EXISTS (SELECT 1 FROM warehouse_manager WHERE wm_id = val.login_id AND wm_regist_dt BETWEEN TO_DATE(#{searchVO.startDate}, 'YYYY-MM-DD') AND TO_DATE(#{searchVO.endDate} || ' 23:59:59', 'YYYY-MM-DD HH24:MI:SS')))
                OR (val.actor_type_cd = 'SYSTEM_ADMIN' AND EXISTS (SELECT 1 FROM system_admin WHERE sa_id = val.login_id AND sa_regist_dt BETWEEN TO_DATE(#{searchVO.startDate}, 'YYYY-MM-DD') AND TO_DATE(#{searchVO.endDate} || ' 23:59:59', 'YYYY-MM-DD HH24:MI:SS')))
            )
        </if>
    </sql>

    <!-- 관리자 회원 전체 건수 조회 -->
    <select id="selectMemberTotalRecord"
            resultType="int">
        SELECT
            COUNT(*)
        FROM vw_actor_login val
        LEFT JOIN officer o ON val.login_id = o.officer_id AND val.actor_type_cd = 'OFFICER'
        WHERE 1 = 1
        <include refid="adminMemberSearchWhere"/>
    </select>

    <!-- 로그인 ID 중복 체크 (전체 액터 대상) -->
    <select id="countLoginId"
            resultType="int">
        SELECT COUNT(*)
        FROM vw_actor_login
        WHERE login_id = #{loginId}
    </select>

    <!-- 관리자 회원 통계 조회 (액터유형별 건수) -->
    <select id="selectMemberStatistics"
            resultType="java.util.LinkedHashMap">
        SELECT
            actor_type_cd AS "actorTypeCd"
          , role_nm AS "roleNm"
          , COUNT(*) AS "count"
        FROM vw_actor_login
        GROUP BY actor_type_cd, role_nm
        ORDER BY actor_type_cd
    </select>

    <!-- 관세사 등록 -->
    <insert id="insertBrokerMember">
        INSERT INTO broker (
            broker_id
          , broker_password
          , broker_ty_cd
          , broker_nm
          , broker_office_nm
          , broker_reg_no
          , broker_bizrno
          , broker_spclty_cd
          , broker_email
          , broker_telno
          , broker_zip
          , broker_adres
          , broker_detail_adres
          , broker_use_yn
          , broker_regist_dt
          , broker_updt_dt
        ) VALUES (
            #{params.loginId}
          , #{params.encodedPassword}
          , #{params.brokerTyCd}
          , #{params.brokerNm}
          , #{params.brokerOfficeNm}
          , #{params.brokerRegNo}
          , #{params.brokerBizrno}
          , #{params.brokerSpcltyCd}
          , #{params.brokerEmail}
          , #{params.brokerTelno}
          , #{params.brokerZip}
          , #{params.brokerAdres}
          , #{params.brokerDetailAdres}
          , #{params.useYn}
          , SYSDATE
          , SYSDATE
        )
    </insert>

    <!-- 공무원 등록 -->
    <insert id="insertOfficerMember">
        INSERT INTO officer (
            officer_id
          , officer_password
          , officer_ty_cd
          , officer_name
          , officer_nm
          , officer_inst_cd
          , officer_dept_cd
          , officer_clsf_cd
          , officer_field_cd
          , officer_email
          , officer_telno
          , officer_zip
          , officer_adres
          , officer_detail_adres
          , officer_use_yn
          , officer_regist_dt
          , officer_updt_dt
        ) VALUES (
            #{params.loginId}
          , #{params.encodedPassword}
          , #{params.officerTyCd}
          , #{params.officerName}
          , #{params.officerNm}
          , #{params.officerInstCd}
          , #{params.officerDeptCd}
          , #{params.officerClsfCd}
          , #{params.officerFieldCd}
          , #{params.officerEmail}
          , #{params.officerTelno}
          , #{params.officerZip}
          , #{params.officerAdres}
          , #{params.officerDetailAdres}
          , #{params.useYn}
          , SYSDATE
          , SYSDATE
        )
    </insert>

    <!-- 운송담당자 등록 -->
    <insert id="insertTransportManagerMember">
        INSERT INTO transport_manager (
            tm_no
          , tm_id
          , tm_password
          , tm_cp_nm
          , tm_cp_telno
          , tm_mn_cd
          , tm_name
          , tm_use_yn
        ) VALUES (
            (SELECT NVL(MAX(tm_no), 0) + 1 FROM transport_manager)
          , #{params.loginId}
          , #{params.encodedPassword}
          , #{params.tmCpNm}
          , #{params.tmCpTelno}
          , #{params.tmMnCd}
          , #{params.tmName}
          , #{params.useYn}
        )
    </insert>

    <!-- 창고관리자 등록 -->
    <insert id="insertWarehouseManagerMember">
        INSERT INTO warehouse_manager (
            wm_id
          , wm_password
          , wm_nm
          , wm_email
          , wm_telno
          , wm_zip
          , wm_adres
          , wm_detail_adres
          , wm_use_yn
          , wm_regist_dt
          , wm_updt_dt
        ) VALUES (
            #{params.loginId}
          , #{params.encodedPassword}
          , #{params.wmNm}
          , #{params.wmEmail}
          , #{params.wmTelno}
          , #{params.wmZip}
          , #{params.wmAdres}
          , #{params.wmDetailAdres}
          , #{params.useYn}
          , SYSDATE
          , SYSDATE
        )
    </insert>

    <!-- 관리자 회원 페이지 목록 조회 -->
    <select id="selectMemberList"
            resultMap="adminMemberListMap">
        SELECT
            login_id
          , login_nm
          , role_cd
          , role_nm
          , actor_type_cd
          , actor_table_nm
          , org_nm
          , email
          , telno
          , use_yn
          , officer_ty_cd
          , officer_ty_nm
        FROM (
            SELECT
                ROW_NUMBER() OVER (
                    ORDER BY
                        val.actor_type_cd
                      , val.login_id
                ) AS rn
              , val.login_id
              , val.login_nm
              , val.role_cd
              , val.role_nm
              , val.actor_type_cd
              , val.actor_table_nm
              , val.org_nm
              , val.email
              , val.telno
              , val.use_yn
              , o.officer_ty_cd
              , CASE
                  WHEN o.officer_ty_cd = 'OFFICER' THEN '행정공무원'
                  WHEN o.officer_ty_cd = 'FIELD_OFFICER' THEN '현장공무원'
                  ELSE '-'
                END AS officer_ty_nm
            FROM vw_actor_login val
            LEFT JOIN officer o ON val.login_id = o.officer_id AND val.actor_type_cd = 'OFFICER'
            WHERE 1 = 1
            <include refid="adminMemberSearchWhere"/>
        )
        WHERE rn BETWEEN #{pagingVO.startRow} AND #{pagingVO.endRow}
        ORDER BY rn
    </select>

    <!-- 회원 상세 정보 조회 -->
    <select id="selectMemberDetail"
            resultMap="adminMemberListMap">
        SELECT
            val.login_id
          , val.login_nm
          , val.role_cd
          , val.role_nm
          , val.actor_type_cd
          , val.actor_table_nm
          , val.org_nm
          , val.email
          , val.telno
          , val.use_yn
          , o.officer_ty_cd
          , CASE
              WHEN o.officer_ty_cd = 'OFFICER' THEN '행정공무원'
              WHEN o.officer_ty_cd = 'FIELD_OFFICER' THEN '현장공무원'
              ELSE '-'
            END AS officer_ty_nm
        FROM vw_actor_login val
        LEFT JOIN officer o ON val.login_id = o.officer_id AND val.actor_type_cd = 'OFFICER'
        WHERE val.actor_type_cd = #{actorTypeCd}
          AND val.login_id = #{loginId}
    </select>

    <!-- 화주 상세 조회 -->
    <select id="selectOwnerProfile"
            resultType="java.util.LinkedHashMap">
        SELECT
            owr_id AS "owrId"
          , owr_ty_cd AS "owrTyCd"
          , owr_nm AS "owrNm"
          , owr_bizrno AS "owrBizrno"
          , owr_ident_no AS "owrIdentNo"
          , owr_cstm_idf_no AS "owrCstmIdfNo"
          , owr_email AS "owrEmail"
          , owr_telno AS "owrTelno"
          , owr_zip AS "owrZip"
          , owr_adres AS "owrAdres"
          , owr_detail_adres AS "owrDetailAdres"
          , owr_use_yn AS "owrUseYn"
          , TO_CHAR(owr_regist_dt, 'YYYY-MM-DD HH24:MI:SS') AS "owrRegistDt"
          , TO_CHAR(owr_updt_dt, 'YYYY-MM-DD HH24:MI:SS') AS "owrUpdtDt"
          , privacy_agree_yn AS "privacyAgreeYn"
          , owr_corp_reg_no AS "owrCorpRegNo"
        FROM owner
        WHERE owr_id = #{loginId}
    </select>

    <!-- 관세사 상세 조회 -->
    <select id="selectBrokerProfile"
            resultType="java.util.LinkedHashMap">
        SELECT
            broker_id AS "brokerId"
          , broker_ty_cd AS "brokerTyCd"
          , broker_nm AS "brokerNm"
          , broker_office_nm AS "brokerOfficeNm"
          , broker_reg_no AS "brokerRegNo"
          , broker_bizrno AS "brokerBizrno"
          , broker_spclty_cd AS "brokerSpcltyCd"
          , broker_email AS "brokerEmail"
          , broker_telno AS "brokerTelno"
          , broker_zip AS "brokerZip"
          , broker_adres AS "brokerAdres"
          , broker_detail_adres AS "brokerDetailAdres"
          , broker_use_yn AS "brokerUseYn"
          , TO_CHAR(broker_regist_dt, 'YYYY-MM-DD HH24:MI:SS') AS "brokerRegistDt"
          , TO_CHAR(broker_updt_dt, 'YYYY-MM-DD HH24:MI:SS') AS "brokerUpdtDt"
        FROM broker
        WHERE broker_id = #{loginId}
    </select>

    <!-- 공무원 상세 조회 -->
    <select id="selectOfficerProfile"
            resultType="java.util.LinkedHashMap">
        SELECT
            officer_id AS "officerId"
          , officer_ty_cd AS "officerTyCd"
          , officer_name AS "officerName"
          , officer_nm AS "officerNm"
          , officer_inst_cd AS "officerInstCd"
          , officer_dept_cd AS "officerDeptCd"
          , officer_clsf_cd AS "officerClsfCd"
          , officer_field_cd AS "officerFieldCd"
          , officer_email AS "officerEmail"
          , officer_telno AS "officerTelno"
          , officer_zip AS "officerZip"
          , officer_adres AS "officerAdres"
          , officer_detail_adres AS "officerDetailAdres"
          , officer_use_yn AS "officerUseYn"
          , TO_CHAR(officer_regist_dt, 'YYYY-MM-DD HH24:MI:SS') AS "officerRegistDt"
          , TO_CHAR(officer_updt_dt, 'YYYY-MM-DD HH24:MI:SS') AS "officerUpdtDt"
        FROM officer
        WHERE officer_id = #{loginId}
    </select>

    <!-- 운송담당자 상세 조회 -->
    <select id="selectTransportManagerProfile"
            resultType="java.util.LinkedHashMap">
        SELECT
            tm_no AS "tmNo"
          , tm_id AS "tmId"
          , tm_cp_nm AS "tmCpNm"
          , tm_cp_telno AS "tmCpTelno"
          , tm_mn_cd AS "tmMnCd"
          , tm_name AS "tmName"
          , tm_use_yn AS "tmUseYn"
        FROM transport_manager
        WHERE tm_id = #{loginId}
          AND tm_id IS NOT NULL
    </select>

    <!-- 창고관리자 상세 조회 -->
    <select id="selectWarehouseManagerProfile"
            resultType="java.util.LinkedHashMap">
        SELECT
            wm_id AS "wmId"
          , wm_nm AS "wmNm"
          , wm_email AS "wmEmail"
          , wm_telno AS "wmTelno"
          , wm_zip AS "wmZip"
          , wm_adres AS "wmAdres"
          , wm_detail_adres AS "wmDetailAdres"
          , wm_use_yn AS "wmUseYn"
          , TO_CHAR(wm_regist_dt, 'YYYY-MM-DD HH24:MI:SS') AS "wmRegistDt"
          , TO_CHAR(wm_updt_dt, 'YYYY-MM-DD HH24:MI:SS') AS "wmUpdtDt"
        FROM warehouse_manager
        WHERE wm_id = #{loginId}
    </select>

    <!-- 시스템관리자 상세 조회 -->
    <select id="selectSystemAdminProfile"
            resultType="java.util.LinkedHashMap">
        SELECT
            sa_id AS "saId"
          , sa_nm AS "saNm"
          , sa_email AS "saEmail"
          , sa_telno AS "saTelno"
          , sa_use_yn AS "saUseYn"
          , TO_CHAR(sa_regist_dt, 'YYYY-MM-DD HH24:MI:SS') AS "saRegistDt"
          , TO_CHAR(sa_updt_dt, 'YYYY-MM-DD HH24:MI:SS') AS "saUpdtDt"
        FROM system_admin
        WHERE sa_id = #{loginId}
    </select>

    <!-- 현재 활성 상태인 시스템관리자 수 조회 -->
    <select id="selectActiveSystemAdminCount"
            resultType="int">
        SELECT
            COUNT(*)
        FROM vw_actor_login
        WHERE actor_type_cd = 'SYSTEM_ADMIN'
          AND use_yn = 'Y'
    </select>

    <!-- 공무원 유형 변경 -->
    <update id="updateOfficerType">
        UPDATE officer
        SET
            officer_ty_cd = #{officerTyCd}
        WHERE officer_id = #{loginId}
    </update>

    <!-- 화주 사용여부 수정 -->
    <update id="updateOwnerUseYn">
        UPDATE owner
        SET
            owr_use_yn = #{useYn}
        WHERE owr_id = #{loginId}
    </update>

    <!-- 관세사 사용여부 수정 -->
    <update id="updateBrokerUseYn">
        UPDATE broker
        SET
            broker_use_yn = #{useYn}
        WHERE broker_id = #{loginId}
    </update>

    <!-- 공무원 사용여부 수정 -->
    <update id="updateOfficerUseYn">
        UPDATE officer
        SET
            officer_use_yn = #{useYn}
        WHERE officer_id = #{loginId}
    </update>

    <!-- 운송담당자 사용여부 수정 -->
    <update id="updateTransportManagerUseYn">
        UPDATE transport_manager
        SET
            tm_use_yn = #{useYn}
        WHERE tm_id = #{loginId}
    </update>

    <!-- 창고관리자 사용여부 수정 -->
    <update id="updateWarehouseManagerUseYn">
        UPDATE warehouse_manager
        SET
            wm_use_yn = #{useYn}
        WHERE wm_id = #{loginId}
    </update>

    <!-- 시스템관리자 사용여부 수정 -->
    <update id="updateSystemAdminUseYn">
        UPDATE system_admin
        SET
            sa_use_yn = #{useYn}
        WHERE sa_id = #{loginId}
    </update>

    <!-- 화주 프로필 수정 -->
    <update id="updateOwnerProfile">
        UPDATE owner
        <set>
            <if test="changes.containsKey('owrTyCd')">owr_ty_cd = #{changes.owrTyCd},</if>
            <if test="changes.containsKey('owrNm')">owr_nm = #{changes.owrNm},</if>
            <if test="changes.containsKey('owrBizrno')">owr_bizrno = #{changes.owrBizrno},</if>
            <if test="changes.containsKey('owrCstmIdfNo')">owr_cstm_idf_no = #{changes.owrCstmIdfNo},</if>
            <if test="changes.containsKey('owrEmail')">owr_email = #{changes.owrEmail},</if>
            <if test="changes.containsKey('owrTelno')">owr_telno = #{changes.owrTelno},</if>
            <if test="changes.containsKey('owrZip')">owr_zip = #{changes.owrZip},</if>
            <if test="changes.containsKey('owrAdres')">owr_adres = #{changes.owrAdres},</if>
            <if test="changes.containsKey('owrDetailAdres')">owr_detail_adres = #{changes.owrDetailAdres},</if>
            <if test="changes.containsKey('owrUseYn')">owr_use_yn = #{changes.owrUseYn},</if>
            <if test="changes.containsKey('owrCorpRegNo')">owr_corp_reg_no = #{changes.owrCorpRegNo},</if>
            owr_updt_dt = SYSDATE
        </set>
        WHERE owr_id = #{loginId}
    </update>

    <!-- 관세사 프로필 수정 -->
    <update id="updateBrokerProfile">
        UPDATE broker
        <set>
            <if test="changes.containsKey('brokerTyCd')">broker_ty_cd = #{changes.brokerTyCd},</if>
            <if test="changes.containsKey('brokerNm')">broker_nm = #{changes.brokerNm},</if>
            <if test="changes.containsKey('brokerOfficeNm')">broker_office_nm = #{changes.brokerOfficeNm},</if>
            <if test="changes.containsKey('brokerRegNo')">broker_reg_no = #{changes.brokerRegNo},</if>
            <if test="changes.containsKey('brokerBizrno')">broker_bizrno = #{changes.brokerBizrno},</if>
            <if test="changes.containsKey('brokerSpcltyCd')">broker_spclty_cd = #{changes.brokerSpcltyCd},</if>
            <if test="changes.containsKey('brokerEmail')">broker_email = #{changes.brokerEmail},</if>
            <if test="changes.containsKey('brokerTelno')">broker_telno = #{changes.brokerTelno},</if>
            <if test="changes.containsKey('brokerZip')">broker_zip = #{changes.brokerZip},</if>
            <if test="changes.containsKey('brokerAdres')">broker_adres = #{changes.brokerAdres},</if>
            <if test="changes.containsKey('brokerDetailAdres')">broker_detail_adres = #{changes.brokerDetailAdres},</if>
            <if test="changes.containsKey('brokerUseYn')">broker_use_yn = #{changes.brokerUseYn},</if>
            broker_updt_dt = SYSDATE
        </set>
        WHERE broker_id = #{loginId}
    </update>

    <!-- 공무원 프로필 수정 -->
    <update id="updateOfficerProfile">
        UPDATE officer
        <set>
            <if test="changes.containsKey('officerTyCd')">officer_ty_cd = #{changes.officerTyCd},</if>
            <if test="changes.containsKey('officerName')">officer_name = #{changes.officerName},</if>
            <if test="changes.containsKey('officerNm')">officer_nm = #{changes.officerNm},</if>
            <if test="changes.containsKey('officerInstCd')">officer_inst_cd = #{changes.officerInstCd},</if>
            <if test="changes.containsKey('officerDeptCd')">officer_dept_cd = #{changes.officerDeptCd},</if>
            <if test="changes.containsKey('officerClsfCd')">officer_clsf_cd = #{changes.officerClsfCd},</if>
            <if test="changes.containsKey('officerFieldCd')">officer_field_cd = #{changes.officerFieldCd},</if>
            <if test="changes.containsKey('officerEmail')">officer_email = #{changes.officerEmail},</if>
            <if test="changes.containsKey('officerTelno')">officer_telno = #{changes.officerTelno},</if>
            <if test="changes.containsKey('officerZip')">officer_zip = #{changes.officerZip},</if>
            <if test="changes.containsKey('officerAdres')">officer_adres = #{changes.officerAdres},</if>
            <if test="changes.containsKey('officerDetailAdres')">officer_detail_adres = #{changes.officerDetailAdres},</if>
            <if test="changes.containsKey('officerUseYn')">officer_use_yn = #{changes.officerUseYn},</if>
            officer_updt_dt = SYSDATE
        </set>
        WHERE officer_id = #{loginId}
    </update>

    <!-- 운송담당자 프로필 수정 -->
    <update id="updateTransportManagerProfile">
        UPDATE transport_manager
        <set>
            <if test="changes.containsKey('tmCpNm')">tm_cp_nm = #{changes.tmCpNm},</if>
            <if test="changes.containsKey('tmCpTelno')">tm_cp_telno = #{changes.tmCpTelno},</if>
            <if test="changes.containsKey('tmMnCd')">tm_mn_cd = #{changes.tmMnCd},</if>
            <if test="changes.containsKey('tmName')">tm_name = #{changes.tmName},</if>
            <if test="changes.containsKey('tmUseYn')">tm_use_yn = #{changes.tmUseYn},</if>
        </set>
        WHERE tm_id = #{loginId}
          AND tm_id IS NOT NULL
    </update>

    <!-- 창고관리자 프로필 수정 -->
    <update id="updateWarehouseManagerProfile">
        UPDATE warehouse_manager
        <set>
            <if test="changes.containsKey('wmNm')">wm_nm = #{changes.wmNm},</if>
            <if test="changes.containsKey('wmEmail')">wm_email = #{changes.wmEmail},</if>
            <if test="changes.containsKey('wmTelno')">wm_telno = #{changes.wmTelno},</if>
            <if test="changes.containsKey('wmZip')">wm_zip = #{changes.wmZip},</if>
            <if test="changes.containsKey('wmAdres')">wm_adres = #{changes.wmAdres},</if>
            <if test="changes.containsKey('wmDetailAdres')">wm_detail_adres = #{changes.wmDetailAdres},</if>
            <if test="changes.containsKey('wmUseYn')">wm_use_yn = #{changes.wmUseYn},</if>
            wm_updt_dt = SYSDATE
        </set>
        WHERE wm_id = #{loginId}
    </update>

    <!-- 시스템관리자 프로필 수정 -->
    <update id="updateSystemAdminProfile">
        UPDATE system_admin
        <set>
            <if test="changes.containsKey('saNm')">sa_nm = #{changes.saNm},</if>
            <if test="changes.containsKey('saEmail')">sa_email = #{changes.saEmail},</if>
            <if test="changes.containsKey('saTelno')">sa_telno = #{changes.saTelno},</if>
            <if test="changes.containsKey('saUseYn')">sa_use_yn = #{changes.saUseYn},</if>
            sa_updt_dt = SYSDATE
        </set>
        WHERE sa_id = #{loginId}
    </update>

    <!-- 회원 변경 이력 저장 -->
    <insert id="insertAdminMemberChangeLog">
        INSERT INTO admin_member_chg_log (
            amcl_no
          , amcl_target_actor_ty_cd
          , amcl_target_login_id
          , amcl_chg_ty_cd
          , amcl_target_field_nm
          , amcl_before_val
          , amcl_after_val
          , amcl_rsn_cn
          , amcl_admin_id
          , amcl_regist_dt
        ) VALUES (
            (
                SELECT
                    'AMCL-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-'
                    || LPAD(
                        NVL(MAX(TO_NUMBER(SUBSTR(amcl_no, 15))), 0) + 1
                      , 6
                      , '0'
                    )
                FROM admin_member_chg_log
                WHERE amcl_no LIKE 'AMCL-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-%'
            )
          , #{targetActorTyCd}
          , #{targetLoginId}
          , #{chgTyCd}
          , #{targetFieldNm}
          , #{beforeVal}
          , #{afterVal}
          , #{rsnCn}
          , #{adminId}
          , SYSDATE
        )
    </insert>

    <!-- 액터별 가장 최근 로그인 ID 조회 -->
    <select id="selectLatestLoginId" resultType="string">
        <choose>
            <when test="actorTypeCd == 'BROKER'">
                SELECT MAX(broker_id) FROM broker
            </when>
            <when test="actorTypeCd == 'OFFICER'">
                SELECT MAX(officer_id) FROM officer
            </when>
            <when test="actorTypeCd == 'TRANSPORT_MANAGER'">
                SELECT MAX(tm_id) FROM transport_manager
            </when>
            <when test="actorTypeCd == 'WAREHOUSE_MANAGER'">
                SELECT MAX(wm_id) FROM warehouse_manager
            </when>
            <when test="actorTypeCd == 'SYSTEM_ADMIN'">
                SELECT MAX(sa_id) FROM system_admin
            </when>
            <otherwise>
                SELECT NULL FROM DUAL
            </otherwise>
        </choose>
    </select>

</mapper>
