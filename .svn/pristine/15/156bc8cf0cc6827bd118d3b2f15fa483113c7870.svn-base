<%@ page pageEncoding="UTF-8" %>
<header class="topbar">
<div class="tb-left">
<span class="tb-brand">TACS</span>
<div class="search-wrap">
<span class="material-symbols-outlined">search</span>
<input id="gSearch" onkeydown="if(event.key==='Enter')doSearch()" placeholder="신청번호 · 업체명 · HS코드 통합 검색..."/>
</div>
</div>
<div class="tb-right">
<% if (request.isUserInRole("SYSTEM_ADMIN")) { %>
<button class="tb-btn" title="액터 목록" onclick="location.href='${ctx}/systemadmin/dashboard.do'">
<span class="material-symbols-outlined">list</span>
</button>
<% } %>
<jsp:include page="/WEB-INF/views/common/notification_bell.jsp" />
<button class="tb-btn" onclick="alert('현장공무원 도움말\\n\\n• 검사 요청 조회: 요청 목록 확인 및 상세 검토\\n• 검역 검사 수행: 검사, 시료채취, 정밀검사 의뢰\\n• 검역 결과 처리: 합격/불합격/조건부 합격 처리\\n• 증명서 발급: 검역증명서 발급')">
<span class="material-symbols-outlined">help</span>
</button>
<div class="tb-sep"></div>
<div class="tb-user">
<div class="tb-user-info">
<div class="name">현장공무원 김검역</div>
<div class="role">검역기관 담당자</div>
</div>
<div class="tb-avatar" onclick="if(confirm('로그아웃 하시겠습니까?')) document.getElementById('logoutForm').submit();" style="cursor:pointer">김</div>
</div>
</div>
</header>
