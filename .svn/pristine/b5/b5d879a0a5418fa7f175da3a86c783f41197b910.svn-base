<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.owner.trace.mapper.IAisMapper">

    <select id="selectPortAliasList" resultType="kr.or.tacs.dto.owner.AisPortAliasDTO">
        SELECT
            apa_no
             , apa_port_cd
             , apa_alias_nm
             , apa_use_yn
             , apa_regist_dt
        FROM ais_port_alias
        WHERE apa_use_yn = 'Y'
        ORDER BY apa_port_cd, apa_no
    </select>

    <select id="selectShipNoByMmsi"
            parameterType="string"
            resultType="long">
        SELECT ship_no
        FROM ship
        WHERE ship_mmsi = #{mmsi}
          AND ship_use_yn = 'Y'
    </select>

    <insert id="mergeAisVslLatest" parameterType="kr.or.tacs.dto.owner.AisVslLatestDTO">
        MERGE INTO ais_vsl_latest avl
            USING (
                SELECT
                    #{avlMmsi}         AS avl_mmsi
                     , #{avlShipNo}       AS avl_ship_no
                     , #{avlShipNm}       AS avl_ship_nm
                     , #{avlDest}         AS avl_dest
                     , #{avlLat}          AS avl_lat
                     , #{avlLon}          AS avl_lon
                     , #{avlSog}          AS avl_sog
                     , #{avlCog}          AS avl_cog
                     , #{avlHead}         AS avl_head
                     , #{avlKrVslYn}      AS avl_kr_vsl_yn
                     , #{avlIncomeKrYn}   AS avl_income_kr_yn
                     , #{avlMsgType}      AS avl_msg_type
                FROM dual
            ) src
            ON (avl.avl_mmsi = src.avl_mmsi)
            WHEN MATCHED THEN
                UPDATE SET
                    avl.avl_ship_no       = src.avl_ship_no
                    , avl.avl_ship_nm       = NVL(src.avl_ship_nm, avl.avl_ship_nm)
                    , avl.avl_dest          = NVL(src.avl_dest, avl.avl_dest)
                    , avl.avl_lat           = NVL(src.avl_lat, avl.avl_lat)
                    , avl.avl_lon           = NVL(src.avl_lon, avl.avl_lon)
                    , avl.avl_sog           = NVL(src.avl_sog, avl.avl_sog)
                    , avl.avl_cog           = NVL(src.avl_cog, avl.avl_cog)
                    , avl.avl_head          = NVL(src.avl_head, avl.avl_head)
                    , avl.avl_kr_vsl_yn     = NVL(src.avl_kr_vsl_yn, avl.avl_kr_vsl_yn)
                    , avl.avl_income_kr_yn  = NVL(src.avl_income_kr_yn, avl.avl_income_kr_yn)
                    , avl.avl_msg_type      = src.avl_msg_type
                    , avl.avl_updt_dt       = SYSDATE
            WHEN NOT MATCHED THEN
                INSERT (
                        avl_mmsi
                    , avl_ship_no
                    , avl_ship_nm
                    , avl_dest
                    , avl_lat
                    , avl_lon
                    , avl_sog
                    , avl_cog
                    , avl_head
                    , avl_kr_vsl_yn
                    , avl_income_kr_yn
                    , avl_msg_type
                    , avl_rcpt_dt
                    , avl_updt_dt
                    )
                    VALUES (
                             src.avl_mmsi
                           , src.avl_ship_no
                           , src.avl_ship_nm
                           , src.avl_dest
                           , src.avl_lat
                           , src.avl_lon
                           , src.avl_sog
                           , src.avl_cog
                           , src.avl_head
                           , NVL(src.avl_kr_vsl_yn, 'N')
                           , NVL(src.avl_income_kr_yn, 'N')
                           , src.avl_msg_type
                           , SYSDATE
                           , SYSDATE
                           )
    </insert>

    <select id="selectIncomingVesselList" resultType="kr.or.tacs.dto.owner.AisVslLatestDTO">
        SELECT
            avl_mmsi
             , avl_ship_no
             , avl_ship_nm
             , avl_dest
             , avl_lat
             , avl_lon
             , avl_sog
             , avl_cog
             , avl_head
             , avl_kr_vsl_yn
             , avl_income_kr_yn
             , avl_msg_type
             , avl_rcpt_dt
             , avl_updt_dt
        FROM ais_vsl_latest
        WHERE avl_income_kr_yn = 'Y'
          AND avl_lat IS NOT NULL
          AND avl_lon IS NOT NULL
        ORDER BY avl_updt_dt DESC
    </select>

    <select id="selectRecentVesselList"
            resultType="kr.or.tacs.dto.owner.AisVslLatestDTO">
        SELECT
            avl_mmsi
             , avl_ship_no
             , avl_ship_nm
             , avl_dest
             , avl_lat
             , avl_lon
             , avl_sog
             , avl_cog
             , avl_head
             , avl_kr_vsl_yn
             , avl_income_kr_yn
             , avl_msg_type
             , avl_rcpt_dt
             , avl_updt_dt
        FROM ais_vsl_latest
        WHERE avl_lat IS NOT NULL
          AND avl_lon IS NOT NULL
        ORDER BY avl_updt_dt DESC
            FETCH FIRST 200 ROWS ONLY
    </select>

    <select id="selectVesselLatest" parameterType="string" resultType="kr.or.tacs.dto.owner.AisVslLatestDTO">
        SELECT
            avl_mmsi
             , avl_ship_no
             , avl_ship_nm
             , avl_dest
             , avl_lat
             , avl_lon
             , avl_sog
             , avl_cog
             , avl_head
             , avl_kr_vsl_yn
             , avl_income_kr_yn
             , avl_msg_type
             , avl_rcpt_dt
             , avl_updt_dt
        FROM ais_vsl_latest
        WHERE avl_mmsi = #{mmsi}
    </select>

</mapper>