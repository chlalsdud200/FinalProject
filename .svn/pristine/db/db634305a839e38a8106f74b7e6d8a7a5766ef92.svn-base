/* 현재 모달에서 선택된 화주 저장 */
var currentStatusClient = '';

/* 1) 상세 버튼 클릭 → 모달 열기 */
function openStatusDetail(client, date, highlightNo) {
  currentStatusClient = client;
  document.getElementById('stM-search-client').value = client;
  document.getElementById('stM-search-date').value = date + ' 전후';
  document.getElementById('stM-search-type').value = 'all';
  renderStatusModalList(highlightNo);
  showModal('status-detail');
}

/* 2) 모달 안의 리스트 렌더링 (필터링 포함) */
function renderStatusModalList(highlightNo) {
  var type = document.getElementById('stM-search-type').value;
  var list = statusDeclareStore[currentStatusClient] || [];

  var filtered = list.filter(function (d) {
    if (type === 'all') return true;
    return d.type === type;
  });

  var body = document.getElementById('stM-list-body');
  var count = document.getElementById('stM-count');
  count.textContent = filtered.length;

  if (filtered.length === 0) {
    body.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:30px;color:#a0b4c8">조회된 신고서가 없습니다.</td></tr>';
    return;
  }

  var html = '';
  filtered.forEach(function (d) {
    var statusColor = d.status === '수리' || d.status === '승인' ? 'badge-ok' :
      d.status === '심사중' ? 'badge-rev' :
        d.status === '서류보완' ? 'badge-doc' : 'badge-new';
    var highlight = (d.no === highlightNo) ? 'background:#fef3c7' : '';
    html += '<tr style="cursor:pointer;' + highlight + '" onclick="selectStatusDeclare(\'' + d.no + '\')" onmouseover="this.style.background=\'#f1f5f9\'" onmouseout="this.style.background=\'' + (d.no === highlightNo ? '#fef3c7' : '') + '\'">';
    html += '<td class="td-id">' + d.no + '</td>';
    html += '<td><span style="font-weight:700;color:' + (d.type === '수입' ? '#565e74' : d.type === '수출' ? '#1d6b4f' : '#9f403d') + '">' + d.type + '</span></td>';
    html += '<td>' + d.item + '</td>';
    html += '<td>' + d.hs + '</td>';
    html += '<td class="td-muted">' + d.acceptDate + '</td>';
    html += '<td><span class="badge ' + statusColor + '">' + d.status + '</span></td>';
    html += '<td><button class="mini mini-accept" style="font-size:9px" onclick="event.stopPropagation();selectStatusDeclare(\'' + d.no + '\')">불러오기</button></td>';
    html += '</tr>';
  });
  body.innerHTML = html;
}

/* 3) 모달 리스트 항목 클릭 → 하단 신고서 영역에 내용 표시 */
function selectStatusDeclare(no) {
  var found = null;
  for (var c in statusDeclareStore) {
    statusDeclareStore[c].forEach(function (d) {
      if (d.no === no) found = Object.assign({ client: c }, d);
    });
  }
  if (!found) { alert('신고서 데이터를 찾을 수 없습니다.'); return; }

  document.getElementById('st-preview-empty').style.display = 'none';
  document.getElementById('st-preview-content').style.display = 'block';

  document.getElementById('stP-title').textContent =
    found.type === '수입' ? '수입신고서 상세' :
      found.type === '수출' ? '수출신고서 상세' : '환급신청서 상세';
  document.getElementById('stP-no').textContent = found.no;

  document.getElementById('stP-f-no').value = found.no;
  document.getElementById('stP-f-type').value = found.type + '신고';
  document.getElementById('stP-f-status').value = found.status;
  document.getElementById('stP-f-client').value = found.client;
  document.getElementById('stP-f-bizNo').value = found.bizNo;
  document.getElementById('stP-f-clientCode').value = found.clientCode;
  document.getElementById('stP-f-acceptDate').value = found.acceptDate;
  document.getElementById('stP-f-customs').value = found.customs;
  document.getElementById('stP-f-officer').value = found.officer;

  document.getElementById('stP-f-item').value = found.item;
  document.getElementById('stP-f-hs').value = found.hs;
  document.getElementById('stP-f-origin').value = found.origin;
  document.getElementById('stP-f-qty').value = found.qty;
  document.getElementById('stP-f-weight').value = found.weight;
  document.getElementById('stP-f-invoice').value = found.invoice;

  document.getElementById('stP-f-bl').value = found.bl;
  document.getElementById('stP-f-exchange').value = found.exchange;
  document.getElementById('stP-f-tax').value = found.tax;

  hideModal('status-detail');

  setTimeout(function () {
    document.getElementById('st-detail-preview').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 100);
}

/* 4) 하단 신고서 닫기 */
function closeStDetailPreview() {
  document.getElementById('st-preview-empty').style.display = 'block';
  document.getElementById('st-preview-content').style.display = 'none';
}

