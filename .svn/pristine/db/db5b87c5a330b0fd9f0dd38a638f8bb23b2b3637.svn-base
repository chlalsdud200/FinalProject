<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.common.resource.mapper.IResourceArchiveMapper">

    <resultMap id="resourceArchiveMap" type="kr.or.tacs.vo.common.ResourceArchiveVO">
        <id property="resNo" column="RES_NO"/>
        <result property="resFgNo" column="RES_FG_NO"/>
        <result property="resTtl" column="RES_TTL"/>
        <result property="resCn" column="RES_CN"/>
        <result property="resRegDt" column="RES_REG_DT"/>
        <result property="fileNo" column="DFI_FILE_NO"/>
        <result property="orgFileName" column="DFI_ORG_NM"/>
        <result property="strFileName" column="DFI_STR_NM"/>
        <result property="fileSize" column="DFI_SIZE"/>
        <result property="filePath" column="DFI_PATH"/>
        <result property="docTyCd" column="TFM_DOC_TY_CD"/>
        <result property="docTyNm" column="DOC_TY_NM"/>
    </resultMap>

    <sql id="docTypeNameCase">
        CASE TFM.tfm_doc_ty_cd
            WHEN 'INVOICE' THEN '송장'
            WHEN 'PACKING_LIST' THEN '포장명세서'
            WHEN 'BL' THEN '선하증권'
            WHEN 'IMPORT_DECL' THEN '수입신고서'
            WHEN 'EXPORT_DECL' THEN '수출신고서'
            WHEN 'MANUAL' THEN '매뉴얼'
            ELSE '기타'
        END
    </sql>
    <sql id="archiveWhere">
        WHERE TFG.tfg_biz_se_cd = 'RES'
          AND DFI.dfi_biz_ty_cd = 'RES'
          AND DFI.dfi_del_yn = 'N'
        <if test="roleCd != 'SYSTEM_ADMIN'">
          AND EXISTS (
              SELECT 1 FROM res_board_auth RBA 
              WHERE RBA.rba_res_no = R.res_no 
                AND RBA.rba_target_role_cd IN ('ALL', #{roleCd})
          )
        </if>
        <if test="docTyCd != null and docTyCd != '' and docTyCd != 'all'">
          AND TFM.tfm_doc_ty_cd = #{docTyCd}
        </if>
        <if test="keyword != null and keyword != ''">
          AND (
                UPPER(R.res_ttl) LIKE '%' || UPPER(#{keyword}) || '%'
             OR UPPER(R.res_cn) LIKE '%' || UPPER(#{keyword}) || '%'
             OR UPPER(DFI.dfi_org_nm) LIKE '%' || UPPER(#{keyword}) || '%'
          )
        </if>
        <if test="fromDate != null and fromDate != ''">
          AND TRUNC(R.res_reg_dt) &gt;= TO_DATE(#{fromDate}, 'YYYY-MM-DD')
        </if>
        <if test="toDate != null and toDate != ''">
          AND TRUNC(R.res_reg_dt) &lt;= TO_DATE(#{toDate}, 'YYYY-MM-DD')
        </if>
    </sql>

    <select id="selectArchiveList" parameterType="kr.or.tacs.vo.common.ResourceArchiveSearchVO" resultMap="resourceArchiveMap">
        SELECT
              R.res_no
            , R.res_fg_no
            , R.res_ttl
            , R.res_cn
            , TO_CHAR(R.res_reg_dt, 'YYYY-MM-DD') AS RES_REG_DT
            , DFI.dfi_file_no
            , DFI.dfi_org_nm
            , DFI.dfi_str_nm
            , DFI.dfi_size
            , DFI.dfi_path
            , TFM.tfm_doc_ty_cd
            , <include refid="docTypeNameCase"/> AS DOC_TY_NM
        FROM res_board R
        JOIN tacs_file_grp TFG
          ON TFG.tfg_no = R.res_fg_no
        JOIN tacs_file_map TFM
          ON TFM.tfm_tfg_no = TFG.tfg_no
        JOIN docs_file_data DFI
          ON DFI.dfi_file_no = TFM.tfm_dfi_no
        <include refid="archiveWhere"/>
        ORDER BY R.res_reg_dt DESC, R.res_no DESC
    </select>

    <select id="selectArchiveFileForDownload" resultMap="resourceArchiveMap">
        SELECT
              R.res_no
            , R.res_fg_no
            , R.res_ttl
            , R.res_cn
            , TO_CHAR(R.res_reg_dt, 'YYYY-MM-DD') AS RES_REG_DT
            , DFI.dfi_file_no
            , DFI.dfi_org_nm
            , DFI.dfi_str_nm
            , DFI.dfi_size
            , DFI.dfi_path
            , TFM.tfm_doc_ty_cd
            , <include refid="docTypeNameCase"/> AS DOC_TY_NM
        FROM res_board R
        JOIN tacs_file_grp TFG
          ON TFG.tfg_no = R.res_fg_no
        JOIN tacs_file_map TFM
          ON TFM.tfm_tfg_no = TFG.tfg_no
        JOIN docs_file_data DFI
          ON DFI.dfi_file_no = TFM.tfm_dfi_no
        WHERE R.res_no = #{resNo}
          AND DFI.dfi_file_no = #{fileNo}
          AND TFG.tfg_biz_se_cd = 'RES'
          AND DFI.dfi_biz_ty_cd = 'RES'
          AND DFI.dfi_del_yn = 'N'
          <if test="roleCd != 'SYSTEM_ADMIN'">
            AND EXISTS (
                SELECT 1 FROM res_board_auth RBA 
                WHERE RBA.rba_res_no = R.res_no 
                  AND RBA.rba_target_role_cd IN ('ALL', #{roleCd})
            )
          </if>
    </select>

    <insert id="insertFileGroup" parameterType="kr.or.tacs.vo.common.ResourceArchiveUploadVO">
        <selectKey keyProperty="resFgNo" resultType="long" order="BEFORE">
            SELECT NVL(MAX(tfg_no), 0) + 1 FROM tacs_file_grp
        </selectKey>
        INSERT INTO tacs_file_grp (
              tfg_no
            , tfg_biz_se_cd
            , tfg_regist_dt
        ) VALUES (
              #{resFgNo}
            , 'RES'
            , SYSDATE
        )
    </insert>

    <insert id="insertDocsFileData" parameterType="kr.or.tacs.vo.common.ResourceArchiveUploadVO">
        <selectKey keyProperty="fileNo" resultType="long" order="BEFORE">
            SELECT NVL(MAX(dfi_file_no), 0) + 1 FROM docs_file_data
        </selectKey>
        INSERT INTO docs_file_data (
              dfi_file_no
            , dfi_actor_id
            , dfi_actor_type
            , dfi_org_nm
            , dfi_str_nm
            , dfi_size
            , dfi_path
            , dfi_del_yn
            , dfi_regist_dt
            , dfi_biz_ty_cd
        ) VALUES (
              #{fileNo}
            , #{actorId}
            , #{actorType}
            , #{orgFileName}
            , #{strFileName}
            , #{fileSize}
            , #{filePath}
            , 'N'
            , SYSDATE
            , 'RES'
        )
    </insert>

    <insert id="insertFileMap" parameterType="kr.or.tacs.vo.common.ResourceArchiveUploadVO">
        <selectKey keyProperty="fileMapNo" resultType="long" order="BEFORE">
            SELECT NVL(MAX(tfm_no), 0) + 1 FROM tacs_file_map
        </selectKey>
        INSERT INTO tacs_file_map (
              tfm_no
            , tfm_tfg_no
            , tfm_dfi_no
            , tfm_doc_ty_cd
        ) VALUES (
              #{fileMapNo}
            , #{resFgNo}
            , #{fileNo}
            , #{docTyCd}
        )
    </insert>

    <insert id="insertResource" parameterType="kr.or.tacs.vo.common.ResourceArchiveUploadVO">
        <selectKey keyProperty="resNo" resultType="long" order="BEFORE">
            SELECT NVL(MAX(res_no), 0) + 1 FROM res_board
        </selectKey>
        INSERT INTO res_board (
              res_no
            , res_fg_no
            , res_ttl
            , res_cn
            , res_reg_dt
        ) VALUES (
              #{resNo}
            , #{resFgNo}
            , #{resTtl}
            , #{resCn}
            , SYSDATE
        )
    </insert>

    <insert id="insertResourceAuths">
        INSERT INTO res_board_auth (
              rba_no
            , rba_res_no
            , rba_target_role_cd
        )
        SELECT
              (SELECT NVL(MAX(rba_no), 0) FROM res_board_auth) + ROWNUM
            , #{resNo}
            , role_cd
        FROM (
            <foreach collection="targetRoleCds" item="roleCd" separator=" UNION ALL ">
            SELECT #{roleCd} AS ROLE_CD FROM dual
            </foreach>
        )
    </insert>

</mapper>
