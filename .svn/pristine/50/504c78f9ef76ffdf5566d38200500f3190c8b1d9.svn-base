/* ── Import detail document table ── */
.doc-table td {
    vertical-align: middle;
}

.doc-type-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 68px;
    padding: 3px 8px;
    background: #f1f5f9;
    color: #475569;
    font-size: 10px;
    font-weight: 800;
}

.doc-file-link,
.doc-file-name {
    color: #0f172a;
    font-weight: 800;
    text-decoration: none;
}

.doc-file-link:hover {
    text-decoration: underline;
}

.doc-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 58px;
    padding: 3px 8px;
    font-size: 10px;
    font-weight: 900;
}

.doc-status.done {
    background: #d1fae5;
    color: #065f46;
}

.doc-status.wait {
    background: #fef3c7;
    color: #92400e;
}

.doc-status.delete {
    background: #fee2e2;
    color: #991b1b;
}

.doc-actions {
    text-align: right;
    white-space: nowrap;
}

.doc-actions .mini + .mini,
.doc-actions .mini + a,
.doc-actions a + .mini {
    margin-left: 6px;
}

.delete-file-row {
    background: #fff5f5;
}

.delete-file-row .doc-file-link,
.delete-file-row .doc-file-name {
    color: #94a3b8;
    text-decoration: line-through;
}
