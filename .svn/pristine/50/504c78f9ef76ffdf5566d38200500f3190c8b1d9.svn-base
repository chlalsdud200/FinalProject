@charset "UTF-8";

/* ── 신청서 폼 양식 ── */
.form-doc { background:#fff; border:1px solid #e2e8f0; margin-bottom:20px; }
.form-doc-head { padding:20px 28px 16px; border-bottom:2px solid #0f172a; display:flex; justify-content:space-between; align-items:flex-end; }
.form-doc-type { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:#64748b; margin-bottom:4px; }
.form-doc-title { font-size:20px; font-weight:900; color:#0f172a; letter-spacing:-.5px; }
.form-doc-head-right { text-align:right; }
.form-doc-meta { font-size:11px; color:#64748b; line-height:1.8; }
.form-doc-meta strong { color:#203444; font-weight:700; }
.form-doc-body { padding:24px 28px; }
.form-group { margin-bottom:24px; }
.form-group-title { font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:1px; color:#94a3b8; padding-bottom:8px; border-bottom:1px solid #f1f5f9; margin-bottom:16px; }
.form-grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:14px 28px; }
.form-grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px 28px; }
.fi { display:flex; flex-direction:column; gap:5px; }
.fi.full { grid-column:1/-1; }
.fi label { font-size:11px; font-weight:700; color:#475569; }
.fi label .req { color:#9f403d; margin-left:2px; }
.fi input,.fi select,.fi textarea { padding:9px 12px; border:1px solid #d1d9e0; background:#fff; font-size:13px; color:#203444; outline:none; font-family:inherit; transition:border-color .15s; }
.fi input:focus,.fi select:focus,.fi textarea:focus { border-color:#565e74; }
.fi input[readonly] { background:#f8fafc; color:#64748b; cursor:default; }
.fi textarea { resize:vertical; min-height:72px; line-height:1.6; }
.form-doc-divider { height:1px; background:#f1f5f9; margin:8px 0 24px; }
/* broker selector inside form-doc */
.broker-selector-row { display:flex; align-items:center; gap:16px; padding:14px 16px; background:#f8fafc; border:1px solid #e2e8f0; margin-bottom:0; }
.broker-selector-row label { font-size:11px; font-weight:700; color:#475569; white-space:nowrap; }
.broker-display { flex:1; font-size:13px; color:#94a3b8; font-style:italic; }
.broker-display.selected { color:#0f172a; font-style:normal; font-weight:700; }


/* 통관상태 뱃지 */
.badge-cstm-req {
    background: #e2e8f0;
    color: #475569;
}

