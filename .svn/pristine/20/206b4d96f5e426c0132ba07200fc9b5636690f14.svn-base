<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.officer.basicscreen.mapper.IScreenDetailMapper">

    <!-- 수입 상세 -->
    <select id="selectImportDetail"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.BasicScreenDetailDTO">
        SELECT
            IR.IR_NO AS reqNo,
            '수입' AS declareType,
            TO_CHAR(IR.IR_DT, 'YYYY-MM-DD HH24:MI') AS requestDate,
            ID.ID_STATUS_CD AS statusCd,
            IR.IR_TFG_NO AS tfgNo,

            ARR.ARR_SCORE AS riskScore,
            ARR.ARR_GRADE_CD AS riskGradeCd,
            ARR.ARR_STATUS_CD AS riskStatusCd,
            ARR.ARR_RESULT_CN AS riskResultCn,

            IR.IR_OWR_ID AS companyName,
            OWR.OWR_TELNO AS companyTel,
            IR.IR_CORP_REG_NO AS corpRegNo,
            IR.IR_CSTM_IDF_NO AS customsIdNo,
            B.BROKER_OFFICE_NM AS brokerName,

            NVL(ID.ID_OFFICER_ID, IRC.IRC_OFFICER_ID) AS officerId,
            O.OFFICER_NM AS officerName,

            IR.IR_BL_AWB_NO AS blNo,
            IR.IR_ARRV_PORT_CD AS arrivalPort,
            CASE
                WHEN REGEXP_LIKE(IR.IR_ARRV_SCHD_YMD, '^[0-9]{8}$')
                THEN TO_CHAR(TO_DATE(IR.IR_ARRV_SCHD_YMD, 'YYYYMMDD'), 'YYYY-MM-DD')
                ELSE IR.IR_ARRV_SCHD_YMD
            END AS arrivalDate,
            TO_CHAR(NULL) AS cargoNo,

            TO_CHAR(IR.IR_INVC_AMT, 'FM999,999,999,999') AS amount,
            IR.IR_DCLR_CURR_CD AS currencyCode,
            TO_CHAR(NULL) AS payMethod,

            NVL(ITEM.IDI_DCLR_GDSNM, IR.IR_COMMENT) AS itemName,
            ITEM.IDI_HS_CD AS hsCode,
            TO_CHAR(ITEM.IDI_QTY, 'FM999,999,999') AS qty,
            ITEM.IDI_ORGN_CNTRY_CD AS origin,

            TO_CHAR(NULL) AS reviewMemo,
            TO_CHAR(NULL) AS reviewStartDate,
            TO_CHAR(NULL) AS acceptDate,

            IR.IR_COMMENT AS requestContent
        FROM IMP_RQST IR
        LEFT JOIN (
            SELECT *
            FROM (
                SELECT D.*,
                       ROW_NUMBER() OVER (
                           PARTITION BY D.ID_IR_NO
                           ORDER BY NVL(D.ID_RCEPT_DT, D.ID_DCLR_DT) DESC
                       ) AS RN
                FROM IMP_DCLR D
            )
            WHERE RN = 1
        ) ID ON ID.ID_IR_NO = IR.IR_NO
        LEFT JOIN BROKER B
            ON IR.IR_BROKER_ID = B.BROKER_ID
        LEFT JOIN OWNER OWR
            ON IR.IR_OWR_ID = OWR.OWR_ID
        LEFT JOIN IMP_DCLR_ITEM ITEM
            ON IR.IR_NO = ITEM.IDI_IR_NO
           AND ITEM.IDI_SN = (
                SELECT MIN(IDI_SN)
                FROM IMP_DCLR_ITEM
                WHERE IDI_IR_NO = IR.IR_NO
           )
        LEFT JOIN IMP_REQ_CNFM IRC
            ON IR.IR_NO = IRC.IRC_IR_NO
        LEFT JOIN OFFICER O
            ON NVL(ID.ID_OFFICER_ID, IRC.IRC_OFFICER_ID) = O.OFFICER_ID
        LEFT JOIN (
            SELECT *
            FROM (
                SELECT
                    A.*,
                    ROW_NUMBER() OVER (
                        PARTITION BY A.ARR_BIZ_TYPE_CD, A.ARR_REF_NO
                        ORDER BY A.ARR_REGIST_DT DESC
                    ) AS RN
                FROM AI_RISK_RESULT A
                WHERE A.ARR_BIZ_TYPE_CD = 'IMPORT'
            )
            WHERE RN = 1
        ) ARR
            ON ARR.ARR_REF_NO = IR.IR_NO
        WHERE IR.IR_NO = #{reqNo}
    </select>


    <!-- 수출 상세 -->
    <select id="selectExportDetail"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.BasicScreenDetailDTO">
        SELECT
            ER.ER_NO AS reqNo,
            '수출' AS declareType,
            TO_CHAR(ER.ER_RQST_DT, 'YYYY-MM-DD HH24:MI') AS requestDate,
            NVL(ED.ED_STATUS_CD, ER.ER_STATUS_CD) AS statusCd,
            ER.ER_TFG_NO AS tfgNo,

            ARR.ARR_SCORE AS riskScore,
            ARR.ARR_GRADE_CD AS riskGradeCd,
            ARR.ARR_STATUS_CD AS riskStatusCd,
            ARR.ARR_RESULT_CN AS riskResultCn,

            NVL(ER.ER_ONER_NM, ER.ER_OWR_ID) AS companyName,
            OWR.OWR_TELNO AS companyTel,
            ER.ER_CORP_REG_NO AS corpRegNo,
            ER.ER_CSTM_IDF_NO AS customsIdNo,
            B.BROKER_OFFICE_NM AS brokerName,

            ED.OFFICER_ID AS officerId,
            O.OFFICER_NM AS officerName,

            TO_CHAR(NULL) AS blNo,
            ER.ER_LOAD_PORT_CD AS arrivalPort,
            TO_CHAR(NULL) AS arrivalDate,
            TO_CHAR(NULL) AS cargoNo,

            TO_CHAR(ED.ED_DCLR_TOT_AMT_KRW, 'FM999,999,999,999') AS amount,
            ED.ED_CURR_CD AS currencyCode,
            TO_CHAR(NULL) AS payMethod,

            NVL(ITEM.EDI_EXPT_GDS_NM, ER.ER_COMMENT) AS itemName,
            ITEM.EDI_HS_CD AS hsCode,
            TO_CHAR(ITEM.EDI_DCLR_QTY, 'FM999,999,999') AS qty,
            ED.ED_PRPS_COUNTRY_CD AS origin,

            TO_CHAR(NULL) AS reviewMemo,
            TO_CHAR(NULL) AS reviewStartDate,
            TO_CHAR(NULL) AS acceptDate,

            ER.ER_COMMENT AS requestContent
        FROM EXP_RQST ER
        LEFT JOIN BROKER B
            ON ER.ER_BROKER_ID = B.BROKER_ID
        LEFT JOIN OWNER OWR
            ON ER.ER_OWR_ID = OWR.OWR_ID
        LEFT JOIN EXP_DCLR ED
            ON ER.ER_NO = ED.ED_ER_NO
        LEFT JOIN EXP_DCLR_ITEM ITEM
            ON ER.ER_NO = ITEM.EDI_ER_NO
           AND ITEM.EDI_SN = (
                SELECT MIN(EDI_SN)
                FROM EXP_DCLR_ITEM
                WHERE EDI_ER_NO = ER.ER_NO
           )
        LEFT JOIN OFFICER O
            ON ED.OFFICER_ID = O.OFFICER_ID
        LEFT JOIN (
            SELECT *
            FROM (
                SELECT
                    A.*,
                    ROW_NUMBER() OVER (
                        PARTITION BY A.ARR_BIZ_TYPE_CD, A.ARR_REF_NO
                        ORDER BY A.ARR_REGIST_DT DESC
                    ) AS RN
                FROM AI_RISK_RESULT A
                WHERE A.ARR_BIZ_TYPE_CD = 'EXPORT'
            )
            WHERE RN = 1
        ) ARR
            ON ARR.ARR_REF_NO = ER.ER_NO
        WHERE ER.ER_NO = #{reqNo}
    </select>


    <!-- 수입 품목 목록 -->
    <select id="selectImportItems"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.BasicScreenDetailDTO">
        SELECT
            IDI_SN                                                      AS itemNo,
            IDI_DCLR_GDSNM                                              AS itemName,
            IDI_TRDNG_GDSNM                                             AS tradeItemName,
            IDI_HS_CD                                                   AS hsCode,
            IDI_ORGN_CNTRY_CD                                           AS origin,
            TO_CHAR(IDI_QTY,          'FM999,999,999')                  AS qty,
            TO_CHAR(IDI_NET_WT,       'FM999,999,999.000')              AS weight,
            CASE WHEN IDI_TAXT_RT IS NULL THEN '-' ELSE TO_CHAR(IDI_TAXT_RT, 'FM990.00') || '%' END AS taxRate,
            TO_CHAR(IDI_TAXT_PRC_KRW, 'FM999,999,999,999')             AS amount,
            TO_CHAR(ROUND(IDI_TAXT_PRC_KRW * IDI_TAXT_RT),
                         'FM999,999,999,999')                           AS taxAmount,
            '미분석'                                                      AS riskGrade,
            '-'                                                         AS reqTarget,
            CASE
                WHEN EXISTS (
                    SELECT 1
                    FROM RJCT_MNG R
                    WHERE R.RM_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND R.RM_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                ) THEN 'ITEM_REJ'
                WHEN EXISTS (
                    SELECT 1
                    FROM CUSTOMS_STATUS_HISTORY H
                    WHERE H.CSH_SCOPE_CD = 'IMPORT_ITEM'
                      AND H.CSH_SRC_PK_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                ) THEN 'ITEM_ACPT'
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                ) THEN 'ITEM_SUPP_SUB'
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD = 'REQ'
                ) THEN 'ITEM_SUPP_REQ'
                ELSE 'ITEM_REVIEW'
            END                                                         AS itemStatusCd,
            NVL(
                (
                    SELECT RM_RJCT_CN
                    FROM (
                        SELECT R.RM_RJCT_CN
                        FROM RJCT_MNG R
                        WHERE R.RM_REF_BIZ_CD = 'IMPORT_ITEM'
                          AND R.RM_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                        ORDER BY R.RM_RJCT_DT DESC
                    )
                    WHERE ROWNUM = 1
                ),
                NVL(
                    (
                        SELECT SR_SUBMIT_CN
                        FROM (
                            SELECT S.SR_SUBMIT_CN
                            FROM SUPP_RQST S
                            WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                              AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                              AND S.SR_STATUS_CD = 'SUB'
                            ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                        )
                        WHERE ROWNUM = 1
                    ),
                    NVL(
                        (
                            SELECT SR_REQ_CN
                            FROM (
                                SELECT S.SR_REQ_CN
                                FROM SUPP_RQST S
                                WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                                  AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                                  AND S.SR_STATUS_CD = 'REQ'
                                ORDER BY S.SR_REQ_DT DESC
                            )
                            WHERE ROWNUM = 1
                        ),
                        (
                            SELECT CSH_MSG
                            FROM (
                                SELECT H.CSH_MSG
                                FROM CUSTOMS_STATUS_HISTORY H
                                WHERE H.CSH_SCOPE_CD = 'IMPORT_ITEM'
                                  AND H.CSH_SRC_PK_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                                  AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                                ORDER BY H.CSH_DT DESC
                            )
                            WHERE ROWNUM = 1
                        )
                    )
                )
            )                                                           AS itemRemark,
            CASE
                WHEN EXISTS (
                    SELECT 1
                    FROM RJCT_MNG R
                    WHERE R.RM_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND R.RM_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                ) THEN (
                    SELECT TO_CHAR(RM_RJCT_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT R.RM_RJCT_DT
                        FROM RJCT_MNG R
                        WHERE R.RM_REF_BIZ_CD = 'IMPORT_ITEM'
                          AND R.RM_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                        ORDER BY R.RM_RJCT_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM CUSTOMS_STATUS_HISTORY H
                    WHERE H.CSH_SCOPE_CD = 'IMPORT_ITEM'
                      AND H.CSH_SRC_PK_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                ) THEN (
                    SELECT TO_CHAR(CSH_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT H.CSH_DT
                        FROM CUSTOMS_STATUS_HISTORY H
                        WHERE H.CSH_SCOPE_CD = 'IMPORT_ITEM'
                          AND H.CSH_SRC_PK_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                          AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                        ORDER BY H.CSH_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                ) THEN (
                    SELECT TO_CHAR(NVL(SR_SUBMIT_DT, SR_REQ_DT), 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT S.SR_SUBMIT_DT, S.SR_REQ_DT
                        FROM SUPP_RQST S
                        WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                          AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                          AND S.SR_STATUS_CD = 'SUB'
                        ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD = 'REQ'
                ) THEN (
                    SELECT TO_CHAR(SR_REQ_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT S.SR_REQ_DT
                        FROM SUPP_RQST S
                        WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                          AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                          AND S.SR_STATUS_CD = 'REQ'
                        ORDER BY S.SR_REQ_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                ELSE NULL
            END                                                         AS itemHistoryDate,

            (
                SELECT TO_CHAR(SR_REQ_DT, 'YYYY-MM-DD HH24:MI')
                FROM (
                    SELECT S.SR_REQ_DT
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                    ORDER BY S.SR_REQ_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppReqDate,

            (
                SELECT SR_REQ_CN
                FROM (
                    SELECT S.SR_REQ_CN
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                    ORDER BY S.SR_REQ_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppReqCn,

            (
                SELECT TO_CHAR(SR_SUBMIT_DT, 'YYYY-MM-DD HH24:MI')
                FROM (
                    SELECT S.SR_SUBMIT_DT
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                      AND S.SR_SUBMIT_DT IS NOT NULL
                    ORDER BY S.SR_SUBMIT_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppSubmitDate,

            (
                SELECT SR_SUBMIT_CN
                FROM (
                    SELECT S.SR_SUBMIT_CN
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'IMPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.IDI_IR_NO || '-' || ITEM.IDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                      AND S.SR_SUBMIT_CN IS NOT NULL
                    ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppSubmitCn,
            /* ── 세금·허가 심사 필수 추가 컬럼 ──────────────────────────
               아래 컬럼명은 추정값입니다. IMP_DCLR_ITEM 실제 DDL 확인 후 수정하세요.
               IDI_TAXT_TP_CD      → 관세구분 (일반/협정/잠정세율 등)
               IDI_ORGN_DTN_STD_CD → 원산지결정기준 (WO/CTH/RVC 등)
               IDI_TAX_RDCT_CD     → 관세감면구분
               IDI_TAXT_AMT        → 관세액 (순수 관세액)
               IDI_VAT_AMT         → 부가세액
               컬럼이 없다면 해당 줄을 TO_CHAR(NULL) AS ... 로 유지하세요. */
            TO_CHAR(NULL)                                               AS customsDutyType,
            TO_CHAR(NULL)                                               AS originCriteria,
            TO_CHAR(NULL)                                               AS taxExemption,
            TO_CHAR(ROUND(IDI_TAXT_PRC_KRW * IDI_TAXT_RT),
                         'FM999,999,999,999')                           AS taxAmt,
            TO_CHAR(NULL)                                               AS vatAmount
        FROM IMP_DCLR_ITEM ITEM
        WHERE ITEM.IDI_IR_NO = #{reqNo}
        ORDER BY IDI_SN
    </select>


    <!-- 수출 품목 목록 -->
    <select id="selectExportItems"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.BasicScreenDetailDTO">
        SELECT
            EDI_SN                                                      AS itemNo,
            EDI_EXPT_GDS_NM                                             AS itemName,
            EDI_TRDNG_GDS_NM                                            AS tradeItemName,
            EDI_HS_CD                                                   AS hsCode,
            TO_CHAR(NULL)                                               AS origin,
            TO_CHAR(EDI_DCLR_QTY,    'FM999,999,999')                  AS qty,
            TO_CHAR(EDI_NET_WT,      'FM999,999,999.000')               AS weight,
            TO_CHAR(NULL)                                               AS taxRate,
            TO_CHAR(EDI_DCLR_PRC_KRW,'FM999,999,999,999')              AS amount,
            TO_CHAR(NULL)                                               AS taxAmount,
            '미분석'                                                      AS riskGrade,
            '-'                                                         AS reqTarget,
            CASE
                WHEN EXISTS (
                    SELECT 1
                    FROM RJCT_MNG R
                    WHERE R.RM_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND R.RM_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                ) THEN 'ITEM_REJ'
                WHEN EXISTS (
                    SELECT 1
                    FROM CUSTOMS_STATUS_HISTORY H
                    WHERE H.CSH_SCOPE_CD = 'EXPORT_ITEM'
                      AND H.CSH_SRC_PK_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                ) THEN 'ITEM_ACPT'
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                ) THEN 'ITEM_SUPP_SUB'
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'REQ'
                ) THEN 'ITEM_SUPP_REQ'
                ELSE 'ITEM_REVIEW'
            END                                                         AS itemStatusCd,
            NVL(
                (
                    SELECT RM_RJCT_CN
                    FROM (
                        SELECT R.RM_RJCT_CN
                        FROM RJCT_MNG R
                        WHERE R.RM_REF_BIZ_CD = 'EXPORT_ITEM'
                          AND R.RM_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                        ORDER BY R.RM_RJCT_DT DESC
                    )
                    WHERE ROWNUM = 1
                ),
                NVL(
                    (
                        SELECT SR_SUBMIT_CN
                        FROM (
                            SELECT S.SR_SUBMIT_CN
                            FROM SUPP_RQST S
                            WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                              AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                              AND S.SR_STATUS_CD = 'SUB'
                            ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                        )
                        WHERE ROWNUM = 1
                    ),
                    NVL(
                        (
                            SELECT SR_REQ_CN
                            FROM (
                                SELECT S.SR_REQ_CN
                                FROM SUPP_RQST S
                                WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                                  AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                                  AND S.SR_STATUS_CD = 'REQ'
                                ORDER BY S.SR_REQ_DT DESC
                            )
                            WHERE ROWNUM = 1
                        ),
                        (
                            SELECT CSH_MSG
                            FROM (
                                SELECT H.CSH_MSG
                                FROM CUSTOMS_STATUS_HISTORY H
                                WHERE H.CSH_SCOPE_CD = 'EXPORT_ITEM'
                                  AND H.CSH_SRC_PK_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                                  AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                                ORDER BY H.CSH_DT DESC
                            )
                            WHERE ROWNUM = 1
                        )
                    )
                )
            )                                                           AS itemRemark,
            CASE
                WHEN EXISTS (
                    SELECT 1
                    FROM RJCT_MNG R
                    WHERE R.RM_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND R.RM_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                ) THEN (
                    SELECT TO_CHAR(RM_RJCT_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT R.RM_RJCT_DT
                        FROM RJCT_MNG R
                        WHERE R.RM_REF_BIZ_CD = 'EXPORT_ITEM'
                          AND R.RM_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                        ORDER BY R.RM_RJCT_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM CUSTOMS_STATUS_HISTORY H
                    WHERE H.CSH_SCOPE_CD = 'EXPORT_ITEM'
                      AND H.CSH_SRC_PK_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                ) THEN (
                    SELECT TO_CHAR(CSH_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT H.CSH_DT
                        FROM CUSTOMS_STATUS_HISTORY H
                        WHERE H.CSH_SCOPE_CD = 'EXPORT_ITEM'
                          AND H.CSH_SRC_PK_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                          AND H.CSH_AFTER_STATUS_CD = 'ITEM_ACPT'
                        ORDER BY H.CSH_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                ) THEN (
                    SELECT TO_CHAR(NVL(SR_SUBMIT_DT, SR_REQ_DT), 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT S.SR_SUBMIT_DT, S.SR_REQ_DT
                        FROM SUPP_RQST S
                        WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                          AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                          AND S.SR_STATUS_CD = 'SUB'
                        ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                    )
                    WHERE ROWNUM = 1
                )
                WHEN EXISTS (
                    SELECT 1
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'REQ'
                ) THEN (
                    SELECT TO_CHAR(SR_REQ_DT, 'YYYY-MM-DD HH24:MI')
                    FROM (
                        SELECT S.SR_REQ_DT
                        FROM SUPP_RQST S
                        WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                          AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                          AND S.SR_STATUS_CD = 'REQ'
                        ORDER BY S.SR_REQ_DT DESC
                    )
                    WHERE ROWNUM = 1
                )
                ELSE NULL
            END                                                         AS itemHistoryDate,

            (
                SELECT TO_CHAR(SR_REQ_DT, 'YYYY-MM-DD HH24:MI')
                FROM (
                    SELECT S.SR_REQ_DT
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                    ORDER BY S.SR_REQ_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppReqDate,

            (
                SELECT SR_REQ_CN
                FROM (
                    SELECT S.SR_REQ_CN
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                    ORDER BY S.SR_REQ_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppReqCn,

            (
                SELECT TO_CHAR(SR_SUBMIT_DT, 'YYYY-MM-DD HH24:MI')
                FROM (
                    SELECT S.SR_SUBMIT_DT
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                      AND S.SR_SUBMIT_DT IS NOT NULL
                    ORDER BY S.SR_SUBMIT_DT DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppSubmitDate,

            (
                SELECT SR_SUBMIT_CN
                FROM (
                    SELECT S.SR_SUBMIT_CN
                    FROM SUPP_RQST S
                    WHERE S.SR_REF_BIZ_CD = 'EXPORT_ITEM'
                      AND S.SR_REF_NO = ITEM.EDI_ER_NO || '-' || ITEM.EDI_SN
                      AND S.SR_STATUS_CD = 'SUB'
                      AND S.SR_SUBMIT_CN IS NOT NULL
                    ORDER BY NVL(S.SR_SUBMIT_DT, S.SR_REQ_DT) DESC
                )
                WHERE ROWNUM = 1
            )                                                           AS suppSubmitCn,
            /* ── 세금·허가 심사 필수 추가 컬럼 ──────────────────────────
               아래 컬럼명은 추정값입니다. EXP_DCLR_ITEM 실제 DDL 확인 후 수정하세요.
               EDI_TAXT_TP_CD      → 관세구분
               EDI_ORGN_DTN_STD_CD → 원산지결정기준
               EDI_TAX_RDCT_CD     → 관세감면구분
               EDI_TAXT_AMT        → 관세액
               EDI_VAT_AMT         → 부가세액 */
            TO_CHAR(NULL)                                               AS customsDutyType,
            TO_CHAR(NULL)                                               AS originCriteria,
            TO_CHAR(NULL)                                               AS taxExemption,
            TO_CHAR(NULL)                                               AS taxAmt,
            TO_CHAR(NULL)                                               AS vatAmount
        FROM EXP_DCLR_ITEM ITEM
        WHERE ITEM.EDI_ER_NO = #{reqNo}
        ORDER BY EDI_SN
    </select>


    <!-- 품목 처리 대상 관세사 조회 -->
    <select id="selectTargetBrokerId" parameterType="string" resultType="string">
        SELECT brokerId
        FROM (
            SELECT IR_BROKER_ID AS brokerId
            FROM IMP_RQST
            WHERE IR_NO = #{reqNo}
            UNION ALL
            SELECT ER_BROKER_ID AS brokerId
            FROM EXP_RQST
            WHERE ER_NO = #{reqNo}
        )
        WHERE ROWNUM = 1
    </select>

    <!-- 란사항 보완요청 저장: SUPP_RQST 사용 -->
    <insert id="insertItemSupplement" parameterType="map">
        INSERT INTO SUPP_RQST (
            SR_NO,
            SR_REF_BIZ_CD,
            SR_REF_NO,
            SENDER_ID,
            SENDER_TY_CD,
            RECEIVER_ID,
            RECEIVER_TY_CD,
            SR_STATUS_CD,
            SR_REQ_DT,
            SR_REQ_CN
        ) VALUES (
            'SR' || SUBSTR(RAWTOHEX(SYS_GUID()), 1, 28),
            #{refBizCd},
            #{refNo},
            #{officerId},
            'OFFICER',
            #{targetId},
            'BROKER',
            'REQ',
            SYSDATE,
            #{reason}
        )
    </insert>

    <!-- 란사항 반려 저장: RJCT_MNG 사용 -->
    <insert id="insertItemReject" parameterType="map">
        INSERT INTO RJCT_MNG (
            RM_NO,
            RM_REF_BIZ_CD,
            RM_REF_NO,
            RM_RJCT_DT,
            RM_RJCT_CN,
            RM_RJCTR_ID,
            RM_TARGET_ID
        ) VALUES (
            'RM' || SUBSTR(RAWTOHEX(SYS_GUID()), 1, 28),
            #{refBizCd},
            #{refNo},
            SYSDATE,
            #{reason},
            #{officerId},
            #{targetId}
        )
    </insert>

    <!-- 란사항 수리 저장: CUSTOMS_STATUS_HISTORY 사용 -->
    <insert id="insertItemAcceptHistory" parameterType="map">
        INSERT INTO CUSTOMS_STATUS_HISTORY (
            CSH_PAY_SCHD_NO,
            CSH_SCOPE_CD,
            CSH_EVENT_TYPE_CD,
            CSH_BEFORE_STATUS_CD,
            CSH_AFTER_STATUS_CD,
            CSH_ACTOR_ROLE_CD,
            CSH_PUBLIC_YN,
            CSH_SRC_TABLE_CD,
            CSH_SRC_PK_NO,
            CSH_MSG,
            CSH_DT
        ) VALUES (
            (SELECT NVL(MAX(CSH_PAY_SCHD_NO), 0) + 1 FROM CUSTOMS_STATUS_HISTORY),
            #{refBizCd},
            'ITEM_ACPT',
            NULL,
            'ITEM_ACPT',
            'OFFICER',
            'Y',
            CASE WHEN #{refBizCd} = 'IMPORT_ITEM' THEN 'IMP_DCLR_ITEM' ELSE 'EXP_DCLR_ITEM' END,
            #{refNo},
            NVL(#{reason}, '란사항 수리 처리'),
            SYSDATE
        )
    </insert>

</mapper>