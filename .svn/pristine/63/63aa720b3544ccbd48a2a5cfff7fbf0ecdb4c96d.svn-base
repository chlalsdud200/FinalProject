<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.transport.export.mapper.ExportTransportMapper">

    <select id="retriveExpTransportReqList"
            resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT *
        FROM (
            SELECT Q.*,
                   ROW_NUMBER() OVER (PARTITION BY Q.trcNo ORDER BY Q.requestDt DESC NULLS LAST, Q.trcNo DESC) AS rn
            FROM (
                SELECT
        T.TRC_NO AS trcNo,
        T.TRC_OWR_ID AS ownerId,
        O.OWR_NM AS ownerNm,
        O.OWR_NM AS ownerPicNm,
        O.OWR_EMAIL AS ownerEmail,
        O.OWR_TELNO AS ownerTelno,
        O.OWR_ADRES AS ownerAdres,
        O.OWR_DETAIL_ADRES AS ownerDetailAdres,
        T.TRC_TRDR_NM AS buyerNm,
        NVL(T.TRC_TRDR_COUNTRY_CD, TD.TRDR_COUNTRY_CD) AS buyerCountryCd,
        TD.TRDR_ADRES AS buyerAdres,
        TD.TRDR_TELNO AS buyerTelno,
        T.TRC_TRAN_MN_CD AS transportMeanCd,
        CASE T.TRC_TRAN_MN_CD
        WHEN 'SEA' THEN '해상'
        WHEN 'AIR' THEN '항공'
        WHEN 'LAND' THEN '육상'
        ELSE T.TRC_TRAN_MN_CD
        END AS transportMeanNm,
        T.TRC_TRAN_TY_CD AS transportTypeCd,
        T.TRC_INCO_TERMS_CD AS incoTermsCd,
        T.TRC_DEPT_PORT_CD AS deptPortCd,
        CASE NVL(DP.PORT_NM, T.TRC_DEPT_PORT_CD)
        WHEN 'KPPUS' THEN '부산항'
        WHEN 'KRPUS' THEN '부산항'
        WHEN 'BUSAN' THEN '부산항'
        ELSE NVL(DP.PORT_NM, T.TRC_DEPT_PORT_CD)
        END AS deptPortNm,
        T.TRC_ARVL_PORT_CD AS arvlPortCd,
        CASE NVL(AP.PORT_NM, T.TRC_ARVL_PORT_CD)
        WHEN 'KPPUS' THEN '부산항'
        WHEN 'KRPUS' THEN '부산항'
        WHEN 'BUSAN' THEN '부산항'
        ELSE NVL(AP.PORT_NM, T.TRC_ARVL_PORT_CD)
        END AS arvlPortNm,
        T.TRC_STATUS_CD AS statusCd,
        CASE T.TRC_STATUS_CD
        WHEN 'TRC_WAIT' THEN '접수대기'
        WHEN 'TRC_DONE' THEN '접수완료'
        WHEN 'TRC_REJECT' THEN '접수반려'
        WHEN 'TRC_END' THEN '완료대기'
        WHEN 'TRC_COMPLETE' THEN '최종완료'
        WHEN 'REQUESTED' THEN '접수대기'
        WHEN 'ACCEPTED' THEN '접수완료'
        WHEN 'REJECTED' THEN '접수반려'
        WHEN '접수대기' THEN '접수대기'
        WHEN '접수완료' THEN '접수완료'
        WHEN '접수반려' THEN '접수반려'
        ELSE T.TRC_STATUS_CD
        END AS statusNm,
        CASE T.TRC_STATUS_CD
        WHEN 'TRC_WAIT' THEN '접수대기'
        WHEN 'TRC_DONE' THEN '접수완료'
        WHEN 'TRC_REJECT' THEN '접수반려'
        WHEN 'TRC_END' THEN '완료대기'
        WHEN 'TRC_COMPLETE' THEN '최종완료'
        WHEN 'REQUESTED' THEN '접수대기'
        WHEN 'ACCEPTED' THEN '접수완료'
        WHEN 'REJECTED' THEN '접수반려'
        WHEN '접수대기' THEN '접수대기'
        WHEN '접수완료' THEN '접수완료'
        WHEN '접수반려' THEN '접수반려'
        ELSE T.TRC_STATUS_CD
        END AS requestDisplayStatusNm,
        TO_CHAR(T.TRC_RQST_DT, 'YYYY-MM-DD HH24:MI') AS requestDt,
        TO_CHAR(T.TRC_RCEPT_DT, 'YYYY-MM-DD HH24:MI') AS doReceiveDt,
        T.TRC_RQST_CN AS requestCn,
        T.TRC_SE_CD AS seCd,
        T.TRC_TFG_NO AS ggNo,
        T.TRC_TFG_NO AS manifestTfgNo,
        W.WIR_NO AS wirNo,
        W.WIR_NO AS inboundReqNo,
        W.WIR_NO AS inboundRequestNo,
        W.WIR_STATUS_CD AS warehouseInStatusCd,
        CASE
        WHEN W.WIR_STATUS_CD = 'WAIT' THEN '입고대기'
        WHEN W.WIR_STATUS_CD = 'REQ_SENT' THEN '보완제출완료'
        WHEN W.WIR_STATUS_CD = 'REQ_FIX' THEN '보완요청'
        WHEN W.WIR_STATUS_CD = 'IN_DONE' THEN '입고완료'
        ELSE W.WIR_STATUS_CD
        END AS warehouseInStatusNm,
        W.WIR_WH_REPLY_STATUS_CD AS warehouseReplyStatusCd,
        CASE
        WHEN W.WIR_WH_REPLY_STATUS_CD = 'WAIT' THEN '회신대기'
        WHEN W.WIR_WH_REPLY_STATUS_CD = 'REQ_FIX' THEN '보완요청'
        WHEN W.WIR_WH_REPLY_STATUS_CD = 'REQ_SENT' THEN '보완제출완료'
        WHEN W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE' THEN '입고완료'
        ELSE W.WIR_WH_REPLY_STATUS_CD
        END AS warehouseReplyStatusNm,
        W.WIR_WM_ID AS wmId,
        W.WIR_WM_ID AS warehouseManagerId,
        W.WIR_WZ_NO AS wzNo,
        W.WIR_WZ_NO AS bondedZoneNo,
        WZ.WZ_NM AS warehouseZoneNm,
        TO_CHAR(W.WIR_IN_PLAN_DT, 'YYYY-MM-DD') AS inPlanDt,
        W.WIR_CARGO_MGMT_NO AS cargoMgmtNo,
        W.WIR_INVOICE_NO AS invoiceNo,
        NVL(W.WIR_INCO_TERMS_CD, T.TRC_INCO_TERMS_CD) AS incoterms,
        W.WIR_RQST_CN AS requestNote,
        NVL(EDI.EDI_EXPT_GDS_NM, T.TRC_ITEM_CTGRY_NM) AS itemCategory,
        NVL(EDI.EDI_EXPT_GDS_NM, T.TRC_ITEM_CTGRY_NM) AS goodsName,
        ED.ED_ER_NO AS exportDeclNo,
        ED.ED_STATUS_CD AS exportDeclStatusCd,
        TO_CHAR(ED.ED_DCLR_DT, 'YYYY-MM-DD') AS exportDeclDt,
        EDI.EDI_DCLR_QTY AS itemQty,
        T.TRC_SHIP_NO AS shipNo,
        NVL(S.SHIP_CP_NM, T.TRC_TRAN_MN_CD) AS carrierNm,
        BI.BI_MBL_NO AS mblNo,
        BI.BI_HBL_NO AS hblNo,
        NVL(BI.BI_HBL_NO, BI.BI_MBL_NO) AS blNo,
        BI.BI_STATUS_CD AS blStatusCd,
        BI.BI_STL_STATUS_CD AS settlementStatusCd,
        INV_FILE.DFI_ORG_NM AS invoiceFile,
        INV_FILE.DFI_FILE_NO AS invoiceFileNo,
        PKG_FILE.DFI_ORG_NM AS packingListFile,
        PKG_FILE.DFI_FILE_NO AS packingListFileNo,
        COALESCE(T.TRC_RJCT_RSN, T.TRC_REJ_MEMO) AS rejectReason,
        T.TRC_REJ_TYPE AS rejectType,
        T.TRC_REJ_MEMO AS rejectMemo
        FROM TRAN_RCP T
        JOIN "OWNER" O
        ON T.TRC_OWR_ID = O.OWR_ID
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_IO_SE_CD = 'EXP'
        AND (
        W.WIR_NO = T.TRC_NO
        OR W.WIR_GG_NO = T.TRC_TFG_NO
        )
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = W.WIR_WZ_NO
        LEFT JOIN SHIP S
        ON S.SHIP_NO = T.TRC_SHIP_NO
        LEFT JOIN PORT DP
        ON T.TRC_DEPT_PORT_CD = DP.PORT_CD
        LEFT JOIN PORT AP
        ON T.TRC_ARVL_PORT_CD = AP.PORT_CD
        LEFT JOIN TRDR TD
        ON T.TRC_TRDR_NM = TD.TRDR_NM
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        LEFT JOIN EXP_DCLR ED
        ON ED.ED_GG_NO = T.TRC_TFG_NO
        AND NVL(ED.ED_TRDE_SE_CD, 'EXP') = 'EXP'
        LEFT JOIN (
        SELECT
        EDI_ER_NO,
        MAX(EDI_EXPT_GDS_NM) AS EDI_EXPT_GDS_NM,
        SUM(NVL(EDI_DCLR_QTY, 0)) AS EDI_DCLR_QTY
        FROM EXP_DCLR_ITEM
        GROUP BY EDI_ER_NO
        ) EDI
        ON EDI.EDI_ER_NO = ED.ED_ER_NO
        LEFT JOIN TACS_FILE_MAP INV_MAP
        ON INV_MAP.TFM_TFG_NO = T.TRC_TFG_NO
        AND (INV_MAP.TFM_DOC_TY_CD IN ('INVOICE', 'EXP_INVOICE') OR INV_MAP.TFM_DOC_TY_CD IS NULL)
        LEFT JOIN DOCS_FILE_DATA INV_FILE
        ON INV_FILE.DFI_FILE_NO = INV_MAP.TFM_DFI_NO
        AND INV_FILE.DFI_DEL_YN = 'N'
        AND INV_FILE.DFI_UPLOAD_STTS_CD = 'DONE'
        AND INV_FILE.DFI_DRIVE_FILE_ID IS NOT NULL
        AND (
        INV_MAP.TFM_DOC_TY_CD IN ('INVOICE', 'EXP_INVOICE')
        OR LOWER(INV_FILE.DFI_ORG_NM) LIKE '%invoice%'
        OR INV_FILE.DFI_ORG_NM LIKE '%송장%'
        )
        LEFT JOIN TACS_FILE_MAP PKG_MAP
        ON PKG_MAP.TFM_TFG_NO = T.TRC_TFG_NO
        AND (PKG_MAP.TFM_DOC_TY_CD IN ('PACKING_LIST', 'EXP_PACKING_LIST') OR PKG_MAP.TFM_DOC_TY_CD IS NULL)
        LEFT JOIN DOCS_FILE_DATA PKG_FILE
        ON PKG_FILE.DFI_FILE_NO = PKG_MAP.TFM_DFI_NO
        AND PKG_FILE.DFI_DEL_YN = 'N'
        AND PKG_FILE.DFI_UPLOAD_STTS_CD = 'DONE'
        AND PKG_FILE.DFI_DRIVE_FILE_ID IS NOT NULL
        AND (
        PKG_MAP.TFM_DOC_TY_CD IN ('PACKING_LIST', 'EXP_PACKING_LIST')
        OR LOWER(PKG_FILE.DFI_ORG_NM) LIKE '%packing%'
        OR LOWER(PKG_FILE.DFI_ORG_NM) LIKE '%pack%'
        OR PKG_FILE.DFI_ORG_NM LIKE '%패킹%'
        OR PKG_FILE.DFI_ORG_NM LIKE '%포장%'
        )
        WHERE T.TRC_SE_CD = 'EXPORT'
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
            ) Q
        )
        WHERE rn = 1
        ORDER BY requestDt DESC NULLS LAST, trcNo DESC
    </select>

    <select id="retriveExpInboundReqList"
            resultType="kr.or.tacs.vo.transport.TransportInboundRequestVO">
        SELECT
        T.TRC_NO AS requestNo,
        O.OWR_NM AS owner,
        T.TRC_TRDR_NM AS listParty,
        TO_CHAR(NVL(W.WIR_IN_PLAN_DT, T.TRC_RCEPT_DT), 'YYYY-MM-DD HH24:MI') AS listAt,
        CASE
        WHEN W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED', '반려', '창고반려') THEN '창고반려'
        WHEN W.WIR_STATUS_CD IN ('IN_DONE', 'DONE', '입고완료') THEN '입고완료'
        WHEN W.WIR_STATUS_CD IN ('REQ_FIX', '보완요청') THEN '보완요청'
        WHEN W.WIR_STATUS_CD IN ('REQ_SENT', 'SENT', '보완제출완료') THEN '보완제출완료'
        WHEN W.WIR_STATUS_CD IN ('WAIT', '입고대기', '입고요청대기') THEN '입고대기'
        WHEN W.WIR_NO IS NULL THEN '입고요청대기'
        ELSE W.WIR_STATUS_CD
        END AS listStatus,
        NVL(TO_CHAR(W.WIR_NO), T.TRC_NO) AS inboundRequestNo,
        W.WIR_WM_ID AS warehouseManagerId,
        TO_CHAR(W.WIR_WZ_NO) AS warehouseAreaNo,
        NVL(WZ.WZ_NM, TO_CHAR(W.WIR_WZ_NO)) AS targetWarehouse,
        TO_CHAR(W.WIR_IN_PLAN_DT, 'YYYY-MM-DD"T"HH24:MI') AS inboundPlanDt,
        CASE
        WHEN W.WIR_STATUS_CD IN ('IN_DONE', 'DONE', '입고완료') THEN '입고완료'
        WHEN W.WIR_STATUS_CD IN ('REQ_FIX', '보완요청') THEN '보완요청'
        WHEN W.WIR_STATUS_CD IN ('REQ_SENT', 'SENT', '보완제출완료') THEN '보완제출완료'
        WHEN W.WIR_STATUS_CD IN ('WAIT', '입고대기', '입고요청대기') THEN '입고대기'
        WHEN W.WIR_NO IS NULL THEN '입고요청대기'
        ELSE W.WIR_STATUS_CD
        END AS requestStatus,
        CASE
        WHEN W.WIR_WH_REPLY_STATUS_CD IN ('WAIT', '회신대기') THEN '회신대기'
        WHEN W.WIR_WH_REPLY_STATUS_CD IN ('REJECT', 'REJECTED', '반려', '창고반려') THEN '반려'
        WHEN W.WIR_WH_REPLY_STATUS_CD IN ('DONE', 'ACCEPT', 'ACCEPTED', '승인') THEN '승인'
        ELSE NVL(W.WIR_WH_REPLY_STATUS_CD, '회신대기')
        END AS warehouseReplyStatus,
        W.WIR_INVOICE_NO AS invoiceNo,
        CASE
        WHEN W.WIR_INVOICE_YMD IS NULL THEN NULL
        WHEN LENGTH(W.WIR_INVOICE_YMD) = 8
        THEN SUBSTR(W.WIR_INVOICE_YMD, 1, 4) || '-' ||
        SUBSTR(W.WIR_INVOICE_YMD, 5, 2) || '-' ||
        SUBSTR(W.WIR_INVOICE_YMD, 7, 2)
        ELSE W.WIR_INVOICE_YMD
        END AS invoiceDt,
        W.WIR_CARGO_MGMT_NO AS inboundCargoNo,
        O.OWR_NM AS shipper,
        T.TRC_TRDR_NM AS consignee,
        NVL(W.WIR_INCO_TERMS_CD, T.TRC_INCO_TERMS_CD) AS incoterms,
        W.WIR_RQST_CN AS requestNote,
        NULL AS rejectReason
        FROM TRAN_RCP T
        JOIN "OWNER" O
        ON T.TRC_OWR_ID = O.OWR_ID
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_NO = T.TRC_NO
        AND W.WIR_IO_SE_CD = 'EXP'
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON W.WIR_WZ_NO = WZ.WZ_NO
        WHERE T.TRC_SE_CD = 'EXPORT'
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        ORDER BY T.TRC_NO
    </select>

    <!-- 수출 적하목록 작성 및 제출 목록 조회 -->
    <select id="retriveExpManifestList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        T.TRC_NO                                            AS trcNo
        , W.WIR_NO                                            AS wirNo
        , NVL(W.WIR_GG_NO, T.TRC_TFG_NO)                      AS ggNo
        , T.TRC_OWR_ID                                        AS ownerId
        , O.OWR_NM                                            AS ownerNm
        , O.OWR_TELNO                                         AS ownerTelno
        , O.OWR_EMAIL                                         AS ownerEmail
        , T.TRC_TRDR_NM                                       AS buyerNm
        , T.TRC_TRDR_COUNTRY_CD                               AS buyerCountryCd
        , W.WIR_INVOICE_NO                                    AS invoiceNo
        , INV_FILE.DFI_ORG_NM                                  AS invoiceFile
        , PKG_FILE.DFI_ORG_NM                                  AS packingListFile
        , W.WIR_CARGO_MGMT_NO                                 AS cargoMgmtNo
        , W.WIR_IO_SE_CD                                      AS ioSeCd
        , W.WIR_STATUS_CD                                     AS warehouseInStatusCd
        , W.WIR_WH_REPLY_STATUS_CD                            AS warehouseReplyStatusCd
        , NVL(W.WIR_STATUS_CD, '입고완료')                     AS warehouseInStatusNm
        , W.WIR_WZ_NO                                         AS wzNo
        , W.WIR_WZ_NO                                         AS bondedZoneNo
        , W.WIR_WZ_NO                                         AS warehouseZoneNm
        , W.WIR_WM_ID                                         AS wmId
        , W.WIR_WM_ID                                         AS bondedManagerId
        , W.WIR_WM_ID                                         AS warehouseManagerNm
        , TO_CHAR(W.WIR_IN_PLAN_DT, 'YYYY-MM-DD')             AS inPlanDt
        , CASE
        WHEN SR.SR_STATUS_CD = 'REQ' THEN 'SUPPLEMENT'
        WHEN M.ECM_NO IS NULL THEN 'DRAFT'
        ELSE 'SUBMITTED'
        END                                                 AS statusCd
        , CASE
        WHEN SR.SR_STATUS_CD = 'REQ' THEN '보완요청'
        WHEN M.ECM_NO IS NULL THEN '작성대기'
        ELSE '제출완료'
        END                                                 AS statusNm
        , CASE
        WHEN SR.SR_STATUS_CD = 'REQ' THEN 'SUPPLEMENT'
        WHEN M.ECM_NO IS NULL THEN 'DRAFT'
        ELSE 'SUBMITTED'
        END                                                 AS manifestStatusCd
        , CASE
        WHEN SR.SR_STATUS_CD = 'REQ' THEN '보완요청'
        WHEN M.ECM_NO IS NULL THEN '작성대기'
        ELSE '제출완료'
        END                                                 AS manifestStatusNm
        , M.ECM_NO                                            AS manifestNo
        , BI.BI_MBL_NO                                        AS mblNo
        , NVL(M.ECM_BL_NO, BI.BI_HBL_NO)                      AS hblNo
        , NVL(M.ECM_BL_NO, NVL(BI.BI_HBL_NO, BI.BI_MBL_NO))   AS blNo
        , CASE
        WHEN NVL(M.ECM_BL_NO, BI.BI_HBL_NO) IS NULL THEN NULL
        WHEN LOWER(NVL(M.ECM_BL_NO, BI.BI_HBL_NO)) LIKE '%.pdf' THEN NVL(M.ECM_BL_NO, BI.BI_HBL_NO)
        ELSE NVL(M.ECM_BL_NO, BI.BI_HBL_NO) || '.pdf'
        END                                                 AS requestFile
        , NVL(S.SHIP_CP_NM, T.TRC_TRAN_MN_CD)                 AS carrierNm
        , T.TRC_DEPT_PORT_CD                                  AS deptPortCd
        , CASE NVL(DP.PORT_NM, T.TRC_DEPT_PORT_CD)
          WHEN 'KPPUS' THEN '부산항'
          WHEN 'KRPUS' THEN '부산항'
          WHEN 'BUSAN' THEN '부산항'
          ELSE NVL(DP.PORT_NM, T.TRC_DEPT_PORT_CD)
          END                                                 AS deptPortNm
        , T.TRC_ARVL_PORT_CD                                  AS arvlPortCd
        , CASE NVL(AP.PORT_NM, T.TRC_ARVL_PORT_CD)
          WHEN 'KPPUS' THEN '부산항'
          WHEN 'KRPUS' THEN '부산항'
          WHEN 'BUSAN' THEN '부산항'
          ELSE NVL(AP.PORT_NM, T.TRC_ARVL_PORT_CD)
          END                                                 AS arvlPortNm
        , TO_CHAR(T.TRC_RCEPT_DT, 'YYYY-MM-DD')               AS eta
        , TO_CHAR(M.ECM_SBMSN_DT, 'YYYY-MM-DD')               AS manifestSubmitDt
        , TRIM(REGEXP_REPLACE(M.ECM_RMRK_CN, ' *\[(WIR_NO|TRC_NO):[^]]+\]', '')) AS manifestRemark
        , M.ECM_TFG_NO                                        AS manifestTfgNo
        , MF_FILE.DFI_ORG_NM                                  AS manifestPdfFile
        , SR.SR_NO                                            AS supplementNo
        , SR.SR_REF_NO                                        AS supplementRefNo
        , SR.SENDER_ID                                        AS supplementSenderId
        , SR.RECEIVER_ID                                      AS supplementReceiverId
        , SRI.SRI_TY_CD                                       AS supplementTypeCd
        , SRI.SRI_REQ_CN                                      AS rejectReason
        , C.CG_NO                                             AS cgNo
        , C.GOODS_NO                                          AS goodsNo
        , C.GOODS_NAME                                       AS goodsName
        , C.CG_QTY                                            AS qty
        , C.CG_PRICE                                          AS price
        , C.CG_TOTAL_PRICE                                    AS goodsTotalPrice
        , C.CG_WEIGHT                                         AS weight
        , C.CG_ORIGIN                                         AS origin
        FROM TRAN_RCP T
        JOIN "OWNER" O
        ON O.OWR_ID = T.TRC_OWR_ID
        LEFT JOIN WH_IN_RPT W
        ON W.WIR_IO_SE_CD = 'EXP'
        AND (
        W.WIR_NO = T.TRC_NO
        OR W.WIR_GG_NO = T.TRC_TFG_NO
        )
        LEFT JOIN SHIP S
        ON S.SHIP_NO = T.TRC_SHIP_NO
        LEFT JOIN PORT DP
        ON DP.PORT_CD = T.TRC_DEPT_PORT_CD
        LEFT JOIN PORT AP
        ON AP.PORT_CD = T.TRC_ARVL_PORT_CD
        LEFT JOIN BL_ISSU BI
        ON BI.BI_TRE_ID = T.TRC_NO
        LEFT JOIN EXP_DCLR ED
        ON ED.ED_GG_NO = T.TRC_TFG_NO
        AND NVL(ED.ED_TRDE_SE_CD, 'EXP') = 'EXP'
        LEFT JOIN (
        SELECT
        EDI_ER_NO,
        MAX(EDI_EXPT_GDS_NM) AS EDI_EXPT_GDS_NM,
        SUM(NVL(EDI_DCLR_QTY, 0)) AS EDI_DCLR_QTY
        FROM EXP_DCLR_ITEM
        GROUP BY EDI_ER_NO
        ) EDI
        ON EDI.EDI_ER_NO = ED.ED_ER_NO
        LEFT JOIN TACS_FILE_MAP INV_MAP
        ON INV_MAP.TFM_TFG_NO = T.TRC_TFG_NO
        AND INV_MAP.TFM_DOC_TY_CD = 'INVOICE'
        LEFT JOIN DOCS_FILE_DATA INV_FILE
        ON INV_FILE.DFI_FILE_NO = INV_MAP.TFM_DFI_NO
        AND INV_FILE.DFI_DEL_YN = 'N'
        LEFT JOIN TACS_FILE_MAP PKG_MAP
        ON PKG_MAP.TFM_TFG_NO = T.TRC_TFG_NO
        AND PKG_MAP.TFM_DOC_TY_CD = 'PACKING_LIST'
        LEFT JOIN DOCS_FILE_DATA PKG_FILE
        ON PKG_FILE.DFI_FILE_NO = PKG_MAP.TFM_DFI_NO
        AND PKG_FILE.DFI_DEL_YN = 'N'
        LEFT JOIN EXP_CARGO_MANIFEST M
        ON M.ECM_OWR_ID = T.TRC_OWR_ID
        AND (
        M.ECM_RMRK_CN LIKE '%' || T.TRC_NO || '%'
        OR M.ECM_GG_NO = NVL(W.WIR_GG_NO, T.TRC_TFG_NO)
        )
        LEFT JOIN TACS_FILE_MAP MF_MAP
        ON MF_MAP.TFM_TFG_NO = M.ECM_TFG_NO
        AND MF_MAP.TFM_DOC_TY_CD = 'MANIFEST_PDF'
        LEFT JOIN DOCS_FILE_DATA MF_FILE
        ON MF_FILE.DFI_FILE_NO = MF_MAP.TFM_DFI_NO
        AND MF_FILE.DFI_DEL_YN = 'N'
        LEFT JOIN (
        SELECT
        SR_NO
        , SR_REF_NO
        , SR_STATUS_CD
        , SENDER_ID
        , RECEIVER_ID
        FROM (
        SELECT
        SR_NO
        , SR_REF_NO
        , SR_STATUS_CD
        , SENDER_ID
        , RECEIVER_ID
        , ROW_NUMBER() OVER (PARTITION BY SR_REF_NO ORDER BY SR_REQ_DT DESC, SR_NO DESC) AS RN
        FROM SUPP_RQST
        WHERE SR_REF_BIZ_CD = 'EXP_MANIFEST'
        )
        WHERE RN = 1
        ) SR
        ON SR.SR_REF_NO = T.TRC_NO
        LEFT JOIN SUPP_RQST_ITEM SRI
        ON SRI.SR_NO = SR.SR_NO
        AND SRI.SRI_SN = 1
        LEFT JOIN (
        SELECT
        CG_NO
        , GOODS_NO
        , GOODS_NAME
        , GG_NO
        , CG_QTY
        , CG_PRICE
        , CG_TOTAL_PRICE
        , CG_WEIGHT
        , CG_ORIGIN
        FROM (
        SELECT
        CG.CG_NO
        , CG.GOODS_NO
        , G.GOODS_NAME
        , CG.GG_NO
        , CG.CG_QTY
        , CG.CG_PRICE
        , CG.CG_TOTAL_PRICE
        , CG.CG_WEIGHT
        , CG.CG_ORIGIN
        , ROW_NUMBER() OVER (PARTITION BY CG.GG_NO ORDER BY CG.CG_NO) AS RN
        FROM CUSTOMS_GOODS CG
        LEFT JOIN GOODS G
        ON G.GOODS_NO = CG.GOODS_NO
        )
        WHERE RN = 1
        ) C
        ON C.GG_NO = NVL(W.WIR_GG_NO, T.TRC_TFG_NO)
        WHERE T.TRC_SE_CD = 'EXPORT'
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
        AND T.TRC_STATUS_CD = 'TRC_DONE'
        ORDER BY T.TRC_RQST_DT DESC NULLS LAST, T.TRC_NO DESC
    </select>

    <!-- 수출 적하목록 제출 INSERT -->
    <insert id="insertExpCargoManifest" parameterType="kr.or.tacs.vo.transport.TransportRequestVO">
        INSERT INTO EXP_CARGO_MANIFEST (
        ECM_NO
        , ECM_OWR_ID
        , ECM_GG_NO
        , ECM_BL_NO
        , ECM_TRDR_NM
        , ECM_SBMSN_DT
        , ECM_TFG_NO
        , ECM_RMRK_CN
        ) VALUES (
        SEQ_EXP_CARGO_MANIFEST.NEXTVAL
        , #{ownerId}
        , #{ggNo,jdbcType=NUMERIC}
        , NVL(#{hblNo,jdbcType=VARCHAR}, #{mblNo,jdbcType=VARCHAR})
        , #{buyerNm,jdbcType=VARCHAR}
        , SYSDATE
        , #{manifestTfgNo,jdbcType=NUMERIC}
        , NVL(#{manifestRemark,jdbcType=VARCHAR}, '수출 적하목록 제출')
        || ' [WIR_NO:' || #{wirNo,jdbcType=VARCHAR} || ']'
        || ' [TRC_NO:' || #{trcNo,jdbcType=VARCHAR} || ']'
        )
    </insert>

    <!-- 수출 적하목록 보완제출 -->
    <update id="updateExpCargoManifestSupplement" parameterType="kr.or.tacs.vo.transport.TransportRequestVO">
        UPDATE EXP_CARGO_MANIFEST
        SET
        ECM_BL_NO = NVL(#{hblNo,jdbcType=VARCHAR}, #{mblNo,jdbcType=VARCHAR})
        , ECM_TRDR_NM = #{buyerNm,jdbcType=VARCHAR}
        , ECM_SBMSN_DT = SYSDATE
        <if test="manifestTfgNo != null">
            , ECM_TFG_NO = #{manifestTfgNo,jdbcType=NUMERIC}
        </if>
        , ECM_RMRK_CN = NVL(#{manifestRemark,jdbcType=VARCHAR}, '수출 적하목록 보완제출')
        || ' [WIR_NO:' || #{wirNo,jdbcType=VARCHAR} || ']'
        || ' [TRC_NO:' || #{trcNo,jdbcType=VARCHAR} || ']'
        WHERE ECM_OWR_ID = #{ownerId}
        AND (
        ECM_RMRK_CN LIKE '%' || #{trcNo,jdbcType=VARCHAR} || '%'
        OR ECM_GG_NO = #{ggNo,jdbcType=NUMERIC}
        )
    </update>

    <!-- 수출 적하목록 보완요청 헤더 제출 처리 -->
    <update id="updateExpManifestSupplementSubmitted" parameterType="kr.or.tacs.vo.transport.TransportRequestVO">
        UPDATE SUPP_RQST
        SET
        SR_STATUS_CD = 'SUB'
        , SR_SUBMIT_DT = SYSDATE
        WHERE SR_REF_BIZ_CD = 'EXP_MANIFEST'
        AND SR_REF_NO = #{trcNo}
        AND SR_STATUS_CD = 'REQ'
    </update>

    <!-- 수출 적하목록 보완요청 항목 제출 처리 -->
    <update id="updateExpManifestSupplementItemSubmitted" parameterType="kr.or.tacs.vo.transport.TransportRequestVO">
        UPDATE SUPP_RQST_ITEM SRI
        SET
        SRI_STATUS_CD = 'SUB'
        WHERE EXISTS (
        SELECT 1
        FROM SUPP_RQST SR
        WHERE SR.SR_NO = SRI.SR_NO
        AND SR.SR_REF_BIZ_CD = 'EXP_MANIFEST'
        AND SR.SR_REF_NO = #{trcNo}
        AND SR.SR_STATUS_CD = 'REQ'
        )
    </update>


    <!-- 수출 보세구역 입고요청 최초 생성: MERGE 없이 INSERT SELECT WHERE NOT EXISTS 사용 -->
    <insert id="insertExpInboundReq">
        INSERT INTO WH_IN_RPT (
        WIR_NO
        , WIR_GG_NO
        , WIR_OWR_ID
        , WIR_WM_ID
        , WIR_WZ_NO
        , WIR_IN_PLAN_DT
        , WIR_STATUS_CD
        , WIR_WH_REPLY_STATUS_CD
        , WIR_INVOICE_NO
        , WIR_CARGO_MGMT_NO
        , WIR_INCO_TERMS_CD
        , WIR_RQST_CN
        , WIR_IO_SE_CD
        )
        SELECT
        NVL(#{wirNo,jdbcType=VARCHAR}, T.TRC_NO)
        , T.TRC_TFG_NO
        , T.TRC_OWR_ID
        , #{wmId,jdbcType=VARCHAR}
        , #{wzNo,jdbcType=VARCHAR}
        , CASE
        WHEN #{inPlanDt,jdbcType=VARCHAR} IS NULL THEN NULL
        WHEN INSTR(#{inPlanDt,jdbcType=VARCHAR}, 'T') > 0 THEN TO_DATE(#{inPlanDt,jdbcType=VARCHAR}, 'YYYY-MM-DD"T"HH24:MI')
        ELSE TO_DATE(#{inPlanDt,jdbcType=VARCHAR}, 'YYYY-MM-DD')
        END
        , 'WAIT'
        , 'WAIT'
        , #{invoiceNo,jdbcType=VARCHAR}
        , #{cargoMgmtNo,jdbcType=VARCHAR}
        , NVL(#{incoTermsCd,jdbcType=VARCHAR}, T.TRC_INCO_TERMS_CD)
        , #{remark,jdbcType=VARCHAR}
        , 'EXP'
        FROM TRAN_RCP T
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD = 'EXPORT'
        AND NOT EXISTS (
        SELECT 1
        FROM WH_IN_RPT W
        WHERE W.WIR_IO_SE_CD = 'EXP'
        AND (
        W.WIR_NO = T.TRC_NO
        OR W.WIR_GG_NO = T.TRC_TFG_NO
        )
        )
    </insert>

    <!-- 수출 보세구역 입고요청 저장/재발송: 최초 요청 상태는 WAIT/WAIT -->
    <update id="updateExpInboundReq">
        UPDATE WH_IN_RPT W
        SET
        W.WIR_WM_ID = NVL(#{wmId,jdbcType=VARCHAR}, W.WIR_WM_ID)
        , W.WIR_WZ_NO = NVL(#{wzNo,jdbcType=VARCHAR}, W.WIR_WZ_NO)
        , W.WIR_IN_PLAN_DT = CASE
        WHEN #{inPlanDt,jdbcType=VARCHAR} IS NULL THEN W.WIR_IN_PLAN_DT
        WHEN INSTR(#{inPlanDt,jdbcType=VARCHAR}, 'T') > 0 THEN TO_DATE(#{inPlanDt,jdbcType=VARCHAR}, 'YYYY-MM-DD"T"HH24:MI')
        ELSE TO_DATE(#{inPlanDt,jdbcType=VARCHAR}, 'YYYY-MM-DD')
        END
        , W.WIR_CARGO_MGMT_NO = NVL(#{cargoMgmtNo,jdbcType=VARCHAR}, W.WIR_CARGO_MGMT_NO)
        , W.WIR_INVOICE_NO = NVL(#{invoiceNo,jdbcType=VARCHAR}, W.WIR_INVOICE_NO)
        , W.WIR_INCO_TERMS_CD = NVL(#{incoTermsCd,jdbcType=VARCHAR}, W.WIR_INCO_TERMS_CD)
        , W.WIR_RQST_CN = NVL(#{remark,jdbcType=VARCHAR}, W.WIR_RQST_CN)
        , W.WIR_STATUS_CD = CASE
        WHEN W.WIR_STATUS_CD IS NULL OR W.WIR_STATUS_CD IN ('', 'SENT', '입고요청완료') THEN 'WAIT'
        ELSE W.WIR_STATUS_CD
        END
        , W.WIR_WH_REPLY_STATUS_CD = CASE
        WHEN W.WIR_WH_REPLY_STATUS_CD IS NULL OR W.WIR_WH_REPLY_STATUS_CD IN ('', 'SENT', '입고요청완료') THEN 'WAIT'
        ELSE W.WIR_WH_REPLY_STATUS_CD
        END
        WHERE W.WIR_IO_SE_CD = 'EXP'
        AND EXISTS (
        SELECT 1
        FROM TRAN_RCP T
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD = 'EXPORT'
        AND (
        W.WIR_NO = T.TRC_NO
        OR W.WIR_GG_NO = T.TRC_TFG_NO
        )
        )
    </update>

    <select id="countExpInboundReqByTrcNo" resultType="int">
        SELECT COUNT(*)
        FROM WH_IN_RPT W
        JOIN TRAN_RCP T
        ON T.TRC_SE_CD = 'EXPORT'
        AND T.TRC_NO = #{trcNo}
        AND (
        W.WIR_NO = T.TRC_NO
        OR W.WIR_GG_NO = T.TRC_TFG_NO
        )
        WHERE W.WIR_IO_SE_CD = 'EXP'
    </select>

    <update id="updateExpTransportReqStatus">
        UPDATE TRAN_RCP
        SET
        TRC_STATUS_CD =
        CASE #{statusCd}
        WHEN 'ACC' THEN 'TRC_DONE'
        WHEN 'ACCEPTED' THEN 'TRC_DONE'
        WHEN 'TRC_DONE' THEN 'TRC_DONE'
        WHEN '접수완료' THEN 'TRC_DONE'
        WHEN 'REJ' THEN 'TRC_REJECT'
        WHEN 'REJECTED' THEN 'TRC_REJECT'
        WHEN 'TRC_REJECT' THEN 'TRC_REJECT'
        WHEN '접수반려' THEN 'TRC_REJECT'
        WHEN 'TRC_END' THEN 'TRC_END'
        WHEN '완료대기' THEN 'TRC_END'
        WHEN 'TRC_COMPLETE' THEN 'TRC_COMPLETE'
        WHEN '최종완료' THEN 'TRC_COMPLETE'
        ELSE TRC_STATUS_CD
        END
        , TRC_RCEPT_DT = CASE
        WHEN #{statusCd} IN ('ACC', 'ACCEPTED', 'TRC_DONE', '접수완료') THEN SYSDATE
        ELSE TRC_RCEPT_DT
        END
        , TRC_REJ_TYPE =
        CASE
        WHEN #{statusCd} IN ('REJ', 'REJECTED', 'TRC_REJECT', '접수반려') THEN #{rejectType,jdbcType=VARCHAR}
        ELSE NULL
        END
        , TRC_REJ_MEMO =
        CASE
        WHEN #{statusCd} IN ('REJ', 'REJECTED', 'TRC_REJECT', '접수반려') THEN #{rejectMemo,jdbcType=VARCHAR}
        ELSE NULL
        END
        , TRC_RJCT_RSN =
        CASE
        WHEN #{statusCd} IN ('REJ', 'REJECTED', 'TRC_REJECT', '접수반려') THEN #{rejectReason,jdbcType=VARCHAR}
        ELSE NULL
        END
        WHERE TRC_NO = #{trcNo}
        AND TRC_SE_CD = 'EXPORT'
    </update>

</mapper>
