}

.exportAndFulfillment-page .data-table td,
.loadedCargoList-page .data-table td,
.warehouseCargoTracking-page .data-table td {
  padding: 11px 14px !important;
  border-bottom: 1px solid #d9eafc !important;
  color: #203444 !important;
  font-size: 12px !important;
  font-weight: 500 !important;
  text-align: center !important;
  white-space: nowrap !important;
}

/* =========================================================
   loadedCargoList 책갈피 탭 정리
   - 중복 탭은 JSP에서 1개로 제거
   - 탭은 표 위에 붙는 책갈피 형태
========================================================= */
.loadedCargoList-page .cargo-tab-table-shell {
  margin-top: 16px !important;
  margin-bottom: 16px !important;
}

.loadedCargoList-page .cargo-bookmark-tabs {
  display: flex !important;
  align-items: flex-end !important;
  gap: 0 !important;
  margin: 0 0 -1px 0 !important;
  padding: 0 0 0 0 !important;
  border-bottom: 1px solid #d9eafc !important;
  position: relative !important;
  z-index: 2 !important;
}

.loadedCargoList-page .cargo-bookmark-tabs .line-tab {
  min-width: 132px !important;
  height: 34px !important;
  padding: 0 18px !important;
  margin: 0 4px 0 0 !important;
  border: 1px solid #cbd8e8 !important;
  border-bottom-color: #d9eafc !important;
  background: #f8fbff !important;
  color: #334155 !important;
  font-size: 12px !important;
  font-weight: 800 !important;
  line-height: 34px !important;
  border-radius: 0 !important;
  box-shadow: none !important;
}

.loadedCargoList-page .cargo-bookmark-tabs .line-tab.active {
  height: 37px !important;
  margin-bottom: -1px !important;
  background: #fff !important;
  color: #1e3054 !important;
  border-color: #d9eafc !important;
  border-top: 3px solid #1e3054 !important;
  border-bottom-color: #fff !important;
}

.loadedCargoList-page .cargo-tab-table-shell [data-panel-group="cargo-list-type"] {
  background: #fff !important;
  border: 1px solid #d9eafc !important;
  padding: 14px 14px 0 14px !important;
}

.loadedCargoList-page .cargo-tab-table-shell [data-panel-group="cargo-list-type"] > .flex.items-center.justify-between.mb-3 {
  margin-bottom: 10px !important;
}

.loadedCargoList-page .cargo-tab-table-shell .bg-white.border.border-slate-200 {
  margin-bottom: 14px !important;
  border: 1px solid #d9eafc !important;
}

.loadedCargoList-page .cargo-tab-table-shell .data-table th,
.loadedCargoList-page .cargo-tab-table-shell .data-table td {
  text-align: center !important;
}

/* 적재/혼재화물 목록 행 클릭 및 상세 텍스트 표시 */
.loadedCargoList-page .cargo-click-row {
  cursor: pointer;
}

.loadedCargoList-page .cargo-click-row.row-selected,
.loadedCargoList-page .cargo-click-row.row-selected td {
  background: #f4f8ff !important;
}

.loadedCargoList-page .cargo-detail-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px 12px;
  margin-bottom: 18px;
}

.loadedCargoList-page .cargo-detail-item {
  min-height: 54px;
  border: 1px solid #d8e2ef;
  background: #fff;
  padding: 8px 10px;
}

.loadedCargoList-page .cargo-detail-item-wide {
  grid-column: span 3;
}

.loadedCargoList-page .cargo-detail-label {
  display: block;
  margin-bottom: 5px;
  color: #536178;
  font-size: 12px;
  font-weight: 800;
}

.loadedCargoList-page .cargo-detail-value {
  display: block;
  color: #182235;
  font-size: 13px;
  font-weight: 700;
  line-height: 1.45;
  word-break: keep-all;
}

.loadedCargoList-page .cargo-memo-box {
  border: 1px solid #d8e2ef;
  background: #fff;
  padding: 12px;
}

.loadedCargoList-page .cargo-memo-textarea {
  width: 100%;
  min-height: 92px;
  resize: vertical;
  border: 1px solid #d1d9e6;
  padding: 10px 12px;
  font-size: 13px;
  line-height: 1.55;
  outline: none;
}

.loadedCargoList-page .cargo-memo-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 8px;
}

.loadedCargoList-page .cargo-memo-saved {
  color: #536178;
  font-size: 12px;
  font-weight: 700;
}

/* 상세 버튼 복구 */
.loadedCargoList-page .btn-cargo-detail {
  height: 28px !important;
  padding: 0 10px !important;
  font-size: 12px !important;
}

/* 상세 정보: 항목별 네모 박스 제거 */
.loadedCargoList-page .cargo-detail-item {
  min-height: auto !important;
  border: 0 !important;
  background: transparent !important;
  padding: 8px 0 !important;
  display: grid;
  grid-template-columns: 130px 1fr;
  align-items: center;
  border-bottom: 1px solid #e3ebf5 !important;
}

.loadedCargoList-page .cargo-detail-label {
  display: block;
  margin-bottom: 0 !important;
  color: #536178;
  font-size: 12px;
  font-weight: 800;
}

.loadedCargoList-page .cargo-detail-value {
  display: block;
  color: #0f1f3d;
  font-size: 13px;
  font-weight: 700;
}

.loadedCargoList-page .cargo-detail-item-wide {
  grid-column: span 3;
}

/* =========================================================
   JSP 화면 기준 최종 정리
   - 상세는 선택 행 바로 아래에 열린다.
   - 상세 안 항목은 네모 박스가 아니라 텍스트형 행으로 표시한다.
   - 상세 품목은 각 품목 행으로 표시한다.
========================================================= */
.loadedCargoList-page .cargo-list-table tbody tr.cargo-click-row:hover td {
  background: #fff !important;
}

.loadedCargoList-page .cargo-list-table tbody tr.cargo-click-row.row-selected td {
  background: #f6f9ff !important;
}

.loadedCargoList-page .cargo-detail-inline-row,
.loadedCargoList-page .cargo-detail-inline-row:hover,
.loadedCargoList-page .cargo-detail-inline-row:hover td {
  background: #fff !important;
}

.loadedCargoList-page .cargo-detail-inline-cell {
  padding: 0 !important;
  background: #fff !important;
  border-bottom: 1px solid #d9eafc !important;
  text-align: left !important;
  white-space: normal !important;
}

.loadedCargoList-page #cargo-list-detail-panel {
  margin: 0 !important;
  padding: 0 !important;
  background: #fff !important;
}

.loadedCargoList-page .cargo-detail-card {
  margin: 0 !important;
  padding: 18px 20px 20px !important;
  border: 0 !important;
  border-top: 1px solid #d9eafc !important;
  border-left: 0 !important;
  background: #fff !important;
}

.loadedCargoList-page .cargo-detail-card .section-title {
  margin-top: 18px !important;
  margin-bottom: 8px !important;
}

.loadedCargoList-page .cargo-detail-card .section-title:first-child {
  margin-top: 0 !important;
}

.loadedCargoList-page .cargo-detail-grid {
  display: grid !important;
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  gap: 0 28px !important;
  margin-bottom: 8px !important;
  padding: 0 !important;
  border-top: 1px solid #e3ebf5 !important;
}

.loadedCargoList-page .cargo-detail-item,
.loadedCargoList-page .cargo-detail-item-wide {
  min-height: 38px !important;
  border: 0 !important;
  border-bottom: 1px solid #e3ebf5 !important;
  background: transparent !important;
  padding: 8px 0 !important;
  display: grid !important;
  grid-template-columns: 120px 1fr !important;
  align-items: center !important;
  grid-column: auto !important;
}

.loadedCargoList-page .cargo-detail-label {
  margin: 0 !important;
  color: #536178 !important;
  font-size: 12px !important;
  font-weight: 800 !important;
}

.loadedCargoList-page .cargo-detail-value {
  color: #0f1f3d !important;
  font-size: 13px !important;
  font-weight: 700 !important;
  line-height: 1.45 !important;
  word-break: break-all !important;
}

.loadedCargoList-page .cargo-item-detail-table th,
.loadedCargoList-page .cargo-item-detail-table td {
  text-align: center !important;
}

.loadedCargoList-page .cargo-item-detail-table td.text-left {
  text-align: left !important;
  white-space: normal !important;
}

.loadedCargoList-page .cargo-remark-text {
  min-height: 36px !important;
  padding: 9px 0 !important;
  border-top: 1px solid #e3ebf5 !important;
  border-bottom: 1px solid #e3ebf5 !important;
  color: #0f1f3d !important;
  font-size: 13px !important;
  font-weight: 700 !important;
  line-height: 1.5 !important;
}

.loadedCargoList-page .empty-cell {
  text-align: center !important;
  padding: 24px !important;
  color: #64748b !important;
  font-weight: 600 !important;
}

@media (max-width: 1100px) {
  .loadedCargoList-page .cargo-detail-grid {
    grid-template-columns: 1fr !important;
  }
}
