@charset "UTF-8";

/* 원본 main.css 디자인 참고용 페이지 보정 CSS - Tailwind 없이 일반 CSS */
:root {
  --officer-bg: #f6f9ff;
  --officer-white: #ffffff;
  --officer-text: #203444;
  --officer-title: #0f172a;
  --officer-muted: #64748b;
  --officer-line: #d9eafc;
  --officer-line-dark: #a0b4c8;
  --officer-primary: #565e74;
  --officer-primary-dark: #373f54;
  --officer-danger: #9f403d;
  --officer-soft: #ecf4ff;
}

* { box-sizing: border-box; }

.page-section,
.sub-content,
[class*="-page"] {
  width: 100%;
}

/* Tailwind 제거 후 기존 JSP 유틸 클래스 보정 */
.bg-background,
.bg-surface { background: var(--officer-bg) !important; }
.text-on-surface { color: var(--officer-text) !important; }
.text-on-surface-variant { color: var(--officer-muted) !important; }
.bg-surface-container-highest { background: #eef5ff !important; }
.border-outline { border-color: var(--officer-line-dark) !important; }
.text-slate-900 { color: var(--officer-title) !important; }
.text-slate-700 { color: #334155 !important; }
.text-slate-500,
.text-slate-400 { color: var(--officer-muted) !important; }
.bg-slate-50 { background: #f8fbff !important; }
.bg-slate-200 { background: #e2e8f0 !important; }
.border-slate-900 { border-color: #111827 !important; }
.border-slate-300 { border-color: #cbd5e1 !important; }

.ml-64 { margin-left: 256px !important; }
.pt-16 { padding-top: 64px !important; }
.min-h-screen { min-height: 100vh !important; }
.p-8 { padding: 32px !important; }
.px-6 { padding-left: 24px !important; padding-right: 24px !important; }
.py-1\.5 { padding-top: 6px !important; padding-bottom: 6px !important; }
.pl-10 { padding-left: 40px !important; }
.pr-4 { padding-right: 16px !important; }
.p-2 { padding: 8px !important; }
.mb-8 { margin-bottom: 32px !important; }
.mb-2 { margin-bottom: 8px !important; }
.mb-1 { margin-bottom: 4px !important; }
.mt-2 { margin-top: 8px !important; }
.mx-2 { margin-left: 8px !important; margin-right: 8px !important; }

.flex { display: flex !important; }
.inline-flex { display: inline-flex !important; }
.grid { display: grid !important; }
.hidden { display: none !important; }
.items-center { align-items: center !important; }
.justify-between { justify-content: space-between !important; }
.justify-center { justify-content: center !important; }
.gap-1 { gap: 4px !important; }
.gap-3 { gap: 12px !important; }
.gap-4 { gap: 16px !important; }
.gap-6 { gap: 24px !important; }
.grid-cols-5 { grid-template-columns: repeat(5, minmax(0, 1fr)) !important; }
.grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)) !important; }
.grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)) !important; }
.grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)) !important; }

.fixed { position: fixed !important; }
.relative { position: relative !important; }
.absolute { position: absolute !important; }
.top-0 { top: 0 !important; }
.right-0 { right: 0 !important; }
.left-64 { left: 256px !important; }
.inset-y-0 { top: 0 !important; bottom: 0 !important; }
.left-3 { left: 12px !important; }
.z-40 { z-index: 40 !important; }
.pointer-events-none { pointer-events: none !important; }

.h-16 { height: 64px !important; }
.h-8 { height: 32px !important; }
.w-px { width: 1px !important; }
.w-72 { width: 288px !important; }

.text-right { text-align: right !important; }
.text-xl { font-size: 20px !important; }
.text-sm { font-size: 14px !important; }
.text-xs { font-size: 12px !important; }
.text-\[10px\] { font-size: 10px !important; }
.text-\[12px\] { font-size: 12px !important; }
.text-\[13px\] { font-size: 13px !important; }
.text-\[24px\] { font-size: 24px !important; }
.text-\[30px\] { font-size: 30px !important; }
.font-bold { font-weight: 700 !important; }
.font-black { font-weight: 900 !important; }
.uppercase { text-transform: uppercase !important; }
.tracking-widest { letter-spacing: .08em !important; }
.tracking-tighter { letter-spacing: -0.04em !important; }
.leading-none { line-height: 1 !important; }
.transition-all,
.transition-colors { transition: all .15s ease !important; }

.border-b-2 { border-bottom-width: 2px !important; border-bottom-style: solid !important; }
.outline-none { outline: none !important; }

/* 공통 페이지 헤더 */
.mb-8 > .text-\[10px\],
.page-section .text-\[10px\].font-black {
  display: block;
  margin-bottom: 4px !important;
  font-size: 10px !important;
  font-weight: 900 !important;
  color: var(--officer-muted) !important;
  text-transform: uppercase;
  letter-spacing: .08em;
}

.page-section .text-\[24px\].font-black,
.page-section h1,
.sub-content h1 {
  margin: 0;
  font-size: 24px !important;
  font-weight: 900 !important;
  color: var(--officer-title) !important;
  letter-spacing: -0.03em;
}

.page-section .text-\[13px\].text-slate-500,
.sub-content .text-\[13px\].text-slate-500 {
  font-size: 13px !important;
  color: var(--officer-muted) !important;
  line-height: 1.65;
}

/* 기존 카드/통계 카드 톤 */
.info-card,
.dashboard-card,
.dashboard-panel,
.content-shell,
.inline-screen-host {
  background: var(--officer-white) !important;
  border: 1px solid var(--officer-line) !important;
  border-left: 4px solid var(--officer-primary) !important;
  padding: 16px 18px !important;
  margin-bottom: 16px !important;
  color: var(--officer-text) !important;
}

.info-card.mb-0 { margin-bottom: 0 !important; }
.info-card .text-\[12px\],
.dashboard-card h3 {
  font-size: 12px !important;
  font-weight: 700 !important;
  color: var(--officer-muted) !important;
}
.info-card .text-\[30px\],
.dashboard-card p {
  font-size: 30px !important;
  font-weight: 900 !important;
  color: var(--officer-title) !important;
  line-height: 1 !important;
}

/* 검색조건 박스 */
.search-panel,
.receipt-search-panel,
.basic-search-box,
.check-search-box,
.screen-search-box,
.tax-search-box,
.hs-search-box,
.supplement-search-box,
.clarification-search-box,
.hold-search-box,
.repair-search-box {
  background: #fff !important;
  border: 1px solid var(--officer-line) !important;
  padding: 18px 20px !important;
  margin-bottom: 18px !important;
}

.section-title,
.search-title,
.receipt-search-title,
.check-section-title,
.screen-section-title,
.tax-section-title,
.hs-section-title,
.supplement-section-title,
.clarification-section-title,
.hold-section-title,
.repair-section-title {
  display: flex !important;
  align-items: center !important;
  gap: 8px !important;
  margin: 0 0 16px !important;
  font-size: 15px !important;
  font-weight: 900 !important;
  color: var(--officer-title) !important;
  letter-spacing: -0.02em !important;
}
.section-title::before,
.search-title::before,
.receipt-search-title::before,
.check-section-title::before,
.screen-section-title::before,
.tax-section-title::before,
.hs-section-title::before,
.supplement-section-title::before,
.clarification-section-title::before,
.hold-section-title::before,
.repair-section-title::before {
  content: '' !important;
  width: 5px !important;
  height: 16px !important;
  display: inline-block !important;
  background: var(--officer-primary) !important;
  flex-shrink: 0 !important;
}

.form-row,
.search-row,
.receipt-search-row,
.check-form-row,
.screen-form-row,
.tax-form-row,
.hs-form-row,
.supplement-form-row,
.clarification-form-row,
.hold-form-row,
.repair-form-row {
  display: flex !important;
  align-items: center !important;
  gap: 12px !important;
  flex-wrap: wrap !important;
  margin-bottom: 12px !important;
}

.form-label,
.search-label,
.receipt-search-label {
  width: 84px !important;
  flex: 0 0 84px !important;
  color: #4d6172 !important;
  font-size: 12px !important;
  font-weight: 800 !important;
}

input[type="text"],
input[type="date"],
select,
.form-input,
.form-select,
.receipt-search-input,
.receipt-search-select,
.receipt-search-date {
  height: 36px !important;
  min-width: 180px;
  border: 1px solid var(--officer-line-dark) !important;
  border-bottom: 2px solid #697d8f !important;
  background: #fff !important;
  padding: 0 11px !important;
  font-size: 13px !important;
  color: var(--officer-text) !important;
  outline: none !important;
  border-radius: 0 !important;
}

select,
.form-select,
.receipt-search-select {
  appearance: auto !important;
}

/* 버튼 */
button,
.btn,
.btn-primary,
.btn-secondary,
.receipt-action-btn,
.receipt-inline-btn,
.check-btn,
.screen-btn,
.tax-btn,
.hs-btn,
.supplement-btn,
.clarification-btn,
.hold-btn,
.repair-btn,
.dashboard-btn {
  height: 34px;
  padding: 0 14px;
  border: 1px solid var(--officer-primary);
  background: #fff;
  color: var(--officer-primary);
  font-size: 13px;
  font-weight: 800;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  border-radius: 0;
}
button:hover,
.btn:hover,
.btn-secondary:hover { background: var(--officer-soft); }
.btn-primary,
button[type="submit"],
.check-btn-primary,
.screen-btn-primary,
.tax-btn-primary,
.hs-btn-primary,
.supplement-btn-primary,
.clarification-btn-primary,
.hold-btn-primary,
.repair-btn-primary,
.dashboard-btn-primary {
  background: var(--officer-primary) !important;
  color: #fff !important;
  border-color: var(--officer-primary) !important;
}

/* 테이블 */
.data-table,
table,
.check-table,
.screen-table,
.tax-table,
.hs-table,
.supplement-table,
.clarification-table,
.hold-table,
.repair-table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
}
.data-table thead tr,
table thead tr,
.check-table thead tr,
.screen-table thead tr,
.tax-table thead tr,
.hs-table thead tr,
.supplement-table thead tr,
.clarification-table thead tr,
.hold-table thead tr,
.repair-table thead tr {
  background: var(--officer-soft) !important;
}
.data-table th,
table th,
.check-table th,
.screen-table th,
.tax-table th,
.hs-table th,
.supplement-table th,
.clarification-table th,
.hold-table th,
.repair-table th {
  padding: 10px 12px !important;
  border-bottom: 2px solid var(--officer-line) !important;
  font-size: 11px !important;
  font-weight: 900 !important;
  text-align: left !important;
  color: #4d6172 !important;
  white-space: nowrap;
  text-transform: uppercase;
  letter-spacing: .08em;
  white-space: nowrap;
}
.data-table td,
table td,
.check-table td,
.screen-table td,
.tax-table td,
.hs-table td,
.supplement-table td,
.clarification-table td,
.hold-table td,
.repair-table td {
  padding: 11px 12px !important;
  border-bottom: 1px solid var(--officer-line) !important;
  font-size: 13px !important;
  color: var(--officer-text) !important;
  vertical-align: middle !important;
  vertical-align: middle;
}
.data-table tbody tr:hover,
table tbody tr:hover {
  background: #ecf4ff;
}
.data-table tbody tr:hover,
table tbody tr:hover { background: #f8fbff !important; }

/* 상세 패널 */
.check-detail-panel,
.screen-detail,
.tax-detail-panel,
.hs-detail-panel,
.supplement-detail-panel,
.clarification-detail-panel,
.hold-detail-panel,
.repair-detail-panel,
.inline-screen-host {
  background: #fff !important;
  border: 1px solid var(--officer-line) !important;
  padding: 18px 20px !important;
}

.badge-done,
.badge-progress,
.badge-wait,
.badge-new,
.badge-pass,
.badge-fail,
.risk-high,
.risk-mid,
.risk-low,
.chip-blue {
  background: none !important;
  border: none !important;
  padding: 0 !important;
  font-size: 12px !important;
  font-weight: 800 !important;
  color: var(--officer-text) !important;
}

@media (max-width: 1200px) {
  .grid-cols-5,
  .grid-cols-4,
  .grid-cols-3 { grid-template-columns: repeat(2, minmax(0, 1fr)) !important; }
}
@media (max-width: 768px) {
  .ml-64 { margin-left: 0 !important; }
  .left-64 { left: 0 !important; }
  .p-8 { padding: 16px !important; }
  .grid-cols-5,
  .grid-cols-4,
  .grid-cols-3,
  .grid-cols-2 { grid-template-columns: 1fr !important; }
}

/* ── btn-primary / btn-secondary: 원본 스타일 ── */
.btn-primary {
  background: #565e74 !important;
  color: #f7f7ff !important;
  border: none !important;
  padding: 7px 18px !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  cursor: pointer !important;
  display: inline-flex !important;
  align-items: center !important;
  gap: 6px !important;
  white-space: nowrap !important;
}
.btn-primary:hover { background: #4a5268 !important; }
.btn-secondary {
  background: #fff !important;
  color: #565e74 !important;
  border: 1px solid #565e74 !important;
  padding: 7px 18px !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  cursor: pointer !important;
  display: inline-flex !important;
  align-items: center !important;
  gap: 6px !important;
  white-space: nowrap !important;
}
.btn-secondary:hover { background: #dae2fd !important; }
.btn-danger {
  background: #9f403d !important;
  color: #fff7f6 !important;
  border: none !important;
  padding: 7px 18px !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  cursor: pointer !important;
}
.btn-sm {
  padding: 3px 12px !important;
  font-size: 11px !important;
}

/* ── form-input / form-select: 원본 (border-bottom 강조) ── */
.form-input,
.form-select {
  width: 100%;
  padding: 7px 12px;
  background: #fff;
  border: 1px solid #a0b4c8;
  border-bottom: 2px solid #697d8f;
  font-size: 12px;
  color: #203444;
  outline: none;
}
.form-input:focus { border-bottom-color: #565e74; }
.form-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: #4d6172;
  margin-bottom: 4px;
  display: block;
}

/* =========================================================
   reportReceiptList 기준 정리본
   - 잡스러운 텍스트/아이콘 제거는 JSP에서 처리
   - 검색조건/목록/버튼 위치만 정돈
========================================================= */

.exportAndFulfillment-page,
.loadedCargoList-page,
.warehouseCargoTracking-page {
  padding: 24px 28px !important;
}

.exportAndFulfillment-page .mb-5,
.loadedCargoList-page .mb-5,
.warehouseCargoTracking-page .section-head {
  margin-bottom: 10px !important;
}

.exportAndFulfillment-page h2.text-xl,
.loadedCargoList-page h2.text-xl,
.warehouseCargoTracking-page .page-heading {
  margin: 0 0 10px !important;
  color: #0f172a !important;
  font-size: 20px !important;
  font-weight: 900 !important;
}

.exportAndFulfillment-page .inline-screen-host,
.loadedCargoList-page .inline-screen-host,
.warehouseCargoTracking-page .inline-screen-host {
  background: transparent !important;
  border: 0 !important;
  border-left: 0 !important;
  padding: 0 !important;
  margin-bottom: 0 !important;
}

.exportAndFulfillment-page .inline-screen-header,
.loadedCargoList-page .inline-screen-header,
.warehouseCargoTracking-page .inline-screen-header {
  margin-bottom: 20px !important;
  padding: 14px 20px !important;
  background: #1e3054 !important;
  border: 0 !important;
}

.exportAndFulfillment-page .inline-screen-header h3,
.loadedCargoList-page .inline-screen-header h3,
.warehouseCargoTracking-page .screen-title {
  margin: 0 !important;
  color: #fff !important;
  font-size: 14px !important;
  font-weight: 900 !important;
}

.exportAndFulfillment-page .inline-screen-body,
.loadedCargoList-page .inline-screen-body,
.warehouseCargoTracking-page .inline-screen-body {
  padding: 0 !important;
}

.exportAndFulfillment-page .line-tabs,
.loadedCargoList-page .line-tabs {
  display: flex !important;
  align-items: center !important;
  gap: 6px !important;
  margin-bottom: 16px !important;
}

.exportAndFulfillment-page .line-tab,
.loadedCargoList-page .line-tab {
  height: 32px !important;
  padding: 0 12px !important;
  border: 1px solid #cbd8e8 !important;
  background: #fff !important;
  color: #334155 !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  cursor: pointer !important;
  border-radius: 0 !important;
}

.exportAndFulfillment-page .line-tab.active,
.loadedCargoList-page .line-tab.active {
  background: #1e3054 !important;
  border-color: #1e3054 !important;
  color: #fff !important;
}

.exportAndFulfillment-page .receipt-search-panel,
.loadedCargoList-page .receipt-search-panel,
.warehouseCargoTracking-page .receipt-search-panel {
  margin-bottom: 18px !important;
  padding: 0 !important;
  background: #fff !important;
  border: 1px solid #dde4ef !important;
}

.exportAndFulfillment-page .receipt-search-title,
.loadedCargoList-page .receipt-search-title,
.warehouseCargoTracking-page .receipt-search-title,
.exportAndFulfillment-page .section-title.receipt-search-title,
.loadedCargoList-page .section-title.receipt-search-title,
.warehouseCargoTracking-page .section-title.receipt-search-title {
  position: relative !important;
  display: block !important;
  margin: 0 !important;
  padding: 8px 16px 8px 20px !important;
  border-bottom: 1px solid #dde4ef !important;
  background: #fff !important;
  color: #111827 !important;
  font-size: 13px !important;
  font-weight: 900 !important;
  line-height: 1.4 !important;
  letter-spacing: 0 !important;
}

.exportAndFulfillment-page .receipt-search-title::before,
.loadedCargoList-page .receipt-search-title::before,
.warehouseCargoTracking-page .receipt-search-title::before,
.exportAndFulfillment-page .section-title.receipt-search-title::before,
.loadedCargoList-page .section-title.receipt-search-title::before,
.warehouseCargoTracking-page .section-title.receipt-search-title::before {
  content: '' !important;
  position: absolute !important;
  left: 0 !important;
  top: 0 !important;
  width: 4px !important;
  height: 100% !important;
  background: #536178 !important;
}

.exportAndFulfillment-page .receipt-search-row,
.loadedCargoList-page .receipt-search-row,
.warehouseCargoTracking-page .receipt-search-row {
  display: flex !important;
  align-items: center !important;
  min-height: 45px !important;
  margin: 0 !important;
  padding: 5px 16px !important;
  gap: 15px !important;
  border-bottom: 0 !important;
  background: #fff !important;
}

.exportAndFulfillment-page .receipt-search-label,
.loadedCargoList-page .receipt-search-label,
.warehouseCargoTracking-page .receipt-search-label {
  width: 90px !important;
  flex: 0 0 90px !important;
  margin: 0 !important;
  color: #374151 !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  line-height: normal !important;
}

.exportAndFulfillment-page .receipt-search-field,
.exportAndFulfillment-page .receipt-search-bottom,
.exportAndFulfillment-page .receipt-search-date-wrap,
.exportAndFulfillment-page .receipt-search-radio-group,
.loadedCargoList-page .receipt-search-field,
.loadedCargoList-page .receipt-search-bottom,
.loadedCargoList-page .receipt-search-date-wrap,
.loadedCargoList-page .receipt-search-radio-group,
.warehouseCargoTracking-page .receipt-search-field,
.warehouseCargoTracking-page .receipt-search-bottom,
.warehouseCargoTracking-page .receipt-search-date-wrap,
.warehouseCargoTracking-page .receipt-search-radio-group {
  display: flex !important;
  align-items: center !important;
  gap: 15px !important;
  flex: 1 !important;
  min-width: 0 !important;
}

.exportAndFulfillment-page .receipt-search-input,
.exportAndFulfillment-page .receipt-search-select,
.exportAndFulfillment-page .receipt-search-date,
.loadedCargoList-page .receipt-search-input,
.loadedCargoList-page .receipt-search-select,
.loadedCargoList-page .receipt-search-date,
.warehouseCargoTracking-page .receipt-search-input,
.warehouseCargoTracking-page .receipt-search-select,
.warehouseCargoTracking-page .receipt-search-date {
  height: 33px !important;
  padding: 0 10px !important;
  border: 1px solid #d1d9e6 !important;
  border-bottom: 1px solid #d1d9e6 !important;
  background: #fff !important;
  color: #0f172a !important;
  font-size: 12px !important;
  outline: none !important;
  border-radius: 0 !important;
  box-shadow: none !important;
  min-width: 0 !important;
}

.exportAndFulfillment-page .receipt-search-input,
.loadedCargoList-page .receipt-search-input,
.warehouseCargoTracking-page .receipt-search-input { width: 200px !important; }

.exportAndFulfillment-page .receipt-search-field-wide .receipt-search-input,
.loadedCargoList-page .receipt-search-field-wide .receipt-search-input,
.warehouseCargoTracking-page .receipt-search-field-wide .receipt-search-input { width: 200px !important; }

.exportAndFulfillment-page .receipt-search-select,
.loadedCargoList-page .receipt-search-select,
.warehouseCargoTracking-page .receipt-search-select { width: 140px !important; }

.exportAndFulfillment-page .receipt-search-date,
.loadedCargoList-page .receipt-search-date,
.warehouseCargoTracking-page .receipt-search-date { width: 130px !important; }

.exportAndFulfillment-page .receipt-check-item,
.loadedCargoList-page .receipt-check-item,
.warehouseCargoTracking-page .receipt-check-item {
  display: inline-flex !important;
  align-items: center !important;
  gap: 5px !important;
  margin-right: 12px !important;
  color: #374151 !important;
  font-size: 12px !important;
  font-weight: 600 !important;
}

.exportAndFulfillment-page .btn-primary,
.exportAndFulfillment-page .btn-secondary,
.exportAndFulfillment-page .receipt-action-btn,
.exportAndFulfillment-page .receipt-inline-btn,
.loadedCargoList-page .btn-primary,
.loadedCargoList-page .btn-secondary,
.loadedCargoList-page .receipt-action-btn,
.loadedCargoList-page .receipt-inline-btn,
.warehouseCargoTracking-page .btn-primary,
.warehouseCargoTracking-page .btn-secondary,
.warehouseCargoTracking-page .receipt-action-btn,
.warehouseCargoTracking-page .receipt-inline-btn {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  height: 33px !important;
  padding: 0 14px !important;
  border: 1px solid transparent !important;
  border-radius: 0 !important;
  font-size: 12px !important;
  font-weight: 700 !important;
  cursor: pointer !important;
  white-space: nowrap !important;
  box-shadow: none !important;
  gap: 0 !important;
}

.exportAndFulfillment-page .btn-primary,
.exportAndFulfillment-page .receipt-action-btn.btn-primary,
.loadedCargoList-page .btn-primary,
.loadedCargoList-page .receipt-action-btn.btn-primary,
.warehouseCargoTracking-page .btn-primary,
.warehouseCargoTracking-page .receipt-action-btn.btn-primary {
  background: #1e3054 !important;
  border-color: #1e3054 !important;
  color: #fff !important;
}

.exportAndFulfillment-page .btn-secondary,
.exportAndFulfillment-page .receipt-inline-btn,
.loadedCargoList-page .btn-secondary,
.loadedCargoList-page .receipt-inline-btn,
.warehouseCargoTracking-page .btn-secondary,
.warehouseCargoTracking-page .receipt-inline-btn {
  background: #fff !important;
  border-color: #cbd8e8 !important;
  color: #334155 !important;
}

.exportAndFulfillment-page .inline-screen-body > .flex.items-center.justify-between.mb-3,
.loadedCargoList-page .inline-screen-body > .flex.items-center.justify-between.mb-3,
.warehouseCargoTracking-page .result-bar {
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  margin-bottom: 10px !important;
}

.exportAndFulfillment-page .inline-screen-body > .flex.items-center.justify-between.mb-3 > div,
.loadedCargoList-page .inline-screen-body > .flex.items-center.justify-between.mb-3 > div,
.warehouseCargoTracking-page .result-title {
  color: #1e293b !important;
  font-size: 15px !important;
  font-weight: 700 !important;
}

.exportAndFulfillment-page .text-blue-600,
.loadedCargoList-page .text-blue-600,
.warehouseCargoTracking-page .result-count {
  margin-left: 6px !important;
  color: #2563eb !important;
}

.exportAndFulfillment-page .bg-white.border.border-slate-200,
.loadedCargoList-page .bg-white.border.border-slate-200,
.warehouseCargoTracking-page .table-wrap {
  margin-bottom: 16px !important;
  background: #fff !important;
  border: 1px solid #d9eafc !important;
  overflow-x: auto !important;
}

.exportAndFulfillment-page .data-table,
.loadedCargoList-page .data-table,
.warehouseCargoTracking-page .data-table {
  width: 100% !important;
  border-collapse: collapse !important;
  background: #fff !important;
}

.exportAndFulfillment-page .data-table th,
.loadedCargoList-page .data-table th,
.warehouseCargoTracking-page .data-table th {
  padding: 10px 14px !important;
  background: #ecf4ff !important;
  border-bottom: 1px solid #d9eafc !important;
  color: #4d6172 !important;
  font-size: 10px !important;
  font-weight: 800 !important;
  text-align: center !important;
  white-space: nowrap !important;
