/* 1) 상세 모달 */
function openCertDetail(no) {
  var d = certDataStore[no] || certDataStore['IMP-20240519-015'];
  document.getElementById('certD-no').textContent = no;
  document.getElementById('certD-type').textContent = d.type + '신고필증';
  document.getElementById('certD-type').style.color = (d.type === '수입') ? '#565e74' : '#1d6b4f';
  document.getElementById('certD-client').textContent = d.client;
  document.getElementById('certD-clientCode').textContent = d.clientCode;
  document.getElementById('certD-bizNo').textContent = d.bizNo;
  document.getElementById('certD-item').textContent = d.item;
  document.getElementById('certD-hs').textContent = d.hs;
  document.getElementById('certD-acceptDate').textContent = d.acceptDate;
  document.getElementById('certD-customs').textContent = d.customs;
  document.getElementById('certD-officer').textContent = d.officer;
  document.getElementById('certD-bl').textContent = d.bl;
  document.getElementById('certD-invoice').textContent = d.invoice;
  document.getElementById('certD-exchange').textContent = d.exchange;
  document.getElementById('certD-tax').textContent = d.taxTotal;
  document.getElementById('certD-payStatus').textContent = d.payStatus;
  document.getElementById('certD-payDate').textContent = d.payDate;
  document.getElementById('certD-enpNo').textContent = d.enpNo;
  showModal('cert-detail-v2');
}

/* 2) 출력 모달 */
function openCertPrint(no) {
  var d = certDataStore[no] || certDataStore['IMP-20240519-015'];
  document.getElementById('certP-no').textContent = no;
  document.getElementById('certP-client').textContent = d.client;
  document.getElementById('certP-item').textContent = d.item;
  document.getElementById('certP-type').textContent = d.type + '신고필증';
  showModal('cert-print');
}

/* 3) 화주전달 모달 */
function openCertSend(no) {
  var d = certDataStore[no] || certDataStore['IMP-20240519-015'];
  document.getElementById('certS-no').textContent = no;
  document.getElementById('certS-client').textContent = d.client;
  document.getElementById('certS-item').textContent = d.item;
  document.getElementById('certS-type').textContent = d.type + '신고필증';
  document.getElementById('certS-fileName').textContent = no + '_' + d.type + '신고필증.pdf';
  showModal('cert-send');
}
