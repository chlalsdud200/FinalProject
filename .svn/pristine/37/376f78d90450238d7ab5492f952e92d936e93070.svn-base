      #detail-body #export-detail-root-final,#detail-body .import-ui-tabs,#detail-body .import-ui-request-detail,#detail-body .import-ui-section,#detail-body .import-ui-card{border:1px solid #cbd5e1!important;border-radius:0!important;box-shadow:none!important;background:#fff!important;overflow:hidden!important;}
      #detail-body #export-detail-root-final{width:100%!important;border:0!important;background:#fff!important;}
      #detail-body .import-inline-tabs-0513,#detail-body .import-ui-tabs{width:100%!important;min-width:0!important;background:#fff!important;}
