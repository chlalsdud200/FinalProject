/* =========================================================
 * export-detail-tabs.js
 * 수출운송 상세/목록 정리본
 * - 수입운송처럼 운송의뢰 상세 안에서 6개 탭 직접 렌더링
 * - '수출 운송 연계업무' 카드/상세화면 열기 구조 제거
 * ========================================================= */
(function () {
  'use strict';

  if (window.__TACS_EXPORT_DETAIL_TABS_BOOTED__) return;
  window.__TACS_EXPORT_DETAIL_TABS_BOOTED__ = true;

  const EXPORT_GROUP = 'export';
  const EXPORT_FIRST_ITEM = 'TACS-FW-001';
  const DETAIL_ITEM = 'TACS-FW-001';
  const EXPORT_ROUTE_STORAGE_KEY = 'tacs.export.currentRoute.v1';
  const EXPORT_DETAIL_DRAFT_PREFIX = 'tacs.export.requestDetailDraft.';
  const EXPORT_DETAIL_RESTORE_MS = 4500;
  let exportBootRestoreRoute;
  let exportBootRestoreDeadline = 0;

  const DETAIL_TABS = [
    { key: 'detail', label: '수출운송의뢰상세' },
    { key: 'inbound', label: '보세구역 입고관리' },
    { key: 'release', label: '보세구역 반출관리' },
    { key: 'shipping', label: '선적처리' },
    { key: 'bl', label: 'MBL 및 비용청구' },
    { key: 'hbl', label: 'HBL 발급' }
  ];

  const SIDE_PANELS = {
    'TACS-FW-009B': {
      title: '보세구역 입고관리',
      build: () => typeof buildExportInboundManagePanel === 'function' ? buildExportInboundManagePanel() : emptyPanel('보세구역 입고관리'),
      bind: () => { if (typeof bindExportInboundManageActions === 'function') bindExportInboundManageActions(EXPORT_GROUP, 'TACS-FW-009B'); }
    },
    'TACS-FW-009': {
      title: '보세구역 반출관리',
      build: () => typeof buildBondedReleaseRequestListPanel === 'function' ? buildBondedReleaseRequestListPanel() : emptyPanel('보세구역 반출관리'),
      bind: () => {
        if (typeof bindBondedReleaseRequestActions === 'function') bindBondedReleaseRequestActions(EXPORT_GROUP, 'TACS-FW-009');
        else if (typeof bindBondedWorkPanelActions === 'function') bindBondedWorkPanelActions(EXPORT_GROUP, 'TACS-FW-009');
      }
    },
    'TACS-FW-007': {
      title: '선적처리',
      build: () => typeof buildPickupDispatchPanel === 'function' ? buildPickupDispatchPanel() : emptyPanel('선적처리'),
      bind: () => { if (typeof bindPickupDispatchActions === 'function') bindPickupDispatchActions(EXPORT_GROUP, 'TACS-FW-007'); }
    },
    'TACS-FW-010': {
      title: '선적지시서 작성 및 제출',
      build: () => typeof buildShippingInstructionSubmitPanel === 'function' ? buildShippingInstructionSubmitPanel() : emptyPanel('선적지시서 작성 및 제출'),
      bind: () => { if (typeof bindShippingInstructionActions === 'function') bindShippingInstructionActions(EXPORT_GROUP, 'TACS-FW-010'); }
    },
    'TACS-FW-010B': {
      title: 'MBL 및 비용청구',
      build: () => typeof buildBLIssuePanel === 'function' ? buildBLIssuePanel() : emptyPanel('MBL 및 비용청구'),
      bind: () => { if (typeof bindBLIssueActions === 'function') bindBLIssueActions(EXPORT_GROUP, 'TACS-FW-010B'); }
    },
    'TACS-FW-011': {
      title: '적하목록 작성 및 제출',
      build: () => typeof buildExportManifestPanel === 'function' ? buildExportManifestPanel() : emptyPanel('적하목록 작성 및 제출'),
      bind: () => { if (typeof bindExportManifestActions === 'function') bindExportManifestActions(EXPORT_GROUP, 'TACS-FW-011'); }
    }
  };

  function $(id) { return document.getElementById(id); }

  function esc(value) {
    if (value === undefined || value === null || value === '') return '-';
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function html(value) {
    return esc(value).replace(/^-$/, '');
  }

  function dateOnly(value) {
    const raw = String(value === undefined || value === null ? '' : value).trim();
    if (!raw || raw === '-') return '';
    const match = raw.replace(/[./]/g, '-').match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
    if (!match) return raw;
    return match[1] + '-' + match[2].padStart(2, '0') + '-' + match[3].padStart(2, '0');
  }

  function normalizeText(value) {
    return String(value === undefined || value === null ? '' : value).trim();
  }

  function pdfName(value) {
    const raw = normalizeText(value);
    if (!raw || raw === '-') return '';
    return /\.pdf$/i.test(raw) ? raw : raw + '.pdf';
  }

  function pick(row, keys, fallback) {
    for (const key of keys) {
      const value = row && row[key];
      if (value !== undefined && value !== null && String(value).trim() !== '') return value;
    }
    return fallback === undefined ? '' : fallback;
  }

  function normalizeStatus(value) {
    const text = String(value || '').trim();
    const upper = text.toUpperCase();
    if (['TRC_DONE', 'ACCEPTED', 'ACC', 'APPROVED', 'APV'].includes(upper) || text === '접수완료' || text === '승인' || text === '승인완료') return '접수완료';
    if (['TRC_REJECT', 'REJECTED', 'REJ'].includes(upper) || text === '접수반려') return '접수반려';
    if (['TRC_WAIT', 'REQUESTED', 'REQ'].includes(upper) || text === '접수대기') return '접수대기';
    return text || '확인중';
  }

  function requestStatus(row) {
    const keys = ['receiptStatus', 'statusNm', 'statusCd', 'requestStatus', 'approvalStatus'];
    const values = keys.map(key => row && row[key]).filter(value => value !== undefined && value !== null && String(value).trim() !== '');
    if (!values.length) return '';
    if (values.some(value => normalizeStatus(value) === '접수완료')) return '접수완료';
    if (values.some(value => normalizeStatus(value) === '접수반려')) return '접수반려';
    return normalizeStatus(values[0]);
  }

  function isExportRequestAccepted(row) {
    const status = requestStatus(row);
    if (!status) return true;
    return status === '접수완료';
  }

  function lockedPanelHtml() {
    return ''
      + '<div class="import-ui-request-detail">'
      + '  <div class="import-ui-section" style="margin:16px;">'
      + '    <h5>접수완료 후 진행 가능</h5>'
      + '    <p class="text-sm text-slate-600" style="margin:0;">운송의뢰가 접수완료 상태가 아니면 보세구역 입고관리, 보세구역 반출관리, 선적처리, MBL 및 비용청구, HBL 발급을 진행할 수 없습니다.</p>'
      + '  </div>'
      + '</div>';
  }

  function workErrorPanelHtml() {
    return ''
      + '<div class="import-ui-request-detail">'
      + '  <div class="import-ui-section" style="margin:16px;">'
      + '    <h5>화면 로딩 오류</h5>'
      + '    <p class="text-sm text-slate-600" style="margin:0;">탭 화면을 불러오는 중 오류가 발생했습니다. 다시 조회 후 시도해주세요.</p>'
      + '  </div>'
      + '</div>';
  }

  function statusCodeForLabel(label) {
    if (label === '접수완료') return 'TRC_DONE';
    if (label === '접수반려') return 'TRC_REJECT';
    return 'TRC_WAIT';
  }

  function requestNo(row) {
    return pick(row, ['trcNo', 'requestNo', 'treId', 'trcNo']);
  }

  function isRefreshNavigation() {
    try {
      const nav = window.performance && window.performance.getEntriesByType
        ? window.performance.getEntriesByType('navigation')[0]
        : null;
      if (nav && nav.type) return nav.type === 'reload';
      if (window.performance && window.performance.navigation) return window.performance.navigation.type === 1;
    } catch (ignore) {}
    return false;
  }

  function requestSnapshot(row) {
    if (!row || typeof row !== 'object') return null;
    const snap = {};
    Object.keys(row).forEach(key => {
      const value = row[key];
      if (value == null || ['string', 'number', 'boolean'].includes(typeof value)) snap[key] = value;
    });
    const no = requestNo(row);
    if (no) {
      snap.trcNo = snap.trcNo || no;
      snap.requestNo = snap.requestNo || no;
      snap.treId = snap.treId || no;
    }
    return snap;
  }

  function readStoredExportRoute() {
    try {
      const raw = window.sessionStorage && window.sessionStorage.getItem(EXPORT_ROUTE_STORAGE_KEY);
      return raw ? JSON.parse(raw) : null;
    } catch (ignore) {
      return null;
    }
  }

  function routeFromHistoryState() {
    try {
      const state = window.history && window.history.state ? window.history.state : null;
      if (!state) return null;
      if (state.tacsExportRoute) return state.tacsExportRoute;
    } catch (ignore) {}
    return null;
  }

  function isExportDetailRoute(route) {
    return !!(route && route.type === 'request-detail' && route.requestNo);
  }

  function clearExportDetailRestore() {
    exportBootRestoreDeadline = 0;
    exportBootRestoreRoute = null;
  }

  function isRecentUserExportNav(itemId) {
    const nav = window.__TACS_TRANSPORT_USER_NAV || null;
    return !!(nav
      && nav.group === EXPORT_GROUP
      && String(nav.item || '') === String(itemId || '')
      && Date.now() - Number(nav.ts || 0) < 2000);
  }

  function bootExportDetailRoute() {
    if (exportBootRestoreRoute !== undefined) return exportBootRestoreRoute;
    const stored = routeFromHistoryState() || readStoredExportRoute();
    exportBootRestoreRoute = isRefreshNavigation() && isExportDetailRoute(stored) ? stored : null;
    if (exportBootRestoreRoute) exportBootRestoreDeadline = Date.now() + EXPORT_DETAIL_RESTORE_MS;
    return exportBootRestoreRoute;
  }

  function activeExportDetailRoute() {
    if (isRecentUserExportNav(EXPORT_FIRST_ITEM)) {
      clearExportDetailRestore();
      return null;
    }
    const boot = bootExportDetailRoute();
    if (boot && exportBootRestoreDeadline && Date.now() <= exportBootRestoreDeadline) return boot;
    return routeFromHistoryState() || (isRefreshNavigation() ? readStoredExportRoute() : null);
  }

  function rememberExportDetailRoute(row, activeKey) {
    const no = requestNo(row);
    if (!no) return;
    const route = {
      type: 'request-detail',
      requestNo: no,
      activeKey: activeKey || 'detail',
      request: requestSnapshot(row),
      ts: Date.now()
    };
    try {
      if (window.sessionStorage) window.sessionStorage.setItem(EXPORT_ROUTE_STORAGE_KEY, JSON.stringify(route));
    } catch (ignore) {}
    try {
      if (window.history && window.history.replaceState) {
        const url = new URL(window.location.href);
        url.pathname = (typeof getContextPath === 'function' ? getContextPath() : '') + '/transport/export.do';
        url.searchParams.set('tab', activeKey === 'detail' ? 'request' : activeKey);
        const state = Object.assign({}, window.history.state || {});
        state.group = EXPORT_GROUP;
        state.item = EXPORT_FIRST_ITEM;
        state.tacsExportRoute = route;
        window.history.replaceState(state, '', url.pathname + url.search + url.hash);
      }
    } catch (ignore) {}
  }

  function rememberExportListRoute(itemId) {
    clearExportDetailRestore();
    try { if (window.sessionStorage) window.sessionStorage.removeItem(EXPORT_ROUTE_STORAGE_KEY); } catch (ignore) {}
    try {
      if (window.history && window.history.replaceState) {
        const url = new URL(window.location.href);
        url.pathname = (typeof getContextPath === 'function' ? getContextPath() : '') + '/transport/export.do';
        url.searchParams.delete('tab');
        if (itemId && itemId !== EXPORT_FIRST_ITEM) url.searchParams.set('page', itemId);
        const state = Object.assign({}, window.history.state || {});
        state.group = EXPORT_GROUP;
        state.item = itemId || EXPORT_FIRST_ITEM;
        delete state.tacsExportRoute;
        window.history.replaceState(state, '', url.pathname + url.search + url.hash);
      }
    } catch (ignore) {}
  }

  function draftKey(no) {
    return EXPORT_DETAIL_DRAFT_PREFIX + normalizeText(no);
  }

  function readDraft(no) {
    no = normalizeText(no);
    if (!no || !window.sessionStorage) return null;
    try {
      const raw = sessionStorage.getItem(draftKey(no));
      return raw ? JSON.parse(raw) : null;
    } catch (ignore) {
      return null;
    }
  }

  function removeDraft(no) {
    no = normalizeText(no);
    if (!no || !window.sessionStorage) return;
    try { sessionStorage.removeItem(draftKey(no)); } catch (ignore) {}
  }

  function mergeDraft(row) {
    row = Object.assign({}, row || {});
    const draft = readDraft(requestNo(row));
    if (!draft || !draft.requestNo) return row;
    row.buyerNm = row.consigneeName = draft.buyerName || '';
    row.buyerCountryCd = row.consigneeCountry = draft.buyerCountry || '';
    row.transportMeanNm = row.transportMode = draft.transportMode || '';
    row.transportTypeCd = row.transportType = draft.transportType || '';
    row.deptPortNm = row.origin = draft.originPort || '';
    row.arvlPortNm = row.destination = draft.destinationPort || '';
    row.blType = draft.blType || '';
    row.itemCategory = row.goodsName = draft.itemCategory || '';
    row.requestCn = row.requestNote = row.requestMemo = draft.requestNote || '';
    return row;
  }

  function readDraftPayload(root) {
    const value = function (name) {
      const el = root ? root.querySelector('[name="' + name + '"]') : null;
      return el ? normalizeText(el.value) : '';
    };
    return {
      requestNo: root ? normalizeText(root.dataset.requestNo || '') : requestNo(window.selectedExportRequest || {}),
      buyerName: value('buyerName'),
      buyerCountry: value('buyerCountry'),
      transportMode: value('transportMode'),
      transportType: value('transportType'),
      originPort: value('originPort'),
      destinationPort: value('destinationPort'),
      blType: value('blType'),
      itemCategory: value('itemCategory'),
      requestNote: value('requestNote')
    };
  }

  function saveDraft(root) {
    if (!root || !root.classList || !root.classList.contains('import-ui-main-request-detail')) return;
    const payload = readDraftPayload(root);
    if (!payload.requestNo || !window.sessionStorage) return;
    try { sessionStorage.setItem(draftKey(payload.requestNo), JSON.stringify(payload)); } catch (ignore) {}
  }

  function allRequests() {
    return Array.isArray(window.TRANSPORT_EXPORT_REQUESTS) ? window.TRANSPORT_EXPORT_REQUESTS : [];
  }

  function findRequest(no) {
    return allRequests().find(row => String(requestNo(row)) === String(no)) || {};
  }

  function rowFromExportRoute(route) {
    if (!isExportDetailRoute(route)) return {};
    return mergeSelected(Object.assign({}, route.request || {}, findRequest(route.requestNo), {
      trcNo: route.requestNo,
      requestNo: route.requestNo,
      treId: route.requestNo
    }));
  }

  function mergeSelected(row) {
    const base = row || window.selectedExportRequest || window.currentExportDetail || window.__currentExportDetailRow || {};
    const no = requestNo(base);
    const dbRow = no ? findRequest(no) : {};
    const merged = mergeDraft(Object.assign({}, dbRow, base));
    window.selectedExportRequest = merged;
    window.currentExportDetail = merged;
    window.__currentExportDetailRow = merged;
    return merged;
  }

  function rowFromDetailButton(btn) {
    const ds = btn && btn.dataset ? btn.dataset : {};
    const no = ds.requestNo || ds.trcNo || ds.treId || '';
    return mergeSelected(Object.assign({}, findRequest(no), {
      trcNo: no,
      requestNo: no,
      requestDt: ds.receiptDate || ds.requestDt,
      ownerNm: ds.shipperName || ds.ownerNm,
      ownerPicNm: ds.shipperContact || ds.ownerPicNm,
      ownerTelno: ds.shipperPhone || ds.ownerTelno,
      ownerEmail: ds.shipperEmail || ds.ownerEmail,
      buyerNm: ds.consigneeName || ds.buyerNm,
      buyerCountryCd: ds.consigneeCountry || ds.buyerCountryCd,
      buyerAdres: ds.consigneeAddress || ds.buyerAdres,
      buyerTelno: ds.consigneePhone || ds.buyerTelno,
      deptPortNm: ds.origin || ds.deptPortNm,
      arvlPortNm: ds.destination || ds.arvlPortNm,
      transportMeanNm: ds.transportMode || ds.transportMeanNm,
      transportTypeCd: ds.transportType || ds.transportTypeCd,
      incoTermsCd: ds.tradeTerm || ds.incoTermsCd,
      requestCn: ds.requestNote || ds.requestCn,
      invoiceFile: ds.invoiceFile,
      invoiceFileNo: ds.invoiceFileNo,
      packingListFile: ds.packingListFile,
      packingListFileNo: ds.packingListFileNo,
      requestFile: ds.requestFile,
      statusNm: ds.receiptStatus || ds.statusNm,
      statusCd: ds.statusCd,
      rejectReason: ds.rejectReason
    }));
  }

  function setPageShell(title, itemId) {
    const dashboard = $('dashboard-view');
    const detail = $('detail-view');
    const pageTitle = $('page-title');
    const crumb = $('breadcrumb');
    const body = $('detail-body');

    if (dashboard) dashboard.classList.add('hidden');
    if (detail) detail.classList.remove('hidden');
    if (pageTitle) pageTitle.textContent = title || '운송의뢰';
    if (crumb) crumb.innerHTML = '수출운송 &gt; <span class="font-semibold text-slate-900">' + esc(title || '운송의뢰') + '</span>';
    if (body) {
      body.dataset.currentGroup = EXPORT_GROUP;
      body.dataset.currentItem = itemId || EXPORT_FIRST_ITEM;
      window.detailBody = body;
    }
    try { currentGroupKey = EXPORT_GROUP; currentItemId = itemId || EXPORT_FIRST_ITEM; } catch (ignore) {}
    if (typeof toggleMenuGroup === 'function') toggleMenuGroup(EXPORT_GROUP, true);
    if (typeof setActiveNav === 'function') setActiveNav(EXPORT_GROUP, itemId || EXPORT_FIRST_ITEM);
  }

  function clearExportBody(itemId) {
    const body = $('detail-body');
    if (!body) return null;
    body.dataset.currentGroup = EXPORT_GROUP;
    body.dataset.currentItem = itemId || EXPORT_FIRST_ITEM;
    body.innerHTML = '';
    return body;
  }



  function purgeDuplicateExportRequestScreens() {
    const body = $('detail-body');
    if (!body) return;
    if (body.dataset.currentGroup !== EXPORT_GROUP || body.dataset.currentItem !== EXPORT_FIRST_ITEM) return;

    const roots = [];
    Array.from(body.children || []).forEach(function (child) {
      if (child && child.id === 'export-request-root-final') roots.push(child);
    });
    if (!roots.length) return;

    const keep = roots[roots.length - 1];
    Array.from(body.children || []).forEach(function (child) {
      if (child !== keep) child.remove();
    });
  }

  function ensureExportRequestSingleScreenGuard() {
    const body = $('detail-body');
    if (!body || body.__tacsExportRequestSingleScreenGuard) return;
    body.__tacsExportRequestSingleScreenGuard = true;
    const observer = new MutationObserver(function () {
      setTimeout(purgeDuplicateExportRequestScreens, 0);
    });
    observer.observe(body, { childList: true });
    setTimeout(purgeDuplicateExportRequestScreens, 0);
  }

  function injectDetailStyle() {
    [
      'export-detail-tabs-clean-style-20260522',
      'export-detail-tabs-import-same-20260522-v2',
      'tacs-export-import-ui-style-20260522-v3'
    ].forEach(id => {
      const old = document.getElementById(id);
      if (old) old.remove();
    });
    const style = document.createElement('style');
    style.id = 'tacs-export-import-ui-style-20260522-v3';
    style.textContent = `
      #detail-body{font-family:Pretendard,"Noto Sans KR","Malgun Gothic",Arial,sans-serif!important;color:#0f172a!important;font-size:12px!important;}
      #detail-body *{letter-spacing:0!important;box-sizing:border-box!important;}
      #detail-body .section-card,#detail-body #export-detail-root-final,#detail-body .import-ui-tabs,#detail-body .import-ui-request-detail,#detail-body .import-ui-section,#detail-body .import-ui-card{border:1px solid #cbd5e1!important;border-radius:0!important;box-shadow:none!important;background:#fff!important;overflow:hidden!important;}
      #detail-body .section-card>.bg-slate-50,#detail-body .section-card>div:first-child.bg-slate-50{height:52px!important;min-height:52px!important;display:flex!important;align-items:center!important;padding:0 24px!important;background:#f8fafc!important;border-bottom:1px solid #cbd5e1!important;}
      #detail-body h4,#detail-body h5{font-size:12px!important;font-weight:900!important;color:#0f172a!important;line-height:1.2!important;letter-spacing:0!important;}
      #detail-body .field-label,#detail-body .list-search-grid label,#detail-body .release-search-grid label,#detail-body .inland-search-grid label,#detail-body .import-ui-field label{display:block!important;margin:0 0 6px!important;font-size:11px!important;font-weight:900!important;line-height:1.2!important;color:#334155!important;}
      #detail-body .field-input,#detail-body .field-select,#detail-body input[type="text"],#detail-body input[type="date"],#detail-body input[type="datetime-local"],#detail-body input[type="number"],#detail-body select,#detail-body textarea{width:100%!important;min-height:40px!important;height:40px!important;padding:0 10px!important;border:1px solid #cbd5e1!important;border-radius:0!important;background:#fff!important;color:#0f172a!important;font-size:12px!important;font-weight:700!important;line-height:40px!important;outline:0!important;box-shadow:none!important;}
      #detail-body textarea,#detail-body .field-textarea{height:auto!important;min-height:76px!important;line-height:1.5!important;padding:10px!important;}
      #detail-body input[readonly],#detail-body textarea[readonly],#detail-body select[disabled],#detail-body input:disabled,#detail-body .bg-slate-50,#detail-body .bg-slate-100,#detail-body .bg-gray-100{background:#e5e7eb!important;color:#334155!important;-webkit-text-fill-color:#334155!important;opacity:1!important;}
      #detail-body .list-search-grid,#detail-body .release-search-grid,#detail-body .inland-search-grid,#detail-body .do-list-search-grid{display:grid!important;grid-template-columns:repeat(auto-fit,minmax(170px,1fr)) 52px!important;gap:10px!important;align-items:end!important;margin:0 0 14px 0!important;}
      #detail-body .list-search-grid>button,#detail-body .release-search-grid>button,#detail-body .inland-search-grid>button,#detail-body .do-list-search-grid>button{width:52px!important;min-width:52px!important;max-width:52px!important;padding:0!important;}
      #detail-body table,#detail-body .tbl,#detail-body .import-ui-goods-table,#detail-body .import-ui-doc-table{width:100%!important;border-collapse:collapse!important;border-spacing:0!important;font-size:12px!important;color:#0f172a!important;}
      #detail-body table th,#detail-body .tbl th,#detail-body table td,#detail-body .tbl td,#detail-body .import-ui-goods-table th,#detail-body .import-ui-goods-table td,#detail-body .import-ui-doc-table th,#detail-body .import-ui-doc-table td{border-left:1px solid #e2e8f0!important;border-right:1px solid #e2e8f0!important;border-bottom:1px solid #e2e8f0!important;font-size:12px!important;line-height:1.35!important;vertical-align:middle!important;}
      #detail-body table th:first-child,#detail-body .tbl th:first-child,#detail-body table td:first-child,#detail-body .tbl td:first-child{border-left:0!important;}
