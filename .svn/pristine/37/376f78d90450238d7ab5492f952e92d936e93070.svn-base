      #detail-body .import-ui-tab.is-disabled{opacity:.45!important;cursor:not-allowed!important;background:#f8fafc!important;color:#94a3b8!important;}
      #detail-body .import-ui-tab.is-active{background:#e8eef7!important;color:#0f172a!important;box-shadow:none!important;}
      #detail-body .import-ui-panel{display:block!important;padding:0!important;background:#fff!important;border:0!important;}
      #detail-body .import-ui-request-detail{border:1px solid #cbd5e1!important;border-top:0!important;background:#fff!important;}
      #detail-body .import-ui-panel .import-ui-request-detail{border:1px solid #cbd5e1!important;border-top:0!important;}
      #detail-body .import-ui-grid3{display:grid!important;grid-template-columns:repeat(3,minmax(0,1fr))!important;gap:16px!important;padding:16px!important;align-items:stretch!important;}
      #detail-body .import-ui-section{padding:14px 16px!important;background:#fff!important;}
      #detail-body .import-ui-section h4,#detail-body .import-ui-section h5{margin:0 0 12px!important;padding-left:9px!important;border-left:4px solid #334155!important;color:#0f172a!important;font-size:12px!important;font-weight:900!important;line-height:1.2!important;}
      #detail-body .import-ui-field{margin:0 0 10px!important;}
      #detail-body .import-ui-field:last-child{margin-bottom:0!important;}
      #detail-body .import-ui-field label{display:block!important;margin:0 0 6px!important;font-size:11px!important;font-weight:900!important;line-height:1.2!important;color:#475569!important;}
      #detail-body .import-ui-field input,#detail-body .import-ui-field textarea,#detail-body .import-ui-field select{width:100%!important;min-height:40px!important;height:40px!important;padding:0 10px!important;border:1px solid #cbd5e1!important;border-radius:0!important;background:#fff!important;color:#0f172a!important;font-size:12px!important;font-weight:700!important;line-height:40px!important;outline:0!important;box-shadow:none!important;}
      #detail-body .import-ui-field input[readonly],#detail-body .import-ui-field textarea[readonly],#detail-body .import-ui-field select[disabled]{background:#e5e7eb!important;color:#334155!important;-webkit-text-fill-color:#334155!important;opacity:1!important;}
      #detail-body .import-ui-field textarea{height:auto!important;min-height:76px!important;line-height:1.5!important;padding:10px!important;resize:vertical!important;font-family:inherit!important;}
      #detail-body .import-ui-file-cell{display:flex!important;gap:8px!important;align-items:center!important;}
      #detail-body .import-ui-file-cell input{min-width:0!important;}
      #detail-body .import-ui-file-download{display:inline-flex!important;align-items:center!important;justify-content:center!important;flex:0 0 auto!important;min-width:72px!important;height:40px!important;min-height:40px!important;border:1px solid #334155!important;background:#1e293b!important;color:#fff!important;-webkit-text-fill-color:#fff!important;padding:0 11px!important;font-size:12px!important;font-weight:900!important;line-height:1!important;text-decoration:none!important;}
      #detail-body .import-ui-actions{display:flex!important;justify-content:flex-end!important;align-items:center!important;gap:8px!important;min-height:56px!important;padding:10px 16px!important;border-top:1px solid #cbd5e1!important;background:#fff!important;}
      #detail-body .import-ui-btn{min-width:64px!important;font-size:12px!important;padding:0 14px!important;}
      #detail-body .import-ui-btn:hover{background:#334155!important;color:#fff!important;}
      #detail-body .import-ui-btn.danger{background:#991b1b!important;border-color:#991b1b!important;color:#fff!important;}
      #detail-body .info-chip,#detail-body .status-chip,#detail-body [class*="status-chip"]{display:inline-flex!important;align-items:center!important;justify-content:center!important;min-width:58px!important;height:28px!important;min-height:28px!important;padding:0 10px!important;border:1px solid #cbd5e1!important;border-radius:0!important;background:#f8fafc!important;color:#0f172a!important;-webkit-text-fill-color:#0f172a!important;font-size:11px!important;font-weight:900!important;line-height:1!important;white-space:nowrap!important;}
      #detail-body .export-request-status-badge{display:inline-flex!important;align-items:center!important;justify-content:center!important;min-width:58px!important;height:26px!important;padding:0 8px!important;border:1px solid #cbd5e1!important;border-radius:0!important;background:#f8fafc!important;color:#0f172a!important;font-size:11px!important;font-weight:900!important;line-height:1!important;white-space:nowrap!important;}
      #detail-body .export-request-status-badge.export-tone-done{background:#ecfdf5!important;color:#047857!important;border-color:#a7f3d0!important;}
      #detail-body .export-request-status-badge.export-tone-danger{background:#fff1f2!important;color:#be123c!important;border-color:#fecdd3!important;}
      #detail-body .export-request-status-badge.export-tone-wait{background:#eaf2ff!important;color:#1e3a8a!important;border-color:#c7dafe!important;}
      #detail-body .export-request-table-wrap{border:1px solid #cbd5e1!important;background:#fff!important;}
