/* import-inland.js
 * 수입운송 > 내륙운송 배차처리 목록 화면.
 * - 왼쪽 메뉴에서 열리는 목록 전용 화면
 * - 상세 탭의 배차 처리 로직은 import-ui.js에서 담당
 */
(function () {
    'use strict';

    if (window.__TACS_IMPORT_INLAND_CLEAN_20260522) return;
    window.__TACS_IMPORT_INLAND_CLEAN_20260522 = true;

    function esc(value) {
        return String(value == null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function contextPath() {
        const fromGlobal = window.contextPath || window.CONTEXT_PATH || window.APP_CONTEXT_PATH;
        return fromGlobal ? String(fromGlobal).replace(/\/$/, '') : '';
    }

    function apiUrl(path) {
        return contextPath() + path;
    }

    function installStyle() {
        if (document.getElementById('tacs-import-inland-clean-style')) return;
        const style = document.createElement('style');
        style.id = 'tacs-import-inland-clean-style';
        style.textContent = [
            '#detail-body .inland-search-grid{display:grid!important;grid-template-columns:repeat(auto-fit,minmax(170px,1fr)) 52px!important;gap:10px!important;align-items:end!important;margin-bottom:14px!important;}',
            '#detail-body .inland-search-grid label{display:block!important;margin:0 0 6px 0!important;font-size:12px!important;font-weight:900!important;line-height:1!important;color:#0f172a!important;}',
            '#detail-body .inland-search-grid input,#detail-body .inland-search-grid select{height:40px!important;min-height:40px!important;box-sizing:border-box!important;}',
            '#detail-body .inland-search-grid button{width:52px!important;min-width:52px!important;max-width:52px!important;height:40px!important;min-height:40px!important;padding:0!important;background:#334155!important;border:1px solid #334155!important;color:#fff!important;-webkit-text-fill-color:#fff!important;font-size:12px!important;font-weight:900!important;}'
        ].join('');
        document.head.appendChild(style);
    }

    window.getTransportContextPath = window.getTransportContextPath || contextPath;
    window.importApiUrl = window.importApiUrl || apiUrl;

    window.importInlandDispatchState = window.importInlandDispatchState || {
        rows: window.TRANSPORT_IMPORT_INLAND_DISPATCH_LIST || window.IMPORT_INLAND_TRANSPORT_LIST || window.TRANSPORT_IMPORT_INLAND_LIST || [],
        cars: window.TRANSPORT_IMPORT_INLAND_CAR_LIST || [],
        selectedTrcNo: null
    };

    function releaseStatusText(row) {
        const raw = String((row && (row.releaseStatusNm || row.releaseStatus || row.releaseStatusCd)) || '').trim();
        const upper = raw.toUpperCase();
        if (upper === 'REL_DONE' || raw === '반출완료') return '반출완료';
        if (upper === 'REL_WAIT' || upper === 'REL_REQ' || upper === 'REQUESTED' || raw === '요청완료') return '반출대기';
        if (upper === 'REL_SENT') return '보완제출완료';
        if (upper === 'REL_FIX' || upper === 'REL_REJECT') return '보완요청';
        return raw || '-';
    }

    function dispatchStatusText(row) {
        const raw = String((row && (row.dispatchStatusNm || row.dispatchStatusCd || row.statusNm)) || '').trim();
        const upper = raw.toUpperCase();
        if (upper === 'TRC_DISPATCH_DONE' || raw === '배차완료') return '배차완료';
        return raw || '배차대기';
    }

    function getFilters() {
        return {
            req: String(window.__TACS_IMPORT_INLAND_REQ_FILTER || '').trim().toLowerCase(),
            owner: String(window.__TACS_IMPORT_INLAND_OWNER_FILTER || '').trim().toLowerCase(),
            item: String(window.__TACS_IMPORT_INLAND_ITEM_FILTER || '').trim().toLowerCase(),
            release: String(window.__TACS_IMPORT_INLAND_RELEASE_FILTER || '').trim(),
            status: String(window.__TACS_IMPORT_INLAND_STATUS_FILTER || '').trim()
        };
    }

    function applyFilterValues() {
        const byId = id => document.getElementById(id);
        window.__TACS_IMPORT_INLAND_REQ_FILTER = byId('importInlandReqFilter')?.value || '';
        window.__TACS_IMPORT_INLAND_OWNER_FILTER = byId('importInlandOwnerFilter')?.value || '';
        window.__TACS_IMPORT_INLAND_ITEM_FILTER = byId('importInlandItemFilter')?.value || '';
        window.__TACS_IMPORT_INLAND_RELEASE_FILTER = byId('importInlandReleaseFilter')?.value || '';
        window.__TACS_IMPORT_INLAND_STATUS_FILTER = byId('importInlandDispatchStatusFilter')?.value || '';
        window.renderImportInlandDispatchRows();
    }

    window.renderImportInlandDispatchRows = function renderImportInlandDispatchRows() {
        const tbody = document.getElementById('importInlandDispatchTbody');
        if (!tbody) return;

        const filters = getFilters();
        let rows = window.importInlandDispatchState.rows || [];
        rows = rows.filter(function (row) {
            const trcNo = String(row.trcNo || '').toLowerCase();
            const owner = String(row.ownerNm || row.ownerId || '').toLowerCase();
            const item = String(row.itemNm || row.itemCategoryNm || row.frghtIemNm || row.goodsName || '').toLowerCase();
            const release = releaseStatusText(row);
            const dispatch = dispatchStatusText(row);
            return (!filters.req || trcNo.includes(filters.req))
                && (!filters.owner || owner.includes(filters.owner))
                && (!filters.item || item.includes(filters.item))
                && (!filters.release || release === filters.release)
                && (!filters.status || dispatch === filters.status);
        });

        if (!rows.length) {
            tbody.innerHTML = '<tr><td colspan="5" class="px-3 py-6 text-center text-slate-500">조건에 맞는 내륙운송 배차 목록이 없습니다.</td></tr>';
            return;
        }

        tbody.innerHTML = rows.map(function (row) {
            const release = releaseStatusText(row);
            const dispatch = dispatchStatusText(row);
            const dispatchClass = dispatch === '배차완료' ? 'done' : 'wait';
            return ''
                + '<tr data-trc-no="' + esc(row.trcNo || '') + '">'
                + '<td><b>' + esc(row.trcNo || '-') + '</b></td>'
                + '<td>' + esc(row.ownerNm || row.ownerId || '-') + '</td>'
                + '<td>' + esc(row.itemNm || row.itemCategoryNm || row.frghtIemNm || row.goodsName || '-') + '</td>'
                + '<td><span class="inland-chip done">' + esc(release) + '</span></td>'
                + '<td><span class="inland-chip ' + dispatchClass + '">' + esc(dispatch) + '</span></td>'
                + '</tr>';
        }).join('');
    };

    window.refreshImportInlandDispatch = async function refreshImportInlandDispatch() {
        try {
            const listRes = await fetch(apiUrl('/transport/import/inland-dispatch/list.do?_=' + Date.now()), {
                headers: {'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                credentials: 'same-origin',
                cache: 'no-store'
            });
            window.importInlandDispatchState.rows = listRes.ok ? await listRes.json() : [];
            window.TRANSPORT_IMPORT_INLAND_DISPATCH_LIST = window.importInlandDispatchState.rows;
            window.__TACS_IMPORT_INLAND_ROWS = window.importInlandDispatchState.rows;
            window.renderImportInlandDispatchRows();
        } catch (error) {
            console.error('[내륙운송 배차 목록 조회 실패]', error);
            const tbody = document.getElementById('importInlandDispatchTbody');
            if (tbody) tbody.innerHTML = '<tr><td colspan="5" class="px-3 py-6 text-center text-danger">내륙운송 배차 목록 조회에 실패했습니다.</td></tr>';
        }
    };

    // 예전 코드에서 호출하던 함수명 보존용. 목록 화면에서는 상세 선택을 쓰지 않는다.
    window.selectImportInlandDispatch = function selectImportInlandDispatch(trcNo) {
        window.importInlandDispatchState.selectedTrcNo = trcNo || null;
    };
    window.renderImportInlandCarOptions = function renderImportInlandCarOptions() {};
    window.renderImportInlandSelectedDetail = function renderImportInlandSelectedDetail() {};
    window.submitImportInlandDispatch = function submitImportInlandDispatch() {
        alert('내륙배차 처리는 운송의뢰 상세의 내륙배차 탭에서 진행해주세요.');
    };

    window.buildImportInlandTransportPanel = function buildImportInlandTransportPanel() {
        installStyle();
        setTimeout(function () {
            window.refreshImportInlandDispatch();
            const btn = document.getElementById('importInlandDispatchSearchBtn');
            if (btn && !btn.dataset.bound) {
                btn.dataset.bound = 'Y';
                btn.addEventListener('click', applyFilterValues);
            }
            ['importInlandReqFilter', 'importInlandOwnerFilter', 'importInlandItemFilter', 'importInlandReleaseFilter', 'importInlandDispatchStatusFilter'].forEach(function (id) {
                const el = document.getElementById(id);
                if (el && !el.dataset.bound) {
                    el.dataset.bound = 'Y';
                    el.addEventListener('keydown', function (event) {
                        if (event.key === 'Enter') applyFilterValues();
                    });
                    el.addEventListener('change', function () {
                        if (el.tagName === 'SELECT') applyFilterValues();
                    });
                }
            });
        }, 0);

        const val = key => esc(window[key] || '');
        const sel = (key, value) => String(window[key] || '') === value ? ' selected' : '';

        return ''
            + '<div id="pickupDispatchListPanel" class="section-card import-left-list-card" style="width:100%;">'
            + '<div class="bg-slate-50 px-6 py-4 border-b border-slate-200"><h4 class="text-sm font-bold text-slate-900">내륙운송 배차처리</h4></div>'
            + '<div class="p-6" style="display:flex;flex-direction:column;gap:16px;width:100%;">'
            + '<div class="inland-search-grid">'
            + '<div><label>의뢰번호</label><input id="importInlandReqFilter" class="field-input" value="' + val('__TACS_IMPORT_INLAND_REQ_FILTER') + '" placeholder="의뢰번호"></div>'
            + '<div><label>화주명</label><input id="importInlandOwnerFilter" class="field-input" value="' + val('__TACS_IMPORT_INLAND_OWNER_FILTER') + '" placeholder="화주명"></div>'
            + '<div><label>품목명</label><input id="importInlandItemFilter" class="field-input" value="' + val('__TACS_IMPORT_INLAND_ITEM_FILTER') + '" placeholder="품목명"></div>'
            + '<div><label>반출상태</label><select id="importInlandReleaseFilter" class="field-select"><option value="">전체</option><option value="반출완료"' + sel('__TACS_IMPORT_INLAND_RELEASE_FILTER', '반출완료') + '>반출완료</option></select></div>'
            + '<div><label>배차상태</label><select id="importInlandDispatchStatusFilter" class="field-select"><option value="">전체</option><option value="배차대기"' + sel('__TACS_IMPORT_INLAND_STATUS_FILTER', '배차대기') + '>배차대기</option><option value="배차완료"' + sel('__TACS_IMPORT_INLAND_STATUS_FILTER', '배차완료') + '>배차완료</option></select></div>'
            + '<button type="button" id="importInlandDispatchSearchBtn">조회</button>'
            + '</div>'
            + '<div class="inland-table-wrap"><table class="inland-table"><thead><tr>'
            + '<th>의뢰번호</th><th>화주명</th><th>품목명</th><th>반출상태</th><th>배차상태</th>'
            + '</tr></thead><tbody id="importInlandDispatchTbody"><tr><td colspan="5" class="px-3 py-6 text-center text-slate-500">내륙운송 배차 목록을 조회하는 중입니다.</td></tr></tbody></table></div>'
            + '</div></div>';
    };
})();
