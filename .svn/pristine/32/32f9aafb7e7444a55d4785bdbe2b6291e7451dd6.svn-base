@charset "UTF-8";

/* 이 파일에는 사이드바/헤더 CSS를 넣지 않는다. */
.report-receipt-page {
  padding: 24px 28px;
}

.page-inner {
  padding: 0;
}



/* basicScreenList.css - 신고접수목록 디자인 기준 */
.breadcrumb {
  display: flex;
  gap: 6px;
  align-items: center;
  margin-bottom: 10px;
  font-size: 11px;
  color: #64748b;
}

.breadcrumb strong {
  background: #1e3054;
  color: #fff;
  padding: 2px 8px;
  font-size: 10px;
}

.page-title {
  margin-bottom: 10px;
  font-size: 20px;
  font-weight: 900;
  color: #0f172a;
}

.page-banner {
  margin-bottom: 20px;
  padding: 14px 20px;
  background: #1e3054;
  color: #fff;
}

.page-banner h3 {
  margin: 0 0 3px;
  font-size: 14px;
  font-weight: 900;
}

.page-banner p {
  margin: 0;
  font-size: 11px;
  color: rgba(255,255,255,.7);
}

.search-panel {
  margin-bottom: 18px;
  background: #fff;
  border: 1px solid #dde4ef;
}

.search-title {
  position: relative;
  padding: 8px 16px 8px 20px;
  border-bottom: 1px solid #dde4ef;
  font-size: 13px;
  font-weight: 900;
  color: #111827;
  margin-bottom: 6px;
}

.search-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 4px;
  height: 100%;
  background: #536178;
}

.search-row {
  display: flex;
  align-items: center;
  min-height: 50px;
  padding: 8px 16px;
  gap: 15px;
}

.search-row.last-row {
  border-bottom: 0;
   padding-bottom: 12px;
}

.search-label {
  width: 80px;
  flex: 0 0 90px;
  font-size: 12px;
  font-weight: 700;
  color: #374151;
}

.search-field {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
}

.form-input,
.form-select {
  height: 33px;
  padding: 0 10px;
  border: 1px solid #d1d9e6;
  background: #fff;
  color: #0f172a;
  font-size: 12px;
  outline: none;
}

.form-input:focus,
.form-select:focus {
  border-color: #3b5bdb;
}

.input-md { width: 200px; }
.select-sm { width: 140px; }
.date-input { width: 130px; }
.date-sep { color: #94a3b8; }

.radio-group label {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  margin-right: 12px;
  font-size: 12px;
  font-weight: 600;
  color: #374151;
}

.btn-primary,
.btn-secondary,
.btn-danger {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 33px;
  padding: 0 14px;
  border: 1px solid transparent;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  white-space: nowrap;
}

.btn-primary {
  background: #1e3054;
  border-color: #1e3054;
  color: #fff;
}

.btn-primary:hover { background: #152540; }

.btn-secondary {
  background: #fff;
  border-color: #cbd8e8;
  color: #334155;
}

.btn-secondary:hover { background: #f1f5f9; }

.btn-danger {
  background: #fef2f2;
  border-color: #fca5a5;
  color: #991b1b;
}

.btn-danger:hover { background: #fee2e2; }

.btn-sm {
  height: 28px;
  padding: 0 10px;
  font-size: 11px;
}

.btn-quick {
  height: 33px;
  padding: 0 10px;
  font-size: 11px;
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.result-count {
  font-size: 15px;
  font-weight: 700;
  color: #1e293b;
}

.result-count span {
  margin-left: 6px;
  color: #2563eb;
}

.result-actions {
  display: flex;
  gap: 6px;
}

.table-card {
  background: #fff;
  border: 1px solid #d9eafc;
  overflow-x: auto;
}

.receipt-table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
}

.receipt-table th {
  padding: 10px 14px;
  background: #ecf4ff;
  border-bottom: 1px solid #d9eafc;
  color: #4d6172;
  font-size: 10px;
  font-weight: 800;
  text-align: center;
  white-space: nowrap;
}

.receipt-table td {
  padding: 11px 14px;
  border-bottom: 1px solid #d9eafc;
  color: #203444;
  font-size: 12px;
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
}

.receipt-table tbody tr:hover td {
  background: #f8fbff;
}

.receipt-table strong {
  font-weight: 700;
  color: #0f2537;
}

.col-check { width: 40px; }
.row-mine td:first-child { border-left: 3px solid #3b5bdb; }
.row-others td,
.row-others strong { color: #94a3b8; }

.badge-mine,
.badge-others {
  display: inline-block;
  margin-left: 5px;
  padding: 1px 5px;
  border: 1px solid #cbd5e1;
  font-size: 9px;
  font-weight: 700;
}

.badge-mine {
  background: #eff6ff;
  color: #1d4ed8;
  border-color: #bfdbfe;
}

.badge-others {
  background: #f1f5f9;
  color: #64748b;
}

.status-text {
  font-weight: 700;
  color: #203444;
}

.risk-text {
  font-size: 11px;
  font-weight: 800;
}

.risk-text.low,
.risk-text.LOW { color: #15803d; }
.risk-text.mid,
.risk-text.MID { color: #c05621; }
.risk-text.high,
.risk-text.HIGH { color: #b91c1c; }

.action-buttons {
  display: flex;
  justify-content: center;
  gap: 5px;
}

.done-text {
  font-size: 11px;
  font-weight: 700;
  color: #94a3b8;
}

.empty-row {
  padding: 28px !important;
  color: #94a3b8 !important;
}

.modal {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 2000;
  background: rgba(15, 23, 42, .5);
  align-items: center;
  justify-content: center;
}

.modal.open {
  display: flex;
}

.modal-box {
  width: 460px;
  max-width: 92vw;
  background: #fff;
  border: 1px solid #dde4ef;
}

.modal-header,
.modal-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 1px solid #e2e8f0;
}

.modal-footer {
  justify-content: flex-end;
  gap: 8px;
  border-top: 1px solid #e2e8f0;
  border-bottom: 0;
}

.modal-close {
  border: 0;
  background: none;
  color: #64748b;
  font-size: 22px;
  cursor: pointer;
}

.modal-body {
  padding: 16px;
}

.modal-label {
  display: block;
  margin-bottom: 6px;
  color: #334155;
  font-size: 12px;
  font-weight: 700;
}

.modal-textarea {
  width: 100%;
  min-height: 100px;
  padding: 10px;
  border: 1px solid #d1d9e6;
  resize: vertical;
  font-size: 12px;
}


/* 기본심사목록 전용: 신고접수목록과 동일한 위치/간격 보정 */
.basic-screen-main .page-inner {
  padding: 24px 28px;
}

.basic-table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
}

.basic-table th {
  padding: 10px 14px;
  background: #ecf4ff;
  border-bottom: 1px solid #d9eafc;
  color: #4d6172;
  font-size: 10px;
  font-weight: 800;
  text-align: center;
  white-space: nowrap;
}

.basic-table td {
  padding: 11px 14px;
  border-bottom: 1px solid #d9eafc;
  color: #203444;
  font-size: 12px;
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
}

.basic-table tbody tr:hover td {
  background: #f8fbff;
}

.basic-table strong {
  font-weight: 700;
  color: #0f2537;
}

.paging-box {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin: 16px 0 8px;
}

.paging-btn,
.paging-current {
  min-width: 40px;
  height: 32px;
  padding: 0 12px;
  border: 1px solid #cbd8e8;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
}

.paging-current {
  background: #4f5b74;
  color: #fff;
}

.paging-btn.disabled {
  color: #a8b4c3;
  background: #f8fafc;
}

.ans-wait {
  font-size: 11px;
  font-weight: 700;
  color: #b45309;
  background: #fffbeb;
  border: 1px solid #fde68a;
  padding: 2px 8px;
}

.ans-new {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  font-weight: 700;
  color: #203444;
}

.ans-new-tag {
  font-size: 10px;
  font-weight: 900;
  background: #ef4444;
  color: #fff;
  padding: 1px 5px;
}

.ans-done {
  font-size: 11px;
  font-weight: 700;
  color: #15803d;
}

 /* ── 본인 행 ── */
tr.row-mine {
  background-color: #fff;
  cursor: pointer;
   }
tr.row-mine:hover {
 background-color: #f0f6ff;
  }
 /* ── 타인 행: 회색, 클릭은 가능 (readonly 이동) ── */
 tr.row-others {
   background-color: #f5f5f5;
   cursor: pointer;
 }
tr.row-others:hover {
   background-color: #ebebeb;
 }
tr.row-others td {
   color: #aaa;
 }
tr.row-others td.td-detail-action a {
   color: #888;
   border-color: #bbb;
}
            /* 타인 뱃지 */
 .badge-others {
	display: inline-block;
	font-size: 11px;
	background: #9ca3af;
	color: #fff;
	border-radius: 4px;
	padding: 1px 6px;
	margin-left: 4px;
	vertical-align: middle;
}
            
            .risk-text.high{
    color:#dc2626;
    font-weight:700;
}

.risk-text.middle{
    color:#f59e0b;
    font-weight:700;
}

.risk-text.low{
    color:#2563eb;
    font-weight:700;
}

.req-link {
    color: inherit;
    text-decoration: none;
    display: block;
}

.req-link:hover {
    text-decoration: underline;
}
/* =========================================================
   검색조건 세로 정렬 최종 보정
   - JSP 내용은 건드리지 않고, label + 입력영역을 1줄씩 아래로 정렬
   - 한 .search-row 안에 항목이 여러 개 있어도 2열 그리드로 자동 줄바꿈
========================================================= */
.basic-screen-main .search-panel,
.search-panel {
  margin-bottom: 18px !important;
  background: #fff !important;
  border: 1px solid #dde4ef !important;
  border-radius: 0 !important;
  box-shadow: none !important;
}

.basic-screen-main .search-title,
.search-title {
  position: relative !important;
  margin: 0 !important;
  padding: 8px 16px 8px 20px !important;
  border-bottom: 1px solid #dde4ef !important;
  background: #fff !important;
  color: #111827 !important;
  font-size: 13px !important;
  font-weight: 900 !important;
  line-height: 20px !important;
}

.basic-screen-main .search-title::before,
.search-title::before {
  content: '' !important;
  position: absolute !important;
  left: 0 !important;
  top: 0 !important;
  width: 4px !important;
  height: 100% !important;
  background: #536178 !important;
}

.basic-screen-main .search-row,
.search-row {
  display: grid !important;
  grid-template-columns: 90px max-content !important;
  column-gap: 14px !important;
  row-gap: 12px !important;
  align-items: center !important;
  min-height: 0 !important;
  padding: 7px 16px 0 16px !important;
  background: #fff !important;
  border-bottom: 0 !important;
}

.basic-screen-main .search-row.last-row,
.search-row.last-row {
  padding-bottom: 6px !important;
}

.basic-screen-main .search-label,
.search-label {
  display: flex !important;
  align-items: center !important;
  width: 90px !important;
  min-width: 90px !important;
  height: 33px !important;
  margin: 0 !important;
  padding: 0 !important;
  color: #24364b !important;
  font-size: 12px !important;
  font-weight: 800 !important;
  line-height: 33px !important;
  white-space: nowrap !important;
}

.basic-screen-main .search-field,
.search-field {
  display: flex !important;
  align-items: center !important;
  justify-content: flex-start !important;
  gap: 14px !important;
  min-height: 33px !important;
  width: auto !important;
  flex: none !important;
}

.basic-screen-main .form-input,
.basic-screen-main .form-select,
.form-input,
.form-select {
  height: 33px !important;
  box-sizing: border-box !important;
  padding: 0 10px !important;
  border: 1px solid #d1d9e6 !important;
  border-radius: 0 !important;
  background: #fff !important;
  color: #0f172a !important;
  font-size: 12px !important;
  outline: none !important;
  box-shadow: none !important;
}

.basic-screen-main .input-md,
.input-md {
  width: 200px !important;
}

.basic-screen-main .input-sm,
.input-sm {
  width: 200px !important;
}

.basic-screen-main .select-sm,
.select-sm {
  width: 140px !important;
}

.basic-screen-main select.form-input,
.basic-screen-main select.form-select,
select.form-input,
select.form-select {
  width: 140px !important;
}

.basic-screen-main .date-input,
.date-input {
  width: 130px !important;
}

.basic-screen-main .date-sep,
.date-sep {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  width: 14px !important;
  color: #6b7b90 !important;
  font-size: 12px !important;
}

.basic-screen-main .radio-group,
.radio-group {
  display: flex !important;
  align-items: center !important;
  gap: 26px !important;
}

.basic-screen-main .radio-group label,
.radio-group label {
  display: inline-flex !important;
  align-items: center !important;
  gap: 6px !important;
  margin: 0 !important;
  color: #111827 !important;
  font-size: 12px !important;
  font-weight: 600 !important;
  white-space: nowrap !important;
}

.basic-screen-main .radio-group input[type='radio'],
.radio-group input[type='radio'] {
  width: 13px !important;
  height: 13px !important;
  margin: 0 !important;
}

.basic-screen-main .btn-primary,
.basic-screen-main .btn-secondary,
.basic-screen-main .btn-quick,
.btn-primary,
.btn-secondary,
.btn-quick {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  height: 33px !important;
  box-sizing: border-box !important;
  border-radius: 0 !important;
  font-size: 12px !important;
  font-weight: 800 !important;
  cursor: pointer !important;
  white-space: nowrap !important;
}

.basic-screen-main .btn-primary,
.btn-primary {
  min-width: 52px !important;
  padding: 0 14px !important;
  border: 1px solid #1e3054 !important;
  background: #1e3054 !important;
  color: #fff !important;
}

.basic-screen-main .btn-secondary,
.basic-screen-main .btn-quick,
.btn-secondary,
.btn-quick {
  min-width: 62px !important;
  padding: 0 14px !important;
  border: 1px solid #cbd8e8 !important;
  background: #fff !important;
  color: #334155 !important;
}

.basic-screen-main .btn-primary:hover,
.btn-primary:hover {
  background: #152540 !important;
}

.basic-screen-main .btn-secondary:hover,
.basic-screen-main .btn-quick:hover,
.btn-secondary:hover,
.btn-quick:hover {
  background: #f8fafc !important;
}


/* 반려 처리된 기본심사 행 */
.basic-table tbody tr.row-rejected td {
  background: #f1f3f6 !important;
  color: #7a8494 !important;
}

.basic-table tbody tr.row-rejected:hover td {
  background: #e9edf3 !important;
}

.basic-table tbody tr.row-rejected strong,
.basic-table tbody tr.row-rejected .req-link {
  color: #64748b !important;
}

.basic-table tbody tr.row-rejected .status-rejected {
  color: #991b1b !important;
  font-weight: 900 !important;
}

.basic-table tbody tr.row-rejected .btn-secondary {
  background: #fff !important;
  border-color: #cbd8e8 !important;
  color: #1e3054 !important;
}
