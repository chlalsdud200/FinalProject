<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.tacs.transport.importp.mapper.ImportTransportMapper">
      <!-- 수입운송 반출요청 탭에서 반출 신청, 보완, 승인 상태를 관리한다. -->
      <update id="updateImpReleaseSupplementRequested">
            UPDATE CARGO_RELEASE_REQ CRR
            SET CRR.CRR_STATUS_CD = 'REL_FIX'
            WHERE TO_CHAR(CRR.CRR_NO) = #{releaseReqNo}
      </update>
      <update id="updateImpReleaseReqData">
            UPDATE CARGO_RELEASE_REQ CRR
            SET
            CRR.CRR_WZ_NO = COALESCE(#{wzNo,jdbcType=VARCHAR}, CRR.CRR_WZ_NO)
            , CRR.CRR_WM_ID = COALESCE(#{wmId,jdbcType=VARCHAR}, CRR.CRR_WM_ID)
            , CRR.CRR_WHM_NO = COALESCE(#{wmId,jdbcType=VARCHAR}, CRR.CRR_WHM_NO)
            , CRR.CRR_PROC_MEM_ID = COALESCE(#{wmId,jdbcType=VARCHAR}, CRR.CRR_PROC_MEM_ID)
            , CRR.CRR_WH_NO = COALESCE(
            (
            SELECT WZ.WZ_WH_NO
            FROM WAREHOUSE_ZONE WZ
            WHERE WZ.WZ_NO = #{wzNo,jdbcType=VARCHAR}
            FETCH FIRST 1 ROW ONLY
            ),
            CRR.CRR_WH_NO
            )
            , CRR.CRR_FRGHT_IEM_NM = COALESCE(#{itemNm,jdbcType=VARCHAR}, CRR.CRR_FRGHT_IEM_NM)
            , CRR.CRR_REQ_CN = COALESCE(#{remark,jdbcType=VARCHAR}, CRR.CRR_REQ_CN)
            , CRR.CRR_RELEASE_DT = CASE
            WHEN #{releaseDt,jdbcType=VARCHAR} IS NOT NULL THEN TO_DATE(#{releaseDt,jdbcType=VARCHAR}, 'YYYY-MM-DD')
            ELSE CRR.CRR_RELEASE_DT
            END
            , CRR.CRR_STATUS_CD = CASE
            WHEN CRR.CRR_STATUS_CD IN ('REL_REJECT', 'REJECT') THEN 'REL_FIX'
            ELSE CRR.CRR_STATUS_CD
            END
            WHERE (
            #{releaseReqNo,jdbcType=VARCHAR} IS NOT NULL
            AND TO_CHAR(CRR.CRR_NO) = #{releaseReqNo,jdbcType=VARCHAR}
            )
            OR (
            #{trcNo,jdbcType=VARCHAR} IS NOT NULL
            AND CRR.CRR_TRE_ID = #{trcNo,jdbcType=VARCHAR}
            )
      </update>
      <update id="updateImpReleaseSupplementSubmitted">
            BEGIN
            UPDATE SUPP_RQST SR
            SET
            SR.SR_STATUS_CD = 'SUB'
            , SR.SR_SUBMIT_DT = SYSDATE
            WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
            AND SR.RECEIVER_TY_CD IN ('TRC', 'WHM', 'TRANSPORT', 'TRANSPORT_MANAGER', 'WAREHOUSE_MANAGER')
            AND SR.SR_STATUS_CD = 'REQ'
            AND SR.SR_REF_NO IN (
            #{releaseReqNo,jdbcType=VARCHAR}
            , (
            SELECT MAX(TO_CHAR(CRR.CRR_NO))
            FROM CARGO_RELEASE_REQ CRR
            WHERE CRR.CRR_TRE_ID = #{trcNo,jdbcType=VARCHAR}
            )
            );

            UPDATE CARGO_RELEASE_REQ CRR
            SET CRR.CRR_STATUS_CD = 'REL_SENT'
            WHERE (
            #{releaseReqNo,jdbcType=VARCHAR} IS NOT NULL
            AND TO_CHAR(CRR.CRR_NO) = #{releaseReqNo,jdbcType=VARCHAR}
            )
            OR (
            #{trcNo,jdbcType=VARCHAR} IS NOT NULL
            AND CRR.CRR_TRE_ID = #{trcNo,jdbcType=VARCHAR}
            );
            END;
      </update>
      <select id="retriveImpReleaseReqList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">

            SELECT
            T.TRC_NO                                      AS trcNo
            , T.TRC_OWR_ID                                  AS ownerId
            , NVL(O.OWR_NM, T.TRC_OWR_ID)                   AS ownerNm
            , NVL(O.OWR_NM, T.TRC_OWR_ID)                   AS owrNm
            , W.WIR_NO                                      AS wirNo
            , W.WIR_GG_NO                                   AS ggNo
            , NVL(W.WIR_WZ_NO, CRR.CRR_WZ_NO)                 AS bondedZoneNo
            , NVL(W.WIR_WZ_NO, CRR.CRR_WZ_NO)                 AS warehouseZoneNo
            , NVL(W.WIR_WZ_NO, CRR.CRR_WZ_NO)                 AS wzNo
            , NVL(W.WIR_WM_ID, CRR.CRR_WM_ID)                 AS bondedManagerId
            , NVL(W.WIR_WM_ID, CRR.CRR_WM_ID)                 AS wmId
            , NVL(WM.WM_NM, CRR.CRR_WM_ID)                    AS bondedManagerNm
            , NVL(WM.WM_NM, CRR.CRR_WM_ID)                    AS warehouseManagerNm
            , NVL(WM.WM_NM, CRR.CRR_WM_ID)                    AS wmNm
            , NVL(WH.WH_NM, CRR.CRR_WH_NO)                    AS whNm
            , NVL(WH.WH_NM, CRR.CRR_WH_NO)                    AS warehouseNm
            , NVL(WZ.WZ_NM, NVL(CRR.CRR_WZ_NO, TO_CHAR(W.WIR_WZ_NO))) AS warehouseZoneNm
            , W.WIR_CARGO_MGMT_NO                           AS cargoMgmtNo
            , CASE
              WHEN CRR.CRR_NO IS NOT NULL THEN 'REL-IMP-' || TO_CHAR(NVL(CRR.CRR_CR_DT, SYSDATE), 'YYYYMMDD') || '-' ||
                   CASE
                   WHEN LENGTH(TO_CHAR(CRR.CRR_NO)) &lt; 4 THEN LPAD(TO_CHAR(CRR.CRR_NO), 4, '0')
                   ELSE TO_CHAR(CRR.CRR_NO)
                   END
              END                                           AS releaseReqDisplayNo
            , CASE
              WHEN CRR.CRR_NO IS NOT NULL THEN 'REL-IMP-' || TO_CHAR(NVL(CRR.CRR_CR_DT, SYSDATE), 'YYYYMMDD') || '-' ||
                   CASE
                   WHEN LENGTH(TO_CHAR(CRR.CRR_NO)) &lt; 4 THEN LPAD(TO_CHAR(CRR.CRR_NO), 4, '0')
                   ELSE TO_CHAR(CRR.CRR_NO)
                   END
              END                                           AS releaseReqDispNo
            , CRR.CRR_NO                                    AS releaseReqNo
            , CRR.CRR_NO                                    AS crrNo
            , CRR.CRR_TRE_ID                                AS crrTreId
            , CRR.CRR_OWR_ID                                AS crrOwrId
            , CRR.CRR_WZ_NO                                 AS crrWzNo
            , CRR.CRR_WM_ID                                 AS crrWmId
            , CRR.CRR_STATUS_CD                             AS crrStatusCd
            , CRR.CRR_FRGHT_IEM_NM                          AS crrFrghtIemNm
            , CRR.CRR_WH_NO                                 AS crrWhNo
            , CRR.CRR_NO                                    AS reqNo
            , NULL                                          AS releaseNo
            , <include refid="impReleaseStatusCdCase"/>   AS releaseStatusCd
            , <include refid="impReleaseStatusCdCase"/>   AS statusCd
            , <include refid="impReleaseStatusNmCase"/>   AS releaseStatusNm
            , <include refid="impReleaseStatusNmCase"/>   AS statusNm
            , TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD HH24:MI') AS releaseReqDt
            , TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD HH24:MI') AS crrReqDt
            , TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD HH24:MI') AS crrCrDt
            , TO_CHAR(NVL(CRR.CRR_RELEASE_DT, CRR.CRR_CR_DT), 'YYYY-MM-DD HH24:MI') AS releaseDt
            , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS itemNm
            , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS itemCategory
            , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS frghtIemNm
            , MIN(G.GOODS_NAME)                              AS goodsName
            , MIN(G.GOODS_HS_CODE)                           AS goodsHsCode
            , MIN(G.GOODS_HS_CODE)                           AS hsCode
            , MIN(G.GOODS_HS_CODE)                           AS itemHsCode
            , MIN(C.GOODS_NO)                                AS goodsNo
            , NVL(SUM(C.CG_QTY), 0)                          AS qty
            , NVL(SUM(C.CG_QTY), 0)                          AS totalQty
            , NVL(SUM(C.CG_QTY), 0)                          AS cgQty
            , NVL(MAX(C.CG_PRICE), 0)                        AS price
            , NVL(MAX(C.CG_PRICE), 0)                        AS cgPrice
            , NVL(SUM(C.CG_TOTAL_PRICE), 0)                  AS goodsTotalPrice
            , NVL(SUM(C.CG_TOTAL_PRICE), 0)                  AS cgTotalPrice
            , NVL(SUM(C.CG_WEIGHT), 0)                       AS weight
            , NVL(SUM(C.CG_WEIGHT), 0)                       AS totalWeight
            , NVL(SUM(C.CG_WEIGHT), 0)                       AS cgWeight
            , MIN(C.CG_ORIGIN)                               AS origin
            , MIN(C.CG_ORIGIN)                               AS cgOrigin
            , CRR.CRR_REQ_CN                                AS releaseRemark
            , (
            SELECT MAX(CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)))
            FROM SUPP_RQST SR
            WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
            AND SR.SR_REF_NO = CRR.CRR_NO
            )                                                AS rejectReason
            , (
            SELECT MAX(CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)))
            FROM SUPP_RQST SR
            WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
            AND SR.SR_REF_NO = CRR.CRR_NO
            )                                                AS suppReqCn
            , (
            SELECT MAX(SR.SR_STATUS_CD) KEEP (DENSE_RANK LAST ORDER BY SR.SR_REQ_DT, SR.SR_NO)
            FROM SUPP_RQST SR
            WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
            AND SR.SR_REF_NO = TO_CHAR(CRR.CRR_NO)
            )                                                AS supplementStatusCd
            , CRR.CRR_REQ_CN                                AS crrRmrk
            , CRR.CRR_REQ_CN                                AS remark
            , NVL(DI.DI_DO_NO, CRR.CRR_CERT_NO)              AS doNo
            , NVL(DI.DI_DO_NO, CRR.CRR_CERT_NO)              AS diDoNo
            , NVL(DI.DI_STATUS_CD, CASE WHEN CRR.CRR_CERT_NO IS NOT NULL THEN 'TRC_DO_REQ' END) AS doStatusCd
            , NVL(DI.DI_STATUS_CD, CASE WHEN CRR.CRR_CERT_NO IS NOT NULL THEN 'TRC_DO_REQ' END) AS diStatusCd
            , CASE NVL(DI.DI_STATUS_CD, CASE WHEN CRR.CRR_CERT_NO IS NOT NULL THEN 'TRC_DO_REQ' ELSE 'TRC_DO_READY' END)
            WHEN 'TRC_DO_READY'  THEN 'TRC_DO_READY'
            WHEN 'TRC_DO_ISSUED' THEN 'TRC_DO_ISSUED'
            WHEN 'TRC_DO_REQ'    THEN 'TRC_DO_REQ'
            ELSE DI.DI_STATUS_CD
            END                                           AS doStatusNm
            , TO_CHAR(DI.DI_DLVRY_DT, 'YYYY-MM-DD')         AS doDlvrDt
            , NVL(WM.WM_NM, DI.DI_DLVRY_OWR_NM)             AS doDlvrOwnerNm
            , COALESCE(TCS.TCS_MBL_NO, BI.BI_MBL_NO, (SELECT MAX(IR.IR_BL_AWB_NO)
            FROM IMP_RQST IR
            WHERE (IR.IR_NO = T.TRC_NO OR IR.IR_NO = REPLACE(T.TRC_NO, 'TRC-', '') OR IR.IR_OWR_ID = T.TRC_OWR_ID)
            AND IR.IR_BL_AWB_NO IS NOT NULL)) AS mblNo
            , COALESCE(TCS.TCS_HBL_NO, BI.BI_HBL_NO) AS hblNo
            , COUNT(C.CG_NO)                                AS goodsCnt
            , NVL(SUM(C.CG_TOTAL_PRICE), 0)                 AS summaryTotalPrice
            , TO_CHAR(T.TRC_RQST_DT, 'YYYY-MM-DD')          AS requestDt
            FROM TRAN_RCP T
            LEFT JOIN TRAN_COST_STL TCS
            ON TCS.TCS_TRC_NO = T.TRC_NO
            LEFT JOIN DO_ISSUANCE DI
            ON DI.DI_TRC_NO = T.TRC_NO
            AND NVL(DI.DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')
            LEFT JOIN BL_ISSU BI
            ON BI.BI_TRE_ID = T.TRC_NO
            LEFT JOIN OWNER O
            ON O.OWR_ID = T.TRC_OWR_ID
            LEFT JOIN WH_IN_RPT W
            ON W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            LEFT JOIN CARGO_RELEASE_REQ CRR
            ON CRR.CRR_TRE_ID = T.TRC_NO
            LEFT JOIN WAREHOUSE_MANAGER WM
            ON WM.WM_ID = NVL(W.WIR_WM_ID, CRR.CRR_WM_ID)
            LEFT JOIN WAREHOUSE_ZONE WZ
            ON WZ.WZ_NO = NVL(W.WIR_WZ_NO, CRR.CRR_WZ_NO)
            LEFT JOIN WAREHOUSE WH
            ON WH.WH_NO = NVL(WZ.WZ_WH_NO, CRR.CRR_WH_NO)
            LEFT JOIN (
            SELECT *
            FROM (
            SELECT C0.*,
            ROW_NUMBER() OVER (
            PARTITION BY C0.GG_NO, C0.GOODS_NO, NVL(C0.CG_QTY, -1), NVL(C0.CG_PRICE, -1), NVL(C0.CG_TOTAL_PRICE, -1), NVL(C0.CG_WEIGHT, -1), NVL(C0.CG_ORIGIN, ' ')
            ORDER BY C0.CG_NO
            ) AS RN
            FROM CUSTOMS_GOODS C0
            )
            WHERE RN = 1
            ) C
            ON C.GG_NO = NVL(W.WIR_GG_NO, T.TRC_TFG_NO)
            LEFT JOIN GOODS G
            ON G.GOODS_NO = C.GOODS_NO
            WHERE T.TRC_SE_CD IN ('IMP', 'IMPORT')
            <if test="tmId != null and tmId != ''">
                  AND T.TRC_TM_NO = (
                  SELECT TM.TM_NO
                  FROM TRANSPORT_MANAGER TM
                  WHERE TM.TM_ID = #{tmId}
                  )
            </if>
            AND T.TRC_STATUS_CD IN ('TRC_DONE', 'TRC_END', 'TRC_COMPLETE')

            AND (
            CRR.CRR_NO IS NOT NULL
            OR (
            TCS.TCS_STL_STATUS_CD IN ('TRC_STL_PAID', 'TCS_STL_PAID', 'PAID')
            AND NVL(DI.DI_STATUS_CD, 'TRC_DO_REQ') IN ('TRC_DO_REQ', 'DELIVERED', 'DO_DELIVERED', 'TRC_DO_SUBMIT_DONE')
            AND W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            )
            )
            GROUP BY
            T.TRC_NO
            , T.TRC_OWR_ID
            , O.OWR_NM
            , W.WIR_NO
            , W.WIR_GG_NO
            , W.WIR_WZ_NO
            , W.WIR_WM_ID
            , WM.WM_NM
            , WH.WH_NM
            , WZ.WZ_NM
            , W.WIR_CARGO_MGMT_NO
            , CRR.CRR_NO
            , CRR.CRR_TRE_ID
            , CRR.CRR_OWR_ID
            , CRR.CRR_WZ_NO
            , CRR.CRR_WM_ID
            , CRR.CRR_WH_NO
            , CRR.CRR_CERT_NO
            , CRR.CRR_STATUS_CD
            , CRR.CRR_RELEASE_DT
            , CRR.CRR_CR_DT
            , CRR.CRR_FRGHT_IEM_NM
            , T.TRC_ITEM_CTGRY_NM
            , CRR.CRR_REQ_CN
            , DI.DI_DO_NO
            , DI.DI_STATUS_CD
            , DI.DI_DLVRY_DT
            , DI.DI_DLVRY_OWR_NM
            , TCS.TCS_MBL_NO
            , TCS.TCS_HBL_NO
            , BI.BI_MBL_NO
            , BI.BI_HBL_NO
            , T.TRC_RQST_DT
            ORDER BY T.TRC_RQST_DT DESC NULLS LAST, T.TRC_NO DESC
      </select>
      <select id="selectImpReleaseReqDetail" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
            SELECT
            T.TRC_NO                                      AS trcNo
            , T.TRC_OWR_ID                                  AS ownerId
            , NVL(O.OWR_NM, T.TRC_OWR_ID)                   AS ownerNm
            , NVL(O.OWR_NM, T.TRC_OWR_ID)                   AS owrNm
            , W.WIR_NO                                      AS wirNo
            , W.WIR_GG_NO                                   AS ggNo
            , NVL(W.WIR_WZ_NO, CRR.CRR_WZ_NO)                 AS bondedZoneNo
            , NVL(W.WIR_WZ_NO, CRR.CRR_WZ_NO)                 AS warehouseZoneNo
            , NVL(W.WIR_WZ_NO, CRR.CRR_WZ_NO)                 AS wzNo
            , NVL(W.WIR_WM_ID, CRR.CRR_WM_ID)                 AS bondedManagerId
            , NVL(W.WIR_WM_ID, CRR.CRR_WM_ID)                 AS wmId
            , NVL(WM.WM_NM, CRR.CRR_WM_ID)                    AS bondedManagerNm
            , NVL(WM.WM_NM, CRR.CRR_WM_ID)                    AS warehouseManagerNm
            , NVL(WM.WM_NM, CRR.CRR_WM_ID)                    AS wmNm
            , NVL(WH.WH_NM, CRR.CRR_WH_NO)                    AS whNm
            , NVL(WH.WH_NM, CRR.CRR_WH_NO)                    AS warehouseNm
            , NVL(WZ.WZ_NM, NVL(CRR.CRR_WZ_NO, TO_CHAR(W.WIR_WZ_NO))) AS warehouseZoneNm
            , W.WIR_CARGO_MGMT_NO                           AS cargoMgmtNo
            , CASE
              WHEN CRR.CRR_NO IS NOT NULL THEN 'REL-IMP-' || TO_CHAR(NVL(CRR.CRR_CR_DT, SYSDATE), 'YYYYMMDD') || '-' ||
                   CASE
                   WHEN LENGTH(TO_CHAR(CRR.CRR_NO)) &lt; 4 THEN LPAD(TO_CHAR(CRR.CRR_NO), 4, '0')
                   ELSE TO_CHAR(CRR.CRR_NO)
                   END
              END                                           AS releaseReqDisplayNo
            , CASE
              WHEN CRR.CRR_NO IS NOT NULL THEN 'REL-IMP-' || TO_CHAR(NVL(CRR.CRR_CR_DT, SYSDATE), 'YYYYMMDD') || '-' ||
                   CASE
                   WHEN LENGTH(TO_CHAR(CRR.CRR_NO)) &lt; 4 THEN LPAD(TO_CHAR(CRR.CRR_NO), 4, '0')
                   ELSE TO_CHAR(CRR.CRR_NO)
                   END
              END                                           AS releaseReqDispNo
            , CRR.CRR_NO                                    AS releaseReqNo
            , CRR.CRR_NO                                    AS crrNo
            , CRR.CRR_TRE_ID                                AS crrTreId
            , CRR.CRR_OWR_ID                                AS crrOwrId
            , CRR.CRR_WZ_NO                                 AS crrWzNo
            , CRR.CRR_WM_ID                                 AS crrWmId
            , CRR.CRR_STATUS_CD                             AS crrStatusCd
            , CRR.CRR_FRGHT_IEM_NM                          AS crrFrghtIemNm
            , CRR.CRR_WH_NO                                 AS crrWhNo
            , CRR.CRR_NO                                    AS reqNo
            , NULL                                          AS releaseNo
            , <include refid="impReleaseStatusCdCase"/>   AS releaseStatusCd
            , <include refid="impReleaseStatusCdCase"/>   AS statusCd
            , <include refid="impReleaseStatusNmCase"/>   AS releaseStatusNm
            , <include refid="impReleaseStatusNmCase"/>   AS statusNm
            , TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD HH24:MI') AS releaseReqDt
            , TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD HH24:MI') AS crrReqDt
            , TO_CHAR(CRR.CRR_CR_DT, 'YYYY-MM-DD HH24:MI') AS crrCrDt
            , TO_CHAR(NVL(CRR.CRR_RELEASE_DT, CRR.CRR_CR_DT), 'YYYY-MM-DD HH24:MI') AS releaseDt
            , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS itemNm
            , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS itemCategory
            , NVL(CRR.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS frghtIemNm
            , MIN(G.GOODS_NAME)                              AS goodsName
            , MIN(G.GOODS_HS_CODE)                           AS goodsHsCode
            , MIN(G.GOODS_HS_CODE)                           AS hsCode
            , MIN(G.GOODS_HS_CODE)                           AS itemHsCode
            , MIN(C.GOODS_NO)                                AS goodsNo
            , NVL(SUM(C.CG_QTY), 0)                          AS qty
            , NVL(SUM(C.CG_QTY), 0)                          AS totalQty
            , NVL(SUM(C.CG_QTY), 0)                          AS cgQty
            , NVL(MAX(C.CG_PRICE), 0)                        AS price
            , NVL(MAX(C.CG_PRICE), 0)                        AS cgPrice
            , NVL(SUM(C.CG_TOTAL_PRICE), 0)                  AS goodsTotalPrice
            , NVL(SUM(C.CG_TOTAL_PRICE), 0)                  AS cgTotalPrice
            , NVL(SUM(C.CG_WEIGHT), 0)                       AS weight
            , NVL(SUM(C.CG_WEIGHT), 0)                       AS totalWeight
            , NVL(SUM(C.CG_WEIGHT), 0)                       AS cgWeight
            , MIN(C.CG_ORIGIN)                               AS origin
            , MIN(C.CG_ORIGIN)                               AS cgOrigin
            , CRR.CRR_REQ_CN                                AS releaseRemark
            , (
            SELECT MAX(CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)))
            FROM SUPP_RQST SR
            WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
            AND SR.SR_REF_NO = CRR.CRR_NO
            )                                                AS rejectReason
            , (
            SELECT MAX(CAST(SUBSTR(SR.SR_REQ_CN, 1, 1000) AS VARCHAR2(1000)))
            FROM SUPP_RQST SR
            WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
            AND SR.SR_REF_NO = CRR.CRR_NO
            )                                                AS suppReqCn
            , (
            SELECT MAX(SR.SR_STATUS_CD) KEEP (DENSE_RANK LAST ORDER BY SR.SR_REQ_DT, SR.SR_NO)
            FROM SUPP_RQST SR
            WHERE SR.SR_REF_BIZ_CD = 'CARGO_RELEASE_REQ'
            AND SR.SR_REF_NO = TO_CHAR(CRR.CRR_NO)
            )                                                AS supplementStatusCd
            , CRR.CRR_REQ_CN                                AS crrRmrk
            , CRR.CRR_REQ_CN                                AS remark
            , NVL(DI.DI_DO_NO, CRR.CRR_CERT_NO)              AS doNo
            , NVL(DI.DI_DO_NO, CRR.CRR_CERT_NO)              AS diDoNo
            , NVL(DI.DI_STATUS_CD, CASE WHEN CRR.CRR_CERT_NO IS NOT NULL THEN 'TRC_DO_REQ' END) AS doStatusCd
            , NVL(DI.DI_STATUS_CD, CASE WHEN CRR.CRR_CERT_NO IS NOT NULL THEN 'TRC_DO_REQ' END) AS diStatusCd
            , CASE NVL(DI.DI_STATUS_CD, CASE WHEN CRR.CRR_CERT_NO IS NOT NULL THEN 'TRC_DO_REQ' ELSE 'TRC_DO_READY' END)
            WHEN 'TRC_DO_READY'  THEN 'TRC_DO_READY'
            WHEN 'TRC_DO_ISSUED' THEN 'TRC_DO_ISSUED'
            WHEN 'TRC_DO_REQ'    THEN 'TRC_DO_REQ'
            ELSE DI.DI_STATUS_CD
            END                                           AS doStatusNm
            , TO_CHAR(DI.DI_DLVRY_DT, 'YYYY-MM-DD')         AS doDlvrDt
            , NVL(WM.WM_NM, DI.DI_DLVRY_OWR_NM)             AS doDlvrOwnerNm
            , COALESCE(TCS.TCS_MBL_NO, BI.BI_MBL_NO, (SELECT MAX(IR.IR_BL_AWB_NO)
            FROM IMP_RQST IR
            WHERE (IR.IR_NO = T.TRC_NO OR IR.IR_NO = REPLACE(T.TRC_NO, 'TRC-', '') OR IR.IR_OWR_ID = T.TRC_OWR_ID)
            AND IR.IR_BL_AWB_NO IS NOT NULL)) AS mblNo
            , COALESCE(TCS.TCS_HBL_NO, BI.BI_HBL_NO) AS hblNo
            , TO_CHAR(T.TRC_RQST_DT, 'YYYY-MM-DD')          AS requestDt
            FROM TRAN_RCP T
            LEFT JOIN TRAN_COST_STL TCS
            ON TCS.TCS_TRC_NO = T.TRC_NO
            LEFT JOIN DO_ISSUANCE DI
            ON DI.DI_TRC_NO = T.TRC_NO
            AND NVL(DI.DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')
            LEFT JOIN BL_ISSU BI
            ON BI.BI_TRE_ID = T.TRC_NO
            LEFT JOIN OWNER O
            ON O.OWR_ID = T.TRC_OWR_ID
            LEFT JOIN WH_IN_RPT W
            ON W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            LEFT JOIN CARGO_RELEASE_REQ CRR
            ON CRR.CRR_TRE_ID = T.TRC_NO
            LEFT JOIN WAREHOUSE_MANAGER WM
            ON WM.WM_ID = NVL(W.WIR_WM_ID, CRR.CRR_WM_ID)
            LEFT JOIN WAREHOUSE_ZONE WZ
            ON WZ.WZ_NO = NVL(W.WIR_WZ_NO, CRR.CRR_WZ_NO)
            LEFT JOIN WAREHOUSE WH
            ON WH.WH_NO = NVL(WZ.WZ_WH_NO, CRR.CRR_WH_NO)
            LEFT JOIN (
            SELECT *
            FROM (
            SELECT C0.*,
            ROW_NUMBER() OVER (
            PARTITION BY C0.GG_NO, C0.GOODS_NO, NVL(C0.CG_QTY, -1), NVL(C0.CG_PRICE, -1), NVL(C0.CG_TOTAL_PRICE, -1), NVL(C0.CG_WEIGHT, -1), NVL(C0.CG_ORIGIN, ' ')
            ORDER BY C0.CG_NO
            ) AS RN
            FROM CUSTOMS_GOODS C0
            )
            WHERE RN = 1
            ) C
            ON C.GG_NO = NVL(W.WIR_GG_NO, T.TRC_TFG_NO)
            LEFT JOIN GOODS G
            ON G.GOODS_NO = C.GOODS_NO
            WHERE T.TRC_NO = #{trcNo}
            AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
            GROUP BY
            T.TRC_NO
            , T.TRC_OWR_ID
            , O.OWR_NM
            , W.WIR_NO
            , W.WIR_GG_NO
            , W.WIR_WZ_NO
            , W.WIR_WM_ID
            , WM.WM_NM
            , WH.WH_NM
            , WZ.WZ_NM
            , W.WIR_CARGO_MGMT_NO
            , CRR.CRR_NO
            , CRR.CRR_TRE_ID
            , CRR.CRR_OWR_ID
            , CRR.CRR_WZ_NO
            , CRR.CRR_WM_ID
            , CRR.CRR_WH_NO
            , CRR.CRR_CERT_NO
            , CRR.CRR_RELEASE_DT
            , CRR.CRR_STATUS_CD
            , CRR.CRR_CR_DT
            , CRR.CRR_FRGHT_IEM_NM
            , T.TRC_ITEM_CTGRY_NM
            , CRR.CRR_REQ_CN
            , DI.DI_DO_NO
            , DI.DI_STATUS_CD
            , DI.DI_DLVRY_DT
            , DI.DI_DLVRY_OWR_NM
            , TCS.TCS_MBL_NO
            , TCS.TCS_HBL_NO
            , BI.BI_MBL_NO
            , BI.BI_HBL_NO
            , T.TRC_RQST_DT
      </select>
      <select id="retriveImpReleaseReqGoodsList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
            SELECT
            C.CG_NO           AS cgNo
            , C.GOODS_NO        AS goodsNo
            , G.GOODS_NAME      AS goodsName
            , G.GOODS_NAME      AS itemNm
            , G.GOODS_HS_CODE   AS goodsHsCode
            , G.GOODS_HS_CODE   AS hsCode
            , G.GOODS_HS_CODE   AS itemHsCode
            , C.GG_NO           AS ggNo
            , C.CG_QTY          AS qty
            , C.CG_PRICE        AS price
            , C.CG_TOTAL_PRICE  AS goodsTotalPrice
            , C.CG_WEIGHT       AS weight
            , C.CG_ORIGIN       AS origin
            FROM (
            SELECT *
            FROM (
            SELECT C0.*,
            ROW_NUMBER() OVER (
            PARTITION BY C0.GG_NO, C0.GOODS_NO, NVL(C0.CG_QTY, -1), NVL(C0.CG_PRICE, -1), NVL(C0.CG_TOTAL_PRICE, -1), NVL(C0.CG_WEIGHT, -1), NVL(C0.CG_ORIGIN, ' ')
            ORDER BY C0.CG_NO
            ) AS RN
            FROM CUSTOMS_GOODS C0
            WHERE C0.GG_NO = #{ggNo}
            )
            WHERE RN = 1
            ) C
            LEFT JOIN GOODS G
            ON C.GOODS_NO = G.GOODS_NO
            ORDER BY C.CG_NO
      </select>
      <insert id="insertImpReleaseReq">
            DECLARE
            V_REQ_NO        CARGO_RELEASE_REQ.CRR_NO%TYPE;
            V_TRC_NO        TRAN_RCP.TRC_NO%TYPE;
            V_OWR_ID        TRAN_RCP.TRC_OWR_ID%TYPE;
            V_WZ_NO         WH_IN_RPT.WIR_WZ_NO%TYPE;
            V_WM_ID         WH_IN_RPT.WIR_WM_ID%TYPE;
            V_WH_NO         WAREHOUSE_ZONE.WZ_WH_NO%TYPE;
            V_OWNER_NM      OWNER.OWR_NM%TYPE;
            V_DO_NO         DO_ISSUANCE.DI_DO_NO%TYPE;
            V_ITEM_NM       TRAN_RCP.TRC_ITEM_CTGRY_NM%TYPE;
            V_EXISTS        NUMBER;
            BEGIN
            SELECT COUNT(*)
            INTO V_EXISTS
            FROM CARGO_RELEASE_REQ
            WHERE CRR_TRE_ID = #{trcNo};

            IF V_EXISTS = 0 THEN

            SELECT
            X.TRC_NO,
            X.TRC_OWR_ID,
            X.WIR_WZ_NO,
            X.WIR_WM_ID,
            X.WZ_WH_NO,
            X.OWNER_NM,
            X.DI_DO_NO,
            X.ITEM_NM
            INTO
            V_TRC_NO,
            V_OWR_ID,
            V_WZ_NO,
            V_WM_ID,
            V_WH_NO,
            V_OWNER_NM,
            V_DO_NO,
            V_ITEM_NM
            FROM (
            SELECT
            T.TRC_NO,
            T.TRC_OWR_ID,
            COALESCE(#{wzNo,jdbcType=VARCHAR}, W.WIR_WZ_NO) AS WIR_WZ_NO,
            COALESCE(#{wmId,jdbcType=VARCHAR}, W.WIR_WM_ID) AS WIR_WM_ID,
            Z.WZ_WH_NO,
            NVL(O.OWR_NM, T.TRC_OWR_ID) AS OWNER_NM,
            DI.DI_DO_NO,
            COALESCE(#{itemNm,jdbcType=VARCHAR}, T.TRC_ITEM_CTGRY_NM) AS ITEM_NM
            FROM TRAN_RCP T
            JOIN TRAN_COST_STL TCS
            ON TCS.TCS_TRC_NO = T.TRC_NO
            AND TCS.TCS_STL_STATUS_CD IN ('TRC_STL_PAID', 'TCS_STL_PAID', 'PAID')
            JOIN DO_ISSUANCE DI
            ON DI.DI_TRC_NO = T.TRC_NO
            AND NVL(DI.DI_TRDE_SE_CD, 'IMP') IN ('IMP', 'IMPORT')
            AND DI.DI_STATUS_CD IN ('TRC_DO_REQ', 'DELIVERED', 'DO_DELIVERED', 'TRC_DO_SUBMIT_DONE')
            LEFT JOIN OWNER O
            ON O.OWR_ID = T.TRC_OWR_ID
            LEFT JOIN WH_IN_RPT W
            ON W.WIR_GG_NO = T.TRC_TFG_NO
            AND W.WIR_IO_SE_CD IN ('IMP', 'IMPORT')
            LEFT JOIN WAREHOUSE_ZONE Z
            ON Z.WZ_NO = COALESCE(#{wzNo,jdbcType=VARCHAR}, W.WIR_WZ_NO)
            WHERE T.TRC_NO = #{trcNo}
            AND T.TRC_SE_CD IN ('IMP', 'IMPORT')
            AND W.WIR_STATUS_CD = 'IN_DONE'
            AND W.WIR_WH_REPLY_STATUS_CD = 'IN_DONE'
            AND COALESCE(#{wzNo,jdbcType=VARCHAR}, W.WIR_WZ_NO) IS NOT NULL
            AND COALESCE(#{wmId,jdbcType=VARCHAR}, W.WIR_WM_ID) IS NOT NULL
            AND Z.WZ_WH_NO IS NOT NULL
            ORDER BY W.WIR_NO DESC
            ) X
            WHERE ROWNUM = 1;

            SELECT SEQ_CARGO_RELEASE_REQ.NEXTVAL
            INTO V_REQ_NO
            FROM DUAL;

            INSERT INTO CARGO_RELEASE_REQ (
            CRR_NO,
            CRR_TRE_ID,
            CRR_OWR_ID,
            CRR_WZ_NO,
            CRR_WM_ID,
            CRR_NM,
            CRR_CERT_NO,
            CRR_FRGHT_IEM_NM,
            CRR_WHM_NO,
            CRR_REQ_CN,
            CRR_CR_DT,
            CRR_RELEASE_DT,
            CRR_STATUS_CD,
            CRR_WH_NO,
            CRR_PROC_MEM_ID,
            DI_TRDE_SE_CD
            )
            VALUES (
            V_REQ_NO,
            V_TRC_NO,
            V_OWR_ID,
            V_WZ_NO,
            V_WM_ID,
            V_OWNER_NM,
            V_DO_NO,
            NVL(V_ITEM_NM, '품목미상'),
            V_WM_ID,
            #{remark,jdbcType=VARCHAR},
            SYSDATE,
            CASE
            WHEN #{releaseDt,jdbcType=VARCHAR} IS NOT NULL THEN TO_DATE(#{releaseDt,jdbcType=VARCHAR}, 'YYYY-MM-DD')
            ELSE NULL
            END,
            'REL_WAIT',
            V_WH_NO,
            V_WM_ID,
            'IMP'
            );

            END IF;

            EXCEPTION
            WHEN NO_DATA_FOUND THEN
            NULL;
            END;
      </insert>



      <select id="countImpReleaseReqByTrcNo" resultType="int">
            SELECT COUNT(*)
            FROM CARGO_RELEASE_REQ
            WHERE CRR_TRE_ID = #{trcNo}
      </select>
      <select id="countImpReleaseApprovedByTrcNo" resultType="int">
            SELECT COUNT(*)
            FROM CARGO_RELEASE_REQ
            WHERE CRR_TRE_ID = #{trcNo}
            AND (
            CRR_STATUS_CD IN ('REL_DONE', 'DONE', 'RELEASED', 'APPROVED')
            OR CRR_RELEASE_DT IS NOT NULL
            )
      </select>
</mapper>
