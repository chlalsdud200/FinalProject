/* ===== 검역 관리 전용 JS =====
 * - 수입검역신청 화면 처리
 * - 첨부문서 자동입력 처리
 * - 관세사 검역결과조회 TOAST UI Grid 처리
 *
 * ※ app.js 에 있던 quConfigs / updateQuForm / qTab 등은 quarantine.jsp 에서 참조하는
 *   DOM 요소(qu-type-select, dynamic-field-1, qu-dynamic-container 등)가 존재하지 않아
 *   실제로 호출되지 않는 dead code였으므로 옮기지 않았다.
 */



/* =========================================================
   수입검역신청 화면 전용 함수
   - quarantineImport.jsp에서 호출하는 함수들
========================================================= */

/* ===== 수입의뢰 조회 모달 열기 ===== */
function openImportRqstModal() {
  var modal = document.getElementById('importRqstModal');

  if (!modal) {
    alert('수입의뢰 조회 모달을 찾을 수 없습니다.');
    return;
  }

  modal.classList.add('show');
}

/* ===== 수입의뢰 조회 모달 닫기 ===== */
function closeImportRqstModal() {
  var modal = document.getElementById('importRqstModal');

  if (!modal) {
    return;
  }

  modal.classList.remove('show');
}

/* ===== 수입검역신청 저장 전 검증 ===== */
function validateQuarantineForm() {
  var form = document.getElementById('quImportForm');

  if (!form) {
    alert('수입검역신청 폼을 찾을 수 없습니다.');
    return false;
  }

  function getValue(name) {
    var el = form.querySelector('[name="' + name + '"]');
    return el ? el.value.trim() : '';
  }

  if (!getValue('iirAplyNo')) {
    alert('수입통관의뢰를 먼저 선택하세요.');
    openImportRqstModal();
    return false;
  }

  if (!getValue('iirExporterNm')) {
    alert('수출자/공급자명을 입력하세요.');
    focusByName(form, 'iirExporterNm');
    return false;
  }

  if (getValue('iirExportCountryCd').length > 2) {
    alert('수출국은 2자리 국가코드로 입력하세요. 예: US, CN, JP, TH');
    focusByName(form, 'iirExportCountryCd');
    return false;
  }

  if (!getValue('iirMainGoodsNm')) {
    alert('대표 검역대상 물품명을 입력하세요.');
    focusByName(form, 'iirMainGoodsNm');
    return false;
  }

  if (!getValue('iirMainHsCd')) {
    alert('대표 HS Code를 입력하세요.');
    focusByName(form, 'iirMainHsCd');
    return false;
  }

  if (!getValue('iilWilNo')) {
      alert('검역장소명을 선택하세요.');
      focusByName(form, 'iilNm');
      return false;
  }
  
  if (!getValue('iilPlanDt')) {
      alert('검역예정일시를 입력하세요.');
      focusByName(form, 'iilPlanDt');
      return false;
  }

  if (!getValue('iirRsnCn')) {
      alert('검역 요청 사유를 입력하세요.');
      focusByName(form, 'iirRsnCn');
      return false;
  }

  var itemRows = document.querySelectorAll('#quarantineItemBody .quarantine-item-row');

  if (itemRows.length === 0) {
    alert('검역 대상 품목을 1개 이상 입력하세요.');
    return false;
  }

  for (var i = 0; i < itemRows.length; i++) {
    var hsCd = itemRows[i].querySelector('[name="itemList[' + i + '].hsCd"]');
    var goodsNm = itemRows[i].querySelector('[name="itemList[' + i + '].goodsNm"]');
    var originCountryCd = itemRows[i].querySelector('[name="itemList[' + i + '].originCountryCd"]');

    if (!hsCd || !hsCd.value.trim()) {
      alert((i + 1) + '번째 품목의 HS코드를 입력하세요.');
      if (hsCd) hsCd.focus();
      return false;
    }

    if (!goodsNm || !goodsNm.value.trim()) {
      alert((i + 1) + '번째 품목의 품명을 입력하세요.');
      if (goodsNm) goodsNm.focus();
      return false;
    }

    if (!originCountryCd || !originCountryCd.value.trim()) {
      alert((i + 1) + '번째 품목의 원산지를 입력하세요.');
      if (originCountryCd) originCountryCd.focus();
      return false;
    }
  }

  return confirm('수입검역신청을 전송하시겠습니까?');
}

/* ===== name 기준 focus 처리 ===== */
function focusByName(form, name) {
  var el = form.querySelector('[name="' + name + '"]');

  if (el) {
    el.focus();
  }
}

/* ===== 검역 대상 품목 추가 ===== */
function addQuarantineItem() {
  var tbody = document.getElementById('quarantineItemBody');

  if (!tbody) {
    alert('품목 입력 영역을 찾을 수 없습니다.');
    return;
  }

  var index = tbody.querySelectorAll('.quarantine-item-row').length;

  var tr = document.createElement('tr');
  tr.className = 'quarantine-item-row';

  tr.innerHTML =
    '<td><input type="text" name="itemList[' + index + '].hsCd" placeholder="HS코드"></td>' +
    '<td><input type="text" name="itemList[' + index + '].goodsNm" placeholder="품명"></td>' +
    '<td><input type="text" name="itemList[' + index + '].scientificNm" placeholder="학명"></td>' +
    '<td><input type="text" name="itemList[' + index + '].useCd" placeholder="용도"></td>' +
    '<td><input type="number" step="0.001" name="itemList[' + index + '].qty" placeholder="수량"></td>' +
    '<td><input type="text" name="itemList[' + index + '].qtyUnitCd" placeholder="단위"></td>' +
    '<td><input type="number" step="0.001" name="itemList[' + index + '].netWeight" placeholder="순중량"></td>' +
    '<td><input type="number" name="itemList[' + index + '].pkgCnt" placeholder="포장개수"></td>' +
    '<td><input type="text" name="itemList[' + index + '].originCountryCd" placeholder="예: US"></td>' +
    '<td style="text-align:center;">' +
      '<button type="button" class="qu-trash-btn" onclick="removeQuarantineItem(this)" title="삭제">' +
        '<span class="material-symbols-outlined">delete</span>' +
      '</button>' +
    '</td>';

  tbody.appendChild(tr);
}

/* ===== 검역 대상 품목 삭제 ===== */
function removeQuarantineItem(button) {
  var tbody = document.getElementById('quarantineItemBody');

  if (!tbody) {
    return;
  }

  var rows = tbody.querySelectorAll('.quarantine-item-row');

  if (rows.length <= 1) {
    alert('검역 대상 품목은 최소 1개 이상 필요합니다.');
    return;
  }

  var row = button.closest('.quarantine-item-row');

  if (row) {
    row.remove();
  }

  reindexQuarantineItems();
}

/* ===== 품목 삭제 후 itemList index 재정렬 ===== */
function reindexQuarantineItems() {
  var rows = document.querySelectorAll('#quarantineItemBody .quarantine-item-row');

  rows.forEach(function(row, index) {
    var fields = row.querySelectorAll('input, select, textarea');

    fields.forEach(function(field) {
      if (field.name) {
        field.name = field.name.replace(/itemList\[\d+\]/, 'itemList[' + index + ']');
      }
    });
  });
}

/* ===== 첨부파일 선택 처리 ===== */
function handleQuAttachFiles(files) {
    const fileListArea = document.getElementById("quAttachFileList");

    if (!fileListArea) {
        return;
    }

    fileListArea.innerHTML = "";

    if (!files || files.length === 0) {
        return;
    }

    Array.from(files).forEach(function(file) {
        const fileItem = document.createElement("div");
        fileItem.className = "qu-attach-file-item";

        fileItem.innerHTML = `
            <span class="material-symbols-outlined file-icon">description</span>
            <div class="qu-attach-file-info">
                <div class="qu-attach-file-name" title="${file.name}">
                    ${file.name}
                </div>
                <div class="qu-attach-file-size">
                    ${formatQuFileSize(file.size)}
                </div>
            </div>
        `;

        fileListArea.appendChild(fileItem);
    });
}

function formatQuFileSize(size) {
    if (size < 1024) {
        return size + " B";
    }

    if (size < 1024 * 1024) {
        return (size / 1024).toFixed(1) + " KB";
    }

    return (size / (1024 * 1024)).toFixed(1) + " MB";
}

/* ===== 첨부파일 드래그 오버 ===== */
function handleQuAttachDragOver(event) {
  event.preventDefault();

  var box = document.getElementById('quAttachBox');

  if (box) {
    box.classList.add('drag-over');
  }
}

/* ===== 첨부파일 드래그 해제 ===== */
function handleQuAttachDragLeave(event) {
  event.preventDefault();

  var box = document.getElementById('quAttachBox');

  if (box) {
    box.classList.remove('drag-over');
  }
}

/* ===== 첨부파일 드롭 ===== */
function handleQuAttachDrop(event) {
    event.preventDefault();

    const box = document.getElementById("quAttachBox");
    if (box) {
        box.classList.remove("drag-over");
    }

    const files = event.dataTransfer.files;
    const input = document.getElementById("quAttachFiles");

    if (input) {
        input.files = files;
    }

    handleQuAttachFiles(files);
}

/* ===== 파일 크기 표시 ===== */
function formatFileSize(size) {
  if (size === 0) {
    return '0 B';
  }

  var units = ['B', 'KB', 'MB', 'GB'];
  var index = Math.floor(Math.log(size) / Math.log(1024));
  var value = size / Math.pow(1024, index);

  return value.toFixed(1) + ' ' + units[index];
}


/* ===== 수입검역신청 커스텀 알림 모달 ===== */
function showQuAiAlert(options) {
    const type = options.type || "success";
    const title = options.title || "알림";
    const message = options.message || "";
    const buttonText = options.buttonText || "확인";

    let modal = document.getElementById("quAiAlertModal");

    if (!modal) {
        modal = document.createElement("div");
        modal.id = "quAiAlertModal";
        modal.className = "qu-ai-alert-bg";

        modal.innerHTML = `
            <div class="qu-ai-alert-box">
                <div class="qu-ai-alert-icon-wrap">
                    <span class="material-symbols-outlined qu-ai-alert-icon"></span>
                </div>

                <div class="qu-ai-alert-content">
                    <div class="qu-ai-alert-title"></div>
                    <div class="qu-ai-alert-message"></div>
                </div>

                <div class="qu-ai-alert-actions">
                    <button type="button" class="qu-ai-alert-btn">확인</button>
                </div>
            </div>
        `;

        document.body.appendChild(modal);
    }

    const icon = modal.querySelector(".qu-ai-alert-icon");
    const titleEl = modal.querySelector(".qu-ai-alert-title");
    const messageEl = modal.querySelector(".qu-ai-alert-message");
    const button = modal.querySelector(".qu-ai-alert-btn");

    modal.classList.remove("success", "error", "warning");
    modal.classList.add(type);

    if (type === "success") {
        icon.textContent = "check_circle";
    } else if (type === "error") {
        icon.textContent = "error";
    } else {
        icon.textContent = "info";
    }

    titleEl.textContent = title;
    messageEl.textContent = message;
    button.textContent = buttonText;

    button.onclick = function () {
        modal.classList.remove("show");
    };

    modal.classList.add("show");
}

let aiFillProgressTimer = null;
let aiFillProgressValue = 0;

/* ===== 첨부문서 자동입력 진행률 표시 ===== */
function showAiFillLoading() {
    const overlay = document.getElementById("aiFillLoadingOverlay");
    const progressBar = document.getElementById("aiFillProgressBar");
    const progressPercent = document.getElementById("aiFillProgressPercent");
    const loadingText = document.getElementById("aiFillLoadingText");
    const aiFillBtn = document.getElementById("aiFillBtn");

    aiFillProgressValue = 0;

    if (overlay) {
        overlay.style.display = "flex";
    }

    if (progressBar) {
        progressBar.style.width = "0%";
    }

    if (progressPercent) {
        progressPercent.textContent = "0%";
    }

    if (loadingText) {
        loadingText.textContent = "PDF 문서를 분석하고 있습니다.";
    }

    if (aiFillBtn) {
        aiFillBtn.disabled = true;
        aiFillBtn.classList.add("is-loading");
    }

    if (aiFillProgressTimer) {
        clearInterval(aiFillProgressTimer);
    }

    aiFillProgressTimer = setInterval(function() {
        /*
         * 실제 서버 진행률은 알 수 없으므로 90%까지만 천천히 증가시킨다.
         * 서버 응답이 오면 completeAiFillLoading()에서 100%로 처리한다.
         */
        if (aiFillProgressValue < 90) {
            aiFillProgressValue += getAiFillProgressStep();
            if (aiFillProgressValue > 90) {
                aiFillProgressValue = 90;
            }

            updateAiFillProgress(aiFillProgressValue);
        }
    }, 450);
}

/* 진행률 증가 폭 */
function getAiFillProgressStep() {
    if (aiFillProgressValue < 25) {
        return 8;
    }

    if (aiFillProgressValue < 60) {
        return 5;
    }

    if (aiFillProgressValue < 80) {
        return 3;
    }

    return 1;
}

/* 진행률 UI 갱신 */
function updateAiFillProgress(percent) {
    const progressBar = document.getElementById("aiFillProgressBar");
    const progressPercent = document.getElementById("aiFillProgressPercent");
    const loadingText = document.getElementById("aiFillLoadingText");

    const safePercent = Math.max(0, Math.min(100, Math.floor(percent)));

    if (progressBar) {
        progressBar.style.width = safePercent + "%";
    }

    if (progressPercent) {
        progressPercent.textContent = safePercent + "%";
    }

    if (loadingText) {
        if (safePercent < 30) {
            loadingText.textContent = "PDF 문서를 읽고 있습니다.";
        } else if (safePercent < 60) {
            loadingText.textContent = "문서에서 검역신청 정보를 추출하고 있습니다.";
        } else if (safePercent < 90) {
            loadingText.textContent = "추출한 정보를 화면에 반영할 준비 중입니다.";
        } else {
            loadingText.textContent = "자동입력 결과를 정리하고 있습니다.";
        }
    }
}

/* 성공 시 100% 처리 */
function completeAiFillLoading(callback) {
    if (aiFillProgressTimer) {
        clearInterval(aiFillProgressTimer);
        aiFillProgressTimer = null;
    }

    aiFillProgressValue = 100;
    updateAiFillProgress(100);

    setTimeout(function() {
        hideAiFillLoading();

        if (typeof callback === "function") {
            callback();
        }
    }, 450);
}

/* 실패/종료 시 로딩 숨김 */
function hideAiFillLoading() {
    const overlay = document.getElementById("aiFillLoadingOverlay");
    const aiFillBtn = document.getElementById("aiFillBtn");

    if (aiFillProgressTimer) {
        clearInterval(aiFillProgressTimer);
        aiFillProgressTimer = null;
    }

    if (overlay) {
        overlay.style.display = "none";
    }

    if (aiFillBtn) {
        aiFillBtn.disabled = false;
        aiFillBtn.classList.remove("is-loading");
    }
}

// 첨부한 PDF 문서를 서버로 보내서 AI 자동입력 실행
function autoFillFromAttachedPdf() {
    const fileInput = document.getElementById("quAttachFiles");
    const irNoInput = document.getElementById("selectedIrNo");

    if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
        showQuAiAlert({
            type: "warning",
            title: "첨부문서 확인",
            message: "자동입력할 첨부문서를 먼저 선택하세요."
        });
        return;
    }

    const pdfFiles = Array.from(fileInput.files).filter(function(file) {
        return file.name.toLowerCase().endsWith(".pdf");
    });

    if (pdfFiles.length === 0) {
        showQuAiAlert({
            type: "warning",
            title: "PDF 파일 필요",
            message: "PDF 파일을 1개 이상 첨부해야 자동입력이 가능합니다."
        });
        return;
    }

    const formData = new FormData();

    pdfFiles.forEach(function(file) {
        formData.append("attachFiles", file);
    });

    if (irNoInput) {
        formData.append("irNo", irNoInput.value);
    }

    const csrfInput = document.querySelector("input[name='_csrf']");
    if (csrfInput) {
        formData.append("_csrf", csrfInput.value);
    }

    showAiFillLoading();

    fetch(window.contextPath + "/broker/quarantine/import/ai-fill.do", {
        method: "POST",
        body: formData
    })
    .then(function(response) {
        if (!response.ok) {
            throw new Error("자동입력 요청 실패");
        }

        return response.json();
    })
    .then(function(result) {
        console.log("첨부문서 자동입력 응답:", result);

        if (!result || result.success === false) {
            hideAiFillLoading();

            showQuAiAlert({
                type: "error",
                title: "자동입력 실패",
                message: result && result.message ? result.message : "첨부문서 자동입력에 실패했습니다."
            });
            return;
        }

        applyImportQuarantineAiData(result.data || result);

        completeAiFillLoading(function() {
            showQuAiAlert({
                type: "success",
                title: "자동입력 완료",
                message: "첨부문서 기준으로 입력값이 자동 반영되었습니다. 내용을 확인하세요."
            });
        });
    })
    .catch(function(error) {
        console.error(error);

        hideAiFillLoading();

        showQuAiAlert({
            type: "error",
            title: "처리 오류",
            message: "첨부문서 자동입력 중 오류가 발생했습니다."
        });
    });
}

// AI가 추출한 값을 수입검역신청 화면 input에 반영
function applyImportQuarantineAiData(data) {
    if (!data) {
        return;
    }

    setQuValue("iirExporterNm", data.iirExporterNm);
    setQuValue("iirExporterCompanyNm", data.iirExporterCompanyNm);
    setQuValue("iirExporterAdres", data.iirExporterAdres);
    setQuValue("iirExportCountryCd", data.iirExportCountryCd);
    setQuValue("iirPhytoCertNo", data.iirPhytoCertNo);
    setQuValue("iirPhytoCertIssueDt", data.iirPhytoCertIssueDt);

    setQuValue("iirTransportNm", data.iirTransportNm);
    setQuValue("iirLoadPortCd", data.iirLoadPortCd);
    setQuValue("iirShipDt", data.iirShipDt);
    setQuValue("iirArrvPortCd", data.iirArrvPortCd);
    setQuValue("iirArrvDt", data.iirArrvDt);

    setQuValue("iirMainGoodsNm", data.iirMainGoodsNm);
    setQuValue("iirMainHsCd", data.iirMainHsCd);
    setQuValue("iirTotalWeight", data.iirTotalWeight);
    setQuValue("iirTotalPkgCnt", data.iirTotalPkgCnt);
    setQuValue("iirPkgUnitCd", data.iirPkgUnitCd);
    setQuValue("iirPkgMaterial", data.iirPkgMaterial);
    setQuValue("iirWoodPkgYn", data.iirWoodPkgYn);
    setQuValue("iirWoodPkgMarkNo", data.iirWoodPkgMarkNo);

    // 품목 1행 자동입력
    if (data.itemList && data.itemList.length > 0) {
        const item = data.itemList[0];

        setQuValue("itemList[0].hsCd", item.hsCd);
        setQuValue("itemList[0].goodsNm", item.goodsNm);
        setQuValue("itemList[0].scientificNm", item.scientificNm);
        setQuValue("itemList[0].useCd", item.useCd);
        setQuValue("itemList[0].qty", item.qty);
        setQuValue("itemList[0].qtyUnitCd", item.qtyUnitCd);
        setQuValue("itemList[0].netWeight", item.netWeight);
        setQuValue("itemList[0].pkgCnt", item.pkgCnt);
        setQuValue("itemList[0].originCountryCd", item.originCountryCd);
    }
}


// name 기준으로 input/select/textarea 값 세팅
function setQuValue(name, value) {
    if (value === undefined || value === null || value === "") {
        return;
    }

    const el = document.querySelector("[name='" + name + "']");

    if (!el) {
        return;
    }

    el.value = value;
}


/* =========================================================
   관세사 검역결과조회 - TOAST UI Grid
========================================================= */

$(function() {
    const gridEl = document.getElementById("quarantineResultGrid");

    // 수입검역신청 페이지에서는 이 div가 없으므로 실행하지 않는다.
    if (!gridEl) {
        return;
    }

    if (typeof TacsGrid === "undefined") {
        console.error("TacsGrid 공통 모듈이 로드되지 않았습니다.");
        return;
    }

    const quarantineResultGrid = TacsGrid.create({
        el: "quarantineResultGrid",
        perPage: 10,
        bodyHeight: 420,

        columns: [
            {
                header: "검역신청번호",
                name: "iirReqNo",
                align: "center",
                width: 150,
                sortable: true
            },
            {
                header: "수입의뢰번호",
                name: "iirAplyNo",
                align: "center",
                width: 150,
                sortable: true
            },
            {
                header: "수입자명",
                name: "idImprNm",
                align: "center",
                width: 140,
                sortable: true
            },
            {
                header: "상품명",
                name: "idiDclrGdsnm",
                minWidth: 180,
                sortable: true
            },
            {
                header: "HS코드",
                name: "idiHsCd",
                align: "center",
                width: 120,
                sortable: true
            },
            {
                header: "신청일",
                name: "iirDt",
                align: "center",
                width: 120,
                sortable: true
            },
            {
                header: "검역완료일",
                name: "iirCmplDt",
                align: "center",
                width: 130,
                sortable: true,
                formatter: function(obj) {
                    return obj.value ? obj.value : "—";
                }
            },
            {
                header: "검역수량",
                name: "idiQty",
                align: "center",
                width: 120,
                sortable: true,
                formatter: function(obj) {
                    const row = obj.row;
                    const qty = row.idiQty || "";
                    const unit = row.idiQtyUnitCd || "";

                    if (!qty && !unit) {
                        return "—";
                    }

                    return qty + " " + unit;
                }
            },
            {
                header: "검역결과",
                name: "iirResultNm",
                align: "center",
                width: 120,
                sortable: true,
                formatter: function(obj) {
                    const row = obj.row;
                    return row.iirResultNm || row.iirStatusNm || row.iirStatusCd || "—";
                }
            },
            {
                header: "상세",
                name: "detailBtn",
                align: "center",
                width: 90,
                formatter: function() {
                    return '<button type="button" class="grid-detail-btn">상세</button>';
                }
            }
        ]
    });

    /*
     * 상세 버튼 클릭 시 기존 상세 URL로 이동
     */
    quarantineResultGrid.on("click", function(ev) {
        if (ev.columnName !== "detailBtn") {
            return;
        }

        if (ev.rowKey === null || ev.rowKey === undefined) {
            return;
        }

        const rowData = quarantineResultGrid.getRow(ev.rowKey);

        if (!rowData || !rowData.iirReqNo) {
            alert("검역신청번호가 없습니다.");
            return;
        }

        location.href = window.contextPath
            + "/broker/quarantine/detail.do?iirReqNo="
            + encodeURIComponent(rowData.iirReqNo);
    });

    /*
     * Grid 목록 조회
     */
	function loadQuarantineResultGrid() {
	    const fromDate = $("#quSearchFromDate").val();
	    const toDate = $("#quSearchToDate").val();

	    if (fromDate && toDate && fromDate > toDate) {
	        alert("조회기간의 종료일은 시작일보다 빠를 수 없습니다.");
	        $("#quSearchToDate").focus();
	        return;
	    }

	    const params = $("#quResultSearchForm").serialize();

	    TacsGrid.load(
	        quarantineResultGrid,
	        window.contextPath + "/broker/quarantine/result/gridData.do",
	        params
	    );
	}

    /*
     * Grid 데이터 로딩 후 총 건수 갱신
     */
    quarantineResultGrid.on("onGridUpdated", function() {
        const countEl = document.getElementById("quTotalCount");

        if (countEl) {
            countEl.textContent = quarantineResultGrid.getData().length;
        }
    });

    /*
     * 검색 submit 방지 후 AJAX 조회
     */
    $("#quResultSearchForm").on("submit", function(e) {
        e.preventDefault();
        loadQuarantineResultGrid();
    });
	
	$("#quResultResetBtn").on("click", function() {
	    $("#quResultSearchForm")
	        .find("input, select")
	        .val("");

	    loadQuarantineResultGrid();
	});

    /*
     * 초기화 버튼 클릭
     * 기존 JSP의 onclick 방식 대신 JS에서 처리하려면 초기화 버튼에 id를 주는 방식이 더 좋다.
     * 현재는 onclick이 있으면 그대로 둬도 됨.
     */

    // 최초 화면 진입 시 조회
    loadQuarantineResultGrid();
});

/* =========================================================
   관세사 보완완료 전송 검증
========================================================= */
function validateSupplementSubmitForm(form) {
    if (!form) {
        alert("보완제출 폼을 찾을 수 없습니다.");
        return false;
    }

    const srNo = form.querySelector("[name='srNo']");
    const iirReqNo = form.querySelector("[name='iirReqNo']");
    const srSubmitCn = form.querySelector("[name='srSubmitCn']");

    if (!srNo || !srNo.value.trim()) {
        alert("보완요청번호가 없습니다.");
        return false;
    }

    if (!iirReqNo || !iirReqNo.value.trim()) {
        alert("검역요청번호가 없습니다.");
        return false;
    }

    if (!srSubmitCn || !srSubmitCn.value.trim()) {
        alert("보완내용을 입력하세요.");
        if (srSubmitCn) {
            srSubmitCn.focus();
        }
        return false;
    }

    return confirm("보완내용과 보완서류를 검역기관에 전송하시겠습니까?");
}

/* =========================================================
   보완서류 재제출 파일명 표시
========================================================= */
function showSupplementFileNames(input) {
    const fileListBox = document.getElementById("supplementFileList");

    if (!fileListBox) {
        return;
    }

    if (!input || !input.files || input.files.length === 0) {
        fileListBox.classList.remove("has-file");
        fileListBox.textContent = "선택된 파일이 없습니다.";
        return;
    }

    const files = Array.from(input.files);

    fileListBox.classList.add("has-file");
    fileListBox.innerHTML = "";

    files.forEach(function(file) {
        const item = document.createElement("div");
        item.className = "supplement-file-item";

        const icon = document.createElement("span");
        icon.className = "material-symbols-outlined";
        icon.textContent = "description";

        const name = document.createElement("span");
        name.textContent = file.name;

        item.appendChild(icon);
        item.appendChild(name);

        fileListBox.appendChild(item);
    });
}


/* =========================================================
   수입검역신청 - 검역장소 선택 시 위치정보 자동 세팅
========================================================= */
function setQuarantineLocationInfo(selectEl) {
    if (!selectEl) {
        return;
    }

    const selectedOption = selectEl.options[selectEl.selectedIndex];

    const iilWilNo = document.getElementById("iilWilNo");
    const iilTyCd = document.getElementById("iilTyCd");
    const iilZip = document.getElementById("iilZip");
    const iilAdres = document.getElementById("iilAdres");
    const iilDetailAdres = document.getElementById("iilDetailAdres");

    if (!selectedOption || !selectedOption.value) {
        if (iilWilNo) iilWilNo.value = "";
        if (iilTyCd) iilTyCd.value = "BONDED_WH";
        if (iilZip) iilZip.value = "";
        if (iilAdres) iilAdres.value = "";
        if (iilDetailAdres) iilDetailAdres.value = "";
        return;
    }

    if (iilWilNo) {
        iilWilNo.value = selectedOption.dataset.wilNo || "";
    }

    if (iilTyCd) {
        iilTyCd.value = selectedOption.dataset.tyCd || "BONDED_WH";
    }

    if (iilZip) {
        iilZip.value = selectedOption.dataset.zip || "";
    }

    if (iilAdres) {
        iilAdres.value = selectedOption.dataset.adres || "";
    }

    if (iilDetailAdres) {
        iilDetailAdres.value = selectedOption.dataset.detailAdres || "";
    }
}