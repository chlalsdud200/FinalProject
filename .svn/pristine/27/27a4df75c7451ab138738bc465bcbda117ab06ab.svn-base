package kr.or.tacs.broker.quarantine.service;

import java.util.List;

import java.io.IOException;

import org.apache.pdfbox.Loader;
import org.apache.pdfbox.pdmodel.PDDocument;
import org.apache.pdfbox.text.PDFTextStripper;

import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import org.springframework.util.StringUtils;
import org.springframework.web.multipart.MultipartFile;
import org.springframework.ai.chat.client.ChatClient;
import java.util.ArrayList;

import java.util.HashMap;
import java.util.Map;

import kr.or.tacs.common.file.service.IFileService;
import kr.or.tacs.common.notification.service.INotificationService;
import kr.or.tacs.dto.broker.quarantine.QuarantineAiFillDTO;
import kr.or.tacs.broker.quarantine.mapper.IQuarantineMapper;
import kr.or.tacs.vo.broker.quarantine.QuarantineItemVO;
import kr.or.tacs.vo.broker.quarantine.QuarantineVO;
import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class QuarantineServiceImpl implements IQuarantineService {

    private final IQuarantineMapper quarantineMapper;
    
    private final ChatClient.Builder chatClientBuilder;
    
    private final IFileService fileService;

    private final INotificationService notificationService;

    @Override
    public List<QuarantineVO> selectImportQuarantineResultList(QuarantineVO searchVO) {
        return quarantineMapper.selectImportQuarantineResultList(searchVO);
    }

    @Override
    public QuarantineVO selectImportQuarantineDetail(String iirReqNo) {
    	// 1. 검역 상세정보 조회
        QuarantineVO detailVO = quarantineMapper.selectImportQuarantineDetail(iirReqNo);

        if (detailVO == null) {
            return null;
        }

        // 2. 상세정보에 파일그룹번호가 있으면 공통 파일 모듈로 첨부파일 목록 조회
        if (detailVO.getIirTfgNo() != null) {
            detailVO.setAttachFileList(fileService.getFileList(detailVO.getIirTfgNo()));
        }

        return detailVO;
    }

    @Override
    public List<QuarantineVO> selectImportRequestCandidateList(String brokerId) {
        return quarantineMapper.selectImportRequestCandidateList(brokerId);
    }

    @Override
    public QuarantineVO selectImportRequestForQuarantine(String irNo, String brokerId) {
        QuarantineVO param = new QuarantineVO();
        param.setIrNo(irNo);
        param.setLoginBrokerId(brokerId);

        return quarantineMapper.selectImportRequestForQuarantine(param);
    }

    @Override
    @Transactional
    public void insertImportQuarantineRequest(QuarantineVO quarantineVO) {

        /*
         * JSP에서 iirAplyNo와 irNo를 같이 넘기지만,
         * 혹시 iirAplyNo가 비어 있으면 irNo로 보정한다.
         */
        if (!StringUtils.hasText(quarantineVO.getIirAplyNo())
                && StringUtils.hasText(quarantineVO.getIrNo())) {
            quarantineVO.setIirAplyNo(quarantineVO.getIrNo());
        }

        /*
         * 수입통관의뢰번호 필수 검증
         */
        if (!StringUtils.hasText(quarantineVO.getIirAplyNo())) {
            throw new IllegalArgumentException("수입 의뢰번호가 없습니다.");
        }
        
        /*
         * 담당 현장공무원 필수 검증
         *
         * 수입검역신청 화면에서 관세사가 검역기관/담당 현장공무원을 직접 선택한다.
         * 선택된 값은 QuarantineVO.iirQrtnOfficerId로 바인딩되고,
         * IMP_INS_REQ.IIR_QRTN_OFFICER_ID에 저장된다.
         *
         * 기존에는 QRT2026000001을 기본값으로 넣었지만,
         * 이제는 사용자가 선택하지 않으면 신청을 막는다.
         */
        if (!StringUtils.hasText(quarantineVO.getIirQrtnOfficerId())) {
            throw new IllegalArgumentException("검역기관 및 담당 현장공무원을 선택하세요.");
        }

        /*
         * 선택한 현장공무원의 소속기관 코드 조회
         *
         * 관세사가 선택한 현장공무원 ID 기준으로 OFFICER.OFFICER_INST_CD를 조회한다.
         * 이 값을 검역기관 코드와 관할기관 코드에 같이 세팅한다.
         *
         * IIR_QRTN_INST_CD:
         * - 검역요청을 담당할 검역기관 코드
         *
         * IIR_JRSD_RGN_AG_CD:
         * - 관할 지역/기관 코드
         */
        String officerInstCd = quarantineMapper.selectOfficerInstCd(quarantineVO.getIirQrtnOfficerId());

        if (!StringUtils.hasText(officerInstCd)) {
            throw new IllegalStateException("선택한 현장공무원의 소속기관 코드가 없습니다.");
        }

        quarantineVO.setIirQrtnInstCd(officerInstCd);
        quarantineVO.setIirJrsdRgnAgCd(officerInstCd);
        
        /*
         * 국가코드는 DB 컬럼 길이가 2자리이므로 ISO 2자리 코드만 허용한다.
         * 예: US, CN, JP, TH, KR
         */
        if (StringUtils.hasText(quarantineVO.getIirExportCountryCd())) {
            quarantineVO.setIirExportCountryCd(quarantineVO.getIirExportCountryCd().trim().toUpperCase());

            if (quarantineVO.getIirExportCountryCd().length() > 2) {
                throw new IllegalArgumentException("수출국은 2자리 국가코드로 입력하세요. 예: US, CN, JP, TH");
            }
        }
        
        /*
         * 운송수단 구분 보정
         * - 수입의뢰에서 넘어온 운송수단 구분이 있으면 사용
         * - 없으면 운송수단명/항구 정보 기준으로 최소 보정
         */
        if (!StringUtils.hasText(quarantineVO.getIirTransportTypeCd())) {
            if (StringUtils.hasText(quarantineVO.getIdTrnspMnCd())) {
                quarantineVO.setIirTransportTypeCd(quarantineVO.getIdTrnspMnCd());
            } else if (StringUtils.hasText(quarantineVO.getIirTransportNm())) {
                String transportNm = quarantineVO.getIirTransportNm().toUpperCase();

                if (transportNm.contains("AIR") || transportNm.contains("항공")) {
                    quarantineVO.setIirTransportTypeCd("AIR");
                } else {
                    quarantineVO.setIirTransportTypeCd("SEA");
                }
            }
        }
        

        /*
         * 같은 수입의뢰번호로 이미 검역신청이 등록되어 있는지 확인
         */
        int already = quarantineMapper.countImportQuarantineRequest(quarantineVO.getIirAplyNo());

        if (already > 0) {
            throw new IllegalStateException("이미 검역신청이 등록된 수입 의뢰입니다.");
        }
        
        /*
         * 검역 위치는 창고 위치 기준으로 저장한다.
         * IMP_INS_LOC.IIL_WIL_NO는 WAREHOUSE_ITEM_LOCATION.WIL_NO를 참조하므로 필수다.
         *
         * 위치 정보가 없으면 DB 저장/파일 업로드 전에 중단한다.
         */
        if (!StringUtils.hasText(quarantineVO.getIilWilNo())) {
            throw new IllegalStateException("선택한 수입의뢰의 창고 위치 정보가 없습니다. 창고 입고/배치 정보를 먼저 확인하세요.");
        }

        if (!StringUtils.hasText(quarantineVO.getIilTyCd())) {
            quarantineVO.setIilTyCd("BONDED_WH");
        }

        /*
         * 1. 수입검역요청 기본정보 저장
         * - XML selectKey에서 IIR_REQ_NO 생성
         * - 생성된 값이 quarantineVO.iirReqNo에 세팅됨
         */
        quarantineMapper.insertImportQuarantineRequest(quarantineVO);
        
        /*
         * 1-1. 첨부파일 저장
         * - 수입검역요청번호가 생성된 뒤 첨부파일을 공통 파일 모듈에 저장한다.
         * - 공통 파일 모듈은 TACS_FILE_GRP, DOCS_FILE_DATA, TACS_FILE_MAP을 저장하고
         *   Google Drive 업로드를 처리한다.
         * - 반환된 파일그룹번호를 IMP_INS_REQ.IIR_TFG_NO에 연결해야
         *   검역기관 상세 화면에서 첨부서류를 조회할 수 있다.
         */
        Long tfgNo = uploadImportQuarantineFiles(quarantineVO);

        if (tfgNo != null) {
            quarantineVO.setIirTfgNo(tfgNo);
            quarantineMapper.updateImportQuarantineFileGroup(quarantineVO);
        }
        

        /*
         * 2. 수입검역장소 저장
         * - XML selectKey에서 IIL_NO 생성
         * - 생성된 값이 quarantineVO.iilNo에 세팅됨
         */
        quarantineMapper.insertImportQuarantineLocation(quarantineVO);

        /*
         * 3. 검역대상 품목 저장
         * - JSP의 itemList[0].hsCd 구조가 QuarantineVO.itemList로 바인딩됨
         */
        List<QuarantineItemVO> itemList = quarantineVO.getItemList();

        if (itemList != null && !itemList.isEmpty()) {
            int sn = 1;

            for (QuarantineItemVO itemVO : itemList) {
                if (itemVO == null) {
                    continue;
                }

                /*
                 * 완전히 빈 품목 행은 저장하지 않는다.
                 */
                if (!hasItemValue(itemVO)) {
                    continue;
                }

                itemVO.setIiriReqNo(quarantineVO.getIirReqNo());
                itemVO.setIiriSn(sn++);

                quarantineMapper.insertImportQuarantineItem(itemVO);
            }
        }

        /*
         * 4. 검역요청 생성 이력 저장
         */
        quarantineMapper.insertImportQuarantineHistory(quarantineVO);

        /*
         * 5. 배정된 현장공무원(검역관)에게 검역신청 접수 알림
         * - 관세사가 검역신청 시 담당 검역관(IIR_QRTN_OFFICER_ID)을 직접 지정하므로 그 1인에게만 전달.
         * - 클릭 시 그 검역신청 상세로 이동.
         */
        String reqNo = quarantineVO.getIirReqNo();
        if (StringUtils.hasText(reqNo)) {
            Map<String, String> bindings = new HashMap<>();
            bindings.put("reqNo", reqNo);
            bindings.put("linkUrl", "/fieldofficer/inspectionRequest/detail.do?reqNo=" + reqNo);
            notificationService.registNotification(
                    "QUARANTINE_REQUESTED", reqNo, quarantineVO.getIirReqOfficerId(), bindings);
        }
    }

    /*
     * 품목 행에 입력값이 하나라도 있는지 확인
     */
    private boolean hasItemValue(QuarantineItemVO itemVO) {
        return StringUtils.hasText(itemVO.getHsCd())
                || StringUtils.hasText(itemVO.getGoodsNm())
                || StringUtils.hasText(itemVO.getScientificNm())
                || StringUtils.hasText(itemVO.getUseCd())
                || StringUtils.hasText(itemVO.getQty())
                || StringUtils.hasText(itemVO.getQtyUnitCd())
                || StringUtils.hasText(itemVO.getNetWeight())
                || StringUtils.hasText(itemVO.getPkgCnt())
                || StringUtils.hasText(itemVO.getOriginCountryCd());
    }
    
    /*
     * 수입검역신청 첨부파일 저장
     *
     * 처리 흐름:
     * 1. JSP에서 넘어온 attachFiles 중 실제 파일만 골라낸다.
     * 2. 공통 파일 서비스 uploadFiles()를 호출한다.
     * 3. 공통 파일 서비스에서 TACS_FILE_GRP, DOCS_FILE_DATA, TACS_FILE_MAP 저장 및
     *    Google Drive 업로드를 처리한다.
     * 4. 생성된 파일그룹번호를 반환한다.
     */
    private Long uploadImportQuarantineFiles(QuarantineVO quarantineVO) {

        MultipartFile[] attachFiles = quarantineVO.getAttachFiles();

        if (attachFiles == null || attachFiles.length == 0) {
            return null;
        }

        List<MultipartFile> uploadFiles = new ArrayList<>();

        for (MultipartFile file : attachFiles) {
            if (file != null && !file.isEmpty()) {
                uploadFiles.add(file);
            }
        }

        if (uploadFiles.isEmpty()) {
            return null;
        }

        try {
            return fileService.uploadFiles(
                    "IMP_INS_REQ",                  // 업무구분코드
                    uploadFiles,                    // 첨부파일 목록
                    quarantineVO.getLoginBrokerId(),// 업로드한 관세사 ID
                    "BROKER"                        // 액터유형
            );
        } catch (Exception e) {
            throw new RuntimeException("수입검역신청 첨부파일 저장 중 오류가 발생했습니다.", e);
        }
    }
    
    @Override
    public QuarantineVO extractImportQuarantineData(MultipartFile[] attachFiles, String irNo) {

    	String pdfText = extractPdfTextFromFiles(attachFiles);

        System.out.println("========== 수입검역신청 첨부 PDF 추출 텍스트 시작 ==========");
        System.out.println(pdfText);
        System.out.println("========== 수입검역신청 첨부 PDF 추출 텍스트 끝 ==========");

        QuarantineAiFillDTO aiDto = extractAiDataFromPdfText(pdfText);

        System.out.println("========== Spring AI 수입검역 자동입력 DTO ==========");
        System.out.println(aiDto);

        return convertAiDtoToQuarantineVO(aiDto);
    }
    
    /*
     * 첨부파일 배열에서 PDF 파일만 골라 텍스트를 추출한다.
     *
     * 처리 흐름:
     * 1. attachFiles 중 PDF 파일만 대상
     * 2. PDFBox Loader로 PDF 로드
     * 3. PDFTextStripper로 텍스트 추출
     * 4. 여러 PDF의 텍스트를 하나의 문자열로 합침
     */
    private String extractPdfTextFromFiles(MultipartFile[] attachFiles) {

        if (attachFiles == null || attachFiles.length == 0) {
            return "";
        }

        StringBuilder textBuilder = new StringBuilder();

        for (MultipartFile file : attachFiles) {
            if (file == null || file.isEmpty()) {
                continue;
            }

            String originalFilename = file.getOriginalFilename();

            if (originalFilename == null
                    || !originalFilename.toLowerCase().endsWith(".pdf")) {
                continue;
            }

            textBuilder.append("\n\n")
                       .append("===== 파일명: ")
                       .append(originalFilename)
                       .append(" =====\n");

            try (PDDocument document = Loader.loadPDF(file.getBytes())) {

                PDFTextStripper stripper = new PDFTextStripper();
                String text = stripper.getText(document);

                textBuilder.append(text);

            } catch (IOException e) {
                throw new RuntimeException("PDF 텍스트 추출 중 오류가 발생했습니다. 파일명: " + originalFilename, e);
            }
        }

        return textBuilder.toString();
    }
    
    
    /*
     * PDFBox로 추출한 문서 텍스트를 Spring AI에 전달해서
     * 수입검역신청 화면에 넣을 데이터만 DTO로 추출한다.
     */
    private QuarantineAiFillDTO extractAiDataFromPdfText(String pdfText) {

        if (!StringUtils.hasText(pdfText)) {
            throw new IllegalArgumentException("PDF에서 추출된 텍스트가 없습니다.");
        }

        String systemPrompt = """
            너는 수입검역신청서 자동입력 도우미다.

            사용자가 제공하는 문서는 식물검역증명서, B/L, Packing List, Invoice 등 무역/검역 관련 문서이다.
            문서에서 수입검역신청 화면에 필요한 값만 추출하라.

            규칙:
            1. 존재하지 않는 값은 빈 문자열로 둔다.
            2. 날짜는 반드시 yyyy-MM-dd 형식으로 변환한다. 예: MAY 20, 2026 -> 2026-05-20
            3. 국가코드는 가능하면 ISO 2자리 코드로 변환한다. 예: VIETNAM -> VN, KOREA -> KR
            4. 중량과 수량은 숫자만 넣는다. 예: 10,080 KG -> 10080
            5. 포장개수도 숫자만 넣는다. 예: 400 BAGS -> 400
            6. 목재포장재 사용 여부는 명확한 목재 포장 정보가 있으면 Y, 아니면 N으로 둔다.
            7. 검역장소명, 검역예정일시, 검역 요청 사유는 문서에서 확정할 수 없으므로 추출하지 않는다.
            8. 설명 문장 없이 지정된 DTO 필드에 맞는 값만 반환한다.
            9. 도착일(iirArrvDt)은 문서에 명확한 Arrival Date 또는 ETA가 있을 때만 입력한다. 
        		Date of Issue, Departure date, Laden on board Date는 도착일로 사용하지 않는다.
        	10. 포장재질(iirPkgMaterial)이 문서에 명확히 없고, BAGS, CARTONS, BOXES처럼 포장 형태만 있으면 해당 값을 iirPkgMaterial에도 넣는다.
        	11. 품목 설명에 FOOD, FOOD GRADE, FOR HUMAN CONSUMPTION 문구가 있으면 itemList.useCd는 "FOOD"로 입력한다.
        	12. Seller/Exporter, Shipper, Exporter가 문서에 있으면 iirExporterNm과 iirExporterCompanyNm에 모두 같은 회사명을 입력한다.
        	13. itemList는 HS코드 개수가 아니라 Packing List 또는 Commercial Invoice의 품목 행 기준으로 생성한다.
			14. HS CODE가 문서에 1개만 있고 품목 행이 여러 개이면, 같은 HS CODE를 각 품목의 hsCd에 반복 입력한다.
			15. Packing List 또는 Invoice에 품목명이 2개 이상 보이면 반드시 itemList도 같은 개수로 생성한다. HS CODE가 1개뿐이어도 품목을 합치지 않는다.
			    예: THAI MILLED RICE 4 BAGS 40 KG, THAI MILLED RICE CORN 2 BAGS 20 KG이면 itemList는 2개이다.
			16. B/L의 Said to contain 영역과 Packing List의 Goods description 영역이 다르면 Packing List와 Invoice의 품목 행을 우선한다.
            """;

        String userPrompt = """
            아래 PDF 추출 텍스트를 기준으로 수입검역신청 자동입력 데이터를 추출해라.

            [PDF 추출 텍스트]
            %s
            """.formatted(pdfText);

        return chatClientBuilder.build()
                .prompt()
                .system(systemPrompt)
                .user(userPrompt)
                .call()
                .entity(QuarantineAiFillDTO.class);
    }
    
    /*
     * AI 응답 DTO를 기존 화면/Controller에서 사용하는 QuarantineVO로 변환한다.
     */
    private QuarantineVO convertAiDtoToQuarantineVO(QuarantineAiFillDTO dto) {

        QuarantineVO vo = new QuarantineVO();

        if (dto == null) {
            return vo;
        }

        /*
         * 수출자/공급자명 보정
         * - 무역서류에서는 Seller/Exporter, Shipper, Exporter가 같은 회사명으로 나오는 경우가 많다.
         * - AI가 iirExporterCompanyNm만 채우고 iirExporterNm을 비워두면
         *   화면의 '수출자/공급자명'이 공백이 되므로 회사명을 대체값으로 넣는다.
         */
        if (StringUtils.hasText(dto.getIirExporterNm())) {
            vo.setIirExporterNm(dto.getIirExporterNm());
        } else if (StringUtils.hasText(dto.getIirExporterCompanyNm())) {
            vo.setIirExporterNm(dto.getIirExporterCompanyNm());
        }

        vo.setIirExporterCompanyNm(dto.getIirExporterCompanyNm());
        vo.setIirExporterAdres(dto.getIirExporterAdres());
        vo.setIirExportCountryCd(dto.getIirExportCountryCd());
        vo.setIirOriginCountryCd(dto.getIirOriginCountryCd());
        vo.setIirPhytoCertNo(dto.getIirPhytoCertNo());
        vo.setIirPhytoCertIssueDt(dto.getIirPhytoCertIssueDt());

        vo.setIirTransportNm(dto.getIirTransportNm());
        vo.setIirLoadPortCd(dto.getIirLoadPortCd());
        vo.setIirShipDt(dto.getIirShipDt());
        vo.setIirArrvPortCd(dto.getIirArrvPortCd());
        vo.setIirArrvDt(dto.getIirArrvDt());

        vo.setIirMainGoodsNm(dto.getIirMainGoodsNm());
        vo.setIirMainHsCd(dto.getIirMainHsCd());
        vo.setIirTotalWeight(dto.getIirTotalWeight());
        vo.setIirTotalPkgCnt(dto.getIirTotalPkgCnt());
        vo.setIirPkgUnitCd(dto.getIirPkgUnitCd());

        /*
         * 포장재질은 PDF에 명확히 없는 경우가 많다.
         * 예: 400 BAGS는 정확한 재질이라기보다 포장 형태/단위에 가깝다.
         * 그래도 화면 자동입력을 위해 포장재질이 비어 있으면 포장단위 값을 대신 넣는다.
         */
        if (StringUtils.hasText(dto.getIirPkgMaterial())) {
            vo.setIirPkgMaterial(dto.getIirPkgMaterial());
        } else if (StringUtils.hasText(dto.getIirPkgUnitCd())) {
            vo.setIirPkgMaterial(dto.getIirPkgUnitCd());
        }
        vo.setIirWoodPkgYn(dto.getIirWoodPkgYn());
        vo.setIirWoodPkgMarkNo(dto.getIirWoodPkgMarkNo());

        if (dto.getItemList() != null && !dto.getItemList().isEmpty()) {
            List<QuarantineItemVO> itemList = dto.getItemList().stream()
                    .map(itemDto -> {
                        QuarantineItemVO itemVO = new QuarantineItemVO();

                        itemVO.setHsCd(itemDto.getHsCd());
                        itemVO.setGoodsNm(itemDto.getGoodsNm());
                        itemVO.setScientificNm(itemDto.getScientificNm());
                        /*
                         * 용도는 PDF에서 별도 항목으로 안 나오는 경우가 많다.
                         * 예: FOOD GRADE 문구가 있으면 식용/식품 용도로 판단해 FOOD로 세팅한다.
                         */
                        if (StringUtils.hasText(itemDto.getUseCd())) {
                            String useCd = itemDto.getUseCd().trim().toUpperCase();

                            if (useCd.contains("FOOD")) {
                                itemVO.setUseCd("FOOD");
                            } else {
                                itemVO.setUseCd(useCd);
                            }
                        } else {
                            itemVO.setUseCd("FOOD");
                        }                        itemVO.setQty(itemDto.getQty());
                        itemVO.setQtyUnitCd(itemDto.getQtyUnitCd());
                        itemVO.setNetWeight(itemDto.getNetWeight());
                        itemVO.setPkgCnt(itemDto.getPkgCnt());
                        itemVO.setOriginCountryCd(itemDto.getOriginCountryCd());

                        return itemVO;
                    })
                    .toList();

            vo.setItemList(itemList);
        }

        return vo;
    }
    
    @Override
    public Long retriveIssuedCertFileNo(String iirReqNo, String brokerId) {

        QuarantineVO param = new QuarantineVO();
        param.setIirReqNo(iirReqNo);
        param.setLoginBrokerId(brokerId);

        return quarantineMapper.selectIssuedCertFileNo(param);
    }

    /*
     * 관세사 보완완료 전송
     *
     * 처리 흐름:
     * 1. 보완요청번호, 검역요청번호, 보완내용 필수 검증
     * 2. SUPP_RQST 상태를 REQ → SUB로 변경
     * 3. 검역결과 후속조치 상태를 보완제출완료로 변경
     *
     * 주의:
     * - 관세사는 SUPP_RQST를 새로 만들지 않는다.
     * - 검역기관이 만든 보완요청을 제출완료 상태로 UPDATE한다.
     */
    @Override
    @Transactional
    public void modifySupplementSubmit(QuarantineVO quarantineVO) {

        if (!StringUtils.hasText(quarantineVO.getSrNo())) {
            throw new IllegalArgumentException("보완요청번호가 없습니다.");
        }

        if (!StringUtils.hasText(quarantineVO.getIirReqNo())) {
            throw new IllegalArgumentException("검역요청번호가 없습니다.");
        }

        if (!StringUtils.hasText(quarantineVO.getSrSubmitCn())) {
            throw new IllegalArgumentException("보완내용을 입력하세요.");
        }

        /*
         * SUPP_RQST 보완제출 처리
         *
         * Mapper에서 아래 조건을 모두 확인한다.
         * - SR_NO 일치
         * - SR_REF_NO = 검역요청번호
         * - RECEIVER_ID = 로그인한 관세사 ID
         * - RECEIVER_TY_CD = BROKER
         * - SR_STATUS_CD = REQ
         */
        int updateCnt = quarantineMapper.updateSupplementSubmit(quarantineVO);

        if (updateCnt == 0) {
            throw new IllegalStateException("보완요청 상태가 아니거나 처리 권한이 없습니다.");
        }

        /*
         * 검역결과 후속조치 수정
         * 현장공무원이 보완자료가 제출된 상태임을 확인할 수 있도록 변경한다.
         */
        int resultUpdateCnt = quarantineMapper.updateResultAfterSupplementSubmit(quarantineVO);

        if (resultUpdateCnt == 0) {
            throw new IllegalStateException("검역결과 후속조치 수정 대상이 없습니다.");
        }
    }
    
    /*
     * 수입의뢰 기준 검역장소 선택 목록 조회
     *
     * 처리 흐름:
     * 1. 수입의뢰번호와 로그인 관세사 ID를 파라미터로 만든다.
     * 2. Mapper에서 해당 수입의뢰의 IR_GG_NO 기준으로 창고 위치 목록을 조회한다.
     * 3. JSP에서는 이 목록을 select option으로 출력한다.
     */
    @Override
    public List<QuarantineVO> selectWarehouseLocationListByImportRequest(String irNo, String brokerId) {

        QuarantineVO param = new QuarantineVO();
        param.setIrNo(irNo);
        param.setLoginBrokerId(brokerId);

        return quarantineMapper.selectWarehouseLocationListByImportRequest(param);
    }

    /*
     * 현장공무원 선택 목록 조회
     *
     * OFFICER.OFFICER_TY_CD = 'FIELD_OFFICER' 인 공무원 목록을 조회한다.
     * 조회 결과는 수입검역신청 JSP의 fieldOfficerList select box에서 사용된다.
     */
	@Override
	public List<QuarantineVO> selectFieldOfficerList() {
		return quarantineMapper.selectFieldOfficerList();
	}
}