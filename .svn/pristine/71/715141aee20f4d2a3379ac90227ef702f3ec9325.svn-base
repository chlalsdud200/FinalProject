function buildBondedCargoRowHtml(line = {}) {
  const value = (key) => line[key] || '';
  return `
    <tr class="bonded-cargo-line bg-white">
      <td class="text-center align-middle"><input type="checkbox" class="bonded-cargo-check h-4 w-4 border-slate-300" /></td>
      <td><input class="field-input min-w-[150px]" type="text" value="${value('shippingMark')}" placeholder="Shipping Mark" /></td>
      <td><textarea class="field-textarea h-16 min-w-[210px]" placeholder="품목 입력">${value('goodsDesc')}</textarea></td>
      <td><input class="field-input min-w-[90px]" type="number" value="${value('qty')}" placeholder="수량" /></td>
      <td>
        <select class="field-select min-w-[120px]">
          <option ${value('pkgType') === 'BOX' ? 'selected' : ''}>BOX</option>
          <option ${value('pkgType') === 'PALLET' ? 'selected' : ''}>PALLET</option>
          <option ${value('pkgType') === 'CARTON' ? 'selected' : ''}>CARTON</option>
          <option ${value('pkgType') === 'BAG' ? 'selected' : ''}>BAG</option>
        </select>
      </td>
      <td><input class="field-input min-w-[90px]" type="number" value="${value('pkgQty')}" placeholder="포장개수" /></td>
      <td><input class="field-input min-w-[100px]" type="text" value="${value('weight')}" placeholder="총중량" /></td>
      <td><input class="field-input min-w-[100px]" type="text" value="${value('netWeight')}" placeholder="순중량" /></td>
      <td><input class="field-input min-w-[100px]" type="text" value="${value('volume')}" placeholder="부피" /></td>
      <td><input class="field-input min-w-[100px]" type="text" value="${value('unitPrice')}" placeholder="단가" /></td>
      <td><input class="field-input min-w-[110px]" type="text" value="${value('amount')}" placeholder="총액" /></td>
      <td>
        <select class="field-select min-w-[90px]">
          <option ${value('currency') === 'USD' ? 'selected' : ''}>USD</option>
          <option ${value('currency') === 'KRW' ? 'selected' : ''}>KRW</option>
          <option ${value('currency') === 'JPY' ? 'selected' : ''}>JPY</option>
        </select>
      </td>
    </tr>
  `;
}

function buildExportInboundCargoRowHtml(line = {}) {
  const value = (key) => line[key] || '';
  return `
    <tr class="bonded-cargo-line bg-white">
      <td class="text-center align-middle"><input type="checkbox" class="bonded-cargo-check h-4 w-4 border-slate-300" /></td>
      <td><textarea class="field-textarea h-16 min-w-[220px]" placeholder="품목">${value('goodsDesc')}</textarea></td>
      <td><input class="field-input min-w-[90px]" type="number" value="${value('qty')}" placeholder="수량" /></td>
      <td><input class="field-input min-w-[100px]" type="text" value="${value('unitPrice')}" placeholder="단가" /></td>
      <td><input class="field-input min-w-[120px]" type="text" value="${value('amount')}" placeholder="총금액" /></td>
      <td><input class="field-input min-w-[100px]" type="text" value="${value('weight')}" placeholder="중량" /></td>
      <td><input class="field-input min-w-[120px]" type="text" value="${value('origin')}" placeholder="원산지" /></td>
    </tr>
  `;
}

function buildBondedCargoWorkPanel(config) {
  window.bondedPanelRows = window.bondedPanelRows || {};
  window.bondedPanelRows[config.itemId] = config.rows || [];

  const rows = config.rows || [];
  const selected = rows[0] || {};
  const useSimpleCargoColumns = true;
  const statusChip = (status = '') => {
    const dangerClass = String(status).includes('반려') ? ' bg-red-100 text-red-700 border border-red-200' : '';
    return `<span class="info-chip${dangerClass}">${status || '-'}</span>`;
  };
  const optionHtml = (options = [], selectedValue = '') => options.map(opt => `<option ${opt === selectedValue ? 'selected' : ''}>${opt}</option>`).join('');
  const fieldHtml = (field) => {
    const value = selected[field.key] || field.value || '';
    const readonlyClass = field.readonly ? 'bg-slate-50 text-slate-500 cursor-not-allowed' : '';

    if (field.type === 'select') {
      return `
        <div class="${field.span || ''}">
          <label class="field-label">${field.label}</label>
          <select
            class="field-select ${readonlyClass}"
            data-bonded-field="${field.key}"
            ${field.readonly ? 'disabled' : ''}
          >
            ${optionHtml(field.options || [], value)}
          </select>
        </div>
      `;
    }

    if (field.type === 'textarea') {
      return `
        <div class="${field.span || 'md:col-span-3'}">
          <label class="field-label">${field.label}</label>
          <textarea
            class="field-textarea h-20 ${readonlyClass}"
            data-bonded-field="${field.key}"
            ${field.readonly ? 'readonly' : ''}
            placeholder="${field.placeholder || ''}"
          >${value}</textarea>
        </div>
      `;
    }

    return `
      <div class="${field.span || ''}">
        <label class="field-label">${field.label}</label>
        <input
          class="field-input ${readonlyClass}"
          data-bonded-field="${field.key}"
          type="${field.inputType || 'text'}"
          value="${value}"
          ${field.readonly ? 'readonly' : ''}
          placeholder="${field.placeholder || ''}"
        />
      </div>
    `;
  };

  if (config.itemId === 'TACS-FW-009B') {
    const inboundListRows = rows.length ? rows.map((row, idx) => `
                  <tr class="bonded-list-row ${idx === 0 ? 'bg-blue-50' : ''}" data-bonded-list-row="${idx}" data-request-no="${row.requestNo || ''}">
                    <td class="font-bold">${row.inboundRequestNo || row.requestNo || ''}</td>
                    <td>${row.owner || ''}</td>
                    <td>${row.inboundCargoNo || row.cargoMgmtNo || row.listParty || ''}</td>
                    <td>${row.invoiceNo || '-'}</td>
                    <td>${row.masterBlNo || '-'}</td>
                    <td>${row.listAt || row.inboundPlanDt || ''}</td>
                    <td class="bonded-list-status-cell">${statusChip(row.listStatus || row.requestStatus || '')}</td>
                    <td class="text-center"><button type="button" class="bonded-row-select px-3 py-1 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim" data-row-index="${idx}" data-request-no="${row.requestNo || ''}">등록</button></td>
                  </tr>
    `).join('') : '<tr><td colspan="8" class="text-center text-slate-500 py-6">조회된 입고관리 대상이 없습니다.</td></tr>';
    const registeredRows = rows.filter(row => String(row.listStatus || row.requestStatus || '') === String(config.completeStatus || '입고완료'));
    const registeredHtml = registeredRows.length ? registeredRows.map(row => `
                  <tr class="bonded-list-row" data-bonded-list-row="${rows.indexOf(row)}" data-request-no="${row.requestNo || ''}">
                    <td class="font-bold">${row.inboundRequestNo || row.requestNo || '-'}</td>
                    <td>${row.owner || ''}</td>
                    <td>${row.inboundCargoNo || row.cargoMgmtNo || row.listParty || '-'}</td>
                    <td>${row.targetWarehouse || '-'}</td>
                    <td>${row.inboundPlanDt || row.listAt || ''}</td>
                    <td class="bonded-list-status-cell">${statusChip(row.requestStatus || row.listStatus || '')}</td>
                    <td class="text-center"><button type="button" class="bonded-row-select px-3 py-1 border border-slate-300 bg-white text-slate-700 text-xs font-bold" data-row-index="${rows.indexOf(row)}" data-request-no="${row.requestNo || ''}">조회</button></td>
                  </tr>
    `).join('') : '<tr><td colspan="7" class="text-center text-slate-500 py-6">입고관리 등록 내역이 없습니다.</td></tr>';

    return `
    <div class="space-y-4 bonded-work-panel" data-item-id="${config.itemId}" data-complete-status="${config.completeStatus || '전송완료'}" data-status-field="${config.statusField || 'requestStatus'}" data-submit-message="${config.submitMessage || '창고관리자에게 요청 정보가 전송되었습니다.'}">
      <div class="section-card border border-slate-300 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
          <div>
            <h4 class="text-sm font-bold text-slate-900">${config.listTitle}</h4>
            <p class="mt-1 text-xs text-slate-600">${config.listDesc}</p>
          </div>
          <button type="button" class="bonded-search-btn px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">조회</button>
        </div>
        <div class="p-5 space-y-3">
          <h5 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">적하목록 제출완료 목록</h5>
          <div class="overflow-x-auto border border-slate-200">
            <table class="w-full tbl min-w-[900px] text-xs">
              <thead>
                <tr>
                  <th>적하목록번호</th>
                  <th>화주명</th>
                  <th>화물관리번호</th>
                  <th>송장번호</th>
                  <th>MASTER B/L</th>
                  <th>제출일</th>
                  <th>상태</th>
                  <th class="text-center" style="width:90px;">처리</th>
                </tr>
              </thead>
              <tbody class="text-sm text-slate-700">${inboundListRows}</tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="section-card border border-slate-300 overflow-hidden bonded-form-card hidden">
        <div class="bg-slate-900 px-5 py-4 text-white flex items-center justify-between gap-3">
          <div>
            <h4 class="text-sm font-black">${config.formTitle}</h4>
            <p class="mt-1 text-xs text-slate-200">${config.formDesc}</p>
          </div>
          <button type="button" class="bonded-form-back px-3 py-1 border border-white/70 bg-white text-slate-900 text-xs font-bold">목록으로</button>
        </div>
        <div class="p-5 space-y-5">
          <div class="text-xs font-bold text-slate-600 bonded-selected-info">선택된 의뢰 : ${selected.requestNo || '-'}</div>
          <div class="bonded-reject-box ${String(selected.warehouseReplyStatus || selected.listStatus || '').includes('반려') ? '' : 'hidden'} border border-red-200 bg-red-50 px-4 py-3">
            <div class="text-xs font-black text-red-700">창고관리자 반려</div>
            <div class="mt-2 text-xs text-red-700 leading-5 bonded-reject-text">${selected.rejectReason || '반려 사유가 등록되어 있지 않습니다.'}</div>
          </div>

          <div>
            <h5 class="text-sm font-black text-slate-900 mb-3 border-l-4 border-slate-800 pl-3">1. ${config.infoTitle}</h5>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
              ${config.fields.map(fieldHtml).join('')}
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between gap-2 mb-3">
              <h5 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">2. 품목사항</h5>
              <div class="flex gap-2">
                <button type="button" class="bonded-add-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">+ 행추가</button>
                <button type="button" class="bonded-check-all-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">전체선택</button>
                <button type="button" class="bonded-delete-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">선택삭제</button>
              </div>
            </div>
            <div class="overflow-x-auto border border-slate-200">
              <table class="w-full tbl min-w-[820px]">
                <thead>
                  <tr>
                    <th class="text-center" style="width:48px;">선택</th>
                    <th>품목</th>
                    <th>수량</th>
                    <th>단가</th>
                    <th>총금액</th>
                    <th>중량</th>
                    <th>원산지</th>
                  </tr>
                </thead>
                <tbody class="bonded-cargo-tbody text-sm text-slate-700">
                  ${(selected.cargo || [{}]).map(line => buildExportInboundCargoRowHtml(line)).join('')}
                </tbody>
              </table>
            </div>
          </div>

          <div>
            <h5 class="text-sm font-black text-slate-900 mb-3 border-l-4 border-slate-800 pl-3">3. 요청사항</h5>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div>
                <label class="field-label">요청사항</label>
                <textarea class="field-textarea h-24" data-bonded-field="requestNote" placeholder="창고관리자에게 전달할 요청사항 입력">${selected.requestNote || ''}</textarea>
              </div>
              <div>
                <label class="field-label">창고 반려사유</label>
                <textarea class="field-textarea h-24 bg-slate-50" data-bonded-field="rejectReason" readonly placeholder="반려 건 선택 시 창고관리자 회신 사유 자동 표시">${selected.rejectReason || ''}</textarea>
              </div>
            </div>
          </div>
        </div>
        <div class="section-card-action-footer flex justify-end gap-2 px-5 py-4 border-t border-slate-200">
          <button type="button" class="bonded-submit px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">${config.submitLabel || '전송'}</button>
        </div>
      </div>

      <div class="section-card border border-slate-300 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">
          <h4 class="text-sm font-bold text-slate-900">입고관리 등록 목록</h4>
          <p class="mt-1 text-xs text-slate-600">보세구역 입고관리 등록 또는 창고 회신이 진행된 의뢰 목록입니다.</p>
        </div>
        <div class="p-5 overflow-x-auto">
          <table class="w-full tbl min-w-[900px] text-xs">
            <thead><tr><th>입고의뢰번호</th><th>화주명</th><th>화물관리번호</th><th>전달대상</th><th>입고일시</th><th>상태</th><th class="text-center" style="width:90px;">처리</th></tr></thead>
            <tbody class="bonded-registered-tbody text-sm text-slate-700">${registeredHtml}</tbody>
          </table>
        </div>
      </div>
    </div>
  `;
  }

  if (config.itemId === 'TACS-FW-009') {
    const releaseListRows = rows.length ? rows.map((row, idx) => `
                  <tr class="bonded-list-row ${idx === 0 ? 'bg-blue-50' : ''}" data-bonded-list-row="${idx}" data-request-no="${row.requestNo || ''}">
                    <td class="font-bold">${row.requestNo || ''}</td>
                    <td>${row.owner || ''}</td>
                    <td>${row.listParty || ''}</td>
                    <td>${row.listAt || ''}</td>
                    <td class="bonded-list-status-cell">${statusChip(row.listStatus || '')}</td>
                    <td class="text-center"><button type="button" class="bonded-row-select px-3 py-1 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim" data-row-index="${idx}" data-request-no="${row.requestNo || ''}">등록</button></td>
                  </tr>
    `).join('') : '<tr><td colspan="6" class="text-center text-slate-500 py-6">조회된 반출요청 대상이 없습니다.</td></tr>';
    const registeredRows = rows.filter(row => String(row.listStatus || row.releaseStatus || '') === String(config.completeStatus || '반출완료'));
    const registeredHtml = registeredRows.length ? registeredRows.map(row => `
                  <tr class="bonded-list-row" data-bonded-list-row="${rows.indexOf(row)}" data-request-no="${row.requestNo || ''}">
                    <td class="font-bold">${row.releaseRequestNo || '-'}</td>
                    <td>${row.owner || ''}</td>
                    <td>${row.cargoMgmtNo || '-'}</td>
                    <td>${row.targetWarehouse || row.listParty || ''}</td>
                    <td>${row.releasePlanDt || row.listAt || ''}</td>
                    <td class="bonded-list-status-cell">${statusChip(row.releaseStatus || row.listStatus || '')}</td>
                    <td class="text-center"><button type="button" class="bonded-row-select px-3 py-1 border border-slate-300 bg-white text-slate-700 text-xs font-bold" data-row-index="${rows.indexOf(row)}" data-request-no="${row.requestNo || ''}">조회</button></td>
                  </tr>
    `).join('') : '<tr><td colspan="7" class="text-center text-slate-500 py-6">반출요청 등록 내역이 없습니다.</td></tr>';

    return `
    <div class="space-y-4 bonded-work-panel" data-item-id="${config.itemId}" data-complete-status="${config.completeStatus || '전송완료'}" data-status-field="${config.statusField || 'requestStatus'}" data-submit-message="${config.submitMessage || '창고관리자에게 요청 정보가 전송되었습니다.'}">
      <div class="section-card border border-slate-300 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
          <div>
            <h4 class="text-sm font-bold text-slate-900">${config.listTitle}</h4>
            <p class="mt-1 text-xs text-slate-600">${config.listDesc}</p>
          </div>
          <button type="button" class="bonded-search-btn px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">조회</button>
        </div>
        <div class="p-5 space-y-3">
          <h5 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">반출요청 대상 목록</h5>
          <div class="overflow-x-auto border border-slate-200">
            <table class="w-full tbl min-w-[900px] text-xs">
              <thead>
                <tr>
                  <th>의뢰번호</th>
                  <th>화주명</th>
                  <th>${config.partyTitle || '상대방'}</th>
                  <th>${config.dateTitle || '일시'}</th>
                  <th>상태</th>
                  <th class="text-center" style="width:90px;">처리</th>
                </tr>
              </thead>
              <tbody class="text-sm text-slate-700">${releaseListRows}</tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="section-card border border-slate-300 overflow-hidden bonded-form-card hidden">
        <div class="bg-slate-900 px-5 py-4 text-white flex items-center justify-between gap-3">
          <div>
            <h4 class="text-sm font-black">${config.formTitle}</h4>
            <p class="mt-1 text-xs text-slate-200">${config.formDesc}</p>
          </div>
          <button type="button" class="bonded-form-back px-3 py-1 border border-white/70 bg-white text-slate-900 text-xs font-bold">목록으로</button>
        </div>
        <div class="p-5 space-y-5">
          <div class="text-xs font-bold text-slate-600 bonded-selected-info">선택된 의뢰 : ${selected.requestNo || '-'}</div>
          <div class="bonded-reject-box ${String(selected.warehouseReplyStatus || selected.listStatus || '').includes('반려') ? '' : 'hidden'} border border-red-200 bg-red-50 px-4 py-3">
            <div class="text-xs font-black text-red-700">창고관리자 반려</div>
            <div class="mt-2 text-xs text-red-700 leading-5 bonded-reject-text">${selected.rejectReason || '반려 사유가 등록되어 있지 않습니다.'}</div>
          </div>

          <div>
            <h5 class="text-sm font-black text-slate-900 mb-3 border-l-4 border-slate-800 pl-3">1. ${config.infoTitle}</h5>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
              ${config.fields.map(fieldHtml).join('')}
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between gap-2 mb-3">
              <h5 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">2. 품목사항</h5>
              <div class="flex gap-2">
                <button type="button" class="bonded-add-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">+ 행추가</button>
                <button type="button" class="bonded-check-all-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">전체선택</button>
                <button type="button" class="bonded-delete-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">선택삭제</button>
              </div>
            </div>
            <div class="overflow-x-auto border border-slate-200">
              <table class="w-full tbl min-w-[820px]">
                <thead>
                  <tr>
                    <th class="text-center" style="width:48px;">선택</th>
                    <th>품목</th>
                    <th>수량</th>
                    <th>단가</th>
                    <th>총금액</th>
                    <th>중량</th>
                    <th>원산지</th>
                  </tr>
                </thead>
                <tbody class="bonded-cargo-tbody text-sm text-slate-700">
                  ${(selected.cargo || [{}]).map(line => buildExportInboundCargoRowHtml(line)).join('')}
                </tbody>
              </table>
            </div>
          </div>

          <div>
            <h5 class="text-sm font-black text-slate-900 mb-3 border-l-4 border-slate-800 pl-3">3. 요청사항</h5>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div>
                <label class="field-label">요청사항</label>
                <textarea class="field-textarea h-24" data-bonded-field="requestNote" placeholder="창고관리자에게 전달할 요청사항 입력">${selected.requestNote || ''}</textarea>
              </div>
              <div>
                <label class="field-label">창고 반려사유</label>
                <textarea class="field-textarea h-24 bg-slate-50" data-bonded-field="rejectReason" readonly placeholder="반려 건 선택 시 창고관리자 회신 사유 자동 표시">${selected.rejectReason || ''}</textarea>
              </div>
            </div>
          </div>
        </div>
        <div class="section-card-action-footer flex justify-end gap-2 px-5 py-4 border-t border-slate-200">
          <button type="button" class="bonded-submit px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">${config.submitLabel || '전송'}</button>
        </div>
      </div>

      <div class="section-card border border-slate-300 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">
          <h4 class="text-sm font-bold text-slate-900">반출요청 등록 목록</h4>
          <p class="mt-1 text-xs text-slate-600">창고관리자에게 반출요청이 전송된 내역입니다.</p>
        </div>
        <div class="p-5 overflow-x-auto">
          <table class="w-full tbl min-w-[900px] text-xs">
            <thead><tr><th>반출요청번호</th><th>화주명</th><th>화물관리번호</th><th>전달대상</th><th>반출일시</th><th>상태</th><th class="text-center" style="width:90px;">처리</th></tr></thead>
            <tbody class="bonded-registered-tbody text-sm text-slate-700">${registeredHtml}</tbody>
          </table>
        </div>
      </div>
    </div>
  `;
  }

  return `
    <div class="grid grid-cols-1 2xl:grid-cols-[0.95fr_1.05fr] gap-4 bonded-work-panel" data-item-id="${config.itemId}" data-complete-status="${config.completeStatus || '전송완료'}" data-status-field="${config.statusField || 'requestStatus'}" data-submit-message="${config.submitMessage || '창고관리자에게 요청 정보가 전송되었습니다.'}">
      <div class="section-card border border-slate-300 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">
          <h4 class="text-sm font-bold text-slate-900">${config.listTitle}</h4>
          <p class="mt-1 text-xs text-slate-600">${config.listDesc}</p>
        </div>
        <div class="p-5 space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1fr_1fr_auto] gap-3">
            <div><label class="field-label">의뢰번호</label><input class="field-input bonded-search-request" type="text" placeholder="의뢰번호 입력" /></div>
            <div><label class="field-label">화주명</label><input class="field-input bonded-search-owner" type="text" placeholder="화주명 입력" /></div>
            <div><label class="field-label">${config.partyTitle || '상대방'}</label><input class="field-input bonded-search-party" type="text" placeholder="${config.partyTitle || '상대방'} 입력" /></div>
            <div><label class="field-label">${config.dateTitle || '일자'}</label><input class="field-input bonded-search-date" type="date" /></div>
            <div class="flex items-end"><button type="button" class="bonded-search-btn w-full md:w-auto px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">조회</button></div>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full tbl">
              <thead>
                <tr>
                  <th>의뢰번호</th>
                  <th>화주명</th>
                  <th>${config.partyTitle || '상대방'}</th>
                  <th>${config.dateTitle || '일시'}</th>
                  <th>상태</th>
                  <th class="text-center" style="width:90px;">처리</th>
                </tr>
              </thead>
              <tbody class="text-sm text-slate-700">
                ${rows.map((row, idx) => `
                  <tr class="bonded-list-row ${idx === 0 ? 'bg-blue-50' : ''}" data-bonded-list-row="${idx}" data-request-no="${row.requestNo || ''}">
                    <td class="font-bold">${row.requestNo || ''}</td>
                    <td>${row.owner || ''}</td>
                    <td>${row.listParty || ''}</td>
                    <td>${row.listAt || ''}</td>
                    <td class="bonded-list-status-cell">${statusChip(row.listStatus || '')}</td>
                    <td class="text-center"><button type="button" class="bonded-row-select px-3 py-1 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim" data-row-index="${idx}" data-request-no="${row.requestNo || ''}">선택</button></td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="section-card border border-slate-300 overflow-hidden">
        <div class="bg-slate-900 px-5 py-4 text-white flex items-center justify-between gap-3">
          <div>
            <h4 class="text-sm font-black">${config.formTitle}</h4>
            <p class="mt-1 text-xs text-slate-200">${config.formDesc}</p>
          </div>
          <button type="button" class="bonded-form-back px-3 py-1 border border-white/70 bg-white text-slate-900 text-xs font-bold">목록으로</button>
        </div>
        <div class="p-5 space-y-5">
          <div class="text-xs font-bold text-slate-600 bonded-selected-info">선택된 의뢰 : ${selected.requestNo || '-'}</div>
          <div class="bonded-reject-box ${String(selected.warehouseReplyStatus || selected.listStatus || '').includes('반려') ? '' : 'hidden'} border border-red-200 bg-red-50 px-4 py-3">
            <div class="text-xs font-black text-red-700">창고관리자 반려</div>
            <div class="mt-2 text-xs text-red-700 leading-5 bonded-reject-text">${selected.rejectReason || '반려 사유가 등록되어 있지 않습니다.'}</div>
          </div>

          <div>
            <h5 class="text-sm font-black text-slate-900 mb-3 border-l-4 border-slate-800 pl-3">1. ${config.infoTitle}</h5>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
              ${config.fields.map(fieldHtml).join('')}
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between gap-2 mb-3">
              <h5 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">2. 품목사항</h5>
              <div class="flex gap-2">
                <button type="button" class="bonded-add-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">+ 행추가</button>
                <button type="button" class="bonded-check-all-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">전체선택</button>
                <button type="button" class="bonded-delete-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">선택삭제</button>
              </div>
            </div>
            <div class="overflow-x-auto border border-slate-200">
              <table class="w-full tbl min-w-[820px]">
                <thead>
                  <tr>
                    <th class="text-center" style="width:48px;">선택</th>
                    <th>품목</th>
                    <th>수량</th>
                    <th>단가</th>
                    <th>총금액</th>
                    <th>중량</th>
                    <th>원산지</th>
                  </tr>
                </thead>
                <tbody class="bonded-cargo-tbody text-sm text-slate-700">
                  ${(selected.cargo || [{}]).map(line => buildExportInboundCargoRowHtml(line)).join('')}
                </tbody>
              </table>
            </div>
          </div>

          <div>
            <h5 class="text-sm font-black text-slate-900 mb-3 border-l-4 border-slate-800 pl-3">3. 요청사항</h5>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div>
                <label class="field-label">요청사항</label>
                <textarea class="field-textarea h-24" data-bonded-field="requestNote" placeholder="창고관리자에게 전달할 요청사항 입력">${selected.requestNote || ''}</textarea>
              </div>
              <div>
                <label class="field-label">창고 반려사유</label>
                <textarea class="field-textarea h-24 bg-slate-50" data-bonded-field="rejectReason" readonly placeholder="반려 건 선택 시 창고관리자 회신 사유 자동 표시">${selected.rejectReason || ''}</textarea>
              </div>
            </div>
          </div>
        </div>
        <div class="section-card-action-footer flex justify-end gap-2 px-5 py-4 border-t border-slate-200">
          <button type="button" class="bonded-submit px-4 py-2 bg-primary text-on-primary text-xs font-bold hover:bg-primary-dim">${config.submitLabel || '전송'}</button>
        </div>
      </div>
    </div>
  `;
}

function getExportInboundManageRows() {
  if (Array.isArray(window.TRANSPORT_EXPORT_INBOUND_REQUESTS)) {
    return window.TRANSPORT_EXPORT_INBOUND_REQUESTS.map(row => ({
      ...row,
      cargo: row.cargo && row.cargo.length ? row.cargo : []
    }));
  }

  return [];
}

function getExportReleaseRequestRows() {
  const source = window.TRANSPORT_EXPORT_RELEASE_REQUESTS
      || window.TRANSPORT_EXPORT_RELEASE_LIST
      || window.TRANSPORT_EXPORT_RELEASE_ROWS
      || [];
  return Array.isArray(source) ? source.map(row => ({
    ...row,
    cargo: row.cargo && row.cargo.length ? row.cargo : []
  })) : [];
}

function getImportUnloadingRows() {
  const source = window.TRANSPORT_IMPORT_UNLOADING_ROWS
      || window.TRANSPORT_IMPORT_INBOUND_LIST
      || window.TRANSPORT_IMPORT_WAREHOUSE_IN_LIST
      || [];
  return Array.isArray(source) ? source.map(row => ({
    ...row,
    cargo: row.cargo && row.cargo.length ? row.cargo : []
  })) : [];
}

function getImportReleaseRequestRows() {
  const source = window.TRANSPORT_IMPORT_RELEASE_REQUESTS
      || window.TRANSPORT_IMPORT_RELEASE_LIST
      || window.IMPORT_RELEASE_LIST
      || [];
  return Array.isArray(source) ? source.map(row => ({
    ...row,
    cargo: row.cargo && row.cargo.length ? row.cargo : []
  })) : [];
}

function buildExportInboundManagePanel() {
  return buildBondedCargoWorkPanel({
    itemId: 'TACS-FW-009B',
    listTitle: '보세구역 입고관리',
    listDesc: '수락 완료된 수출 운송의뢰를 선택하면 오른쪽에 입고요청 정보와 란사항 입력창이 함께 표시됩니다.',
    partyTitle: '거래자',
    dateTitle: '입고일시',
    formTitle: '수출 보세구역 입고관리',
    formDesc: '수락 완료된 수출 운송의뢰 기준으로 창고관리자에게 보세구역 입고요청을 전송합니다.',
    infoTitle: '입고요청 정보',
    completeStatus: '입고완료',
    statusField: 'requestStatus',
    submitLabel: '전송',
    submitMessage: '수출 보세구역 입고요청 정보가 창고관리자에게 전송되었습니다.',
    fields: [
      {key:'inboundRequestNo', label:'입고요청번호', readonly:true},
      {key:'warehouseAreaNo', label:'창고구역번호', readonly:true},

      {key:'inboundPlanDt', label:'입고일시', inputType:'datetime-local', readonly:true},
      {key:'targetWarehouse', label:'전달대상', type:'select', options:['222','인천항 보세창고 관리자','부산항 보세창고 관리자','평택항 보세창고 관리자'], readonly:false},
      {key:'requestStatus', label:'요청상태', readonly:true},
      {key:'warehouseReplyStatus', label:'창고 회신상태', readonly:true},

      {key:'inboundCargoNo', label:'화물관리번호', readonly:true},
      {key:'incoterms', label:'인도조건', type:'select', options:['FOB','CIF','CFR','EXW'], readonly:true}
    ],
    rows: getExportInboundManageRows()
  });
}



function bindBondedWorkPanelActions(groupKey, itemId) {
  const root = detailBody.querySelector(`.bonded-work-panel[data-item-id="${itemId}"]`);
  if (!root) return;

  const rows = (window.bondedPanelRows && window.bondedPanelRows[itemId]) || [];
  const useSimpleCargoColumns = true;
  let selectedIndex = 0;

  const applySearchFilter = () => {
    const requestText = (root.querySelector('.bonded-search-request')?.value || '').trim().toLowerCase();
    const ownerText = (root.querySelector('.bonded-search-owner')?.value || '').trim().toLowerCase();
    const partyText = (root.querySelector('.bonded-search-party')?.value || '').trim().toLowerCase();
    const dateText = (root.querySelector('.bonded-search-date')?.value || '').trim().toLowerCase();

    root.querySelectorAll('.bonded-list-row').forEach((tr) => {
      const row = rows[Number(tr.getAttribute('data-bonded-list-row') || 0)] || {};
      const visible =
          (!requestText || String(row.requestNo || '').toLowerCase().includes(requestText)) &&
          (!ownerText || String(row.owner || '').toLowerCase().includes(ownerText)) &&
          (!partyText || String(row.listParty || '').toLowerCase().includes(partyText)) &&
          (!dateText || String(row.listAt || '').toLowerCase().includes(dateText));
      tr.classList.toggle('hidden', !visible);
    });
  };

  const fillPanel = (row) => {
    if (!row) return;
    root.querySelectorAll('[data-bonded-field]').forEach((el) => {
      const key = el.getAttribute('data-bonded-field');
      if (!key) return;
      const value = row[key] || '';
      if (el.tagName === 'SELECT' && value && !Array.from(el.options).some(option => option.value === value || option.textContent === value)) {
        el.insertAdjacentHTML('beforeend', `<option value="${value}">${value}</option>`);
      }
      el.value = value;
    });
    const tbody = root.querySelector('.bonded-cargo-tbody');
    if (tbody) {
      tbody.innerHTML = (row.cargo && row.cargo.length ? row.cargo : [{}])
          .map(line => buildExportInboundCargoRowHtml(line))
          .join('');
    }
    const selectedInfo = root.querySelector('.bonded-selected-info');
    if (selectedInfo) selectedInfo.textContent = `선택된 의뢰 : ${row.requestNo || '-'}`;
    const rejectBox = root.querySelector('.bonded-reject-box');
    const rejectText = root.querySelector('.bonded-reject-text');
    const isRejected = String(row.warehouseReplyStatus || row.listStatus || '').includes('반려');
    if (rejectBox) rejectBox.classList.toggle('hidden', !isRejected);
    if (rejectText) rejectText.textContent = row.rejectReason || '반려 사유가 등록되어 있지 않습니다.';
  };

  root.addEventListener('click', function (e) {
    const target = e.target instanceof Element ? e.target : e.target?.parentElement;
    const btn = target?.closest('.bonded-row-select');
    const tr = btn ? btn.closest('.bonded-list-row') : target?.closest('.bonded-list-row');
    if (!tr) return;

    selectedIndex = Number(tr.getAttribute('data-bonded-list-row') || btn?.dataset.rowIndex || 0);
    const selectedRow = rows[selectedIndex];

    if (!selectedRow) {
      alert('선택한 의뢰 데이터를 찾을 수 없습니다.');
      return;
    }

    root.querySelectorAll('.bonded-list-row').forEach(row => {
      row.classList.remove('bg-blue-50');
    });

    tr.classList.add('bg-blue-50');
    const formCard = root.querySelector('.bonded-form-card');
    if (formCard) formCard.classList.remove('hidden');
    fillPanel(selectedRow);
  });

  const formBackBtn = root.querySelector('.bonded-form-back');
  if (formBackBtn) {
    formBackBtn.addEventListener('click', function () {
      const formCard = root.querySelector('.bonded-form-card');
      if (formCard) formCard.classList.add('hidden');
      const firstCard = root.querySelector('.section-card');
      if (firstCard) firstCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  const searchBtn = root.querySelector('.bonded-search-btn');
  if (searchBtn) searchBtn.addEventListener('click', applySearchFilter);
  root.querySelectorAll('.bonded-search-request, .bonded-search-owner, .bonded-search-party, .bonded-search-date').forEach(input => {
    input.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') applySearchFilter();
    });
  });

  const addBtn = root.querySelector('.bonded-add-line');
  if (addBtn) {
    addBtn.addEventListener('click', () => {
      const tbody = root.querySelector('.bonded-cargo-tbody');
      if (tbody) tbody.insertAdjacentHTML('beforeend', buildExportInboundCargoRowHtml({}));
    });
  }

  const deleteBtn = root.querySelector('.bonded-delete-line');
  if (deleteBtn) {
    deleteBtn.addEventListener('click', () => {
      const checked = Array.from(root.querySelectorAll('.bonded-cargo-check:checked'));
      if (!checked.length) {
        alert('삭제할 란사항 행을 선택해주세요.');
        return;
      }
      checked.forEach(chk => {
        const tr = chk.closest('tr');
        if (tr) tr.remove();
      });
    });
  }

  const submitBtn = root.querySelector('.bonded-submit');
  if (submitBtn) {
    submitBtn.addEventListener('click', () => {
      const completeStatus = root.getAttribute('data-complete-status') || '전송완료';
      const statusField = root.getAttribute('data-status-field') || 'requestStatus';
      const statusEl = root.querySelector(`[data-bonded-field="${statusField}"]`);
      if (statusEl) statusEl.value = completeStatus;
      const replyStatusEl = root.querySelector('[data-bonded-field="warehouseReplyStatus"]');
      if (replyStatusEl) replyStatusEl.value = '회신대기';
      const rejectBox = root.querySelector('.bonded-reject-box');
      if (rejectBox) rejectBox.classList.add('hidden');
      const listStatusCell = root.querySelector(`[data-bonded-list-row="${selectedIndex}"] .bonded-list-status-cell`);
      if (listStatusCell) listStatusCell.innerHTML = `<span class="info-chip">${completeStatus}</span>`;
      if (rows[selectedIndex]) {
        rows[selectedIndex].listStatus = completeStatus;
        rows[selectedIndex][statusField] = completeStatus;
        rows[selectedIndex].releaseStatus = completeStatus;
      }
      const registeredTbody = root.querySelector('.bonded-registered-tbody');
      if (registeredTbody) {
        const completedRows = rows.filter(row => String(row.listStatus || row.releaseStatus || '') === completeStatus);
        if (itemId === 'TACS-FW-009B') {
          registeredTbody.innerHTML = completedRows.length ? completedRows.map(row => `
            <tr class="bonded-list-row" data-bonded-list-row="${rows.indexOf(row)}" data-request-no="${row.requestNo || ''}">
              <td class="font-bold">${row.inboundRequestNo || row.requestNo || '-'}</td>
              <td>${row.owner || ''}</td>
              <td>${row.inboundCargoNo || row.cargoMgmtNo || row.listParty || '-'}</td>
              <td>${row.targetWarehouse || '-'}</td>
              <td>${row.inboundPlanDt || row.listAt || ''}</td>
              <td class="bonded-list-status-cell"><span class="info-chip">${row.requestStatus || row.listStatus || ''}</span></td>
              <td class="text-center"><button type="button" class="bonded-row-select px-3 py-1 border border-slate-300 bg-white text-slate-700 text-xs font-bold" data-row-index="${rows.indexOf(row)}" data-request-no="${row.requestNo || ''}">조회</button></td>
            </tr>
          `).join('') : '<tr><td colspan="7" class="text-center text-slate-500 py-6">입고관리 등록 내역이 없습니다.</td></tr>';
        } else {
          registeredTbody.innerHTML = completedRows.length ? completedRows.map(row => `
            <tr class="bonded-list-row" data-bonded-list-row="${rows.indexOf(row)}" data-request-no="${row.requestNo || ''}">
              <td class="font-bold">${row.releaseRequestNo || '-'}</td>
              <td>${row.owner || ''}</td>
              <td>${row.cargoMgmtNo || '-'}</td>
              <td>${row.targetWarehouse || row.listParty || ''}</td>
              <td>${row.releasePlanDt || row.listAt || ''}</td>
              <td class="bonded-list-status-cell"><span class="info-chip">${row.releaseStatus || row.listStatus || ''}</span></td>
              <td class="text-center"><button type="button" class="bonded-row-select px-3 py-1 border border-slate-300 bg-white text-slate-700 text-xs font-bold" data-row-index="${rows.indexOf(row)}" data-request-no="${row.requestNo || ''}">조회</button></td>
            </tr>
          `).join('') : '<tr><td colspan="7" class="text-center text-slate-500 py-6">반출요청 등록 내역이 없습니다.</td></tr>';
        }
      }
      alert(root.getAttribute('data-submit-message') || '요청 정보가 전송되었습니다.');
    });
  }
}


function bindExportInboundManageActions(groupKey, itemId) {
  // 예전 export-inbound-row 방식은 더 이상 사용하지 않음.
  // TACS-FW-009B는 공통 보세구역 패널의 .bonded-row-select 이벤트에서 처리한다.
  if (itemId !== 'TACS-FW-009B') return;
  bindBondedWorkPanelActions(groupKey, itemId);
}




function buildUnloadingCoordinationPanel() {
  return buildBondedCargoWorkPanel({
    itemId: 'TACS-FW-025',
    listTitle: '보세구역 입고관리',
    listDesc: '입항 예정 화물을 선택하면 오른쪽에서 하선·보세구역 입고 요청 정보와 란사항을 한 화면에서 작성할 수 있습니다.',
    partyTitle: '거래자',
    dateTitle: '입고일시',
    formTitle: '수입 보세구역 입고관리',
    formDesc: '입항 적하목록과 B/L 정보를 기준으로 하선 일정, 보세구역 입고정보, 화물 란사항을 창고관리자에게 전달합니다.',
    infoTitle: '하선/입고요청 정보',
    completeStatus: '입고완료',
    statusField: 'requestStatus',
    submitLabel: '전달',
    submitMessage: '보세구역 입고관리 정보가 창고관리자에게 전달되었습니다.',
    fields: [
      {key:'inboundRequestNo', label:'입고요청번호', readonly:true},
      {key:'manifestNo', label:'의뢰번호', readonly:true},
      {key:'masterBlNo', label:'Master B/L 번호', readonly:true},
      {key:'warehouseManagerId', label:'창고관리자ID', readonly:true},
      {key:'warehouseNo', label:'창고번호', readonly:true},
      {key:'dischargePlanDt', label:'하선예정일시', inputType:'datetime-local', readonly:true},
      {key:'inboundPlanDt', label:'입고일시', inputType:'datetime-local', readonly:true},
      {key:'targetWarehouse', label:'전달대상', type:'select', options:['인천항 보세창고 관리자','부산항 보세창고 관리자','평택항 보세창고 관리자'], readonly:true},
      {key:'requestStatus', label:'요청상태', readonly:true},
      {key:'warehouseReplyStatus', label:'창고회신상태', readonly:true},
      {key:'vesselVoyage', label:'선박/항차', readonly:true},
      {key:'cargoMgmtNo', label:'화물관리번호', readonly:true},
      {key:'shipper', label:'거래자', readonly:true},
      {key:'consignee', label:'화주', readonly:true}
    ],
    rows: getImportUnloadingRows()
  });
}


function bindUnloadingCoordinationActions(groupKey, itemId) {
  if (itemId !== 'TACS-FW-025') return;

  const submitBtn = detailBody.querySelector('.unloading-submit-btn');
  const deliveryStatus = detailBody.querySelector('.unloading-delivery-status');
  const warehouseStatus = detailBody.querySelector('.unloading-warehouse-status');
  const warehouseManager = detailBody.querySelector('.unloading-warehouse-manager');

  if (submitBtn) {
    submitBtn.addEventListener('click', function() {
      if (!warehouseManager || !warehouseManager.value) {
        alert('전달대상 창고관리자를 선택해주세요.');
        return;
      }
      if (deliveryStatus) deliveryStatus.value = '입고완료';
      if (warehouseStatus) warehouseStatus.value = '확인대기';
      alert('보세구역 입고관리 정보가 창고관리자에게 발송되었습니다.');
    });
  }
}


function buildBondedReleaseRequestListPanel() {
  return buildBondedCargoWorkPanel({
    itemId: 'TACS-FW-009',
    listTitle: '보세구역 반출요청',
    listDesc: '수출 보세구역 입고 완료 화물을 선택하면 오른쪽에서 반출요청 정보와 란사항을 한 화면에서 작성할 수 있습니다.',
    partyTitle: '보세구역',
    dateTitle: '반출일시',
    formTitle: '수출 보세구역 반출요청',
    formDesc: '수출신고필증, 입고요청, 배차정보를 기준으로 창고관리자에게 보세구역 반출을 요청합니다.',
    infoTitle: '반출요청 정보',
    completeStatus: '반출완료',
    statusField: 'releaseStatus',
    submitLabel: '반출요청',
    submitMessage: '수출 보세구역 반출요청 정보가 창고관리자에게 전송되었습니다.',
    fields: [
      {key:'releaseRequestNo', label:'반출요청번호', readonly:true},
      {key:'exportDeclNo', label:'수출신고필증번호', readonly:true},
      {key:'warehouseNo', label:'창고번호', readonly:true},
      {key:'releasePlanDt', label:'반출일시', inputType:'date', readonly:true},
      {key:'targetWarehouse', label:'전달대상', type:'select', options:['인천항 보세창고 관리자','부산항 보세창고 관리자','평택항 보세창고 관리자'], readonly:true},
      {key:'pickupPlace', label:'상차지(보세구역)', readonly:true},
      {key:'vehicleDriver', label:'차량/기사', readonly:true},
      {key:'shippingPort', label:'선적항', readonly:true}
    ],
    rows: getExportReleaseRequestRows()
  });
}


function bindBondedReleaseRequestActions(groupKey, itemId) {
  if (itemId !== 'TACS-FW-009') return;

  const requestModal = document.getElementById('bondedReleaseRequestModal');
  const requestClose = document.getElementById('bondedReleaseModalClose');
  const requestCancel = document.getElementById('bondedReleaseModalCancel');
  const requestSubmit = document.getElementById('bondedReleaseModalSubmit');
  const reqNoInput = document.getElementById('bondedReleaseReqNo');
  const ownerInput = document.getElementById('bondedReleaseOwner');
  const certInput = document.getElementById('bondedReleaseCertNo');
  const itemInput = document.getElementById('bondedReleaseItem');
  const cargoNoInput = document.getElementById('bondedReleaseCargoNo');
  const pkgInput = document.getElementById('bondedReleasePkg');
  const weightInput = document.getElementById('bondedReleaseWeight');
  const cbmInput = document.getElementById('bondedReleaseCbm');
  const vehicleInput = document.getElementById('bondedReleaseVehicle');
  const driverInput = document.getElementById('bondedReleaseDriver');
  const portInput = document.getElementById('bondedReleasePort');
  const vesselInput = document.getElementById('bondedReleaseVessel');
  const zoneSelect = document.getElementById('bondedReleaseZone');
  const managerSelect = document.getElementById('bondedReleaseManager');

  const passModal = document.getElementById('bondedPassRequestModal');
  const passClose = document.getElementById('bondedPassModalClose');
  const passCancel = document.getElementById('bondedPassModalCancel');
  const passSubmit = document.getElementById('bondedPassModalSubmit');
  const passReqNo = document.getElementById('bondedPassReqNo');
  const passOwner = document.getElementById('bondedPassOwner');
  const passCertNo = document.getElementById('bondedPassCertNo');
  const passItem = document.getElementById('bondedPassItem');
  const passZone = document.getElementById('bondedPassZone');
  const passManager = document.getElementById('bondedPassManager');

  const rejectModal = document.getElementById('bondedReleaseRejectModal');
  const rejectReason = document.getElementById('bondedReleaseRejectReason');
  const rejectClose = document.getElementById('bondedReleaseRejectClose');
  const rejectConfirm = document.getElementById('bondedReleaseRejectConfirm');

  let selectedRow = null;
  let selectedPassRow = null;

  function openRequestModal(btn) {
    selectedRow = btn.closest('tr');
    reqNoInput.value = btn.dataset.requestNo || '';
    ownerInput.value = btn.dataset.owner || '';
    certInput.value = btn.dataset.certNo || '';
    itemInput.value = btn.dataset.item || '';
    if (cargoNoInput) cargoNoInput.value = btn.dataset.cargoNo || '';
    if (pkgInput) pkgInput.value = btn.dataset.pkg || '';
    if (weightInput) weightInput.value = btn.dataset.weight || '';
    if (cbmInput) cbmInput.value = btn.dataset.cbm || '';
    if (vehicleInput) vehicleInput.value = btn.dataset.vehicle || '';
    if (driverInput) driverInput.value = btn.dataset.driver || '';
    if (portInput) portInput.value = btn.dataset.port || '';
    if (vesselInput) vesselInput.value = `${btn.dataset.vessel || ''}${btn.dataset.voyage ? ' / ' + btn.dataset.voyage : ''}`;
    zoneSelect.value = btn.dataset.zone || zoneSelect.options[0].value;
    managerSelect.value = btn.dataset.manager || '';
    requestModal.classList.remove('hidden');
    requestModal.classList.add('flex');
  }

  function closeRequestModal() {
    requestModal.classList.add('hidden');
    requestModal.classList.remove('flex');
  }

  function closeRejectModal() {
    rejectModal.classList.add('hidden');
    rejectModal.classList.remove('flex');
  }

  function openPassModal(btn) {
    selectedPassRow = btn.closest('tr');
    passReqNo.value = btn.dataset.requestNo || '';
    passOwner.value = btn.dataset.owner || '';
    passCertNo.value = btn.dataset.certNo || '';
    passItem.value = btn.dataset.item || '';
    passZone.value = btn.dataset.zone || '';
    passManager.value = btn.dataset.manager || '';
    passModal.classList.remove('hidden');
    passModal.classList.add('flex');
  }

  function closePassModal() {
    passModal.classList.add('hidden');
    passModal.classList.remove('flex');
  }

  detailBody.querySelectorAll('.bonded-release-request-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      openRequestModal(this);
    });
  });

  detailBody.querySelectorAll('.bonded-pass-request-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      openPassModal(this);
    });
  });

  detailBody.querySelectorAll('.bonded-release-reject-reason-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      rejectReason.value = this.dataset.reason || '반려 사유가 등록되어 있지 않습니다.';
      rejectModal.classList.remove('hidden');
      rejectModal.classList.add('flex');
    });
  });

  if (requestClose) requestClose.addEventListener('click', closeRequestModal);
  if (requestCancel) requestCancel.addEventListener('click', closeRequestModal);
  if (requestModal) requestModal.addEventListener('click', e => { if (e.target === requestModal) closeRequestModal(); });

  if (passClose) passClose.addEventListener('click', closePassModal);
  if (passCancel) passCancel.addEventListener('click', closePassModal);
  if (passModal) passModal.addEventListener('click', e => { if (e.target === passModal) closePassModal(); });


  if (rejectClose) rejectClose.addEventListener('click', closeRejectModal);
  if (rejectConfirm) rejectConfirm.addEventListener('click', closeRejectModal);
  if (rejectModal) rejectModal.addEventListener('click', e => { if (e.target === rejectModal) closeRejectModal(); });

  if (requestSubmit) {
    requestSubmit.addEventListener('click', function() {
      if (!managerSelect.value) {
        alert('보세구역 창고관리자를 선택하세요.');
        return;
      }

      if (selectedRow) {
        const managerCell = selectedRow.querySelector('.warehouse-manager-cell');
        const statusCell = selectedRow.querySelector('.bonded-release-status-cell');
        const actionCell = selectedRow.querySelector('.bonded-release-action-cell');

        if (managerCell) managerCell.textContent = managerSelect.value;
        if (statusCell) statusCell.innerHTML = '<span class="info-chip">반출대기</span>';
        if (actionCell) actionCell.innerHTML = '<button type="button" class="px-3 py-1 border border-slate-300 bg-white text-slate-500 text-xs font-bold" disabled>요청완료</button>';
      }

      closeRequestModal();
      alert('선택한 보세구역 창고관리자에게 반출 요청이 전송되었습니다.');
    });
  }

  if (passSubmit) {
    passSubmit.addEventListener('click', function() {
      if (selectedPassRow) {
        const statusCell = selectedPassRow.querySelector('.bonded-release-status-cell');
        const actionCell = selectedPassRow.querySelector('.bonded-release-action-cell');
        if (statusCell) statusCell.innerHTML = '<span class="info-chip">승인완료</span>';
        if (actionCell) actionCell.innerHTML = '<button type="button" class="px-3 py-1 border border-slate-300 bg-white text-slate-500 text-xs font-bold" disabled>요청완료</button>';
      }
      closePassModal();
      alert('반출증 요청이 전송되었습니다.');
    });
  }
}
