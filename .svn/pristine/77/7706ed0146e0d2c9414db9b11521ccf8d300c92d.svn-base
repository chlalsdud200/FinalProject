<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TACS 자료실 관리</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: Arial, "Noto Sans KR", sans-serif; background: #f3f6fb; color: #172033; }
        .wrap { max-width: 980px; margin: 0 auto; padding: 28px; }
        .head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
        h1 { margin: 0; font-size: 24px; }
        .panel { background: #fff; border: 1px solid #d8e1ef; padding: 20px; }
        label { display: block; font-size: 12px; font-weight: 700; margin: 14px 0 6px; color: #40516c; }
        input[type="text"], select, textarea { width: 100%; border: 1px solid #c7d2e3; padding: 9px 10px; font-size: 13px; font-family: inherit; background: #fff; }
        textarea { min-height: 120px; resize: vertical; line-height: 1.5; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .roles { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; margin-top: 6px; }
        .roles label { display: flex; align-items: center; gap: 8px; margin: 0; padding: 10px; border: 1px solid #d8e1ef; background: #f8fafc; color: #172033; }
        button, .link { border: 1px solid #46516a; background: #46516a; color: #fff; height: 36px; padding: 0 14px; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; }
        .link.secondary { background: #fff; color: #46516a; }
        .actions { display: flex; justify-content: flex-end; gap: 8px; margin-top: 18px; }
        .message { margin-bottom: 12px; padding: 10px 12px; font-size: 13px; border: 1px solid #bbf7d0; background: #f0fdf4; color: #166534; }
        .error { margin-bottom: 12px; padding: 10px 12px; font-size: 13px; border: 1px solid #fecaca; background: #fef2f2; color: #b91c1c; }
    </style>
</head>
<body>
<div class="wrap">
    <div class="head">
        <h1>자료실 관리</h1>
        <a class="link secondary" href="${pageContext.request.contextPath}/systemadmin/dashboard.do">관리자 홈</a>
    </div>

    <c:if test="${not empty message}">
        <div class="message">${message}</div>
    </c:if>
    <c:if test="${not empty error}">
        <div class="error">${error}</div>
    </c:if>

    <section class="panel">
        <form action="${pageContext.request.contextPath}/admin/resources/upload.do" method="post" enctype="multipart/form-data">
            <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}">

            <div class="grid">
                <div>
                    <label for="resTtl">자료명</label>
                    <input id="resTtl" name="resTtl" type="text" maxlength="300" required placeholder="예: 송장 표준 양식">
                </div>
                <div>
                    <label for="docTyCd">문서 유형</label>
                    <select id="docTyCd" name="docTyCd" required>
                        <option value="INVOICE">송장</option>
                        <option value="PACKING_LIST">포장명세서</option>
                        <option value="BL">선하증권</option>
                        <option value="IMPORT_DECL">수입신고서</option>
                        <option value="EXPORT_DECL">수출신고서</option>
                        <option value="MANUAL">매뉴얼</option>
                        <option value="ETC">기타</option>
                    </select>
                </div>
            </div>

            <label for="resCn">설명</label>
            <textarea id="resCn" name="resCn" placeholder="자료 설명을 입력하세요."></textarea>

            <label for="file">파일</label>
            <input id="file" name="file" type="file" required>

            <label>노출 대상</label>
            <div class="roles">
                <label><input type="checkbox" name="targetRoleCds" value="OWNER"> 화주</label>
                <label><input type="checkbox" name="targetRoleCds" value="BROKER"> 관세사</label>
                <label><input type="checkbox" name="targetRoleCds" value="TRANSPORT_MANAGER"> 운송담당자</label>
                <label><input type="checkbox" name="targetRoleCds" value="WAREHOUSE_MANAGER"> 창고관리자</label>
                <label><input type="checkbox" name="targetRoleCds" value="OFFICER"> 행정공무원</label>
                <label><input type="checkbox" name="targetRoleCds" value="FIELD_OFFICER"> 현장공무원</label>
            </div>

            <div class="actions">
                <button type="submit">등록</button>
            </div>
        </form>
    </section>
</div>
</body>
</html>
