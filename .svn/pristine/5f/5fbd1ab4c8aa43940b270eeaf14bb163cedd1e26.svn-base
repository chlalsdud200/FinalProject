<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.owner.transport.mapper.ITransportProgressMapper">

    <resultMap id="transportProgressMap" type="kr.or.tacs.dto.owner.OwnerTransportProgressDTO">
        <result property="trcNo" column="TRC_NO"/>
        <result property="trcTmNo" column="TRC_TM_NO"/>
        <result property="trcOwrId" column="TRC_OWR_ID"/>
        <result property="trcSeCd" column="TRC_SE_CD"/>
        <result property="trcSeNm" column="TRC_SE_NM"/>

        <result property="tmCpNm" column="TM_CP_NM"/>
        <result property="tmName" column="TM_NAME"/>
        <result property="tmCpTelno" column="TM_CP_TELNO"/>

        <result property="deptPortCd" column="DEPT_PORT_CD"/>
        <result property="deptPortNm" column="DEPT_PORT_NM"/>
        <result property="arvlPortCd" column="ARVL_PORT_CD"/>
        <result property="arvlPortNm" column="ARVL_PORT_NM"/>

        <result property="trcBiNo" column="TRC_BI_NO"/>
        <result property="doStatusCd" column="DO_STATUS_CD"/>

        <result property="ianNo" column="IAN_NO"/>
        <result property="ianSendSttsCd" column="IAN_SEND_STTS_CD"/>
        <result property="ianSendSttsNm" column="IAN_SEND_STTS_NM"/>
        <result property="ianSendDt" column="IAN_SEND_DT"/>
        <result property="ianRegistDt" column="IAN_REGIST_DT"/>
        <result property="ianCurrLoc" column="IAN_CURR_LOC"/>
        <result property="ianArrvStatusCd" column="IAN_ARRV_STATUS_CD"/>

        <result property="etaDt" column="ETA_DT"/>
        <result property="trcRqstDt" column="TRC_RQST_DT"/>
        <result property="trcRceptDt" column="TRC_RCEPT_DT"/>
        <result property="lastUpdateDt" column="LAST_UPDATE_DT"/>

        <result property="trcStatusCd" column="TRC_STATUS_CD"/>
        <result property="trcStatusNm" column="TRC_STATUS_NM"/>

        <result property="trcRqstCn" column="TRC_RQST_CN"/>
        <result property="trcDlvyReqDt" column="TRC_DLVY_REQ_DT"/>
    </resultMap>

    <resultMap id="transportDetailMap" type="kr.or.tacs.dto.owner.OwnerTranDetailDTO">

        <!-- TRAN_RCP -->
        <result property="trcNo" column="TRC_NO"/>
        <result property="trcTmNo" column="TRC_TM_NO"/>
        <result property="trcOwrId" column="TRC_OWR_ID"/>
        <result property="trcShipNo" column="TRC_SHIP_NO"/>
        <result property="trcPortCd" column="TRC_PORT_CD"/>
        <result property="trcDeptPortCd" column="TRC_DEPT_PORT_CD"/>
        <result property="trcTfgNo" column="TRC_TFG_NO"/>
        <result property="trcArvlPortCd" column="TRC_ARVL_PORT_CD"/>
        <result property="trcTrdrNm" column="TRC_TRDR_NM"/>
        <result property="trcTranMnCd" column="TRC_TRAN_MN_CD"/>
        <result property="trcTranTyCd" column="TRC_TRAN_TY_CD"/>
        <result property="trcIncoTermsCd" column="TRC_INCO_TERMS_CD"/>
        <result property="trcRqstCn" column="TRC_RQST_CN"/>
        <result property="trcReviewRsltCn" column="TRC_REVIEW_RSLT_CN"/>
        <result property="trcRjctRsn" column="TRC_RJCT_RSN"/>
        <result property="trcRceptDt" column="TRC_RCEPT_DT"/>
        <result property="trcSeCd" column="TRC_SE_CD"/>
        <result property="trcStatusCd" column="TRC_STATUS_CD"/>
        <result property="trcRqstDt" column="TRC_RQST_DT"/>
        <result property="trcRejType" column="TRC_REJ_TYPE"/>
        <result property="trcRejMemo" column="TRC_REJ_MEMO"/>
        <result property="trcOwrPicNm" column="TRC_OWR_PIC_NM"/>
        <result property="trcDlvyReqDt" column="TRC_DLVY_REQ_DT"/>
        <result property="trcItemCtgryNm" column="TRC_ITEM_CTGRY_NM"/>
        <result property="trcTrdrCountryCd" column="TRC_TRDR_COUNTRY_CD"/>
        <result property="trcBiNo" column="TRC_BI_NO"/>

        <!-- 코드명 -->
        <result property="trcSeNm" column="TRC_SE_NM"/>
        <result property="trcStatusNm" column="TRC_STATUS_NM"/>
        <result property="trcTranMnNm" column="TRC_TRAN_MN_NM"/>
        <result property="trcTranTyNm" column="TRC_TRAN_TY_NM"/>
        <result property="trcIncoTermsNm" column="TRC_INCO_TERMS_NM"/>

        <!-- PORT / COUNTRY -->
        <result property="portNm" column="PORT_NM"/>
        <result property="deptPortNm" column="DEPT_PORT_NM"/>
        <result property="arvlPortNm" column="ARVL_PORT_NM"/>
        <result property="trdrCountryNm" column="TRDR_COUNTRY_NM"/>

        <!-- TRANSPORT_MANAGER -->
        <result property="tmNo" column="TM_NO"/>
        <result property="tmId" column="TM_ID"/>
        <result property="tmCpNm" column="TM_CP_NM"/>
        <result property="tmCpTelno" column="TM_CP_TELNO"/>
        <result property="tmMnCd" column="TM_MN_CD"/>
        <result property="tmName" column="TM_NAME"/>

        <!-- DISPATCH -->
        <result property="dispatchNo" column="DISPATCH_NO"/>
        <result property="dispatchTreId" column="DISPATCH_TRE_ID"/>
        <result property="dispatchOwrId" column="DISPATCH_OWR_ID"/>
        <result property="dispatchCarNo" column="DISPATCH_CAR_NO"/>
        <result property="dispatchDrvNm" column="DISPATCH_DRV_NM"/>
        <result property="dispatchLoadgAdres" column="DISPATCH_LOADG_ADRES"/>
        <result property="dispatchDrvTelno" column="DISPATCH_DRV_TELNO"/>
        <result property="dispatchPickupDt" column="DISPATCH_PICKUP_DT"/>
        <result property="dispatchStatusCd" column="DISPATCH_STATUS_CD"/>
        <result property="dispatchStatusNm" column="DISPATCH_STATUS_NM"/>

        <!-- IMP_ARRV_NTC -->
        <result property="ianNo" column="IAN_NO"/>
        <result property="ianOwrId" column="IAN_OWR_ID"/>
        <result property="ianSendSttsCd" column="IAN_SEND_STTS_CD"/>
        <result property="ianSendSttsNm" column="IAN_SEND_STTS_NM"/>
        <result property="ianSendDt" column="IAN_SEND_DT"/>
        <result property="ianRegistDt" column="IAN_REGIST_DT"/>
        <result property="ianCurrLoc" column="IAN_CURR_LOC"/>
        <result property="ianArrvStatusCd" column="IAN_ARRV_STATUS_CD"/>
        <result property="ianTrcNo" column="IAN_TRC_NO"/>

        <!-- BL_ISSU -->
        <result property="biNo" column="BI_NO"/>
        <result property="biTreId" column="BI_TRE_ID"/>
        <result property="biOwrId" column="BI_OWR_ID"/>
        <result property="biTmNo" column="BI_TM_NO"/>
        <result property="biGgNo" column="BI_GG_NO"/>
        <result property="biMblNo" column="BI_MBL_NO"/>
        <result property="biHblNo" column="BI_HBL_NO"/>
        <result property="biStatusCd" column="BI_STATUS_CD"/>
        <result property="biStatusNm" column="BI_STATUS_NM"/>
        <result property="biOwrMsg" column="BI_OWR_MSG"/>
        <result property="biStlStatusCd" column="BI_STL_STATUS_CD"/>
        <result property="biStlStatusNm" column="BI_STL_STATUS_NM"/>
        <result property="biXprotFee" column="BI_XPROT_FEE"/>
        <result property="biWhFee" column="BI_WH_FEE"/>
        <result property="biTtlAmt" column="BI_TTL_AMT"/>
        <result property="biExpln" column="BI_EXPLN"/>

        <!-- TRAN_COST_STL -->
        <result property="tcsNo" column="TCS_NO"/>
        <result property="tcsTrcNo" column="TCS_TRC_NO"/>
        <result property="tcsOwrId" column="TCS_OWR_ID"/>
        <result property="tcsGgNo" column="TCS_GG_NO"/>
        <result property="tcsMblNo" column="TCS_MBL_NO"/>
        <result property="tcsHblNo" column="TCS_HBL_NO"/>
        <result property="tcsOwrMsgCn" column="TCS_OWR_MSG_CN"/>
        <result property="tcsStlStatusCd" column="TCS_STL_STATUS_CD"/>
        <result property="tcsStlStatusNm" column="TCS_STL_STATUS_NM"/>
        <result property="tcsFrgtAmt" column="TCS_FRGT_AMT"/>
        <result property="tcsWhAmt" column="TCS_WH_AMT"/>
        <result property="tcsTotBillAmt" column="TCS_TOT_BILL_AMT"/>
        <result property="tcsStlExpln" column="TCS_STL_EXPLN"/>

    </resultMap>

    <sql id="progressWhere">
        WHERE trc.TRC_OWR_ID = #{owrId}

        <if test="tradeSeCd != null and tradeSeCd != ''">
            AND trc.TRC_SE_CD = #{tradeSeCd}
        </if>

        AND trc.TRC_STATUS_CD IN (
        'TRC_DONE'
        , 'TRC_DISPATCH_WAIT'
        , 'TRC_DISPATCH_DONE'
        , 'TRC_ARR_ARRIVED'
        , 'TRC_NTC_NSENT'
        , 'TRC_NTC_SENT'
        , 'TRC_DO_READY'
        , 'TRC_DO_ISSUED'
        , 'TRC_DO_REQ'
        , 'TRC_STL_UNPAID'
        , 'TRC_STL_REQ'
        , 'TRC_STL_PAID'
        , 'TRC_END'
        , 'TRC_COMPLETE'
        )

        <if test="statusCd != null and statusCd != ''">
            <choose>
                <when test="statusCd == 'CONTRACT_ACTIVE'">
                    AND trc.TRC_STATUS_CD IN (
                    'TRC_DONE'
                    , 'TRC_DISPATCH_WAIT'
                    , 'TRC_DISPATCH_DONE'
                    , 'TRC_ARR_ARRIVED'
                    , 'TRC_NTC_NSENT'
                    , 'TRC_NTC_SENT'
                    , 'TRC_DO_READY'
                    , 'TRC_DO_ISSUED'
                    , 'TRC_DO_REQ'
                    , 'TRC_STL_UNPAID'
                    , 'TRC_STL_REQ'
                    , 'TRC_STL_PAID'
                    )
                </when>
                <otherwise>
                    AND trc.TRC_STATUS_CD = #{statusCd}
                </otherwise>
            </choose>
        </if>

        <if test="startDate != null and startDate != ''">
            AND trc.TRC_RQST_DT &gt;= TO_DATE(#{startDate}, 'YYYY-MM-DD')
        </if>

        <if test="endDate != null and endDate != ''">
            AND trc.TRC_RQST_DT &lt; TO_DATE(#{endDate}, 'YYYY-MM-DD') + 1
        </if>

        <if test="keyword != null and keyword != ''">
            AND (
            trc.TRC_NO LIKE '%' || #{keyword} || '%'
            OR tm.TM_CP_NM LIKE '%' || #{keyword} || '%'
            OR tm.TM_NAME LIKE '%' || #{keyword} || '%'
            OR TO_CHAR(trc.TRC_BI_NO) LIKE '%' || #{keyword} || '%'
            OR trc.TRC_RQST_CN LIKE '%' || #{keyword} || '%'
            )
        </if>
    </sql>

    <select id="selectTrcProgressCount"
            parameterType="kr.or.tacs.dto.owner.OwnerTranSearchDTO"
            resultType="int">
        SELECT COUNT(*)
        FROM TRAN_RCP trc
        INNER JOIN TRANSPORT_MANAGER tm
        ON trc.TRC_TM_NO = tm.TM_NO
        <include refid="progressWhere"/>
    </select>

    <select id="selectImpTrcProgressList"
            parameterType="kr.or.tacs.dto.owner.OwnerTranSearchDTO"
            resultMap="transportProgressMap">
        SELECT
        trc.TRC_NO
        , trc.TRC_TM_NO
        , trc.TRC_OWR_ID
        , trc.TRC_SE_CD
        , CASE trc.TRC_SE_CD
        WHEN 'IMP' THEN 'IMPORT'
        WHEN 'EXP' THEN 'EXPORT'
        ELSE trc.TRC_SE_CD
        END AS TRC_SE_NM

        , trc.TRC_STATUS_CD
        , NVL(cc_status.CC_NM, trc.TRC_STATUS_CD) AS TRC_STATUS_NM

        , trc.TRC_BI_NO

        , trc.TRC_DEPT_PORT_CD AS DEPT_PORT_CD
        , trc.TRC_DEPT_PORT_CD AS DEPT_PORT_NM
        , trc.TRC_ARVL_PORT_CD AS ARVL_PORT_CD
        , trc.TRC_ARVL_PORT_CD AS ARVL_PORT_NM

        , tm.TM_CP_NM
        , tm.TM_NAME
        , tm.TM_CP_TELNO

        , trc.TRC_STATUS_CD AS DO_STATUS_CD

        , ian.IAN_NO
        , ian.IAN_SEND_STTS_CD
        , NVL(cc_send.CC_NM, ian.IAN_SEND_STTS_CD) AS IAN_SEND_STTS_NM
        , ian.IAN_SEND_DT
        , ian.IAN_REGIST_DT
        , ian.IAN_CURR_LOC AS ARRV_CURR_LOC
        , ian.IAN_ARRV_STATUS_CD AS ARRV_STATUS_CD
        , NVL(cc_arrv.CC_NM, ian.IAN_ARRV_STATUS_CD) AS ARRV_STATUS_NM
        , ian.IAN_ARRV_DT AS ETA_DT

        , trc.TRC_RQST_DT
        , trc.TRC_RCEPT_DT
        , NVL(trc.TRC_RCEPT_DT, trc.TRC_RQST_DT) AS LAST_UPDATE_DT

        FROM TRAN_RCP trc

        INNER JOIN TRANSPORT_MANAGER tm
        ON trc.TRC_TM_NO = tm.TM_NO

        LEFT JOIN (
        SELECT
        IAN_NO
        , IAN_OWR_ID
        , IAN_SEND_STTS_CD
        , IAN_SEND_DT
        , IAN_REGIST_DT
        , IAN_CURR_LOC
        , IAN_ARRV_STATUS_CD
        , IAN_TRC_NO
        , IAN_ARRV_DT
        FROM (
        SELECT
        ian.*
        , ROW_NUMBER() OVER (
        PARTITION BY ian.IAN_TRC_NO
        ORDER BY NVL(ian.IAN_ARRV_DT, NVL(ian.IAN_SEND_DT, ian.IAN_REGIST_DT)) DESC,
        ian.IAN_NO DESC
        ) AS rn
        FROM IMP_ARRV_NTC ian
        )
        WHERE rn = 1
        ) ian
        ON ian.IAN_TRC_NO = trc.TRC_NO

        LEFT JOIN COM_CODE cc_status
        ON cc_status.CC_CD = trc.TRC_STATUS_CD
        AND cc_status.CC_USE_YN = 'Y'

        LEFT JOIN COM_CODE cc_arrv
        ON cc_arrv.CC_CD = ian.IAN_ARRV_STATUS_CD
        AND cc_arrv.CC_CCG_ID = 'ARRIVAL_STATUS'
        AND cc_arrv.CC_USE_YN = 'Y'

        LEFT JOIN COM_CODE cc_send
        ON cc_send.CC_CD = ian.IAN_SEND_STTS_CD
        AND cc_send.CC_CCG_ID = 'ARRIVAL_NOTICE_STATUS'
        AND cc_send.CC_USE_YN = 'Y'

        <include refid="progressWhere"/>

        ORDER BY trc.TRC_NO DESC

        OFFSET #{offset} ROWS FETCH NEXT #{size} ROWS ONLY
    </select>

    <select id="selectImpTrc"
            parameterType="String"
            resultMap="transportDetailMap">
        SELECT
            trc.TRC_NO
             , trc.TRC_TM_NO
             , trc.TRC_OWR_ID
             , trc.TRC_SHIP_NO
             , trc.TRC_PORT_CD
             , trc.TRC_DEPT_PORT_CD
             , trc.TRC_TFG_NO
             , trc.TRC_ARVL_PORT_CD
             , trc.TRC_TRDR_NM
             , trc.TRC_TRAN_MN_CD
             , trc.TRC_TRAN_TY_CD
             , trc.TRC_INCO_TERMS_CD
             , trc.TRC_RQST_CN
             , trc.TRC_REVIEW_RSLT_CN
             , trc.TRC_RJCT_RSN
             , trc.TRC_RCEPT_DT
             , trc.TRC_SE_CD
             , trc.TRC_STATUS_CD
             , trc.TRC_RQST_DT
             , trc.TRC_REJ_TYPE
             , trc.TRC_REJ_MEMO
             , trc.TRC_OWR_PIC_NM
             , trc.TRC_DLVY_REQ_DT
             , trc.TRC_ITEM_CTGRY_NM
             , trc.TRC_TRDR_COUNTRY_CD
             , trc.TRC_BI_NO

             , CASE trc.TRC_SE_CD
                   WHEN 'IMPORT' THEN '수입'
                   WHEN 'EXPORT' THEN '수출'
                   ELSE trc.TRC_SE_CD
            END AS TRC_SE_NM

             , NVL(cc_status.CC_NM, trc.TRC_STATUS_CD) AS TRC_STATUS_NM
             , NVL(cc_mn.CC_NM, trc.TRC_TRAN_MN_CD) AS TRC_TRAN_MN_NM
             , NVL(cc_ty.CC_NM, trc.TRC_TRAN_TY_CD) AS TRC_TRAN_TY_NM
             , NVL(cc_inco.CC_NM, trc.TRC_INCO_TERMS_CD) AS TRC_INCO_TERMS_NM

             , port.PORT_NM AS PORT_NM
             , dept_port.PORT_NM AS DEPT_PORT_NM
             , arvl_port.PORT_NM AS ARVL_PORT_NM
             , country.COUNTRY_NM_KR AS TRDR_COUNTRY_NM

             , tm.TM_NO
             , tm.TM_ID
             , tm.TM_CP_NM
             , tm.TM_CP_TELNO
             , tm.TM_MN_CD
             , tm.TM_NAME

             , dp.DISPATCH_NO
             , dp.DISPATCH_TRE_ID
             , dp.DISPATCH_OWR_ID
             , dp.DISPATCH_CAR_NO
             , dp.DISPATCH_DRV_NM
             , dp.DISPATCH_LOADG_ADRES
             , dp.DISPATCH_DRV_TELNO
             , dp.DISPATCH_PICKUP_DT
             , dp.DISPATCH_STATUS_CD
             , NVL(cc_dp.CC_NM, dp.DISPATCH_STATUS_CD) AS DISPATCH_STATUS_NM

             , ian.IAN_NO
             , ian.IAN_OWR_ID
             , ian.IAN_SEND_STTS_CD
             , NVL(cc_send.CC_NM, ian.IAN_SEND_STTS_CD) AS IAN_SEND_STTS_NM
             , ian.IAN_SEND_DT
             , ian.IAN_REGIST_DT
             , ian.IAN_CURR_LOC
             , ian.IAN_ARRV_STATUS_CD
             , NVL(cc_arrv.CC_NM, ian.IAN_ARRV_STATUS_CD) AS IAN_ARRV_STATUS_NM
             , ian.IAN_TRC_NO

             , bi.BI_NO
             , bi.BI_TRE_ID
             , bi.BI_OWR_ID
             , bi.BI_TM_NO
             , bi.BI_GG_NO
             , bi.BI_MBL_NO
             , bi.BI_HBL_NO
             , bi.BI_STATUS_CD
             , NVL(cc_bi_status.CC_NM, bi.BI_STATUS_CD) AS BI_STATUS_NM
             , bi.BI_OWR_MSG
             , bi.BI_STL_STATUS_CD
             , NVL(cc_bi_stl.CC_NM, bi.BI_STL_STATUS_CD) AS BI_STL_STATUS_NM
             , bi.BI_XPROT_FEE
             , bi.BI_WH_FEE
             , bi.BI_TTL_AMT
             , bi.BI_EXPLN

             , tcs.TCS_NO
             , tcs.TCS_TRC_NO
             , tcs.TCS_OWR_ID
             , tcs.TCS_GG_NO
             , tcs.TCS_MBL_NO
             , tcs.TCS_HBL_NO
             , tcs.TCS_OWR_MSG_CN
             , tcs.TCS_STL_STATUS_CD
             , NVL(cc_tcs_stl.CC_NM, tcs.TCS_STL_STATUS_CD) AS TCS_STL_STATUS_NM
             , tcs.TCS_FRGT_AMT
             , tcs.TCS_WH_AMT
             , tcs.TCS_TOT_BILL_AMT
             , tcs.TCS_STL_EXPLN
             , tcs.TCS_DT

        FROM TRAN_RCP trc

                 INNER JOIN TRANSPORT_MANAGER tm
                            ON trc.TRC_TM_NO = tm.TM_NO

                 LEFT JOIN PORT port
                           ON port.PORT_CD = trc.TRC_PORT_CD

                 LEFT JOIN PORT dept_port
                           ON dept_port.PORT_CD = trc.TRC_DEPT_PORT_CD

                 LEFT JOIN PORT arvl_port
                           ON arvl_port.PORT_CD = trc.TRC_ARVL_PORT_CD

                 LEFT JOIN COUNTRY country
                           ON country.COUNTRY_CD = trc.TRC_TRDR_COUNTRY_CD

                 LEFT JOIN DISPATCH dp
                           ON dp.DISPATCH_TRE_ID = trc.TRC_NO

                 LEFT JOIN (
            SELECT
                IAN_NO
                 , IAN_OWR_ID
                 , IAN_SEND_STTS_CD
                 , IAN_SEND_DT
                 , IAN_REGIST_DT
                 , IAN_CURR_LOC
                 , IAN_ARRV_STATUS_CD
                 , IAN_TRC_NO
                 , IAN_ARRV_DT
            FROM (
                     SELECT
                         ian.*
                          , ROW_NUMBER() OVER (
                    PARTITION BY ian.IAN_TRC_NO
                    ORDER BY NVL(ian.IAN_ARRV_DT, NVL(ian.IAN_SEND_DT, ian.IAN_REGIST_DT)) DESC,
                             ian.IAN_NO DESC
                  ) AS rn
                     FROM IMP_ARRV_NTC ian
                 )
            WHERE rn = 1
        ) ian
                           ON ian.IAN_TRC_NO = trc.TRC_NO

                 LEFT JOIN BL_ISSU bi
                           ON bi.BI_NO = trc.TRC_BI_NO

                 LEFT JOIN TRAN_COST_STL tcs
                           ON tcs.TCS_TRC_NO = trc.TRC_NO

                 LEFT JOIN COM_CODE cc_status
                           ON cc_status.CC_CD = trc.TRC_STATUS_CD
                               AND cc_status.CC_USE_YN = 'Y'

                 LEFT JOIN COM_CODE cc_mn
                           ON cc_mn.CC_CD = trc.TRC_TRAN_MN_CD
                               AND cc_mn.CC_USE_YN = 'Y'

                 LEFT JOIN COM_CODE cc_ty
                           ON cc_ty.CC_CD = trc.TRC_TRAN_TY_CD
                               AND cc_ty.CC_USE_YN = 'Y'

                 LEFT JOIN COM_CODE cc_inco
                           ON cc_inco.CC_CD = trc.TRC_INCO_TERMS_CD
                               AND cc_inco.CC_USE_YN = 'Y'

                 LEFT JOIN COM_CODE cc_dp
                           ON cc_dp.CC_CD = dp.DISPATCH_STATUS_CD
                               AND cc_dp.CC_USE_YN = 'Y'

                 LEFT JOIN COM_CODE cc_send
                           ON cc_send.CC_CD = ian.IAN_SEND_STTS_CD
                               AND cc_send.CC_CCG_ID = 'ARRIVAL_NOTICE_STATUS'
                               AND cc_send.CC_USE_YN = 'Y'

                 LEFT JOIN COM_CODE cc_arrv
                           ON cc_arrv.CC_CD = ian.IAN_ARRV_STATUS_CD
                               AND cc_arrv.CC_CCG_ID = 'ARRIVAL_STATUS'
                               AND cc_arrv.CC_USE_YN = 'Y'

                 LEFT JOIN COM_CODE cc_bi_status
                           ON cc_bi_status.CC_CD = bi.BI_STATUS_CD
                               AND cc_bi_status.CC_USE_YN = 'Y'

                 LEFT JOIN COM_CODE cc_bi_stl
                           ON cc_bi_stl.CC_CD = bi.BI_STL_STATUS_CD
                               AND cc_bi_stl.CC_USE_YN = 'Y'

                 LEFT JOIN COM_CODE cc_tcs_stl
                           ON cc_tcs_stl.CC_CD = tcs.TCS_STL_STATUS_CD
                               AND cc_tcs_stl.CC_USE_YN = 'Y'

        WHERE trc.TRC_NO = #{value}
          AND trc.TRC_SE_CD = 'IMPORT'
    </select>

</mapper>
