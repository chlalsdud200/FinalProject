#pickupDispatchListPanel .tbl td,
#pickupDispatchListPanel .tbl th,
#pickupDispatchModal .tbl td,
#pickupDispatchModal .tbl th{white-space:normal !important;word-break:keep-all;vertical-align:middle}
#pickupDispatchModal tbody tr{cursor:pointer}
#pickupDispatchModal tbody tr:hover td{background:#eef4fb !important}
#bondedReleaseRequestModal .field-select,
#bondedReleaseRequestModal .field-input,
#bondedReleaseRequestModal .field-textarea{font-size:13px !important}
#bondedReleaseRequestModal textarea,
#bondedReleaseRejectModal textarea{resize:none}
.import-manifest-row td{white-space:normal !important;word-break:keep-all;vertical-align:middle}
.import-manifest-row:hover td{background:#eef4fb !important}
#manifestCustomsModal textarea{resize:none}
.do-row{cursor:pointer}
.do-row:hover td{background:#eef4fb !important}
.do-row td{white-space:normal !important;word-break:keep-all;vertical-align:middle}
.do-settlement-cell .info-chip,
.do-status-cell .info-chip{min-width:64px !important;height:28px !important;padding:0 10px !important;justify-content:center !important}

/* 적하목록 비교 화면 정리 */
#manifestPackingDownloadBtn,
#manifestPackingViewBtn,
#manifestManualConfirmArea{
  display:none!important;
}

.manifest-pdf-value-input{background:#fff!important;color:#0f172a!important}
.manifest-compare-result span{white-space:nowrap}

/* 업로드 input 숨김 */
#manifestPackingUploadInput{
  display:none!important;
}

/* 실제 PDF 업로드 버튼 */
#manifestPackingUploadBtn,
.manifest-packing-upload-label{
  display:inline-flex!important;
  align-items:center!important;
  justify-content:center!important;
  min-width:92px!important;
  height:34px!important;
  padding:0 16px!important;
  background:#334155!important;
  border:1px solid #334155!important;
  border-radius:4px!important;
  -webkit-text-fill-color:#ffffff!important;
  color:#ffffff!important;
  font-size:0!important;
  font-weight:800!important;
  line-height:1!important;
  text-indent:0!important;
  opacity:1!important;
  visibility:visible!important;
  white-space:nowrap!important;
  cursor:pointer!important;
}

#manifestPackingUploadBtn::after,
.manifest-packing-upload-label::after{
  content:"PDF 업로드"!important;
  -webkit-text-fill-color:#ffffff!important;
  color:#ffffff!important;
  font-size:12px!important;
  font-weight:800!important;
  line-height:1!important;
}

#manifestPackingUploadBtn input,
.manifest-packing-upload-label input{
  display:none!important;
}

/* 좌측 리스트 조회버튼 폭 강제 축소 */
#detail-body button[id$="SearchBtn"],
#detail-body button[id*="SearchBtn"],
#detail-body .section-card button{
  width:auto!important;
  min-width:72px!important;
  max-width:96px!important;
  height:40px!important;
  min-height:40px!important;
  padding:0 16px!important;
  flex:0 0 auto!important;
}

#detail-body .section-card button.w-full{
  width:auto!important;
}

/* 운송의뢰 리스트 처리 버튼 세로/가로 정렬 통일 */
#detail-body .import-list-action-btn{
  display:inline-flex!important;
  align-items:center!important;
  justify-content:center!important;
  width:72px!important;
  height:40px!important;
  padding:0!important;
  margin:0 auto!important;
  line-height:1!important;
}
/* === 2026-05-20 보세구역 입고/반출 리스트 테이블 폭 통일 ===
 * min-w-[1040px], min-w-[1080px] 테이블만 다른 리스트보다 넓게 잡혀
 * 좌우 공백/스크롤이 튀는 문제를 공통 리스트 폭 기준으로 맞춘다.
 */
#detail-body table[class*="min-w-[1040px]"],
#detail-body table[class*="min-w-[1080px]"],
#detail-body .import-inbound-manage-panel table.tbl,
#detail-body .import-release-request-panel table.tbl,
#detail-body .release-request-panel table.tbl,
#detail-body #importReleaseRequestTbody.closest-table-placeholder{
  width:100%!important;
  min-width:100%!important;
  table-layout:fixed!important;
}

#detail-body table[class*="min-w-[1040px]"] th,
#detail-body table[class*="min-w-[1040px]"] td,
#detail-body table[class*="min-w-[1080px]"] th,
#detail-body table[class*="min-w-[1080px]"] td{
  height:44px!important;
  padding:10px 12px!important;
  text-align:center!important;
  vertical-align:middle!important;
  white-space:normal!important;
  word-break:keep-all!important;
}

#detail-body table[class*="min-w-[1040px]"] th,
#detail-body table[class*="min-w-[1080px]"] th{
  background:#f8fafc!important;
  font-size:12px!important;
  font-weight:900!important;
  color:#334155!important;
}

#detail-body table[class*="min-w-[1040px]"] td,
#detail-body table[class*="min-w-[1080px]"] td{
  font-size:12px!important;
  font-weight:700!important;
  color:#0f172a!important;
}

/* 입고/반출 리스트 테이블 wrapper도 다른 리스트와 동일하게 */
#detail-body .import-inbound-manage-panel .overflow-x-auto,
#detail-body .import-release-request-panel .overflow-x-auto,
#detail-body .release-request-panel .overflow-x-auto{
  width:100%!important;
  margin-top:0!important;
  border:1px solid #e2e8f0!important;
  border-radius:0!important;
  overflow-x:auto!important;
}

/* === 2026-05-20 입고/반출 리스트 검색영역-테이블 간격 복구 ===
 * 이전 min-width 통일 CSS에서 테이블 wrapper margin-top을 0으로 눌러서
 * 보세구역 입고관리/반출관리만 검색 input 바로 아래에 테이블이 붙는 문제를 복구한다.
 * D/O 관리는 기존 정상 레이아웃 유지.
 */
#detail-body .import-inbound-manage-panel .list-search-grid + .overflow-x-auto,
#detail-body .import-inbound-manage-panel .list-search-grid + div.overflow-x-auto,
#detail-body .import-release-request-panel .list-search-grid + .overflow-x-auto,
#detail-body .release-request-panel .list-search-grid + .overflow-x-auto,
#detail-body .bonded-work-panel .list-search-grid + .overflow-x-auto{
  margin-top:14px!important;
}

/* 반출관리/입고관리에서 grid 다음 테이블이 바로 오는 구조 보정 */
#detail-body .import-inbound-manage-panel .p-5 > .overflow-x-auto,
#detail-body .import-release-request-panel .p-5 > .overflow-x-auto,
#detail-body .release-request-panel .p-5 > .overflow-x-auto,
#detail-body .bonded-work-panel .p-5 > .overflow-x-auto{
  margin-top:14px!important;
}

/* 검색영역은 D/O처럼 table과 겹치지 않게 아래 공간 확보 */
#detail-body .import-inbound-manage-panel .list-search-grid,
#detail-body .import-release-request-panel .list-search-grid,
#detail-body .release-request-panel .list-search-grid,
#detail-body .bonded-work-panel .list-search-grid{
  margin-bottom:0!important;
}

/* 테이블 wrapper는 폭만 맞추고, 위 간격은 유지 */
#detail-body .import-inbound-manage-panel .overflow-x-auto,
#detail-body .import-release-request-panel .overflow-x-auto,
#detail-body .release-request-panel .overflow-x-auto{
  border:1px solid #e2e8f0!important;
  border-radius:0!important;
  overflow-x:auto!important;
}

/* === 2026-05-20 최종: 좌측 리스트 검색영역-테이블 간격 공통 복구 ===
 * 운송의뢰/도착/적하목록/D/O/입고/반출 전체에서
 * 검색 필터 바로 아래에 테이블이 붙는 문제를 공통으로 해결한다.
 */
#detail-body .list-search-grid,
#detail-body .do-list-search-grid,
#detail-body .release-search-grid,
#detail-body .inland-search-grid,
#detail-body .import-list-search-grid{
  margin-bottom:16px!important;
}

#detail-body .list-search-grid + .overflow-x-auto,
#detail-body .do-list-search-grid + .overflow-hidden,
#detail-body .do-list-search-grid + .overflow-x-auto,
#detail-body .release-search-grid + .overflow-x-auto,
#detail-body .inland-search-grid + .overflow-x-auto,
#detail-body .import-list-search-grid + .overflow-x-auto,
#detail-body .section-card .p-5 > .overflow-x-auto,
#detail-body .section-card .p-6 > .overflow-x-auto,
#detail-body .section-card .p-5 > .overflow-hidden,
#detail-body .section-card .p-6 > .overflow-hidden{
  margin-top:16px!important;
}

/* flex column 구조(내륙처럼 gap 쓰는 화면)는 기존 간격을 유지하고,
   겹침 방지용으로만 보정한다. */
#detail-body .section-card .p-6[style*="flex-direction:column"] > .overflow-x-auto,
#detail-body .section-card .p-6[style*="flex-direction: column"] > .overflow-x-auto,
#detail-body .section-card .p-6[style*="flex-direction:column"] > div,
#detail-body .section-card .p-6[style*="flex-direction: column"] > div{
  margin-top:0!important;
}
/* D/O 관리 - 정산 처리 버튼 흰색으로 안 보이는 문제 수정 */
.import-ui-do-settle-btn,
button.import-ui-do-settle-btn,
.import-ui-btn.import-ui-do-settle-btn,
.import-ui-btn.secondary.import-ui-do-settle-btn {
  min-width: 92px !important;
  height: 36px !important;
  padding: 0 14px !important;

  background: #334155 !important;
  border: 1px solid #334155 !important;
  color: #ffffff !important;

  font-size: 13px !important;
  font-weight: 800 !important;
  line-height: 36px !important;
  text-align: center !important;

  opacity: 1 !important;
  visibility: visible !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.import-ui-do-settle-btn:hover,
button.import-ui-do-settle-btn:hover,
.import-ui-btn.import-ui-do-settle-btn:hover,
.import-ui-btn.secondary.import-ui-do-settle-btn:hover {
  background: #1e293b !important;
  border-color: #1e293b !important;
  color: #ffffff !important;
}