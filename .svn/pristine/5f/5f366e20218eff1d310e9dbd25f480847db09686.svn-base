package kr.or.tacs.warehouse.inbound.service;

import java.util.HashMap;
import java.util.List;
import java.util.Map;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import kr.or.tacs.dto.warehouse.WarehouseGoodsDTO;
import kr.or.tacs.dto.warehouse.WarehouseWhInRptDTO;
import kr.or.tacs.dto.warehouse.WarehouseZoneDTO;
import kr.or.tacs.warehouse.inbound.mapper.IInboundMapper;

@Service
public class InboundServiceImpl implements IInboundService {

    @Autowired
    private IInboundMapper inboundMapper;
	
    /*
     * 로그인한 창고관리자의 입고 목록만 조회
     */
    @Override
    public List<WarehouseWhInRptDTO> selectInbound(String wmId) {
        return inboundMapper.selectInbound(wmId);
    }

    /*
     * 입고의뢰번호 + 로그인한 창고관리자 기준으로 물품 상세 조회
     */
    @Override
    public List<WarehouseGoodsDTO> selectInboundGoodsList(String wirNo, String wmId) {
        return inboundMapper.selectInboundGoodsList(wirNo, wmId);
    }

    /*
     * 검색 결과 개수도 로그인한 창고관리자 기준으로 count
     *
     * 검색조건과 페이징 조건은 searchDTO 안에 담아서 넘긴다.
     */
    @Override
    public int selectInboundCount(WarehouseWhInRptDTO searchDTO, String wmId) {
        return inboundMapper.selectInboundCount(searchDTO, wmId);
    }

    /*
     * 검색 목록도 로그인한 창고관리자 기준으로 조회
     *
     * PageDTO를 상속한 WarehouseWhInRptDTO를 그대로 Mapper에 넘긴다.
     * 기존 pagingVO.setStartRow(...)는 여기서 하지 않는다.
     * 페이지 계산은 PageDTO 또는 Controller에서 맞춘다.
     */
    @Override
    public List<WarehouseWhInRptDTO> selectInboundList(WarehouseWhInRptDTO searchDTO, String wmId) {
        return inboundMapper.selectInboundList(searchDTO, wmId);
    }

    /*
     * 빈 위치 조회도 로그인한 창고관리자의 구역만 허용
     */
    @Override
    public List<Map<String, Object>> selectEmptyLocations(String zone, String wmId) {
        return inboundMapper.selectEmptyLocations(zone, wmId);
    }

    /*
     * 입고 승인/반려 처리
     * wmId를 같이 넘겨서 본인 입고의뢰만 처리되게 해야 한다.
     */
    @Transactional
    @Override
    public int approveInbound(WarehouseWhInRptDTO whInRptDTO, String wmId) {
        
        String actionStatus = whInRptDTO.getWirStatusCd();
        
        if ("APPROVE".equals(actionStatus)) {
            whInRptDTO.setWirStatusCd("IN_DONE");
            whInRptDTO.setWirWhReplyStatusCd("IN_DONE");
            
            if (whInRptDTO.getGoodsList() != null && !whInRptDTO.getGoodsList().isEmpty()) {
                whInRptDTO.setWirwzno(whInRptDTO.getGoodsList().get(0).getWzNo());
            }
            
            int result = 0;
            
            // 여기만 wmId 추가
            result += inboundMapper.updateInboundApproval(whInRptDTO, wmId);
            
            for (WarehouseGoodsDTO goods : whInRptDTO.getGoodsList()) {
                
                whInRptDTO.setWirwzno(goods.getWzNo());
                whInRptDTO.setLocationCode(goods.getLocationCode());
                
                // 기존 로직 그대로 유지
                result += inboundMapper.insertWarehouseItemLocationByGoods(whInRptDTO, goods);
                
                // 기존 로직 그대로 유지
                result += inboundMapper.insertWarehouseItemByGoods(whInRptDTO, goods);
            }
            
            result += inboundMapper.updateSupplementRequestApprovedByWirNo(whInRptDTO.getWirNo());
            return result;
        }
        
        return 0;
    }

    /*
     * 로그인한 창고관리자의 창고구역 조회
     */
    @Override
    public List<WarehouseZoneDTO> selectMyWarehouseZones(String wmId) {
        return inboundMapper.selectMyWarehouseZones(wmId);
    }

    /**
     * 입고 보완요청 등록
     *
     * 창고관리자가 입고의뢰건에 대해 운송업체에게 보완요청을 남긴다.
     *
     * 저장 흐름:
     * 1. 입고의뢰번호(wirNo) 기준으로 실제 운송업체 ID(TM_ID)를 조회한다.
     * 2. SUPP_RQST에 보완요청 마스터를 등록한다.
     * 3. SUPP_RQST_ITEM에 보완요청 상세 사유를 등록한다.
     *
     * SUPP_RQST와 SUPP_RQST_ITEM은 같이 저장되어야 하므로
     * 하나라도 실패하면 전체 rollback 되도록 @Transactional을 사용한다.
     */
    @Transactional
    @Override
    public int insertSupplementRequest(String wirNo, String reason, String wmId, String sriTyCd) {

        /*
         * 보완유형 검증
         *
         * SUPP_RQST_ITEM.SRI_TY_CD 값
         * DATA : 데이터수정
         * FILE : 파일재제출
         */
        if (!"DATA".equals(sriTyCd) && !"FILE".equals(sriTyCd)) {
            throw new IllegalArgumentException("잘못된 보완유형입니다.");
        }

        /*
         * 입고의뢰번호 기준으로 실제 운송업체 ID를 조회한다.
         *
         * 조회 흐름:
         * WH_IN_RPT
         * → TRAN_RCP
         * → TRANSPORT_MANAGER
         * → TM_ID
         *
         * 이 값이 SUPP_RQST.RECEIVER_ID에 들어간다.
         */
        String receiverId = inboundMapper.selectTransportManagerIdByWirNo(wirNo);

        if (receiverId == null || receiverId.isBlank()) {
            throw new IllegalStateException("입고요청을 보낸 운송업체 ID를 찾을 수 없습니다.");
        }

     
        Map<String, Object> paramMap = new HashMap<>();

        // 보완요청이 어떤 업무/어떤 입고의뢰 건에 대한 것인지 저장하는 기준값
        paramMap.put("srRefBizCd", "WH_IN_RPT");
        paramMap.put("srRefNo", wirNo);

        // WH_IN_RPT 상태 변경 쿼리에서 사용할 기준값
        paramMap.put("wirNo", wirNo);
        paramMap.put("wmId", wmId);

        // 보완요청 발신자/수신자 정보
        paramMap.put("senderId", wmId);
        paramMap.put("senderTyCd", "WAREHOUSE_MANAGER");
        paramMap.put("receiverId", receiverId);
        paramMap.put("receiverTyCd", "TRANSPORT_MANAGER");

        // 보완요청 내용
        paramMap.put("sriTyCd", sriTyCd);
        paramMap.put("srReqCn", reason);

        
        // 같은 입고의뢰 건에대해 보완요청 1번만 할 수있음 재요청 불가 
        int statusResult = inboundMapper.updateWhInRptStatusToReqFix(paramMap);
        
        if(statusResult == 0) {
        	throw new IllegalStateException("이미 보완요청 처리된 건이거나 보완요청 할 수 없는 상태입니다.");
        }
        
        int masterResult = inboundMapper.insertSupplementRequestMaster(paramMap);	// 상태 변경에 성공한 경우에만 보완요청 테이블에 등록한다
       
        
        return statusResult + masterResult;
    }

    
}