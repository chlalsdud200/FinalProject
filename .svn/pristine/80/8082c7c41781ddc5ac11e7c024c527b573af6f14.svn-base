@charset "UTF-8";

/* ── Card Section ── */
.card-section { background: #fff; border: 1px solid #e2e8f0; overflow: hidden; margin-bottom: 20px; }
.card-header { background:#f8fafc; border-bottom:1px solid #e2e8f0; padding:10px 16px; display:flex; justify-content:space-between; align-items:center; }
.card-header h3 { color:#203444; font-size:12px; font-weight:700; letter-spacing:0; }
.card-header button { background:none; border:none; color:#565e74; font-size:11px; font-weight:700; cursor:pointer; padding:0; }
.card-header button:hover { color:#374151; }
