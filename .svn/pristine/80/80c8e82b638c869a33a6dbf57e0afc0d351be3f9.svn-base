// Inventory 페이지 스크립트

var _wh3dConnectedUrl = null;
var _wh3dLoadTimer = null;

function toggle3DView() {
  const view2d = document.getElementById('inventory-2d-view');
  const view3d = document.getElementById('inventory-3d-view');
  const btn = document.getElementById('btn-3d-toggle');

  if (!view2d || !view3d || !btn) return;

  const isClosed = view3d.style.display === 'none' || view3d.style.display === '';

  if (isClosed) {
    view2d.style.display = 'none';
    view3d.style.display = 'block';

    btn.innerHTML =
      '<span class="material-symbols-outlined">table_rows</span>보관 현황 목록 보기';

    ensure3DConnected(true);
  } else {
    view2d.style.display = 'block';
    view3d.style.display = 'none';

    btn.innerHTML =
      '<span class="material-symbols-outlined">3d_rotation</span>3D 창고 보기';
  }
}

function getThreeUrlFromQuery() {
  try {
    const qs = new URLSearchParams(window.location.search);
    const u = (qs.get('threeUrl') || '').trim();
    return u || null;
  } catch (e) {
    return null;
  }
}

function normalizeBaseUrl(u) {
  if (!u) return u;
  return u.endsWith('/') ? u : u + '/';
}

function getDefaultThreeUrl() {
  return normalizeBaseUrl(getThreeUrlFromQuery() || 'http://localhost:5173/admin-react/warehouse3d');
}

/*
 * 3D 창고 보기 버튼으로 iframe을 새로 열 때는
 * React 3D 화면이 항상 허브 화면부터 시작해야 한다.
 *
 * reset=1:
 * - React 쪽에서 sessionStorage에 저장된 내부 창고 상태를 무시하고
 *   허브 화면으로 초기화하기 위한 신호다.
 *
 * t:
 * - 같은 URL로 다시 열 때 브라우저가 iframe을 재사용하지 않도록 하는 값이다.
 */
function getThreeUrlForInventoryOpen() {
  const baseUrl = getDefaultThreeUrl();
  const separator = baseUrl.indexOf('?') > -1 ? '&' : '?';

  return baseUrl + separator + 'reset=1&t=' + Date.now();
}

function open3DInNewTab() {
  const preferred = _wh3dConnectedUrl || getDefaultThreeUrl();
  window.open(preferred, '_blank', 'noopener');
}

function retry3DConnect() {
  ensure3DConnected(true);
}

function ensure3DConnected(forceRetry) {
  const frame = document.getElementById('wh3d-frame');
  const overlay = document.getElementById('wh3d-overlay');
  const status = document.getElementById('wh3d-status');

  if (!frame || !overlay || !status) return;

  overlay.style.display = 'flex';
  status.textContent = '3D 창고 화면을 불러오고 있습니다...';

  if (_wh3dLoadTimer) {
    clearTimeout(_wh3dLoadTimer);
    _wh3dLoadTimer = null;
  }

  const targetUrl = getThreeUrlForInventoryOpen();

  if (!_wh3dConnectedUrl || forceRetry) {
    _wh3dConnectedUrl = targetUrl;
  }

  frame.onload = function () {
    overlay.style.display = 'none';

    if (_wh3dLoadTimer) {
      clearTimeout(_wh3dLoadTimer);
      _wh3dLoadTimer = null;
    }
  };

  if (forceRetry || frame.src === 'about:blank' || frame.src !== _wh3dConnectedUrl) {
    frame.src = _wh3dConnectedUrl;
  }

  status.textContent = '3D 창고 화면을 불러오고 있습니다... (' + _wh3dConnectedUrl + ')';

  _wh3dLoadTimer = setTimeout(function () {
    if (overlay.style.display === 'none') return;

    status.innerHTML =
      '3D 창고 화면이 로드되지 않았습니다. 아래를 확인하세요.<br>' +
      '1) React 3D 프로젝트에서 <b>npm run dev</b> 실행<br>' +
      '2) 터미널의 Local 주소가 <b>http://localhost:5173/</b>인지 확인<br>' +
      '3) 포트가 다르면 주소 뒤에 <b>?threeUrl=http://localhost:5174/</b>처럼 지정<br>' +
      '4) React 파일 <b>BondedWarehouseDigitalTwin_v4.jsx</b>가 App에서 렌더링되는지 확인';
  }, 1800);
}

/**
 * HTML escape 처리
 *
 * 서버에서 내려온 문자열을 테이블에 넣을 때
 * HTML 태그가 실행되지 않도록 방어한다.
 */
function escapeHtml(value) {
  if (value == null) return '';

  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

/**
 * 보세재고 목록 조회
 *
 * page:
 * - 현재 조회할 페이지 번호
 *
 * 화면 검색조건:
 * - zone      : 보관 구역
 * - startDate : 반입 시작일
 * - endDate   : 반입 종료일
 * - keyword   : 입고의뢰번호 / 품명 / 위치코드 검색어
 */
function loadInventoryList(page) {
  const zone = document.getElementById('inventoryZone')?.value || '';
  const startDate = document.getElementById('startDate')?.value || '';
  const endDate = document.getElementById('endDate')?.value || '';
  const keyword = document.getElementById('inventoryKeyword')?.value || '';

  const tbody = document.getElementById('inventoryTableBody');
  if (!tbody) return;

  tbody.innerHTML = `
    <tr>
      <td colspan="9" style="text-align:center; padding:50px 0;">조회 중...</td>
    </tr>
  `;

  const url =
    '/warehouse/inventory/search.do'
    + '?page=' + encodeURIComponent(page || 1)
    + '&zone=' + encodeURIComponent(zone)
    + '&startDate=' + encodeURIComponent(startDate)
    + '&endDate=' + encodeURIComponent(endDate)
    + '&keyword=' + encodeURIComponent(keyword);

  fetch(url)
    .then(response => {
      if (!response.ok) throw new Error('보세재고 목록 조회 실패');
      return response.json();
    })
    .then(data => {
      renderInventoryList(data.dataList, data.currentPage);
      renderInventoryPagination(data);
    })
    .catch(error => {
      console.error(error);

      tbody.innerHTML = `
        <tr>
          <td colspan="9" style="text-align:center; padding:50px 0; color:#ef4444;">
            보세재고 목록 조회 실패
          </td>
        </tr>
      `;
    });
}

/**
 * 보세재고 테이블 렌더링
 *
 * JSP의 기존 컬럼 구조와 동일하게 맞춘다.
 *
 * 컬럼 순서:
 * 입고의뢰번호 | 물품명 | 창고구역번호 | 유형 | 보관위치 | 위치반입일시 | 위치반출일시 | 상태
 */
function renderInventoryList(list, currentPage) {
  const tbody = document.getElementById('inventoryTableBody');
  if (!tbody) return;

  let html = '';
  
  /*
   * 화면 순번 계산
   * 1페이지: 1~10
   * 2페이지: 11~20
   */
  const page = Number(currentPage || 1);
  const pageSize = 10;
  const startNo = (page - 1) * pageSize;

  if (!list || list.length === 0) {
    tbody.innerHTML = `
      <tr>
        <td colspan="9" class="empty-table-result">
          조회하신 재고가 없습니다.
        </td>
      </tr>
    `;
    return;
  }

  list.forEach((item,index) => {
    /*
     * 수입/수출 뱃지
     * JSP에서 쓰는 inventory-badge / type-import / type-export와 동일하게 맞춘다.
     */
    let typeBadge = '<span class="inventory-badge">-</span>';

    if (item.wirIoSeCd === 'IMP' || item.wirIoSeCd === 'IMPORT') {
      typeBadge = '<span class="inventory-badge type-import">수입</span>';
    } else if (item.wirIoSeCd === 'EXP' || item.wirIoSeCd === 'EXPORT') {
      typeBadge = '<span class="inventory-badge type-export">수출</span>';
    }

    /*
     * 상태 뱃지
     * 상태 텍스트는 서버에서 내려온 wiStatusNm 그대로 사용한다.
     * 상태 코드/이름에 따라 CSS class만 결정한다.
     */
    const statusCd = item.wiStatusCd || '';
    const statusNm = item.wiStatusNm || '보관중';

	let statusClass = 'status-wait';

	/*
	 * 반출완료를 입고완료보다 먼저 판단한다.
	 *
	 * 이유:
	 * 반출완료 건도 WI_STATUS_CD는 IN_DONE으로 남아 있을 수 있다.
	 * 이 경우 statusCd를 먼저 보면 입고완료 색으로 잘못 표시된다.
	 * 그래서 서버에서 내려준 상태명(statusNm)이 반출완료이면
	 * 무조건 반출완료 색을 우선 적용한다.
	 */
	if (
	  statusNm === '반출완료' ||
	  statusCd === 'OUT_DONE' ||
	  statusCd === 'REL_DONE' ||
	  item.wilOutDt
	) {
	  statusClass = 'status-out-done';
	} else if (
	  statusCd === 'REJECT' ||
	  statusNm === '반려'
	) {
	  statusClass = 'status-reject';
	} else if (
	  statusCd === 'IN_DONE' ||
	  statusNm === '입고완료' ||
	  statusNm === '보관중'
	) {
	  statusClass = 'status-in-done';
	} else if (
	  statusCd === 'WAIT' ||
	  statusCd === 'SENT' ||
	  statusNm === '입고요청' ||
	  statusNm === '입고대기'
	) {
	  statusClass = 'status-wait';
	}

    const statusBadge = `
      <span class="inventory-badge ${statusClass}">
        ${escapeHtml(statusNm)}
      </span>
    `;

    html += `
      <tr>
	    <td class="td-no">${startNo + index + 1}</td>
        <td>${escapeHtml(item.wirNo)}</td>
        <td>${escapeHtml(item.goodsName)}</td>
        <td>${escapeHtml(item.wilWhZoneNo)}</td>
        <td>${typeBadge}</td>
        <td>${escapeHtml(item.locationCode || item.wilClNo)}</td>
        <td>${escapeHtml(item.wilInDt)}</td>
        <td>${escapeHtml(item.wilOutDt || '-')}</td>
        <td>${statusBadge}</td>
      </tr>
    `;
  });

  tbody.innerHTML = html;
}

/**
 * 보세재고 페이지네이션 렌더링
 */
function renderInventoryPagination(paging) {
  const pagination = document.getElementById('inventoryPagination');

  if (!pagination) return;

  /*
   * 1페이지만 있어도 1 버튼은 보이게 한다.
   */
  if (!paging || !paging.totalPage) {
    pagination.innerHTML = '';
    return;
  }

  const currentPage = Number(paging.currentPage || 1);
  const startPage = Number(paging.startPage || 1);
  const endPage = Number(paging.endPage || paging.totalPage);
  const totalPage = Number(paging.totalPage || 1);

  let html = '';

  if (currentPage > 1) {
    html += `
      <button type="button"
              class="page-btn"
              onclick="loadInventoryList(${currentPage - 1})">
        &lt;
      </button>
    `;
  } else {
    html += `
      <button type="button"
              class="page-btn disabled"
              disabled>
        &lt;
      </button>
    `;
  }

  for (let i = startPage; i <= endPage; i++) {
    html += `
      <button type="button"
              class="page-btn ${i === currentPage ? 'active' : ''}"
              onclick="loadInventoryList(${i})">
        ${i}
      </button>
    `;
  }

  if (currentPage < totalPage) {
    html += `
      <button type="button"
              class="page-btn"
              onclick="loadInventoryList(${currentPage + 1})">
        &gt;
      </button>
    `;
  } else {
    html += `
      <button type="button"
              class="page-btn disabled"
              disabled>
        &gt;
      </button>
    `;
  }

  pagination.innerHTML = html;
}

/**
 * 검색 버튼 / 엔터 / 최초 진입 이벤트 연결
 */
document.addEventListener('click', function (e) {
  const searchBtn = e.target.closest('#inventorySearchBtn');

  if (searchBtn) {
    loadInventoryList(1);
  }
});

document.addEventListener('keydown', function (e) {
  if (e.target && e.target.id === 'inventoryKeyword' && e.key === 'Enter') {
    e.preventDefault();
    loadInventoryList(1);
  }
});

/**
 * 보세재고 조회 화면 초기화
 *
 * 일반 새로고침으로 들어온 경우:
 * - DOMContentLoaded 시점에 실행
 *
 * 사이드바 AJAX 전환으로 들어온 경우:
 * - DOMContentLoaded가 이미 끝난 상태라서 즉시 실행
 */
function initInventoryPage() {
  const tbody = document.getElementById('inventoryTableBody');

  /*
   * 현재 화면이 보세재고 조회 화면이 아니면 실행하지 않는다.
   */
  if (!tbody) {
    return;
  }

  loadInventoryList(1);
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initInventoryPage);
} else {
  initInventoryPage();
}

console.log('Inventory page initialized');