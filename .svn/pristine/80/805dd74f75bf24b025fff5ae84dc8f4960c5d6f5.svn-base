<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<div class="tacs-docs-trash page active" id="pg-docs-trash"
     data-actor-id="${docsActorId}"
     data-actor-type="${docsActorType}"
     data-biz-type="${docsBizType}"
     data-docs-role="${docsRole}"
     style="padding:0;">

  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;gap:16px;flex-wrap:wrap;">
    <div>
      <h1 style="font-size:28px;font-weight:900;color:#0f172a;letter-spacing:-0.5px;margin:0 0 8px;">휴지통</h1>
      <div style="font-size:13px;color:#64748b;">휴지통으로 이동된 항목을 확인하고 영구삭제할 수 있습니다.</div>
    </div>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;justify-content:flex-end;">
      <button class="btn btn-outline" id="btn-trash-empty" onclick="trashEmptyAll()" style="display:flex;align-items:center;gap:4px;padding:7px 11px;border:1px solid #cbd5e1;background:#fff;color:#dc2626;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;">
        <span class="material-symbols-outlined" style="font-size:16px;">delete_forever</span>전체 삭제
      </button>
      <button class="btn btn-primary" id="btn-trash-delete-selected" onclick="trashDeleteSelected()" style="display:flex;align-items:center;gap:4px;padding:7px 11px;border:1px solid #0f172a;background:#0f172a;color:#fff;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;opacity:.5;" disabled>
        <span class="material-symbols-outlined" style="font-size:16px;">delete</span>선택 영구삭제
      </button>
      <button class="btn btn-secondary" id="btn-trash-delete-current" onclick="trashDeleteCurrentList()" style="display:flex;align-items:center;gap:4px;padding:7px 11px;border:1px solid #64748b;background:#64748b;color:#fff;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;">
        <span class="material-symbols-outlined" style="font-size:16px;">delete_sweep</span>현재목록 삭제
      </button>
    </div>
  </div>

  <div id="trash-table-wrap" style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;">
    <table style="width:100%;border-collapse:collapse;text-align:left;font-size:13px;">
      <thead>
        <tr style="background:#f8fafc;border-bottom:1px solid #e2e8f0;">
          <th style="padding:12px 16px;width:40px;text-align:center;">
            <input type="checkbox" id="trash-check-all" onclick="trashToggleAll(this.checked)" style="cursor:pointer;">
          </th>
          <th style="padding:12px 16px;color:#475569;font-weight:600;width:72px;">유형</th>
          <th style="padding:12px 16px;color:#475569;font-weight:600;">이름</th>
          <th style="padding:12px 16px;color:#475569;font-weight:600;width:120px;">크기</th>
          <th style="padding:12px 16px;color:#475569;font-weight:600;width:180px;">휴지통 이동일</th>
        </tr>
      </thead>
      <tbody id="trash-list-body"></tbody>
    </table>
  </div>

  <div id="trash-pagination" style="display:flex;justify-content:center;margin-top:20px;gap:4px;"></div>

  <div id="trash-empty-state" style="display:none;padding:60px 20px;text-align:center;background:#fff;border:1px solid #e2e8f0;border-radius:12px;margin-top:0;">
    <div style="display:flex;justify-content:center;align-items:center;gap:8px;margin-bottom:6px;">
      <span class="material-symbols-outlined" style="font-size:24px;color:#cbd5e1;">delete</span>
      <div style="font-size:16px;font-weight:700;color:#0f172a;">휴지통이 비어 있음</div>
    </div>
    <div style="font-size:13px;color:#64748b;line-height:1.5;">휴지통으로 이동된 항목이 없습니다.</div>
  </div>
</div>

<script>
(function () {
  'use strict';

  window.TrashState = window.TrashState || {
    currentPage: 1,
    selectedIds: new Set(),
    items: []
  };

  function trashEsc(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function trashGetContextPath() {
    if (typeof window.contextPath !== 'undefined') {
      return window.contextPath || '';
    }

    var meta = document.querySelector('meta[name="ctx-path"]');
    if (meta) {
      return meta.getAttribute('content') || '';
    }

    var path = window.location.pathname || '';
    var first = path.split('/').filter(Boolean)[0];
    var actorRoots = ['owner', 'warehouse', 'broker', 'fieldofficer', 'transport', 'officer', 'admin', 'systemadmin'];

    if (first && actorRoots.indexOf(first) === -1) {
      return '/' + first;
    }

    return '';
  }

  function trashIsUsableCsrfValue(value) {
    return !!value && value !== 'undefined' && value !== 'null' && value.indexOf('$' + '{') < 0;
  }

  function trashCsrfHeaders() {
    var tokenEl = document.querySelector('meta[name="_csrf"]');
    var headerEl = document.querySelector('meta[name="_csrf_header"]');
    var token = tokenEl ? tokenEl.getAttribute('content') : '';
    var header = headerEl ? headerEl.getAttribute('content') : '';
    var headers = { 'X-Requested-With': 'XMLHttpRequest' };

    if (trashIsUsableCsrfValue(token) && trashIsUsableCsrfValue(header)) {
      headers[header] = token;
    }

    return headers;
  }

  function trashRequest(url, options) {
    var baseHeaders = trashCsrfHeaders();
    var opt = options || {};
    opt.credentials = 'same-origin';
    opt.headers = Object.assign(baseHeaders, opt.headers || {});

    return fetch(trashGetContextPath() + url, opt).then(function (res) {
      if (!res.ok) {
        return res.text().then(function (text) {
          throw new Error(text || ('HTTP ' + res.status));
        });
      }

      var ct = res.headers.get('content-type') || '';
      if (ct.indexOf('application/json') >= 0) {
        return res.json();
      }

      return res.text();
    });
  }

  function trashFormatSize(size) {
    var n = Number(size || 0);
    if (!n) return '-';

    var units = ['B', 'KB', 'MB', 'GB'];
    var idx = 0;

    while (n >= 1024 && idx < units.length - 1) {
      n = n / 1024;
      idx++;
    }

    return (idx === 0 ? n.toFixed(0) : n.toFixed(1)) + ' ' + units[idx];
  }

  function trashLoad(page) {
    TrashState.currentPage = page || 1;
    TrashState.selectedIds.clear();
    trashUpdateUI();

    trashRequest('/api/docs/trash/list.do?page=' + encodeURIComponent(TrashState.currentPage), { method: 'GET' })
      .then(function (res) {
        trashRenderList(res || {});
      })
      .catch(function (error) {
        console.error(error);
        alert('휴지통 목록을 불러오는데 실패했습니다. 서버 로그에서 /api/docs/trash/list.do 오류를 확인해 주세요.');
        trashRenderEmpty();
      });
  }

  function trashRenderList(pagingVO) {
    TrashState.items = Array.isArray(pagingVO.dataList) ? pagingVO.dataList : [];

    var tbody = document.getElementById('trash-list-body');
    var emptyState = document.getElementById('trash-empty-state');
    var tableWrap = document.getElementById('trash-table-wrap');
    var pagination = document.getElementById('trash-pagination');
    var checkAll = document.getElementById('trash-check-all');

    if (!tbody || !emptyState || !tableWrap || !pagination) return;

    if (TrashState.items.length === 0) {
      trashRenderEmpty();
      return;
    }

    tableWrap.style.display = 'block';
    emptyState.style.display = 'none';

    tbody.innerHTML = TrashState.items.map(function (item) {
      var id = trashEsc(item.id);
      var type = item.type === 'folder' ? 'folder' : 'file';
      var icon = type === 'folder' ? 'folder' : 'description';
      var color = type === 'folder' ? '#6366f1' : '#64748b';

      return '' +
        '<tr style="border-bottom:1px solid #f1f5f9;">' +
        '  <td style="padding:12px 16px;text-align:center;"><input type="checkbox" class="trash-item-chk" value="' + id + '" onclick="trashCheckItem()"></td>' +
        '  <td style="padding:12px 16px;"><span class="material-symbols-outlined" style="color:' + color + ';font-size:20px;vertical-align:middle;">' + icon + '</span></td>' +
        '  <td style="padding:12px 16px;font-weight:500;color:#0f172a;">' + trashEsc(item.name || '-') + '</td>' +
        '  <td style="padding:12px 16px;color:#64748b;">' + trashFormatSize(item.size) + '</td>' +
        '  <td style="padding:12px 16px;color:#64748b;">' + trashEsc(item.trashDt || '-') + '</td>' +
        '</tr>';
    }).join('');

    var pageHtml = '';
    var totalPage = Number(pagingVO.totalPage || 0);
    var startPage = Number(pagingVO.startPage || 1);
    var endPage = Number(pagingVO.endPage || totalPage);
    var currentPage = Number(pagingVO.currentPage || TrashState.currentPage);

    if (totalPage > 0) {
      if (startPage > 1) {
        pageHtml += '<button onclick="trashLoad(' + (startPage - 1) + ')" style="padding:6px 10px;border:1px solid #e2e8f0;background:#fff;border-radius:6px;cursor:pointer;">이전</button>';
      }

      for (var i = startPage; i <= endPage; i++) {
        if (i === currentPage) {
          pageHtml += '<button style="padding:6px 10px;border:1px solid #0f172a;background:#0f172a;color:#fff;border-radius:6px;cursor:default;font-weight:700;">' + i + '</button>';
        } else {
          pageHtml += '<button onclick="trashLoad(' + i + ')" style="padding:6px 10px;border:1px solid #e2e8f0;background:#fff;border-radius:6px;cursor:pointer;">' + i + '</button>';
        }
      }

      if (endPage < totalPage) {
        pageHtml += '<button onclick="trashLoad(' + (endPage + 1) + ')" style="padding:6px 10px;border:1px solid #e2e8f0;background:#fff;border-radius:6px;cursor:pointer;">다음</button>';
      }
    }

    pagination.innerHTML = pageHtml;
    if (checkAll) checkAll.checked = false;
    trashUpdateUI();
  }

  function trashRenderEmpty() {
    var tbody = document.getElementById('trash-list-body');
    var emptyState = document.getElementById('trash-empty-state');
    var tableWrap = document.getElementById('trash-table-wrap');
    var pagination = document.getElementById('trash-pagination');

    TrashState.items = [];
    TrashState.selectedIds.clear();

    if (tbody) tbody.innerHTML = '';
    if (tableWrap) tableWrap.style.display = 'none';
    if (emptyState) emptyState.style.display = 'block';
    if (pagination) pagination.innerHTML = '';

    trashUpdateUI();
  }

  function trashToggleAll(checked) {
    var chks = document.querySelectorAll('.trash-item-chk');
    TrashState.selectedIds.clear();

    chks.forEach(function (chk) {
      chk.checked = checked;
      if (checked) {
        TrashState.selectedIds.add(chk.value);
      }
    });

    trashUpdateUI();
  }

  function trashCheckItem() {
    var chks = document.querySelectorAll('.trash-item-chk');
    var allChecked = chks.length > 0;

    TrashState.selectedIds.clear();

    chks.forEach(function (chk) {
      if (chk.checked) {
        TrashState.selectedIds.add(chk.value);
      } else {
        allChecked = false;
      }
    });

    var checkAll = document.getElementById('trash-check-all');
    if (checkAll) checkAll.checked = allChecked;

    trashUpdateUI();
  }

  function trashUpdateUI() {
    var selectedBtn = document.getElementById('btn-trash-delete-selected');
    var currentBtn = document.getElementById('btn-trash-delete-current');
    var emptyBtn = document.getElementById('btn-trash-empty');
    var hasSelected = TrashState.selectedIds.size > 0;
    var hasItems = TrashState.items.length > 0;

    if (selectedBtn) {
      selectedBtn.disabled = !hasSelected;
      selectedBtn.style.opacity = hasSelected ? '1' : '.5';
    }

    [currentBtn, emptyBtn].forEach(function (btn) {
      if (!btn) return;
      btn.disabled = !hasItems;
      btn.style.opacity = hasItems ? '1' : '.5';
      btn.style.cursor = hasItems ? 'pointer' : 'not-allowed';
    });
  }

  function trashEmptyAll() {
    if (TrashState.items.length === 0) {
      alert('휴지통에 삭제할 항목이 없습니다.');
      return;
    }

    if (!confirm('휴지통을 비우시겠습니까?\n모든 항목이 영구적으로 삭제되며 복구할 수 없습니다.')) return;

    trashRequest('/api/docs/trash/all.do', { method: 'DELETE' })
      .then(function () {
        alert('휴지통을 비웠습니다.');
        trashLoad(1);
      })
      .catch(function (error) {
        console.error(error);
        alert('처리 중 오류가 발생했습니다.');
      });
  }

  function trashDeleteSelected() {
    if (TrashState.selectedIds.size === 0) return;
    if (!confirm('선택한 항목을 영구적으로 삭제하시겠습니까?')) return;

    trashDeleteIds(Array.from(TrashState.selectedIds), TrashState.currentPage, '선택한 항목이 영구 삭제되었습니다.');
  }

  function trashDeleteCurrentList() {
    if (TrashState.items.length === 0) {
      alert('현재 목록에 삭제할 항목이 없습니다.');
      return;
    }

    if (!confirm('현재 페이지의 목록을 영구적으로 삭제하시겠습니까?')) return;

    var ids = TrashState.items.map(function (item) { return item.id; });
    trashDeleteIds(ids, TrashState.currentPage, '현재 목록의 항목들이 영구 삭제되었습니다.');
  }

  function trashDeleteIds(ids, page, message) {
    trashRequest('/api/docs/trash/items.do', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids: ids })
    })
      .then(function () {
        alert(message);
        trashLoad(page || 1);
      })
      .catch(function (error) {
        console.error(error);
        alert('처리 중 오류가 발생했습니다.');
      });
  }

  window.trashLoad = trashLoad;
  window.trashRenderList = trashRenderList;
  window.trashRenderEmpty = trashRenderEmpty;
  window.trashToggleAll = trashToggleAll;
  window.trashCheckItem = trashCheckItem;
  window.trashUpdateUI = trashUpdateUI;
  window.trashEmptyAll = trashEmptyAll;
  window.trashDeleteSelected = trashDeleteSelected;
  window.trashDeleteCurrentList = trashDeleteCurrentList;

  function trashBoot() {
    if (document.getElementById('pg-docs-trash')) {
      trashLoad(1);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', trashBoot);
  } else {
    trashBoot();
  }
})();
</script>
