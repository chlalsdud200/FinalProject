/* TACS_IMPORT_INBOUND_CLEAN_V5_20260518: 수입 보세구역 입고관리 화면 단일 렌더 기준 정리본. */
function resolveActionButtonLabel(item, fallbackLabel) {
    const title = item?.title || '';
    const exactMap = {
        '선적배차처리': '처리',
        '화물 검수 체크리스트': '처리',
        '보세구역 반입 처리': '처리',
        '선적지시서 작성 및 제출': '처리',
        '적하목록 작성 및 제출': '처리',
        '도착통지서 발송': '처리',
        '적하목록 작성 및 제출': '처리',
        'B/L 정정 신청': '처리',
        '보세구역 입고관리': '처리',
        '통관용 서류 전달': '처리',
        'Free Time 및 추가비용 관리': '처리',
        '선적 서류 보완요청': '보완'
    };
    return exactMap[title] || fallbackLabel;
}


function buildBondedCargoRowHtml(line = {}) {
    const value = (key) => line[key] || '';
    return `
    <tr class="bonded-cargo-line bg-white">
      <td class="text-center align-middle"><input type="checkbox" class="bonded-cargo-check h-4 w-4 border-slate-300" /></td>
      <td><input class="field-input min-w-[100px]" type="text" value="${value('cgNo') || value('shippingMark')}" placeholder="화물번호" /></td>
      <td><input class="field-input min-w-[110px]" type="text" value="${value('goodsDesc') || value('goodsNo')}" placeholder="품목명" /></td>
      <td><input class="field-input min-w-[90px]" type="number" value="${value('qty')}" placeholder="수량" /></td>
      <td><input class="field-input min-w-[110px]" type="text" value="${value('unitPrice')}" placeholder="단가" /></td>
      <td><input class="field-input min-w-[120px]" type="text" value="${value('amount')}" placeholder="총액" /></td>
      <td><input class="field-input min-w-[100px]" type="text" value="${value('weight')}" placeholder="중량" /></td>
      <td><input class="field-input min-w-[90px]" type="text" value="${value('origin')}" placeholder="원산지" /></td>
    </tr>
  `;
}


function escapeImportInboundHtml(value) {
    return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function isImportInboundSupplementRequested(row) {
    const statusText = String(
        row?.listStatus ||
        row?.requestStatus ||
        row?.statusNm ||
        row?.statusCd ||
        row?.warehouseReplyStatus ||
        row?.warehouseReplyStatusCd ||
        ''
    ).trim();
    return ['보완요청', 'REQ_FIX', 'FIX_REQ', 'SUPPLEMENT', 'SUPPLEMENT_REQUESTED'].includes(statusText);
}

function buildImportInboundSupplementNoticeHtml(row) {
    row = row || {};
    // DB SUPP_RQST_ITEM.SRI_REQ_CN 이 매퍼에서 suppReqCn / rejectReason 으로 내려온 값을 그대로 표시한다.
    const message = row.suppReqCn || row.rejectReason || row.supplementReason || row.rejectMemo || row.sriReqCn || '';
    const hasMessage = String(message || '').trim();
    if (!hasMessage) {
        return '';
    }
    return `
          <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900 import-inbound-supp-notice">
            <div class="flex items-start gap-3">
              <div class="mt-0.5 h-2 w-2 rounded-full bg-amber-500 flex-shrink-0"></div>
              <div class="min-w-0">
                <div class="font-black">창고 보완요청 메시지</div>
                <div class="mt-1 whitespace-pre-wrap break-words leading-6">${escapeImportInboundHtml(message)}</div>
              </div>
            </div>
          </div>
    `;
}

function mergeImportInboundDetailRow(baseRow, detailRow) {
    baseRow = baseRow || {};
    detailRow = detailRow || {};
    const merged = Object.assign({}, baseRow, detailRow);
    const msg = detailRow.suppReqCn || detailRow.rejectReason || detailRow.supplementReason || detailRow.sriReqCn || baseRow.suppReqCn || baseRow.rejectReason || baseRow.supplementReason || '';
    if (msg) {
        merged.suppReqCn = msg;
        merged.rejectReason = msg;
    }
    merged.listStatus = normalizeImportWarehouseInStatus(merged);
    merged.requestStatus = merged.listStatus;
    merged.inboundRequestNo = merged.inboundRequestNo || merged.wirNo || baseRow.inboundRequestNo || baseRow.wirNo || '';
    return merged;
}

function fetchImportInboundDetailForMessage(row) {
    row = row || {};
    const wirNo = row.wirNo || row.inboundRequestNo || '';
    if (!wirNo) return Promise.resolve(row);
    const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';
    return fetch(contextPath + '/transport/import/unloading-in/detail.do?wirNo=' + encodeURIComponent(wirNo) + '&_=' + Date.now(), {
        method: 'GET',
        headers: {'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        cache: 'no-store'
    })
        .then(function (res) { return res.ok ? res.json() : row; })
        .then(function (detail) { return mergeImportInboundDetailRow(row, detail); })
        .catch(function () { return row; });
}

function buildBondedCargoWorkPanel(config) {
    window.bondedPanelRows = window.bondedPanelRows || {};
    window.bondedPanelRows[config.itemId] = config.rows || [];

    const rows = config.rows || [];
    const selected = rows[0] || {};
    const optionHtml = (options = [], selectedValue = '') => options.map(opt => {
        const value = typeof opt === 'object' ? String(opt.value || '') : String(opt || '');
        const label = typeof opt === 'object' ? String(opt.label || opt.value || '') : String(opt || '');
        return `<option value="${value}" ${value === String(selectedValue || '') ? 'selected' : ''}>${label}</option>`;
    }).join('');
    const fieldHtml = (field) => {
        const value = selected[field.key] || field.value || '';
        const readonlyClass = field.readonly ? 'bg-slate-50' : '';
        if (field.type === 'select') {
            return `
        <div class="${field.span || ''}">
          <label class="field-label">${field.label}</label>
          <select class="field-select ${field.key === 'targetWarehouse' ? 'unloading-warehouse-manager' : ''} ${readonlyClass}" data-bonded-field="${field.key}">
            ${optionHtml(field.options || [], value)}
          </select>
        </div>
      `;
        }
        if (field.type === 'textarea') {
            return `
        <div class="${field.span || 'md:col-span-3'}">
          <label class="field-label">${field.label}</label>
          <textarea class="field-textarea h-20 ${readonlyClass}" data-bonded-field="${field.key}" ${field.readonly ? 'readonly' : ''} placeholder="${field.placeholder || ''}">${value}</textarea>
        </div>
      `;
        }
        return `
      <div class="${field.span || ''}">
        <label class="field-label">${field.label}</label>
        <input class="field-input ${readonlyClass}" data-bonded-field="${field.key}" type="${field.inputType || 'text'}" value="${value}" ${field.readonly ? 'readonly' : ''} placeholder="${field.placeholder || ''}" />
      </div>
    `;
    };

    const listTableHtml = config.inboundRequestTitle ? `
          <div class="overflow-hidden border border-slate-200 rounded-sm">
            <table class="w-full tbl table-fixed bonded-list-table text-[11px]">
              <thead>
                <tr>
                  <th class="px-3 text-left" style="width:34%;">요청번호</th>
                  <th class="px-3 text-left" style="width:25%;">화주 / 화물관리번호</th>
                  <th class="px-2 text-center" style="width:17%;">${config.dateTitle || '일시'}</th>
                  <th class="px-2 text-center" style="width:12%;">상태</th>
                  <th class="px-2 text-center" style="width:12%;">처리</th>
                </tr>
              </thead>
              <tbody class="text-[11px] text-slate-700">
                ${rows.map((row, idx) => `
                  <tr class="bonded-list-row ${idx === 0 ? 'bg-blue-50' : ''}" data-bonded-list-row="${idx}">
                    <td class="px-3 py-3 align-top">
                      <div class="text-[10px] font-bold text-slate-500 leading-4">운송의뢰번호</div>
                      <div class="font-black text-slate-900 leading-5 break-all">${row.requestNo || ''}</div>
                      <div class="mt-1 text-[10px] font-bold text-slate-500 leading-4">입고의뢰번호</div>
                      <div class="font-semibold text-slate-700 leading-5 break-all">${row.inboundRequestNo || row.wirNo || ''}</div>
                    </td>
                    <td class="px-3 py-3 align-top">
                      <div class="font-bold text-slate-900 leading-5 break-keep">${row.owner || ''}</div>
                      <div class="mt-1 text-[10px] font-bold text-slate-500 leading-4">화물관리번호</div>
                      <div class="font-semibold text-slate-700 leading-5 break-all">${row.listParty || ''}</div>
                    </td>
                    <td class="px-2 py-3 text-center align-middle leading-5 break-keep">${String(row.listAt || '').replace(' ', '<br>')}</td>
                    <td class="bonded-list-status-cell px-2 py-3 text-center align-middle"><span class="info-chip text-[11px] px-2 py-1 whitespace-nowrap">${row.listStatus || ''}</span></td>
                    <td class="px-2 py-3 text-center align-middle"><button type="button" class="bonded-row-select px-2 py-1 bg-primary text-white text-[11px] font-bold hover:bg-primary-dim whitespace-nowrap" data-row-index="${idx}">선택</button></td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
    ` : `
          <div class="overflow-x-auto">
            <table class="w-full tbl table-fixed bonded-list-table text-[11px]">
              <thead>
                <tr>
                  <th class="whitespace-nowrap px-2" style="width:118px;">${config.requestTitle || '의뢰번호'}</th>
                  <th class="whitespace-nowrap px-2" style="width:82px;">화주명</th>
                  <th class="whitespace-nowrap px-2" style="width:145px;">${config.partyTitle || '상대방'}</th>
                  <th class="whitespace-nowrap px-2" style="width:104px;">${config.dateTitle || '일시'}</th>
                  <th class="whitespace-nowrap px-2" style="width:70px;">상태</th>
                  <th class="text-center whitespace-nowrap px-2" style="width:64px;">처리</th>
                </tr>
              </thead>
              <tbody class="text-[11px] text-slate-700">
                ${rows.map((row, idx) => `
                  <tr class="bonded-list-row ${idx === 0 ? 'bg-blue-50' : ''}" data-bonded-list-row="${idx}">
                    <td class="font-bold whitespace-nowrap px-2 leading-5">${row.requestNo || ''}</td>
                    <td class="whitespace-nowrap px-2 leading-5">${row.owner || ''}</td>
                    <td class="whitespace-nowrap px-2 leading-5">${row.listParty || ''}</td>
                    <td class="whitespace-nowrap px-2 leading-5">${row.listAt || ''}</td>
                    <td class="bonded-list-status-cell whitespace-nowrap px-2"><span class="info-chip text-[11px] px-2 py-1">${row.listStatus || ''}</span></td>
                    <td class="text-center whitespace-nowrap px-2"><button type="button" class="bonded-row-select px-2 py-1 bg-primary text-white text-[11px] font-bold hover:bg-primary-dim" data-row-index="${idx}">선택</button></td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
    `;

    if (config.itemId === 'TACS-FW-009') {
        const releaseListRows = rows.map((row, idx) => `
                  <tr class="bonded-list-row ${idx === 0 ? 'bg-blue-50' : ''}" data-bonded-list-row="${idx}">
                    <td class="font-bold px-3 py-3 leading-5">${row.requestNo || ''}</td>
                    <td class="px-3 py-3 leading-5">${row.owner || ''}</td>
                    <td class="px-3 py-3 leading-5">${row.listParty || ''}</td>
                    <td class="px-3 py-3 leading-5">${row.listAt || ''}</td>
                    <td class="bonded-list-status-cell px-3 py-3"><span class="info-chip text-[11px] px-2 py-1">${row.listStatus || ''}</span></td>
                    <td class="text-center px-3 py-3"><button type="button" class="bonded-row-select px-3 py-1 bg-primary text-white text-xs font-bold hover:bg-primary-dim" data-row-index="${idx}">등록</button></td>
                  </tr>
        `).join('');
        const registeredRows = rows.filter(row => String(row.listStatus || row.releaseStatus || '') === String(config.completeStatus || '반출완료'));
        const registeredHtml = registeredRows.length ? registeredRows.map(row => `
                  <tr>
                    <td class="font-bold px-3 py-3 leading-5">${formatImportReleaseReqNo(row)}</td>
                    <td class="px-3 py-3 leading-5">${row.owner || ''}</td>
                    <td class="px-3 py-3 leading-5">${row.cargoMgmtNo || '-'}</td>
                    <td class="px-3 py-3 leading-5">${row.targetWarehouse || row.listParty || ''}</td>
                    <td class="px-3 py-3 leading-5">${row.releasePlanDt || row.listAt || ''}</td>
                    <td class="px-3 py-3"><span class="info-chip text-[11px] px-2 py-1">${row.releaseStatus || row.listStatus || ''}</span></td>
                    <td class="text-center px-3 py-3"><button type="button" class="bonded-row-select px-3 py-1 border border-slate-300 bg-slate-700 text-white text-xs font-bold" data-row-index="${rows.indexOf(row)}">조회</button></td>
                  </tr>
        `).join('') : '<tr><td colspan="7" class="text-center text-slate-500 py-6">반출요청 등록 내역이 없습니다.</td></tr>';

        return `
    <div class="space-y-4 bonded-work-panel" data-item-id="${config.itemId}" data-complete-status="${config.completeStatus || '전송완료'}" data-status-field="${config.statusField || 'requestStatus'}" data-submit-message="${config.submitMessage || '창고관리자에게 요청 정보가 전송되었습니다.'}" data-request-title="${config.requestTitle || '의뢰'}">
      <div class="section-card overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between">
          <div>
            <h4 class="text-sm font-bold text-slate-900">${config.listTitle}</h4>
            <p class="mt-1 text-xs text-slate-600">${config.listDesc}</p>
          </div>
          <button type="button" class="bonded-search-btn px-4 py-2 bg-primary text-white text-xs font-bold hover:bg-primary-dim">조회</button>
        </div>
        <div class="p-5 space-y-3">
          <h5 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">반출요청 대상 목록</h5>
          <div class="overflow-x-auto border border-slate-200">
            <table class="w-full tbl min-w-[900px] text-xs">
              <thead>
                <tr>
                  <th>의뢰번호</th>
                  <th>화주명</th>
                  <th>${config.partyTitle || '상대방'}</th>
                  <th>${config.dateTitle || '일시'}</th>
                  <th>상태</th>
                  <th>처리</th>
                </tr>
              </thead>
              <tbody class="text-slate-700">${releaseListRows}</tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="section-card overflow-hidden bonded-form-card hidden">
        <div class="bg-slate-900 px-5 py-4 text-white">
          <h4 class="text-sm font-black">${config.formTitle}</h4>
          <p class="mt-1 text-xs text-slate-200">${config.formDesc}</p>
        </div>
        <div class="p-5 space-y-5">
          <div class="text-xs font-bold text-slate-600 bonded-selected-info">선택된 ${config.requestTitle || '의뢰'} : ${selected.requestNo || '-'}</div>
          <div class="import-inbound-supp-notice-wrap">${buildImportInboundSupplementNoticeHtml(selected)}</div>

          <div>
            <h5 class="text-sm font-black text-slate-900 mb-3 border-l-4 border-slate-800 pl-3">1. ${config.infoTitle}</h5>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
              ${config.fields.map(fieldHtml).join('')}
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between gap-2 mb-3">
              <h5 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">2. 화물 정보</h5>
              <div class="flex gap-2">
                <button type="button" class="bonded-add-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">+ 행추가</button>
                <button type="button" class="bonded-select-all-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">전체선택</button>
                <button type="button" class="bonded-delete-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">선택삭제</button>
              </div>
            </div>
            <div class="overflow-x-auto border border-slate-200">
              <table class="w-full tbl min-w-[920px]">
                <thead>
                  <tr>
                    <th class="text-center" style="width:48px;">선택</th>
                    <th>화물번호<br><span class="text-[10px] font-semibold text-slate-500">CG_NO</span></th>
                    <th>품목명<br><span class="text-[10px] font-semibold text-slate-500">GOODS_NAME</span></th>
                    <th>수량<br><span class="text-[10px] font-semibold text-slate-500">CG_QTY</span></th>
                    <th>단가<br><span class="text-[10px] font-semibold text-slate-500">CG_PRICE</span></th>
                    <th>총액<br><span class="text-[10px] font-semibold text-slate-500">CG_TOTAL_PRICE</span></th>
                    <th>중량<br><span class="text-[10px] font-semibold text-slate-500">CG_WEIGHT</span></th>
                    <th>원산지<br><span class="text-[10px] font-semibold text-slate-500">CG_ORIGIN</span></th>
                  </tr>
                </thead>
                <tbody class="bonded-cargo-tbody text-sm text-slate-700">
                  ${(selected.cargo || [{}]).map(line => buildBondedCargoRowHtml(line)).join('')}
                </tbody>
              </table>
            </div>
          </div>

          <div>
            <h5 class="text-sm font-black text-slate-900 mb-3 border-l-4 border-slate-800 pl-3">3. 요청사항</h5>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div>
                <label class="field-label">요청사항</label>
                <textarea class="field-textarea h-24" data-bonded-field="requestNote" placeholder="창고관리자에게 전달할 요청사항 입력">${selected.requestNote || ''}</textarea>
              </div>
              <div>
                <label class="field-label">창고 보완요청/반려사유</label>
                <textarea class="field-textarea h-24 bg-slate-50" data-bonded-field="rejectReason" readonly placeholder="보완요청 또는 반려 건 선택 시 창고관리자 메시지 자동 표시">${selected.rejectReason || ''}</textarea>
              </div>
            </div>
          </div>
        </div>
        <div class="section-card-action-footer flex justify-end gap-2 px-5 py-4 border-t border-slate-200">
          <button type="button" class="bonded-submit px-4 py-2 bg-primary text-white text-xs font-bold hover:bg-primary-dim">${config.submitLabel || '전송'}</button>
        </div>
      </div>

      <div class="section-card overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">
          <h4 class="text-sm font-bold text-slate-900">반출요청 등록 목록</h4>
          <p class="mt-1 text-xs text-slate-600">창고관리자에게 반출요청이 전송된 내역입니다.</p>
        </div>
        <div class="p-5 overflow-x-auto">
          <table class="w-full tbl min-w-[900px] text-xs">
            <thead><tr><th>반출요청번호</th><th>화주명</th><th>화물관리번호</th><th>전달대상</th><th>반출일시</th><th>상태</th><th>처리</th></tr></thead>
            <tbody class="bonded-registered-tbody">${registeredHtml}</tbody>
          </table>
        </div>
      </div>
    </div>
  `;
    }

    return `
    <div class="grid grid-cols-1 2xl:grid-cols-[1.05fr_0.95fr] gap-4 bonded-work-panel" data-item-id="${config.itemId}" data-complete-status="${config.completeStatus || '전송완료'}" data-status-field="${config.statusField || 'requestStatus'}" data-submit-message="${config.submitMessage || '창고관리자에게 요청 정보가 전송되었습니다.'}" data-request-title="${config.requestTitle || '의뢰'}">
      <div class="section-card overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">
          <h4 class="text-sm font-bold text-slate-900">${config.listTitle}</h4>
          <p class="mt-1 text-xs text-slate-600">${config.listDesc}</p>
        </div>
        <div class="p-5 space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1fr_1fr_auto] gap-3">
            <div><label class="field-label">${config.requestTitle || '의뢰번호'}</label><input class="field-input bonded-search-request" type="text" placeholder="${config.requestTitle || '의뢰번호'} 입력" /></div>
            <div><label class="field-label">화주명</label><input class="field-input bonded-search-owner" type="text" placeholder="화주명 입력" /></div>
            <div><label class="field-label">${config.partyTitle || '상대방'}</label><input class="field-input bonded-search-party" type="text" placeholder="${config.partyTitle || '상대방'} 입력" /></div>
            <div><label class="field-label">${config.dateTitle || '일자'}</label><input class="field-input bonded-search-date" type="date" /></div>
            <div class="flex items-end"><button type="button" class="bonded-search-btn w-full md:w-auto px-4 py-2 bg-primary text-white text-xs font-bold hover:bg-primary-dim">조회</button></div>
          </div>
${listTableHtml}
        </div>
      </div>

      <div class="section-card overflow-hidden">
        <div class="bg-slate-900 px-5 py-4 text-white">
          <h4 class="text-sm font-black">${config.formTitle}</h4>
          <p class="mt-1 text-xs text-slate-200">${config.formDesc}</p>
        </div>
        <div class="p-5 space-y-5">
          <div class="text-xs font-bold text-slate-600 bonded-selected-info">선택된 ${config.requestTitle || '의뢰'} : ${selected.requestNo || '-'}</div>
          <div class="import-inbound-supp-notice-wrap">${buildImportInboundSupplementNoticeHtml(selected)}</div>

          <div>
            <h5 class="text-sm font-black text-slate-900 mb-3 border-l-4 border-slate-800 pl-3">1. ${config.infoTitle}</h5>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
              ${config.fields.map(fieldHtml).join('')}
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between gap-2 mb-3">
              <h5 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">2. 화물 정보</h5>
              <div class="flex gap-2">
                <button type="button" class="bonded-add-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">+ 행추가</button>
                <button type="button" class="bonded-select-all-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">전체선택</button>
                <button type="button" class="bonded-delete-line px-3 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">선택삭제</button>
              </div>
            </div>
            <div class="overflow-x-auto border border-slate-200">
              <table class="w-full tbl min-w-[920px]">
                <thead>
                  <tr>
                    <th class="text-center" style="width:48px;">선택</th>
                    <th>화물번호<br><span class="text-[10px] font-semibold text-slate-500">CG_NO</span></th>
                    <th>품목명<br><span class="text-[10px] font-semibold text-slate-500">GOODS_NAME</span></th>
                    <th>수량<br><span class="text-[10px] font-semibold text-slate-500">CG_QTY</span></th>
                    <th>단가<br><span class="text-[10px] font-semibold text-slate-500">CG_PRICE</span></th>
                    <th>총액<br><span class="text-[10px] font-semibold text-slate-500">CG_TOTAL_PRICE</span></th>
                    <th>중량<br><span class="text-[10px] font-semibold text-slate-500">CG_WEIGHT</span></th>
                    <th>원산지<br><span class="text-[10px] font-semibold text-slate-500">CG_ORIGIN</span></th>
                  </tr>
                </thead>
                <tbody class="bonded-cargo-tbody text-sm text-slate-700">
                  ${(selected.cargo || [{}]).map(line => buildBondedCargoRowHtml(line)).join('')}
                </tbody>
              </table>
            </div>
          </div>

          <div>
            <h5 class="text-sm font-black text-slate-900 mb-3 border-l-4 border-slate-800 pl-3">3. 요청사항</h5>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div>
                <label class="field-label">요청사항</label>
                <textarea class="field-textarea h-24" data-bonded-field="requestNote" placeholder="창고관리자에게 전달할 요청사항 입력">${selected.requestNote || ''}</textarea>
              </div>
              <div>
                <label class="field-label">창고 보완요청/반려사유</label>
                <textarea class="field-textarea h-24 bg-slate-50" data-bonded-field="rejectReason" readonly placeholder="보완요청 또는 반려 건 선택 시 창고관리자 메시지 자동 표시">${selected.rejectReason || ''}</textarea>
              </div>
            </div>
          </div>
        </div>
        <div class="section-card-action-footer flex justify-end gap-2 px-5 py-4 border-t border-slate-200">
          <button type="button" class="bonded-submit px-4 py-2 bg-primary text-white text-xs font-bold hover:bg-primary-dim">${config.submitLabel || '전송'}</button>
        </div>
      </div>
    </div>
  `;
}

function getLegacyExportInboundRows() {
    const source = window.TRANSPORT_EXPORT_INBOUND_REQUESTS || [];
    return Array.isArray(source) ? source.map(row => ({
        ...row,
        cargo: row.cargo && row.cargo.length ? row.cargo : []
    })) : [];
}

function getLegacyExportReleaseRows() {
    const source = window.TRANSPORT_EXPORT_RELEASE_REQUESTS
        || window.TRANSPORT_EXPORT_RELEASE_LIST
        || window.TRANSPORT_EXPORT_RELEASE_ROWS
        || [];
    return Array.isArray(source) ? source.map(row => ({
        ...row,
        cargo: row.cargo && row.cargo.length ? row.cargo : []
    })) : [];
}

function buildExportInboundManagePanel() {
    return buildBondedCargoWorkPanel({
        itemId: 'TACS-FW-009B',
        listTitle: '보세구역 입고관리',
        listDesc: '수락 완료된 수출 운송의뢰를 선택하면 오른쪽에 입고요청 정보와 화물정보 입력창이 함께 표시됩니다.',
        partyTitle: '거래자',
        dateTitle: '입고요청일',
        formTitle: '수출 보세구역 입고관리',
        formDesc: '상업송장·포장명세서 기준으로 입고요청 정보와 화물 정보를 작성해 창고관리자에게 전송합니다.',
        infoTitle: '입고요청 정보',
        completeStatus: '입고완료',
        statusField: 'requestStatus',
        submitLabel: '전송',
        submitMessage: '수출 보세구역 입고요청 정보가 창고관리자에게 전송되었습니다.',
        fields: [
            {key: 'requestNo', label: '의뢰번호', readonly: true},
            {key: 'masterBlNo', label: 'Master B/L 번호', readonly: true},
            {key: 'warehouseManagerId', label: '창고관리자ID', readonly: true},
            {key: 'warehouseNo', label: '창고번호', readonly: true},
            {key: 'inboundPlanDt', label: '입고요청일', readonly: true},
            {
                key: 'targetWarehouse',
                label: '전달대상',
                type: 'select',
                options: ['인천항 보세창고 관리자', '부산항 보세창고 관리자', '평택항 보세창고 관리자']
            },
            {key: 'invoiceNo', label: '송장번호'},
            {key: 'shipper', label: '화주'},
            {key: 'consignee', label: '거래자'}
        ],
        rows: getLegacyExportInboundRows()
    });
}


function bindBondedWorkPanelActions(groupKey, itemId) {
    // detailBody가 지역변수로만 존재하는 화면에서도 반출요청/입고관리 바인딩이 죽지 않게 현재 DOM에서 다시 찾는다.
    const currentDetailBody = document.getElementById('detail-body') || (typeof detailBody !== 'undefined' ? detailBody : null);
    if (!currentDetailBody) return;

    const root = currentDetailBody.querySelector(`.bonded-work-panel[data-item-id="${itemId}"]`);
    if (!root) return;

    const rows = (window.bondedPanelRows && window.bondedPanelRows[itemId]) || [];
    let selectedIndex = 0;

    const applySearchFilter = () => {
        const requestText = (root.querySelector('.bonded-search-request')?.value || '').trim().toLowerCase();
        const ownerText = (root.querySelector('.bonded-search-owner')?.value || '').trim().toLowerCase();
        const partyText = (root.querySelector('.bonded-search-party')?.value || '').trim().toLowerCase();
        const dateText = (root.querySelector('.bonded-search-date')?.value || '').trim().toLowerCase();

        root.querySelectorAll('.bonded-list-row').forEach((tr) => {
            const row = rows[Number(tr.getAttribute('data-bonded-list-row') || 0)] || {};
            const visible =
                (!requestText || String(row.requestNo || '').toLowerCase().includes(requestText)) &&
                (!ownerText || String(row.owner || '').toLowerCase().includes(ownerText)) &&
                (!partyText || String(row.listParty || '').toLowerCase().includes(partyText)) &&
                (!dateText || String(row.listAt || '').toLowerCase().includes(dateText));
            tr.classList.toggle('hidden', !visible);
        });
    };

    const fillPanel = (row) => {
        if (!row) return;
        root.querySelectorAll('[data-bonded-field]').forEach((el) => {
            const key = el.getAttribute('data-bonded-field');
            if (!key) return;

            // 수입 보세구역 입고관리의 전달대상 select는 운송담당자가 직접 선택해야 하므로
            // 이전 readonly hotfix나 선택 row 갱신 과정에서 disabled/readonly가 남지 않게 풀어준다.
            if (key === 'targetWarehouse') {
                const managerValue = row.targetWarehouse || row.bondedManagerId || row.wmId || row.wirWmId || '';
                el.disabled = false;
                el.removeAttribute('disabled');
                el.removeAttribute('readonly');
                el.classList.remove('bg-slate-50');
                el.value = managerValue;
                if (managerValue && el.value !== String(managerValue)) {
                    el.insertAdjacentHTML('beforeend', `<option value="${managerValue}" selected>${row.targetWarehouseNm || row.bondedManagerNm || row.warehouseManagerNm || managerValue}</option>`);
                    el.value = managerValue;
                }
                return;
            }

            el.value = row[key] || '';
        });
        const tbody = root.querySelector('.bonded-cargo-tbody');
        if (tbody) tbody.innerHTML = (row.cargo && row.cargo.length ? row.cargo : [{}]).map(line => buildBondedCargoRowHtml(line)).join('');
        const selectedInfo = root.querySelector('.bonded-selected-info');
        if (selectedInfo) selectedInfo.textContent = `선택된 ${root.dataset.requestTitle || '의뢰'} : ${row.requestNo || '-'}`;

        const suppNoticeWrap = root.querySelector('.import-inbound-supp-notice-wrap');
        if (suppNoticeWrap) suppNoticeWrap.innerHTML = buildImportInboundSupplementNoticeHtml(row);
    };

    root.querySelectorAll('.bonded-row-select').forEach((btn) => {
        btn.addEventListener('click', () => {
            selectedIndex = Number(btn.getAttribute('data-row-index') || 0);
            root.querySelectorAll('.bonded-list-row').forEach(row => row.classList.remove('bg-blue-50'));
            const selectedTr = root.querySelector(`[data-bonded-list-row="${selectedIndex}"]`);
            if (selectedTr) selectedTr.classList.add('bg-blue-50');
            const formCard = root.querySelector('.bonded-form-card');
            if (formCard) formCard.classList.remove('hidden');
            fillPanel(rows[selectedIndex]);
            syncSubmitButtonState();
        });
    });

    const searchBtn = root.querySelector('.bonded-search-btn');
    if (searchBtn) searchBtn.addEventListener('click', applySearchFilter);
    root.querySelectorAll('.bonded-search-request, .bonded-search-owner, .bonded-search-party, .bonded-search-date').forEach(input => {
        input.addEventListener('keydown', (event) => {
            if (event.key === 'Enter') applySearchFilter();
        });
    });

    const targetWarehouseSelect = root.querySelector('[data-bonded-field="targetWarehouse"]');
    if (targetWarehouseSelect) {
        targetWarehouseSelect.disabled = false;
        targetWarehouseSelect.removeAttribute('disabled');
        targetWarehouseSelect.removeAttribute('readonly');
        targetWarehouseSelect.classList.remove('bg-slate-50');
        targetWarehouseSelect.addEventListener('change', () => {
            if (rows[selectedIndex]) {
                rows[selectedIndex].targetWarehouse = targetWarehouseSelect.value || '';
                rows[selectedIndex].bondedManagerId = targetWarehouseSelect.value || '';
                const selectedOption = targetWarehouseSelect.options[targetWarehouseSelect.selectedIndex];
                rows[selectedIndex].targetWarehouseNm = selectedOption ? selectedOption.textContent.trim() : '';
                rows[selectedIndex].bondedManagerNm = rows[selectedIndex].targetWarehouseNm;
            }
        });
    }

    const addBtn = root.querySelector('.bonded-add-line');
    if (addBtn) {
        addBtn.addEventListener('click', () => {
            const tbody = root.querySelector('.bonded-cargo-tbody');
            if (tbody) tbody.insertAdjacentHTML('beforeend', buildBondedCargoRowHtml({}));
        });
    }

    const selectAllBtn = root.querySelector('.bonded-select-all-line');
    if (selectAllBtn) {
        selectAllBtn.addEventListener('click', () => {
            const checks = Array.from(root.querySelectorAll('.bonded-cargo-check'));
            if (!checks.length) return;
            const shouldCheck = checks.some(chk => !chk.checked);
            checks.forEach(chk => {
                chk.checked = shouldCheck;
            });
            selectAllBtn.textContent = shouldCheck ? '전체해제' : '전체선택';
        });
    }

    const deleteBtn = root.querySelector('.bonded-delete-line');
    if (deleteBtn) {
        deleteBtn.addEventListener('click', () => {
            const checked = Array.from(root.querySelectorAll('.bonded-cargo-check:checked'));
            if (!checked.length) {
                alert('삭제할 화물정보 행을 선택해주세요.');
                return;
            }
            checked.forEach(chk => {
                const tr = chk.closest('tr');
                if (tr) tr.remove();
            });
        });
    }

    const applySubmitSuccess = () => {
        const rawCompleteStatus = root.getAttribute('data-complete-status') || '전송완료';
        const completeStatus = itemId === 'TACS-FW-033' && rawCompleteStatus === '요청완료' ? '발송완료' : rawCompleteStatus;
        const statusField = root.getAttribute('data-status-field') || 'requestStatus';
        const statusEl = root.querySelector(`[data-bonded-field="${statusField}"]`);
        if (statusEl) statusEl.value = completeStatus;

        const listStatusCell = root.querySelector(`[data-bonded-list-row="${selectedIndex}"] .bonded-list-status-cell`);
        if (listStatusCell) listStatusCell.innerHTML = `<span class="info-chip">${completeStatus}</span>`;

        if (rows[selectedIndex]) {
            rows[selectedIndex].listStatus = completeStatus;
            rows[selectedIndex][statusField] = completeStatus;
            rows[selectedIndex].releaseStatus = completeStatus;
            rows[selectedIndex].releaseStatusNm = completeStatus;
            rows[selectedIndex].releaseStatusCd = (completeStatus === '요청완료' || completeStatus === '발송완료') ? 'REL_WAIT' : completeStatus;
            if (typeof window.markImportWorkflowStatus === 'function') {
                if (itemId === 'TACS-FW-025') window.markImportWorkflowStatus('inbound', rows[selectedIndex], completeStatus);
                if (itemId === 'TACS-FW-033') window.markImportWorkflowStatus('release', rows[selectedIndex], completeStatus);
            }
        }

        const registeredTbody = root.querySelector('.bonded-registered-tbody');
        if (registeredTbody) {
            const completedRows = rows.filter(row => String(row.listStatus || row.releaseStatus || '') === completeStatus);
            registeredTbody.innerHTML = completedRows.length ? completedRows.map(row => `
                <tr>
                  <td class="font-bold px-3 py-3 leading-5">${formatImportReleaseReqNo(row)}</td>
                  <td class="px-3 py-3 leading-5">${row.owner || ''}</td>
                  <td class="px-3 py-3 leading-5">${row.cargoMgmtNo || '-'}</td>
                  <td class="px-3 py-3 leading-5">${row.targetWarehouse || row.listParty || ''}</td>
                  <td class="px-3 py-3 leading-5">${row.releasePlanDt || row.listAt || ''}</td>
                  <td class="px-3 py-3"><span class="info-chip text-[11px] px-2 py-1">${row.releaseStatus || row.listStatus || ''}</span></td>
                  <td class="text-center px-3 py-3"><button type="button" class="bonded-row-select px-3 py-1 border border-slate-300 bg-slate-700 text-white text-xs font-bold" data-row-index="${rows.indexOf(row)}">조회</button></td>
                </tr>
            `).join('') : '<tr><td colspan="7" class="text-center text-slate-500 py-6">반출요청 등록 내역이 없습니다.</td></tr>';
        }

        syncSubmitButtonState();
    };

    const submitBtn = root.querySelector('.bonded-submit');
    const originalSubmitLabel = submitBtn ? submitBtn.textContent : '';
    const isReleaseAlreadyRequested = (row) => {
        if (itemId !== 'TACS-FW-033' || !row) return false;
        const statusText = String(row.listStatus || row.releaseStatus || row.releaseStatusNm || row.releaseStatusCd || '').trim();
        return ['요청완료', '발송완료', '반출요청', 'REL_WAIT', 'REL_REQ', 'REQUESTED', '반출완료', 'DONE'].includes(statusText);
    };
    const syncSubmitButtonState = () => {
        if (!submitBtn) return;
        const selectedRow = rows[selectedIndex] || {};

        if (itemId === 'TACS-FW-025') {
            const statusText = String(selectedRow.listStatus || selectedRow.requestStatus || '').trim();
            const closed = ['입고완료', '반려'].includes(statusText);
            submitBtn.disabled = closed;
            submitBtn.textContent = closed ? statusText : (originalSubmitLabel || '전달');
            submitBtn.classList.toggle('bg-slate-400', closed);
            submitBtn.classList.toggle('hover:bg-primary-dim', !closed);
            return;
        }

        if (itemId !== 'TACS-FW-033') return;
        const requested = isReleaseAlreadyRequested(selectedRow);
        submitBtn.disabled = requested;
        submitBtn.textContent = requested ? '발송완료' : (originalSubmitLabel || '반출요청');
        submitBtn.classList.toggle('bg-slate-400', requested);
        submitBtn.classList.toggle('hover:bg-primary-dim', !requested);
    };

    syncSubmitButtonState();

    if (submitBtn) {
        submitBtn.addEventListener('click', () => {
            // 수입 > 하선 및 보세구역 입고관리(TACS-FW-025)는 DB 업데이트 API를 호출해야 함.
            if (itemId === 'TACS-FW-025') {
                const selectedRow = rows[selectedIndex] || {};
                const trcNo = selectedRow.trcNo || selectedRow.requestNo || root.querySelector('[data-bonded-field="requestNo"]')?.value || '';
                const wirNo = selectedRow.wirNo || selectedRow.inboundRequestNo || root.querySelector('[data-bonded-field="manifestNo"]')?.value || '';
                const wmId = root.querySelector('[data-bonded-field="targetWarehouse"]')?.value || '';

                if (!trcNo) {
                    alert('운송의뢰번호(TRC_NO)를 찾을 수 없습니다. 목록에서 항목을 다시 선택해주세요.');
                    return;
                }

                if (!wmId) {
                    alert('전달대상 창고관리자를 선택해주세요.');
                    return;
                }

                if (!wirNo) {
                    alert('입고요청번호(WIR_NO)를 찾을 수 없습니다. 목록에서 항목을 다시 선택해주세요.');
                    return;
                }

                const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';
                const headers = {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json'
                };
                const csrf = window.TRANSPORT_CSRF || {};
                const csrfHeader = csrf.header || document.querySelector('meta[name="_csrf_header"]')?.getAttribute('content');
                const csrfToken = csrf.token || document.querySelector('meta[name="_csrf"]')?.getAttribute('content');
                if (csrfHeader && csrfToken) {
                    headers[csrfHeader] = csrfToken;
                }

                submitBtn.disabled = true;

                fetch(contextPath + '/transport/import/unloading-in/deliver.do', {
                    method: 'POST',
                    headers: headers,
                    body: new URLSearchParams({trcNo, wirNo, wmId}).toString()
                })
                    .then(res => {
                        if (!res.ok) throw new Error('HTTP ' + res.status);
                        return res.json();
                    })
                    .then(data => {
                        if (!data || data.success !== true) {
                            throw new Error('DB update failed');
                        }
                        applySubmitSuccess();
                        alert(root.getAttribute('data-submit-message') || '보세구역 입고관리 정보가 창고관리자에게 전달되었습니다.');
                    })
                    .catch(err => {
                        console.error('[수입 보세구역 입고관리 전달 실패]', err);
                        alert('전달 처리에 실패했습니다. 서버 로그와 Network의 deliver.do 응답을 확인해주세요.');
                    })
                    .finally(() => {
                        submitBtn.disabled = false;
                    });
                return;
            }

            // 수입 > 보세구역 반출 요청(TACS-FW-033)은 CARGO_RELEASE_REQ / CARGO_RELEASE 상태 업데이트 API를 호출해야 함.
            if (itemId === 'TACS-FW-033') {
                const selectedRow = rows[selectedIndex] || {};
                const trcNo = selectedRow.trcNo || selectedRow.requestNo || root.querySelector('[data-bonded-field="requestNo"]')?.value || '';

                if (!trcNo) {
                    alert('운송의뢰번호(TRC_NO)를 찾을 수 없습니다. 목록에서 항목을 다시 선택해주세요.');
                    return;
                }

                const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';
                const headers = {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json'
                };
                const csrf = window.TRANSPORT_CSRF || {};
                const csrfHeader = csrf.header || document.querySelector('meta[name="_csrf_header"]')?.getAttribute('content');
                const csrfToken = csrf.token || document.querySelector('meta[name="_csrf"]')?.getAttribute('content');
                if (csrfHeader && csrfToken) {
                    headers[csrfHeader] = csrfToken;
                }

                submitBtn.disabled = true;

                fetch(contextPath + '/transport/import/release-request/request.do', {
                    method: 'POST',
                    headers: headers,
                    body: new URLSearchParams({trcNo}).toString()
                })
                    .then(res => {
                        if (!res.ok) throw new Error('HTTP ' + res.status);
                        return res.json();
                    })
                    .then(data => {
                        if (!data || data.success !== true) {
                            throw new Error('DB update failed');
                        }
                        applySubmitSuccess();
                        window.__TACS_IMPORT_RELEASE_LOADED = false;
                        const reload = typeof loadImportReleaseRequestRows === 'function'
                            ? loadImportReleaseRequestRows()
                            : Promise.resolve([]);
                        return Promise.resolve(reload).then(() => {
                            alert(root.getAttribute('data-submit-message') || '수입 보세구역 반출요청 정보가 창고관리자에게 전송되었습니다.');
                        });
                    })
                    .catch(err => {
                        console.error('[수입 보세구역 반출요청 실패]', err);
                        alert('반출요청 처리에 실패했습니다. 서버 로그와 Network의 request.do 응답을 확인해주세요.');
                    })
                    .finally(() => {
                        if (itemId === 'TACS-FW-033') {
                            syncSubmitButtonState();
                        } else {
                            submitBtn.disabled = false;
                        }
                    });
                return;
            }

            applySubmitSuccess();
            alert(root.getAttribute('data-submit-message') || '요청 정보가 전송되었습니다.');
        });
    }
}


function bindExportInboundManageActions(groupKey, itemId) {
    if (itemId !== 'TACS-FW-009B') return;
    detailBody.querySelectorAll('.export-inbound-row').forEach(row => {
        row.addEventListener('click', function () {
            selectedExportInboundRequestNo = this.dataset.requestNo;
            openDetail(groupKey, 'TACS-FW-009B');
        });
    });
    const addCargoBtn = detailBody.querySelector('.export-inbound-add-row');
    if (addCargoBtn) {
        addCargoBtn.addEventListener('click', function () {
            const body = detailBody.querySelector('.export-inbound-cargo-body');
            if (!body) return;
            body.insertAdjacentHTML('beforeend', `
        <tr>
          <td class="text-center"><input type="checkbox" /></td>
          <td><input type="text" placeholder="Shipping Mark" /></td>
          <td><textarea placeholder="품목 입력"></textarea></td>
          <td><input type="number" placeholder="수량" /></td>
          <td>
            <select>
              <option>BOX</option>
              <option>CTN</option>
              <option>PLT</option>
              <option>BAG</option>
              <option>EA</option>
            </select>
          </td>
          <td><input type="number" placeholder="포장개수" /></td>
          <td><input type="number" placeholder="총중량" /></td>
          <td><input type="number" placeholder="순중량" /></td>
          <td><input type="number" step="0.01" placeholder="부피" /></td>
          <td><input type="number" placeholder="단가" /></td>
          <td><input type="number" placeholder="총액" /></td>
          <td>
            <select>
              <option>USD</option>
              <option>KRW</option>
            </select>
          </td>
        </tr>
      `);
        });
    }
    const deleteCargoBtn = detailBody.querySelector('.export-inbound-delete-row');
    if (deleteCargoBtn) {
        deleteCargoBtn.addEventListener('click', function () {
            const checkedRows = detailBody.querySelectorAll('.export-inbound-cargo-body input[type="checkbox"]:checked');
            checkedRows.forEach(chk => chk.closest('tr')?.remove());
        });
    }
    const sendBtn = detailBody.querySelector('.export-inbound-send-btn');
    if (sendBtn) {
        sendBtn.addEventListener('click', function () {
            const reqStatus = detailBody.querySelector('#exportInboundReqStatus');
            const replyStatus = detailBody.querySelector('#exportInboundReplyStatus');
            const reason = detailBody.querySelector('#exportInboundRejectReason');
            if (reqStatus) reqStatus.value = '입고완료';
            if (replyStatus) replyStatus.value = '회신대기';
            if (reason) reason.value = '창고관리자 회신 대기 중';
            alert('창고관리자에게 보세구역 입고 요청이 전송되었습니다.');
        });
    }
}


function formatImportUnloadingDateTime(value) {
    if (!value) return '';
    return String(value).replace('T', ' ').slice(0, 16);
}

function formatImportUnloadingMoney(value) {
    if (value === null || value === undefined || value === '') return '';
    const n = Number(value);
    return Number.isFinite(n) ? n.toLocaleString() : String(value);
}

function mapImportUnloadingCargoLine(line) {
    return {
        cgNo: line.cgNo || '',
        goodsNo: line.goodsNo || '',
        shippingMark: line.cgNo || '',
        goodsDesc: line.goodsName || line.itemNm || line.itemCategory || line.goodsDesc || line.goodsNo || '',
        qty: line.qty || '',
        unitPrice: formatImportUnloadingMoney(line.price),
        amount: formatImportUnloadingMoney(line.goodsTotalPrice),
        weight: line.weight || '',
        origin: line.origin || ''
    };
}


function normalizeImportWarehouseInStatus(row) {
    const raw = String(
        row?.statusNm ||
        row?.warehouseInStatusNm ||
        row?.whReplyStatusNm ||
        row?.wirWhReplyStatusNm ||
        row?.statusCd ||
        row?.warehouseInStatusCd ||
        row?.warehouseReplyStatusCd ||
        row?.whReplyStatusCd ||
        row?.wirWhReplyStatusCd ||
        row?.wirStatusCd ||
        row?.WIR_WH_REPLY_STATUS_CD ||
        row?.WIR_STATUS_CD ||
        ''
    ).trim();

    if (!raw) return '';
    if (['입고완료', 'IN_DONE', 'DONE', 'COMPLETE', 'COMPLETED'].includes(raw)) return '입고완료';
    if (['보완요청', 'REQ_FIX', 'FIX_REQ', 'SUPPLEMENT', 'SUPPLEMENT_REQUESTED'].includes(raw)) return '보완요청';
    if (['반려', 'REJECT', 'REJECTED', 'REJ'].includes(raw)) return '반려';
    if (['입고요청완료', 'SENT'].includes(raw)) return '입고대기';
    if (['WAIT', 'WAIT_CONFIRM', 'REQUEST', '요청대기', '입고요청', '입고대기'].includes(raw)) return '입고대기';
    return raw;
}


function isImportDOManagerPlaceholder(value) {
    const text = String(value || '').trim();
    return !text || text === '창고관리자' || text === '-- 창고관리자 선택 --';
}

function normalizeWarehouseManagerOption(raw) {
    raw = raw || {};
    const wmId = String(raw.wmId || raw.bondedManagerId || raw.managerId || raw.WM_ID || raw.value || '').trim();
    const wmNm = String(raw.warehouseManagerNm || raw.bondedManagerNm || raw.wmNm || raw.managerNm || raw.WM_NM || raw.managerName || '').trim();
    const whNo = String(raw.whNo || raw.warehouseNo || raw.WH_NO || '').trim();
    const warehouseNm = String(raw.warehouseNm || raw.whNm || raw.WH_NM || '').trim();
    const wzNo = String(raw.wzNo || raw.bondedZoneNo || raw.warehouseZoneNo || raw.WZ_NO || '').trim();
    const warehouseZoneNm = String(raw.warehouseZoneNm || raw.bondedZoneNm || raw.zoneNm || raw.WZ_NM || '').trim();
    const value = wmId || wmNm;
    const label = String(raw.label || buildImportWarehouseTargetLabel({
        warehouseNm,
        whNm: warehouseNm,
        warehouseZoneNm,
        bondedZoneNm: warehouseZoneNm,
        bondedManagerNm: wmNm,
        warehouseManagerNm: wmNm,
        wmNm,
        bondedManagerId: wmId,
        wmId
    }) || wmNm || value || '').trim();
    if (!value) return null;
    return {value, label: label || value, wmId, wmNm: wmNm || value, whNo, warehouseNm, wzNo, warehouseZoneNm};
}

function buildImportWarehouseTargetLabel(row) {
    row = row || {};
    const warehouse = String(row.warehouseNm || row.whNm || '').trim();
    const zone = String(row.warehouseZoneNm || row.bondedZoneNm || row.zoneNm || '').trim();
    const manager = String(row.bondedManagerNm || row.warehouseManagerNm || row.wmNm || row.managerNm || '').trim();
    if (warehouse && zone && warehouse.indexOf(zone) < 0) return warehouse + ' / ' + zone;
    if (warehouse && manager && warehouse.indexOf(manager) < 0) return warehouse + ' / ' + manager;
    if (zone && manager && zone.indexOf(manager) < 0) return zone + ' / ' + manager;
    return warehouse || zone || manager || String(row.targetWarehouseNm || row.targetWarehouse || row.bondedManagerId || row.wmId || '').trim();
}

function mergeWarehouseManagerOptions(baseOptions, extraOptions) {
    const map = new Map();
    [...(baseOptions || []), ...(extraOptions || [])].forEach(opt => {
        const normalized = normalizeWarehouseManagerOption(opt);
        if (!normalized) return;
        const before = map.get(normalized.value);
        if (!before || normalized.label.length > before.label.length) {
            map.set(normalized.value, normalized);
        }
    });
    return [{value: '', label: '-- 창고관리자 선택 --'}, ...Array.from(map.values())];
}

function getImportWarehouseManagerOptions(rows) {
    const apiOptions = Array.isArray(window.__TACS_IMPORT_WAREHOUSE_MANAGERS) ? window.__TACS_IMPORT_WAREHOUSE_MANAGERS : [];
    const rowOptions = (Array.isArray(rows) ? rows : []).map(row => ({
        value: row.bondedManagerId || row.wmId || row.targetWarehouse || '',
        label: buildImportWarehouseTargetLabel(row)
    }));
    return mergeWarehouseManagerOptions(apiOptions, rowOptions);
}

function getImportDOZoneOptions() {
    const apiOptions = Array.isArray(window.__TACS_IMPORT_WAREHOUSE_MANAGERS) ? window.__TACS_IMPORT_WAREHOUSE_MANAGERS : [];
    const map = new Map();
    apiOptions.forEach(opt => {
        const normalized = normalizeWarehouseManagerOption(opt);
        if (!normalized || !normalized.wzNo) return;
        if (!map.has(normalized.wzNo)) {
            map.set(normalized.wzNo, {
                value: normalized.wzNo,
                label: normalized.warehouseZoneNm || normalized.wzNo,
                managerNm: normalized.wmNm || '',
                wmId: normalized.wmId || ''
            });
        }
    });
    return [{value: '', label: '-- 창고구역 선택 --', managerNm: '', wmId: ''}, ...Array.from(map.values())];
}

function getImportDOManagerOptions(rows) {
    const apiOptions = Array.isArray(window.__TACS_IMPORT_WAREHOUSE_MANAGERS) ? window.__TACS_IMPORT_WAREHOUSE_MANAGERS : [];
    const rowOptions = (Array.isArray(rows) ? rows : []).flatMap(row => ([
        {value: row.deliveryTargetNm || row.deliveryTarget || '', label: row.deliveryTargetNm || row.deliveryTarget || ''},
        {value: row.issueTargetNm || row.issueTarget || '', label: row.issueTargetNm || row.issueTarget || ''},
        {value: row.bondedManagerId || row.wmId || '', label: row.bondedManagerNm || row.warehouseManagerNm || row.wmNm || ''}
    ]));

    const map = new Map();
    [...apiOptions, ...rowOptions].forEach(opt => {
        const normalized = normalizeWarehouseManagerOption(opt);
        if (!normalized) return;
        // D/O 전달대상자는 DO_ISSUANCE.DI_DLVRY_OWR_NM 이름 컬럼에 저장되므로 value도 담당자명으로 맞춘다.
        const managerNm = String(normalized.wmNm || normalized.label || normalized.value || '').trim();
        if (isImportDOManagerPlaceholder(managerNm)) return;
        if (!map.has(managerNm)) map.set(managerNm, {value: managerNm, label: managerNm});
    });

    return [{value: '', label: '-- 창고담당자 선택 --'}, ...Array.from(map.values())];
}

function buildImportDOZoneSelectOptions(selectedZoneNo) {
    const selected = String(selectedZoneNo || '').trim();
    return getImportDOZoneOptions().map(opt => `<option value="${escHtml(opt.value)}" data-manager-nm="${escHtml(opt.managerNm || '')}" data-wm-id="${escHtml(opt.wmId || '')}"${selected && opt.value === selected ? ' selected' : ''}>${escHtml(opt.label)}</option>`).join('');
}

function buildImportDOManagerSelectOptions(selectedValue, rows) {
    const selected = isImportDOManagerPlaceholder(selectedValue) ? '' : String(selectedValue || '').trim();
    const options = getImportDOManagerOptions(rows);
    if (selected && !isImportDOManagerPlaceholder(selected) && !options.some(opt => opt.value === selected || opt.label === selected)) {
        options.push({value: selected, label: selected});
    }
    return options.map(opt => `<option value="${escHtml(opt.value)}"${selected && (opt.value === selected || opt.label === selected) ? ' selected' : ''}>${escHtml(opt.label)}</option>`).join('');
}

function loadImportWarehouseManagers() {
    if (window.__TACS_IMPORT_WAREHOUSE_MANAGERS_LOADED || window.__TACS_IMPORT_WAREHOUSE_MANAGERS_LOADING) return;
    window.__TACS_IMPORT_WAREHOUSE_MANAGERS_LOADING = true;
    const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';

    fetch(contextPath + '/transport/import/warehouse-manager/list.do?_=' + Date.now(), {
        headers: { 'Accept': 'application/json' },
        cache: 'no-store'
    })
        .then(res => res.ok ? res.json() : Promise.reject(res))
        .then(list => {
            window.__TACS_IMPORT_WAREHOUSE_MANAGERS = (Array.isArray(list) ? list : [])
                .map(normalizeWarehouseManagerOption)
                .filter(Boolean);
            window.__TACS_IMPORT_WAREHOUSE_MANAGERS_LOADED = true;
        })
        .catch(err => {
            console.error('창고관리자 목록 조회 실패', err);
            window.__TACS_IMPORT_WAREHOUSE_MANAGERS = [];
            window.__TACS_IMPORT_WAREHOUSE_MANAGERS_LOADED = true;
        })
        .finally(() => {
            window.__TACS_IMPORT_WAREHOUSE_MANAGERS_LOADING = false;
            refreshImportUnloadingPanel();
            const body = document.getElementById('detail-body');
            if (body && body.dataset && body.dataset.currentItem === 'TACS-FW-030') {
                body.innerHTML = '<div class="space-y-6">' + buildDOIssueReissuePanel() + '</div>';
                if (typeof bindDOIssueReissueActions === 'function') bindDOIssueReissueActions('import', 'TACS-FW-030');
                if (typeof normalizeDetailActionButtons === 'function') normalizeDetailActionButtons();
            }
        });
}

function mapImportUnloadingRow(row, detail, goodsList) {
    const d = detail || row || {};
    const goods = Array.isArray(goodsList) ? goodsList : [];
    const displayRequestNo = d.trcNo || row.trcNo || d.requestNo || row.requestNo || '';
    const wirNo = d.wirNo || row.wirNo || '';
    const warehouseInStatus = normalizeImportWarehouseInStatus(d);
    return {
        trcNo: displayRequestNo,
        wirNo: wirNo,
        requestNo: displayRequestNo || wirNo,
        owner: d.ownerNm || row.ownerNm || d.owrNm || row.owrNm || d.owner || row.owner || '',
        listParty: d.cargoMgmtNo || row.cargoMgmtNo || '',
        listAt: d.inPlanDt || row.inPlanDt || '',
        listStatus: warehouseInStatus,
        inboundRequestNo: wirNo,
        manifestNo: displayRequestNo || wirNo,
        masterBlNo: d.mblNo || row.mblNo || d.blNo || row.blNo || '',
        houseBlNo: d.hblNo || d.blNo || '',
        bondedManagerId: d.bondedManagerId || row.bondedManagerId || d.wmId || row.wmId || '',
        bondedManagerNm: d.bondedManagerNm || row.bondedManagerNm || d.warehouseManagerNm || row.warehouseManagerNm || d.wmNm || row.wmNm || '',
        whNo: d.whNo || row.whNo || d.warehouseNo || row.warehouseNo || '',
        warehouseNo: d.warehouseNo || row.warehouseNo || d.whNo || row.whNo || '',
        whNm: d.whNm || row.whNm || d.warehouseNm || row.warehouseNm || '',
        warehouseNm: d.warehouseNm || row.warehouseNm || d.whNm || row.whNm || '',
        bondedZoneNo: d.bondedZoneNo || row.bondedZoneNo || '',
        warehouseZoneNm: d.warehouseZoneNm || row.warehouseZoneNm || '',
        deptPortCd: d.deptPortCd || row.deptPortCd || '',
        deptPortNm: d.deptPortNm || row.deptPortNm || '',
        arvlPortCd: d.arvlPortCd || row.arvlPortCd || '',
        arvlPortNm: d.arvlPortNm || row.arvlPortNm || '',
        dischargePlanDt: formatImportUnloadingDateTime(d.inPlanDt || row.inPlanDt),
        inboundPlanDt: formatImportUnloadingDateTime(d.inPlanDt || row.inPlanDt),
        targetWarehouse: d.bondedManagerId || row.bondedManagerId || d.wmId || row.wmId || '',
        targetWarehouseNm: buildImportWarehouseTargetLabel(d.wirNo ? d : row),
        requestStatus: warehouseInStatus,
        warehouseReplyStatus: warehouseInStatus,
        vesselVoyage: d.vesselVoyage || '',
        cargoMgmtNo: d.cargoMgmtNo || row.cargoMgmtNo || '',
        shipper: d.buyerNm || row.buyerNm || '',
        consignee: d.ownerNm || row.ownerNm || d.owrNm || row.owrNm || d.owner || row.owner || '',
        invoiceNo: d.invoiceNo || row.invoiceNo || d.wirInvoiceNo || row.wirInvoiceNo || d.invoiceFile || row.invoiceFile || '',
        invoiceDt: d.invoiceYmd || row.invoiceYmd || d.wirInvoiceYmd || row.wirInvoiceYmd || d.requestDt || row.requestDt || '',
        incoTermsCd: d.incoTermsCd || row.incoTermsCd || '',
        requestNote: d.rejectMemo || d.requestCn || '',
        suppReqCn: d.suppReqCn || row.suppReqCn || d.supplementReason || row.supplementReason || '',
        rejectReason: d.suppReqCn || d.rejectReason || d.supplementReason || row.suppReqCn || row.rejectReason || '',
        cargo: goods.length ? goods.map(mapImportUnloadingCargoLine) : [{}]
    };
}

function refreshImportUnloadingPanel() {
    const body = document.getElementById('detail-body');
    if (!body || body.dataset.currentItem !== 'TACS-FW-025') return;
    if (window.__TACS_IMPORT_INBOUND_FORCE_LIST_ON_NEXT_RENDER === true) {
        resetImportInboundCategoryToList();
    }
    body.innerHTML = '<div class="space-y-6">' + buildUnloadingCoordinationPanel() + '</div>';
    if (typeof bindImportInboundManageActions === 'function') {
        bindImportInboundManageActions();
    }
    if (typeof normalizeDetailActionButtons === 'function') normalizeDetailActionButtons();
}

function renderImportInboundManagePanelView(mode, row) {
    window.__TACS_IMPORT_INBOUND_VIEW_MODE = 'list';
    window.__TACS_IMPORT_INBOUND_SELECTED_ROW = null;

    const body = document.getElementById('detail-body');
    if (!body || body.dataset.currentItem !== 'TACS-FW-025') return;

    const root = body.querySelector('.import-inbound-manage-panel[data-item-id="TACS-FW-025"]');
    if (!root) {
        refreshImportUnloadingPanel();
        return;
    }

    const wrap = document.createElement('div');
    wrap.innerHTML = buildUnloadingCoordinationPanel();
    const nextRoot = wrap.firstElementChild;
    if (!nextRoot) return;

    root.replaceWith(nextRoot);
    if (typeof bindImportInboundManageActions === 'function') {
        bindImportInboundManageActions();
    }
    if (typeof normalizeDetailActionButtons === 'function') normalizeDetailActionButtons();
}

window.showImportInboundManageListView = function () {
    renderImportInboundManagePanelView('list');
};

window.showImportInboundManageFormView = function (row) {
    renderImportInboundManagePanelView('form', row);
};

function loadImportUnloadingInRows() {
    if (window.__TACS_IMPORT_UNLOADING_LOADING) return;
    window.__TACS_IMPORT_UNLOADING_LOADING = true;
    const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';

    fetch(contextPath + '/transport/import/unloading-in/list.do')
        .then(res => res.ok ? res.json() : Promise.reject(res))
        .then(list => Promise.all((Array.isArray(list) ? list : []).map(row => {
            const wirNo = encodeURIComponent(row.wirNo || '');
            const ggNo = encodeURIComponent(row.ggNo || '');
            return Promise.all([
                fetch(`${contextPath}/transport/import/unloading-in/detail.do?wirNo=${wirNo}`).then(res => res.ok ? res.json() : row).catch(() => row),
                fetch(`${contextPath}/transport/import/unloading-in/goods.do?ggNo=${ggNo}`).then(res => res.ok ? res.json() : []).catch(() => [])
            ]).then(([detail, goods]) => mapImportUnloadingRow(row, detail, goods));
        })))
        .then(rows => {
            window.__TACS_IMPORT_UNLOADING_ROWS = rows;
            window.__TACS_IMPORT_UNLOADING_LOADED = true;
        })
        .catch(err => {
            console.error('보세구역 입고관리 데이터 조회 실패', err);
            window.__TACS_IMPORT_UNLOADING_ROWS = [];
            window.__TACS_IMPORT_UNLOADING_LOADED = true;
        })
        .finally(() => {
            window.__TACS_IMPORT_UNLOADING_LOADING = false;
            refreshImportUnloadingPanel();
        });
}

function normalizeImportInboundManifestRow(row, goodsList) {
    row = row || {};
    const statusCd = String(row.manifestStatusCd || row.statusCd || '').toUpperCase();
    const isSubmitted = statusCd === 'SUBMITTED' || String(row.manifestStatusNm || row.statusNm || '').indexOf('제출완료') >= 0;
    return {
        trcNo: row.trcNo || row.requestNo || '',
        wirNo: row.wirNo || row.inRptNo || '',
        ggNo: row.ggNo || '',
        manifestNo: row.manifestNo || row.icmNo || '',
        requestNo: row.trcNo || row.requestNo || '',
        ownerId: row.ownerId || '',
        owner: row.ownerNm || row.owner || '',
        listParty: row.cargoMgmtNo || '',
        cargoMgmtNo: row.cargoMgmtNo || '',
        invoiceNo: row.invoiceNo || row.wirInvoiceNo || '',
        incoTermsCd: row.incoTermsCd || '',
        deptPortCd: row.deptPortCd || '',
        deptPortNm: row.deptPortNm || '',
        arvlPortCd: row.arvlPortCd || '',
        arvlPortNm: row.arvlPortNm || '',
        masterBlNo: row.mblNo || row.blNo || '',
        houseBlNo: row.hblNo || '',
        listAt: row.manifestSubmitDt || row.inPlanDt || '',
        manifestSubmitDt: row.manifestSubmitDt || '',
        manifestStatusCd: isSubmitted ? 'SUBMITTED' : (row.manifestStatusCd || row.statusCd || ''),
        manifestStatusNm: isSubmitted ? '제출완료' : (row.manifestStatusNm || row.statusNm || ''),
        bondedManagerId: row.bondedManagerId || row.wmId || '',
        bondedManagerNm: row.bondedManagerNm || row.warehouseManagerNm || row.wmNm || '',
        warehouseManagerNm: row.warehouseManagerNm || row.bondedManagerNm || row.wmNm || '',
        whNm: row.whNm || row.warehouseNm || '',
        warehouseNm: row.warehouseNm || row.whNm || '',
        warehouseZoneNm: row.warehouseZoneNm || row.wzNm || row.bondedZoneNm || '',
        inboundPlanDt: formatImportUnloadingDateTime(row.inPlanDt || ''),
        targetWarehouse: row.bondedManagerId || row.wmId || '',
        targetWarehouseNm: buildImportWarehouseTargetLabel(row),
        requestStatus: row.listStatus || row.statusNm || '등록대기',
        consignee: row.ownerNm || row.owner || '',
        requestNote: row.manifestRemark || '',
        cargo: Array.isArray(goodsList) && goodsList.length ? goodsList.map(mapImportUnloadingCargoLine) : [{
            cgNo: row.cgNo || '',
            goodsDesc: row.goodsName || '',
            qty: row.qty || '',
            unitPrice: row.price || '',
            amount: row.goodsTotalPrice || row.totalPrice || '',
            weight: row.weight || '',
            origin: row.origin || ''
        }]
    };
}

function loadImportInboundManifestRows() {
    if (window.__TACS_IMPORT_INBOUND_MANIFEST_LOADING) return;
    window.__TACS_IMPORT_INBOUND_MANIFEST_LOADING = true;
    const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';

    Promise.all([
        fetch(contextPath + '/transport/import/manifest/list.do', {
            method: 'GET',
            headers: {'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
            cache: 'no-store'
        }).then(res => res.ok ? res.json() : Promise.reject(res)),
        fetch(contextPath + '/transport/import/unloading-in/list.do', {
            method: 'GET',
            headers: {'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
            cache: 'no-store'
        }).then(res => res.ok ? res.json() : []).catch(() => [])
    ])
        .then(([manifestList, unloadingList]) => {
            const submitted = (Array.isArray(manifestList) ? manifestList : []).filter(row => {
                const cd = String(row.manifestStatusCd || row.statusCd || '').toUpperCase();
                const nm = String(row.manifestStatusNm || row.statusNm || '');
                return cd === 'SUBMITTED' || nm.indexOf('제출완료') >= 0;
            });

            return Promise.all(submitted.map(row => {
                const ggNo = encodeURIComponent(row.ggNo || '');
                if (!ggNo) return Promise.resolve(normalizeImportInboundManifestRow(row, []));
                return fetch(`${contextPath}/transport/import/manifest/goods.do?ggNo=${ggNo}`, {
                    method: 'GET',
                    headers: {'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                    cache: 'no-store'
                })
                    .then(res => res.ok ? res.json() : [])
                    .catch(() => [])
                    .then(goods => normalizeImportInboundManifestRow(row, goods));
            })).then(manifestRows => {
                const registeredKeys = new Set((Array.isArray(unloadingList) ? unloadingList : [])
                    .map(row => String(row.wirNo || row.trcNo || ''))
                    .filter(Boolean));
                const registeredSourceRows = (Array.isArray(unloadingList) ? unloadingList : [])
                    .filter(row => registeredKeys.has(String(row.wirNo || row.trcNo || '')));

                return Promise.all(registeredSourceRows.map(row => {
                    const wirNo = encodeURIComponent(row.wirNo || row.inboundRequestNo || '');
                    const ggNo = encodeURIComponent(row.ggNo || '');

                    const detailPromise = wirNo
                        ? fetch(`${contextPath}/transport/import/unloading-in/detail.do?wirNo=${wirNo}`, {
                            method: 'GET',
                            headers: {'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                            cache: 'no-store'
                        }).then(res => res.ok ? res.json() : row).catch(() => row)
                        : Promise.resolve(row);

                    const goodsPromise = ggNo
                        ? fetch(`${contextPath}/transport/import/unloading-in/goods.do?ggNo=${ggNo}`, {
                            method: 'GET',
                            headers: {'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                            cache: 'no-store'
                        }).then(res => res.ok ? res.json() : []).catch(() => [])
                        : Promise.resolve([]);

                    return Promise.all([detailPromise, goodsPromise])
                        .then(([detail, goods]) => mapImportUnloadingRow(row, detail || row, goods));
                })).then(registeredRows => {
                    const registeredWir = new Set(registeredRows.map(row => String(row.wirNo || '')));
                    const pendingRows = manifestRows.filter(row => !registeredWir.has(String(row.wirNo || '')));

                    window.__TACS_IMPORT_INBOUND_MANIFEST_ROWS = pendingRows;
                    window.__TACS_IMPORT_INBOUND_REGISTERED_ROWS = registeredRows;
                    window.TRANSPORT_IMPORT_WAREHOUSE_IN_LIST = registeredRows.concat(pendingRows);
                    window.TRANSPORT_IMPORT_INBOUND_LIST = window.TRANSPORT_IMPORT_WAREHOUSE_IN_LIST;
                    window.__TACS_IMPORT_UNLOADING_ROWS = window.TRANSPORT_IMPORT_WAREHOUSE_IN_LIST;
                    window.__TACS_IMPORT_INBOUND_MANIFEST_LOADED = true;
                    if (typeof window.refreshImportWorkflowSummary === 'function') window.refreshImportWorkflowSummary();
                });
            });
        })
        .catch(err => {
            console.error('수입 보세구역 입고관리 적하목록 조회 실패', err);
            window.__TACS_IMPORT_INBOUND_MANIFEST_ROWS = [];
            window.__TACS_IMPORT_INBOUND_REGISTERED_ROWS = [];
            window.__TACS_IMPORT_INBOUND_MANIFEST_LOADED = true;
        })
        .finally(() => {
            window.__TACS_IMPORT_INBOUND_MANIFEST_LOADING = false;
            refreshImportUnloadingPanel();
            if (typeof window.refreshImportWorkflowSummary === 'function') window.refreshImportWorkflowSummary();
        });
}

function buildImportInboundManifestRows(rows, loading) {
    if (loading) {
        return '<tr><td colspan="8" class="text-center text-slate-500 py-6">적하목록 제출완료 의뢰를 불러오는 중입니다.</td></tr>';
    }
    if (!rows || !rows.length) {
        return '<tr><td colspan="8" class="text-center text-slate-500 py-6">등록 가능한 적하목록 제출완료 의뢰가 없습니다.</td></tr>';
    }
    return rows.map((row, idx) => '' +
        '<tr>' +
        '<td class="font-bold">' + safeText(row.manifestNo || '-') + '</td>' +
        '<td>' + safeText(row.owner || '-') + '</td>' +
        '<td>' + safeText(row.cargoMgmtNo || '-') + '</td>' +
        '<td>' + safeText(row.invoiceNo || '-') + '</td>' +
        '<td>' + safeText(row.masterBlNo || '-') + '</td>' +
        '<td>' + safeText(row.manifestSubmitDt || '-') + '</td>' +
        '<td><span class="info-chip">제출완료</span></td>' +
        '<td><button type="button" class="import-inbound-register-btn px-3 py-1 bg-slate-800 text-white text-xs font-bold" data-index="' + idx + '">등록</button></td>' +
        '</tr>'
    ).join('');
}

function buildImportInboundRegisteredRows(rows) {
    if (!rows || !rows.length) {
        return '<tr><td colspan="7" class="text-center text-slate-500 py-6">등록된 수입 보세구역 입고관리 내역이 없습니다.</td></tr>';
    }
    return rows.map((row, idx) => '' +
        '<tr>' +
        '<td class="font-bold">' + safeText(row.inboundRequestNo || row.wirNo || '-') + '</td>' +
        '<td>' + safeText(row.owner || '-') + '</td>' +
        '<td>' + safeText(row.cargoMgmtNo || row.listParty || '-') + '</td>' +
        '<td>' + safeText(row.targetWarehouseNm || row.bondedManagerNm || row.targetWarehouse || '-') + '</td>' +
        '<td>' + safeText(row.inboundPlanDt || row.listAt || '-') + '</td>' +
        '<td><span class="info-chip">' + safeText(normalizeImportInboundDisplayStatus(row.listStatus || row.requestStatus || '')) + '</span></td>' +
        '<td><button type="button" class="import-inbound-registered-form-btn px-3 py-1 bg-slate-800 text-white text-xs font-bold" data-index="' + idx + '">등록</button></td>' +
        '</tr>'
    ).join('');
}

function bindImportInboundManageActions() {
    const root = document.querySelector('.import-inbound-manage-panel[data-item-id="TACS-FW-025"]');
    if (!root) return;

    root.querySelectorAll('input.field-input').forEach(function (input) {
        if (String(input.value || '').trim() === '-' || String(input.value || '').trim() === '－' || String(input.value || '').trim() === '—') input.value = '';
    });

    function applyListSearch() {
        window.__TACS_IMPORT_INBOUND_CATEGORY_SEARCH = {
            inboundNo: cleanImportInboundSearchValue(document.getElementById('importInboundSearchInboundNo')?.value),
            owner: cleanImportInboundSearchValue(document.getElementById('importInboundSearchOwner')?.value),
            cargoNo: cleanImportInboundSearchValue(document.getElementById('importInboundSearchCargoNo')?.value),
            masterBlNo: cleanImportInboundSearchValue(document.getElementById('importInboundSearchMasterBlNo')?.value),
            status: cleanImportInboundSearchValue(document.getElementById('importInboundSearchStatus')?.value)
        };
        renderImportInboundManagePanelView('list');
    }

    const searchBtn = document.getElementById('importInboundSearchBtn');
    if (searchBtn) searchBtn.addEventListener('click', applyListSearch);

    root.querySelectorAll('#importInboundSearchInboundNo, #importInboundSearchOwner, #importInboundSearchCargoNo, #importInboundSearchMasterBlNo, #importInboundSearchStatus').forEach(function (input) {
        const eventName = input && input.tagName === 'SELECT' ? 'change' : 'keydown';
        input.addEventListener(eventName, function (event) {
            if (eventName === 'change' || event.key === 'Enter') {
                event.preventDefault();
                applyListSearch();
            }
        });
    });

    const backBtn = document.getElementById('importInboundBackToListBtn');
    if (backBtn) {
        backBtn.addEventListener('click', function () {
            window.__TACS_IMPORT_INBOUND_VIEW_MODE = 'list';
            window.__TACS_IMPORT_INBOUND_SELECTED_ROW = null;
            renderImportInboundManagePanelView('list');
        });
    }

    const supplementSubmitBtn = document.getElementById('importInboundSupplementSubmitBtn');
    if (supplementSubmitBtn) {
        supplementSubmitBtn.addEventListener('click', function () {
            submitImportInboundSupplement(window.__TACS_IMPORT_INBOUND_SELECTED_ROW, supplementSubmitBtn);
        });
    }
}

function getImportInboundAllRowsForView() {
    const registeredRows = Array.isArray(window.__TACS_IMPORT_INBOUND_REGISTERED_ROWS) ? window.__TACS_IMPORT_INBOUND_REGISTERED_ROWS : [];
    const manifestRows = Array.isArray(window.__TACS_IMPORT_INBOUND_MANIFEST_ROWS) ? window.__TACS_IMPORT_INBOUND_MANIFEST_ROWS : [];
    const merged = [];
    const seen = new Set();

    registeredRows.concat(manifestRows).forEach(function (row) {
        if (!row) return;
        const key = String(row.wirNo || row.inboundRequestNo || row.trcNo || row.requestNo || row.manifestNo || merged.length);
        if (seen.has(key)) return;
        seen.add(key);
        merged.push(row);
    });
    return merged;
}

function getImportInboundCurrentDetailRow(rows) {
    const selected = window.__TACS_IMPORT_INBOUND_SELECTED_ROW;
    if (selected) return selected;

    const body = document.getElementById('detail-body');
    const currentNo = String(
        body?.dataset?.trcNo ||
        body?.dataset?.currentTrcNo ||
        body?.dataset?.requestNo ||
        window.__TACS_IMPORT_CURRENT_TRC_NO ||
        window.__TACS_CURRENT_IMPORT_TRC_NO ||
        window.selectedImportRequestNo ||
        window.currentImportRequestNo ||
        ''
    ).trim();

    if (!currentNo) return (Array.isArray(rows) && rows.length ? rows[0] : null);
    return (Array.isArray(rows) ? rows : []).find(function (row) {
        const values = [row.trcNo, row.requestNo, row.inboundRequestNo, row.wirNo, row.manifestNo];
        return values.some(function (value) { return String(value || '').trim() === currentNo; });
    }) || (Array.isArray(rows) && rows.length ? rows[0] : null);
}

function buildImportInboundValueBox(label, value) {
    const esc = (typeof safeText === 'function') ? safeText : function (v) { return String(v == null ? '' : v); };
    return '' +
        '<div>' +
        '  <label class="field-label">' + esc(label) + '</label>' +
        '  <div class="field-input bg-slate-100 text-slate-900 font-bold min-h-[35px] flex items-center">' + esc(value || '-') + '</div>' +
        '</div>';
}

function buildImportInboundCargoReadonlyRows(cargo) {
    const esc = (typeof safeText === 'function') ? safeText : function (v) { return String(v == null ? '' : v); };
    const lines = Array.isArray(cargo) && cargo.length ? cargo : [];
    if (!lines.length) {
        return '<tr><td colspan="7" class="text-center text-slate-500 py-4">화물정보가 없습니다.</td></tr>';
    }
    return lines.map(function (line) {
        return '' +
            '<tr>' +
            '<td class="font-bold">' + esc(line.cgNo || line.shippingMark || '-') + '</td>' +
            '<td>' + esc(line.goodsDesc || line.goodsNo || '-') + '</td>' +
            '<td>' + esc(line.qty || '-') + '</td>' +
            '<td>' + esc(line.unitPrice || '-') + '</td>' +
            '<td>' + esc(line.amount || '-') + '</td>' +
            '<td>' + esc(line.weight || '-') + '</td>' +
            '<td>' + esc(line.origin || '-') + '</td>' +
            '</tr>';
    }).join('');
}

function buildImportInboundReadonlyDetail(row, showBackButton) {
    row = row || {};
    const esc = (typeof safeText === 'function') ? safeText : function (v) { return String(v == null ? '' : v); };

    const requestNo = row.inboundRequestNo || row.wirNo || row.requestNo || row.trcNo || '-';
    const inboundDt = row.inboundPlanDt || row.listAt || row.inPlanDt || '-';
    const target = row.targetWarehouseNm || row.warehouseZoneNm || row.bondedZoneNm || row.bondedManagerNm || row.targetWarehouse || '-';
    const status = normalizeImportInboundDisplayStatus(row.listStatus || row.requestStatus || row.statusNm || '');
    const invoiceNo = row.invoiceNo || '-';
    const masterBlNo = row.masterBlNo || row.mblNo || row.blNo || '-';
    const deptPort = row.deptPortNm || row.deptPortCd || '-';
    const arvlPort = row.arvlPortNm || row.arvlPortCd || '-';
    const owner = row.owner || row.consignee || '-';
    const cargoMgmtNo = row.cargoMgmtNo || row.listParty || '-';
    const incoTermsCd = row.incoTermsCd || '-';
    const note = row.requestNote || '-';

    const isSupplement = isImportInboundSupplementRequested(row) || status === '보완요청';
    const editableClass = isSupplement ? 'bg-white' : 'bg-slate-100';

    const warehouseSelectBoxes = function () {
        const currentWmId = String(row.bondedManagerId || row.wmId || row.targetWarehouse || '').trim();
        const currentWzNo = String(row.bondedZoneNo || row.wzNo || row.warehouseZoneNo || '').trim();
        const currentWhNo = String(row.whNo || row.warehouseNo || '').trim();
        const currentWarehouseNm = String(row.warehouseNm || row.whNm || '').trim();
        const currentZoneNm = String(row.warehouseZoneNm || row.bondedZoneNm || '').trim();
        const currentManagerNm = String(row.bondedManagerNm || row.warehouseManagerNm || row.wmNm || '').trim();

        if (!isSupplement) {
            return '' +
                valueBox('창고명', currentWarehouseNm || row.targetWarehouseNm || '-', 'warehouseNo', true) +
                valueBox('보세구역', currentZoneNm || '-', 'bondedZoneNo', true) +
                valueBox('창고담당자', currentManagerNm || target || '-', 'targetWarehouse', true);
        }

        const options = typeof getImportWarehouseManagerOptions === 'function'
            ? getImportWarehouseManagerOptions(getImportInboundAllRowsForView())
            : [];
        const realOptions = options.filter(function (opt) {
            return String(opt.value || opt.wmId || '').trim();
        });

        const uniqueBy = function (keyFn, labelFn) {
            const map = new Map();
            realOptions.forEach(function (opt) {
                const value = String(keyFn(opt) || '').trim();
                if (!value || map.has(value)) return;
                map.set(value, String(labelFn(opt) || value).trim());
            });
            return Array.from(map.entries()).map(function (entry) { return {value: entry[0], label: entry[1]}; });
        };

        const warehouseOptions = uniqueBy(
            function (opt) { return opt.whNo || opt.warehouseNo || opt.warehouseNm; },
            function (opt) { return opt.warehouseNm || opt.whNm || opt.label; }
        );
        const zoneOptions = uniqueBy(
            function (opt) { return opt.wzNo || opt.bondedZoneNo || opt.warehouseZoneNo || opt.warehouseZoneNm; },
            function (opt) { return opt.warehouseZoneNm || opt.bondedZoneNm || opt.zoneNm || opt.label; }
        );

        const optionTag = function (value, label, selected) {
            return '<option value="' + esc(value) + '"' + (selected ? ' selected' : '') + '>' + esc(label || value) + '</option>';
        };

        const hasCurrentWarehouseOption = warehouseOptions.some(function (opt) {
            return (currentWhNo && opt.value === currentWhNo) || (!currentWhNo && currentWarehouseNm && opt.label === currentWarehouseNm);
        });
        const currentWarehouseHtml = !hasCurrentWarehouseOption && (currentWhNo || currentWarehouseNm)
            ? optionTag(currentWhNo || currentWarehouseNm, currentWarehouseNm || currentWhNo, true)
            : '';
        const warehouseHtml = '<option value="">-- 창고명 선택 --</option>' + currentWarehouseHtml + warehouseOptions.map(function (opt) {
            const selected = (currentWhNo && opt.value === currentWhNo) || (!currentWhNo && currentWarehouseNm && opt.label === currentWarehouseNm);
            return optionTag(opt.value, opt.label, selected);
        }).join('');

        const hasCurrentZoneOption = zoneOptions.some(function (opt) {
            return (currentWzNo && opt.value === currentWzNo) || (!currentWzNo && currentZoneNm && opt.label === currentZoneNm);
        });
        const currentZoneHtml = !hasCurrentZoneOption && (currentWzNo || currentZoneNm)
            ? optionTag(currentWzNo || currentZoneNm, currentZoneNm || currentWzNo, true)
            : '';
        const zoneHtml = '<option value="">-- 보세구역 선택 --</option>' + currentZoneHtml + zoneOptions.map(function (opt) {
            const selected = (currentWzNo && opt.value === currentWzNo) || (!currentWzNo && currentZoneNm && opt.label === currentZoneNm);
            return optionTag(opt.value, opt.label, selected);
        }).join('');

        let hasCurrentManagerOption = false;
        const managerOptionHtml = realOptions.map(function (opt) {
            const value = String(opt.value || opt.wmId || '').trim();
            const label = String(opt.wmNm || opt.bondedManagerNm || opt.warehouseManagerNm || opt.managerNm || opt.label || value).trim();
            const wzNo = String(opt.wzNo || opt.bondedZoneNo || opt.warehouseZoneNo || '').trim();
            const whNo = String(opt.whNo || opt.warehouseNo || '').trim();
            const whNm = String(opt.warehouseNm || opt.whNm || '').trim();
            const zoneNm = String(opt.warehouseZoneNm || opt.bondedZoneNm || opt.zoneNm || '').trim();
            const selected =
                (currentWmId && value === currentWmId) ||
                (!currentWmId && currentManagerNm && label === currentManagerNm) ||
                (!currentWmId && currentWzNo && wzNo === currentWzNo);
            hasCurrentManagerOption = hasCurrentManagerOption || selected;
            return '<option value="' + esc(value) + '" data-wz-no="' + esc(wzNo) + '" data-wh-no="' + esc(whNo) + '" data-warehouse-nm="' + esc(whNm) + '" data-zone-nm="' + esc(zoneNm) + '"' + (selected ? ' selected' : '') + '>' + esc(label) + '</option>';
        }).join('');
        const currentManagerHtml = !hasCurrentManagerOption && (currentWmId || currentManagerNm)
            ? '<option value="' + esc(currentWmId) + '" data-wz-no="' + esc(currentWzNo) + '" data-wh-no="' + esc(currentWhNo) + '" data-warehouse-nm="' + esc(currentWarehouseNm) + '" data-zone-nm="' + esc(currentZoneNm) + '" selected>' + esc(currentManagerNm || currentWmId) + '</option>'
            : '';
        const managerHtml = '<option value="">-- 창고담당자 선택 --</option>' + currentManagerHtml + managerOptionHtml;

        return '' +
            '<div>' +
            '  <label class="field-label">창고명</label>' +
            '  <select class="field-select bg-white text-slate-900 font-bold min-h-[35px]" data-import-inbound-field="warehouseNo" data-current-wh-no="' + esc(currentWhNo) + '" data-current-warehouse-nm="' + esc(currentWarehouseNm) + '">' + warehouseHtml + '</select>' +
            '</div>' +
            '<div>' +
            '  <label class="field-label">보세구역</label>' +
            '  <select class="field-select bg-white text-slate-900 font-bold min-h-[35px]" data-import-inbound-field="bondedZoneNo" data-current-wz-no="' + esc(currentWzNo) + '" data-current-zone-nm="' + esc(currentZoneNm) + '">' + zoneHtml + '</select>' +
            '</div>' +
            '<div>' +
            '  <label class="field-label">창고담당자</label>' +
            '  <select class="field-select bg-white text-slate-900 font-bold min-h-[35px]" data-import-inbound-field="targetWarehouse" data-current-wm-id="' + esc(currentWmId) + '" data-current-manager-nm="' + esc(currentManagerNm) + '" data-current-wz-no="' + esc(currentWzNo) + '" data-current-wh-no="' + esc(currentWhNo) + '">' + managerHtml + '</select>' +
            '</div>';
    };

    const valueBox = function (label, value, key, forceReadonly) {
        const readonly = forceReadonly || !isSupplement;
        const cls = readonly ? 'bg-slate-100' : editableClass;
        const attr = readonly ? ' readonly' : '';
        return '' +
            '<div>' +
            '  <label class="field-label">' + esc(label) + '</label>' +
            '  <input class="field-input ' + cls + ' text-slate-900 font-bold min-h-[35px]" data-import-inbound-field="' + esc(key || '') + '" value="' + esc(value || '-') + '"' + attr + ' />' +
            '</div>';
    };

    const textareaBox = function (label, value, key, forceReadonly) {
        const readonly = forceReadonly || !isSupplement;
        const cls = readonly ? 'bg-slate-100' : editableClass;
        const attr = readonly ? ' readonly' : '';
        return '' +
            '<div><label class="field-label">' + esc(label) + '</label>' +
            '<textarea class="field-textarea ' + cls + ' text-slate-900 font-bold min-h-[68px] whitespace-pre-wrap" data-import-inbound-field="' + esc(key || '') + '"' + attr + '>' + esc(value || '-') + '</textarea></div>';
    };

    const cargoRows = function (cargo) {
        const lines = Array.isArray(cargo) && cargo.length ? cargo : [];
        if (!lines.length) {
            return '<tr><td colspan="7" class="text-center text-slate-500 py-4">화물정보가 없습니다.</td></tr>';
        }
        return lines.map(function (line) {
            if (!isSupplement) {
                return '' +
                    '<tr>' +
                    '<td class="font-bold">' + esc(line.cgNo || line.shippingMark || '-') + '</td>' +
                    '<td>' + esc(line.goodsDesc || line.goodsNo || '-') + '</td>' +
                    '<td>' + esc(line.qty || '-') + '</td>' +
                    '<td>' + esc(line.unitPrice || '-') + '</td>' +
                    '<td>' + esc(line.amount || '-') + '</td>' +
                    '<td>' + esc(line.weight || '-') + '</td>' +
                    '<td>' + esc(line.origin || '-') + '</td>' +
                    '</tr>';
            }
            const input = function (key, value, type) {
                return '<input class="field-input bg-white text-center font-bold min-w-[90px]" data-import-inbound-cargo-field="' + key + '" type="' + (type || 'text') + '" value="' + esc(value || '') + '" />';
            };
            return '' +
                '<tr data-goods-no="' + esc(line.goodsNo || '') + '">' +
                '<td>' + input('cgNo', line.cgNo || line.shippingMark) + '</td>' +
                '<td>' + input('goodsDesc', line.goodsDesc || line.goodsNo) + '</td>' +
                '<td>' + input('qty', line.qty, 'number') + '</td>' +
                '<td>' + input('unitPrice', line.unitPrice) + '</td>' +
                '<td>' + input('amount', line.amount) + '</td>' +
                '<td>' + input('weight', line.weight) + '</td>' +
                '<td>' + input('origin', line.origin) + '</td>' +
                '</tr>';
        }).join('');
    };

    return '' +
        '<div class="section-card overflow-hidden import-inbound-readonly-detail">' +
        '  <div class="p-5 space-y-5">' +
        (showBackButton ? '    <div class="flex justify-end"><button type="button" id="importInboundBackToListBtn" class="px-4 py-2 border border-slate-300 bg-white text-xs font-bold text-slate-700 hover:bg-slate-50">목록으로</button></div>' : '') +
        buildImportInboundSupplementNoticeHtml(row) +
        '    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">' +
        '      <section class="border border-slate-200 bg-white p-4 space-y-3">' +
        '        <h4 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">1. 입고요청 정보</h4>' +
                 valueBox('입고신청번호', row.inboundRequestNo || row.wirNo || '-', 'manifestNo', true) +
                 valueBox('의뢰번호', row.trcNo || row.requestNo || '-', 'requestNo', true) +
                 valueBox('입고요청일', inboundDt, 'inboundPlanDt') +
                 warehouseSelectBoxes() +
                 valueBox('입고상태', status, 'requestStatus', true) +
        '      </section>' +
        '      <section class="border border-slate-200 bg-white p-4 space-y-3">' +
        '        <h4 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">2. 운송/B/L 정보</h4>' +
                 valueBox('송장번호', invoiceNo, 'invoiceNo') +
                 valueBox('Master B/L', masterBlNo, 'masterBlNo') +
                 valueBox('출발지', deptPort, 'deptPort') +
                 valueBox('목적지', arvlPort, 'arvlPort') +
        '      </section>' +
        '      <section class="border border-slate-200 bg-white p-4 space-y-3">' +
        '        <h4 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">3. 화주/화물/요청</h4>' +
                 valueBox('화주', owner, 'owner') +
                 valueBox('화물관리번호', cargoMgmtNo, 'cargoMgmtNo') +
                 valueBox('인코텀즈', incoTermsCd, 'incoTermsCd') +
                 textareaBox('요청사항', note, 'requestNote') +
        '      </section>' +
        '    </div>' +
        '    <section class="space-y-3">' +
        '      <h4 class="text-sm font-black text-slate-900 border-l-4 border-slate-800 pl-3">4. 화물 정보</h4>' +
        '      <div class="overflow-x-auto border border-slate-200">' +
        '        <table class="w-full tbl min-w-[900px] text-xs">' +
        '          <thead><tr><th>화물번호<br><span class="text-[10px] font-semibold text-slate-500">CG_NO</span></th><th>품목명<br><span class="text-[10px] font-semibold text-slate-500">GOODS_NAME</span></th><th>수량<br><span class="text-[10px] font-semibold text-slate-500">CG_QTY</span></th><th>단가<br><span class="text-[10px] font-semibold text-slate-500">CG_PRICE</span></th><th>총액<br><span class="text-[10px] font-semibold text-slate-500">CG_TOTAL_PRICE</span></th><th>중량<br><span class="text-[10px] font-semibold text-slate-500">CG_WEIGHT</span></th><th>원산지<br><span class="text-[10px] font-semibold text-slate-500">CG_ORIGIN</span></th></tr></thead>' +
        '          <tbody>' + cargoRows(row.cargo) + '</tbody>' +
        '        </table>' +
        '      </div>' +
        '    </section>' +
        (isSupplement ? '  <div class="section-card-action-footer flex justify-end gap-2 px-5 py-3 border-t border-slate-200 bg-white"><button type="button" id="importInboundSupplementSubmitBtn" class="px-4 py-2 bg-slate-800 text-white text-xs font-bold hover:bg-slate-700">보완제출</button></div>' : '') +
        '  </div>' +
        '</div>';
}

function getImportInboundCategorySearch() {
    const search = window.__TACS_IMPORT_INBOUND_CATEGORY_SEARCH || {
        inboundNo: '',
        owner: '',
        cargoNo: '',
        masterBlNo: '',
        status: ''
    };
    ['inboundNo', 'owner', 'cargoNo', 'masterBlNo', 'status'].forEach(function (key) {
        search[key] = cleanImportInboundSearchValue(search[key]);
        if (search[key] == null) search[key] = '';
    });
    return search;
}

function normalizeImportInboundSearchText(value) {
    return String(value == null ? '' : value).trim().toLowerCase();
}

function cleanImportInboundSearchValue(value) {
    const text = String(value == null ? '' : value).trim();
    return (text === '-' || text === '－' || text === '—') ? '' : text;
}

function normalizeImportInboundDisplayStatus(value) {
    const raw = String(value == null ? '' : value).trim();
    const upper = raw.toUpperCase();
    if (!raw || raw === '-') return '';
    if (raw === '등록대기' || raw === '입고요청' || raw === '입고대기') return '입고대기';
    if (raw === '보완요청' || ['REQ_FIX', 'FIX_REQ', 'SUPPLEMENT', 'SUPPLEMENT_REQUESTED'].includes(upper)) return '보완요청';
    if (raw === '반려' || ['REJECT', 'REJECTED', 'REJ'].includes(upper)) return '반려';
    return raw;
}

function filterImportInboundCategoryRows(rows) {
    const search = getImportInboundCategorySearch();
    const inbound = normalizeImportInboundSearchText(search.inboundNo);
    const owner = normalizeImportInboundSearchText(search.owner);
    const cargo = normalizeImportInboundSearchText(search.cargoNo);
    const bl = normalizeImportInboundSearchText(search.masterBlNo);
    const status = normalizeImportInboundSearchText(search.status);

    return (rows || []).filter(function (row) {
        const inboundText = normalizeImportInboundSearchText(row.inboundRequestNo || row.wirNo);
        const ownerText = normalizeImportInboundSearchText(row.owner || row.consignee || row.ownerNm);
        const cargoText = normalizeImportInboundSearchText(row.cargoMgmtNo || row.listParty);
        const blText = normalizeImportInboundSearchText(row.masterBlNo || row.mblNo || row.blNo);
        const statusText = normalizeImportInboundSearchText(normalizeImportInboundDisplayStatus(row.listStatus || row.requestStatus || row.statusNm));

        return (!inbound || inboundText.indexOf(inbound) >= 0)
            && (!owner || ownerText.indexOf(owner) >= 0)
            && (!cargo || cargoText.indexOf(cargo) >= 0)
            && (!bl || blText.indexOf(bl) >= 0)
            && (!status || statusText.indexOf(status) >= 0);
    });
}

function getImportInboundWarehouseName(row) {
    row = row || {};
    const direct = row.whNm || row.warehouseNm || row.whName || '';
    if (direct && direct !== '-') return direct;
    const target = String(row.targetWarehouseNm || row.targetWarehouse || '').trim();
    if (target && target !== '-') {
        if (target.indexOf('/') >= 0) return target.split('/')[0].trim();
        if (target.indexOf('창고') >= 0) return target;
    }
    return '-';
}

function getImportInboundZoneName(row) {
    row = row || {};
    const direct = row.warehouseZoneNm || row.wzNm || row.bondedZoneNm || row.zoneNm || '';
    if (direct && direct !== '-') return direct;
    const target = String(row.targetWarehouseNm || row.targetWarehouse || '').trim();
    if (target && target.indexOf('/') >= 0) return target.split('/').slice(1).join('/').trim() || '-';
    return '-';
}

function buildImportInboundCategoryListRows(rows, loading, emptyMessage, allRows) {
    const esc = (typeof safeText === 'function') ? safeText : function (v) { return String(v == null ? '' : v); };
    const sourceRows = Array.isArray(allRows) ? allRows : (rows || []);
    if (loading) {
        return '<tr><td colspan="8" class="text-center text-slate-500 py-6">보세구역 입고관리 목록을 불러오는 중입니다.</td></tr>';
    }
    if (!rows || !rows.length) {
        return '<tr><td colspan="8" class="text-center text-slate-500 py-6">' + esc(emptyMessage || '보세구역 입고관리 대상 의뢰가 없습니다.') + '</td></tr>';
    }
    return rows.map(function (row) {
        const warehouseNm = getImportInboundWarehouseName(row);
        const zoneNm = getImportInboundZoneName(row);
        const ownerNm = row.owner || row.consignee || row.ownerNm || '-';
        const inboundDt = row.inboundPlanDt || row.listAt || row.inPlanDt || '-';
        const status = normalizeImportInboundDisplayStatus(row.listStatus || row.requestStatus || row.statusNm || '');
        return '' +
            '<tr class="import-inbound-list-row">' +
            '<td class="font-bold text-slate-900">' + esc(row.inboundRequestNo || row.wirNo || '-') + '</td>' +
            '<td>' + esc(ownerNm) + '</td>' +
            '<td>' + esc(row.cargoMgmtNo || row.listParty || '-') + '</td>' +
            '<td>' + esc(row.masterBlNo || row.mblNo || row.blNo || '-') + '</td>' +
            '<td>' + esc(warehouseNm) + '</td>' +
            '<td>' + esc(zoneNm) + '</td>' +
            '<td class="text-center whitespace-nowrap">' + esc(inboundDt) + '</td>' +
            '<td class="text-center"><span class="info-chip whitespace-nowrap">' + esc(status) + '</span></td>' +
            '</tr>';
    }).join('');
}

function buildImportInboundCategoryListPanel(rows, loading) {
    const esc = (typeof safeText === 'function') ? safeText : function (v) { return String(v == null ? '' : v); };
    rows = Array.isArray(rows) ? rows : [];
    const search = getImportInboundCategorySearch();
    const filteredRows = filterImportInboundCategoryRows(rows);
    const emptyMessage = rows && rows.length ? '검색 조건에 맞는 보세구역 입고관리 대상이 없습니다.' : '보세구역 입고관리 대상 의뢰가 없습니다.';
    const selected = function (value) {
        return String(search.status || '') === value ? ' selected' : '';
    };

    return '' +
        '<div class="section-card overflow-hidden">' +
        '  <div class="bg-slate-50 px-6 py-4 border-b border-slate-200">' +
        '      <h4 class="text-sm font-bold text-slate-900">보세구역 입고관리 목록</h4>' +
        '  </div>' +
        '  <div class="p-6 space-y-4">' +
        '    <div class="list-search-grid">' +
        '      <div><label class="field-label">입고의뢰번호</label><input id="importInboundSearchInboundNo" class="field-input" type="text" autocomplete="off" value="' + esc(cleanImportInboundSearchValue(search.inboundNo)) + '" placeholder="입고의뢰번호"></div>' +
        '      <div><label class="field-label">화주명</label><input id="importInboundSearchOwner" class="field-input" type="text" autocomplete="off" value="' + esc(cleanImportInboundSearchValue(search.owner)) + '" placeholder="화주명"></div>' +
        '      <div><label class="field-label">화물관리번호</label><input id="importInboundSearchCargoNo" class="field-input" type="text" autocomplete="off" value="' + esc(cleanImportInboundSearchValue(search.cargoNo)) + '" placeholder="화물관리번호"></div>' +
        '      <div><label class="field-label">Master B/L</label><input id="importInboundSearchMasterBlNo" class="field-input" type="text" autocomplete="off" value="' + esc(cleanImportInboundSearchValue(search.masterBlNo)) + '" placeholder="Master B/L"></div>' +
        '      <div><label class="field-label">상태</label><select id="importInboundSearchStatus" class="field-select"><option value="">전체</option><option value="입고대기"' + selected('입고대기') + '>입고대기</option><option value="입고완료"' + selected('입고완료') + '>입고완료</option><option value="보완요청"' + selected('보완요청') + '>보완요청</option><option value="보완제출완료"' + selected('보완제출완료') + '>보완제출완료</option></select></div>' +
        '      <button type="button" id="importInboundSearchBtn" class="px-4 py-2 bg-slate-800 text-white text-xs font-bold hover:bg-slate-900">조회</button>' +
        '    </div>' +
        '    <div class="overflow-hidden border border-slate-200">' +
        '      <table class="w-full tbl table-fixed text-xs">' +
        '        <thead><tr><th>입고의뢰번호</th><th>화주명</th><th>화물관리번호</th><th>Master B/L</th><th>창고명</th><th>창고구역</th><th>입고요청일</th><th>상태</th></tr></thead>' +
        '        <tbody>' + buildImportInboundCategoryListRows(filteredRows, loading, emptyMessage, rows) + '</tbody>' +
        '      </table>' +
        '    </div>' +
        '  </div>' +
        '</div>';
}

function cleanImportInboundPayloadValue(value) {
    const text = String(value == null ? '' : value).trim();
    return (text === '-' || text === '－' || text === '—') ? '' : text;
}

function parseImportInboundNumber(value) {
    const text = cleanImportInboundPayloadValue(value).replace(/,/g, '');
    if (!text) return null;
    const number = Number(text);
    return Number.isFinite(number) ? number : null;
}

function getImportInboundDetailFieldValue(key) {
    return cleanImportInboundPayloadValue(document.querySelector('[data-import-inbound-field="' + key + '"]')?.value);
}

function collectImportInboundCargoPayload() {
    return Array.from(document.querySelectorAll('.import-inbound-readonly-detail tbody tr')).map(function (tr) {
        const value = function (key) {
            return cleanImportInboundPayloadValue(tr.querySelector('[data-import-inbound-cargo-field="' + key + '"]')?.value);
        };
        const cgNo = parseImportInboundNumber(value('cgNo'));
        if (!cgNo) return null;
        return {
            cgNo: cgNo,
            goodsNo: parseImportInboundNumber(tr.getAttribute('data-goods-no')),
            goodsName: value('goodsDesc'),
            qty: parseImportInboundNumber(value('qty')),
            price: parseImportInboundNumber(value('unitPrice')),
            goodsTotalPrice: parseImportInboundNumber(value('amount')),
            weight: parseImportInboundNumber(value('weight')),
            origin: value('origin')
        };
    }).filter(Boolean);
}

function collectImportInboundSupplementPayload(row) {
    row = row || {};
    const targetSelect = document.querySelector('[data-import-inbound-field="targetWarehouse"]');
    const zoneSelect = document.querySelector('[data-import-inbound-field="bondedZoneNo"]');
    const warehouseSelect = document.querySelector('[data-import-inbound-field="warehouseNo"]');
    const selectedOption = targetSelect?.options?.[targetSelect.selectedIndex] || null;
    const selectedZoneOption = zoneSelect?.options?.[zoneSelect.selectedIndex] || null;
    const selectedWarehouseOption = warehouseSelect?.options?.[warehouseSelect.selectedIndex] || null;

    let wmId = cleanImportInboundPayloadValue(
        targetSelect?.value ||
        targetSelect?.dataset?.currentWmId ||
        row.bondedManagerId ||
        row.wmId ||
        row.warehouseManagerId ||
        row.targetWarehouse
    );
    let wzNo = cleanImportInboundPayloadValue(
        selectedOption?.dataset?.wzNo ||
        zoneSelect?.value ||
        zoneSelect?.dataset?.currentWzNo ||
        targetSelect?.dataset?.currentWzNo ||
        row.bondedZoneNo ||
        row.wzNo ||
        row.warehouseZoneNo
    );
    const whNo = cleanImportInboundPayloadValue(
        selectedOption?.dataset?.whNo ||
        warehouseSelect?.value ||
        warehouseSelect?.dataset?.currentWhNo ||
        targetSelect?.dataset?.currentWhNo ||
        row.whNo ||
        row.warehouseNo
    );

    // 화면에 기존 값이 input/텍스트로만 표시되어 select value가 비어도,
    // 창고관리자 옵션 목록에서 창고/구역/담당자 이름 또는 구역번호로 다시 찾아서 wmId/wzNo를 보완한다.
    if ((!wmId || !wzNo) && typeof getImportWarehouseManagerOptions === 'function') {
        const options = getImportWarehouseManagerOptions(getImportInboundAllRowsForView()).filter(function (opt) {
            return String(opt.value || opt.wmId || '').trim();
        });
        const warehouseText = cleanImportInboundPayloadValue(
            selectedWarehouseOption?.textContent ||
            warehouseSelect?.dataset?.currentWarehouseNm ||
            row.warehouseNm ||
            row.whNm
        );
        const zoneText = cleanImportInboundPayloadValue(
            selectedZoneOption?.textContent ||
            zoneSelect?.dataset?.currentZoneNm ||
            row.warehouseZoneNm ||
            row.bondedZoneNm
        );
        const managerText = cleanImportInboundPayloadValue(
            selectedOption?.textContent ||
            targetSelect?.dataset?.currentManagerNm ||
            row.bondedManagerNm ||
            row.warehouseManagerNm ||
            row.wmNm
        );
        const matched = options.find(function (opt) {
            const optWmId = String(opt.value || opt.wmId || '').trim();
            const optWzNo = String(opt.wzNo || opt.bondedZoneNo || opt.warehouseZoneNo || '').trim();
            const optWhNo = String(opt.whNo || opt.warehouseNo || '').trim();
            const optWhNm = String(opt.warehouseNm || opt.whNm || '').trim();
            const optZoneNm = String(opt.warehouseZoneNm || opt.bondedZoneNm || opt.zoneNm || '').trim();
            const optManagerNm = String(opt.wmNm || opt.bondedManagerNm || opt.warehouseManagerNm || opt.managerNm || opt.label || '').trim();
            return (wmId && optWmId === wmId) ||
                (wzNo && optWzNo === wzNo) ||
                (whNo && optWhNo === whNo && (!zoneText || optZoneNm === zoneText)) ||
                (managerText && optManagerNm === managerText) ||
                (warehouseText && optWhNm === warehouseText && (!zoneText || optZoneNm === zoneText));
        });
        if (matched) {
            wmId = wmId || cleanImportInboundPayloadValue(matched.value || matched.wmId);
            wzNo = wzNo || cleanImportInboundPayloadValue(matched.wzNo || matched.bondedZoneNo || matched.warehouseZoneNo);
        }
    }

    return {
        wirNo: cleanImportInboundPayloadValue(row.wirNo || row.inboundRequestNo || row.requestNo),
        receiverId: wmId,
        wmId: wmId,
        wzNo: wzNo,
        inPlanDt: getImportInboundDetailFieldValue('inboundPlanDt'),
        cargoMgmtNo: cleanImportInboundPayloadValue(getImportInboundDetailFieldValue('cargoMgmtNo') || row.cargoMgmtNo || row.listParty),
        invoiceNo: getImportInboundDetailFieldValue('invoiceNo'),
        incoTermsCd: getImportInboundDetailFieldValue('incoTermsCd'),
        remark: getImportInboundDetailFieldValue('requestNote'),
        goodsJson: JSON.stringify(collectImportInboundCargoPayload())
    };
}

function applyImportInboundSupplementPayloadToRow(row, payload) {
    if (!row || !payload) return row;
    row.bondedManagerId = payload.wmId || row.bondedManagerId;
    row.wmId = payload.wmId || row.wmId;
    row.bondedZoneNo = payload.wzNo || row.bondedZoneNo;
    row.wzNo = payload.wzNo || row.wzNo;
    row.inboundPlanDt = payload.inPlanDt || row.inboundPlanDt;
    row.inPlanDt = payload.inPlanDt || row.inPlanDt;
    row.cargoMgmtNo = payload.cargoMgmtNo || row.cargoMgmtNo;
    row.invoiceNo = payload.invoiceNo || row.invoiceNo;
    row.incoTermsCd = payload.incoTermsCd || row.incoTermsCd;
    row.requestNote = payload.remark || row.requestNote;
    row.listStatus = '보완제출완료';
    row.requestStatus = '보완제출완료';
    row.statusNm = '보완제출완료';
    row.statusCd = 'REQ_SENT';
    try {
        row.cargo = JSON.parse(payload.goodsJson || '[]').map(function (goods) {
            return {
                cgNo: goods.cgNo || '',
                goodsNo: goods.goodsNo || '',
                shippingMark: goods.cgNo || '',
                goodsDesc: goods.goodsName || '',
                qty: goods.qty || '',
                unitPrice: goods.price || '',
                amount: goods.goodsTotalPrice || '',
                weight: goods.weight || '',
                origin: goods.origin || ''
            };
        });
    } catch (e) {}
    return row;
}

function submitImportInboundSupplement(row, button) {
    const payload = collectImportInboundSupplementPayload(row);
    if (!payload.wirNo) {
        alert('입고의뢰번호를 찾을 수 없습니다.');
        return;
    }
    if (!payload.wmId) {
        alert('창고명, 보세구역, 창고담당자를 선택해주세요.');
        return;
    }
    if (!confirm('수정한 입고관리 정보를 보완제출하시겠습니까?')) {
        return;
    }

    const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';
    const headers = {
        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
        'X-Requested-With': 'XMLHttpRequest',
        'Accept': 'application/json'
    };
    const csrf = window.TRANSPORT_CSRF || {};
    const csrfHeader = csrf.header || document.querySelector('meta[name="_csrf_header"]')?.getAttribute('content');
    const csrfToken = csrf.token || document.querySelector('meta[name="_csrf"]')?.getAttribute('content');
    if (csrfHeader && csrfToken) {
        headers[csrfHeader] = csrfToken;
    }

    if (button) button.disabled = true;

    fetch(contextPath + '/transport/import/unloading-in/supplement.do', {
        method: 'POST',
        headers: headers,
        body: new URLSearchParams(payload).toString()
    })
        .then(function (res) {
            if (!res.ok) throw new Error('HTTP ' + res.status);
            return res.json();
        })
        .then(function (data) {
            if (!data || data.success !== true) {
                throw new Error(data?.message || '보완제출 실패');
            }
            applyImportInboundSupplementPayloadToRow(row, payload);
            window.__TACS_IMPORT_INBOUND_LOADED = false;
            window.__TACS_IMPORT_UNLOADING_LOADED = false;
            if (typeof loadImportUnloadingInRows === 'function') loadImportUnloadingInRows();
            alert(data.message || '보완제출이 완료되었습니다.');
            renderImportInboundManagePanelView('list');
        })
        .catch(function (err) {
            console.error('[수입 보세구역 입고관리 보완제출 실패]', err);
            alert('보완제출 처리에 실패했습니다. 입력값과 서버 로그를 확인해주세요.');
        })
        .finally(function () {
            if (button) button.disabled = false;
        });
}


function resetImportInboundCategoryToList() {
    window.__TACS_IMPORT_INBOUND_VIEW_MODE = 'list';
    window.__TACS_IMPORT_INBOUND_SELECTED_ROW = null;
    window.__TACS_IMPORT_INBOUND_FORCE_LIST_ON_NEXT_RENDER = false;

    const body = document.getElementById('detail-body');
    if (body) {
        delete body.dataset.trcNo;
        delete body.dataset.currentTrcNo;
        delete body.dataset.requestNo;
        body.dataset.currentGroup = 'import';
        body.dataset.currentItem = 'TACS-FW-025';
    }
}

window.resetImportInboundCategoryToList = resetImportInboundCategoryToList;

function buildUnloadingCoordinationPanel() {
    if (!window.__TACS_IMPORT_INBOUND_MANIFEST_LOADED && !window.__TACS_IMPORT_INBOUND_MANIFEST_LOADING) {
        loadImportInboundManifestRows();
    }
    if (!window.__TACS_IMPORT_WAREHOUSE_MANAGERS_LOADED && !window.__TACS_IMPORT_WAREHOUSE_MANAGERS_LOADING) {
        loadImportWarehouseManagers();
    }

    if (window.__TACS_IMPORT_INBOUND_FORCE_LIST_ON_NEXT_RENDER === true) {
        resetImportInboundCategoryToList();
    }

    const rows = getImportInboundAllRowsForView();
    const loading = window.__TACS_IMPORT_INBOUND_MANIFEST_LOADING;
    const viewMode = 'list';

    return '' +
        '<div class="import-inbound-manage-panel" data-item-id="TACS-FW-025" data-view-mode="' + viewMode + '">' +
        buildImportInboundCategoryListPanel(rows, loading) +
        '</div>';
}

function bindUnloadingCoordinationActions(groupKey, itemId) {
    if (itemId !== 'TACS-FW-025') return;

    const submitBtn = detailBody.querySelector('.unloading-submit-btn');
    const deliveryStatus = detailBody.querySelector('.unloading-delivery-status');
    const warehouseStatus = detailBody.querySelector('.unloading-warehouse-status');
    const warehouseManager = detailBody.querySelector('.unloading-warehouse-manager');

    if (submitBtn) {
        submitBtn.addEventListener('click', function () {
            if (!warehouseManager || !warehouseManager.value) {
                alert('전달대상 창고관리자를 선택해주세요.');
                return;
            }

            const selected = window.__TACS_IMPORT_UNLOADING_SELECTED || {};
            const trcNo = selected.trcNo || selected.requestNo || detailBody.querySelector('[data-bonded-field="requestNo"]')?.value || '';
            const wirNo = selected.wirNo || selected.inboundRequestNo || detailBody.querySelector('[data-bonded-field="manifestNo"]')?.value || '';

            if (!trcNo) {
                alert('운송의뢰번호(TRC_NO)를 찾을 수 없습니다. 목록에서 항목을 다시 선택해주세요.');
                return;
            }

            if (!wirNo) {
                alert('입고요청번호(WIR_NO)를 찾을 수 없습니다. 목록에서 항목을 다시 선택해주세요.');
                return;
            }

            const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';
            const headers = {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                'X-Requested-With': 'XMLHttpRequest',
                'Accept': 'application/json'
            };
            const csrf = window.TRANSPORT_CSRF || {};
            const csrfHeader = csrf.header || document.querySelector('meta[name="_csrf_header"]')?.getAttribute('content');
            const csrfToken = csrf.token || document.querySelector('meta[name="_csrf"]')?.getAttribute('content');
            if (csrfHeader && csrfToken) {
                headers[csrfHeader] = csrfToken;
            }

            submitBtn.disabled = true;

            fetch(contextPath + '/transport/import/unloading-in/deliver.do', {
                method: 'POST',
                headers: headers,
                body: new URLSearchParams({trcNo, wirNo, wmId: warehouseManager.value}).toString()
            })
                .then(function (res) {
                    if (!res.ok) throw new Error('HTTP ' + res.status);
                    return res.json();
                })
                .then(function (result) {
                    if (!result || result.success !== true) {
                        throw new Error('DB update failed');
                    }
                    if (deliveryStatus) deliveryStatus.value = '입고요청';
                    if (warehouseStatus) warehouseStatus.value = '입고요청';
                    window.__TACS_IMPORT_UNLOADING_LOADED = false;
                    if (typeof loadImportUnloadingInRows === 'function') loadImportUnloadingInRows();
                    alert('보세구역 입고관리 정보가 창고관리자에게 전달되었습니다.');
                })
                .catch(function (err) {
                    console.error('보세구역 입고관리 전달 실패', err);
                    alert('전달 처리에 실패했습니다. 서버 로그와 Network의 deliver.do 응답을 확인해주세요.');
                })
                .finally(function () {
                    submitBtn.disabled = false;
                });
        });
    }
}


function buildBondedReleaseRequestListPanel() {
    return buildBondedCargoWorkPanel({
        itemId: 'TACS-FW-009',
        listTitle: '보세구역 반출요청',
        listDesc: '수출 보세구역 입고 완료 화물을 선택하면 오른쪽에서 반출요청 정보와 화물정보를 한 화면에서 작성할 수 있습니다.',
        partyTitle: '보세구역',
        dateTitle: '반출일시',
        formTitle: '수출 보세구역 반출요청',
        formDesc: '수출신고필증, 입고요청, 배차정보를 기준으로 창고관리자에게 보세구역 반출을 요청합니다.',
        infoTitle: '반출요청 정보',
        completeStatus: '반출완료',
        statusField: 'releaseStatus',
        submitLabel: '반출요청',
        submitMessage: '수출 보세구역 반출요청 정보가 창고관리자에게 전송되었습니다.',
        fields: [
            {key: 'releaseRequestNo', label: '반출요청번호', readonly: true},
            {key: 'exportDeclNo', label: '수출신고필증번호', readonly: true},
            {key: 'warehouseNo', label: '창고번호', readonly: true},
            {key: 'releasePlanDt', label: '반출일시', inputType: 'date'},
            {
                key: 'targetWarehouse',
                label: '전달대상',
                type: 'select',
                options: ['인천항 보세창고 관리자', '부산항 보세창고 관리자', '평택항 보세창고 관리자']
            },
            {key: 'pickupPlace', label: '상차지(보세구역)'},
            {key: 'vehicleDriver', label: '차량/기사'},
            {key: 'shippingPort', label: '선적항'}
        ],
        rows: getLegacyExportReleaseRows()
    });
}


function bindBondedReleaseRequestActions(groupKey, itemId) {
    if (itemId !== 'TACS-FW-009') return;

    const requestModal = document.getElementById('bondedReleaseRequestModal');
    const requestClose = document.getElementById('bondedReleaseModalClose');
    const requestCancel = document.getElementById('bondedReleaseModalCancel');
    const requestSubmit = document.getElementById('bondedReleaseModalSubmit');
    const reqNoInput = document.getElementById('bondedReleaseReqNo');
    const ownerInput = document.getElementById('bondedReleaseOwner');
    const certInput = document.getElementById('bondedReleaseCertNo');
    const itemInput = document.getElementById('bondedReleaseItem');
    const cargoNoInput = document.getElementById('bondedReleaseCargoNo');
    const pkgInput = document.getElementById('bondedReleasePkg');
    const weightInput = document.getElementById('bondedReleaseWeight');
    const cbmInput = document.getElementById('bondedReleaseCbm');
    const vehicleInput = document.getElementById('bondedReleaseVehicle');
    const driverInput = document.getElementById('bondedReleaseDriver');
    const portInput = document.getElementById('bondedReleasePort');
    const vesselInput = document.getElementById('bondedReleaseVessel');
    const zoneSelect = document.getElementById('bondedReleaseZone');
    const managerSelect = document.getElementById('bondedReleaseManager');

    const passModal = document.getElementById('bondedPassRequestModal');
    const passClose = document.getElementById('bondedPassModalClose');
    const passCancel = document.getElementById('bondedPassModalCancel');
    const passSubmit = document.getElementById('bondedPassModalSubmit');
    const passReqNo = document.getElementById('bondedPassReqNo');
    const passOwner = document.getElementById('bondedPassOwner');
    const passCertNo = document.getElementById('bondedPassCertNo');
    const passItem = document.getElementById('bondedPassItem');
    const passZone = document.getElementById('bondedPassZone');
    const passManager = document.getElementById('bondedPassManager');

    const rejectModal = document.getElementById('bondedReleaseRejectModal');
    const rejectReason = document.getElementById('bondedReleaseRejectReason');
    const rejectClose = document.getElementById('bondedReleaseRejectClose');
    const rejectConfirm = document.getElementById('bondedReleaseRejectConfirm');

    let selectedRow = null;
    let selectedPassRow = null;

    function openRequestModal(btn) {
        selectedRow = btn.closest('tr');
        reqNoInput.value = btn.dataset.requestNo || '';
        ownerInput.value = btn.dataset.owner || '';
        certInput.value = btn.dataset.certNo || '';
        itemInput.value = btn.dataset.item || '';
        if (cargoNoInput) cargoNoInput.value = btn.dataset.cargoNo || '';
        if (pkgInput) pkgInput.value = btn.dataset.pkg || '';
        if (weightInput) weightInput.value = btn.dataset.weight || '';
        if (cbmInput) cbmInput.value = btn.dataset.cbm || '';
        if (vehicleInput) vehicleInput.value = btn.dataset.vehicle || '';
        if (driverInput) driverInput.value = btn.dataset.driver || '';
        if (portInput) portInput.value = btn.dataset.port || '';
        if (vesselInput) vesselInput.value = `${btn.dataset.vessel || ''}${btn.dataset.voyage ? ' / ' + btn.dataset.voyage : ''}`;
        zoneSelect.value = btn.dataset.zone || zoneSelect.options[0].value;
        managerSelect.value = btn.dataset.manager || '';
        requestModal.classList.remove('hidden');
        requestModal.classList.add('flex');
    }

    function closeRequestModal() {
        requestModal.classList.add('hidden');
        requestModal.classList.remove('flex');
    }

    function closeRejectModal() {
        rejectModal.classList.add('hidden');
        rejectModal.classList.remove('flex');
    }

    function openPassModal(btn) {
        selectedPassRow = btn.closest('tr');
        passReqNo.value = btn.dataset.requestNo || '';
        passOwner.value = btn.dataset.owner || '';
        passCertNo.value = btn.dataset.certNo || '';
        passItem.value = btn.dataset.item || '';
        passZone.value = btn.dataset.zone || '';
        passManager.value = btn.dataset.manager || '';
        passModal.classList.remove('hidden');
        passModal.classList.add('flex');
    }

    function closePassModal() {
        passModal.classList.add('hidden');
        passModal.classList.remove('flex');
    }

    detailBody.querySelectorAll('.bonded-release-request-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            openRequestModal(this);
        });
    });

    detailBody.querySelectorAll('.bonded-pass-request-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            openPassModal(this);
        });
    });

    detailBody.querySelectorAll('.bonded-release-reject-reason-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            rejectReason.value = this.dataset.reason || '반려 사유가 등록되어 있지 않습니다.';
            rejectModal.classList.remove('hidden');
            rejectModal.classList.add('flex');
        });
    });

    if (requestClose) requestClose.addEventListener('click', closeRequestModal);
    if (requestCancel) requestCancel.addEventListener('click', closeRequestModal);
    if (requestModal) requestModal.addEventListener('click', e => {
        if (e.target === requestModal) closeRequestModal();
    });

    if (passClose) passClose.addEventListener('click', closePassModal);
    if (passCancel) passCancel.addEventListener('click', closePassModal);
    if (passModal) passModal.addEventListener('click', e => {
        if (e.target === passModal) closePassModal();
    });


    if (rejectClose) rejectClose.addEventListener('click', closeRejectModal);
    if (rejectConfirm) rejectConfirm.addEventListener('click', closeRejectModal);
    if (rejectModal) rejectModal.addEventListener('click', e => {
        if (e.target === rejectModal) closeRejectModal();
    });

    if (requestSubmit) {
        requestSubmit.addEventListener('click', function () {
            if (!managerSelect.value) {
                alert('보세구역 창고관리자를 선택하세요.');
                return;
            }

            if (selectedRow) {
                const managerCell = selectedRow.querySelector('.warehouse-manager-cell');
                const statusCell = selectedRow.querySelector('.bonded-release-status-cell');
                const actionCell = selectedRow.querySelector('.bonded-release-action-cell');

                if (managerCell) managerCell.textContent = managerSelect.value;
                if (statusCell) statusCell.innerHTML = '<span class="info-chip">요청대기</span>';
                if (actionCell) actionCell.innerHTML = '<button type="button" class="px-3 py-1 border border-slate-300 bg-slate-700 text-white text-xs font-bold" disabled>발송완료</button>';
            }

            closeRequestModal();
            alert('선택한 보세구역 창고관리자에게 반출 요청이 전송되었습니다.');
        });
    }

    if (passSubmit) {
        passSubmit.addEventListener('click', function () {
            if (selectedPassRow) {
                const statusCell = selectedPassRow.querySelector('.bonded-release-status-cell');
                const actionCell = selectedPassRow.querySelector('.bonded-release-action-cell');
                if (statusCell) statusCell.innerHTML = '<span class="info-chip">승인완료</span>';
                if (actionCell) actionCell.innerHTML = '<button type="button" class="px-3 py-1 border border-slate-300 bg-slate-700 text-white text-xs font-bold" disabled>발송완료</button>';
            }
            closePassModal();
            alert('반출증 요청이 전송되었습니다.');
        });
    }
}
