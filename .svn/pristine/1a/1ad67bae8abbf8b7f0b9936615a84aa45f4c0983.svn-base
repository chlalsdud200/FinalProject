/* ── Filter bar ── */
.filter-bar { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; background: #fff; border: 1px solid #e2e8f0; padding: 12px 16px; }
.filter-bar label { font-size: 11px; font-weight: 700; color: #475569; white-space: nowrap; }
.filter-bar select { padding: 6px 10px; border: 1px solid #e2e8f0; font-size: 13px; background: #fff; color: #203444; outline: none; font-family: inherit; min-width: 140px; }
.filter-bar select:focus { border-color: #565e74; }
.filter-bar .filter-sep { width: 1px; height: 24px; background: #e2e8f0; margin: 0 4px; }
