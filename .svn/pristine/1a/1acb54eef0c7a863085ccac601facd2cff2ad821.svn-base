<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.systemadmin.notification.mapper.IAdminNotificationHistoryMapper">

    <resultMap id="historyMap" type="kr.or.tacs.vo.systemadmin.notification.AdminNotificationHistoryVO">
        <id property="notiNo" column="noti_no"/>
        <result property="notiEventCd" column="noti_event_cd"/>
        <result property="npBizNm" column="np_biz_nm"/>
        <result property="notiRefKey" column="noti_ref_key"/>
        <result property="notiReceiverId" column="noti_receiver_id"/>
        <result property="notiSenderId" column="noti_sender_id"/>
        <result property="notiTitle" column="noti_title"/>
        <result property="notiBody" column="noti_body"/>
        <result property="notiLinkUrl" column="noti_link_url"/>
        <result property="notiReadYn" column="noti_read_yn"/>
        <result property="notiReadDt" column="noti_read_dt"/>
        <result property="notiSendStatus" column="noti_send_status"/>
        <result property="notiRetryCount" column="noti_retry_count"/>
        <result property="notiLastError" column="noti_last_error"/>
        <result property="notiSendDt" column="noti_send_dt"/>
    </resultMap>

    <resultMap id="eventOptionMap" type="kr.or.tacs.vo.systemadmin.notification.AdminNotificationEventOptionVO">
        <result property="eventCd" column="np_event_cd"/>
        <result property="bizNm" column="np_biz_nm"/>
    </resultMap>

    <sql id="historyColumns">
          n.noti_no
        , n.noti_event_cd
        , p.np_biz_nm
        , n.noti_ref_key
        , n.noti_receiver_id
        , n.noti_sender_id
        , n.noti_title
        , n.noti_body
        , n.noti_link_url
        , n.noti_read_yn
        , TO_CHAR(n.noti_read_dt, 'YYYY-MM-DD HH24:MI:SS') AS noti_read_dt
        , n.noti_send_status
        , n.noti_retry_count
        , n.noti_last_error
        , TO_CHAR(n.noti_send_dt, 'YYYY-MM-DD HH24:MI:SS') AS noti_send_dt
    </sql>

    <sql id="historyFrom">
        FROM notification n
        LEFT JOIN noti_policy p
          ON p.np_event_cd = n.noti_event_cd
    </sql>

    <sql id="historyWhere">
        WHERE 1 = 1
        <if test="eventCd != null and eventCd != ''">
          AND n.noti_event_cd = #{eventCd}
        </if>
        <if test="receiverId != null and receiverId != ''">
          AND n.noti_receiver_id LIKE '%' || #{receiverId} || '%'
        </if>
        <if test="senderId != null and senderId != ''">
          AND n.noti_sender_id LIKE '%' || #{senderId} || '%'
        </if>
        <if test="refKey != null and refKey != ''">
          AND n.noti_ref_key LIKE '%' || #{refKey} || '%'
        </if>
        <if test="readYn != null and readYn != ''">
          AND n.noti_read_yn = #{readYn}
        </if>
        <if test="sendStatus != null and sendStatus != ''">
          AND n.noti_send_status = #{sendStatus}
        </if>
        <if test="fromDt != null and fromDt != ''">
          AND n.noti_send_dt &gt;= TO_DATE(#{fromDt}, 'YYYY-MM-DD')
        </if>
        <if test="toDt != null and toDt != ''">
          AND n.noti_send_dt &lt; TO_DATE(#{toDt}, 'YYYY-MM-DD') + 1
        </if>
    </sql>

    <select id="selectHistoryList"
            parameterType="kr.or.tacs.vo.systemadmin.notification.AdminNotificationHistorySearchVO"
            resultMap="historyMap">
        <bind name="offset" value="(currentPage - 1) * screenSize"/>
        SELECT
            <include refid="historyColumns"/>
        <include refid="historyFrom"/>
        <include refid="historyWhere"/>
        ORDER BY n.noti_no DESC
        OFFSET #{offset} ROWS FETCH NEXT #{screenSize} ROWS ONLY
    </select>

    <select id="countHistory"
            parameterType="kr.or.tacs.vo.systemadmin.notification.AdminNotificationHistorySearchVO"
            resultType="long">
        SELECT COUNT(*)
        <include refid="historyFrom"/>
        <include refid="historyWhere"/>
    </select>

    <select id="selectHistory"
            resultMap="historyMap">
        SELECT
            <include refid="historyColumns"/>
        <include refid="historyFrom"/>
        WHERE n.noti_no = #{notiNo}
    </select>

    <select id="selectEventOptionList"
            resultMap="eventOptionMap">
        SELECT
            np_event_cd
          , np_biz_nm
        FROM noti_policy
        WHERE np_use_yn = 'Y'
        ORDER BY np_event_cd
    </select>
</mapper>
