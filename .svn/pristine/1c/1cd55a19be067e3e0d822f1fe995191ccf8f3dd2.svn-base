package kr.or.tacs.systemadmin.hsknowledge.service;

import java.util.List;

import org.springframework.http.ResponseEntity;
import org.springframework.web.multipart.MultipartFile;

import kr.or.tacs.vo.common.CustomUser;
import kr.or.tacs.vo.common.PaginationInfoVO;
import kr.or.tacs.vo.systemadmin.hsknowledge.HsRefChunkVO;
import kr.or.tacs.vo.systemadmin.hsknowledge.HsRefDocSearchQueryVO;
import kr.or.tacs.vo.systemadmin.hsknowledge.HsRefDocSearchResultVO;
import kr.or.tacs.vo.systemadmin.hsknowledge.HsRefDocSearchVO;
import kr.or.tacs.vo.systemadmin.hsknowledge.HsRefDocVO;

public interface IHsRefDocService {

    PaginationInfoVO<HsRefDocVO> retriveHsRefDocList(HsRefDocSearchVO search);

    HsRefDocVO retriveHsRefDoc(Long hsRefDocNo);

    Long registHsRefDoc(String hsParentDocumentId,
                        String hsMilvusCollection,
                        String hsEmbeddingModel,
                        MultipartFile file,
                        CustomUser loginUser) throws Exception;

    void modifyHsRefDoc(Long hsRefDocNo,
                        String hsParentDocumentId,
                        String hsMilvusCollection,
                        String hsEmbeddingModel,
                        String hsEmbedStatusCd,
                        String hsUseYn);

    void modifyHsRefDocUseYn(Long hsRefDocNo, String useYn);

    List<HsRefChunkVO> retriveHsRefChunkList(Long hsRefDocNo);

    ResponseEntity<byte[]> retriveHsRefDocDownload(Long hsRefDocNo);

    void registHsRefDocEmbedding(Long hsRefDocNo);

    void registHsRefDocReembedding(Long hsRefDocNo);

    List<HsRefDocSearchResultVO> retriveHsRefDocSearch(HsRefDocSearchQueryVO request);
}
