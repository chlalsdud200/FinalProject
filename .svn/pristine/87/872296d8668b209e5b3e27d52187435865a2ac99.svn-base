<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.systemadmin.hsknowledge.mapper.IHsKeywordMapper">

    <resultMap id="hsKeywordMap" type="kr.or.tacs.vo.systemadmin.hsknowledge.HsKeywordVO">
        <id property="hsKeywordNo" column="HS_KEYWORD_NO"/>
        <result property="hsCode" column="HS_CODE"/>
        <result property="hsName" column="HS_NAME"/>
        <result property="keyword" column="KEYWORD"/>
        <result property="keywordWeight" column="KEYWORD_WEIGHT"/>
        <result property="useYn" column="USE_YN"/>
        <result property="registDt" column="REGIST_DT"/>
    </resultMap>

    <sql id="hsKeywordColumns">
          K.hs_keyword_no
        , K.hs_code
        , H.hs_name
        , K.keyword
        , K.keyword_weight
        , K.use_yn
        , TO_CHAR(K.regist_dt, 'YYYY-MM-DD HH24:MI') AS regist_dt
    </sql>

    <sql id="hsKeywordSearchWhere">
        WHERE 1 = 1
        <if test="hsCode != null and hsCode != ''">
          AND UPPER(K.hs_code) LIKE '%' || UPPER(#{hsCode}) || '%'
        </if>
        <if test="hsName != null and hsName != ''">
          AND UPPER(H.hs_name) LIKE '%' || UPPER(#{hsName}) || '%'
        </if>
        <if test="keyword != null and keyword != ''">
          AND UPPER(K.keyword) LIKE '%' || UPPER(#{keyword}) || '%'
        </if>
        <if test="useYn != null and useYn != '' and useYn != 'all'">
          AND NVL(K.use_yn, 'Y') = #{useYn}
        </if>
    </sql>

    <select id="selectHsKeywordList"
            parameterType="kr.or.tacs.vo.systemadmin.hsknowledge.HsKeywordSearchVO"
            resultMap="hsKeywordMap">
        SELECT
              hs_keyword_no
            , hs_code
            , hs_name
            , keyword
            , keyword_weight
            , use_yn
            , regist_dt
        FROM (
            SELECT
                  ROWNUM AS row_no
                , hs_keyword_no
                , hs_code
                , hs_name
                , keyword
                , keyword_weight
                , use_yn
                , regist_dt
            FROM (
                SELECT
                    <include refid="hsKeywordColumns"/>
                FROM hs_keyword K
                LEFT JOIN hs_code H
                  ON H.hs_code = K.hs_code
                <include refid="hsKeywordSearchWhere"/>
                ORDER BY K.hs_keyword_no DESC
            )
            WHERE ROWNUM &lt;= #{endRow}
        )
        WHERE row_no &gt;= #{startRow}
    </select>

    <select id="selectHsKeywordTotalRecord"
            parameterType="kr.or.tacs.vo.systemadmin.hsknowledge.HsKeywordSearchVO"
            resultType="int">
        SELECT
            COUNT(*)
        FROM hs_keyword K
        LEFT JOIN hs_code H
          ON H.hs_code = K.hs_code
        <include refid="hsKeywordSearchWhere"/>
    </select>

    <select id="selectHsKeyword" resultMap="hsKeywordMap">
        SELECT
            <include refid="hsKeywordColumns"/>
        FROM hs_keyword K
        LEFT JOIN hs_code H
          ON H.hs_code = K.hs_code
        WHERE K.hs_keyword_no = #{hsKeywordNo}
    </select>

    <select id="countActiveHsKeyword" resultType="int">
        SELECT COUNT(*)
        FROM hs_keyword
        WHERE hs_code = #{hsCode}
          AND UPPER(TRIM(keyword)) = UPPER(TRIM(#{keyword}))
          AND NVL(use_yn, 'Y') = 'Y'
        <if test="hsKeywordNo != null">
          AND hs_keyword_no &lt;&gt; #{hsKeywordNo}
        </if>
    </select>

    <select id="countHsCode" resultType="int">
        SELECT COUNT(*)
        FROM hs_code
        WHERE hs_code = #{hsCode}
    </select>

    <insert id="insertHsKeyword" parameterType="kr.or.tacs.vo.systemadmin.hsknowledge.HsKeywordVO">
        <selectKey keyProperty="hsKeywordNo" resultType="long" order="BEFORE">
            SELECT seq_hs_keyword_no.NEXTVAL FROM dual
        </selectKey>
        INSERT INTO hs_keyword (
              hs_keyword_no
            , hs_code
            , keyword
            , keyword_weight
            , use_yn
            , regist_dt
        ) VALUES (
              #{hsKeywordNo}
            , #{hsCode}
            , #{keyword}
            , #{keywordWeight}
            , #{useYn}
            , SYSDATE
        )
    </insert>

    <update id="updateHsKeyword" parameterType="kr.or.tacs.vo.systemadmin.hsknowledge.HsKeywordVO">
        UPDATE hs_keyword
        SET
              hs_code = #{hsCode}
            , keyword = #{keyword}
            , keyword_weight = #{keywordWeight}
            , use_yn = #{useYn}
        WHERE hs_keyword_no = #{hsKeywordNo}
    </update>

    <update id="updateHsKeywordUseYn">
        UPDATE hs_keyword
        SET use_yn = #{useYn}
        WHERE hs_keyword_no = #{hsKeywordNo}
    </update>
</mapper>
