<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fmt" uri="jakarta.tags.fmt" %>

<%
    request.setAttribute("activeMenu", "arrivalNotice");
    request.setAttribute("activeGroup", "");
    request.setAttribute("activeSub", "");
%>

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="ctx-path" content="${pageContext.request.contextPath}">
    <title>TACS 도착통지서</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
          rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block"
          rel="stylesheet">

    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/owner.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/owner/arrivalNotice.css">
</head>

<body>
<div class="app" id="app">

    <%@ include file="/WEB-INF/views/owner/sidebar.jsp" %>

    <div class="main-wrap">
        <%@ include file="/WEB-INF/views/common/header.jsp" %>

        <main class="content">
            <div class="page active" id="pg-arrival-notice">

                <div class="page-title-row">
                    <h2>도착통지서</h2>
                </div>

                <div class="alert-bar info arrival-alert">
                    <span class="material-symbols-outlined">notifications_active</span>
                    운송업체가 전달한 도착통지서(Arrival Notice)를 조회하세요.
                </div>

                <div class="arrival-kpi-grid">
                    <div class="arrival-kpi-card">
                        <div class="arrival-kpi-label">발송대기</div>
                        <div class="arrival-kpi-value pending">
                            <c:out value="${pendingCount}" default="0"/>
                        </div>
                        <div class="arrival-kpi-sub">아직 수신되지 않은 통지서</div>
                    </div>

                    <div class="arrival-kpi-card">
                        <div class="arrival-kpi-label">수신완료</div>
                        <div class="arrival-kpi-value sent">
                            <c:out value="${sentCount}" default="0"/>
                        </div>
                        <div class="arrival-kpi-sub">운송업체가 발송한 통지서</div>
                    </div>

                    <div class="arrival-kpi-card">
                        <div class="arrival-kpi-label">전체</div>
                        <div class="arrival-kpi-value total">
                            <c:out value="${totalCount}" default="0"/>
                        </div>
                        <div class="arrival-kpi-sub">전체 도착통지서</div>
                    </div>
                </div>

                <div class="two-col-wide arrival-layout">
                    <div class="card-section arrival-card">

                        <div class="card-header arrival-card-header">
                            <h3>도착통지서 목록</h3>

                            <form method="get"
                                  action="${pageContext.request.contextPath}/owner/arrival-notice/list.do"
                                  class="arrival-search-area">

                                <select name="sendSttsCd" class="arrival-filter-select">
                                    <option value="">전체</option>
                                    <option value="TRC_NTC_NSENT"
                                            <c:if test="${param.sendSttsCd eq 'TRC_NTC_NSENT'}">selected</c:if>>
                                        발송대기
                                    </option>
                                    <option value="TRC_NTC_SENT"
                                            <c:if test="${param.sendSttsCd eq 'TRC_NTC_SENT'}">selected</c:if>>
                                        수신완료
                                    </option>
                                </select>

                                <input type="text"
                                       name="keyword"
                                       value="${param.keyword}"
                                       placeholder="통지서번호 · 운송의뢰번호 · 현재위치"
                                       class="arrival-search-input"/>

                                <button type="submit" class="mini mini-view">검색</button>
                            </form>
                        </div>

                        <table class="data-table arrival-table">
                            <thead>
                            <tr>
                                <th>도착통지서번호</th>
                                <th>운송의뢰번호</th>
                                <th>현재위치</th>
                                <th>도착예정일</th>
                                <th>수신일</th>
                                <th>도착상태</th>
                                <th>발송상태</th>
                                <th></th>
                            </tr>
                            </thead>

                            <tbody>
                            <c:choose>
                                <c:when test="${empty arrivalList}">
                                    <tr>
                                        <td colspan="8" class="arrival-empty">
                                            조회된 도착통지서가 없습니다.
                                        </td>
                                    </tr>
                                </c:when>

                                <c:otherwise>
                                    <c:forEach var="arrival" items="${arrivalList}">
                                        <tr>
                                            <td class="td-id">
                                                <c:out value="${arrival.ianNo}"/>
                                            </td>

                                            <td>
                                                <c:out value="${arrival.ianTrcNo}" default="-"/>
                                            </td>

                                            <td>
                                                <c:out value="${arrival.ianCurrLoc}" default="-"/>
                                            </td>

                                            <td>
                                                <c:choose>
                                                    <c:when test="${not empty arrival.ianArrvDt}">
                                                        <fmt:formatDate value="${arrival.ianArrvDt}" pattern="yyyy-MM-dd"/>
                                                    </c:when>
                                                    <c:otherwise>-</c:otherwise>
                                                </c:choose>
                                            </td>

                                            <td>
                                                <c:choose>
                                                    <c:when test="${not empty arrival.ianSendDt}">
                                                        <fmt:formatDate value="${arrival.ianSendDt}" pattern="yyyy-MM-dd"/>
                                                    </c:when>
                                                    <c:otherwise>-</c:otherwise>
                                                </c:choose>
                                            </td>

                                            <td>
                                                <c:out value="${arrival.arrvStatusNm}" default="-"/>
                                            </td>

                                            <td>
                                                <c:choose>
                                                    <c:when test="${arrival.ianSendSttsCd eq 'TRC_NTC_NSENT'}">
                                                        <span class="arrival-status wait">
                                                            <c:out value="${arrival.sendSttsNm}" default="발송대기"/>
                                                        </span>
                                                    </c:when>

                                                    <c:when test="${arrival.ianSendSttsCd eq 'TRC_NTC_SENT'}">
                                                        <span class="arrival-status sent">
                                                            <c:out value="${arrival.sendSttsNm}" default="수신완료"/>
                                                        </span>
                                                    </c:when>

                                                    <c:otherwise>
                                                        <span class="arrival-status default">
                                                            <c:out value="${arrival.sendSttsNm}" default="-"/>
                                                        </span>
                                                    </c:otherwise>
                                                </c:choose>
                                            </td>

                                            <td>
                                                <a class="arrival-detail-btn"
                                                   href="${pageContext.request.contextPath}/owner/arrival-notice/detail.do/${arrival.ianNo}">
                                                    상세
                                                </a>
                                            </td>
                                        </tr>
                                    </c:forEach>
                                </c:otherwise>
                            </c:choose>
                            </tbody>
                        </table>

                        <div class="arrival-guide">
                            도착통지서 수신이 지연되면 운송업체에 문의하세요.
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%@ include file="/WEB-INF/views/common/ownerModals.jsp" %>
        <%@ include file="/WEB-INF/views/common/footer.jsp" %>
    </div>
</div>

<%@ include file="/WEB-INF/views/common/ownerScripts.jsp" %>

</body>
</html>