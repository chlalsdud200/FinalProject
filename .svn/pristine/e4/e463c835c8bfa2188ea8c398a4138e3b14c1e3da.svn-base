<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.tacs.common.mypage.mapper.MyPageMapper">

    <select id="selectLoginPasswordHash" resultType="string">
        SELECT
            login_pw
        FROM vw_actor_login
        WHERE login_id = #{loginId}
          AND role_cd = #{roleCd}
          AND use_yn = 'Y'
    </select>

    <select id="selectLoginContact" resultType="kr.or.tacs.vo.common.mypage.MyPageLoginContactVO">
        SELECT
            login_id AS login_id
          , login_nm AS login_nm
          , role_cd AS role_cd
          , actor_type_cd AS actor_type_cd
          , actor_table_nm AS actor_table_nm
          , telno AS telno
        FROM vw_actor_login
        WHERE login_id = #{loginId}
          AND role_cd = #{roleCd}
          AND use_yn = 'Y'
    </select>

    <select id="selectOwnerProfile" resultType="kr.or.tacs.vo.common.mypage.MyPageProfileVO">
        SELECT
            owr_id AS login_id
          , 'OWNER' AS role_cd
          , 'OWNER' AS actor_type_cd
          , 'OWNER' AS actor_table_nm
          , owr_ty_cd AS type_cd
          , CASE owr_ty_cd
                WHEN 'INDV' THEN '개인'
                WHEN 'OPERATOR' THEN '개인사업자'
                WHEN 'CORP' THEN '법인'
                ELSE owr_ty_cd
            END AS type_nm
          , owr_nm AS name
          , owr_nm AS org_name
          , owr_email AS email
          , owr_telno AS telno
          , owr_zip AS zip
          , owr_adres AS adres
          , owr_detail_adres AS detail_adres
          , CASE
                WHEN owr_ident_no IS NULL THEN NULL
                WHEN LENGTH(REGEXP_REPLACE(owr_ident_no, '[^0-9]', '')) &gt;= 7
                    THEN SUBSTR(REGEXP_REPLACE(owr_ident_no, '[^0-9]', ''), 1, 6)
                         || '-'
                         || SUBSTR(REGEXP_REPLACE(owr_ident_no, '[^0-9]', ''), 7, 1)
                         || '******'
                ELSE NULL
            END AS ident_no_masked
          , owr_bizrno AS bizrno
          , owr_corp_reg_no AS corp_reg_no
          , owr_cstm_idf_no AS cstm_idf_no
        FROM owner
        WHERE owr_id = #{loginId}
          AND owr_use_yn = 'Y'
    </select>

    <select id="selectBrokerProfile" resultType="kr.or.tacs.vo.common.mypage.MyPageProfileVO">
        SELECT
            broker_id AS login_id
          , 'BROKER' AS role_cd
          , 'BROKER' AS actor_type_cd
          , 'BROKER' AS actor_table_nm
          , broker_ty_cd AS type_cd
          , broker_ty_cd AS type_nm
          , broker_nm AS name
          , broker_office_nm AS org_name
          , broker_email AS email
          , broker_telno AS telno
          , broker_zip AS zip
          , broker_adres AS adres
          , broker_detail_adres AS detail_adres
          , broker_bizrno AS bizrno
          , broker_reg_no AS broker_reg_no
          , broker_spclty_cd AS broker_spclty_cd
        FROM broker
        WHERE broker_id = #{loginId}
          AND broker_use_yn = 'Y'
    </select>

    <select id="selectOfficerProfile" resultType="kr.or.tacs.vo.common.mypage.MyPageProfileVO">
        SELECT
            officer_id AS login_id
          , 'OFFICER' AS role_cd
          , 'OFFICER' AS actor_type_cd
          , 'OFFICER' AS actor_table_nm
          , officer_ty_cd AS type_cd
          , officer_ty_cd AS type_nm
          , officer_nm AS name
          , officer_name AS org_name
          , officer_email AS email
          , officer_telno AS telno
          , officer_zip AS zip
          , officer_adres AS adres
          , officer_detail_adres AS detail_adres
          , officer_inst_cd AS officer_inst_cd
          , officer_dept_cd AS officer_dept_cd
          , officer_clsf_cd AS officer_clsf_cd
          , officer_field_cd AS officer_field_cd
        FROM officer
        WHERE officer_id = #{loginId}
          AND officer_use_yn = 'Y'
    </select>

    <select id="selectTransportProfile" resultType="kr.or.tacs.vo.common.mypage.MyPageProfileVO">
        SELECT
            tm_id AS login_id
          , 'TRANSPORT_MANAGER' AS role_cd
          , 'TRANSPORT_MANAGER' AS actor_type_cd
          , 'TRANSPORT_MANAGER' AS actor_table_nm
          , tm_mn_cd AS type_cd
          , tm_mn_cd AS type_nm
          , tm_name AS name
          , tm_cp_nm AS org_name
          , tm_cp_telno AS telno
          , tm_no AS tm_no
          , tm_mn_cd AS tm_mn_cd
        FROM transport_manager
        WHERE tm_id = #{loginId}
          AND tm_use_yn = 'Y'
    </select>

    <select id="selectWarehouseProfile" resultType="kr.or.tacs.vo.common.mypage.MyPageProfileVO">
        SELECT
            wm_id AS login_id
          , 'WAREHOUSE_MANAGER' AS role_cd
          , 'WAREHOUSE_MANAGER' AS actor_type_cd
          , 'WAREHOUSE_MANAGER' AS actor_table_nm
          , wm_nm AS name
          , wm_nm AS org_name
          , wm_email AS email
          , wm_telno AS telno
          , wm_zip AS zip
          , wm_adres AS adres
          , wm_detail_adres AS detail_adres
        FROM warehouse_manager
        WHERE wm_id = #{loginId}
          AND wm_use_yn = 'Y'
    </select>

    <select id="selectSystemAdminProfile" resultType="kr.or.tacs.vo.common.mypage.MyPageProfileVO">
        SELECT
            sa_id AS login_id
          , 'SYSTEM_ADMIN' AS role_cd
          , 'SYSTEM_ADMIN' AS actor_type_cd
          , 'SYSTEM_ADMIN' AS actor_table_nm
          , sa_nm AS name
          , 'TACS' AS org_name
          , sa_email AS email
          , sa_telno AS telno
        FROM system_admin
        WHERE sa_id = #{loginId}
          AND sa_use_yn = 'Y'
    </select>

    <update id="updateOwnerProfile">
        UPDATE owner
        SET
            owr_nm = #{name}
          , owr_cstm_idf_no = #{cstmIdfNo}
          , owr_email = #{email}
          , owr_telno = #{telno}
          , owr_zip = #{zip}
          , owr_adres = #{adres}
          , owr_detail_adres = #{detailAdres}
          , owr_bizrno = #{bizrno}
          , owr_corp_reg_no = #{corpRegNo}
          , owr_updt_dt = SYSDATE
        WHERE owr_id = #{loginId}
          AND owr_use_yn = 'Y'
    </update>

    <update id="updateBrokerProfile">
        UPDATE broker
        SET
            broker_nm = #{name}
          , broker_office_nm = #{orgName}
          , broker_bizrno = #{bizrno}
          , broker_spclty_cd = #{brokerSpcltyCd}
          , broker_email = #{email}
          , broker_telno = #{telno}
          , broker_zip = #{zip}
          , broker_adres = #{adres}
          , broker_detail_adres = #{detailAdres}
          , broker_updt_dt = SYSDATE
        WHERE broker_id = #{loginId}
          AND broker_use_yn = 'Y'
    </update>

    <update id="updateOfficerProfile">
        UPDATE officer
        SET
            officer_email = #{email}
          , officer_telno = #{telno}
          , officer_zip = #{zip}
          , officer_adres = #{adres}
          , officer_detail_adres = #{detailAdres}
          , officer_updt_dt = SYSDATE
        WHERE officer_id = #{loginId}
          AND officer_use_yn = 'Y'
    </update>

    <update id="updateTransportProfile">
        UPDATE transport_manager
        SET
            tm_name = #{name}
          , tm_cp_telno = #{telno}
        WHERE tm_id = #{loginId}
          AND tm_use_yn = 'Y'
    </update>

    <update id="updateWarehouseProfile">
        UPDATE warehouse_manager
        SET
            wm_nm = #{name}
          , wm_email = #{email}
          , wm_telno = #{telno}
          , wm_zip = #{zip}
          , wm_adres = #{adres}
          , wm_detail_adres = #{detailAdres}
          , wm_updt_dt = SYSDATE
        WHERE wm_id = #{loginId}
          AND wm_use_yn = 'Y'
    </update>

    <update id="updateSystemAdminProfile">
        UPDATE system_admin
        SET
            sa_nm = #{name}
          , sa_email = #{email}
          , sa_telno = #{telno}
          , sa_updt_dt = SYSDATE
        WHERE sa_id = #{loginId}
          AND sa_use_yn = 'Y'
    </update>


    <insert id="insertMyPageSmsAuth" parameterType="kr.or.tacs.vo.common.SmsAuthVO">
        <selectKey keyProperty="saNo" resultType="long" order="BEFORE">
            SELECT
                NVL(MAX(sa_no), 0) + 1
            FROM sms_auth
        </selectKey>
        INSERT INTO sms_auth (
            sa_no
          , sa_auth_prpos_cd
          , sa_target_id
          , sa_phone_no
          , sa_auth_cd
          , sa_verify_yn
          , sa_fail_cnt
          , sa_expr_dt
          , sa_regist_dt
        ) VALUES (
            #{saNo}
          , #{saAuthPrposCd}
          , #{saTargetId}
          , #{saPhoneNo}
          , #{saAuthCd}
          , 'N'
          , 0
          , SYSDATE + (3 / 24 / 60)
          , SYSDATE
        )
    </insert>

    <select id="selectLatestMyPageSmsAuth" resultType="kr.or.tacs.vo.common.SmsAuthVO">
        SELECT
            sa_no AS sa_no
          , sa_auth_prpos_cd AS sa_auth_prpos_cd
          , sa_target_id AS sa_target_id
          , sa_phone_no AS sa_phone_no
          , sa_auth_cd AS sa_auth_cd
          , sa_verify_yn AS sa_verify_yn
          , sa_verify_dt AS sa_verify_dt
          , sa_fail_cnt AS sa_fail_cnt
          , sa_expr_dt AS sa_expr_dt
          , sa_regist_dt AS sa_regist_dt
        FROM sms_auth
        WHERE sa_auth_prpos_cd = #{purposeCd}
          AND sa_target_id = #{targetId}
          AND sa_phone_no = #{phoneNo}
          AND sa_verify_yn = 'N'
          AND sa_expr_dt > SYSDATE
        ORDER BY sa_no DESC
        FETCH FIRST 1 ROW ONLY
    </select>

    <update id="updateMyPageSmsAuthSuccess">
        UPDATE sms_auth
        SET
            sa_verify_yn = 'Y'
          , sa_verify_dt = SYSDATE
        WHERE sa_no = #{saNo}
    </update>

    <update id="updateMyPageSmsAuthFailCnt">
        UPDATE sms_auth
        SET
            sa_fail_cnt = sa_fail_cnt + 1
        WHERE sa_no = #{saNo}
    </update>

    <update id="updateOwnerPassword">
        UPDATE owner
        SET
            owr_password = #{encodedPassword}
          , owr_updt_dt = SYSDATE
        WHERE owr_id = #{loginId}
          AND owr_use_yn = 'Y'
    </update>

    <update id="updateBrokerPassword">
        UPDATE broker
        SET
            broker_password = #{encodedPassword}
          , broker_updt_dt = SYSDATE
        WHERE broker_id = #{loginId}
          AND broker_use_yn = 'Y'
    </update>

    <update id="updateOfficerPassword">
        UPDATE officer
        SET
            officer_password = #{encodedPassword}
          , officer_updt_dt = SYSDATE
        WHERE officer_id = #{loginId}
          AND officer_use_yn = 'Y'
    </update>

    <update id="updateTransportPassword">
        UPDATE transport_manager
        SET
            tm_password = #{encodedPassword}
        WHERE tm_id = #{loginId}
          AND tm_use_yn = 'Y'
    </update>

    <update id="updateWarehousePassword">
        UPDATE warehouse_manager
        SET
            wm_password = #{encodedPassword}
          , wm_updt_dt = SYSDATE
        WHERE wm_id = #{loginId}
          AND wm_use_yn = 'Y'
    </update>

    <update id="updateSystemAdminPassword">
        UPDATE system_admin
        SET
            sa_password = #{encodedPassword}
          , sa_updt_dt = SYSDATE
        WHERE sa_id = #{loginId}
          AND sa_use_yn = 'Y'
    </update>

</mapper>
