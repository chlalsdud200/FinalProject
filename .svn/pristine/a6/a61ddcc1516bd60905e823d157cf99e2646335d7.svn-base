/* import-ui.js
 * 수입 운송의뢰 상세 인라인 탭 UI.
 */
(function () {
    'use strict';

    if (window.__TACS_IMPORT_UI_LOADED) return;
    window.__TACS_IMPORT_UI_LOADED = true;

    const GROUP = 'import';
    const REQUEST_LIST_ID = 'TACS-FW-015';
    const REQUEST_DETAIL_ID = 'TACS-FW-016';
    const IMPORT_ROUTE_STORAGE_KEY = 'tacs.import.currentRoute.v2';
    const IMPORT_ROUTE_BOOT_RESTORE_MS = 12000;
    let importBootRestoreRoute;
    let importBootRestoreDeadline = 0;

    const WORK_ITEMS = [
        {id: 'request', title: '수입운송의뢰상세', itemId: REQUEST_DETAIL_ID},
        {id: 'arrival', title: '도착통지서 발송', itemId: 'TACS-FW-020'},
        {id: 'inbound', title: '입고관리', itemId: 'TACS-FW-025'},
        {id: 'do', title: 'D/O', itemId: 'TACS-FW-030'},
        {id: 'release', title: '반출관리', itemId: 'TACS-FW-033'},
        {id: 'inland', title: '내륙배차', itemId: 'TACS-FW-035'}
    ];

    const doFileState = new Map();

    /*
     * 화면 분리 가드
     * - 왼쪽 사이드바 화면(각 리스트)과 운송의뢰 상세 내부 탭은 같은 detail-body를 공유한다.
     * - 이전 상세 탭의 비동기 setTimeout/search/render가 사이드바 리스트 화면 위에 다시 그려지는 문제를 막기 위해
     *   수입 상세 탭 전용 render token을 둔다.
     */
    let importInlineRenderToken = 0;

    function isImportInlineDetailActive(root) {
        const body = document.getElementById('detail-body');
        if (!root || !root.isConnected || !body || !body.contains(root)) return false;
        return body.dataset.currentGroup === GROUP && body.dataset.currentItem === REQUEST_DETAIL_ID;
    }

    function bumpImportInlineRenderToken() {
        importInlineRenderToken += 1;
        return importInlineRenderToken;
    }

    function cleanupImportInlineDetail() {
        bumpImportInlineRenderToken();
        const body = document.getElementById('detail-body');
        if (!body) return;

        // 운송의뢰 상세 탭 화면에서만 비운다. 이미 다른 리스트가 렌더된 상태라면 건드리지 않는다.
        if (body.querySelector('.import-inline-tabs-0513') || body.querySelector('.import-ui-main-request-detail')) {
            body.innerHTML = '';
        }
        doFileState.clear();
    }

    function esc(value) {
        return String(value == null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function pick(row, keys, fallback) {
        row = row || {};
        for (let i = 0; i < keys.length; i += 1) {
            const value = row[keys[i]];
            if (value !== undefined && value !== null && String(value).trim() !== '' && String(value).trim() !== '-') return value;
        }
        return fallback == null ? '' : fallback;
    }

    function normalizeText(value) {
        return String(value == null ? '' : value).trim();
    }

    function contextPath() {
        if (typeof window.getContextPath === 'function') return window.getContextPath();
        if (typeof window.getTransportContextPath === 'function') return window.getTransportContextPath();
        return (window.contextPath || document.body?.dataset?.contextPath || '').replace(/\/$/, '');
    }

    function withContext(url) {
        if (/^https?:\/\//i.test(url)) return url;
        return contextPath() + url;
    }

    function csrfHeaders(isMultipart) {
        const csrf = window.TRANSPORT_CSRF || {};
        const token = csrf.token
            || document.querySelector('meta[name="_csrf"]')?.getAttribute('content')
            || document.querySelector('meta[name="csrf-token"]')?.getAttribute('content')
            || document.querySelector('input[name="_csrf"]')?.value
            || '';
        const header = csrf.header
            || document.querySelector('meta[name="_csrf_header"]')?.getAttribute('content')
            || 'X-CSRF-TOKEN';
        const headers = {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        };
        if (!isMultipart) headers['Content-Type'] = 'application/x-www-form-urlencoded; charset=UTF-8';
        if (token) headers[header] = token;
        return headers;
    }

    function postJson(url, data) {
        const isMultipart = data instanceof FormData;
        let body = data;
        if (!isMultipart) {
            body = new URLSearchParams();
            Object.keys(data || {}).forEach(function (key) {
                if (data[key] !== undefined && data[key] !== null) body.append(key, data[key]);
            });
        }
        return fetch(withContext(url), {
            method: 'POST',
            headers: csrfHeaders(isMultipart),
            credentials: 'same-origin',
            body: isMultipart ? body : body.toString()
        }).then(function (response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.json();
        }).then(function (json) {
            if (!json || json.success !== true) {
                throw new Error((json && json.message) ? json.message : '처리에 실패했습니다.');
            }
            return json;
        });
    }

    function getJson(url) {
        const controller = (typeof AbortController !== 'undefined') ? new AbortController() : null;
        const timeoutId = controller ? window.setTimeout(function () {
            try { controller.abort(); } catch (e) { /* noop */ }
        }, 8000) : null;

        return fetch(withContext(url), {
            method: 'GET',
            headers: {'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
            credentials: 'same-origin',
            cache: 'no-store',
            signal: controller ? controller.signal : undefined
        }).then(function (response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.json();
        }).finally(function () {
            if (timeoutId) window.clearTimeout(timeoutId);
        });
    }

    function jsonRows(json) {
        if (Array.isArray(json)) return json;
        if (!json || typeof json !== 'object') return [];

        const candidates = [
            json.data, json.list, json.rows, json.result, json.items,
            json.resultList, json.dataList, json.body, json.payload
        ];

        for (let i = 0; i < candidates.length; i += 1) {
            const candidate = candidates[i];
            if (Array.isArray(candidate)) return candidate;
        }

        /*
         * Spring 응답이 {success:true, data:{list:[...]}} 또는
         * {result:{rows:[...]}} 처럼 한 번 더 감싸져 오는 경우까지 처리한다.
         * 기존에는 이 형태를 빈 배열로 보고 D/O 상세 탭이 계속 0원/빈 설명으로 렌더링됐다.
         */
        for (let i = 0; i < candidates.length; i += 1) {
            const candidate = candidates[i];
            if (candidate && typeof candidate === 'object') {
                const nested = [
                    candidate.data, candidate.list, candidate.rows, candidate.result, candidate.items,
                    candidate.resultList, candidate.dataList, candidate.body, candidate.payload
                ];
                for (let j = 0; j < nested.length; j += 1) {
                    if (Array.isArray(nested[j])) return nested[j];
                }
            }
        }

        return [];
    }

    function getJsonFlexible(urls) {
        const list = Array.isArray(urls) ? urls : [urls];
        let index = 0;
        function tryNext(lastError) {
            if (index >= list.length) return Promise.reject(lastError || new Error('조회 가능한 API를 찾지 못했습니다.'));
            const url = list[index++];
            return getJson(url + (url.indexOf('?') >= 0 ? '&' : '?') + '_=' + Date.now())
                .catch(function (error) {
                    if (/HTTP 404/.test(error.message || '')) return tryNext(error);
                    throw error;
                });
        }
        return tryNext();
    }

    const TAB_DATA_CONFIG = {
        arrival: {
            loadedFlag: '__TACS_IMPORT_ARRIVAL_LOADED',
            loadingFlag: '__TACS_IMPORT_ARRIVAL_LOADING',
            storeKeys: ['TRANSPORT_IMPORT_ARRIVAL_TRACKING', 'TRANSPORT_IMPORT_ARRIVAL_LIST', '__TACS_IMPORT_ARRIVAL_TRACKING_ROWS'],
            urls: [
                '/transport/import/arrival-notice/list.do',
                '/transport/import/arrival-tracking/list.do',
                '/transport/import/manifest/arrival-list.do',
                '/transport/import/manifest/list.do'
            ]
        },
        inbound: {
            loadedFlag: '__TACS_IMPORT_INBOUND_LOADED',
            loadingFlag: '__TACS_IMPORT_INBOUND_LOADING',
            storeKeys: ['__TACS_IMPORT_INBOUND_REGISTERED_ROWS', 'TRANSPORT_IMPORT_WAREHOUSE_IN_LIST', 'TRANSPORT_IMPORT_INBOUND_LIST'],
            urls: [
                '/transport/import/unloading-in/list.do'
            ]
        },
        do: {
            loadedFlag: '__TACS_IMPORT_DO_LOADED',
            loadingFlag: '__TACS_IMPORT_DO_LOADING',
            storeKeys: ['TRANSPORT_IMPORT_DO_LIST', '__TACS_IMPORT_DO_ROWS'],
            urls: [
                '/transport/import/do/list.do'
            ]
        },
        release: {
            loadedFlag: '__TACS_IMPORT_RELEASE_LOADED',
            loadingFlag: '__TACS_IMPORT_RELEASE_LOADING',
            storeKeys: ['__TACS_IMPORT_RELEASE_ROWS', 'TRANSPORT_IMPORT_RELEASE_LIST', 'IMPORT_RELEASE_LIST'],
            urls: [
                '/transport/import/release-request/list.do'
            ]
        },
        inland: {
            loadedFlag: '__TACS_IMPORT_INLAND_LOADED',
            loadingFlag: '__TACS_IMPORT_INLAND_LOADING',
            storeKeys: ['TRANSPORT_IMPORT_INLAND_DISPATCH_LIST', '__TACS_IMPORT_INLAND_ROWS'],
            urls: [
                '/transport/import/inland-dispatch/list.do'
            ]
        }
    };

    function storeRows(keys, rows) {
        if (!Array.isArray(rows)) rows = [];
        (keys || []).forEach(function (key) {
            window[key] = rows;
        });
        return rows;
    }

    function tabRows(type) {
        if (type === 'arrival') {
            return rowsOf(window.TRANSPORT_IMPORT_ARRIVAL_TRACKING, window.TRANSPORT_IMPORT_ARRIVAL_LIST, window.__TACS_IMPORT_ARRIVAL_TRACKING_ROWS);
        }
        if (type === 'inbound') {
            return rowsOf(window.__TACS_IMPORT_INBOUND_DETAIL_ROWS, window.__TACS_IMPORT_INBOUND_REGISTERED_ROWS, window.TRANSPORT_IMPORT_WAREHOUSE_IN_LIST, window.TRANSPORT_IMPORT_INBOUND_LIST);
        }
        if (type === 'do') {
            return rowsOf(window.TRANSPORT_IMPORT_DO_LIST, window.__TACS_IMPORT_DO_ROWS);
        }
        if (type === 'release') {
            return rowsOf(window.__TACS_IMPORT_RELEASE_ROWS, window.TRANSPORT_IMPORT_RELEASE_LIST, window.IMPORT_RELEASE_LIST);
        }
        if (type === 'inland') {
            const rows = window.importInlandDispatchState && window.importInlandDispatchState.rows;
            return rowsOf(rows, window.TRANSPORT_IMPORT_INLAND_DISPATCH_LIST, window.__TACS_IMPORT_INLAND_ROWS);
        }
        return [];
    }

    function tabHasDataForRequest(type, trcNo) {
        return !!findRowByRequestNo(tabRows(type), trcNo);
    }

    function loadWarehouseOptions() {
        if (window.__TACS_WAREHOUSE_LOADED || window.__TACS_WAREHOUSE_LOADING) {
            return Promise.resolve(window.TRANSPORT_WAREHOUSE_LIST || []);
        }
        window.__TACS_WAREHOUSE_LOADING = true;
        return getJsonFlexible([
            '/transport/import/warehouse-manager/list.do',
            '/transport/import/warehouse/manager/list.do',
            '/transport/import/inbound/warehouse-manager/list.do',
            '/transport/import/warehouseManager/list.do'
        ]).then(function (json) {
            const rows = jsonRows(json);
            window.TRANSPORT_WAREHOUSE_LIST = rows;
            window.WAREHOUSE_LIST = rows;
            window.TRANSPORT_WAREHOUSE_ZONE_LIST = rows;
            window.WAREHOUSE_ZONE_LIST = rows;
            window.__TACS_WAREHOUSE_LOADED = true;
            window.__TACS_WAREHOUSE_ZONE_LOADED = true;
            return rows;
        }).catch(function (error) {
            console.warn('[창고 목록 조회 실패]', error);
            return [];
        }).finally(function () {
            window.__TACS_WAREHOUSE_LOADING = false;
        });
    }

    function loadWarehouseZoneOptions() {
        return Promise.resolve(window.TRANSPORT_WAREHOUSE_ZONE_LIST || []);
    }

    function loadWarehouseManagerOptions() {
        if (window.__TACS_WAREHOUSE_MANAGER_LOADED || window.__TACS_WAREHOUSE_MANAGER_LOADING) {
            return Promise.resolve(window.TRANSPORT_WAREHOUSE_MANAGER_LIST || []);
        }
        window.__TACS_WAREHOUSE_MANAGER_LOADING = true;
        return getJsonFlexible([
            '/transport/import/warehouse-manager/list.do',
            '/transport/import/warehouse/manager/list.do',
            '/transport/import/inbound/warehouse-manager/list.do',
            '/transport/import/warehouseManager/list.do'
        ]).then(function (json) {
            const rows = jsonRows(json);
            window.TRANSPORT_WAREHOUSE_MANAGER_LIST = rows;
            window.WAREHOUSE_MANAGER_LIST = rows;
            window.__TACS_WAREHOUSE_MANAGER_LOADED = true;
            return rows;
        }).catch(function (error) {
            console.warn('[창고담당자 목록 조회 실패]', error);
            return [];
        }).finally(function () {
            window.__TACS_WAREHOUSE_MANAGER_LOADING = false;
        });
    }

    function loadCarOptions() {
        if (window.__TACS_IMPORT_CAR_LOADED) {
            return Promise.resolve(window.TRANSPORT_CAR_LIST || window.CAR_LIST || window.__TACS_CAR_LIST || []);
        }
        if (window.__TACS_IMPORT_CAR_LOADING) {
            return Promise.resolve(window.TRANSPORT_CAR_LIST || window.CAR_LIST || window.__TACS_CAR_LIST || []);
        }
        window.__TACS_IMPORT_CAR_LOADING = true;
        return getJsonFlexible([
            '/transport/import/inland-dispatch/cars.do'
        ]).then(function (json) {
            const rows = jsonRows(json);
            window.TRANSPORT_CAR_LIST = rows;
            window.CAR_LIST = rows;
            window.__TACS_CAR_LIST = rows;
            window.__TACS_IMPORT_CAR_LOADED = true;
            return rows;
        }).catch(function (error) {
            console.warn('[차량 목록 조회 실패]', error);
            return [];
        }).finally(function () {
            window.__TACS_IMPORT_CAR_LOADING = false;
        });
    }

    function loadDoListForLookup() {
        if (window.__TACS_IMPORT_DO_LOADING) return Promise.resolve(window.TRANSPORT_IMPORT_DO_LIST || []);
        if (window.__TACS_IMPORT_DO_LOADED && Array.isArray(window.TRANSPORT_IMPORT_DO_LIST) && window.TRANSPORT_IMPORT_DO_LIST.length > 0) {
            return Promise.resolve(window.TRANSPORT_IMPORT_DO_LIST);
        }
        window.__TACS_IMPORT_DO_LOADING = true;
        return getJsonFlexible(['/transport/import/do/list.do']).then(function (json) {
            const rows = mergeDoSettlementPatches(jsonRows(json));
            storeRows(['TRANSPORT_IMPORT_DO_LIST', '__TACS_IMPORT_DO_ROWS'], rows);
            window.__TACS_IMPORT_DO_LOADED = true;
            return rows;
        }).catch(function (error) {
            console.warn('[D/O 목록 조회 실패]', error);
            window.__TACS_IMPORT_DO_LOADED = false;
            return [];
        }).finally(function () {
            window.__TACS_IMPORT_DO_LOADING = false;
        });
    }

    function ensureTabData(type, trcNo, root) {
        const cfg = TAB_DATA_CONFIG[type];
        if (!cfg) return Promise.resolve(false);
        if (window[cfg.loadingFlag]) return Promise.resolve(true);
        /*
         * 현재 의뢰번호 데이터가 없으면 이미 한 번 목록을 불러왔더라도 다시 조회한다.
         * 이전 의뢰(예: 00027) 상태 캐시만 남아 있으면 신규 의뢰(예: 00028)의
         * 입고관리 탭이 빈 값으로 렌더링되는 고질 오류가 발생한다.
         */
        if (window[cfg.loadedFlag] && tabHasDataForRequest(type, trcNo)) return Promise.resolve(false);
        if (window[cfg.loadedFlag] && !trcNo && tabRows(type).length > 0) return Promise.resolve(false);

        window[cfg.loadingFlag] = true;
        return getJsonFlexible(cfg.urls).then(function (json) {
            const rows = jsonRows(json);
            storeRows(cfg.storeKeys, rows);
            if (type === 'inland') {
                window.importInlandDispatchState = window.importInlandDispatchState || {};
                window.importInlandDispatchState.rows = rows;
            }
            window[cfg.loadedFlag] = true;
            const extraLoads = [];
            if (type === 'release' || type === 'inland') {
                extraLoads.push(loadDoListForLookup());
            }
            if (type === 'inbound' || type === 'release') {
                extraLoads.push(loadWarehouseOptions());
                extraLoads.push(loadWarehouseZoneOptions());
                extraLoads.push(loadWarehouseManagerOptions());
            }
            if (type === 'inland') extraLoads.push(loadCarOptions());
            return Promise.all(extraLoads).then(function () { return true; });
        }).catch(function (error) {
            console.warn('[수입 상세 탭 데이터 조회 실패]', type, error);
            window[cfg.loadedFlag] = true;
            return false;
        }).finally(function () {
            window[cfg.loadingFlag] = false;
            if (isImportInlineDetailActive(root) && root.dataset.activeWorkId === type) {
                renderInlineTab(root, type);
            }
        });
    }

    function rowsOf() {
        const rows = [];
        Array.prototype.slice.call(arguments).forEach(function (list) {
            if (Array.isArray(list)) rows.push.apply(rows, list);
        });
        return rows;
    }

    function requestRows() {
        return rowsOf(
            window.TRANSPORT_IMPORT_REQUESTS,
            window.__TACS_IMPORT_REQUEST_LIST,
            window.__IMPORT_REQUEST_LIST,
            window.importTransportRequests,
            window.importRequestRows,
            window.importRequests
        );
    }

    function currentRequest() {
        try {
            return window.selectedImportRequest || selectedImportRequest || {};
        } catch (e) {
            return window.selectedImportRequest || {};
        }
    }

    function currentRequestNo(row) {
        return pick(row, ['trcNo', 'TRC_NO', 'requestNo', 'tcsTrcNo', 'reqNo'], '');
    }

    function setCurrentRequest(req) {
        window.selectedImportRequest = req || {};
        try {
            selectedImportRequest = req || {};
        } catch (e) {
            // 전역 let 접근이 불가능한 환경이면 window 값만 사용한다.
        }
    }


    const __requestGoodsHydrateRunning = Object.create(null);
    const __requestRouteHydrateRunning = Object.create(null);

    /*
     * 새로고침 직후에는 sessionStorage/history에 저장된 최소 스냅샷으로 먼저 상세가 복원된다.
     * 이 상태를 그대로 두면 저장된 최신 DB 값이 아니라 예전 스냅샷/빈 객체가 화면에 남아서
     * 사용자가 입력했던 값이 사라진 것처럼 보인다. 복원 직후 의뢰 목록 API를 한 번 더 조회해
     * 현재 의뢰번호의 최신 row로 상세 탭을 다시 그린다.
     */
    function refreshRestoredRequestRoute(no, workId) {
        no = normalizeText(no);
        if (!no || __requestRouteHydrateRunning[no]) return;
        __requestRouteHydrateRunning[no] = true;

        getJsonFlexible([
            '/transport/import/request/list.do',
            '/transport/import/list.do'
        ]).then(function (json) {
            const rows = firstRows(json);
            if (rows.length) {
                storeRows(['TRANSPORT_IMPORT_REQUESTS', '__TACS_IMPORT_REQUEST_LIST', '__IMPORT_REQUEST_LIST'], rows);
            }
            const latest = rows.find(function (row) { return rowMatchesRequestNo(row, no); }) || null;
            if (!latest) return null;

            const current = currentRequest();
            const next = Object.assign({}, current || {}, latest);
            setCurrentRequest(next);
            return next;
        }).then(function (latest) {
            if (!latest) return;
            const root = document.querySelector('.import-inline-tabs-0513');
            if (!root || !isImportInlineDetailActive(root)) return;
            if (!rowMatchesRequestNo({trcNo: root.dataset.requestNo || root.dataset.trcNo || ''}, no)) return;
            const active = validImportWorkId(workId || root.dataset.activeWorkId || 'request');
            renderRequestDetail(latest, active);
        }).catch(function (error) {
            console.warn('[수입운송의뢰 상세 복원 데이터 재조회 실패]', error);
        }).finally(function () {
            __requestRouteHydrateRunning[no] = false;
        });
    }

    function firstArrayRow(json) {
        if (Array.isArray(json)) return json[0] || null;
        if (!json || typeof json !== 'object') return null;
        const keys = ['data', 'rows', 'list', 'result', 'resultList', 'items'];
        for (let i = 0; i < keys.length; i += 1) {
            const v = json[keys[i]];
            if (Array.isArray(v)) return v[0] || null;
        }
        return null;
    }

    function firstRows(json) {
        if (Array.isArray(json)) return json;
        if (!json || typeof json !== 'object') return [];
        const keys = ['data', 'rows', 'list', 'result', 'resultList', 'items'];
        for (let i = 0; i < keys.length; i += 1) {
            if (Array.isArray(json[keys[i]])) return json[keys[i]];
        }
        return [];
    }

    function patchGoodsFields(target, source) {
        if (!target || !source) return false;
        let changed = false;
        const pairs = [
            ['ggNo', ['ggNo', 'GG_NO', 'tfgNo', 'trcTfgNo', 'TRC_TFG_NO']],
            ['goodsName', ['goodsName', 'itemNm', 'GOODS_NAME', 'goodsNm']],
            ['itemNm', ['itemNm', 'goodsName', 'GOODS_NAME', 'goodsNm']],
            ['goodsHsCode', ['goodsHsCode', 'hsCode', 'GOODS_HS_CODE']],
            ['hsCode', ['hsCode', 'goodsHsCode', 'GOODS_HS_CODE']],
            ['qty', ['qty', 'goodsQty', 'CG_QTY', 'quantity', 'totalQty']],
            ['weight', ['weight', 'goodsWeight', 'CG_WEIGHT', 'totalWeight']],
            ['price', ['price', 'CG_PRICE']],
            ['goodsTotalPrice', ['goodsTotalPrice', 'CG_TOTAL_PRICE', 'totalPrice']]
        ];
        pairs.forEach(function (pair) {
            const key = pair[0];
            const val = pick(source, pair[1], '');
            if (!isUsableValue(target[key]) && isUsableValue(val)) {
                target[key] = val;
                changed = true;
            }
        });
        if (Array.isArray(source.goodsList) && source.goodsList.length && (!Array.isArray(target.goodsList) || !target.goodsList.length)) {
            target.goodsList = source.goodsList;
            changed = true;
        }
        return changed;
    }

    function hydrateRequestGoodsIfNeeded(req) {
        const no = currentRequestNo(req);
        if (!no || __requestGoodsHydrateRunning[no]) return;
        const hasGoods = isUsableValue(pick(req, ['goodsName', 'itemNm'], ''))
            && (isUsableValue(pick(req, ['qty'], '')) || isUsableValue(pick(req, ['weight'], '')));
        if (hasGoods) return;
        __requestGoodsHydrateRunning[no] = true;
        getJsonFlexible([
            '/transport/import/request/list.do',
            '/transport/import/list.do'
        ]).then(function (json) {
            const rows = firstRows(json);
            const reqRow = rows.find(function (row) { return rowMatchesRequestNo(row, no); }) || null;
            const current = currentRequest();
            let changed = false;
            if (reqRow) {
                changed = patchGoodsFields(current, reqRow) || changed;
                storeRows(['TRANSPORT_IMPORT_REQUESTS', '__TACS_IMPORT_REQUEST_LIST', '__IMPORT_REQUEST_LIST'], rows);
            }
            const ggNo = pick(current, ['ggNo', 'GG_NO', 'tfgNo', 'trcTfgNo', 'TRC_TFG_NO'], '');
            if (!ggNo) return changed;
            return getJsonFlexible([
                '/transport/import/manifest/goods.do?ggNo=' + encodeURIComponent(ggNo),
                '/transport/import/inbound/goods.do?ggNo=' + encodeURIComponent(ggNo),
                '/transport/import/unloading-in/goods.do?ggNo=' + encodeURIComponent(ggNo)
            ]).then(function (goodsJson) {
                const goodsRows = firstRows(goodsJson).filter(Boolean);
                if (goodsRows.length) {
                    current.goodsList = goodsRows;
                    changed = patchGoodsFields(current, goodsRows[0]) || changed;
                }
                return changed;
            }).catch(function () { return changed; });
        }).then(function (changed) {
            __requestGoodsHydrateRunning[no] = false;
            const current = currentRequest();
            setCurrentRequest(current);
            if (changed) renderRequestDetail(current);
        }).catch(function (error) {
            __requestGoodsHydrateRunning[no] = false;
            console.warn('[수입운송의뢰 품목 재조회 실패]', error);
        });
    }

    function validImportWorkId(workId) {
        const value = String(workId || '').trim();
        return WORK_ITEMS.some(function (work) { return work.id === value; }) ? value : 'request';
    }

    function readStoredImportRoute() {
        try {
            const raw = window.sessionStorage && window.sessionStorage.getItem(IMPORT_ROUTE_STORAGE_KEY);
            return raw ? JSON.parse(raw) : null;
        } catch (e) {
            return null;
        }
    }

    function importRouteRequestSnapshot(req) {
        if (!req || typeof req !== 'object') return null;
        const snap = {};
        Object.keys(req).forEach(function (key) {
            const value = req[key];
            if (value == null) {
                snap[key] = value;
                return;
            }
            const valueType = typeof value;
            if (valueType === 'string' || valueType === 'number' || valueType === 'boolean') {
                snap[key] = value;
            }
        });
        const no = currentRequestNo(req) || req.trcNo || req.requestNo || req.irNo || req.TRC_NO;
        if (no) {
            snap.trcNo = snap.trcNo || no;
            snap.requestNo = snap.requestNo || no;
            snap.irNo = snap.irNo || no;
            snap.TRC_NO = snap.TRC_NO || no;
        }
        return snap;
    }

    function requestFromImportRoute(route) {
        if (!route || typeof route !== 'object') return null;
        const req = route.request || route.req || route.row || null;
        if (!req || typeof req !== 'object') return null;
        const no = route.trcNo || currentRequestNo(req);
        const snap = Object.assign({}, req);
        if (no) {
            snap.trcNo = snap.trcNo || no;
            snap.requestNo = snap.requestNo || no;
            snap.irNo = snap.irNo || no;
            snap.TRC_NO = snap.TRC_NO || no;
        }
        return snap;
    }

    function rememberImportRoute(route) {
        if (!route || !route.type) return;
        if (!allowMenuRouteOverwrite(route)) return;
        const nextRoute = Object.assign({}, route, { ts: Date.now() });
        try {
            if (window.sessionStorage) {
                window.sessionStorage.setItem(IMPORT_ROUTE_STORAGE_KEY, JSON.stringify(nextRoute));
            }
        } catch (e) {
            // 저장소 사용 불가 시에도 화면 렌더링은 그대로 진행한다.
        }
        try {
            if (window.history && window.history.replaceState) {
                const url = new URL(window.location.href);
                url.pathname = (typeof getContextPath === 'function' ? getContextPath() : '') + '/transport/import.do';
                url.searchParams.delete('page');
                url.searchParams.delete('trcNo');
                url.searchParams.delete('requestNo');
                url.searchParams.delete('reqNo');
                url.searchParams.delete('no');
                const state = Object.assign({}, window.history.state || {});
                state.group = GROUP;
                state.item = route.type === 'request-detail' ? REQUEST_DETAIL_ID : route.itemId;
                state.tacsImportRoute = nextRoute;
                window.history.replaceState(state, '', url.pathname + url.search + url.hash);
            }
        } catch (e) {
            // URL/히스토리 동기화 실패는 화면 렌더링에 영향 주지 않는다.
        }
    }

    function routeFromHistoryState() {
        try {
            const state = window.history && window.history.state ? window.history.state : null;
            if (!state) return null;
            if (state.tacsImportRoute) return state.tacsImportRoute;
            if (state.group === GROUP && state.item === REQUEST_DETAIL_ID && state.trcNo) {
                return { type: 'request-detail', trcNo: state.trcNo, workId: state.workId || 'request' };
            }
            if (state.group === GROUP && state.item) {
                return { type: 'menu', itemId: state.item };
            }
        } catch (e) {}
        return null;
    }

    function isRefreshNavigation() {
        try {
            const nav = window.performance && window.performance.getEntriesByType
                ? window.performance.getEntriesByType('navigation')[0]
                : null;
            if (nav && nav.type) return nav.type === 'reload';
            if (window.performance && window.performance.navigation) return window.performance.navigation.type === 1;
        } catch (e) {
            return false;
        }
        return false;
    }

    function isImportDetailRoute(route) {
        return !!(route && route.type === 'request-detail' && route.trcNo);
    }

    function bootImportDetailRoute() {
        if (typeof importBootRestoreRoute !== 'undefined') return importBootRestoreRoute;
        const storedRoute = routeFromHistoryState() || readStoredImportRoute();
        importBootRestoreRoute = (isRefreshNavigation() && isImportDetailRoute(storedRoute)) ? storedRoute : null;
        if (importBootRestoreRoute) importBootRestoreDeadline = Date.now() + IMPORT_ROUTE_BOOT_RESTORE_MS;
        return importBootRestoreRoute;
    }

    function isBootDetailRestoreActive() {
        return !!(bootImportDetailRoute() && importBootRestoreDeadline && Date.now() <= importBootRestoreDeadline);
    }

    function clearImportBootRestore() {
        importBootRestoreDeadline = 0;
        importBootRestoreRoute = null;
    }

    function isRecentUserImportNav(groupKey, itemId) {
        const nav = window.__TACS_TRANSPORT_USER_NAV || null;
        return !!(nav
            && nav.group === groupKey
            && String(nav.item || '') === String(itemId || '')
            && Date.now() - Number(nav.ts || 0) < 1500);
    }

    function allowMenuRouteOverwrite(route) {
        if (!isBootDetailRestoreActive()) return true;
        return isImportDetailRoute(route);
    }

    function shouldSuppressBootMenuOpen(groupKey, itemId) {
        if (groupKey !== GROUP || itemId === REQUEST_DETAIL_ID || !isBootDetailRestoreActive()) return false;
        const evt = window.event;
        if (isRecentUserImportNav(groupKey, itemId) || (evt && evt.isTrusted)) {
            clearImportBootRestore();
            return false;
        }
        return true;
    }

    function activeImportRouteForRestore() {
        const bootRoute = bootImportDetailRoute();
        if (bootRoute) return bootRoute;
        return routeFromHistoryState() || (isRefreshNavigation() ? readStoredImportRoute() : null);
    }

    function importRouteRequestNo() {
        const route = activeImportRouteForRestore();
        if (route && route.type === 'request-detail' && route.trcNo) return route.trcNo;
        try {
            const params = new URLSearchParams(window.location.search || '');
            return params.get('trcNo') || params.get('requestNo') || params.get('reqNo') || params.get('no') || '';
        } catch (e) {
            return '';
        }
    }

    function importRouteWorkId(req) {
        const no = currentRequestNo(req);
        const route = activeImportRouteForRestore();
        if (route && route.type === 'request-detail' && String(route.trcNo || '') === String(no || '')) {
            return validImportWorkId(route.workId);
        }
        return 'request';
    }

    function updateImportDetailUrl(req, workId) {
        const no = currentRequestNo(req);
        if (!no) return;
        rememberImportRoute({
            type: 'request-detail',
            trcNo: no,
            workId: validImportWorkId(workId || importRouteWorkId(req)),
            request: importRouteRequestSnapshot(req)
        });
    }

    function routedRequest(route) {
        const activeRoute = route || activeImportRouteForRestore();
        const routeNo = (activeRoute && activeRoute.trcNo) ? String(activeRoute.trcNo) : importRouteRequestNo();
        if (routeNo) {
            const row = findRequestRow(routeNo);
            if (row && currentRequestNo(row) && rowMatchesRequestNo(row, routeNo)) return row;
            const routeReq = requestFromImportRoute(activeRoute);
            if (routeReq && currentRequestNo(routeReq)) return routeReq;
            const current = currentRequest();
            if (current && currentRequestNo(current) && rowMatchesRequestNo(current, routeNo)) return current;
            return { trcNo: routeNo, requestNo: routeNo, irNo: routeNo, TRC_NO: routeNo, __routeStub: true };
        }
        const current = currentRequest();
        if (current && currentRequestNo(current)) return current;
        return requestRows()[0] || {};
    }

    /*
     * 같은 건인데 화면/DB에서 번호 형태가 섞여 들어오는 경우가 있다.
     * 예)
     * - TRAN_RCP.TRC_NO : TRC-IMP-20260522-002
     * - IMP_RQST.IR_NO : IMP-20260522-002
     * 그래서 단순 문자열 비교만 하면 새로고침 후 도착통지 행을 못 찾아서
     * TRC_NTC_SENT가 있어도 화면이 다시 미발송처럼 보인다.
     */
    function requestNoKeys(value) {
        const raw = String(value || '').trim().toUpperCase();
        if (!raw) return [];

        const noTrc = raw.replace(/^TRC-/, '');
        const compact = noTrc.replace(/-/g, '');
        const compactNoPrefix = compact.replace(/^TRC/, '');

        /*
         * 도착통지/적하목록 쪽에서 같은 의뢰번호가 아래처럼 섞여 들어온다.
         * - TRC-IMP-20260522-002
         * - IMP-20260522-002
         * - IMP-20260522-00022
         * - IMP-2026-0522-002
         * 단순 문자열 비교만 하면 TRC_NTC_SENT가 있어도 행을 못 찾아서 화면이 미발송처럼 보인다.
         * 그래서 IMP + 8자리 날짜 + 마지막 순번 숫자 기준의 canonical key를 하나 더 만든다.
         */
        const nums = noTrc.match(/^(IMP|EXP)-?(\d{4})-?(\d{2})-?(\d{2})-?(\d+)$/);
        const canonical = nums ? (nums[1] + nums[2] + nums[3] + nums[4] + String(parseInt(nums[5], 10))) : '';

        return [raw, noTrc, compact, compactNoPrefix, canonical].filter(function (item, index, arr) {
            return item && arr.indexOf(item) === index;
        });
    }

    function requestNoValues(row) {
        if (!row) return [];
        return [
            row.trcNo, row.requestNo, row.reqNo, row.tcsTrcNo, row.TCS_TRC_NO, row.TRC_NO, row.TR_NO,
            row.ianTrcNo, row.IAN_TRC_NO, row.arrivalTrcNo, row.arrivalNoticeTrcNo,
            row.arrivalNoticeReqNo, row.arrivalNoticeNo, row.noticeNo, row.ntcNo,
            row.diTrcNo, row.DI_TRC_NO,
            row.wirNo, row.WIR_NO, row.wirTrcNo, row.WIR_TRC_NO, row.WIR_REF_NO,
            row.ianIrNo, row.IAN_IR_NO, row.irNo, row.IR_NO,
            row.crrTreId, row.CRR_TRE_ID, row.crrRefNo, row.CRR_REF_NO,
            row.dispatchTrcNo, row.DISPATCH_TRC_NO, row.treId, row.TRE_ID,
            row.relatedTrcNo
        ];
    }

    function rowMatchesRequestNo(row, no) {
        const targetKeys = requestNoKeys(no);
        if (!targetKeys.length || !row) return false;
        const rowKeys = [];
        requestNoValues(row).forEach(function (value) {
            rowKeys.push.apply(rowKeys, requestNoKeys(value));
        });
        return targetKeys.some(function (key) { return rowKeys.includes(key); });
    }

    function findRowByRequestNo(list, no) {
        if (!Array.isArray(list)) return null;
        return list.find(function (row) { return rowMatchesRequestNo(row, no); }) || null;
    }

    function doSettlementPatchRows() {
        window.__TACS_IMPORT_DO_SETTLEMENT_PATCH_ROWS = window.__TACS_IMPORT_DO_SETTLEMENT_PATCH_ROWS || [];
        return window.__TACS_IMPORT_DO_SETTLEMENT_PATCH_ROWS;
    }

    function rememberDoSettlementPatch(trcNo, patchRow) {
        if (!trcNo || !patchRow) return;
        const patches = doSettlementPatchRows().filter(function (row) {
            return !rowMatchesRequestNo(row, trcNo);
        });
        patches.unshift(Object.assign({}, patchRow, {trcNo: trcNo, requestNo: trcNo}));
        window.__TACS_IMPORT_DO_SETTLEMENT_PATCH_ROWS = patches.slice(0, 20);
    }

    function mergeDoSettlementPatchValue(baseRow, patchRow) {
        const merged = Object.assign({}, baseRow || {});
        const amountKeys = [
            'freightAmt', 'tcsFrgtAmt', 'tcsFrghtAmt', 'tcsFreightAmt', 'freight', 'TCS_FRGT_AMT', 'TCS_FRGHT_AMT', 'TCS_FREIGHT_AMT',
            'warehouseAmt', 'tcsWhAmt', 'warehouse', 'whAmt', 'TCS_WH_AMT',
            'totalBillAmt', 'tcsTotBillAmt', 'totalAmt', 'billAmt', 'TCS_TOT_BILL_AMT'
        ];
        Object.keys(patchRow || {}).forEach(function (key) {
            const patchValue = patchRow[key];
            if (!isUsableValue(patchValue)) return;
            if (amountKeys.includes(key)) {
                if (numberOnly(merged[key]) <= 0 && numberOnly(patchValue) > 0) merged[key] = patchValue;
                return;
            }
            if (/settlement|tcsStl|TCS_STL/.test(key) && normalizeSettlementStatus(merged[key]) === '미정산') {
                merged[key] = patchValue;
                return;
            }
            if (!isUsableValue(merged[key])) merged[key] = patchValue;
        });
        return merged;
    }

    function mergeDoSettlementPatches(rows) {
        const patches = doSettlementPatchRows();
        if (!patches.length) return Array.isArray(rows) ? rows : [];
        const mergedRows = (Array.isArray(rows) ? rows : []).map(function (row) {
            const patch = patches.find(function (item) { return rowMatchesRequestNo(row, currentRequestNo(item)); });
            return patch ? mergeDoSettlementPatchValue(row, patch) : row;
        });
        patches.forEach(function (patch) {
            if (!findRowByRequestNo(mergedRows, currentRequestNo(patch))) mergedRows.unshift(patch);
        });
        return mergedRows;
    }

    function isUsableValue(value) {
        return value !== undefined && value !== null && String(value).trim() !== '' && String(value).trim() !== '-';
    }

    function mergeRowsForRequest(list, no) {
        const merged = {};
        (Array.isArray(list) ? list : []).forEach(function (row) {
            if (!rowMatchesRequestNo(row, no)) return;
            Object.keys(row).forEach(function (key) {
                if (!isUsableValue(merged[key]) && isUsableValue(row[key])) {
                    merged[key] = row[key];
                }
            });
        });
        return Object.keys(merged).length ? merged : null;
    }

    function workRow(type, no) {
        return mergeRowsForRequest(tabRows(type), no) || findRowByRequestNo(tabRows(type), no) || {};
    }

    function findRequestRow(no) {
        return findRowByRequestNo(requestRows(), no) || {};
    }

    function mergedRequestContext(no) {
        const merged = {};
        [
            findRequestRow(no),
            workRow('arrival', no),
            workRow('inbound', no),
            workRow('do', no),
            workRow('release', no),
            workRow('inland', no)
        ].forEach(function (row) {
            if (!row) return;
            Object.keys(row).forEach(function (key) {
                if (!isUsableValue(merged[key]) && isUsableValue(row[key])) {
                    merged[key] = row[key];
                }
            });
        });
        return merged;
    }

    function requestMblValue(no, req, fallbackRow) {
        const source = Object.assign({}, mergedRequestContext(no), fallbackRow || {}, req || {});
        return cleanFileName(pick(source, [
            'mblNo', 'masterBlNo', 'masterBl', 'blNo', 'icmMblNo', 'ICM_MBL_NO',
            'biMblNo', 'BI_MBL_NO', 'irBlAwbNo', 'IR_BL_AWB_NO', 'mblFile', 'hblFile'
        ], ''));
    }

    function selectedFromButton(button) {
        const no = button.dataset.trcNo || button.dataset.requestNo || button.dataset.no || '';
        const row = Object.assign({}, mergedRequestContext(no), findRequestRow(no));
        const req = {
            requestNo: no || currentRequestNo(row),
            receiptDate: button.dataset.receiptDate || pick(row, ['receiptDate', 'requestDt', 'trcRceptDt', 'registDt'], ''),
            receiptStatus: button.dataset.receiptStatus || pick(row, ['receiptStatus', 'statusNm', 'statusCd', 'trcStatusCd', 'TRC_STATUS_CD'], ''),
            displayStatus: button.dataset.displayStatus || pick(row, ['displayStatus', 'requestDisplayStatusNm', 'releaseStatusNm'], ''),
            statusCd: button.dataset.statusCd || pick(row, ['statusCd', 'trcStatusCd', 'TRC_STATUS_CD'], ''),
            statusNm: button.dataset.statusNm || pick(row, ['statusNm', 'trcStatusNm', 'TRC_STATUS_NM'], ''),
            rejectReason: button.dataset.rejectReason || pick(row, ['rejectReason', 'rejectCn'], ''),
            shipperName: button.dataset.shipperName || pick(row, ['shipperName', 'ownerNm', 'owrNm', 'trcOwrNm'], ''),
            shipperContact: button.dataset.shipperContact || pick(row, ['shipperContact', 'ownerPicNm', 'owrPicNm'], ''),
            shipperPhone: button.dataset.shipperPhone || pick(row, ['shipperPhone', 'ownerTelno', 'owrTelno'], ''),
            shipperEmail: button.dataset.shipperEmail || pick(row, ['shipperEmail', 'ownerEmail', 'owrEmail'], ''),
            consignorName: button.dataset.consignorName || button.dataset.buyerName || pick(row, ['consignorName', 'buyerNm', 'buyerName', 'traderNm', 'trcTrdrNm'], ''),
            consignorCountry: button.dataset.consignorCountry || button.dataset.buyerCountry || pick(row, ['consignorCountry', 'buyerCountryCd', 'buyerCountryNm', 'traderCountryCd', 'trcTrdrCountryCd'], ''),
            carrierName: button.dataset.carrierName || pick(row, ['carrierName', 'carrierNm'], ''),
            originPort: button.dataset.originPort || pick(row, ['originPort', 'deptPortNm', 'deptPortCd'], ''),
            destinationPort: button.dataset.destinationPort || pick(row, ['destinationPort', 'arvlPortNm', 'arvlPortCd'], ''),
            transportMode: button.dataset.transportMode || pick(row, ['transportMode', 'transportMeanNm', 'transportMeanCd'], ''),
            transportType: button.dataset.transportType || pick(row, ['transportType', 'transportTypeCd'], ''),
            transshipYn: button.dataset.transshipYn || pick(row, ['transshipYn'], ''),
            requestNote: button.dataset.requestNote || pick(row, ['requestNote', 'requestCn', 'trcRequestCn'], ''),
            blType: button.dataset.blType || pick(row, ['blType'], ''),
            bondedWarehouse: button.dataset.bondedWarehouse || pick(row, ['bondedWarehouse', 'warehouseNm', 'wzNm'], ''),
            importDeclNo: button.dataset.importDeclNo || pick(row, ['importDeclNo'], ''),
            containerSpec: button.dataset.containerSpec || pick(row, ['containerSpec'], ''),
            itemCategory: button.dataset.itemCategory || pick(row, ['itemCategory', 'frghtIemNm', 'TRC_ITEM_CTGRY_NM', 'CRR_FRGHT_IEM_NM'], ''),
            goodsName: button.dataset.goodsName || pick(row, ['goodsName', 'itemNm', 'GOODS_NAME'], ''),
            itemNm: button.dataset.goodsName || pick(row, ['itemNm', 'goodsName', 'GOODS_NAME'], ''),
            qty: button.dataset.qty || pick(row, ['qty', 'goodsQty', 'CG_QTY'], ''),
            weight: button.dataset.weight || pick(row, ['weight', 'goodsWeight', 'netWeight', 'CG_WEIGHT'], ''),
            mblNo: button.dataset.mblNo || button.dataset.blNo || requestMblValue(no, null, row),
            hblNo: button.dataset.hblNo || pick(row, ['hblNo', 'houseBlNo', 'icmHblNo', 'ICM_HBL_NO', 'biHblNo', 'BI_HBL_NO'], ''),
            blNo: button.dataset.blNo || button.dataset.mblNo || requestMblValue(no, null, row),
            mblFile: button.dataset.mblFile || requestMblValue(no, null, row),
            hblFile: button.dataset.hblFile || pick(row, ['hblFile', 'hblNo'], ''),
            eta: button.dataset.eta || pick(row, ['eta', 'arrivalScheduledDate', 'arrvDt'], ''),
            cargoMgmtNo: button.dataset.cargoMgmtNo || pick(row, ['cargoMgmtNo', 'cargoManagementNo', 'wirCargoMgmtNo', 'WIR_CARGO_MGMT_NO'], ''),
            invoiceNo: button.dataset.invoiceNo || pick(row, ['invoiceNo', 'wirInvoiceNo', 'invcNo'], ''),
            invoiceFile: button.dataset.invoiceFile || pick(row, ['invoiceFile', 'invoiceNo', 'invcNo'], ''),
            invoiceFileNo: button.dataset.invoiceFileNo || pick(row, ['invoiceFileNo', 'invFileNo'], ''),
            invoiceUrl: button.dataset.invoiceUrl || pick(row, ['invoiceUrl', 'invoiceFileUrl', 'invFileUrl'], ''),
            packingListFile: button.dataset.packingListFile || pick(row, ['packingListFile', 'pkgListFile'], ''),
            packingListFileNo: button.dataset.packingListFileNo || pick(row, ['packingListFileNo', 'pkgFileNo'], ''),
            packingListUrl: button.dataset.packingListUrl || pick(row, ['packingListUrl', 'packingListFileUrl', 'pkgFileUrl'], '')
        };
        setCurrentRequest(req);
        return req;
    }

    function normalizeReceiptStatus(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        if (['TRC_DONE', 'ACCEPTED', 'ACC'].includes(upper) || raw === '접수완료') return '접수완료';
        if (['REQ_FIX', 'FIX_REQ', 'SUPPLEMENT', 'SUPPLEMENT_REQUESTED'].includes(upper) || raw === '보완요청') return '접수완료';
        if (['IN_DONE'].includes(upper) || raw === '입고완료') return '접수완료';
        if (['REL_DONE', 'DONE', 'RELEASED'].includes(upper) || raw === '반출완료') return '접수완료';
        if (['TRC_REJECT', 'REJECTED', 'REJ'].includes(upper) || raw === '접수반려') return '접수반려';
        if (['TRC_WAIT', 'REQUESTED', 'REQ'].includes(upper) || raw === '접수대기') return '접수대기';
        return raw || '접수대기';
    }

    function normalizeDoStatus(value, hasDoNo) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        if (['TRC_DO_REQ', 'DELIVERED', 'DLVR'].includes(upper) || raw === '전달완료' || raw === 'D/O전달완료') return '전달완료';
        if (['TRC_DO_ISSUED', 'ISSUED'].includes(upper) || raw === '발급완료' || raw === 'D/O발급완료') return '발급완료';
        if (['TRC_DO_READY', 'READY', 'REQUESTED', 'WAIT', 'DRAFT', 'ISSUABLE'].includes(upper) || raw === '발급가능' || raw === '발급대기' || raw === 'D/O발급대기') return '발급대기';
        return raw || (hasDoNo ? '발급완료' : '발급대기');
    }

    function normalizeSettlementStatus(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        if (upper === 'TRC_STL_PAID' || upper === 'PAID' || upper === 'DONE' || upper === 'COMPLETE' || upper === 'COMPLETED' || raw === '정산완료') return '정산완료';
        if (upper === 'TRC_STL_REQ' || upper === 'REQUEST' || upper === 'REQUESTED' || raw === '정산요청' || raw === '정산요청완료') return '정산요청';
        if (upper === 'TRC_STL_UNPAID' || upper === 'UNPAID' || raw === '미정산') return '미정산';
        return raw || '미정산';
    }

    function cleanFileName(value) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '';
        return raw.replace(/\.pdf$/i, '');
    }

    function pdfName(value) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '';
        return /\.pdf$/i.test(raw) ? raw : raw + '.pdf';
    }

    function numberOnly(value) {
        return Number(String(value || '0').replace(/[^0-9.-]/g, '')) || 0;
    }

    function money(value) {
        return numberOnly(value).toLocaleString('ko-KR') + '원';
    }

    function today() {
        return new Date().toISOString().slice(0, 10);
    }

    function dateOnly(value) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '';
        const match = raw.replace(/[./]/g, '-').match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
        if (!match) return '';
        return match[1] + '-' + match[2].padStart(2, '0') + '-' + match[3].padStart(2, '0');
    }

    function dateTimeMinute(value) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '';
        const normalized = raw.replace('T', ' ');
        return normalized.length >= 16 ? normalized.substring(0, 16) : normalized;
    }

    function formatLocalDateTimeMinute(date) {
        const d = date instanceof Date ? date : new Date();
        const pad = function (num) { return String(num).padStart(2, '0'); };
        return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
    }

    function releaseRequestDisplayNo(row, actualNo) {
        const display = pick(row, [
            'releaseReqDisplayNo', 'releaseReqDispNo', 'releaseRequestDisplayNo', 'releaseRequestNoDisplay',
            'crrDisplayNo', 'CRR_DISPLAY_NO'
        ], '');
        if (display) return display;
        const rawNo = normalizeText(actualNo);
        if (!rawNo || rawNo === '-') return '';
        // DB 기준키(CRR_NO)는 숫자로 유지하고, 화면 표시용 번호만 입고관리번호(WIR_NO)와 분리한다.
        if (!/^\d+$/.test(rawNo)) return rawNo;
        const dateSource = pick(row, ['crrCrDt', 'crrReqDt', 'releaseReqDt', 'releasePlanDt', 'requestDt'], '');
        const trcSource = pick(row, ['trcNo', 'requestNo', 'CRR_TRE_ID', 'crrTreId'], '');
        let ymd = '';
        let m = normalizeText(dateSource).replace(/[./]/g, '-').match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
        if (m) {
            ymd = m[1] + m[2].padStart(2, '0') + m[3].padStart(2, '0');
        } else {
            m = normalizeText(dateSource).replace(/[.]/g, '/').match(/^(\d{2})[/-](\d{1,2})[/-](\d{1,2})/);
            if (m) ymd = (Number(m[1]) < 50 ? '20' : '19') + m[1] + m[2].padStart(2, '0') + m[3].padStart(2, '0');
        }
        if (!ymd) {
            const trcDate = normalizeText(trcSource).match(/(20\d{6})/);
            if (trcDate) ymd = trcDate[1];
        }
        if (!ymd) ymd = today().replace(/-/g, '');
        return 'REL-IMP-' + ymd + '-' + (rawNo.length < 4 ? rawNo.padStart(4, '0') : rawNo);
    }

    function downloadUrl(fileNo, directUrl) {
        if (fileNo) return withContext('/common/file/download.do?fileNo=' + encodeURIComponent(fileNo));
        return directUrl || '';
    }

    function fileDownloadField(label, name, fileNo, directUrl) {
        const displayName = pdfName(name) || (fileNo || directUrl ? label + '.pdf' : '첨부파일 없음');
        const url = downloadUrl(fileNo, directUrl);
        return ''
            + '<div class="import-ui-field">'
            + '<label>' + esc(label) + '</label>'
            + '<div class="import-ui-file-cell">'
            + '<input value="' + esc(displayName) + '" readonly>'
            + (url ? '<a href="' + esc(url) + '" class="import-ui-file-download">다운로드</a>' : '')
            + '</div>'
            + '</div>';
    }

    function field(label, value, opts) {
        opts = opts || {};
        const name = opts.name ? ' name="' + esc(opts.name) + '"' : '';
        const editableClass = opts.editable ? ' import-ui-editable' : '';
        const readonly = opts.editable ? '' : ' readonly';
        const type = opts.type || 'text';
        let displayValue = type === 'date' ? dateOnly(value) : normalizeText(value);

        // 품목/화물명은 Mapper 쪽에서 이미 "외 n건"이 붙어서 내려오는 경우가 있어서
        // 화면에서 다시 붙거나 "외 0건"이 중복 노출되지 않도록 최종 렌더링 직전에 정리한다.
        if (opts.goodsName === true || /품목|화물/.test(normalizeText(label))) {
            displayValue = sanitizeGoodsDisplayName(displayValue);
        }

        if (opts.textarea) {
            return ''
                + '<div class="import-ui-field">'
                + '<label>' + esc(label) + '</label>'
                + '<textarea' + name + readonly + ' class="' + editableClass.trim() + '">' + esc(displayValue) + '</textarea>'
                + '</div>';
        }
        return ''
            + '<div class="import-ui-field">'
            + '<label>' + esc(label) + '</label>'
            + '<input type="' + esc(type) + '"' + name + readonly + ' value="' + esc(displayValue) + '" class="' + editableClass.trim() + '">'
            + '</div>';
    }

    const importOptionModalConfig = {
        buyerCountry: {
            title: '거래자 국가',
            url: '/transport/import/request/country/list.do'
        },
        transportMode: {
            title: '운송수단',
            url: '/transport/import/request/common-option/list.do?type=TRANSPORT_MEAN'
        },
        transportType: {
            title: '운송형태',
            url: '/transport/import/request/common-option/list.do?type=TRANSPORT_TYPE'
        },
        originPort: {
            title: '출발항',
            url: '/transport/import/request/port/list.do'
        },
        destinationPort: {
            title: '도착항',
            url: '/transport/import/request/port/list.do'
        },
        blType: {
            title: 'B/L 구분',
            rows: [
                {value: 'Master B/L', label: 'Master B/L'},
                {value: 'House B/L', label: 'House B/L'}
            ]
        },
        itemCategory: {
            title: '화물품목구분',
            url: '/transport/import/request/common-option/list.do?type=ITEM_CATEGORY'
        }
    };

    let importOptionModalTarget = null;
    const importRequestDetailBusy = new Set();
    const savedImportRequestDetails = new Set();
    const IMPORT_REQUEST_DETAIL_DRAFT_PREFIX = 'tacs.import.requestDetailDraft.';

    function requestDetailDraftKey(trcNo) {
        return IMPORT_REQUEST_DETAIL_DRAFT_PREFIX + normalizeText(trcNo);
    }

    function readRequestDetailDraft(trcNo) {
        trcNo = normalizeText(trcNo);
        if (!trcNo || !window.sessionStorage) return null;
        try {
            const raw = sessionStorage.getItem(requestDetailDraftKey(trcNo));
            return raw ? JSON.parse(raw) : null;
        } catch (e) {
            return null;
        }
    }

    function removeRequestDetailDraft(trcNo) {
        trcNo = normalizeText(trcNo);
        if (!trcNo || !window.sessionStorage) return;
        try {
            sessionStorage.removeItem(requestDetailDraftKey(trcNo));
        } catch (e) {}
    }

    function mergeRequestDetailDraft(row) {
        row = Object.assign({}, row || {});
        const draft = readRequestDetailDraft(currentRequestNo(row));
        if (!draft || !draft.trcNo) return row;
        const display = draft._display || {};

        row.receiptDate = draft.receiptDate || row.receiptDate || '';
        row.shipperName = draft.shipperName || row.shipperName || '';
        row.shipperPhone = draft.shipperPhone || row.shipperPhone || '';
        row.shipperEmail = draft.shipperEmail || row.shipperEmail || '';
        row.consignorName = row.buyerName = row.buyerNm = draft.buyerNm || '';
        row.consignorCountry = row.buyerCountry = display.buyerCountry || draft.buyerCountryCd || '';
        row.buyerCountryCd = draft.buyerCountryCd || '';
        row.transportMode = row.transportMeanNm = display.transportMean || draft.transportMeanCd || '';
        row.transportMeanCd = draft.transportMeanCd || '';
        row.transportType = display.transportType || draft.transportTypeCd || '';
        row.transportTypeCd = draft.transportTypeCd || '';
        row.originPort = row.deptPortNm = display.deptPort || draft.deptPortCd || '';
        row.deptPortCd = draft.deptPortCd || '';
        row.destinationPort = row.arvlPortNm = display.arvlPort || draft.arvlPortCd || '';
        row.arvlPortCd = draft.arvlPortCd || '';
        row.blType = display.blType || row.blType || '';
        row.itemCategory = draft.itemCategory || '';
        row.goodsName = row.itemNm = draft.goodsName || '';
        row.qty = row.goodsQty = draft.qty || '';
        row.weight = row.goodsWeight = draft.weight || '';
        row.mblNo = row.blNo = draft.mblNo || '';
        row.requestNote = row.requestCn = draft.requestCn || '';
        return row;
    }

    function saveRequestDetailDraft(root) {
        if (!root || !root.classList || !root.classList.contains('import-ui-main-request-detail')) return;
        const payload = readRequestDetailPayload(root);
        if (!payload || !payload.trcNo || !window.sessionStorage) return;
        try {
            sessionStorage.setItem(requestDetailDraftKey(payload.trcNo), JSON.stringify(payload));
        } catch (e) {}
    }

    function optionSaveValue(type, value) {
        const text = normalizeText(value);
        if (!text) return '';
        const first = text.split('/')[0].trim();
        if (type === 'transportMode') {
            if (text === '해상') return 'SEA';
            if (text === '항공') return 'AIR';
        }
        if (type === 'transportType') {
            if (text === 'Less than Container Load') return 'LCL';
            if (text === 'Full Container Load') return 'FCL';
        }
        return first || text;
    }

    function optionField(label, value, opts) {
        opts = opts || {};
        if (!opts.editable) return field(label, value, opts);
        const type = opts.optionType || opts.name;
        const name = opts.name || type;
        const displayValue = normalizeText(value);
        const saveValue = optionSaveValue(type, displayValue);
        return ''
            + '<div class="import-ui-field import-ui-option-field">'
            + '<label>' + esc(label) + '</label>'
            + '<div class="import-ui-option-cell" data-option-type="' + esc(type) + '">'
            + '<input type="hidden" name="' + esc(name) + '" value="' + esc(saveValue) + '">'
            + '<input type="text" readonly value="' + esc(displayValue) + '" class="import-ui-editable import-ui-option-display" data-option-name="' + esc(name) + '">'
            + '<button type="button" class="import-ui-option-btn" data-option-type="' + esc(type) + '">검색</button>'
            + '</div>'
            + '</div>';
    }

    function ensureImportOptionModal() {
        let modal = document.getElementById('importOptionModal');
        if (modal) return modal;
        modal = document.createElement('div');
        modal.id = 'importOptionModal';
        modal.className = 'import-option-modal';
        modal.style.display = 'none';
        modal.innerHTML = ''
            + '<div class="import-option-backdrop"></div>'
            + '<div class="import-option-panel">'
            + '<div class="import-option-head">'
            + '<h4 id="importOptionModalTitle">선택</h4>'
            + '<button type="button" class="import-option-close">×</button>'
            + '</div>'
            + '<div class="import-option-search">'
            + '<input id="importOptionKeyword" type="text" placeholder="코드 또는 명칭 검색">'
            + '<button type="button" class="import-option-search-btn">조회</button>'
            + '</div>'
            + '<div class="import-option-list-wrap">'
            + '<table class="import-option-table">'
            + '<thead><tr><th>코드</th><th>명칭</th></tr></thead>'
            + '<tbody id="importOptionTbody"></tbody>'
            + '</table>'
            + '</div>'
            + '</div>';
        document.body.appendChild(modal);

        const keyword = modal.querySelector('#importOptionKeyword');
        if (keyword) {
            keyword.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    loadImportOptionRows();
                }
            });
        }
        return modal;
    }

    function normalizeImportOptionRows(rows) {
        return (Array.isArray(rows) ? rows : []).map(function (row) {
            row = row || {};
            const value = normalizeText(row.value || row.VALUE || row.code || row.CODE || row.countryCd || row.COUNTRYCD || row.COUNTRY_CD || row.portCd || row.PORTCD || row.PORT_CD || row.name || row.NAME || row.label || row.LABEL);
            const label = normalizeText(row.portNm || row.PORTNM || row.PORT_NM || row.label || row.LABEL || row.name || row.NAME || row.countryNmKr || row.COUNTRYNMKR || row.COUNTRY_NM_KR || row.countryNmEn || row.COUNTRYNMEN || row.COUNTRY_NM_EN || value);
            return {value: value, label: label};
        }).filter(function (row) {
            return row.value || row.label;
        });
    }

    function renderImportOptionRows(rows) {
        const tbody = document.getElementById('importOptionTbody');
        if (!tbody) return;
        const list = normalizeImportOptionRows(rows);
        if (!list.length) {
            tbody.innerHTML = '<tr><td colspan="2" class="import-option-empty">조회 결과가 없습니다.</td></tr>';
            return;
        }
        tbody.innerHTML = list.map(function (row) {
            return '<tr class="import-option-row" data-value="' + esc(row.value) + '" data-label="' + esc(row.label || row.value) + '">'
                + '<td>' + esc(row.value || '-') + '</td>'
                + '<td>' + esc(row.label || row.value || '-') + '</td>'
                + '</tr>';
        }).join('');
    }

    function loadImportOptionRows() {
        if (!importOptionModalTarget) return;
        const cfg = importOptionModalConfig[importOptionModalTarget.type] || {};
        const keywordEl = document.getElementById('importOptionKeyword');
        const keyword = normalizeText(keywordEl ? keywordEl.value : '');
        const tbody = document.getElementById('importOptionTbody');
        if (tbody) tbody.innerHTML = '<tr><td colspan="2" class="import-option-empty">조회 중입니다.</td></tr>';

        if (cfg.rows) {
            const lowered = keyword.toLowerCase();
            renderImportOptionRows(cfg.rows.filter(function (row) {
                const text = normalizeText((row.value || '') + ' ' + (row.label || '')).toLowerCase();
                return !lowered || text.indexOf(lowered) > -1;
            }));
            return;
        }

        const sep = cfg.url && cfg.url.indexOf('?') > -1 ? '&' : '?';
        const url = cfg.url + sep + 'keyword=' + encodeURIComponent(keyword);
        getJson(url)
            .then(renderImportOptionRows)
            .catch(function (error) {
                console.error('[수입운송 옵션 조회 실패]', error);
                if (tbody) tbody.innerHTML = '<tr><td colspan="2" class="import-option-empty">목록을 불러오지 못했습니다.</td></tr>';
            });
    }

    function openImportOptionModal(trigger) {
        const cell = trigger ? trigger.closest('.import-ui-option-cell') : null;
        if (!cell) return;
        const type = cell.dataset.optionType || '';
        const cfg = importOptionModalConfig[type];
        if (!cfg) return;

        const modal = ensureImportOptionModal();
        importOptionModalTarget = {
            type: type,
            hidden: cell.querySelector('input[type="hidden"]'),
            display: cell.querySelector('.import-ui-option-display')
        };

        const title = modal.querySelector('#importOptionModalTitle');
        const keyword = modal.querySelector('#importOptionKeyword');
        if (title) title.textContent = cfg.title || '선택';
        if (keyword) keyword.value = '';
        modal.style.display = 'flex';
        loadImportOptionRows();
        if (keyword) keyword.focus();
    }

    function closeImportOptionModal() {
        const modal = document.getElementById('importOptionModal');
        if (modal) modal.style.display = 'none';
        importOptionModalTarget = null;
    }

    function selectImportOption(row) {
        if (!row || !importOptionModalTarget) return;
        const value = row.dataset.value || '';
        const label = row.dataset.label || value;
        if (importOptionModalTarget.hidden) importOptionModalTarget.hidden.value = value;
        if (importOptionModalTarget.display) importOptionModalTarget.display.value = label;
        const detailRoot = (importOptionModalTarget.display || importOptionModalTarget.hidden || {}).closest
            ? (importOptionModalTarget.display || importOptionModalTarget.hidden).closest('.import-ui-main-request-detail')
            : null;
        [importOptionModalTarget.hidden, importOptionModalTarget.display].forEach(function (el) {
            if (!el) return;
            el.dispatchEvent(new Event('input', {bubbles: true}));
            el.dispatchEvent(new Event('change', {bubbles: true}));
        });
        saveRequestDetailDraft(detailRoot);
        closeImportOptionModal();
    }

    function selectField(label, name, options, selectedValue) {
        const selected = normalizeText(selectedValue);
        const rows = Array.isArray(options) ? options : [];
        return ''
            + '<div class="import-ui-field">'
            + '<label>' + esc(label) + '</label>'
            + '<select name="' + esc(name) + '" class="import-ui-editable">'
            + rows.map(function (opt) {
                const value = normalizeText(opt.value);
                const labelText = normalizeText(opt.label || opt.value);
                return '<option value="' + esc(value) + '"' + (value === selected ? ' selected' : '') + '>' + esc(labelText || value) + '</option>';
            }).join('')
            + '</select>'
            + '</div>';
    }

    function carFieldValue(row, keys, fallback) {
        return normalizeText(pick(row || {}, keys, fallback || ''));
    }

    function inlandCarRows() {
        const source = Array.isArray(window.TRANSPORT_CAR_LIST) ? window.TRANSPORT_CAR_LIST
            : (Array.isArray(window.CAR_LIST) ? window.CAR_LIST
                : (Array.isArray(window.__TACS_CAR_LIST) ? window.__TACS_CAR_LIST : []));
        const seen = {};
        const rows = [];
        source.forEach(function (car) {
            const no = inlandCarNo(car);
            if (!no || seen[no]) return;
            seen[no] = true;
            rows.push(car);
        });
        return rows;
    }

    function inlandCarNo(car) {
        return carFieldValue(car, ['carNo', 'vehicleNo', 'CAR_NO', 'D_CAR_NO'], '');
    }

    function inlandCarName(car) {
        return carFieldValue(car, ['carNm', 'vehicleNm', 'CAR_NM', 'D_CAR_NM'], '');
    }

    function inlandDriverName(car) {
        return carFieldValue(car, ['driverNm', 'carDriverNm', 'drvNm', 'CAR_DRIVER_NM', 'D_DRIVER_NM'], '');
    }

    function inlandDriverTel(car) {
        return carFieldValue(car, ['driverTelno', 'driverTel', 'driverPhone', 'carDriverTelno', 'CAR_DRIVER_TELNO', 'D_DRIVER_TELNO', 'CAR_DRIVER_TEL'], '');
    }

    function inlandCarSelectField(selectedCarNo) {
        const selected = normalizeText(selectedCarNo);
        const rows = inlandCarRows();
        const hasSelected = selected && rows.some(function (car) { return inlandCarNo(car) === selected; });
        let html = '<div class="import-ui-field"><label>차량번호</label><select name="carNo" class="import-ui-editable import-ui-inland-car-select">';
        html += '<option value="">차량 선택</option>';
        if (selected && !hasSelected) {
            html += '<option value="' + esc(selected) + '" selected>' + esc(selected) + '</option>';
        }
        html += rows.map(function (car) {
            const no = inlandCarNo(car);
            if (!no) return '';
            return '<option value="' + esc(no) + '"'
                + (no === selected ? ' selected' : '')
                + ' data-car-nm="' + esc(inlandCarName(car)) + '"'
                + ' data-driver-nm="' + esc(inlandDriverName(car)) + '"'
                + ' data-driver-telno="' + esc(inlandDriverTel(car)) + '">'
                + esc(no) + '</option>';
        }).join('');
        html += '</select></div>';
        return html;
    }

    function globalRows() {
        return rowsOf.apply(null, Array.prototype.slice.call(arguments).map(function (name) {
            return window[name];
        }));
    }


    function isMeaningfulOptionValue(value) {
        const raw = normalizeText(value);
        return raw && raw !== '-' && raw !== 'null' && raw !== 'undefined';
    }

    function isMeaningfulStatus(value) {
        const raw = normalizeText(value);
        if (!raw || raw === '-' || raw === 'null' || raw === 'undefined') return false;
        return true;
    }

    function warehouseSourceRows() {
        return globalRows(
            'TRANSPORT_WAREHOUSE_LIST',
            'WAREHOUSE_LIST',
            '__TACS_WAREHOUSE_LIST',
            'warehouseList',
            'windowWarehouseList',
            'transportWarehouseList',
            'TRANSPORT_IMPORT_WAREHOUSE_LIST',
            'IMPORT_WAREHOUSE_LIST',
            '__TACS_IMPORT_WAREHOUSE_LIST'
        );
    }

    function selectedWarehouseValue(selectedRow) {
        selectedRow = selectedRow || {};

        const selectedWzNo = pick(selectedRow, [
            'wzNo',
            'warehouseZoneNo',
            'bondedZoneNo',
            'wirWzNo',
            'WIR_WZ_NO',
            'WZ_NO'
        ], '');

        if (!selectedWzNo) return '';

        const matched = warehouseSourceRows().find(function (row) {
            return pick(row, [
                'wzNo',
                'warehouseZoneNo',
                'bondedZoneNo',
                'WZ_NO'
            ], '') === selectedWzNo;
        });

        if (!matched) return '';

        return pick(matched, [
            'whNo',
            'warehouseNo',
            'warehouseId',
            'whId',
            'WH_NO',
            'WRHS_NO'
        ], '');
    }

    function uniqueOptions(rows, valueKeys, labelKeys, fallbackOption) {
        const map = new Map();
        if (fallbackOption && fallbackOption.value) {
            map.set(String(fallbackOption.value), fallbackOption);
        }
        (Array.isArray(rows) ? rows : []).forEach(function (row) {
            const value = pick(row, valueKeys, '');
            if (!isMeaningfulOptionValue(value)) return;
            const label = pick(row, labelKeys, value);
            if (!map.has(String(value))) {
                map.set(String(value), {value: value, label: label || value});
            }
        });
        return Array.from(map.values());
    }

    function inboundWarehouseManagerOptions(row) {
        const selectedValue = pick(row, ['wmId', 'warehouseManagerId', 'bondedManagerId', 'wirWmId', 'WIR_WM_ID', 'WM_ID'], '');
        const selectedLabel = resolveWarehouseManagerName(row);
        return uniqueOptions(
            globalRows('TRANSPORT_WAREHOUSE_MANAGER_LIST', 'WAREHOUSE_MANAGER_LIST', 'TRANSPORT_WAREHOUSE_LIST', 'WAREHOUSE_LIST'),
            ['wmId', 'warehouseManagerId', 'bondedManagerId', 'WM_ID'],
            ['wmNm', 'warehouseManagerNm', 'bondedManagerNm', 'WM_NM'],
            isMeaningfulOptionValue(selectedValue) ? {value: selectedValue, label: selectedLabel || selectedValue} : null
        );
    }

    function inboundWarehouseZoneOptions(row) {
        const selectedValue = pick(row, ['wzNo', 'warehouseZoneNo', 'bondedZoneNo', 'wirWzNo', 'WIR_WZ_NO', 'WZ_NO'], '');
        const selectedLabel = resolveWarehouseZoneName(row);
        return uniqueOptions(
            globalRows('TRANSPORT_WAREHOUSE_ZONE_LIST', 'WAREHOUSE_ZONE_LIST', 'TRANSPORT_WAREHOUSE_LIST', 'WAREHOUSE_LIST'),
            ['wzNo', 'warehouseZoneNo', 'bondedZoneNo', 'WZ_NO'],
            ['wzNm', 'warehouseZoneNm', 'zoneNm', 'WZ_NM'],
            isMeaningfulOptionValue(selectedValue) ? {value: selectedValue, label: selectedLabel || selectedValue} : null
        );
    }

    function inboundWarehouseOptions(row) {
        const selectedValue = selectedWarehouseValue(row);
        const selectedLabel = resolveWarehouseName(row);
        return uniqueOptions(
            warehouseSourceRows(),
            ['whNo', 'warehouseNo', 'warehouseId', 'whId', 'WH_NO', 'WRHS_NO'],
            ['whNm', 'warehouseNm', 'warehouseName', 'WH_NM', 'WRHS_NM'],
            isMeaningfulOptionValue(selectedValue) ? {value: selectedValue, label: selectedLabel || selectedValue} : null
        );
    }

    function formValues(root) {
        const data = {};
        if (!root) return data;
        root.querySelectorAll('input[name], select[name], textarea[name]').forEach(function (el) {
            data[el.name] = el.value;
        });
        return data;
    }

    function noticeStatusText(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        if (upper === 'TRC_NTC_SENT' || raw === '발송완료' || raw === '통지완료') return '통지완료';
        if (upper === 'TRC_NTC_NSENT' || raw === '발송대기') return '발송대기';
        return raw || '발송대기';
    }


    function requestStatusOf(req) {
        req = req || currentRequest();
        const no = currentRequestNo(req);
        const receiptLike = function (value) {
            const normalized = normalizeReceiptStatus(value);
            return ['접수완료', '접수대기', '접수반려'].includes(normalized) ? normalized : '';
        };
        const rawReceiptStatus = function (row) {
            row = row || {};
            // 접수상태 판정에는 TRC_* 접수 컬럼을 먼저 보고,
            // statusNm/statusCd에 도착통지/입고/반출 진행상태가 섞이면 접수상태로 쓰지 않는다.
            let raw = pick(row, ['receiptStatus', 'trcStatusCd', 'TRC_STATUS_CD', 'trcStatusNm', 'TRC_STATUS_NM', 'trcStatus'], '');
            let normalized = receiptLike(raw);
            if (normalized) return normalized;
            raw = pick(row, ['statusCd', 'statusNm', 'status'], '');
            normalized = receiptLike(raw);
            return normalized || '';
        };
        const visibleReceiptStatus = function () {
            const body = document.getElementById('detail-body');
            const statusInput = body ? Array.from(body.querySelectorAll('.import-ui-field')).find(function (fieldEl) {
                const label = fieldEl.querySelector('label');
                return label && normalizeText(label.textContent) === '접수상태';
            }) : null;
            const raw = statusInput ? (statusInput.querySelector('input,textarea,select') || {}).value : '';
            return receiptLike(raw);
        };

        // 1) 상세 버튼에서 세팅된 현재 의뢰값 우선 확인
        let status = rawReceiptStatus(req);
        const visibleStatus = visibleReceiptStatus();
        if (visibleStatus && (!status || status === '접수대기')) return visibleStatus;
        if (status) return status;

        // 2) 현재 의뢰값에 상태가 빠진 경우, 원본 운송의뢰 목록에서 다시 찾기
        const row = findRequestRow(no);
        status = rawReceiptStatus(row);
        if (visibleStatus && (!status || status === '접수대기')) return visibleStatus;
        if (status) return status;

        // 3) 화면에 이미 렌더된 접수상태 input이 있으면 마지막으로 확인
        if (visibleStatus) return visibleStatus;

        return '';
    }

    function requestFlowStatusValues(req) {
        req = req || currentRequest();
        const no = currentRequestNo(req);
        const rows = [
            req,
            findRequestRow(no),
            mergedRequestContext(no)
        ].filter(Boolean);
        const keys = [
            'displayStatus', 'displayStatusNm', 'displayStatusCd',
            'requestDisplayStatusNm', 'REQUEST_DISPLAY_STATUS_NM',
            'requestDisplayStatusCd', 'REQUEST_DISPLAY_STATUS_CD',
            'flowStatus', 'flowStatusNm', 'flowStatusCd',
            'statusNm', 'statusCd', 'status',
            'receiptStatusNm', 'receiptStatusCd', 'receiptStatus',
            'trcStatusNm', 'TRC_STATUS_NM', 'trcStatusCd', 'TRC_STATUS_CD'
        ];
        const values = [];
        rows.forEach(function (row) {
            keys.forEach(function (key) {
                const raw = normalizeText(row && row[key]);
                if (raw && values.indexOf(raw) < 0) values.push(raw);
            });
        });
        return values;
    }

    function flowStatusMatches(req, codeList, nameList) {
        const codes = (codeList || []).map(function (v) { return normalizeText(v).toUpperCase(); });
        const names = (nameList || []).map(normalizeText);
        return requestFlowStatusValues(req).some(function (value) {
            const raw = normalizeText(value);
            const upper = raw.toUpperCase();
            return codes.indexOf(upper) >= 0 || names.indexOf(raw) >= 0;
        });
    }

    const INBOUND_SUPPLEMENT_CODES = ['REQ_FIX', 'IN_FIX', 'FIX_REQ', 'REQ_SENT', 'SUPPLEMENT', 'SUPPLEMENT_REQUESTED', 'SUPPLEMENT_SUBMITTED', 'REJECT', 'REJECTED'];
    const INBOUND_SUPPLEMENT_NAMES = ['보완요청', '입고 보완요청', '입고보완요청', '보완제출', '보완제출완료', '입고 보완제출완료', '입고보완제출완료', '입고반려', '반려'];

    function isInboundSupplementStatusValue(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        return INBOUND_SUPPLEMENT_CODES.indexOf(upper) >= 0 || INBOUND_SUPPLEMENT_NAMES.indexOf(raw) >= 0;
    }

    function requestShowsInboundSupplement(req) {
        return flowStatusMatches(req, INBOUND_SUPPLEMENT_CODES, INBOUND_SUPPLEMENT_NAMES);
    }

    function hasInboundSupplementState(trcNo) {
        const keys = [
            'inStatusNm', 'warehouseInStatusNm', 'warehouseReplyStatusNm', 'wirStatusNm', 'whInStatusNm', 'statusNm',
            'statusCd', 'inStatusCd', 'warehouseInStatusCd', 'warehouseReplyStatusCd', 'whReplyStatusCd',
            'wirStatusCd', 'wirWhReplyStatusCd', 'WIR_STATUS_CD', 'WIR_WH_REPLY_STATUS_CD'
        ];
        return flowRowsForRequest('inbound', trcNo).some(function (row) {
            return keys.some(function (key) { return isInboundSupplementStatusValue(row && row[key]); });
        });
    }

    function shouldOpenInboundForSupplement(req, trcNo) {
        return requestShowsInboundSupplement(req) || hasInboundSupplementState(trcNo || currentRequestNo(req));
    }

    const RELEASE_STAGE_CODES = [
        'REL_WAIT', 'REL_REQ', 'REL_SENT', 'REL_FIX', 'REL_REJECT', 'REL_DONE',
        'OUT_WAIT', 'OUT_REQ', 'OUT_SENT', 'OUT_FIX', 'OUT_REJECT', 'OUT_DONE',
        'RELEASE_WAIT', 'RELEASE_REQ', 'RELEASE_SENT', 'RELEASE_FIX', 'RELEASE_REJECT', 'RELEASE_DONE',
        'CRR_WAIT', 'CRR_REQ', 'CRR_FIX', 'CRR_REJECT', 'CRR_DONE'
    ];
    const RELEASE_STAGE_NAMES = [
        '반출대기', '반출요청', '반출요청완료',
        '반출보완요청', '반출 보완요청', '반출수정요청', '반출 수정요청',
        '반출반려', '반출 반려', '반출완료'
    ];
    const RELEASE_GENERIC_NAMES = ['보완요청', '수정요청', '반려'];

    function requestShowsReleaseStage(req) {
        return flowStatusMatches(req, RELEASE_STAGE_CODES, RELEASE_STAGE_NAMES);
    }

    function hasReleaseStageState(trcNo) {
        const no = trcNo || currentRequestNo(currentRequest());
        const releaseKeys = [
            'releaseStatusCd', 'releaseRequestStatusCd', 'crrStatusCd', 'crStatusCd', 'whOutStatusCd',
            'CRR_STATUS_CD', 'CR_STATUS_CD', 'WH_OUT_STATUS_CD',
            'releaseStatusNm', 'releaseRequestStatusNm', 'crrStatusNm', 'crStatusNm', 'whOutStatusNm',
            'CRR_STATUS_NM', 'CR_STATUS_NM', 'WH_OUT_STATUS_NM'
        ];
        const displayKeys = [
            'releaseDisplayStatusCd', 'releaseDisplayStatusNm',
            'workStatusCd', 'workStatusNm', 'progressStatusCd', 'progressStatusNm',
            'displayStatusCd', 'displayStatusNm', 'displayStatus', 'statusLabel', 'statusText'
        ];
        return flowRowsForRequest('release', no).some(function (row) {
            if (rowHasAnyStatus(row, releaseKeys, RELEASE_STAGE_CODES, RELEASE_STAGE_NAMES.concat(RELEASE_GENERIC_NAMES))) return true;
            return rowHasAnyStatus(row, displayKeys, RELEASE_STAGE_CODES, RELEASE_STAGE_NAMES);
        }) || requestShowsReleaseStage(currentRequest()) || requestShowsReleaseStage(findRequestRow(no));
    }

    function isAllTabsOpenStatus(req) {
        return flowStatusMatches(req, [
            'ARRIVAL_PENDING', 'TRC_ARR_PENDING', 'TRC_ARR_WAIT',
            'COMPLETE_WAIT', 'DONE_WAIT', 'TRC_COMPLETE_WAIT', 'TRC_DONE_WAIT',
            'FINAL_DONE', 'TRC_FINAL_DONE', 'TRC_FIN_DONE', 'TRC_END_DONE', 'TRC_ALL_DONE'
        ], ['도착대기', '완료대기', '최종완료']);
    }

    function isReceiptCompleteOnlyStatus(req, trcNo) {
        if (isAllTabsOpenStatus(req)) return false;
        const no = trcNo || currentRequestNo(req);
        // 보완요청/보완제출완료처럼 이미 입고 단계로 들어간 건은
        // TRAN_RCP가 아직 접수완료(TRC_DONE)로 남아 있어도 입고관리 탭을 닫으면 안 된다.
        if (hasInboundSupplementState(no)) return false;
        // 이미 반출 단계(반출대기/반출요청/반출보완요청/반출반려/반출완료)에 들어간 건은
        // TRAN_RCP가 아직 접수완료(TRC_DONE)로 남아 있어도 도착통지서까지만 잠그면 안 된다.
        if (hasReleaseStageState(no)) return false;
        // 도착통지서 발송완료(TRC_NTC_SENT) 이후에는 입고관리 탭을 열어야 한다.
        if (isArrivalNoticeSent(no)) return false;
        const status = requestStatusOf(req);
        if (status !== '접수완료') return false;
        if (requestShowsInboundSupplement(req)) return false;
        return !flowStatusMatches(req, ['REQ_FIX', 'IN_FIX', 'FIX_REQ', 'REQ_SENT', 'SUPPLEMENT_SUBMITTED', 'REJECT', 'REJECTED'], [
            '도착통지서 발송완료', '도착통지 발송완료', '발송완료',
            '입고대기', '입고요청', '입고요청완료', '입고완료', '입고 보완요청', '입고보완요청', '보완요청', '보완제출', '보완제출완료', '입고 보완제출완료', '입고보완제출완료', '입고반려', '반려',
            '정산요청', '정산완료',
            'D/O발급대기', 'D/O발급완료', 'D/O전달완료',
            '반출대기', '반출요청', '반출요청완료', '반출보완요청', '반출 보완요청', '반출수정요청', '반출 수정요청', '반출반려', '반출 반려', '반출완료',
            '배차대기', '배차완료'
        ]);
    }

    function isRequestAccepted(req) {
        const status = requestStatusOf(req);
        if (!status) return true;
        return status === '접수완료' || isAllTabsOpenStatus(req);
    }

    function arrivalRowForRequest(trcNo) {
        return findRowByRequestNo(tabRows('arrival'), trcNo) || {};
    }

    function isArrivalNoticeSent(trcNo) {
        const no = trcNo || currentRequestNo(currentRequest());
        const rows = [
            arrivalRowForRequest(no),
            currentRequest(),
            findRequestRow(no),
            mergeRowsForRequest(tabRows('arrival'), no)
        ];
        const statusKeys = [
            'noticeStatusCd', 'arrivalNoticeStatusCd', 'arrivalNoticeSendStatusCd',
            'ianSendSttsCd', 'IAN_SEND_STTS_CD', 'sendSttsCd',
            'noticeStatus', 'noticeStatusNm', 'sendStatusNm',
            'ianSendSttsNm', 'IAN_SEND_STTS_NM', 'sendSttsNm',
            'arrivalNoticeStatus', 'arrivalNoticeStatusNm', 'ianSendStatusCd'
        ];
        const requestKeys = ['trcNo', 'requestNo', 'reqNo', 'TRC_NO', 'IAN_TRC_NO', 'ianTrcNo'];

        /*
         * 입고관리 게이트의 기준은 DOM 글자나 임시 표시명이 아니라 DB 상태값이다.
         * IMP_ARRV_NTC.IAN_SEND_STTS_CD = TRC_NTC_SENT 이거나,
         * 같은 값을 매핑한 arrivalNoticeStatusCd/noticeStatusCd 등이 있으면 다음 단계 진행 가능으로 본다.
         * SENT/NSENT 구버전 코드는 더 이상 인정하지 않는다.
         */
        return rows.some(function (row) {
            if (!row) return false;
            const rowNo = requestKeys.map(function (key) { return row[key]; }).find(isUsableValue);
            if (rowNo && no && !rowMatchesRequestNo(row, no)) return false;
            return statusKeys.some(function (key) {
                const raw = normalizeText(row[key]);
                const upper = raw.toUpperCase();
                return upper === 'TRC_NTC_SENT'
                    || raw === '발송완료'
                    || raw === '통지완료';
            });
        });
    }


    function flowRowsForRequest(type, trcNo) {
        const no = trcNo || currentRequestNo(currentRequest());
        return [
            workRow(type, no),
            mergeRowsForRequest(tabRows(type), no),
            currentRequest(),
            findRequestRow(no),
            mergedRequestContext(no)
        ].filter(Boolean);
    }

    function rowHasAnyStatus(row, keys, exactCodes, exactNames) {
        const codes = (exactCodes || []).map(function (v) { return normalizeText(v).toUpperCase(); });
        const names = (exactNames || []).map(normalizeText);
        return (keys || []).some(function (key) {
            const raw = normalizeText(row && row[key]);
            const upper = raw.toUpperCase();
            return raw && (codes.includes(upper) || names.includes(raw));
        });
    }

    function isInboundCompleted(trcNo) {
        const keys = [
            'warehouseInStatusCd', 'warehouseReplyStatusCd', 'wirWhReplyStatusCd',
            'inStatusCd', 'whInStatusCd', 'wirStatusCd', 'WIR_STATUS_CD', 'WIR_WH_REPLY_STATUS_CD',
            'warehouseInStatusNm', 'warehouseReplyStatusNm', 'inStatusNm', 'whInStatusNm', 'statusNm'
        ];
        return flowRowsForRequest('inbound', trcNo).some(function (row) {
            return rowHasAnyStatus(row, keys, ['IN_DONE', 'APR'], ['입고완료']);
        });
    }

    function isDoDeliveredForGate(trcNo) {
        const keys = [
            'doStatusCd', 'diStatusCd', 'DI_STATUS_CD', 'doStatus',
            'doStatusNm', 'diStatusNm', 'DI_STATUS_NM', 'statusNm'
        ];
        return flowRowsForRequest('do', trcNo).some(function (row) {
            return rowHasAnyStatus(row, keys, ['TRC_DO_REQ', 'DELIVERED', 'DO_DELIVERED'], ['D/O전달완료', '전달완료']);
        });
    }

    function isReleaseCompleted(trcNo) {
        const keys = [
            'releaseStatusCd', 'crrStatusCd', 'crStatusCd', 'whOutStatusCd', 'CR_STATUS_CD',
            'releaseStatusNm', 'crrStatusNm', 'crStatusNm', 'whOutStatusNm', 'statusNm'
        ];
        return flowRowsForRequest('release', trcNo).some(function (row) {
            return rowHasAnyStatus(row, keys, ['REL_DONE', 'OUT_DONE', 'RELEASE_DONE', 'DONE'], ['반출완료']);
        });
    }

    function tabGateState(id, trcNo, req) {
        const accepted = isRequestAccepted(req);
        const allTabsOpen = isAllTabsOpenStatus(req);
        const releaseStageOpen = hasReleaseStageState(trcNo);
        if (id === 'request') return {open: true, title: '', message: ''};
        if (allTabsOpen) return {open: true, title: '', message: ''};
        if (!accepted) return {open: false, title: '접수완료 후 진행 가능', message: '운송의뢰가 접수완료 상태가 아니면 다음 단계를 진행할 수 없습니다.'};
        if (id === 'arrival') return {open: true, title: '', message: ''};
        if (releaseStageOpen && (id === 'inbound' || id === 'do' || id === 'release')) return {open: true, title: '', message: ''};
        if (releaseStageOpen && id === 'inland' && isReleaseCompleted(trcNo)) return {open: true, title: '', message: ''};
        if (releaseStageOpen && id === 'inland') return {open: false, title: '반출완료 후 진행 가능', message: '반출 보완요청/반출요청 상태에서는 반출관리까지만 열립니다. 창고 승인 후 반출완료가 되면 내륙배차가 열립니다.'};
        if (id === 'inbound' && shouldOpenInboundForSupplement(req, trcNo)) return {open: true, title: '', message: ''};
        if (isReceiptCompleteOnlyStatus(req, trcNo)) {
            return {open: false, title: '도착대기 후 진행 가능', message: '접수완료 상태에서는 도착통지서 탭만 열립니다. 도착대기 또는 최종완료 상태가 되면 모든 상세탭이 열립니다.'};
        }
        if (!isArrivalNoticeSent(trcNo)) return {open: false, title: '도착통지 발송 후 진행 가능', message: '도착통지서 발송완료 후 입고관리만 열립니다.'};
        if (id === 'inbound') return {open: true, title: '', message: ''};
        if (!isInboundCompleted(trcNo)) return {open: false, title: '입고완료 후 진행 가능', message: '입고관리 상태가 입고완료(IN_DONE)일 때 D/O, 반출관리, 내륙배차가 열립니다.'};
        if (id === 'do') return {open: true, title: '', message: ''};
        if (!isDoDeliveredForGate(trcNo)) return {open: false, title: 'D/O 전달완료 후 진행 가능', message: 'D/O가 전달완료(TRC_DO_REQ)된 뒤 반출관리를 진행할 수 있습니다.'};
        if (id === 'release') return {open: true, title: '', message: ''};
        if (!isReleaseCompleted(trcNo)) return {open: false, title: '반출완료 후 진행 가능', message: '반출관리 상태가 반출완료(REL_DONE)일 때 내륙배차가 열립니다.'};
        return {open: true, title: '', message: ''};
    }

    function lockPanelHtml(title, message) {
        return ''
            + '<div class="import-ui-request-detail">'
            + '<div class="import-ui-section" style="margin:16px;">'
            + '<h5>' + esc(title || '진행 불가') + '</h5>'
            + '<p class="text-sm text-slate-600" style="margin:0;">' + esc(message || '이전 단계를 먼저 처리해주세요.') + '</p>'
            + '</div>'
            + '</div>';
    }

    function setTabDisabledState(root, req) {
        if (!root) return;
        req = req || currentRequest();
        const no = currentRequestNo(req);
        root.querySelectorAll('.import-ui-tab').forEach(function (button) {
            const id = button.dataset.workId || '';
            const gate = tabGateState(id, no, req);
            const disabled = !gate.open;
            button.classList.toggle('is-disabled', disabled);
            button.setAttribute('aria-disabled', disabled ? 'true' : 'false');
            if (disabled) {
                const tip = gate.message || gate.title || '이전 단계를 먼저 완료하면 열립니다.';
                button.setAttribute('title', tip);
                button.setAttribute('data-lock-title', gate.title || '이전 단계 완료 후 진행 가능');
                button.setAttribute('data-lock-message', tip);
            } else {
                button.removeAttribute('title');
                button.removeAttribute('data-lock-title');
                button.removeAttribute('data-lock-message');
            }
        });
    }

    function markArrivalSentForRequest(trcNo, noticeNo) {
        const rows = tabRows('arrival');
        let row = findRowByRequestNo(rows, trcNo);
        if (!row) {
            row = {trcNo: trcNo, requestNo: trcNo, reqNo: noticeNo || '', arrivalNoticeReqNo: noticeNo || '', arrivalNoticeNo: noticeNo || ''};
            window.TRANSPORT_IMPORT_ARRIVAL_TRACKING = window.TRANSPORT_IMPORT_ARRIVAL_TRACKING || [];
            window.TRANSPORT_IMPORT_ARRIVAL_TRACKING.push(row);
        }
        if (noticeNo && noticeNo !== '-') {
            if (!isUsableValue(row.reqNo)) row.reqNo = noticeNo;
            if (!isUsableValue(row.arrivalNoticeReqNo)) row.arrivalNoticeReqNo = noticeNo;
            if (!isUsableValue(row.arrivalNoticeNo)) row.arrivalNoticeNo = noticeNo;
            row.ianNo = noticeNo;
            row.IAN_NO = noticeNo;
        }
        row.trcNo = row.trcNo || trcNo;
        row.TRC_NO = row.TRC_NO || trcNo;
        row.transportRequestNo = row.transportRequestNo || trcNo;
        row.requestNo = row.requestNo || trcNo;
        row.noticeStatus = 'TRC_NTC_SENT';
        row.noticeStatusCd = 'TRC_NTC_SENT';
        row.noticeStatusNm = '발송완료';
        row.sendStatusNm = '발송완료';
        row.arrivalNoticeStatusCd = 'TRC_NTC_SENT';
        row.arrivalNoticeSendStatusCd = 'TRC_NTC_SENT';
        row.ianSendSttsCd = 'TRC_NTC_SENT';
        row.ianSendSttsNm = '발송완료';
        row.IAN_SEND_STTS_CD = 'TRC_NTC_SENT';
        row.IAN_SEND_STTS_NM = '발송완료';
        row.statusCd = 'TRC_NTC_SENT';
        row.statusNm = '발송완료';
        window.__TACS_IMPORT_ARRIVAL_LOADED = true;

        if (typeof window.syncManifestArrivalNoticeStatus === 'function') {
            window.syncManifestArrivalNoticeStatus(trcNo);
        }
    }

    function refreshArrivalNoticeSentState(detail) {
        detail = detail || {};
        const trcNo = detail.trcNo || detail.transportRequestNo || detail.reqNo || currentRequestNo(currentRequest());
        if (!trcNo) return;

        const noticeNo = detail.noticeNo || detail.arrivalNoticeNo || detail.arrivalNoticeReqNo || detail.ianNo || '';
        markArrivalSentForRequest(trcNo, noticeNo);
        if (typeof window.patchImportArrivalNoticeSentDom === 'function') {
            window.patchImportArrivalNoticeSentDom(trcNo, noticeNo);
            setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, noticeNo); }, 0);
            setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, noticeNo); }, 120);
        }

        [currentRequest(), findRequestRow(trcNo)].forEach(function (row) {
            if (!row || (currentRequestNo(row) && !rowMatchesRequestNo(row, trcNo))) return;
            row.noticeStatus = 'TRC_NTC_SENT';
            row.noticeStatusCd = 'TRC_NTC_SENT';
            row.noticeStatusNm = '발송완료';
            row.arrivalNoticeStatus = 'TRC_NTC_SENT';
            row.arrivalNoticeStatusCd = 'TRC_NTC_SENT';
            row.arrivalNoticeSendStatusCd = 'TRC_NTC_SENT';
            row.ianSendSttsCd = 'TRC_NTC_SENT';
            row.ianSendSttsNm = '발송완료';
            row.IAN_SEND_STTS_CD = 'TRC_NTC_SENT';
            row.IAN_SEND_STTS_NM = '발송완료';
            row.sendStatusCd = 'TRC_NTC_SENT';
            row.sendSttsCd = 'TRC_NTC_SENT';
            row.sendStatusNm = '발송완료';
            // generic statusCd/statusNm은 접수상태 판정에 쓰이므로
            // 도착통지서 상태를 덮어쓰지 않는다.
            if (noticeNo && noticeNo !== '-') {
                row.reqNo = row.reqNo || noticeNo;
                row.arrivalNoticeNo = row.arrivalNoticeNo || noticeNo;
                row.arrivalNoticeReqNo = row.arrivalNoticeReqNo || noticeNo;
                row.ianNo = noticeNo;
                row.IAN_NO = noticeNo;
            }
        });

        document.querySelectorAll('.import-inline-tabs-0513').forEach(function (root) {
            if (!isImportInlineDetailActive(root)) return;
            const req = currentRequest();
            if (currentRequestNo(req) && !rowMatchesRequestNo(req, trcNo)) return;
            if ((root.dataset.activeWorkId || '') === 'arrival') {
                renderInlineTab(root, 'arrival');
                if (typeof window.patchImportArrivalNoticeSentDom === 'function') {
                    setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, noticeNo); }, 0);
                    setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, noticeNo); }, 120);
                    setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, noticeNo); }, 300);
                }
            }
            setTabDisabledState(root, req);
        });
    }

    function isDoneStatus(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        return ['DONE', 'IN_DONE', 'OUT_DONE', 'RELEASE_DONE', 'TRC_DISPATCH_DONE', 'TRC_NTC_SENT', 'DELIVERED'].includes(upper)
            || raw.indexOf('완료') >= 0 || raw.indexOf('통지완료') >= 0 || raw.indexOf('반출완료') >= 0;
    }

    function statusText(value, fallback) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        if (!raw || raw === '-') return fallback || '';
        if (upper === 'WAIT' || upper === 'IN_WAIT') return '입고대기';
        if (upper === 'SENT') return '입고요청';
        if (upper === 'IN_DONE') return '입고완료';
        if (upper === 'REQ_FIX' || upper === 'FIX_REQ' || upper === 'SUPPLEMENT' || upper === 'SUPPLEMENT_REQUESTED') return '보완요청';
        if (upper === 'SUB') return '보완완료';
        if (upper === 'REQ_SENT' || upper === 'REL_SENT') return '보완제출완료';
        if (upper === 'APR') return '입고완료';
        if (upper === 'OUT_WAIT' || upper === 'RELEASE_WAIT' || upper === 'REL_WAIT' || upper === 'REQ') return fallback === '반출대기' ? '반출대기' : '대기';
        if (upper === 'REL_FIX') return '보완요청';
        if (upper === 'OUT_DONE' || upper === 'RELEASE_DONE') return '반출완료';
        if (upper === 'TRC_DISPATCH_WAIT') return '배차대기';
        if (upper === 'TRC_DISPATCH_DONE') return '배차완료';
        if (upper === 'TRC_NTC_SENT') return '입고요청';
        if (upper === 'REL_REQ' || upper === 'REQUESTED') return fallback === '반출대기' ? '반출대기' : '발송완료';
        return raw;
    }

    function section(title, content) {
        return '<section class="import-ui-section"><h5>' + esc(title) + '</h5>' + content + '</section>';
    }

    const inboundDetailMessageCache = new Map();
    const inboundDetailGoodsCache = new Map();

    function inboundSupplementMessage(row) {
        return pick(row, [
            'suppReqCn',
            'rejectReason',
            'supplementReason',
            'rejectMemo',
            'sriReqCn',
            'SRI_REQ_CN'
        ], '');
    }

    function inboundSupplementNoticeHtml(row) {
        const message = normalizeText(inboundSupplementMessage(row));
        if (!message) return '';
        return ''
            + '<div class="import-ui-field import-ui-inbound-supp-notice-wrap">'
            + '<label style="color:#92400e;">창고 보완요청 메시지</label>'
            + '<textarea readonly style="min-height:58px;background:#fffbeb!important;border-color:#f59e0b!important;color:#78350f!important;-webkit-text-fill-color:#78350f!important;font-weight:900;line-height:1.55;">' + esc(message) + '</textarea>'
            + '</div>';
    }

    function mergeInboundDetailIntoStores(trcNo, detail) {
        if (!detail || typeof detail !== 'object') return;
        const keys = [
            '__TACS_IMPORT_INBOUND_DETAIL_ROWS',
            '__TACS_IMPORT_INBOUND_REGISTERED_ROWS',
            'TRANSPORT_IMPORT_WAREHOUSE_IN_LIST',
            'TRANSPORT_IMPORT_INBOUND_LIST'
        ];
        keys.forEach(function (key) {
            const rows = window[key];
            if (!Array.isArray(rows)) return;
            let matched = false;
            rows.forEach(function (row) {
                if (!rowMatchesRequestNo(row, trcNo)
                    && normalizeText(pick(row, ['wirNo', 'WIR_NO', 'inboundRequestNo'], '')) !== normalizeText(pick(detail, ['wirNo', 'WIR_NO', 'inboundRequestNo'], ''))) {
                    return;
                }
                Object.keys(detail).forEach(function (key) {
                    // 상세조회 값이 null/빈값이면 기존 목록의 실제 값(품목/금액/메시지)을 덮어쓰지 않는다.
                    // 단, 상태값은 상세조회가 더 정확할 수 있으므로 값이 있을 때만 갱신한다.
                    if (isUsableValue(detail[key])) row[key] = detail[key];
                });
                matched = true;
            });
            if (!matched && rowMatchesRequestNo(detail, trcNo)) rows.push(detail);
        });
    }

    function goodsListOf(row) {
        const list = row && (row.goodsList || row.itemList || row.customsGoodsList || row.goodsRows || row.goods);
        return Array.isArray(list) ? list.filter(Boolean) : [];
    }

    function hasInboundGoodsList(row) {
        return goodsListOf(row).length > 0;
    }

    function ensureInboundGoodsDetail(root, trcNo) {
        const row = workRow('inbound', trcNo) || workRow('release', trcNo);
        if (hasInboundGoodsList(row)) return;

        const wirNo = pick(row, ['wirNo', 'WIR_NO', 'inboundRequestNo'], '');
        if (!wirNo) return;

        const cacheKey = String(wirNo);
        if (inboundDetailGoodsCache.get(cacheKey) === 'loading' || inboundDetailGoodsCache.get(cacheKey) === 'done') return;
        inboundDetailGoodsCache.set(cacheKey, 'loading');

        getJson('/transport/import/unloading-in/detail.do?wirNo=' + encodeURIComponent(wirNo) + '&_=' + Date.now())
            .then(function (detail) {
                inboundDetailGoodsCache.set(cacheKey, 'done');
                if (!window.__TACS_IMPORT_INBOUND_DETAIL_ROWS) window.__TACS_IMPORT_INBOUND_DETAIL_ROWS = [];
                mergeInboundDetailIntoStores(trcNo, detail);
                if (root && root.isConnected && (root.dataset.activeWorkId === 'inbound' || root.dataset.activeWorkId === 'release')) {
                    renderInlineTab(root, root.dataset.activeWorkId);
                }
            })
            .catch(function (error) {
                inboundDetailGoodsCache.delete(cacheKey);
                console.warn('[입고 품목 상세 조회 실패]', error);
            });
    }

    function ensureInboundSupplementMessage(root, trcNo) {
        const row = workRow('inbound', trcNo);
        const rawStatus = pick(row, [
            'inStatusNm', 'warehouseInStatusNm', 'wirStatusNm', 'statusNm', 'statusCd',
            'warehouseInStatusCd', 'warehouseReplyStatusCd', 'wirStatusCd', 'whInStatusNm',
            'whReplyStatusCd', 'wirWhReplyStatusCd', 'WIR_STATUS_CD', 'WIR_WH_REPLY_STATUS_CD'
        ], '');
        const status = statusText(rawStatus, '입고대기');
        const hasMessage = normalizeText(inboundSupplementMessage(row));
        if (hasMessage || status !== '보완요청') return;

        const wirNo = pick(row, ['wirNo', 'WIR_NO', 'inboundRequestNo'], trcNo);
        if (!wirNo) return;

        const cacheKey = String(wirNo);
        if (inboundDetailMessageCache.get(cacheKey) === 'loading' || inboundDetailMessageCache.get(cacheKey) === 'done') return;
        inboundDetailMessageCache.set(cacheKey, 'loading');

        getJson('/transport/import/unloading-in/detail.do?wirNo=' + encodeURIComponent(wirNo) + '&_=' + Date.now())
            .then(function (detail) {
                inboundDetailMessageCache.set(cacheKey, 'done');
                mergeInboundDetailIntoStores(trcNo, detail);
                if (root && root.isConnected && root.dataset.activeWorkId === 'inbound') {
                    renderInlineTab(root, 'inbound');
                }
            })
            .catch(function (error) {
                inboundDetailMessageCache.delete(cacheKey);
                console.warn('[입고 보완요청 메시지 상세 조회 실패]', error);
            });
    }

    function renderShell(title, itemId, bodyHtml, options) {
        options = options || {};
        const dashboard = document.getElementById('dashboard-view');
        const detail = document.getElementById('detail-view');
        const body = document.getElementById('detail-body');
        const pageTitle = document.getElementById('page-title');
        const breadcrumb = document.getElementById('breadcrumb');
        const back = document.getElementById('backBtn');

        try { currentGroupKey = GROUP; currentItemId = itemId; } catch (e) {}
        if (typeof window.toggleMenuGroup === 'function') window.toggleMenuGroup(GROUP, true);
        if (typeof window.setActiveNav === 'function') window.setActiveNav(GROUP, itemId === REQUEST_DETAIL_ID ? REQUEST_LIST_ID : itemId);
        if (typeof window.setSavedLastItemId === 'function') window.setSavedLastItemId(GROUP, itemId);

        if (dashboard) dashboard.classList.add('hidden');
        if (detail) detail.classList.remove('hidden');
        if (pageTitle) pageTitle.textContent = title;
        if (breadcrumb) breadcrumb.innerHTML = '수입운송 &gt; <span class="font-semibold text-slate-900">' + esc(title) + '</span>';
        if (body) {
            window.detailBody = body;
            body.dataset.currentGroup = GROUP;
            body.dataset.currentItem = itemId;
            if (itemId === REQUEST_DETAIL_ID) bumpImportInlineRenderToken();
            body.innerHTML = bodyHtml;
        }
        if (back) {
            back.classList.remove('hidden');
            back.innerHTML = options.backLabelHtml || '<span class="material-symbols-outlined text-lg">arrow_back</span><span>운송의뢰</span>';
            back.onclick = options.backHandler || function () {
                rememberImportRoute({ type: 'menu', itemId: REQUEST_LIST_ID });
                importBootRestoreDeadline = 0;
                importBootRestoreRoute = null;
                if (typeof window.renderCurrentImportRequestList === 'function') window.renderCurrentImportRequestList();
                else if (typeof window.openDetail === 'function') window.openDetail(GROUP, REQUEST_LIST_ID);
            };
        }
        if (typeof window.normalizeDetailActionButtons === 'function') window.normalizeDetailActionButtons();
        return body;
    }

    function ensureStyle() {
        if (document.getElementById('tacs-import-ui-clean-style')) return;
        const style = document.createElement('style');
        style.id = 'tacs-import-ui-clean-style';
        style.textContent = `
            #detail-body .import-ui-tabs{margin:0 0 0;border:1px solid #cbd5e1;background:#fff;}
            #detail-body .import-ui-tab-bar{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));border-bottom:1px solid #cbd5e1;background:#fff;}
            #detail-body .import-ui-tab{position:relative;height:56px;border:0;border-right:1px solid #d7e1ef;background:#fff;font-size:13px;font-weight:900;color:#0f172a;cursor:pointer;}
            #detail-body .import-ui-tab:last-child{border-right:0;}
            #detail-body .import-ui-tab:hover{background:#f3f7ff;color:#1d4ed8;}
            #detail-body .import-ui-tab.is-disabled{opacity:.72;cursor:help;background:#f8fafc;color:#94a3b8;}
            #detail-body .import-ui-tab.is-disabled:hover{background:#eef2f7;color:#64748b;}
            #detail-body .import-ui-tab.is-disabled::after{content:attr(data-lock-message);display:none;position:absolute;left:50%;top:calc(100% + 8px);transform:translateX(-50%);z-index:9999;width:max-content;max-width:340px;padding:9px 11px;border:1px solid #cbd5e1;border-radius:10px;background:#0f172a;color:#fff;font-size:12px;font-weight:800;line-height:1.45;text-align:left;white-space:normal;box-shadow:0 10px 25px rgba(15,23,42,.18);pointer-events:none;}
            #detail-body .import-ui-tab.is-disabled::before{content:'';display:none;position:absolute;left:50%;top:100%;transform:translateX(-50%);z-index:10000;border:7px solid transparent;border-bottom-color:#0f172a;pointer-events:none;}
            #detail-body .import-ui-tab.is-disabled:hover::after,#detail-body .import-ui-tab.is-disabled:hover::before{display:block;}
            #detail-body .import-ui-tab.is-active{background:#eaf2ff;color:#0f3f8c;box-shadow:none;}
            #detail-body .import-ui-panel{display:none;padding:16px;background:#fff;border-bottom:1px solid #dbe4f0;}
            #detail-body .import-ui-panel.is-active{display:block;}
            #detail-body .import-ui-request-detail{border:1px solid #cbd5e1;border-top:0;background:#fff;}
            #detail-body .import-ui-grid3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px;padding:16px;}
            #detail-body .import-ui-extra-section{padding:0 16px 16px;}
            #detail-body .import-ui-goods-table-wrap{border:1px solid #cbd5e1;background:#fff;overflow-x:auto;}
            #detail-body .import-ui-goods-table{width:100%;border-collapse:collapse;font-size:12px;}
            #detail-body .import-ui-goods-table th{background:#eaf2ff;border-bottom:1px solid #94a3b8;padding:10px 12px;text-align:center;font-weight:900;color:#0f172a;}
            #detail-body .import-ui-goods-table td{border-bottom:1px solid #e2e8f0;padding:10px 12px;text-align:center;color:#0f172a;font-weight:700;vertical-align:middle;}
            #detail-body .import-ui-goods-table tr:last-child td{border-bottom:0;}
            #detail-body .import-ui-goods-table .left{text-align:left;}
            #detail-body .import-ui-goods-edit{width:100%;height:34px;min-height:34px;border:1px solid #cbd5e1;background:#fff;padding:0 8px;box-sizing:border-box;font-size:12px;font-weight:700;line-height:1.2;color:#0f172a;}
            #detail-body .import-ui-goods-edit[readonly]{background:#e5e7eb;color:#334155;-webkit-text-fill-color:#334155;cursor:default;}
            #detail-body .import-ui-goods-empty{text-align:center!important;color:#64748b!important;background:#f8fafc!important;font-weight:800;}
            #detail-body .import-ui-section{border:1px solid #cbd5e1;background:#fff;padding:14px 16px;}
            #detail-body .import-ui-section h5,.import-ui-card h4{margin:0 0 12px;padding-left:9px;border-left:4px solid #334155;font-size:12px;font-weight:900;color:#0f172a;}
            #detail-body .import-ui-field{margin-bottom:10px;}
            #detail-body .import-ui-field label{display:block;margin:0 0 6px;font-size:11px;font-weight:900;color:#475569;}
            #detail-body .import-ui-field input,#detail-body .import-ui-field select,#detail-body .import-ui-field textarea{width:100%;min-height:40px;border:1px solid #cbd5e1;background:#e5e7eb;padding:0 10px;font-size:12px;font-weight:700;color:#334155;outline:0;box-sizing:border-box;}
            #detail-body .import-ui-field textarea{min-height:76px;padding:10px;resize:vertical;}
            #detail-body .import-ui-field input.import-ui-editable,#detail-body .import-ui-field select.import-ui-editable,#detail-body .import-ui-field textarea.import-ui-editable{background:#fff;color:#0f172a;}
            #detail-body .import-ui-option-cell{display:flex;align-items:center;gap:6px;}
            #detail-body .import-ui-option-cell .import-ui-option-display{min-width:0;cursor:pointer;}
            #detail-body .import-ui-option-btn{display:inline-flex;align-items:center;justify-content:center;flex:0 0 52px;width:52px;height:40px;min-height:40px;border:1px solid #334155;background:#334155;color:#fff;-webkit-text-fill-color:#fff;font-size:12px;font-weight:900;line-height:1;cursor:pointer;}
            #detail-body .import-ui-field input.import-ui-editable:disabled,#detail-body .import-ui-field select.import-ui-editable:disabled,#detail-body .import-ui-field textarea.import-ui-editable:disabled{background:#e5e7eb!important;color:#334155!important;-webkit-text-fill-color:#334155!important;opacity:1!important;cursor:not-allowed;}
            #detail-body .import-ui-field select.import-ui-editable:disabled option{color:#334155!important;background:#e5e7eb!important;}
            #detail-body .import-ui-file-cell{display:flex;gap:8px;align-items:center;}
            #detail-body .import-ui-file-cell input{min-width:0;}
            #detail-body .import-ui-file-download{display:inline-flex!important;align-items:center!important;justify-content:center!important;flex:0 0 auto!important;min-width:72px!important;min-height:38px!important;border:1px solid #334155!important;background:#1e293b!important;color:#fff!important;-webkit-text-fill-color:#fff!important;padding:9px 11px!important;font-size:12px!important;font-weight:900!important;text-decoration:none!important;}
            #detail-body .import-ui-actions{display:flex;justify-content:flex-end;align-items:center;gap:8px;padding:14px 16px;border-top:1px solid #e2e8f0;}
            #detail-body .import-ui-btn{display:inline-flex;align-items:center;justify-content:center;box-sizing:border-box;min-height:34px;padding:0 14px;border:1px solid #1e293b;background:#1e293b;color:#fff;-webkit-text-fill-color:#fff;font-size:12px;font-weight:900;line-height:1;white-space:nowrap;cursor:pointer;vertical-align:middle;}
            #detail-body .import-ui-btn.secondary{background:#fff;color:#1e293b;-webkit-text-fill-color:#1e293b;border-color:#cbd5e1;}
            #detail-body .import-ui-btn.danger{background:#b91c1c;border-color:#b91c1c;color:#fff;-webkit-text-fill-color:#fff;}
            #detail-body .import-ui-btn:disabled{cursor:not-allowed!important;}
            #detail-body .import-ui-do-flow-btn,.import-ui-do-flow-btn{display:inline-flex!important;align-items:center!important;justify-content:center!important;box-sizing:border-box!important;width:112px!important;min-width:112px!important;max-width:112px!important;height:34px!important;min-height:34px!important;max-height:34px!important;margin:0!important;padding:0 12px!important;border:1px solid #1e293b!important;border-radius:0!important;opacity:1!important;font-size:12px!important;font-weight:900!important;line-height:1!important;text-align:center!important;white-space:nowrap!important;vertical-align:middle!important;box-shadow:none!important;appearance:none!important;-webkit-appearance:none!important;}
            #detail-body .import-ui-do-flow-btn.is-active,.import-ui-do-flow-btn.is-active{background:#1e293b!important;border-color:#1e293b!important;color:#fff!important;-webkit-text-fill-color:#fff!important;cursor:pointer!important;}
            #detail-body .import-ui-do-flow-btn.is-locked,#detail-body .import-ui-do-flow-btn.is-done,#detail-body .import-ui-do-flow-btn:disabled,.import-ui-do-flow-btn.is-locked,.import-ui-do-flow-btn.is-done,.import-ui-do-flow-btn:disabled{pointer-events:none!important;box-shadow:none!important;background:#e5e7eb!important;border-color:#cbd5e1!important;color:#64748b!important;-webkit-text-fill-color:#64748b!important;opacity:1!important;filter:none!important;cursor:not-allowed!important;}
            #detail-body .import-ui-field input[readonly],#detail-body .import-ui-field textarea[readonly]{cursor:default!important;}
            #detail-body .import-ui-two-col{display:grid;grid-template-columns:minmax(0,1.25fr) minmax(320px,.75fr);gap:16px;}
            #detail-body .import-ui-form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;}
            #detail-body .import-ui-doc-field{grid-column:1/-1;}
            #detail-body .import-ui-doc-toolbar{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
            #detail-body .import-ui-doc-select,#detail-body .import-ui-doc-upload-btn{display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:7px 12px;border:1px solid #334155;background:#475569;color:#fff;-webkit-text-fill-color:#fff;font-size:12px;font-weight:900;cursor:pointer;}
            #detail-body .import-ui-doc-upload-btn{background:#1e293b;color:#fff;-webkit-text-fill-color:#fff;}
            #detail-body .import-ui-doc-help{font-size:12px;color:#64748b;font-weight:700;}
            #detail-body .import-ui-doc-drop{min-height:94px;border:1px dashed #94a3b8;background:#f8fafc;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;font-size:12px;color:#475569;cursor:pointer;margin-bottom:10px;text-align:center;}
            #detail-body .import-ui-doc-drop:hover,#detail-body .import-ui-doc-drop.is-dragover{background:#eff6ff;border-color:#2563eb;color:#1d4ed8;}
            #detail-body .import-ui-doc-summary{font-size:11px;color:#64748b;max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding:0 10px;}
            #detail-body .import-ui-doc-table-wrap{border:1px solid #cbd5e1;background:#fff;overflow-x:auto;}
            #detail-body .import-ui-doc-table{width:100%;border-collapse:collapse;font-size:12px;}
            #detail-body .import-ui-doc-table th{background:#eaf2ff;border-bottom:1px solid #cbd5e1;padding:8px 10px;text-align:left;font-weight:900;color:#334155;}
            #detail-body .import-ui-doc-table td{border-bottom:1px solid #e2e8f0;padding:8px 10px;color:#0f172a;vertical-align:middle;}
            #detail-body .import-ui-doc-table tr:last-child td{border-bottom:0;}
            #detail-body .import-ui-doc-empty{text-align:center!important;color:#64748b!important;background:#f1f5f9!important;font-weight:800;}
            #detail-body .import-ui-doc-name{font-weight:900;word-break:break-all;}\n            #detail-body .import-ui-doc-status{text-align:center!important;white-space:nowrap!important;}\n
            #detail-body .import-ui-doc-chip{display:inline-flex;align-items:center;justify-content:center;min-height:20px;padding:2px 8px;border-radius:999px;background:#e2e8f0;color:#334155;font-size:11px;font-weight:900;line-height:1;white-space:nowrap;}
            #detail-body .import-ui-doc-chip.pending{background:#fff7ed;color:#c2410c;border:1px solid #fed7aa;}
            #detail-body .import-ui-doc-chip.done{background:#dcfce7;color:#166534;border:1px solid #bbf7d0;}
            #detail-body .import-ui-doc-action{text-align:center!important;white-space:nowrap;}
            #detail-body .import-ui-doc-action a,#detail-body .import-ui-doc-remove{display:inline-flex;align-items:center;justify-content:center;min-height:26px;padding:5px 9px;border:1px solid #334155;background:#fff;color:#0f172a;font-size:11px;font-weight:900;text-decoration:none;cursor:pointer;}
            #detail-body .import-ui-doc-remove{border-color:#fecaca;background:#fee2e2;color:#991b1b;}
            #detail-body .import-ui-summary-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;}
            #detail-body .import-ui-summary-cell{border:1px solid #cbd5e1;background:#fff;padding:12px;}
            #detail-body .import-ui-summary-cell span{display:block;font-size:11px;font-weight:800;color:#64748b;}
            #detail-body .import-ui-summary-cell strong{display:block;margin-top:4px;font-size:13px;font-weight:900;color:#0f172a;word-break:break-word;}
            #detail-body td:has(.import-request-detail-btn){display:table-cell!important;text-align:center!important;vertical-align:middle!important;white-space:nowrap;}
            #detail-body td:has(.import-request-detail-btn) .btn,#detail-body td:has(.import-request-detail-btn) button,#detail-body td:has(.import-request-detail-btn) a{margin:0!important;vertical-align:middle;}
            #detail-body .import-request-action-cell{display:table-cell!important;text-align:center!important;vertical-align:middle!important;white-space:nowrap!important;}
            #detail-body .import-request-action-cell button,#detail-body .import-request-action-cell a{display:inline-flex!important;align-items:center!important;justify-content:center!important;margin:0 3px!important;vertical-align:middle!important;}
            .import-option-modal{position:fixed;inset:0;z-index:3000;align-items:center;justify-content:center;padding:24px;font-family:Pretendard,"Noto Sans KR","Malgun Gothic",Arial,sans-serif;}
            .import-option-backdrop{position:absolute;inset:0;background:rgba(15,23,42,.42);}
            .import-option-panel{position:relative;z-index:1;width:min(680px,100%);max-height:82vh;background:#fff;border:1px solid #334155;box-shadow:0 18px 50px rgba(15,23,42,.22);display:flex;flex-direction:column;}
            .import-option-head{height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 16px;border-bottom:1px solid #cbd5e1;background:#f8fafc;}
            .import-option-head h4{margin:0;font-size:14px;font-weight:900;color:#0f172a;}
            .import-option-close{width:34px;height:34px;border:0;background:transparent;color:#334155;font-size:24px;line-height:1;cursor:pointer;}
            .import-option-search{display:flex;gap:8px;padding:14px 16px;border-bottom:1px solid #e2e8f0;}
            .import-option-search input{flex:1;min-width:0;height:38px;border:1px solid #cbd5e1;padding:0 10px;font-size:12px;font-weight:700;color:#0f172a;outline:0;}
            .import-option-search-btn{width:64px;height:38px;border:1px solid #334155;background:#334155;color:#fff;font-size:12px;font-weight:900;cursor:pointer;}
            .import-option-list-wrap{overflow:auto;}
            .import-option-table{width:100%;border-collapse:collapse;font-size:12px;}
            .import-option-table th{height:38px;padding:9px 12px;background:#f8fafc;border-bottom:1px solid #cbd5e1;color:#334155;font-weight:900;text-align:left;}
            .import-option-table td{height:40px;padding:9px 12px;border-bottom:1px solid #e2e8f0;color:#0f172a;font-weight:700;}
            .import-option-row{cursor:pointer;}
            .import-option-row:hover{background:#eaf2ff;}
            .import-option-empty{text-align:center!important;color:#64748b!important;background:#f8fafc!important;font-weight:800!important;}
            @media(max-width:1200px){#detail-body .import-ui-grid3,#detail-body .import-ui-two-col{grid-template-columns:1fr;}#detail-body .import-ui-summary-grid{grid-template-columns:repeat(2,minmax(0,1fr));}}
            @media(max-width:760px){#detail-body .import-ui-tab-bar{grid-template-columns:1fr;}#detail-body .import-ui-form-grid,#detail-body .import-ui-summary-grid{grid-template-columns:1fr;}#detail-body .import-ui-file-cell{align-items:stretch;flex-direction:column;}#detail-body .import-ui-file-download{text-align:center;}}
        `;
        document.head.appendChild(style);
    }

    function requestDetailHtml(req) {
        req = mergeRequestDetailDraft(req || {});
        const no = currentRequestNo(req);
        const originalRow = findRequestRow(no) || {};
        const receiptStatusRaw = pick(req, [
            'receiptStatus', 'receiptStatusNm', 'receiptStatusCd',
            'trcStatusNm', 'trcStatusCd', 'TRC_STATUS_NM', 'TRC_STATUS_CD',
            'status', 'statusNm', 'statusCd'
        ], pick(originalRow, [
            'receiptStatus', 'receiptStatusNm', 'receiptStatusCd',
            'trcStatusNm', 'trcStatusCd', 'TRC_STATUS_NM', 'TRC_STATUS_CD',
            'status', 'statusNm', 'statusCd'
        ], ''));
        const status = normalizeText(receiptStatusRaw) ? normalizeReceiptStatus(receiptStatusRaw) : '확인중';
        const displayStatus = normalizeText(req.displayStatus) || status;
        let invoiceFileName = pick(req, [
            'invoiceFile', 'invoiceFileNm', 'invoiceFileName', 'invoiceOrgNm',
            'invFile', 'invFileNm', 'invOrgNm', 'INVOICE_FILE', 'INVOICE_FILE_NM', 'INV_FILE_NM'
        ], pick(originalRow, [
            'invoiceFile', 'invoiceFileNm', 'invoiceFileName', 'invoiceOrgNm',
            'invFile', 'invFileNm', 'invOrgNm', 'INVOICE_FILE', 'INVOICE_FILE_NM', 'INV_FILE_NM'
        ], ''));
        let invoiceFileNo = pick(req, [
            'invoiceFileNo', 'invoiceDfiNo', 'invoiceDfiFileNo',
            'invFileNo', 'invDfiNo', 'dfiInvoiceNo', 'INVOICE_FILE_NO', 'INV_FILE_NO'
        ], pick(originalRow, [
            'invoiceFileNo', 'invoiceDfiNo', 'invoiceDfiFileNo',
            'invFileNo', 'invDfiNo', 'dfiInvoiceNo', 'INVOICE_FILE_NO', 'INV_FILE_NO'
        ], ''));
        const invoiceUrl = pick(req, ['invoiceUrl', 'invoiceFileUrl', 'invFileUrl'], pick(originalRow, ['invoiceUrl', 'invoiceFileUrl', 'invFileUrl'], ''));
        const packingFileName = pick(req, ['packingListFile', 'pkgListFile'], pick(originalRow, ['packingListFile', 'pkgListFile', 'PACKING_LIST_FILE'], ''));
        const packingFileNo = pick(req, ['packingListFileNo', 'pkgFileNo'], pick(originalRow, ['packingListFileNo', 'pkgFileNo', 'PACKING_LIST_FILE_NO'], ''));
        const packingUrl = pick(req, ['packingListUrl', 'packingListFileUrl', 'pkgFileUrl'], pick(originalRow, ['packingListUrl', 'packingListFileUrl', 'pkgFileUrl'], ''));
        const masterBl = requestMblValue(no, req, originalRow);
        const buyerName = pick(req, ['consignorName', 'buyerName', 'buyerNm'], '');
        const buyerCountry = pick(req, ['consignorCountry', 'buyerCountry', 'buyerCountryCd'], '');
        /*
         * 운송의뢰는 접수대기 상태에서만 수정 가능하다.
         * 접수완료/반려 이후에는 승인된 의뢰 원본으로 보고 전부 readonly 처리한다.
         */
        const canEditRequest = !req.__routeStub && normalizeText(receiptStatusRaw) && status === '접수대기';
        const noticeSent = isArrivalNoticeSent(no)
            || displayStatus === '도착통지서 발송완료'
            || displayStatus === '발송완료'
            || normalizeText(req.arrivalNoticeStatus) === 'TRC_NTC_SENT'
            || normalizeText(req.arrivalNoticeStatusCd) === 'TRC_NTC_SENT'
            || normalizeText(req.arrivalNoticeSendStatusCd) === 'TRC_NTC_SENT';
        const detailSaved = savedImportRequestDetails.has(no);
        const actionHtml = canEditRequest
            ? '<div class="import-ui-actions"><button type="button" class="import-ui-btn danger request-reject-btn" data-request-type="수입" data-request-no="' + esc(no) + '">반려</button><button type="button" class="import-ui-btn import-request-save-btn" data-request-no="' + esc(no) + '"' + (detailSaved ? ' disabled aria-disabled="true"' : '') + '>' + (detailSaved ? '저장완료' : '저장') + '</button><button type="button" class="import-ui-btn import-request-submit-btn" data-request-no="' + esc(no) + '">수락</button></div>'
            : status === '접수반려'
                ? '<div class="import-ui-actions"><span class="info-chip">접수반려</span></div>'
                : '<div class="import-ui-actions"><span class="info-chip">' + esc(noticeSent ? '발송완료' : status) + '</span></div>';

        return ''
            + '<div class="import-ui-request-detail import-ui-main-request-detail" data-request-no="' + esc(no) + '">'
            + '<div class="import-ui-grid3">'
            + '<div class="import-ui-section"><h5>1. 의뢰/화주 정보</h5>'
            + field('의뢰번호', no)
            + field('접수일자', req.receiptDate, {name: 'receiptDate'})
            + field('접수상태', status)
            + field('화주명', req.shipperName, {name: 'shipperName'})
            + field('화주 연락처', req.shipperPhone, {name: 'shipperPhone'})
            + field('화주 이메일', req.shipperEmail, {name: 'shipperEmail'})
            + '</div>'
            + '<div class="import-ui-section"><h5>2. 운송/B/L 정보</h5>'
            + field('바이어명', buyerName, {editable: canEditRequest, name: 'buyerName'})
            + optionField('거래자 국가', buyerCountry, {editable: canEditRequest, name: 'buyerCountry'})
            + optionField('운송수단', req.transportMode, {editable: canEditRequest, name: 'transportMode'})
            + optionField('운송형태', req.transportType, {editable: canEditRequest, name: 'transportType'})
            + optionField('출발항', req.originPort, {editable: canEditRequest, name: 'originPort'})
            + optionField('도착항', req.destinationPort, {editable: canEditRequest, name: 'destinationPort'})
            + optionField('B/L 구분', req.blType, {editable: canEditRequest, name: 'blType'})
            + '</div>'
            + '<div class="import-ui-section"><h5>3. 화물/첨부/요청</h5>'
            + optionField('화물품목구분', req.itemCategory, {editable: canEditRequest, name: 'itemCategory'})
            + field('품명', pick(req, ['goodsName', 'itemNm'], ''), {editable: canEditRequest, name: 'goodsName'})
            + field('수량', pick(req, ['qty', 'goodsQty'], ''), {editable: canEditRequest, name: 'qty', type: 'number'})
            + field('중량', pick(req, ['weight', 'goodsWeight', 'netWeight'], ''), {editable: canEditRequest, name: 'weight', type: 'number'})
            + field('Master B/L', masterBl, {editable: canEditRequest, name: 'mblNo'})
            + fileDownloadField('송장', invoiceFileName, invoiceFileNo, invoiceUrl)
            + fileDownloadField('포장명세서', packingFileName, packingFileNo, packingUrl)
            + field('요청사항', req.requestNote, {textarea: true, editable: canEditRequest, name: 'requestNote'})
            + '</div>'
            + '</div>'
            + actionHtml
            + '</div>';
    }

    function tabsHtml(active) {
        active = active || 'request';
        return ''
            + '<div class="import-ui-tabs import-inline-tabs-0513" data-active-work-id="' + esc(active) + '">'
            + '<div class="import-ui-tab-bar">'
            + WORK_ITEMS.map(function (item) {
                return '<button type="button" class="import-ui-tab import-inline-tab' + (item.id === active ? ' is-active' : '') + '" data-work-id="' + esc(item.id) + '">' + esc(item.title) + '</button>';
            }).join('')
            + '</div>'
            + '<div class="import-ui-panel import-inline-panel"></div>'
            + '</div>';
    }

    function renderRequestDetail(req, forcedWorkId) {
        ensureStyle();
        req = req || currentRequest();
        if (!currentRequestNo(req)) {
            const firstRow = requestRows()[0] || {};
            req = Object.assign({}, firstRow, req);
        }
        req = mergeRequestDetailDraft(req);
        setCurrentRequest(req);
        hydrateRequestGoodsIfNeeded(req);
        const initialWorkId = validImportWorkId(forcedWorkId || importRouteWorkId(req));
        updateImportDetailUrl(req, initialWorkId);
        const body = renderShell('운송의뢰', REQUEST_DETAIL_ID, '<div class="space-y-0">' + tabsHtml(initialWorkId) + requestDetailHtml(req) + '</div>');
        if (body) {
            const root = body.querySelector('.import-inline-tabs-0513');
            if (root) {
                root.dataset.requestNo = currentRequestNo(req);
                setTabDisabledState(root, req);
                renderInlineTab(root, initialWorkId);
            }
        }
        if (typeof window.bindImportRequestReceiptActions === 'function') {
            setTimeout(function () { window.bindImportRequestReceiptActions(GROUP, REQUEST_DETAIL_ID); }, 0);
        }
    }

    function isInboundReadonlyStatus(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        return raw === '입고대기'
            || raw === '입고요청'
            || raw === '입고요청완료'
            || raw === '입고완료'
            || raw === '보완완료'
            || raw === '보완제출완료'
            || raw === '보완승인'
            || upper === 'WAIT'
            || upper === 'IN_WAIT'
            || upper === 'SENT'
            || upper === 'REQ_SENT'
            || upper === 'IN_DONE'
            || upper === 'SUB'
            || upper === 'APR';
    }

    function applyReadonlyToInboundHtml(html, readonly) {
        if (!readonly) return html;
        return html
            .replace(/<select name="(warehouseId|wzNo|wmId)" class="import-ui-editable">/g,
                '<select name="$1" class="import-ui-editable" disabled aria-readonly="true">')
            .replace(/<input([^>]*class="import-ui-editable"[^>]*)(?<!readonly)>/g,
                function (match, attrs) {
                    return match.indexOf(' readonly') >= 0 || match.indexOf(' disabled') >= 0
                        ? match
                        : '<input' + attrs + ' readonly aria-readonly="true">';
                })
            .replace(/<textarea([^>]*class="import-ui-editable"[^>]*)(?<!readonly)>/g,
                function (match, attrs) {
                    return match.indexOf(' readonly') >= 0 || match.indexOf(' disabled') >= 0
                        ? match
                        : '<textarea' + attrs + ' readonly aria-readonly="true">';
                })
            .replace(/<button type="button" class="import-ui-btn secondary import-ui-inbound-supp-btn"([^>]*)>보완<\/button>/g,
                '<button type="button" class="import-ui-btn secondary import-ui-inbound-supp-btn"$1 disabled>보완</button>')
            .replace(/<button type="button" class="import-ui-btn import-ui-inbound-send-btn"([^>]*)>발송<\/button>/g,
                '<button type="button" class="import-ui-btn import-ui-inbound-send-btn"$1 disabled>발송</button>')
            .replace(/<button type="button" class="import-ui-btn import-ui-inbound-send-btn"([^>]*)>보완제출<\/button>/g,
                '<button type="button" class="import-ui-btn import-ui-inbound-send-btn"$1 disabled>보완제출</button>');
    }

    function resolveWarehouseName(row) {
        row = row || {};
        const direct = pick(row, ['whNm', 'warehouseNm', 'warehouseName', 'WH_NM'], '');
        if (isMeaningfulOptionValue(direct)) return direct;

        const targetLabel = pick(row, ['targetWarehouseNm', 'targetWarehouse'], '');
        if (isMeaningfulOptionValue(targetLabel) && targetLabel.indexOf('/') >= 0) {
            const labelWarehouse = targetLabel.split('/')[0].trim();
            if (isMeaningfulOptionValue(labelWarehouse)) return labelWarehouse;
        }

        const whValue = selectedWarehouseValue(row);
        if (isMeaningfulOptionValue(whValue)) {
            const matched = warehouseSourceRows().find(function (w) {
                return normalizeText(pick(w, ['whNo', 'warehouseNo', 'warehouseId', 'whId', 'WH_NO', 'WRHS_NO'], '')) === normalizeText(whValue);
            });
            const label = matched ? pick(matched, ['whNm', 'warehouseNm', 'warehouseName', 'WH_NM', 'WRHS_NM'], '') : '';
            if (isMeaningfulOptionValue(label)) return label;
        }

        const selectedWzNo = pick(row, ['wzNo', 'warehouseZoneNo', 'bondedZoneNo', 'wirWzNo', 'WIR_WZ_NO', 'WZ_NO'], '');
        if (isMeaningfulOptionValue(selectedWzNo)) {
            const matchedByZone = warehouseSourceRows().find(function (w) {
                return normalizeText(pick(w, ['wzNo', 'warehouseZoneNo', 'bondedZoneNo', 'WZ_NO'], '')) === normalizeText(selectedWzNo);
            });
            const labelByZone = matchedByZone ? pick(matchedByZone, ['whNm', 'warehouseNm', 'warehouseName', 'WH_NM', 'WRHS_NM'], '') : '';
            if (isMeaningfulOptionValue(labelByZone)) return labelByZone;
        }

        return '-';
    }

    function resolveWarehouseZoneName(row) {
        row = row || {};
        const direct = pick(row, ['warehouseZoneNm', 'wzNm', 'zoneNm', 'bondedZoneNm', 'WZ_NM'], '');
        if (isMeaningfulOptionValue(direct)) return direct;

        const selectedWzNo = pick(row, ['wzNo', 'warehouseZoneNo', 'bondedZoneNo', 'wirWzNo', 'WIR_WZ_NO', 'WZ_NO'], '');
        if (isMeaningfulOptionValue(selectedWzNo)) {
            const matched = globalRows('TRANSPORT_WAREHOUSE_ZONE_LIST', 'WAREHOUSE_ZONE_LIST', 'TRANSPORT_WAREHOUSE_LIST', 'WAREHOUSE_LIST').find(function (z) {
                return normalizeText(pick(z, ['wzNo', 'warehouseZoneNo', 'bondedZoneNo', 'WZ_NO'], '')) === normalizeText(selectedWzNo);
            });
            const label = matched ? pick(matched, ['wzNm', 'warehouseZoneNm', 'zoneNm', 'WZ_NM'], '') : '';
            if (isMeaningfulOptionValue(label)) return label;
            return selectedWzNo;
        }

        return '-';
    }

    function resolveWarehouseManagerName(row) {
        row = row || {};
        const direct = pick(row, ['bondedManagerNm', 'warehouseManagerNm', 'wmNm', 'managerNm', 'WM_NM'], '');
        if (isMeaningfulOptionValue(direct)) return direct;

        const selectedWmId = pick(row, ['wmId', 'warehouseManagerId', 'bondedManagerId', 'wirWmId', 'WIR_WM_ID', 'WM_ID'], '');
        if (isMeaningfulOptionValue(selectedWmId)) {
            const matched = globalRows('TRANSPORT_WAREHOUSE_MANAGER_LIST', 'WAREHOUSE_MANAGER_LIST', 'TRANSPORT_WAREHOUSE_LIST', 'WAREHOUSE_LIST').find(function (m) {
                return normalizeText(pick(m, ['wmId', 'warehouseManagerId', 'bondedManagerId', 'WM_ID'], '')) === normalizeText(selectedWmId);
            });
            const label = matched ? pick(matched, ['wmNm', 'warehouseManagerNm', 'bondedManagerNm', 'WM_NM'], '') : '';
            if (isMeaningfulOptionValue(label)) return label;
            return selectedWmId;
        }

        return '-';
    }


    function formatGoodsNumber(value, moneyYn) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '-';
        const n = numberOnly(raw);
        if (!n && !/^0([.]0+)?$/.test(raw.replace(/,/g, ''))) return raw;
        const formatted = n.toLocaleString('ko-KR', moneyYn ? {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        } : {});
        return moneyYn ? formatted + ' USD' : formatted;
    }

    function formatGoodsWeight(value) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '-';
        const n = numberOnly(raw);
        if (!n && !/^0([.]0+)?$/.test(raw.replace(/,/g, ''))) return raw;
        return n.toLocaleString('ko-KR') + ' KG';
    }

    function editableGoodsNumber(value, moneyYn) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '';
        const cleaned = raw.replace(/,/g, '').replace(/[^0-9.-]/g, '');
        if (!moneyYn) return cleaned;
        const number = Number(cleaned);
        return Number.isFinite(number) ? number.toFixed(2) : cleaned;
    }

    function sanitizeGoodsDisplayName(value) {
        let raw = normalizeText(value);
        if (!raw || raw === '-') return raw;

        // 예: "전자기기 외 0건", "전자기기 외 0건 외 0건" => "전자기기"
        // 예: "전자기기 외 2건 외 0건" => "전자기기 외 2건"
        let prev;
        do {
            prev = raw;
            raw = raw
                .replace(/\s*외\s*0\s*건\s*$/g, '')
                .replace(/(\s*외\s*[1-9][0-9]*\s*건)\s*외\s*0\s*건\s*$/g, '$1')
                .replace(/(\s*외\s*[1-9][0-9]*\s*건)(?:\s*\1)+\s*$/g, '$1')
                .trim();
        } while (raw !== prev);

        return raw || '-';
    }


