<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>

<header class="topbar">
<div class="tb-left">
<span class="tb-brand">TACS</span>
<div class="search-wrap">
<span class="material-symbols-outlined">search</span>
<input id="gSearch" onkeydown="if(event.key==='Enter')doSearch()" placeholder="의뢰번호 · B/L · 업체명 검색 후 Enter"/>
</div>
</div>
<div class="tb-right">
<% if (request.isUserInRole("SYSTEM_ADMIN")) { %>
<button class="tb-btn" title="액터 목록" onclick="location.href='${pageContext.request.contextPath}/systemadmin/dashboard.do'">
<span class="material-symbols-outlined">list</span>
</button>
<% } %>
<jsp:include page="/WEB-INF/views/common/notification_bell.jsp" />
<button class="tb-btn" onclick="alert('화주 통합 포털 Demo v2')"><span class="material-symbols-outlined">help</span></button>
<div class="tb-sep"></div>
<div class="tb-user">
<div class="tb-user-info">
<div class="name">화주 운영관리자</div>
<div class="role">TACS 통합 포털 · DEMO</div>
</div>
<div class="tb-avatar" onclick="if(confirm('로그아웃 하시겠습니까?')) location.href='${pageContext.request.contextPath}/logout'" style="cursor:pointer">화</div>
</div>
</div>
</header>
