/* ── AI Tax Card ── */
.ai-tax-card { background: #fff; border: 1px solid #e2e8f0; padding: 20px; margin-bottom: 20px; }
.ai-tax-title { font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; margin-bottom: 14px; display: flex; align-items: center; gap: 6px; }
.ai-tax-title .material-symbols-outlined { font-size: 16px; color: #605c78; }
.ai-tax-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 14px; }
.ai-tax-item { background: #f8fafc; border: 1px solid #e2e8f0; padding: 14px 16px; }
.ai-tax-item .label { font-size: 10px; font-weight: 700; color: #64748b; text-transform: uppercase; margin-bottom: 6px; }
.ai-tax-item .value { font-size: 18px; font-weight: 900; color: #0f172a; letter-spacing: -0.5px; }

/* ── Refund alert card ── */
.refund-side { background: #fff; border: 1px solid #e2e8f0; padding: 20px; }
.refund-side h4 { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; color: #64748b; margin-bottom: 16px; }

/* ── Mapping table ── */
.mapping-table td ul { padding-left: 18px; line-height: 1.8; }
.mapping-table td li { margin: 0; font-size: 11px; color: #475569; }

.port-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    z-index: 9999;
    align-items: center;
    justify-content: center;
}

.port-modal.open {
    display: flex;
}

.port-modal-box {
    width: 720px;
    max-width: 95vw;
    max-height: 80vh;
    background: #fff;
    border: 1px solid #cbd5e1;
    box-shadow: 0 20px 60px rgba(15, 23, 42, 0.25);
    display: flex;
    flex-direction: column;
}

.port-modal-header {
    background: #373f54;
    color: #f7f7ff;
    padding: 14px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.port-modal-header h3 {
    font-size: 15px;
    font-weight: 800;
    margin: 0;
}

.port-modal-close {
    background: none;
    border: none;
    color: #fff;
    font-size: 24px;
    cursor: pointer;
}


.port-modal-body {
    padding: 20px;
    overflow-y: auto;
}

.port-search-area {
    margin-bottom: 14px;
}

.port-search-area input {
    width: 100%;
    height: 40px;
    padding: 0 12px;
    border: 1px solid #a0b4c8;
    border-bottom: 2px solid #697d8f;
    font-size: 13px;
    outline: none;
}

.port-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
}

.port-table th {
    background: #ecf4ff;
    padding: 10px 12px;
    text-align: left;
    font-weight: 800;
    color: #4d6172;
    border-bottom: 2px solid #d9eafc;
}

.port-table td {
    padding: 10px 12px;
    border-bottom: 1px solid #e2e8f0;
    color: #203444;
}

.port-table tr:hover {
    background: #f8fafc;
}

.port-select-btn {
    padding: 5px 12px;
    background: #565e74;
    color: #fff;
    border: none;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
}

.port-picker-row {
    display: flex;
    align-items: center;
    gap: 8px;
}

.port-picker-input {
    flex: 1;
    min-width: 0;
    cursor: pointer;
    background: #fff;
}

.port-search-btn {
    flex-shrink: 0;
    height: 40px;
    padding: 0 16px;
    border: 1px solid #a0b4c8;
    background: #565e74;
    color: #f7f7ff;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: background .15s, border-color .15s;
}

.port-search-btn:hover {
    background: #4a5268;
    border-color: #565e74;
}