package kr.or.tacs.warehouse.dashboard.service;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import kr.or.tacs.dto.warehouse.WarehouseDashboardDTO;
import kr.or.tacs.dto.warehouse.WarehouseZoneDTO;
import kr.or.tacs.warehouse.dashboard.mapper.IWarehouseDashboardMapper;
import kr.or.tacs.warehouse.inventory.service.Inventory3DService;

@Service
public class WarehouseDashboardServiceImpl implements IWarehouseDashboardService {

	@Autowired
	private IWarehouseDashboardMapper warehouseDashboardMapper;
	
	@Autowired
	private Inventory3DService inventory3DService;
	
	
	@Override
	public WarehouseDashboardDTO selectWarehouseDashboard(String wmId) {
		
		// 상단 카드 집계 조회
		WarehouseDashboardDTO dashboard = warehouseDashboardMapper.selectDashboardCount(wmId);
		
		// 최근 입출고 현황 조회
		List<WarehouseDashboardDTO> recentFlowList = warehouseDashboardMapper.selectRecentFlowList(wmId);
		
		// 창고 구역별 적재 현황 조회
		List<WarehouseZoneDTO> zoneStatusList = inventory3DService.selectZoneStatusList(wmId);
		dashboard.setZoneStatusList(zoneStatusList);
		
		return dashboard;
	}

}
