<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%
    request.setAttribute("activeMenu", "transport");
    request.setAttribute("activeGroup", "transport");
    request.setAttribute("activeSub", "forwarder");
    request.setAttribute("transportTab", "import");
%>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="ctx-path" content="${pageContext.request.contextPath}">
    <title>TACS 수입 운송</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
          rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
          rel="stylesheet">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/owner.css">
</head>
<body>
<div class="app" id="app">
    <%@ include file="/WEB-INF/views/owner/sidebar.jsp" %>

    <div class="main-wrap">
        <%@ include file="/WEB-INF/views/common/header.jsp" %>

        <main class="content">
            <div class="page active" id="pg-transport">
                <div class="page-title-row">
                    <h2>운송</h2>
                </div>
                <%@ include file="/WEB-INF/views/owner/transport/fragments/transportTabs.jsp" %>
                <div id="trans-import-trans">
                    <div class="filter-bar" style="margin-bottom:20px; border-left:3px solid #565e74;">
                        <div class="search-wrap" style="flex:1">
                            <span class="material-symbols-outlined">search</span>
                            <input placeholder="의뢰번호 · 운송업체 · B/L 검색" style="width:100%"/>
                        </div>
                        <select style="min-width:120px">
                            <option>전체 상태</option>
                            <option>운송중</option>
                            <option>준비중</option>
                        </select>
                        <input style="padding:6px 8px;border:1px solid #e2e8f0;font-size:12px" type="date"/>
                        <span style="font-size:11px;color:#94a3b8">~</span>
                        <input style="padding:6px 8px;border:1px solid #e2e8f0;font-size:12px" type="date"/>
                        <button class="btn btn-dark">조회</button>
                    </div>
                    <div style="font-size:12px;font-weight:700;color:#475569;margin-bottom:10px">수입 운송 진행 현황</div>
                    <div class="card-section">
                        <table class="data-table">
                            <thead>
                            <tr>
                                <th>의뢰번호</th>
                                <th>운송 구간</th>
                                <th>운송업체</th>
                                <th>B/L 상태</th>
                                <th>D/O 수령여부</th>
                                <th>도착 예정일(ETA)</th>
                                <th>상태</th>
                                <th></th>
                            </tr>
                            </thead>
                            <tbody>
                            <tr>
                                <td><span
                                        style="background:#dcfce7;color:#15803d;font-size:10px;font-weight:700;padding:2px 6px;margin-right:6px">수입</span><a
                                        href="${pageContext.request.contextPath}/owner/transport/import/detail.do/IMP-004"
                                        style="cursor:pointer;text-decoration:underline;color:#15803d;font-size:13px;font-weight:800">IMP-004</a>
                                </td>
                                <td style="font-weight:600"><span class="material-symbols-outlined"
                                                                  style="font-size:14px;vertical-align:middle;margin-right:4px;color:#94a3b8">directions_boat</span>상하이
                                    <span style="color:#cbd5e1">→</span> 인천
                                </td>
                                <td>글로벌로지스</td>
                                <td><span class="doc-status ok">수령완료</span></td>
                                <td><span class="badge badge-ok">수령</span></td>
                                <td style="font-weight:700;color:#dc2626">04/22 (D-1)</td>
                                <td><span class="badge badge-ok">운송중</span></td>
                                <td><a class="mini mini-view"
                                       href="${pageContext.request.contextPath}/owner/transport/import/detail.do/IMP-004"
                                       style="text-decoration:none">상세보기</a></td>
                            </tr>
                            <tr>
                                <td><span
                                        style="background:#dcfce7;color:#15803d;font-size:10px;font-weight:700;padding:2px 6px;margin-right:6px">수입</span><a
                                        href="${pageContext.request.contextPath}/owner/transport/import/detail.do/IMP-007"
                                        style="cursor:pointer;text-decoration:underline;color:#15803d;font-size:13px;font-weight:800">IMP-007</a>
                                </td>
                                <td style="font-weight:600"><span class="material-symbols-outlined"
                                                                  style="font-size:14px;vertical-align:middle;margin-right:4px;color:#94a3b8">directions_boat</span>도쿄
                                    <span style="color:#cbd5e1">→</span> 부산
                                </td>
                                <td>대한포워딩</td>
                                <td><span class="doc-status wait">검토필요</span></td>
                                <td><span class="badge badge-wait">미수령</span></td>
                                <td>05/03</td>
                                <td><span class="badge badge-wait">준비중</span></td>
                                <td><a class="mini mini-view"
                                       href="${pageContext.request.contextPath}/owner/transport/import/detail.do/IMP-007"
                                       style="text-decoration:none">상세보기</a></td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>

        <%@ include file="/WEB-INF/views/common/ownerModals.jsp" %>
        <%@ include file="/WEB-INF/views/common/footer.jsp" %>
    </div>
</div>

<%@ include file="/WEB-INF/views/common/ownerScripts.jsp" %>

</body>
</html>
