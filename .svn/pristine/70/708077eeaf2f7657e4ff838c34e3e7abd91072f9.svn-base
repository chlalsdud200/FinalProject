/* ownerPay.css */

.pay-result-wrap {
    max-width: 780px;
    margin: 0 auto;
}

.pay-result-body {
    padding: 42px 38px;
    text-align: center;
}

.pay-result-icon {
    width: 72px;
    height: 72px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.pay-result-icon .material-symbols-outlined {
    font-size: 42px;
}

.pay-result-icon.success {
    background: #d1fae5;
    color: #065f46;
}

.pay-result-icon.cancel {
    background: #fef3c7;
    color: #92400e;
}

.pay-result-icon.fail {
    background: #fecaca;
    color: #991b1b;
}

.pay-result-title {
    font-size: 24px;
    font-weight: 900;
    color: #0f172a;
    margin-bottom: 8px;
}

.pay-result-desc {
    font-size: 13px;
    color: #64748b;
    margin-bottom: 28px;
}

.pay-info-box {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    text-align: left;
    padding: 22px 24px;
    margin-bottom: 28px;
}

.pay-info-grid {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 12px 16px;
    font-size: 13px;
}

.pay-info-label {
    font-weight: 800;
    color: #64748b;
}

.pay-info-value {
    font-weight: 700;
    color: #203444;
}

.pay-info-value.strong {
    font-weight: 900;
    color: #0f172a;
}

.pay-info-value.success {
    font-weight: 800;
    color: #1d6b4f;
}

.pay-info-value.cancel {
    font-weight: 800;
    color: #92400e;
}

.pay-info-value.fail {
    font-weight: 800;
    color: #991b1b;
}

.pay-info-value.break {
    word-break: break-all;
}

.pay-action-row {
    display: flex;
    justify-content: center;
    gap: 8px;
}

.pay-action-row a {
    text-decoration: none;
}
/* 인쇄 시 결제 결과 영역만 출력 */
@media print {
    body {
        background: #fff !important;
    }

    .aside,
    .topbar,
    header,
    footer,
    .breadcrumb,
    .pay-action-row {
        display: none !important;
    }

    .app,
    .main-wrap,
    .content {
        display: block !important;
        width: 100% !important;
        min-height: auto !important;
        margin: 0 !important;
        padding: 0 !important;
        background: #fff !important;
    }

    .pay-result-wrap {
        max-width: 720px !important;
        width: 100% !important;
        margin: 0 auto !important;
        border: 1px solid #d9e2ef !important;
        box-shadow: none !important;
        page-break-inside: avoid;
    }

    .pay-result-wrap .card-header {
        background: #fff !important;
        color: #111827 !important;
        border-bottom: 1px solid #d9e2ef !important;
    }

    .pay-result-wrap .card-header h3 {
        color: #111827 !important;
    }

    .pay-result-body {
        padding: 36px 32px !important;
    }

    .pay-info-box {
        background: #fff !important;
        border: 1px solid #d9e2ef !important;
    }

    .pay-result-icon {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }

    @page {
        size: A4 portrait;
        margin: 18mm;
    }
}
