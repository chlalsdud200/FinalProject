@charset "UTF-8";

/* 신고접수목록 전용 CSS */
.report-receipt-main .page-inner {
  padding: 24px 28px;
}

/* 상단 */
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 10px;
  color: #64748b;
  font-size: 11px;
}

.breadcrumb strong {
  padding: 2px 8px;
  background: #1e3054;
  color: #fff;
  font-size: 10px;
}

.page-title {
  margin-bottom: 10px;
  color: #0f172a;
  font-size: 20px;
  font-weight: 900;
}

.page-banner {
  margin-bottom: 20px;
  padding: 14px 20px;
  background: #1e3054;
  color: #fff;
}

.page-banner h3 {
  margin: 0 0 3px;
  font-size: 14px;
  font-weight: 900;
}

.page-banner p {
  margin: 0;
  color: rgba(255, 255, 255, .7);
  font-size: 11px;
}

/* 검색조건 */
.search-panel {
  margin-bottom: 18px;
  background: #fff;
  border: 1px solid #dde4ef;
}

.search-title {
  position: relative;
  margin: 0;
  padding: 8px 16px 8px 20px;
  border-bottom: 1px solid #dde4ef;
  color: #111827;
  font-size: 13px;
  font-weight: 900;
}

.search-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 4px;
  height: 100%;
  background: #536178;
}

.search-row {
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  gap: 6px 12px;
  padding: 10px 16px;
  background: #fff;
  overflow-x: auto;
}

/* 검색조건 그리드 레이아웃 */
.search-grid {
  display: grid;
  grid-template-columns: 1px 1fr 1px 1fr 1px 1fr auto;
  grid-template-rows: auto auto;
  align-items: center;
  column-gap: 90px;
  row-gap: 5px;
  padding: 0 20px;
  margin: 5px;
  background: #fff;
}

.sg-row {
  display: contents;
}

.sg-cell {
  display: contents;
}

.sg-label {
  display: flex;
  align-items: center;
  height: 40px;
  color: #374151;
  font-size: 12px;
  font-weight: 700;
  white-space: nowrap;
}

.sg-input,
.sg-select {
  height: 33px;
  width: 100%;
  box-sizing: border-box;
}

.sg-cell-auto {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  grid-column: 7;
  grid-row: 1 / 3;
  padding-left: 10px;
}

.sg-btn-group {
  display: flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
}

.date-inline {
  display: flex;
  align-items: center;
  gap: 6px;
  min-width: 0;
}

.search-label {
  width: 72px;
  flex: 0 0 72px;
  height: 33px;
  display: flex;
  align-items: center;
  color: #374151;
  font-size: 12px;
  font-weight: 700;
  white-space: nowrap;
}

.search-field {
  display: flex;
  align-items: center;
  gap: 8px;
}

.date-group {
  gap: 8px;
}

.search-btn-group {
  margin-left: auto;
}

.form-input,
.form-select {
  height: 33px;
  padding: 0 10px;
  border: 1px solid #d1d9e6;
  background: #fff;
  color: #0f172a;
  font-size: 12px;
  outline: none;
  box-shadow: none;
  box-sizing: border-box;
}

.form-input:focus,
.form-select:focus {
  border-color: #3b5bdb;
}

.input-md, .select-sm { width: 100%; }
.date-input { width: 112px; flex: 0 0 112px; }
.date-sep { color: #94a3b8; }

.radio-group {
  display: flex;
  align-items: center;
  gap: 16px;
  height: 40px;
}

.radio-group label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin: 0;
  color: #111827;
  font-size: 12px;
  font-weight: 600;
  white-space: nowrap;
}

.radio-group input[type='radio'] {
  width: 13px;
  height: 13px;
  margin: 0;
}

.date-inline {
  display: flex;
  align-items: center;
  gap: 6px;
  min-width: 0;
}

.sg-date-cell {
  grid-template-columns: 86px minmax(0, 1fr);
}

@media (max-width: 1280px) {
  .sg-row {
    grid-template-columns: minmax(320px, 1fr) minmax(320px, 1fr) 112px;
  }

  .sg-cell.sg-cell-auto {
    grid-column: 3;
  }
}

@media (max-width: 900px) {
  .sg-row {
    grid-template-columns: 1fr;
  }

  .sg-cell.sg-cell-auto {
    grid-column: 1;
    justify-content: flex-start;
  }
}

/* 버튼 */
.btn-primary,
.btn-secondary,
.btn-danger,
.btn-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
  cursor: pointer;
  white-space: nowrap;
}

.btn-primary,
.btn-secondary,
.btn-danger {
  height: 33px;
  padding: 0 14px;
  border: 1px solid transparent;
  font-size: 12px;
  font-weight: 700;
}

.btn-primary {
  background: #1e3054;
  border-color: #1e3054;
  color: #fff;
}

.btn-primary:hover {
  background: #152540;
}

.btn-secondary {
  background: #fff;
  border-color: #cbd8e8;
  color: #334155;
}

.btn-secondary:hover {
  background: #f1f5f9;
}

.btn-danger {
  background: #fef2f2;
  border-color: #fca5a5;
  color: #991b1b;
}

.btn-danger:hover {
  background: #fee2e2;
}

.btn-quick {
  height: 33px;
  padding: 0 10px;
  font-size: 11px;
}

.btn-action {
  min-width: 58px;
  height: 28px;
  padding: 0 10px;
  border: 1px solid transparent;
  font-size: 11px;
  font-weight: 700;
}

.btn-accept {
  background: #1e3054;
  border-color: #1e3054;
  color: #fff;
}

.btn-reject {
  background: #fff5f5;
  border-color: #f3b4b4;
  color: #991b1b;
}

.btn-detail {
  background: #fff;
  border-color: #cbd8e8;
  color: #1e3054;
}

.btn-detail:hover {
  background: #ecf4ff;
}

.btn-reject-reason {
  background: #fff;
  border-color: #f3b4b4;
  color: #b91c1c;
}

.btn-reject-reason:hover {
  background: #fef2f2;
}

/* 결과/목록 */
.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.result-count {
  color: #1e293b;
  font-size: 15px;
  font-weight: 700;
}

.result-count span {
  margin-left: 6px;
  color: #2563eb;
}

.table-card {
  overflow-x: auto;
  background: #fff;
  border: 1px solid #d9eafc;
}

.receipt-table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
}

.receipt-table th {
  padding: 10px 14px;
  background: #ecf4ff;
  border-bottom: 1px solid #d9eafc;
  color: #4d6172;
  font-size: 10px;
  font-weight: 800;
  text-align: center;
  white-space: nowrap;
}

.receipt-table td {
  padding: 11px 14px;
  border-bottom: 1px solid #d9eafc;
  color: #203444;
  font-size: 12px;
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
}

.receipt-row {
  cursor: pointer;
}

.receipt-table tbody tr.receipt-row:hover td {
  background: #f8fbff;
}

.receipt-table strong {
  color: #0f2537;
  font-weight: 700;
}

.col-check {
  width: 40px;
}

.row-check {
  cursor: pointer;
}

.row-check:disabled {
  cursor: not-allowed;
  opacity: .45;
}

.action-buttons {
  display: flex;
  justify-content: center;
  gap: 5px;
}

.status-text {
  color: #203444;
  font-weight: 900;
}

.status-text.wait {
  color: #203444;
}

.status-text.reject {
  color: #b91c1c;
}

.empty-text {
  padding: 28px !important;
  color: #94a3b8 !important;
  text-align: center !important;
}

/* 반려 처리 행 */
.receipt-table tbody tr.row-locked td {
  background: #f1f3f6 !important;
  color: #7a8494 !important;
}

.receipt-table tbody tr.row-locked:hover td {
  background: #e9edf3 !important;
}

.receipt-table tbody tr.row-locked strong {
  color: #64748b !important;
}

/* 모달 */
.modal {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 2000;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, .5);
}

.modal.open {
  display: flex;
}

.modal-box {
  width: 460px;
  max-width: 92vw;
  background: #fff;
  border: 1px solid #dde4ef;
}

.modal-header,
.modal-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 1px solid #e2e8f0;
}

.modal-footer {
  justify-content: flex-end;
  gap: 8px;
  border-top: 1px solid #e2e8f0;
  border-bottom: 0;
}

.modal-close {
  border: 0;
  background: none;
  color: #64748b;
  font-size: 22px;
  cursor: pointer;
}

.modal-body {
  padding: 16px;
}

.modal-label {
  display: block;
  margin-bottom: 6px;
  color: #334155;
  font-size: 12px;
  font-weight: 700;
}

.modal-textarea {
  width: 100%;
  min-height: 100px;
  padding: 10px;
  border: 1px solid #d1d9e6;
  resize: vertical;
  font-size: 12px;
}

#rejectReasonModal .form-input,
#rejectReasonModal .modal-textarea {
  width: 100%;
}