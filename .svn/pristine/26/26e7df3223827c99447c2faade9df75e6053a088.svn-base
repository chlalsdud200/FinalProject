<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>보세반출 처리 - TACS</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet"/>

    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/base.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/sidebar.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/topbar.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/warehouse/outbound.css">
</head>

<body>

<input type="hidden" id="csrfHeaderName" value="${_csrf.headerName}">
<input type="hidden" id="csrfToken" value="${_csrf.token}">

<div class="app" id="app">
    <jsp:include page="/WEB-INF/views/warehouse/common/sidebar.jsp" />

    <div class="main-wrap">
        <jsp:include page="/WEB-INF/views/warehouse/common/header.jsp" />

        <div class="content">
            <div class="page-title-row">
                <h2>보세반출 처리</h2>
            </div>
            <!-- =========================================================
                 2. 반출처리 관리
                 ========================================================= -->
             <div id="outbound-release" class="outbound-panel active">

                <!-- 검색 조건 -->
                <div class="filter-bar outbound-filter">
                    <div class="form-item">
                        <label>반출요청일</label>
                        <div class="date-range">
                            <input type="date" id="outboundStartDate">
							<span>~</span>
							<input type="date" id="outboundEndDate">
                        </div>
                    </div>

                    <div class="filter-sep"></div>

                    <div class="form-item">
                        <label>유형</label>
                        <select id="outboundType">
						    <option value="">전체</option>
						    <option value="IMP">수입</option>
						    <option value="EXP">수출</option>
						</select>
                    </div>

                    <div class="filter-sep"></div>

                    <div class="form-item">
                        <label>반출 상태</label>
                        <select id="outboundStatus">
						    <option value="">전체</option>
						    <option value="REL_WAIT">반출대기</option>
						    <option value="REL_FIX">보완요청</option>
						    <option value="REL_SENT">보완제출완료</option>
						    <option value="REL_DONE">반출완료</option>
						    <option value="REJECT">반려</option>
						</select>
                    </div>

                    <div class="filter-sep"></div>

                    <div class="search-wrap outbound-search">
                        <span class="material-symbols-outlined">search</span>
                       <input type="text"
						      id="outboundKeyword"
						      placeholder="반출요청번호, 화주명, 품명, 보관위치 검색">
                    </div>

                    <button type="button" id="outboundSearchBtn" class="btn btn-primary outbound-search-btn">
                        <span class="material-symbols-outlined">search</span>
                        조회
                    </button>
                </div>

                <!-- 목록 -->
                <div class="card-section">
                    <div class="card-header">
                        <h3>반출처리 목록</h3>
                    </div>

                    <table class="data-table outbound-table">
                         <thead>
						    <tr>
						   		<th class="col-no">NO</th>
						        <th>반출요청번호</th>
						        <th>반출요청일시</th>
						        <th>유형</th>
						        <th>요청업체</th>
						        <th>화주명</th>
						        <th>품명</th>
						        <th>보관위치</th>
								<th>D/O 및 신고필증 상태</th>
								<th>반출상태</th>
								<th>관리</th>
						    </tr>
						</thead>
                        <tbody id="outboundTableBody">
						    <c:choose>
						        <c:when test="${empty outboundProcessList}">
						            <tr>
						                <td colspan="11" class="outbound-empty">
						                    조회된 반출요청이 없습니다.
						                </td>
						            </tr>
						        </c:when>
						
						        <c:otherwise>
						            <c:forEach var="release" items="${outboundProcessList}" varStatus="status">
									    <tr>
									        <td class="td-no">${status.index + 1}</td>
									
									        <!-- 반출요청번호 -->
									        <td>${release.crrNo}</td>
										
										    <!-- 반출요청일시 -->
										    <td>${release.crrCrDt}</td>
										
										    <!-- 수입/수출 구분 -->
											<td>
											    <c:choose>
											        <c:when test="${release.diTrdeSeCd eq 'IMP'}">
											            <span class="outbound-type-badge import">${release.diTrdeSeNm}</span>
											        </c:when>
											        <c:when test="${release.diTrdeSeCd eq 'EXP'}">
											            <span class="outbound-type-badge export">${release.diTrdeSeNm}</span>
											        </c:when>
											        <c:otherwise>
											            <span class="outbound-type-badge">-</span>
											        </c:otherwise>
											    </c:choose>
											</td>
										
										    <!-- 요청업체: 반출요청을 보낸 운송업체 -->
										    <td>${release.tmCpNm}</td>
										
										    <!-- 화주명 -->
										    <td>${release.crrNm}</td>
										
										    <!-- 품명: XML에서 대표품명 외 n건 형태로 가공한 값 -->
										    <td>
										        <c:choose>
										            <c:when test="${not empty release.goodsSummary}">
										                ${release.goodsSummary}
										            </c:when>
										            <c:otherwise>
										                -
										            </c:otherwise>
										        </c:choose>
										    </td>
										
										    <!-- 실제 보관위치 -->
										    <td>
										        <c:choose>
										            <c:when test="${not empty release.locationNm}">
										                ${release.locationNm}
										            </c:when>
										            <c:when test="${not empty release.locationCode}">
										                ${release.locationCode}
										            </c:when>
										            <c:otherwise>
										                -
										            </c:otherwise>
										        </c:choose>
										    </td>
										

											<!-- D/O 및 신고필증 상태 -->
											<td>
											    <c:choose>
											        <c:when test="${release.doStatusNm eq '수령완료' and release.declarationStatusNm eq '수령완료'}">
											            <span class="outbound-badge success">수령완료</span>
											        </c:when>
											
											        <c:when test="${release.doStatusNm eq '수령완료' or release.declarationStatusNm eq '수령완료'}">
											            <span class="outbound-badge progress">일부수령</span>
											        </c:when>
											
											        <c:otherwise>
											            <span class="outbound-badge wait">수령전</span>
											        </c:otherwise>
											    </c:choose>
											</td>
										
										    <!-- 반출상태 -->
											<td>
											    <c:choose>
											        <c:when test="${release.crStatusCd eq 'REL_WAIT'}">
											            <span class="outbound-badge release-wait">반출대기</span>
											        </c:when>
											
											        <c:when test="${release.crStatusCd eq 'REL_FIX'}">
											            <span class="outbound-badge release-fix">보완요청</span>
											        </c:when>
											
											        <c:when test="${release.crStatusCd eq 'REL_SENT'}">
											            <span class="outbound-badge release-sent">보완제출완료</span>
											        </c:when>
											
											        <c:when test="${release.crStatusCd eq 'REL_DONE'}">
											            <span class="outbound-badge release-done">반출완료</span>
											        </c:when>
											
											        <c:when test="${release.crStatusCd eq 'REJECT'}">
											            <span class="outbound-badge release-reject">반려</span>
											        </c:when>
											
											        <c:otherwise>
											            <span class="outbound-badge release-default">${release.crStatusNm}</span>
											        </c:otherwise>
											    </c:choose>
											</td>
										
										    <!-- 관리 -->
										    <td>
										        <button type="button"
										                class="mini mini-primary outbound-process-detail-btn"
										                data-crr-no="${release.crrNo}"

										
										                data-crr-cr-dt="${release.crrCrDt}"
										                data-crr-tre-id="${release.crrTreId}"
										                data-crr-owr-id="${release.crrOwrId}"
										                data-crr-nm="${release.crrNm}"
										                data-crr-cert-no="${release.crrCertNo}"
										                data-crr-req-cn="${release.crrReqCn}"
										
										                data-cr-status-cd="${release.crStatusCd}"
										                data-cr-status-nm="${release.crStatusNm}"
										                data-di-trde-se-cd="${release.diTrdeSeCd}"
										                data-di-trde-se-nm="${release.diTrdeSeNm}"
										                data-cr-dt="${release.crDt}"
										
										                data-tm-id="${release.tmId}"
										                data-tm-cp-nm="${release.tmCpNm}"
										                data-tm-name="${release.tmName}"
										                data-tm-cp-telno="${release.tmCpTelno}"
										
										                data-cr-wh-no="${release.crWhNo}"
										                data-wh-nm="${release.whNm}"
										                data-crr-wz-no="${release.crrWzNo}"
										                data-wz-nm="${release.wzNm}"
										                data-location-code="${release.locationCode}"
										                data-location-nm="${release.locationNm}"
										
										                data-goods-name="${release.goodsName}"
										                data-item-cnt="${release.itemCnt}"
										                data-goods-summary="${release.goodsSummary}"
										                data-total-qty="${release.totalQty}"
										                data-total-weight="${release.totalWeight}"
										                data-origin-summary="${release.originSummary}"
										
										                data-di-tfg-no="${release.diTfgNo}"
										                data-file-cnt="${release.fileCnt}"
										                data-doc-status-nm="${release.docStatusNm}"
										                data-do-status-nm="${release.doStatusNm}"
														data-declaration-status-nm="${release.declarationStatusNm}">
										            상세보기
										        </button>
										    </td>
										</tr>
						            </c:forEach>
						        </c:otherwise>
						    </c:choose>
						</tbody>
                    </table>
                    
                    <div id="outboundPagination" class="outbound-pagination"></div>
                </div>
            </div>

            <!-- =========================================================
                 파일보기 모달
                 =========================================================
                 현재는 UI 뼈대만 둔다.

                 나중에 [파일보기] 클릭 시:
                 1. 버튼의 data-tfg-no 값에서 DI_TFG_NO를 가져온다.
                 2. /warehouse/outbound/files.do?tfgNo=...
                    같은 API로 파일 목록을 조회한다.
                 3. 이 모달 안에 D/O 파일, 신고필증 파일을 각각 표시한다.
                 4. 사용자가 원하는 파일만 개별 다운로드한다.
            -->
            <div id="outboundFileModal" class="outbound-modal">
                <div class="outbound-modal-box">
                    <div class="outbound-modal-header">
                        <h3>첨부파일 목록</h3>
                        <button type="button" class="outbound-modal-close">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>

                    <div class="outbound-modal-body">
                        <div class="outbound-file-empty">
                            조회된 첨부파일이 없습니다.
                        </div>
                    </div>
                </div>
            </div>
                        <!-- =========================================================
                 반출처리 상세보기 모달
                 ========================================================= -->
            <!-- =========================================================
     반출처리 상세보기 모달
     - 보세입고 상세/승인 모달과 동일한 느낌으로 맞춘다.
     - JS에서 id 기준으로 값을 세팅하므로 input id는 유지한다.
     ========================================================= -->
			<!-- =========================================================
     반출처리 상세보기 모달
     - 반출요청 기본정보 + 운송업체 + 창고/보관위치 + 물품 + 첨부서류 확인
     - crReleaseNo, diTfgNo는 화면에는 보여주지 않고 hidden으로만 보관
     ========================================================= -->
		<div id="outboundProcessModal" class="outbound-modal">
		    <div class="outbound-modal-box"
		         style="width: 920px; max-height: 92vh; display: flex; flex-direction: column; border: 2px solid #0f172a; background: #fff;">
		
		        <!-- 서버 처리용 hidden 값 -->
		        <input type="hidden" id="process-di-tfg-no">
		        <input type="hidden" id="process-di-trde-se-cd">
		        <input type="hidden" id="process-cr-status-cd">
		
		        <!-- 헤더 -->
		        <div class="modal-head" style="background: #0f172a; padding: 18px 24px;">
		            <div>
		                <div class="modal-title" style="color: #fff; font-size: 16px; font-weight: 700;">
		                    반출요청 상세 및 처리
		                </div>
		                <div class="modal-subtitle" style="color: rgba(255,255,255,0.75); font-size: 12px; margin-top: 4px;">
		                    BONDED CARGO RELEASE APPROVAL
		                </div>
		            </div>
		
		            <button type="button" class="modal-close-btn outbound-process-modal-close">
		                <span class="material-symbols-outlined">close</span>
		            </button>
		        </div>
		
		        <!-- 본문 -->
		        <div class="outbound-modal-body"
		             style="padding: 24px; overflow-y: auto; background: #fff; flex: 1;">
		
		            <!-- 1. 반출요청 기본 정보 -->
		            <h4 style="font-size: 13px; font-weight: 700; border-left: 4px solid #0f172a; padding-left: 8px; margin: 0 0 12px 0;">
		                1. 반출요청 기본 정보
		            </h4>
		
		            <div style="border: 1px solid #111827; margin-bottom: 20px;">
		                <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
		                    <tr>
		                        <th style="width: 130px; background: #f8fafc; border: 1px solid #e2e8f0; padding: 10px; text-align: left; font-size: 13px;">
		                            반출요청번호
		                        </th>
		                        <td style="border: 1px solid #e2e8f0; padding: 8px;">
		                            <input id="process-crr-no" readonly
		                                   style="width: 100%; height: 36px; border: 1px solid #cbd5e1; padding: 0 10px; border-radius: 4px; background: #fff;">
		                        </td>
		
		                        <th style="width: 130px; background: #f8fafc; border: 1px solid #e2e8f0; padding: 10px; text-align: left; font-size: 13px;">
		                            반출요청일시
		                        </th>
		                        <td style="border: 1px solid #e2e8f0; padding: 8px;">
		                            <input id="process-crr-cr-dt" readonly
		                                   style="width: 100%; height: 36px; border: 1px solid #cbd5e1; padding: 0 10px; border-radius: 4px; background: #fff;">
		                        </td>
		                    </tr>
		
		                    <tr>
		                        <th style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 10px; text-align: left; font-size: 13px;">
		                            화주명
		                        </th>
		                        <td style="border: 1px solid #e2e8f0; padding: 8px;">
		                            <input id="process-crr-nm" readonly
		                                   style="width: 100%; height: 36px; border: 1px solid #cbd5e1; padding: 0 10px; border-radius: 4px; background: #fff;">
		                        </td>
		
		                        <th style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 10px; text-align: left; font-size: 13px;">
		                            D/O 번호
		                        </th>
		                        <td style="border: 1px solid #e2e8f0; padding: 8px;">
		                            <input id="process-crr-cert-no" readonly
		                                   style="width: 100%; height: 36px; border: 1px solid #cbd5e1; padding: 0 10px; border-radius: 4px; background: #fff;">
		                        </td>
		                    </tr>
		
		                    <tr>
		                        <th style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 10px; text-align: left; font-size: 13px;">
		                            수출입구분
		                        </th>
		                        <td style="border: 1px solid #e2e8f0; padding: 8px;">
		                            <input id="process-di-trde-se-nm" readonly
		                                   style="width: 100%; height: 36px; border: 1px solid #cbd5e1; padding: 0 10px; border-radius: 4px; background: #fff;">
		                        </td>
		
		                        <th style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 10px; text-align: left; font-size: 13px;">
		                            반출상태
		                        </th>
		                        <td style="border: 1px solid #e2e8f0; padding: 8px;">
		                            <input id="process-cr-status-nm" readonly
		                                   style="width: 100%; height: 36px; border: 1px solid #cbd5e1; padding: 0 10px; border-radius: 4px; background: #fff;">
		                        </td>
		                    </tr>
		                </table>
		            </div>
		
		            <!-- 2. 운송업체 정보 -->
		            <h4 style="font-size: 13px; font-weight: 700; border-left: 4px solid #0f172a; padding-left: 8px; margin: 0 0 12px 0;">
		                2. 운송업체 정보
		            </h4>
		
		            <div style="border: 1px solid #111827; margin-bottom: 20px;">
		                <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
		                    <tr>
		                        <th style="width: 130px; background: #f8fafc; border: 1px solid #e2e8f0; padding: 10px; text-align: left; font-size: 13px;">
		                            요청업체
		                        </th>
		                        <td style="border: 1px solid #e2e8f0; padding: 8px;">
		                            <input id="process-tm-cp-nm" readonly
		                                   style="width: 100%; height: 36px; border: 1px solid #cbd5e1; padding: 0 10px; border-radius: 4px; background: #fff;">
		                        </td>
		
		                        <th style="width: 130px; background: #f8fafc; border: 1px solid #e2e8f0; padding: 10px; text-align: left; font-size: 13px;">
		                            운송담당자
		                        </th>
		                        <td style="border: 1px solid #e2e8f0; padding: 8px;">
		                            <input id="process-tm-name" readonly
		                                   style="width: 100%; height: 36px; border: 1px solid #cbd5e1; padding: 0 10px; border-radius: 4px; background: #fff;">
		                        </td>
		                    </tr>
		
		                    <tr>
		                        <th style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 10px; text-align: left; font-size: 13px;">
		                            연락처
		                        </th>
		                        <td colspan="3" style="border: 1px solid #e2e8f0; padding: 8px;">
		                            <input id="process-tm-cp-telno" readonly
		                                   style="width: 100%; height: 36px; border: 1px solid #cbd5e1; padding: 0 10px; border-radius: 4px; background: #fff;">
		                        </td>
		                    </tr>
		                </table>
		            </div>
		
		            <!-- 3. 물품 내역 -->
					<h4 style="font-size: 13px; font-weight: 700; border-left: 4px solid #0f172a; padding-left: 8px; margin: 0 0 12px 0;">
					    3. 물품 내역
					</h4>
					
					<!-- 담당 창고 -->
					<div style="border: 1px solid #111827; padding: 14px; margin-bottom: 10px;">
					    <label style="display: block; font-size: 12px; font-weight: 700; margin-bottom: 8px;">
					        담당 창고
					    </label>
					    <input id="process-wh-nm"
					           readonly
					           style="width: 100%; height: 36px; border: 1px solid #cbd5e1; padding: 0 10px; border-radius: 4px; background: #fff;">
					</div>
					
					<!-- 전달대상 / 품명 -->
					<div style="border: 1px solid #111827; padding: 14px; margin-bottom: 20px;">
					    <label style="display: block; font-size: 12px; font-weight: 700; margin-bottom: 8px;">
					        전달대상 / 품명
					    </label>
					    <input id="process-goods-summary"
					           readonly
					           style="width: 100%; height: 36px; border: 1px solid #cbd5e1; padding: 0 10px; border-radius: 4px; background: #fff;">
					</div>
					
					<!-- 물품 상세 테이블 -->
					<div style="border: 1px solid #111827; margin-bottom: 20px;">
					    <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
					        <thead>
					            <tr style="background: #f8fafc;">
					                <th style="border-bottom: 1px solid #e2e8f0; padding: 12px; text-align: left; font-size: 13px;">
					                    물품명
					                </th>
					                <th style="width: 90px; border-bottom: 1px solid #e2e8f0; padding: 12px; text-align: center; font-size: 13px;">
					                    수량
					                </th>
					                <th style="width: 90px; border-bottom: 1px solid #e2e8f0; padding: 12px; text-align: center; font-size: 13px;">
					                    중량
					                </th>
					                <th style="width: 90px; border-bottom: 1px solid #e2e8f0; padding: 12px; text-align: center; font-size: 13px;">
					                    원산지
					                </th>
					                <th style="width: 150px; border-bottom: 1px solid #e2e8f0; padding: 12px; text-align: center; font-size: 13px;">
					                    창고구역
					                </th>
					                <th style="width: 170px; border-bottom: 1px solid #e2e8f0; padding: 12px; text-align: center; font-size: 13px;">
					                    창고위치
					                </th>
					            </tr>
					        </thead>
					
					        <tbody>
					            <tr>
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0;">
					                    <input id="process-goods-name"
					                           readonly
					                           style="width: 100%; height: 34px; border: none; background: transparent;">
					                </td>
					
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0; text-align: center;">
					                    <input id="process-total-qty"
					                           readonly
					                           style="width: 100%; height: 34px; border: none; background: transparent; text-align: center;">
					                </td>
					
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0; text-align: center;">
					                    <input id="process-total-weight"
					                           readonly
					                           style="width: 100%; height: 34px; border: none; background: transparent; text-align: center;">
					                </td>
					
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0; text-align: center;">
					                    <input id="process-origin-summary"
					                           readonly
					                           style="width: 100%; height: 34px; border: none; background: transparent; text-align: center;">
					                </td>
					
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0;">
					                    <input id="process-wz-nm"
					                           readonly
					                           style="width: 100%; height: 34px; border: 1px solid #cbd5e1; border-radius: 4px; padding: 0 8px; background: #fff;">
					                </td>
					
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0;">
					                    <input id="process-location-nm"
					                           readonly
					                           style="width: 100%; height: 34px; border: 1px solid #cbd5e1; border-radius: 4px; padding: 0 8px; background: #fff;">
					                </td>
					            </tr>
					        </tbody>
					    </table>
					</div>
					
					<!-- 서버/디버깅용 hidden 값 -->
					<input type="hidden" id="process-cr-wh-no">
					<input type="hidden" id="process-crr-wz-no">
					<input type="hidden" id="process-location-code">
					<input type="hidden" id="process-item-cnt">
		
		            <!-- 5. 첨부서류 정보 -->
					<h4 style="font-size: 13px; font-weight: 700; border-left: 4px solid #0f172a; padding-left: 8px; margin: 0 0 12px 0;">
					    5. 첨부서류 정보
					</h4>
					
					<!--
					    D/O + 신고필증 첨부서류 영역
					
					    상세보기 모달이 열릴 때 outbound.js에서
					    /warehouse/outbound/files.do?tfgNo=파일그룹번호 API를 호출해서
					    아래 tbody 안에 파일 목록을 렌더링한다.
					
					    기본은 수령전 상태로 보여주고,
					    JS에서 실제 파일이 있으면 수령완료 / 파일명 / 파일보기 버튼으로 교체한다.
					-->
					<div style="border: 1px solid #111827; margin-bottom: 20px;">
					    <table style="width: 100%; border-collapse: collapse; table-layout: fixed;">
					        <thead>
							    <tr style="background: #f8fafc;">
							        <th style="border-bottom: 1px solid #e2e8f0; padding: 12px; text-align: left; font-size: 13px;">
							            파일명
							        </th>
							        <th style="width: 100px; border-bottom: 1px solid #e2e8f0; padding: 12px; text-align: center; font-size: 13px;">
							            수령상태
							        </th>
							        <th style="width: 110px; border-bottom: 1px solid #e2e8f0; padding: 12px; text-align: center; font-size: 13px;">
							            관리
							        </th>
							    </tr>
							</thead>
					
					        <tbody id="process-doc-file-list">
					            <tr>
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0;">
					                    D/O
					                </td>
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0; text-align: center;">
					                    <span class="outbound-badge wait">수령전</span>
					                </td>
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0;">
					                    -
					                </td>
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0; text-align: center;">
					                    -
					                </td>
					            </tr>
					
					            <tr>
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0;">
					                    신고필증
					                </td>
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0; text-align: center;">
					                    <span class="outbound-badge wait">수령전</span>
					                </td>
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0;">
					                    -
					                </td>
					                <td style="padding: 12px; border-top: 1px solid #e2e8f0; text-align: center;">
					                    -
					                </td>
					            </tr>
					        </tbody>
					    </table>
					</div>
		
		            <!-- 6. 반출요청 내용 -->
		            <h4 style="font-size: 13px; font-weight: 700; border-left: 4px solid #0f172a; padding-left: 8px; margin: 0 0 12px 0;">
		                6. 반출요청 내용
		            </h4>
		
		            <div style="border: 1px solid #111827; padding: 14px; margin-bottom: 20px;">
		                <label style="display: block; font-size: 12px; font-weight: 700; margin-bottom: 8px;">
		                    반출요청내용
		                </label>
		                <textarea id="process-crr-req-cn"
		                          readonly
		                          style="width: 100%; height: 100px; border: 1px solid #cbd5e1; padding: 10px; resize: none; border-radius: 4px; background: #fff;"></textarea>
		            </div>
		        </div>
		
		        <!-- 하단 버튼은 기존 그대로 유지 -->
		        <div class="modal-footer"
		             style="display: flex; justify-content: flex-end; gap: 10px; padding: 16px 24px; border-top: 1px solid #e2e8f0; background: #fff; flex-shrink: 0;">
		            <button type="button"
		                    onclick="closeOutboundProcessModal()"
		                    style="min-width: 64px; height: 36px; border: 1px solid #d1d5db; background: #f8fafc; color: #374151; border-radius: 4px;">
		                취소
		            </button>
		
		            <button type="button"
		                    id="outboundRejectBtn"
		                    style="min-width: 64px; height: 36px; border: none; background: #ef4444; color: #fff; border-radius: 4px;">
		                반려
		            </button>
		
		            <button type="button"
		                    id="outboundSuppBtn"
		                    style="min-width: 80px; height: 36px; border: none; background: #f59e0b; color: #fff; border-radius: 4px;">
		                보완요청
		            </button>
		
		            <button type="button"
		                    id="outboundApproveBtn"
		                    style="min-width: 80px; height: 36px; border: none; background: #0f172a; color: #fff; border-radius: 4px;">
		                반출승인
		            </button>
		        </div>
		    </div>
		</div>
			
			<!-- =========================================================
		     반출 보완요청 사유 입력 모달
		     - 반출요청 상세 모달에서 보완요청 버튼 클릭 시 열린다.
		     - 실제 저장은 JS에서 /warehouse/outbound/supplement.do로 POST 전송한다.
		     ========================================================= -->
			<div id="outboundSupplementModal" class="outbound-modal">
			    <div class="outbound-modal-box"
			         style="width: 520px; border: 2px solid #0f172a; background: #fff;">
			
			        <div class="modal-head" style="background: #0f172a; padding: 15px 24px;">
			            <div>
			                <div class="modal-title" style="color: #fff;">
			                    반출 보완요청 사유 입력
			                </div>
			                <div class="modal-subtitle" style="color: rgba(255, 255, 255, 0.7);">
			                    RELEASE SUPPLEMENT REQUEST
			                </div>
			            </div>
			
			            <button type="button"
			                    class="modal-close-btn outbound-supplement-modal-close">
			                <span class="material-symbols-outlined">close</span>
			            </button>
			        </div>
			
			        <div style="padding: 24px; background: #fff;">
			            <!-- 실제 서버로 보낼 반출요청번호 -->
			            <input type="hidden" id="supp-crr-no">
			
			            <!-- 실제 서버로 보낼 반출마스터번호 -->
			            <input type="hidden" id="supp-cr-release-no">
			
			            <div style="border: 1px solid #000; padding: 15px; margin-bottom: 16px;">
			                <label style="font-size: 11px; font-weight: 700;">반출요청번호</label>
			                <input id="supp-crr-no-view"
			                       type="text"
			                       readonly
			                       style="width: 100%; margin-top: 6px;">
			            </div>
			
			            <div style="border: 1px solid #000; padding: 15px;">
			                <label style="font-size: 11px; font-weight: 700;">보완요청 사유</label>
			                <textarea id="outbound-supp-reason"
			                          placeholder="운송업체가 확인할 반출 보완요청 사유를 입력하세요."
			                          style="width: 100%; height: 110px; margin-top: 6px; resize: none;"></textarea>
			            </div>
			        </div>
			
			        <div class="modal-footer"
			             style="gap: 10px; flex-shrink: 0; background: #fff; border-top: 1px solid #e2e8f0; display: flex; justify-content: flex-end; padding: 16px 24px;">
			            <button type="button" class="outbound-supplement-cancel-btn">
			                취소
			            </button>
			
			            <button type="button"
			                    id="outboundSupplementSubmitBtn"
			                    style="background: #f59e0b; color: #fff;">
			                보완요청 등록
			            </button>
			        </div>
			    </div>
			</div>
        </div>

        <jsp:include page="/WEB-INF/views/warehouse/common/footer.jsp" />
    </div>
</div>

<script src="${pageContext.request.contextPath}/resources/js/warehouse/common.js"></script>
<script src="${pageContext.request.contextPath}/resources/js/warehouse/navigation.js"></script>
<script src="${pageContext.request.contextPath}/resources/js/warehouse/outbound.js"></script>
</body>
</html>
