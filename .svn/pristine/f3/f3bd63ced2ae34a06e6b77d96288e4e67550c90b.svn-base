(function () {
    'use strict';

    if (window.__TACS_EXPORT_SPLIT_LOADER__) return;
    window.__TACS_EXPORT_SPLIT_LOADER__ = true;
    window.TRANSPORT_DEFER_PAGE_BOOT = true;
    window.__TACS_EXPORT_REQUEST_LEGACY_BLOCKED = true;
    window.__TACS_EXPORT_SINGLE_REQUEST_SCREEN = true;

    var VERSION = '20260601-export-request-single-renderer-final';
    var files = [
        'export-request.js',
        'export-bonded.js',
        'export-dispatch.js',
        'export-shipping-instruction.js',
        'export-bl.js',
        'export-manifest.js',
        'export-detail-tabs.js'
    ];

    function getBasePath() {
        var current = document.currentScript && document.currentScript.getAttribute('src');
  if (!current) return (window.contextPath || '') + '/resources/js/transport/pages/';
        return current.split('?')[0].replace(/[^\/]+$/, '');
    }

    function isAlreadyLoaded(file) {
        var scripts = document.getElementsByTagName('script');
        for (var i = 0; i < scripts.length; i++) {
            var src = scripts[i].getAttribute('src') || '';
            if (src.indexOf('/' + file) >= 0 || src.indexOf(file + '?') >= 0) return true;
        }
        return false;
    }

    function loadNext(index, basePath) {
        if (index >= files.length) {
            window.__TACS_EXPORT_SPLIT_READY = true;
            window.TRANSPORT_DEFER_PAGE_BOOT = false;
            document.dispatchEvent(new CustomEvent('tacs:export-split-ready'));
            return;
        }

        var file = files[index];
        if (isAlreadyLoaded(file)) {
            loadNext(index + 1, basePath);
            return;
        }

        var script = document.createElement('script');
        script.src = basePath + file + '?v=' + VERSION;
        script.async = false;
        script.onload = function () {
            loadNext(index + 1, basePath);
        };
        script.onerror = function () {
            console.error('export transport script load failed:', file);
            loadNext(index + 1, basePath);
        };
        document.head.appendChild(script);
    }

    loadNext(0, getBasePath());
})();
