package kr.or.tacs.broker.status.mapper;

import java.util.List;
import java.util.Map;
import kr.or.tacs.dto.PageDTO;
import org.apache.ibatis.annotations.Mapper;
import org.apache.ibatis.annotations.Param;
import java.math.BigDecimal;
@Mapper
public interface IStatusMapper {

	int selectImportDeclareCount(
	        @Param("brokerId") String brokerId,
	        @Param("pageDTO") PageDTO pageDTO
	);

	List<Map<String, Object>> selectImportDeclareList(
	        @Param("brokerId") String brokerId,
	        @Param("pageDTO") PageDTO pageDTO
	);

    Map<String, Object> selectImportDeclareDetail(
            @Param("idIrNo") String idIrNo,
            @Param("brokerId") String brokerId
    );

    List<Map<String, Object>> selectImportDeclareItemList(@Param("idIrNo") String idIrNo);

    List<Map<String, Object>> selectImportDeclareMdlspecList(@Param("idIrNo") String idIrNo);
    
    Map<String, Object> selectSupplementItem(
            @Param("idIrNo") String idIrNo,
            @Param("idiSn") Integer idiSn,
            @Param("brokerId") String brokerId
    );

    List<Map<String, Object>> selectSupplementMdlspecList(
            @Param("idIrNo") String idIrNo,
            @Param("idiSn") Integer idiSn
    );

    int updateSupplementItem(Map<String, Object> param);

    int deleteSupplementMdlspecByItem(
            @Param("idIrNo") String idIrNo,
            @Param("idiSn") Integer idiSn
    );

    int insertSupplementMdlspec(Map<String, Object> param);

    int updateItemStatusToSuppSub(
            @Param("idIrNo") String idIrNo,
            @Param("idiSn") Integer idiSn
    );
    
    List<Map<String, Object>> selectTaxList(
            @Param("brokerId") String brokerId,
            @Param("pageDTO") PageDTO pageDTO
    );

    List<Map<String, Object>> selectCertList(
            @Param("brokerId") String brokerId,
            @Param("pageDTO") PageDTO pageDTO
    );
    
    List<Map<String, Object>> selectTaxChargeList(@Param("brokerId") String brokerId);

    Map<String, Object> selectChargeSourceForCreate(
            @Param("irNo") String irNo,
            @Param("ctNo") Long ctNo,
            @Param("brokerId") String brokerId
    );

    Map<String, Object> selectBrokerFeePolicyByAmount(@Param("dclrAmt") BigDecimal dclrAmt);

    int countBrokerChargeByTax(
            @Param("irNo") String irNo,
            @Param("ctNo") Long ctNo
    );

    int insertBrokerCharge(Map<String, Object> param);
}