package kr.or.tacs.owner.trace.controller;

import kr.or.tacs.dto.owner.AisVslLatestDTO;
import kr.or.tacs.owner.trace.service.IAisVesselService;
import lombok.RequiredArgsConstructor;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.List;

@RestController
@RequestMapping("/api/tacs/ais")
@RequiredArgsConstructor
public class AisVesselApiController {

    @Autowired
    private IAisVesselService aisVesselService;

    /**
     * 한국 입항 대상 선박 목록 조회
     *
     * React 지도 화면에서 주기적으로 호출할 API.
     */
    @GetMapping("/vessels")
    public ResponseEntity<List<AisVslLatestDTO>> retrieveIncomingVesselList() {
        List<AisVslLatestDTO> vesselList = aisVesselService.retrieveIncomingVesselList();
        return ResponseEntity.ok(vesselList);
    }

    /**
     * 특정 MMSI 기준 최신 선박 위치 조회
     *
     * 예:
     * GET /api/ais/vessels/123456789
     */
    @GetMapping("/vessels/{mmsi}")
    public ResponseEntity<AisVslLatestDTO> retrieveVesselLatest(@PathVariable String mmsi) {
        AisVslLatestDTO vessel = aisVesselService.retrieveVesselLatest(mmsi);

        if (vessel == null) {
            return ResponseEntity.notFound().build();
        }

        return ResponseEntity.ok(vessel);
    }

    /**
     * 항구 별칭 캐시 재로딩
     *
     * AIS_PORT_ALIAS 테이블에 데이터를 추가/수정한 뒤
     * 서버 재시작 없이 캐시를 다시 읽고 싶을 때 사용.
     */
    @PostMapping("/port-alias/reload")
    public ResponseEntity<String> reloadPortAlias() {
        aisVesselService.refreshPortAliases();
        return ResponseEntity.ok("AIS port alias cache reloaded");
    }
}
