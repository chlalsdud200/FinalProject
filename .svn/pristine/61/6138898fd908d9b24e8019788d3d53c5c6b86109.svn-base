package kr.or.tacs.owner.export.service;

import kr.or.tacs.cmmenums.*;
import kr.or.tacs.common.file.service.IFileService;
import kr.or.tacs.common.notification.service.INotificationService;
import kr.or.tacs.dto.owner.OwnerExportRequestDTO;
import kr.or.tacs.dto.owner.OwnerExportSearchDTO;
import kr.or.tacs.owner.export.mapper.IExportMapper;
import kr.or.tacs.vo.BrokerVO;
import kr.or.tacs.vo.OwnerVO;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

@Service
public class ExportServiceImpl implements IExportService{

    @Autowired
    IExportMapper expMapper;

    @Autowired
    private IFileService fileService;

    @Autowired
    private INotificationService notificationService;

    @Override
    @Transactional
    public ServiceResult registExp(OwnerExportRequestDTO expDTO) throws Exception {
        Long seq = expMapper.selectExpRqstSeq();

        String today = LocalDate.now().format(DateTimeFormatter.BASIC_ISO_DATE);
        String erNo = String.format("EXP-%s-%05d", today, seq);

        expDTO.setErNo(erNo);

        OwnerVO ownerInfo = expMapper.selectOwnerInfo(expDTO.getErOwrId());

        expDTO.setErOnerNm(ownerInfo.getOwrNm());
        expDTO.setErBizrno(ownerInfo.getOwrBizrno());
        expDTO.setErCstmIdfNo(ownerInfo.getOwrCstmIdfNo());

        // 1. 파일 업로드 + 파일 DB 등록
        Long tfgNo = fileService.uploadFiles(
                TacsCstmSt.CSTM_REQ.name(),
                expDTO.getDocFiles(),
                expDTO.getErOwrId(),
                TacsUserType.OWNER.name()
        );

        // 2. 수출의뢰 DTO에 파일그룹번호 세팅
        expDTO.setErTfgNo(tfgNo);

        // 3. 상태값 세팅
        expDTO.setErStatusCd(TacsCstmSt.CSTM_REQ.name());

        // 4. 수출의뢰 insert
        int result = expMapper.insertExp(expDTO);

        if(result > 0){
            return ServiceResult.OK;
        }

        return ServiceResult.FAILED;
    }

    @Override
    public OwnerVO retriveOwnerInfo(String owrId) {
        return expMapper.selectOwnerInfo(owrId);
    }

    @Override
    public List<BrokerVO> retriveBrokerList() {
        return expMapper.selectBrokerList();
    }

    @Override
    public List<OwnerExportRequestDTO> retriveExpList(OwnerExportSearchDTO searchDTO) {
        return expMapper.selectExpList(searchDTO);
    }

    @Override
    public OwnerExportRequestDTO retriveExp(String erNo) {
        return expMapper.selectExp(erNo);
    }

    @Override
    public int retriveExpCount(OwnerExportSearchDTO searchDTO) {
        return expMapper.selectExpCount(searchDTO);
    }

    @Override
    @Transactional
    public ServiceResult modifyExp(OwnerExportRequestDTO expDTO) throws Exception {

        String erNo = expDTO.getErNo();

        OwnerExportRequestDTO saved = expMapper.selectExp(erNo);

        if (saved == null){
            return ServiceResult.FAILED;
        }

        // 로그인한 화주와 DB의 화주가 같은지 확인 (안전장치1)
        if (!expDTO.getErOwrId().equals(saved.getErOwrId())){
            return ServiceResult.FAILED;
        }

        // 클라이언트로부터 받은 수입번호와 조회한 수입번호가 같은지 확인 (안전장치1)
        if (!expDTO.getErNo().equals(saved.getErNo())){
            return ServiceResult.FAILED;
        }

        int result = expMapper.update(expDTO);

        if(result <= 0){
            return ServiceResult.FAILED;
        }

        // 삭제여부 Y로 바꾸기 (수입도 Y)
        if(expDTO.getDeleteDfiFileNoList() != null && !expDTO.getDeleteDfiFileNoList().isEmpty()){
            for (Long dfiFileNo : expDTO.getDeleteDfiFileNoList()){
                fileService.deleteFile(dfiFileNo);
            }
        }

        // 업데이트시 새 첨부파일 추가 업로드처리
        if(expDTO.getDocFiles() != null && !expDTO.getDocFiles().isEmpty() && expDTO.getDocFiles().stream().anyMatch(file -> !file.isEmpty())){
            fileService.uploadFilesToGroup(
                    expDTO.getErTfgNo(),
                    TacsCstmSt.CSTM_REQ.getCode(),
                    expDTO.getDocFiles(),
                    expDTO.getErOwrId(),
                    TacsUserType.OWNER.getCode()
            );
        }

        // 보완요청시 보완요청 테이블 업데이트 및 상태값(보완제출로) 업데이트
        if("SUPP_SUBMIT".equals(expDTO.getSubmitType())){

            TacsSuppSt.SUB.getCode();

            if(expDTO.getSrSubmitCn() == null || expDTO.getSrSubmitCn().trim().isEmpty()){
                return ServiceResult.FAILED;
            }

            expDTO.setSrRefBizCd(TacsBizCd.EXPORT.getCode());
            expDTO.setBeforeSrStatusCd(TacsSuppSt.REQ.getCode());
            expDTO.setSrStatusCd(TacsSuppSt.SUB.getCode());

            int suppResult = expMapper.updateExpSupp(expDTO);

            if (suppResult <= 0){
                return ServiceResult.FAILED;
            }

            expDTO.setBeforeErStatusCd(TacsCstmSt.CSTM_SUPP.getCode());
            expDTO.setErStatusCd(TacsCstmSt.CSTM_SUPP_SUB.getCode());

            int statusResult = expMapper.updateExpStatus(expDTO);

            if(statusResult <= 0){
                return ServiceResult.FAILED;
            }

            // 관세사가 화주에게 요청한 보완자료를 화주가 제출 → 요청한 관세사에게 통지
            Map<String, String> suppBindings = new HashMap<>();
            suppBindings.put("reqNo", erNo);
            suppBindings.put("linkUrl", "/broker/clients/detail.do?reqNo=" + erNo);
            notificationService.registNotification(
                "CSTM_SUPP_SUBMITTED",
                erNo,
                expDTO.getErOwrId(),
                suppBindings
            );
        }

        return ServiceResult.OK;
    }

    @Override
    public OwnerExportRequestDTO retriveSupp(String erNo) {
        return expMapper.selectSupp(erNo);
    }

}
