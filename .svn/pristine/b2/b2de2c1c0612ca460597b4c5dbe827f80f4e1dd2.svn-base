@charset "UTF-8";

:root {
  --navy: #1b2d44;
  --navy-dk: #112340;
  --navy-lt: #254878;
  --blue: #2563eb;
  --green: #16a34a;
  --orange: #d97706;
  --red: #dc2626;
  --cyan: #0891b2;
  --purple: #7c3aed;
  --border: #e2e8f0;
  --txt: #1e293b;
  --txt2: #64748b;
  --txt3: #94a3b8;
  --bg: #f8fafc;
}

* { box-sizing: border-box; }

.modal-label {
    display: block;
    margin-bottom: 6px;
    color: #334155;
    font-size: 12px;
    font-weight: 700;
}

.detail-wrap {
  background: #f4f6fa;
  min-height: calc(100vh - 56px);
}

.det-wrap {
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 56px);
  background: #f4f6fa;
}

.det-hdr {
  background: #fff;
  border-bottom: 1px solid var(--border);
  padding: 14px 24px;
  flex-shrink: 0;
}

.det-hdr-inner {
  display: flex;
  align-items: stretch;
  gap: 16px;
}

.det-hdr-left { flex: 1; min-width: 0; }

.det-hdr-top {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.det-no {
  font-size: 20px;
  font-weight: 900;
  color: var(--navy);
}

.det-meta {
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
  margin-bottom: 6px;
}

.det-m {
  font-size: 12px;
  color: var(--txt2);
}

.det-m span {
  font-weight: 700;
  color: #0f2537;
}

.det-m.hl span { color: var(--blue); }

.det-ai {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
  flex-wrap: wrap;
}

.ai-score-sm {
  background: var(--navy);
  color: #fff;
  border-radius: 4px;
  padding: 3px 10px;
  font-size: 12px;
  font-weight: 700;
}

.ai-tags-sm { display: flex; gap: 4px; flex-wrap: wrap; }

.ai-tag-sm {
  background: #f1f5f9;
  border: 1px solid var(--border);
  color: var(--txt2);
  font-size: 10.5px;
  padding: 2px 7px;
  border-radius: 10px;
}

.status-panel {
  flex-shrink: 0;
  min-width: 165px;
  border-radius: 6px;
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2px solid transparent;
  text-align: center;
}

.status-panel .sp-label {
  font-size: 9.5px;
  font-weight: 900;
  letter-spacing: .7px;
  text-transform: uppercase;
  opacity: .65;
  margin-bottom: 5px;
}

.status-panel .sp-val {
  font-size: 21px;
  font-weight: 900;
  line-height: 1;
}

.status-panel .sp-desc {
  font-size: 11px;
  margin-top: 4px;
  opacity: .72;
}

.sp-접수대기 { background: #fff7ed; border-color: #fcd34d; color: #92400e; }
.sp-접수완료 { background: #eff6ff; border-color: #93c5fd; color: #1e40af; }
.sp-심사중 { background: #faf5ff; border-color: #c4b5fd; color: #5b21b6; }
.sp-보완요청 { background: #fff7ed; border-color: #fdba74; color: #9a3412; }
.sp-소명요청 { background: #e0f2fe; border-color: #67e8f9; color: #164e63; }
.sp-통관보류 { background: #f8fafc; border-color: #94a3b8; color: #334155; }
.sp-승인완료 { background: #f0fdf4; border-color: #86efac; color: #14532d; }
.sp-반려 { background: #fef2f2; border-color: #fca5a5; color: #7f1d1d; }
.sp-DCLR_WAIT { background: #fff7ed; border-color: #fcd34d; color: #92400e; }
.sp-DCLR_REVIEW { background: #faf5ff; border-color: #c4b5fd; color: #5b21b6; }
.sp-DCLR_DONE { background: #f0fdf4; border-color: #86efac; color: #14532d; }
.sp-DCLR_TEMP { background: #f8fafc; border-color: #cbd5e1; color: #475569; }


.det-tab-bar {
  background: #fff;
  border-bottom: 2px solid var(--border);
  display: flex;
  flex-shrink: 0;
  padding: 0 24px;
  overflow-x: auto;
}

.det-tab-bar::-webkit-scrollbar { display: none; }

.det-tab-i {
  border: 0;
  background: #fff;
  padding: 9px 14px;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--txt2);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  white-space: nowrap;
  transition: all .15s;
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: inherit;
}

.det-tab-i.locked {
  color: #cbd5e1 !important;
  opacity: 1;
  cursor: not-allowed;
}

.det-tab-i.locked:hover {
  color: #cbd5e1 !important;
}

.det-tab-i .material-symbols-outlined { font-size: 15px; }
.det-tab-i:hover { color: #0f172a; }
.det-tab-i.on { color: var(--blue); border-bottom-color: var(--blue); }
.det-tab-i .tc { background: var(--red); color: #fff; font-size: 10px; padding: 1px 5px; border-radius: 8px; font-weight: 700; }

.tab-body {
  flex: 1;
  overflow-y: auto;
  padding: 18px 24px;
}

.tab-pane { display: none; }
.tab-pane.on { display: block; }

.basic-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 260px;
  gap: 12px;
}

.fs {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 14px 16px;
  margin-bottom: 10px;
}

.fs-t {
  font-size: 11.5px;
  font-weight: 800;
  color: var(--navy);
  padding-bottom: 8px;
  margin-bottom: 10px;
  border-bottom: 1px solid var(--border);
  letter-spacing: .02em;
  text-transform: uppercase;
}

.fg { display: grid; gap: 8px 14px; }
.fg2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.fg3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.fg4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }

.fr, .fr-top {
  display: grid;
  grid-template-columns: 110px minmax(0, 1fr);
  gap: 6px;
  align-items: center;
}

.fr-top { align-items: flex-start; }

.flabel {
  font-size: 11px;
  color: var(--txt2);
  font-weight: 700;
}

.fval {
  font-size: 12.5px;
  color: #0f2537;
  font-weight: 600;
  min-width: 0;
  word-break: keep-all;
}

.fval.officer { color: var(--blue); font-weight: 800; }
.fval.amount { color: var(--red); font-weight: 900; font-size: 14px; }

.finput,
.fselect,
.ftarea {
  width: 100%;
  border: 1px solid #d1d9e6;
  border-radius: 4px;
  font-size: 12px;
  font-family: inherit;
  color: #0f172a;
  background: #fff;
  outline: none;
}

.finput,
.fselect {
  height: 32px;
  padding: 0 10px;
}

.ftarea {
  padding: 7px 10px;
  resize: vertical;
  min-height: 80px;
}

.finput:focus,
.fselect:focus,
.ftarea:focus { border-color: #3b5bdb; }

.ai-box {
  background: linear-gradient(135deg, #112340 0%, #254878 100%);
  border-radius: 6px;
  padding: 14px 16px;
  color: #fff;
  margin-bottom: 10px;
  position: relative;
  overflow: hidden;
}

.ai-box::after {
  content: 'AI';
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 44px;
  font-weight: 900;
  color: rgba(255,255,255,.06);
}

.ai-t {
  font-size: 10px;
  color: rgba(255,255,255,.55);
  margin-bottom: 5px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
}

.ai-num { font-size: 26px; font-weight: 900; margin-bottom: 3px; }
.ai-num span { font-size: 14px; opacity: .7; }
.ai-desc { font-size: 11.5px; color: rgba(255,255,255,.75); }
.ai-tags { display: flex; gap: 5px; margin-top: 7px; flex-wrap: wrap; }
.ai-tag { background: rgba(255,255,255,.12); padding: 2px 8px; border-radius: 10px; font-size: 11px; }
.ai-lo { font-size: 11px; font-weight: 800; color: #15803d; }
.ai-md { font-size: 11px; font-weight: 800; color: #c05621; }
.ai-hi { font-size: 11px; font-weight: 800; color: #b91c1c; }

.save-row { display: flex; justify-content: flex-end; margin-top: 6px; }

.table-scroll { overflow-x: auto; }
.ptbl { width: 100%; border-collapse: collapse; font-size: 12px; background: #fff; }
.ptbl th { padding: 7px 10px; text-align: left; font-size: 10px; font-weight: 800; color: #4d6172; background: #ecf4ff; border: 1px solid #d9eafc; text-transform: uppercase; letter-spacing: .06em; }
.ptbl td { padding: 8px 10px; border: 1px solid #d9eafc; color: #203444; }
.ptbl tfoot td { background: #ecf4ff; font-weight: 700; }
.item-table { min-width: 760px; }
.total-tax { color: var(--red); font-size: 14px; font-weight: 900; }

.badge { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 3px; font-size: 11px; font-weight: 700; white-space: nowrap; }
.badge-wait { background: #fff7ed; color: #c2410c; border: 1px solid #fed7aa; }
.badge-recv { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
.badge-proc { background: #faf5ff; color: #6d28d9; border: 1px solid #ddd6fe; }
.badge-suppl { background: #fff7ed; color: #c05621; border: 1px solid #fbd38d; }
.badge-stmt { background: #e0f2fe; color: #0369a1; border: 1px solid #bae6fd; }
.badge-ok { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
.badge-ng { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }
.badge-hold { background: #f8fafc; color: #475569; border: 1px solid #cbd5e1; }

.file-list { display: grid; gap: 8px; }
.file-item { display: flex; align-items: center; gap: 10px; padding: 8px 12px; background: var(--bg); border: 1px solid var(--border); border-radius: 4px; }
.file-ico { font-size: 18px; color: var(--blue); }
.file-name { flex: 1; font-size: 12.5px; font-weight: 700; color: #0f2537; min-width: 0; }
.file-meta { font-size: 11px; color: var(--txt3); }

.file-info {
  flex: 1;
  min-width: 0;
}

.file-actions {
  margin-left: auto;
  display: flex;
  gap: 6px;
  align-items: center;
}

.work-type-bar {
  background: #f8fbff;
  border: 1px solid #d9eafc;
  border-radius: 4px;
  padding: 12px 16px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.work-type-label {
  font-size: 12px;
  font-weight: 900;
  color: #203444;
  white-space: nowrap;
}
.work-type-select {
  width: 170px;
  height: 34px;
  border: 2px solid #3b5bdb;
  border-radius: 4px;
  padding: 0 10px;
  background: #fff;
  color: #1d4ed8;
  font-size: 12px;
  font-weight: 800;
  outline: none;
  font-family: inherit;
  cursor: pointer;
}
.work-type-desc {
  font-size: 12px;
  color: #64748b;
  margin-left: 2px;
}
.work-form-card {
  background: #fff;
  border: 1px solid #d9eafc;
  border-radius: 4px;
  overflow: hidden;
  margin-top: 12px;
  margin-bottom: 10px;
}
.wfc-header {
  min-height: 44px;
  padding: 0 16px;
  background: #f8fbff;
  border-bottom: 1px solid #d9eafc;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.wfc-title {
  font-size: 13px;
  font-weight: 900;
  color: #203444;

}
.wfc-body {
  padding: 16px;
}
.wfc-footer {
  padding: 10px 16px;
  background: #f8fbff;
  border-top: 1px solid #d9eafc;
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}
.work-due-row { margin-top: 10px; }


/* 업무처리 탭 - 요청 폼 이미지 기준 보정 */
.wfc-body .fr,
.wfc-body .fr-top {
  display: grid;
  grid-template-columns: 100px minmax(0, 1fr);
  gap: 12px;
  align-items: start;
  margin-bottom: 12px;
}

.wfc-body .flabel {
  padding-top: 7px;
  font-size: 12px;
  font-weight: 800;
  color: #475569;
}

.wfc-body .ftarea {
  min-height: 82px;
  border: 1px solid #cbd8e8;
  border-radius: 4px;
  padding: 10px 12px;
  font-size: 12px;
  resize: vertical;
  background: #fff;
}

.wfc-body .finput {
  width: 160px;
  height: 34px;
  border: 1px solid #cbd8e8;
  border-radius: 4px;
  padding: 0 10px;
  font-size: 12px;
  background: #fff;
}

.wfc-body input[type="file"] {
  width: 100%;
  height: 34px;
  border: 1px solid #cbd8e8;
  border-radius: 4px;
  padding: 5px 8px;
  background: #fff;
  font-size: 12px;
}

.wfc-body .note,
.wfc-body .text-muted {
  margin-left: 112px;
  margin-top: -6px;
  font-size: 11px;
  color: #94a3b8;
  background: transparent;
  border: 0;
  padding: 0;
}

.wfc-footer .btn-secondary,
.wfc-footer .btn-primary,
.wfc-footer .btn-danger {
  height: 32px;
  padding: 0 13px;
  font-size: 12px;
  font-weight: 800;
  border-radius: 4px;
}

.wfc-footer .btn-primary {
  background: #ea580c;
  border-color: #ea580c;
  color: #fff;
}

.wfc-footer .btn-primary:hover {
  background: #c2410c;
}

/* 업무처리 탭 - 처리 요청 이력 표 */
.work-history-card {
  background: #fff;
  border: 1px solid #d9eafc;
  border-radius: 4px;
  padding: 14px 16px;
  margin-bottom: 12px;
}

.work-history-title {
  margin: 0 0 10px;
  font-size: 12px;
  font-weight: 900;
  color: #203444;
}

.work-history-table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
}

.work-history-table th th {
  background: #ecf4ff;
  border: 1px solid #d9eafc;
  padding: 9px 12px;
  font-size: 11px;
  font-weight: 900;
  color: #4d6172;
  text-align: left;
}

.work-history-table td td {
  border: 1px solid #d9eafc;
  padding: 10px 12px;
  font-size: 12px;
  color: #203444;
}
.tax-locked { display: flex; align-items: center; gap: 10px; padding: 18px; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; color: var(--txt2); font-size: 12.5px; }
.tax-locked .material-symbols-outlined { font-size: 20px; color: var(--txt3); }
.tax-locked {
  display: none;
}
.tax-content {
  display: block;
}
.note { font-size: 11.5px; color: var(--txt2); padding: 7px 12px; background: var(--bg); border: 1px solid var(--border); border-radius: 4px; margin-bottom: 10px; }
.tax-agent-info { margin-bottom: 12px; }
.tax-btn-row { display: flex; gap: 8px; align-items: center; }

.act-bar { background: #fff; border-top: 2px solid var(--border); padding: 12px 24px; display: flex; align-items: center; gap: 8px; flex-shrink: 0; flex-wrap: wrap; }
.act-bar-main { display: flex; align-items: center; gap: 8px; flex: 1; flex-wrap: wrap; }
.act-bar-side { display: flex; align-items: center; gap: 6px; }
.act-sep { width: 1px; height: 24px; background: var(--border); margin: 0 4px; }

.btn-primary,
.btn-secondary,
.btn-danger,
.btn-approve {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  height: 32px;
  padding: 0 14px;
  border-radius: 4px;
  border: 1px solid transparent;
  font-size: 12px;
  font-weight: 700;
  font-family: inherit;
  cursor: pointer;
  white-space: nowrap;
  text-decoration: none;
}

.btn-primary { background: var(--navy); border-color: var(--navy); color: #fff; }
.btn-primary:hover { background: #152540; }
.btn-secondary { background: #fff; border-color: #cbd8e8; color: #334155; }
.btn-secondary:hover { background: #f1f5f9; }
.btn-danger { height: 34px; width:70px; background: #fff; color: #991b1b; border-color: #fca5a5; }
.btn-danger:hover { background: #fee2e2; }
.btn-approve { height: 34px; background: #1e3054;  color: #fff; font-size: 13px; }
.btn-approve:hover { background: #1e3054; }
.btn-sm { height: 28px; padding: 0 10px; font-size: 11px; }
.btn-sm .material-symbols-outlined,
.btn-secondary .material-symbols-outlined,
.btn-primary .material-symbols-outlined { font-size: 14px; }

.mov { display: none; position: fixed; inset: 0; background: rgba(15,23,42,.5); z-index: 2000; align-items: center; justify-content: center; }
.mov.on { display: flex; }
.mbox { background: #fff; border-radius: 8px; max-width: 95vw; max-height: 90vh; overflow-y: auto; }
.approve-modal-box { width: 660px; }
.sms-modal-box { width: 480px; }
.mhdr { padding: 14px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; background: #fff; z-index: 1; }
.mtitle { font-size: 15px; font-weight: 800; display: flex; align-items: center; gap: 4px; }
.mclose { cursor: pointer; font-size: 18px; color: var(--txt2); background: none; border: none; line-height: 1; }
.mbody { padding: 18px 20px; }
.mfoot { padding: 12px 20px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 8px; position: sticky; bottom: 0; background: #fff; }

.approve-flow { display: flex; flex-direction: column; gap: 0; margin: 12px 0; }
.af-item { display: flex; align-items: flex-start; gap: 12px; padding: 10px 12px; border-radius: 6px; background: #f0fdf4; margin-bottom: 2px; border: 1px solid #bbf7d0; }
.af-num { width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; color: #fff; }
.af-num.g { background: var(--green); }
.af-num.b { background: var(--blue); }
.af-body .af-title { font-size: 12.5px; font-weight: 700; }
.af-body .af-desc { font-size: 11.5px; color: var(--txt2); margin-top: 2px; }
.af-arrow { text-align: center; color: var(--txt3); font-size: 18px; margin: 2px 0; }
.sms-opt { display: flex; align-items: flex-start; gap: 10px; padding: 8px 12px; background: #fff; border: 1px solid var(--border); border-radius: 4px; cursor: pointer; margin-bottom: 6px; }
.sms-opt:hover { border-color: #3b5bdb; }
.sms-opt-t { font-size: 12.5px; font-weight: 700; }
.sms-opt-p { font-size: 11px; color: var(--txt2); margin-top: 2px; }

.toast { position: fixed; bottom: 80px; right: 24px; background: #0f172a; color: #fff; padding: 10px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; z-index: 3000; transform: translateY(20px); opacity: 0; transition: all .3s; max-width: 360px; }
.toast.on { transform: translateY(0); opacity: 1; }
.toast.g { background: var(--green); }
.toast.b { background: var(--blue); }
.toast.o { background: var(--orange); }
.toast.r { background: var(--red); }

.empty-box,
.empty-cell { padding: 18px; text-align: center; color: var(--txt2); font-size: 12px; background: var(--bg); }

@media (max-width: 1100px) {
  .det-hdr-inner,
  .basic-layout { grid-template-columns: 1fr; flex-direction: column; }
  .status-panel { width: 100%; }
  .fg2, .fg3, .fg4 { grid-template-columns: 1fr; }
  .work-type-bar { align-items: flex-start; flex-direction: column; }
}

/* 업무처리 요청이력/버튼 정리 */
.work-file-row {
  margin-top: 10px;
}

.work-file-field {
  width: 100%;
}

.work-file-input {
  width: 100%;
  max-width: none;
}

.work-file-help {
  margin: 5px 0 0;
  font-size: 11px;
  color: var(--txt3);
}

.work-file-help.required {
  color: #dc2626;
  font-weight: 800;
}

.wfc-footer .work-action-btn,
.work-action-btn {
  min-width: 112px;
  height: 34px;
  padding: 0 16px;
  font-size: 12px;
  font-weight: 800;
  border-radius: 4px;
}

.wfc-footer .btn-primary.work-action-btn {
  background: #1e3054;
  border-color: #1e3054;
  color: #fff;
}

.wfc-footer .btn-primary.work-action-btn:hover {
  background: #32497a;
  border-color: #314f8c;
}

.work-history-table th,
.work-history-table td {
  vertical-align: middle;
}

.work-history-table th:nth-child(1),
.work-history-table td:nth-child(1) { width: 120px; }
.work-history-table th:nth-child(2),
.work-history-table td:nth-child(2) { width: 180px; }
.work-history-table th:nth-child(4),
.work-history-table td:nth-child(4) { width: 130px; }
.work-history-table th:nth-child(5),
.work-history-table td:nth-child(5) { width: 110px; }
.work-history-table th:nth-child(6),
.work-history-table td:nth-child(6) { width: 90px; text-align: center; }

.hidden { display: none !important; }

/* 업무처리 유형별 첨부파일 표시 제어 */
.work-file-row.hidden {
  display: none !important;
}

.work-file-help.required {
  color: #dc2626;
  font-weight: 800;
}

.work-action-btn {
  min-width: 118px;
  height: 32px;
  justify-content: center;
}

.readonly-notice {
  font-size: 13px;
  font-weight: 700;
  color: #64748b;
}

/* =============================================================
   공통 — 처리상태 뱃지
   ============================================================= */
.line-status-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: 3px;
  font-size: 11.5px;
  font-weight: 700;
  border: 1px solid transparent;
  white-space: nowrap;
}
.ls-ITEM_REVIEW   { background: #faf5ff; color: #5b21b6; border-color: #c4b5fd; }
.ls-ITEM_SUPP_REQ { background: #fff7ed; color: #c2410c; border-color: #fed7aa; }
.ls-ITEM_SUPP_SUB { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
.ls-ITEM_ACPT     { background: #f0fdf4; color: #15803d; border-color: #bbf7d0; }
.ls-ITEM_REJ      { background: #fef2f2; color: #b91c1c; border-color: #fecaca; }
#tab-items .customs-item-card {
            background:#fff; border:1px solid #d8e5f2; border-radius:12px;
            box-shadow:0 6px 18px rgba(30,58,90,.06); margin-bottom:16px; overflow:hidden;
        }
        #tab-items .cic-head {
            display:flex; align-items:center; justify-content:space-between; gap:16px;
            padding:16px 18px; background:linear-gradient(180deg,#f7fbff 0%,#ffffff 100%);
            border-bottom:1px solid #e2edf8;
        }
        #tab-items .cic-title-area { display:flex; align-items:center; gap:12px; min-width:0; }
        #tab-items .cic-no {
            width:34px; height:34px; display:inline-flex; align-items:center; justify-content:center;
            border-radius:10px; background:#eaf3ff; color:#1d4ed8; font-weight:800; font-size:13px;
        }
        #tab-items .cic-hs { font-size:12px; font-weight:800; color:#41627e; letter-spacing:.02em; }
        #tab-items .cic-name { margin-top:2px; font-size:17px; font-weight:800; color:#0f2537; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        #tab-items .cic-tags { display:flex; flex-wrap:wrap; justify-content:flex-end; gap:6px; }
        #tab-items .cic-tag { display:inline-flex; align-items:center; min-height:26px; padding:0 9px; border-radius:999px; font-size:11.5px; font-weight:700; border:1px solid transparent; }
        #tab-items .cic-tag.status { background:#eef6ff; color:#1d4ed8; border-color:#cfe3ff; }
        #tab-items .cic-tag.req { background:#faf5ff; color:#7e22ce; border-color:#e9d5ff; }

        #tab-items .cic-core-grid { display:grid; grid-template-columns:1fr 1.08fr 1fr; gap:12px; padding:14px 16px; }
        #tab-items .cic-box { border:1px solid #e4edf7; background:#fff; border-radius:10px; padding:13px 14px; min-width:0; }
        #tab-items .cic-focus-box { background:#fbfdff; border-color:#cfe3ff; }
        #tab-items .cic-money-box { background:#fffdf8; border-color:#f1dfb8; }
        #tab-items .cic-box-title { font-size:12.5px; font-weight:800; color:#29465f; margin-bottom:10px; padding-bottom:8px; border-bottom:1px solid #edf3f9; }
        #tab-items .cic-row { display:flex; align-items:flex-start; justify-content:space-between; gap:14px; min-height:28px; padding:5px 0; font-size:12.5px; }
        #tab-items .cic-row span { color:#6b7f91; flex:0 0 auto; }
        #tab-items .cic-row strong { color:#1f3347; text-align:right; font-weight:700; word-break:break-word; }
        #tab-items .cic-row.main strong { font-size:20px; color:#1d4ed8; line-height:1; }
        #tab-items .cic-row.price strong { font-size:15px; color:#9a5b00; }
        #tab-items .cic-row.total { margin-top:5px; padding-top:10px; border-top:1px dashed #e7d6ad; }
        #tab-items .cic-row.total strong { font-size:15px; color:#8a3d00; }
        #tab-items .cic-row-note {
            margin-top: 10px; padding-top: 10px;
            border-top: 1px dashed #e7d6ad;
            font-size: 11px; color: #a07040; line-height: 1.5;
        }
#tab-items .btn-item-supp, #tab-items .btn-item-acpt, #tab-items .btn-item-rej {
            height:32px; min-width:72px; border-radius:7px; border:1px solid #cbd5e1;
            background:#fff; color:#334155; font-size:12px; font-weight:700; cursor:pointer;
        }
        #tab-items .btn-item-acpt { background:#29465f; color:#fff; border-color:#29465f; }
        #tab-items .btn-item-rej { background:#fff7f7; color:#a13d3d; border-color:#e3b4b4; }
        #tab-items .btn-item-supp:hover, #tab-items .btn-item-acpt:hover, #tab-items .btn-item-rej:hover { filter:brightness(.97); }


        /* ===== 품목별 처리상태 → 신고 전체 승인 가능 여부 ===== */
        #tab-items .item-progress-panel {
            display:grid; grid-template-columns:1.1fr .9fr; gap:12px; margin-bottom:14px;
        }
        #tab-items .progress-box {
            background:#ffffff; border:1px solid #d9eafc; border-radius:10px; padding:14px 16px;
        }
        #tab-items .progress-title { font-size:13px; font-weight:800; color:#15324a; margin-bottom:8px; }
        #tab-items .progress-bar { height:10px; border-radius:999px; background:#eef4fb; overflow:hidden; }
        #tab-items .progress-fill { height:100%; background:#29465f; border-radius:999px; }
        #tab-items .progress-text { margin-top:8px; font-size:12.5px; color:#64748b; }
        #tab-items .progress-text strong { color:#0f2537; }
        #tab-items .item-state-summary { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; }
        #tab-items .state-count {
            border:1px solid #e2edf8; background:#fbfdff; border-radius:9px; padding:12px 10px; text-align:center;
        }
        #tab-items .state-count span { display:block; font-size:11.5px; color:#64748b; margin-bottom:5px; }
        #tab-items .state-count strong { display:block; font-size:18px; color:#0f2537; }
        #tab-items .cic-tag.done { background:#f0fdf4; color:#15803d; border-color:#bbf7d0; }
        #tab-items .cic-tag.block { background:#fff7ed; color:#c2410c; border-color:#fed7aa; }
        #tab-items .cic-tag.reject { background:#fff1f2; color:#be123c; border-color:#fecdd3; }
        #tab-items .item-complete-msg { font-size:12.5px; font-weight:800; color:#15803d; margin-right:auto; }
        #tab-items .item-reject-msg { font-size:12.5px; font-weight:800; color:#be123c; margin-right:auto; }
        .final-approve-guide {
            display:flex; align-items:center; gap:8px; margin-right:auto; font-size:12.5px; color:#9a3412;
            background:#fff7ed; border:1px solid #fed7aa; border-radius:8px; padding:8px 10px;
        }
        .final-approve-guide.ready { color:#166534; background:#f0fdf4; border-color:#bbf7d0; }
        .final-approve-guide .material-symbols-outlined { font-size:18px; }
        .btn-approve:disabled, .btn-primary:disabled, button:disabled {
            opacity:.48; cursor:not-allowed; filter:grayscale(.25);
        }

        @media (max-width:1100px) {
            #tab-items .cic-core-grid { grid-template-columns:1fr; }
            #tab-items .cic-head { align-items:flex-start; flex-direction:column; }
            #tab-items .cic-tags { justify-content:flex-start; }
            #tab-items .item-progress-panel { grid-template-columns:1fr; }
            #tab-items .item-state-summary { grid-template-columns:1fr 1fr 1fr; }
            #tab-items .csh-table .csh-reason { max-width: 120px; }
        }

/* =============================================================
   품목정보 탭 — 란사항 처리/이력 영역
   ============================================================= */
#tab-items .item-process-panel {
  margin: 0 16px 12px;
  padding: 13px 14px;
  border: 1px solid #d9eafc;
  border-radius: 10px;
  background: #f8fbff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
}

#tab-items .ipp-left {
  min-width: 0;
  flex: 1;
}

#tab-items .ipp-label {
  margin-bottom: 6px;
  font-size: 11px;
  font-weight: 900;
  color: #64748b;
  letter-spacing: .04em;
  text-transform: uppercase;
}

#tab-items .ipp-desc {
  margin-top: 7px;
  font-size: 12px;
  color: #64748b;
  line-height: 1.45;
}

#tab-items .ipp-actions {
  display: flex;
  align-items: center;
  gap: 7px;
  flex-shrink: 0;
}

#tab-items .item-history-box {
  margin: 0 16px 16px;
  border: 1px solid #e2edf8;
  border-radius: 10px;
  background: #fff;
  overflow: hidden;
}

#tab-items .ihb-head {
  padding: 11px 14px;
  background: #ffffff;
  border-bottom: 1px solid #e2edf8;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

#tab-items .ihb-title {
  font-size: 12.5px;
  font-weight: 900;
  color: #203444;
}

#tab-items .ihb-sub {
  margin-top: 3px;
  font-size: 11px;
  color: #94a3b8;
}

#tab-items .item-history-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}

#tab-items .item-history-table th {
  background: #ecf4ff;
  border-bottom: 1px solid #d9eafc;
  padding: 8px 10px;
  font-size: 11px;
  font-weight: 900;
  color: #4d6172;
  text-align: left;
  white-space: nowrap;
}

#tab-items .item-history-table td {
  border-bottom: 1px solid #f1f5f9;
  padding: 9px 10px;
  color: #203444;
  vertical-align: middle;
}

#tab-items .item-history-table tr:last-child td {
  border-bottom: 0;
}

#tab-items .item-history-table .ihb-msg {
  max-width: 360px;
  line-height: 1.45;
  word-break: keep-all;
}

#tab-items .item-complete-msg,
#tab-items .item-reject-msg {
  min-width: 72px;
  height: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 7px;
  padding: 0 12px;
  font-size: 12px;
  font-weight: 800;
}

#tab-items .item-complete-msg {
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  color: #15803d;
}

#tab-items .item-reject-msg {
  background: #fff1f2;
  border: 1px solid #fecdd3;
  color: #be123c;
}

@media (max-width: 900px) {
  #tab-items .item-process-panel {
    align-items: flex-start;
    flex-direction: column;
  }

  #tab-items .ipp-actions {
    width: 100%;
    justify-content: flex-end;
    flex-wrap: wrap;
  }

  #tab-items .item-history-table {
    min-width: 720px;
  }

  #tab-items .item-history-box {
    overflow-x: auto;
  }
}


/* ===== 최종 보정: 품목 처리 영역은 버튼만, 이력은 처리 전 숨김 ===== */
#tab-items .item-process-panel.simple {
  margin: 0 16px 16px;
  padding: 12px 0 0;
  border: 0;
  border-top: 1px solid #e2edf8;
  border-radius: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 7px;
}

#tab-items .item-process-panel.simple .ipp-left,
#tab-items .item-process-panel.simple .ipp-label,
#tab-items .item-process-panel.simple .ipp-desc,
#tab-items .item-process-panel.simple .line-status-badge {
  display: none !important;
}

#tab-items .item-history-box.is-empty {
  display: none !important;
}

#tab-items .item-history-box {
  margin: 0 16px 12px;
}


/* ===== 반려 처리된 품목 카드 잠금 표시 ===== */
#tab-items .customs-item-card.is-rejected {
  background: #f8fafc;
  border-color: #cbd5e1;
  box-shadow: none;
  opacity: .82;
}

#tab-items .customs-item-card.is-rejected .cic-head {
  background: #f1f5f9;
}

#tab-items .customs-item-card.is-rejected .cic-box,
#tab-items .customs-item-card.is-rejected .cic-focus-box,
#tab-items .customs-item-card.is-rejected .cic-money-box {
  background: #f8fafc;
  border-color: #d7dee8;
}

#tab-items .customs-item-card.is-rejected .cic-name,
#tab-items .customs-item-card.is-rejected .cic-row strong {
  color: #64748b;
}

#tab-items .customs-item-card.is-rejected .btn-item-supp,
#tab-items .customs-item-card.is-rejected .btn-item-acpt,
#tab-items .customs-item-card.is-rejected .btn-item-rej {
  display: none !important;
}

#tab-items .item-rejected-lock {
  min-height: 34px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 14px;
  border-radius: 7px;
  border: 1px solid #cbd5e1;
  background: #f1f5f9;
  color: #64748b;
  font-size: 12px;
  font-weight: 800;
}

#tab-items .customs-item-card.is-rejected .item-process-panel.simple {
  justify-content: flex-end;
}
#tab-items .item-wait-msg {
    width: 100%;
    padding: 8px 10px;
    border: 1px solid #fed7aa;
    background: #fff7ed;
    color: #c2410c;
    border-radius: 6px;
    font-size: 12.5px;
    font-weight: 800;
    text-align: center;
}


/* =============================================================
   품목정보 탭 — HS 확인 미니 버튼/결과
   ============================================================= */
#tab-items .cic-hs {
  display: flex;
  align-items: center;
  gap: 7px;
  flex-wrap: wrap;
}

#tab-items .btn-hs-check {
  height: 22px;
  padding: 0 8px;
  border: 1px solid #cfe3ff;
  border-radius: 999px;
  background: #ffffff;
  color: #1d4ed8;
  font-size: 10.5px;
  font-weight: 800;
  font-family: inherit;
  cursor: pointer;
  line-height: 1;
}

#tab-items .btn-hs-check:hover {
  background: #eef6ff;
  border-color: #93c5fd;
}

#tab-items .btn-hs-check:disabled {
  opacity: .55;
  cursor: wait;
}

#tab-items .hs-mini-result {
  margin-top: 1px;
  max-width: 600px;
  border: 1px solid #d9eafc;
  border-radius: 8px;
  background: #fbfdff;
  padding: 5px;
}

#tab-items .hs-mini-result.hidden {
  display: none !important;
}
#tab-items .btn-tariff-check {
  height: 24px;
  padding: 0 10px;
  border: 1px solid #d9eafc;
  border-radius: 999px;
  background: #fff;
  color: #334155;
  font-size: 10.5px;
  font-weight: 800;
  cursor: pointer;
}

#tab-items .btn-tariff-check:hover {
  background: #f8fbff;
  border-color: #93c5fd;
  color: #1d4ed8;
}

#tab-items .tariff-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

#tab-items .tariff-title-row .btn-tariff-check {
  height: 24px;
  padding: 0 9px;
  border: 1px solid #cfe3ff;
  border-radius: 999px;
  background: #fff;
  color: #1d4ed8;
  font-size: 10.5px;
  font-weight: 800;
  cursor: pointer;
}

#tab-items .tariff-title-row .btn-tariff-check:hover {
  background: #eef6ff;
}
.badge-cancel {
  background-color: #e2e8f0;
  color: #64748b;
}

/* ===== 탭/세금납부 보정 ===== */
.tab-pane { display: none; }
.tab-pane.on { display: block; }
#tab-tax .tax-locked { display: flex; margin-bottom: 12px; }
#tab-tax .tax-content { display: block; }
#tab-tax .amount { text-align: right; font-weight: 800; color: #1e3054; }
#tab-tax .tax-btn-row { justify-content: flex-end; margin-top: 12px; }

/* =============================================================
   세금납부 탭 — 납부기한/납세고지번호 카드형 표시
   ============================================================= */
#tab-tax .tax-meta-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin: 0 0 12px;
}

#tab-tax .tax-meta-item {
  min-height: 64px;
  padding: 13px 16px;
  border: 1px solid #d9eafc;
  border-radius: 8px;
  background: #f8fbff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 7px;
}

#tab-tax .tax-meta-label {
  font-size: 11px;
  font-weight: 900;
  color: #64748b;
  letter-spacing: .04em;
}

#tab-tax .tax-meta-val {
  font-size: 17px;
  font-weight: 900;
  color: #0f2537;
  line-height: 1.1;
}

#tab-tax .tax-meta-val.due-date {
  color: #1e3054;
}

@media (max-width: 768px) {
  #tab-tax .tax-meta-row {
    grid-template-columns: 1fr;
  }
}


/* =============================================================
   기본정보 탭 — 처리단계 세로 진행상태
   ============================================================= */
.process-card {
  overflow: hidden;
}

.process-card .process-timeline {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 4px 0 0;
}

.process-card .process-row {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 12px;
  min-height: 38px;
}

.process-card .process-row:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 10px;
  top: 24px;
  bottom: -14px;
  width: 2px;
  background: #e2e8f0;
}

.process-card .process-row.done:not(:last-child)::after,
.process-card .process-row.on:not(:last-child)::after {
  background: #cbd5e1;
}

.process-card .process-node {
  position: relative;
  z-index: 1;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 22px;
  font-size: 12px;
  font-weight: 800;
  color: #94a3b8;
  background: #e2e8f0;
}

.process-card .process-row.done .process-node {
  color: #fff;
  background: #2563eb;
}

.process-card .process-row.on .process-node {
  color: #fff;
  background: #7c3aed;
  box-shadow: 0 0 0 4px #ede9fe;
}

.process-card .process-text strong {
  display: block;
  font-size: 13px;
  color: #0f172a;
  line-height: 1.2;
}

.process-card .process-text span {
  display: block;
  margin-top: 4px;
  font-size: 12px;
  color: #64748b;
  line-height: 1.35;
}

.process-card .process-row.wait .process-text strong,
.process-card .process-row.wait .process-text span {
  color: #94a3b8;
}

.process-card .process-note {
  margin-top: 12px;
  padding: 10px 12px;
  border: 1px solid #dbeafe;
  border-radius: 6px;
  background: #f8fbff;
  font-size: 12px;
  color: #334155;
}

.process-card .process-note strong {
  color: #1e3a8a;
}
