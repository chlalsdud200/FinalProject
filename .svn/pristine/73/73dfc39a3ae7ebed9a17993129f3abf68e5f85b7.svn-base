<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<div class="tacs-mypage" id="tacsMypage" data-actor-path="${mypageActorPath}" data-initial-tab="${mypageTab}">
    <section class="tacs-mypage-shell">
        <div class="tacs-mypage-tabs" role="tablist" aria-label="마이페이지 탭">
            <button type="button" class="tacs-mypage-tab ${mypageTab eq 'alarm' ? '' : 'is-active'}" data-mypage-tab="profile" role="tab">
                회원정보 수정
            </button>
            <button type="button" class="tacs-mypage-tab ${mypageTab eq 'alarm' ? 'is-active' : ''}" data-mypage-tab="alarm" role="tab">
                알림 수신 설정
            </button>
        </div>

        <div class="tacs-mypage-panels">
            <section class="tacs-mypage-panel ${mypageTab eq 'alarm' ? '' : 'is-active'}" id="mypage-profile-panel" data-mypage-panel="profile">
                <div class="tacs-password-card" data-mypage-password-area>
                    <div class="tacs-password-visual">
                        <span class="material-symbols-outlined">lock</span>
                    </div>
                    <div class="tacs-password-body">
                        <p class="tacs-section-label">보안 확인</p>
                        <h2>비밀번호 확인</h2>
                        <p class="tacs-password-desc">개인정보 보호를 위해 현재 비밀번호를 한 번 더 입력해 주세요.</p>

                        <form class="tacs-password-form" data-mypage-password-form method="post">
                            <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}" />
                            <label class="tacs-field-label" for="mypage-current-password">현재 비밀번호</label>
                            <input class="tacs-field-input" type="password" id="mypage-current-password" name="currentPassword" autocomplete="current-password" placeholder="현재 비밀번호 입력" />
                            <p class="tacs-form-help" data-mypage-password-message>현재 비밀번호를 입력한 뒤 확인 버튼을 눌러 주세요.</p>
                            <div class="tacs-button-row">
                                <button type="button" class="tacs-btn tacs-btn-secondary" data-mypage-back>취소</button>
                                <button type="submit" class="tacs-btn tacs-btn-primary">확인</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="tacs-profile-area" data-mypage-profile-area hidden>
                    <div class="tacs-owner-register-form" data-mypage-owner-form hidden>
                        <form class="compact-form tacs-owner-profile-form" data-mypage-profile-form method="post">
                            <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}" />
                            <input type="hidden" data-owner-profile-input="cstmIdfNo" name="cstmIdfNo" />

                            <section class="form-section">
                                <div class="section-head">
                                    <div class="section-head-icon">
                                        <span class="material-symbols-outlined">manage_accounts</span>
                                    </div>
                                    <div>
                                        <div class="section-head-title">계정 정보</div>
                                    </div>
                                </div>

                                <div class="grid-12 account-grid">
                                    <div class="span-4 account-id-field">
                                        <label class="field-label">아이디</label>
                                        <div class="field-row">
                                            <div class="icon-box"><span class="material-symbols-outlined">person</span></div>
                                            <input class="input-box" data-owner-profile-value="loginId" placeholder="아이디" readonly />
                                        </div>
                                    </div>

                                    <div class="span-4 account-pw-field">
                                        <label class="field-label">
                                            비밀번호
                                            <span class="field-optional">(변경 시에만 입력)</span>
                                            <span class="password-rule-inline">8~16자, 영문/숫자/특수문자 중 2종 이상, 공백 불가</span>
                                        </label>
                                        <div class="field-row">
                                            <div class="icon-box"><span class="material-symbols-outlined">lock</span></div>
                                            <div class="input-box password-input-wrap">
                                                <input class="password-input" type="password" name="newPassword" autocomplete="new-password" placeholder="8~16자 입력" maxlength="16" data-owner-new-password />
                                                <button type="button" class="password-toggle" data-owner-password-toggle aria-label="비밀번호 보기">
                                                    <span class="material-symbols-outlined">visibility</span>
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="span-4 account-pw-confirm-field">
                                        <label class="field-label">
                                            비밀번호 확인
                                            <span class="field-feedback" data-owner-password-feedback></span>
                                        </label>
                                        <div class="field-row">
                                            <div class="icon-box"><span class="material-symbols-outlined">lock_reset</span></div>
                                            <div class="input-box password-input-wrap">
                                                <input class="password-input" type="password" name="newPasswordConfirm" autocomplete="new-password" placeholder="비밀번호 재입력" maxlength="16" data-owner-new-password-confirm />
                                                <button type="button" class="password-toggle" data-owner-password-toggle aria-label="비밀번호 확인 보기">
                                                    <span class="material-symbols-outlined">visibility</span>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </section>

                            <section class="form-section">
                                <div class="section-head">
                                    <div class="section-head-icon">
                                        <span class="material-symbols-outlined">assignment_ind</span>
                                    </div>
                                    <div class="section-title-inline">
                                        <div class="section-head-title">화주 기본 정보</div>
                                        <span class="owner-type-badge" data-owner-type-name>법인</span>
                                    </div>
                                </div>

                                <div class="grid-12 owner-basic-grid">
                                    <div class="span-3">
                                        <label class="field-label"><span data-owner-name-label>이름 또는 상호명</span> <span class="required">*</span></label>
                                        <div class="field-row">
                                            <div class="icon-box"><span class="material-symbols-outlined" data-owner-name-icon>person</span></div>
                                            <input class="input-box" data-owner-profile-input="name" name="name" placeholder="이름 또는 상호명 입력" maxlength="300" required />
                                        </div>
                                    </div>

                                    <div class="span-3" data-owner-ident-box>
                                        <label class="field-label">주민등록번호</label>
                                        <div class="field-row ident-no-row is-readonly-row">
                                            <div class="icon-box"><span class="material-symbols-outlined">badge</span></div>
                                            <input class="input-box" data-owner-profile-value="identNoMasked" placeholder="마스킹 표시" readonly />
                                        </div>
                                    </div>

                                    <div class="span-3" data-owner-bizrno-box>
                                        <label class="field-label">사업자등록번호</label>
                                        <div class="field-row">
                                            <div class="icon-box"><span class="material-symbols-outlined">badge</span></div>
                                            <input class="input-box" data-owner-profile-input="bizrno" name="bizrno" placeholder="10자리 숫자" maxlength="12" inputmode="numeric" />
                                        </div>
                                    </div>

                                    <div class="span-3" data-owner-corp-box>
                                        <label class="field-label">법인등록번호</label>
                                        <div class="field-row">
                                            <div class="icon-box"><span class="material-symbols-outlined">corporate_fare</span></div>
                                            <input class="input-box" data-owner-profile-input="corpRegNo" name="corpRegNo" placeholder="13자리 숫자" maxlength="14" inputmode="numeric" />
                                        </div>
                                    </div>
                                </div>
                            </section>

                            <section class="form-section">
                                <div class="section-head">
                                    <div class="section-head-icon">
                                        <span class="material-symbols-outlined">contact_phone</span>
                                    </div>
                                    <div>
                                        <div class="section-head-title">연락처 및 주소</div>
                                    </div>
                                </div>

                                <div class="grid-12 contact-grid">
                                    <div class="span-3 contact-phone-field">
                                        <label class="field-label">휴대전화 <span class="required">*</span></label>
                                        <div class="field-row">
                                            <div class="icon-box"><span class="material-symbols-outlined">smartphone</span></div>
                                            <input class="input-box" data-owner-profile-input="telno" name="telno" placeholder="01012345678" maxlength="13" required readonly />
                                        </div>
                                    </div>

                                    <div class="span-8 owner-sms-auth-field">
                                        <div class="owner-sms-auth" data-owner-sms-auth-area>
                                            <span class="owner-sms-label">SMS 인증</span>
                                            <button type="button" class="side-btn btn-light" data-owner-sms-send disabled>인증번호 발송</button>
                                            <input class="input-box owner-sms-code" name="authCode" data-owner-sms-code maxlength="6" inputmode="numeric" placeholder="6자리" disabled />
                                            <button type="button" class="side-btn btn-dark" data-owner-sms-verify disabled>확인</button>
                                            <p class="owner-sms-message" data-owner-sms-message></p>
                                        </div>
                                    </div>

                                    <div class="span-8 email-field">
                                        <label class="field-label">이메일 <span class="required">*</span></label>
                                        <input data-owner-profile-input="email" name="email" type="hidden" />
                                        <div class="email-row">
                                            <div class="icon-box"><span class="material-symbols-outlined">alternate_email</span></div>
                                            <input class="input-box email-local" data-owner-email-local placeholder="이메일 아이디" maxlength="64" required />
                                            <span class="email-at">@</span>
                                            <input class="input-box email-domain" data-owner-email-domain placeholder="도메인 입력" maxlength="100" required />
                                            <select class="input-box email-select" data-owner-email-domain-select>
                                                <option value="">직접입력</option>
                                                <option value="naver.com">네이버</option>
                                                <option value="kakao.com">카카오</option>
                                                <option value="gmail.com">구글</option>
                                                <option value="nate.com">네이트</option>
                                                <option value="daum.net">다음</option>
                                                <option value="hanmail.net">한메일</option>
                                                <option value="outlook.com">아웃룩</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="span-5 address-fields">
                                        <div>
                                            <label class="field-label">우편번호 <span class="required">*</span></label>
                                            <div class="field-row">
                                                <div class="icon-box"><span class="material-symbols-outlined">markunread_mailbox</span></div>
                                                <input class="input-box" data-owner-profile-input="zip" name="zip" placeholder="34366" maxlength="5" required />
                                                <button type="button" class="side-btn btn-dark" data-owner-address-search>검색</button>
                                            </div>
                                        </div>

                                        <div>
                                            <label class="field-label">기본주소 <span class="required">*</span></label>
                                            <div class="field-row">
                                                <div class="icon-box"><span class="material-symbols-outlined">home_pin</span></div>
                                                <input class="input-box" data-owner-profile-input="adres" name="adres" placeholder="기본주소 입력" maxlength="200" required />
                                            </div>
                                        </div>

                                        <div>
                                            <label class="field-label">상세주소</label>
                                            <div class="field-row">
                                                <div class="icon-box"><span class="material-symbols-outlined">edit_location</span></div>
                                                <input class="input-box" data-owner-profile-input="detailAdres" name="detailAdres" placeholder="상세주소 입력" maxlength="200" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="span-7 contact-map-field">
                                        <div class="address-map">
                                            <div data-owner-address-map></div>
                                            <div class="address-map-placeholder" data-owner-address-map-placeholder>
                                                <div class="address-map-title">
                                                    <span class="material-symbols-outlined">map</span>
                                                    지도 영역
                                                </div>
                                                <div class="address-map-text" data-owner-address-map-text>
                                                    주소 검색에서 선택한 위치가 지도에 표시됩니다.
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </section>

                            <div class="tacs-profile-notice tacs-owner-profile-message" data-mypage-profile-message aria-live="polite"></div>

                            <div class="submit-row">
                                <div class="submit-actions">
                                    <button type="button" class="submit-btn submit-secondary" data-mypage-profile-reset>취소</button>
                                    <span class="submit-tooltip" data-mypage-profile-save-wrap data-disabled-reason="">
                                    <button type="submit" class="submit-btn submit-primary" data-mypage-profile-save disabled>
                                        <span class="material-symbols-outlined text-base">save</span>
                                        수정완료
                                    </button>
                                    </span>
                                </div>
                            </div>
                        </form>
                    </div>

                    <div class="tacs-profile-card tacs-actor-profile-card" data-mypage-generic-form hidden>
                        <div class="tacs-profile-title-row">
                            <div>
                                <p class="tacs-section-label">PROFILE</p>
                                <h2>회원정보 수정</h2>
                            </div>
                            <span class="material-symbols-outlined">badge</span>
                        </div>

                        <form class="tacs-profile-form tacs-actor-profile-form" data-mypage-profile-form method="post">
                            <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}" />
                            <div class="tacs-actor-profile-sections" data-mypage-profile-fields></div>
                            <div class="tacs-button-row tacs-actor-button-row">
                                <button type="button" class="tacs-btn tacs-btn-secondary" data-mypage-profile-reset>취소</button>
                                <button type="submit" class="tacs-btn tacs-btn-primary" data-mypage-profile-save>저장</button>
                            </div>
                        </form>
                    </div>

                    <div class="tacs-password-change-card" data-mypage-password-change-area hidden>
                        <div class="tacs-profile-title-row tacs-password-change-title">
                            <div>
                                <p class="tacs-section-label">PASSWORD</p>
                                <h2>비밀번호 변경</h2>
                                <p>비밀번호 변경은 현재 등록된 휴대폰번호로 SMS 인증을 완료한 뒤 가능합니다.</p>
                            </div>
                            <span class="material-symbols-outlined">sms</span>
                        </div>

                        <div class="tacs-password-phone-box">
                            <span>인증번호 발송 대상</span>
                            <strong data-mypage-password-phone>-</strong>
                            <p>보안을 위해 계정에 등록된 휴대폰번호로만 인증번호가 발송됩니다.</p>
                        </div>

                        <form class="tacs-password-sms-form" data-mypage-sms-send-form method="post">
                            <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}" />
                            <div class="tacs-button-row">
                                <button type="submit" class="tacs-btn tacs-btn-secondary" data-mypage-sms-send>인증번호 발송</button>
                            </div>
                        </form>

                        <form class="tacs-password-sms-form" data-mypage-sms-verify-form method="post">
                            <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}" />
                            <label class="tacs-field-label" for="mypage-sms-auth-code">인증번호</label>
                            <div class="tacs-inline-form-row">
                                <input class="tacs-field-input" type="text" id="mypage-sms-auth-code" name="authCode" maxlength="6" inputmode="numeric" placeholder="숫자 6자리" />
                                <button type="submit" class="tacs-btn tacs-btn-secondary" data-mypage-sms-verify>인증번호 확인</button>
                            </div>
                        </form>

                        <form class="tacs-password-change-form" data-mypage-password-change-form method="post">
                            <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}" />
                            <div class="tacs-profile-grid">
                                <label class="tacs-profile-field">
                                    <span>새 비밀번호</span>
                                    <input class="tacs-field-input" type="password" name="newPassword" autocomplete="new-password" placeholder="8~16자" maxlength="16" disabled />
                                </label>
                                <label class="tacs-profile-field">
                                    <span>새 비밀번호 확인</span>
                                    <input class="tacs-field-input" type="password" name="newPasswordConfirm" autocomplete="new-password" placeholder="새 비밀번호 재입력" maxlength="16" disabled />
                                </label>
                            </div>
                            <p class="tacs-form-help">비밀번호는 8자 이상이며, 영문/숫자/특수문자 중 2종 이상을 조합해야 합니다.</p>
                            <div class="tacs-profile-notice" data-mypage-password-change-message>SMS 인증 후 새 비밀번호를 변경할 수 있습니다.</div>
                            <div class="tacs-button-row">
                                <button type="submit" class="tacs-btn tacs-btn-primary" data-mypage-password-change disabled>비밀번호 변경</button>
                            </div>
                        </form>
                    </div>

                </div>
            </section>

            <section class="tacs-mypage-panel ${mypageTab eq 'alarm' ? 'is-active' : ''}" id="mypage-alarm-panel" data-mypage-panel="alarm">
                <div class="tacs-alarm-pref">
                    <div class="tacs-alarm-pref-head">
                        <p class="tacs-section-label">알림 수신 설정</p>
                        <h2>알림 종류별 수신 여부</h2>
                        <p class="tacs-alarm-pref-desc">끄면 해당 종류의 알림을 더 이상 받지 않습니다. 본인 의뢰 건에만 적용됩니다.</p>
                        <div class="tacs-alarm-pref-bulk">
                            <button type="button" class="tacs-alarm-bulk-btn" data-alarm-bulk="on">전체 켜기</button>
                            <button type="button" class="tacs-alarm-bulk-btn is-off" data-alarm-bulk="off">전체 끄기</button>
                        </div>
                    </div>
                    <ul class="tacs-alarm-pref-list" data-alarm-pref-list>
                        <li class="tacs-alarm-pref-empty" data-alarm-pref-loading>불러오는 중…</li>
                    </ul>
                </div>
            </section>
        </div>
    </section>
</div>
