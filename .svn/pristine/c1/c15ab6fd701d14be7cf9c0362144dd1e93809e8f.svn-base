<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.officer.basicscreen.mapper.IWorkHistoryMapper">

    <!-- ════════════════════════════════════════════════
         보완요청 — SUPP_RQST
         SR_STATUS_CD: REQ(요청중) | SUB(보완제출)
         해지 시 DELETE 처리 (CANCEL 코드 없음)
    ════════════════════════════════════════════════ -->

    <!-- 관세사 ID 조회 -->
    <select id="selectBrokerIdByReqNo"
            parameterType="kr.or.tacs.dto.officer.WorkHistoryDTO"
            resultType="string">
        <choose>
            <when test="refBizCd == 'IMP_RQST'">
                SELECT IR_BROKER_ID FROM IMP_RQST WHERE IR_NO = #{reqNo}
            </when>
            <otherwise>
                SELECT ER_BROKER_ID FROM EXP_RQST WHERE ER_NO = #{reqNo}
            </otherwise>
        </choose>
    </select>

    <!-- 보완요청 등록 -->
    <insert id="insertSupplement" parameterType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        <selectKey keyProperty="srNo" resultType="string" order="BEFORE">
            SELECT 'SR-' || TO_CHAR(SYSDATE, 'YYYYMMDD') || '-'
                   || LPAD(SEQ_SUPP_RQST.NEXTVAL, 4, '0')
            FROM DUAL
        </selectKey>
        INSERT INTO SUPP_RQST (
            SR_NO, SR_REF_BIZ_CD, SR_REF_NO,
            SENDER_ID, SENDER_TY_CD,
            RECEIVER_ID, RECEIVER_TY_CD,
            SR_STATUS_CD, SR_REQ_DT, SR_REQ_CN
        ) VALUES (
            #{srNo}, #{refBizCd}, #{reqNo},
            #{officerId}, 'OFFICER',
            #{receiverId}, 'BROKER',
            'REQ', SYSDATE, #{reason}
        )
    </insert>

    <!-- 보완요청 해지: DELETE (CANCEL 코드 없음) -->
    <delete id="cancelSupplement" parameterType="string">
        DELETE FROM SUPP_RQST WHERE SR_NO = #{srNo}
    </delete>

    <!-- 최근 활성(REQ) 보완요청 조회 -->
    <select id="selectLatestActiveSupplement"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        SELECT
            SR_NO        AS srNo,
            SR_NO        AS workHistoryId,
            SR_REF_NO    AS reqNo,
            'supplement' AS workType,
            'ACTIVE'     AS status
        FROM SUPP_RQST
        WHERE SR_REF_NO    = #{reqNo}
          AND SR_STATUS_CD = 'REQ'
        ORDER BY SR_REQ_DT DESC
        FETCH FIRST 1 ROWS ONLY
    </select>


    <!-- ════════════════════════════════════════════════
         통관보류 — CUSTOMS_STATUS_HISTORY
         CSH_EVENT_TYPE_CD: CSTM_HOLD (CSTM_STATUS 그룹)
         해지 시 DELETE 처리
    ════════════════════════════════════════════════ -->

    <!-- 통관보류 등록 -->
    <insert id="insertHold" parameterType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        <selectKey keyProperty="cshNo" resultType="long" order="BEFORE">
            SELECT SEQ_CUSTOMS_STATUS_HIST.NEXTVAL FROM DUAL
        </selectKey>
        INSERT INTO CUSTOMS_STATUS_HISTORY (
            CSH_PAY_SCHD_NO,
            CSH_SCOPE_CD,
            CSH_EVENT_TYPE_CD,
            CSH_BEFORE_STATUS_CD,
            CSH_AFTER_STATUS_CD,
            CSH_ACTOR_ROLE_CD,
            CSH_PUBLIC_YN,
            CSH_SRC_TABLE_CD,
            CSH_SRC_PK_NO,
            CSH_MSG,
            CSH_DT
        ) VALUES (
            #{cshNo},
            #{scopeCd},
            'CSTM_HOLD',
            'CSTM_INPRG',
            'CSTM_HOLD',
            'OFFICER',
            'N',
            #{refBizCd},
            #{reqNo},
            #{reason},
            SYSDATE
        )
    </insert>

    <!-- 통관보류 해지: DELETE -->
    <delete id="cancelHold" parameterType="long">
        DELETE FROM CUSTOMS_STATUS_HISTORY
         WHERE CSH_PAY_SCHD_NO = #{cshNo}
    </delete>

    <!-- 최근 활성 통관보류 조회 -->
    <select id="selectLatestActiveHold"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        SELECT
            TO_CHAR(CSH_PAY_SCHD_NO) AS workHistoryId,
            CSH_PAY_SCHD_NO          AS cshNo,
            CSH_SRC_PK_NO            AS reqNo,
            'hold'                   AS workType,
            'ACTIVE'                 AS status,
            CSH_SCOPE_CD             AS scopeCd,
            CSH_SRC_TABLE_CD         AS refBizCd
        FROM CUSTOMS_STATUS_HISTORY
        WHERE CSH_SRC_PK_NO    = #{reqNo}
          AND CSH_EVENT_TYPE_CD = 'CSTM_HOLD'
        ORDER BY CSH_DT DESC
        FETCH FIRST 1 ROWS ONLY
    </select>


    <!-- ════════════════════════════════════════════════
         통합 이력 조회 (SUPP_RQST + CUSTOMS_STATUS_HISTORY)
    ════════════════════════════════════════════════ -->
    <select id="selectWorkHistoryList"
            parameterType="string"
            resultType="kr.or.tacs.dto.officer.WorkHistoryDTO">
        SELECT *
          FROM (
              /* 보완요청 이력 */
              SELECT
                  SR_NO                                     AS workHistoryId,
                  'supplement'                              AS workType,
                  SR_REQ_CN                                 AS reason,
                  TO_CHAR(SR_REQ_DT, 'YYYY-MM-DD HH24:MI') AS registDt,
                  CASE SR_STATUS_CD
                      WHEN 'REQ' THEN '진행중'
                      WHEN 'SUB' THEN '보완제출'
                      ELSE SR_STATUS_CD
                  END                                       AS status,
                  SENDER_ID                                 AS officerId,
                  SR_REQ_DT                                 AS sortDt
              FROM SUPP_RQST
              WHERE SR_REF_NO = #{reqNo}

              UNION ALL

              /* 통관보류 이력 */
              SELECT
                  TO_CHAR(CSH_PAY_SCHD_NO)                 AS workHistoryId,
                  'hold'                                    AS workType,
                  CSH_MSG                                   AS reason,
                  TO_CHAR(CSH_DT, 'YYYY-MM-DD HH24:MI')    AS registDt,
                  '진행중'                                   AS status,
                  NULL                                      AS officerId,
                  CSH_DT                                    AS sortDt
              FROM CUSTOMS_STATUS_HISTORY
              WHERE CSH_SRC_PK_NO    = #{reqNo}
                AND CSH_EVENT_TYPE_CD = 'CSTM_HOLD'
          )
        ORDER BY sortDt DESC
    </select>
    
	    <!-- 수입 신고 상태 업데이트 -->
	<update id="updateImpDeclStatus">
	    UPDATE IMP_DCLR
	       SET ID_STATUS_CD = #{statusCd}
	     WHERE ID_IR_NO = #{reqNo}
	</update>
	
	<!-- 수출 신고 상태 업데이트 -->
	<update id="updateExpDeclStatus">
	    UPDATE EXP_DCLR
	       SET ED_STATUS_CD = #{statusCd}
	     WHERE ED_ER_NO = #{reqNo}
	</update>

</mapper>