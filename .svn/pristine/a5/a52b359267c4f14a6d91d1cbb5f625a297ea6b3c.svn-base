<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.broker.status.mapper.IStatusMapper">

   <select id="selectImportDeclareCount" resultType="int">
		    SELECT COUNT(*)
		      FROM imp_dclr id
		      JOIN imp_rqst ir
		        ON ir.ir_no = id.id_ir_no
		     WHERE ir.ir_broker_id = #{brokerId}
		
		    <if test="pageDTO.keyword != null and pageDTO.keyword != ''">
		        <choose>
		            <when test="pageDTO.searchType == 'irNo'">
		                AND id.id_ir_no LIKE '%' || #{pageDTO.keyword} || '%'
		            </when>
		            <when test="pageDTO.searchType == 'owner'">
		                AND (
		                    id.id_impr_nm LIKE '%' || #{pageDTO.keyword} || '%'
		                    OR ir.ir_owr_id LIKE '%' || #{pageDTO.keyword} || '%'
		                )
		            </when>
		            <when test="pageDTO.searchType == 'item'">
		                AND EXISTS (
		                    SELECT 1
		                      FROM imp_dclr_item si
		                     WHERE si.idi_ir_no = id.id_ir_no
		                       AND (
		                           si.idi_dclr_gdsnm LIKE '%' || #{pageDTO.keyword} || '%'
		                           OR si.idi_trdng_gdsnm LIKE '%' || #{pageDTO.keyword} || '%'
		                           OR si.idi_hs_cd LIKE '%' || #{pageDTO.keyword} || '%'
		                       )
		                )
		            </when>
		            <otherwise>
		                AND (
		                    id.id_ir_no LIKE '%' || #{pageDTO.keyword} || '%'
		                    OR id.id_impr_nm LIKE '%' || #{pageDTO.keyword} || '%'
		                    OR ir.ir_owr_id LIKE '%' || #{pageDTO.keyword} || '%'
		                    OR EXISTS (
		                        SELECT 1
		                          FROM imp_dclr_item si
		                         WHERE si.idi_ir_no = id.id_ir_no
		                           AND (
		                               si.idi_dclr_gdsnm LIKE '%' || #{pageDTO.keyword} || '%'
		                               OR si.idi_trdng_gdsnm LIKE '%' || #{pageDTO.keyword} || '%'
		                               OR si.idi_hs_cd LIKE '%' || #{pageDTO.keyword} || '%'
		                           )
		                    )
		                )
		            </otherwise>
		        </choose>
		    </if>
		
		    <if test="pageDTO.statusCd != null and pageDTO.statusCd != ''">
		        AND id.id_status_cd = #{pageDTO.statusCd}
		    </if>
		
		    <if test="pageDTO.startDate != null and pageDTO.startDate != ''">
		        AND TRUNC(NVL(id.id_dclr_dt, id.id_regist_dt)) <![CDATA[>=]]> TO_DATE(#{pageDTO.startDate}, 'YYYY-MM-DD')
		    </if>
		
		    <if test="pageDTO.endDate != null and pageDTO.endDate != ''">
		        AND TRUNC(NVL(id.id_dclr_dt, id.id_regist_dt)) <![CDATA[<=]]> TO_DATE(#{pageDTO.endDate}, 'YYYY-MM-DD')
		    </if>
		</select>
		
		
		<select id="selectImportDeclareList" resultType="map">
		    SELECT *
		      FROM (
		        SELECT ROWNUM AS RN, base.*
		          FROM (
		            SELECT
		                id.id_ir_no AS IDIRNO,
		                id.id_status_cd AS IDSTATUSCD,
		                CASE id.id_status_cd
		                    WHEN 'TEMP' THEN '임시저장'
		                    WHEN 'SUBMIT' THEN '신고제출'
		                    WHEN 'CSTM_INPRG' THEN '세관심사중'
		                    WHEN 'CSTM_ACPT' THEN '수리'
		                    WHEN 'CSTM_REJ' THEN '반려'
		                    ELSE id.id_status_cd
		                END AS IDSTATUSNM,
		                TO_CHAR(NVL(id.id_dclr_dt, id.id_regist_dt), 'YYYY-MM-DD') AS IDDCLRDTSTR,
		                id.id_impr_nm AS IDIMPRNM,
		                ir.ir_owr_id AS IROWRID,
		                ir.ir_broker_id AS IRBROKERID,
		                ir.ir_bl_awb_no AS IRBLAWBNO,
		                NVL(p.port_nm, ir.ir_arrv_port_cd) AS ARRVPORTNM,
		                item.main_item_nm AS MAINITEMNM,
		                item.main_hs_cd AS MAINHSCD,
		                NVL(item.item_cnt, 0) AS ITEMCNT
		              FROM imp_dclr id
		              JOIN imp_rqst ir
		                ON ir.ir_no = id.id_ir_no
		              LEFT JOIN port p
		                ON p.port_cd = ir.ir_arrv_port_cd
		               AND p.port_use_yn = 'Y'
		              LEFT JOIN (
		                    SELECT
		                        idi_ir_no,
		                        MIN(idi_dclr_gdsnm) KEEP (DENSE_RANK FIRST ORDER BY idi_sn) AS main_item_nm,
		                        MIN(idi_hs_cd) KEEP (DENSE_RANK FIRST ORDER BY idi_sn) AS main_hs_cd,
		                        COUNT(*) AS item_cnt
		                      FROM imp_dclr_item
		                     GROUP BY idi_ir_no
		              ) item
		                ON item.idi_ir_no = id.id_ir_no
		             WHERE ir.ir_broker_id = #{brokerId}
		
		            <if test="pageDTO.keyword != null and pageDTO.keyword != ''">
		                <choose>
		                    <when test="pageDTO.searchType == 'irNo'">
		                        AND id.id_ir_no LIKE '%' || #{pageDTO.keyword} || '%'
		                    </when>
		                    <when test="pageDTO.searchType == 'owner'">
		                        AND (
		                            id.id_impr_nm LIKE '%' || #{pageDTO.keyword} || '%'
		                            OR ir.ir_owr_id LIKE '%' || #{pageDTO.keyword} || '%'
		                        )
		                    </when>
		                    <when test="pageDTO.searchType == 'item'">
		                        AND EXISTS (
		                            SELECT 1
		                              FROM imp_dclr_item si
		                             WHERE si.idi_ir_no = id.id_ir_no
		                               AND (
		                                   si.idi_dclr_gdsnm LIKE '%' || #{pageDTO.keyword} || '%'
		                                   OR si.idi_trdng_gdsnm LIKE '%' || #{pageDTO.keyword} || '%'
		                                   OR si.idi_hs_cd LIKE '%' || #{pageDTO.keyword} || '%'
		                               )
		                        )
		                    </when>
		                    <otherwise>
		                        AND (
		                            id.id_ir_no LIKE '%' || #{pageDTO.keyword} || '%'
		                            OR id.id_impr_nm LIKE '%' || #{pageDTO.keyword} || '%'
		                            OR ir.ir_owr_id LIKE '%' || #{pageDTO.keyword} || '%'
		                            OR EXISTS (
		                                SELECT 1
		                                  FROM imp_dclr_item si
		                                 WHERE si.idi_ir_no = id.id_ir_no
		                                   AND (
		                                       si.idi_dclr_gdsnm LIKE '%' || #{pageDTO.keyword} || '%'
		                                       OR si.idi_trdng_gdsnm LIKE '%' || #{pageDTO.keyword} || '%'
		                                       OR si.idi_hs_cd LIKE '%' || #{pageDTO.keyword} || '%'
		                                   )
		                            )
		                        )
		                    </otherwise>
		                </choose>
		            </if>
		
		            <if test="pageDTO.statusCd != null and pageDTO.statusCd != ''">
		                AND id.id_status_cd = #{pageDTO.statusCd}
		            </if>
		
		            <if test="pageDTO.startDate != null and pageDTO.startDate != ''">
		                AND TRUNC(NVL(id.id_dclr_dt, id.id_regist_dt)) <![CDATA[>=]]> TO_DATE(#{pageDTO.startDate}, 'YYYY-MM-DD')
		            </if>
		
		            <if test="pageDTO.endDate != null and pageDTO.endDate != ''">
		                AND TRUNC(NVL(id.id_dclr_dt, id.id_regist_dt)) <![CDATA[<=]]> TO_DATE(#{pageDTO.endDate}, 'YYYY-MM-DD')
		            </if>
		
		             ORDER BY NVL(id.id_dclr_dt, id.id_regist_dt) DESC
		          ) base
		         WHERE ROWNUM <![CDATA[<=]]> #{pageDTO.endRow}
		      )
		     WHERE RN <![CDATA[>=]]> #{pageDTO.startRow}
		</select>

        <select id="selectImportDeclareDetail" resultType="map">
        SELECT
            id.id_ir_no AS IDIRNO,
            id.id_status_cd AS IDSTATUSCD,
            CASE id.id_status_cd
                WHEN 'TEMP' THEN '임시저장'
                WHEN 'SUBMIT' THEN '신고제출'
                WHEN 'CSTM_INPRG' THEN '세관심사중'
                WHEN 'CSTM_ACPT' THEN '수리'
                WHEN 'CSTM_REJ' THEN '반려'
                ELSE id.id_status_cd
            END AS IDSTATUSNM,
            id.id_dclrnt_nm AS IDDCLRNTNM,
            id.id_dclrnt_eml AS IDDCLRNTEML,
            id.id_dclrnt_telno AS IDDCLRNTTELNO,
            id.id_impr_nm AS IDIMPRNM,
            id.id_impr_clnc_cd AS IDIMPRCLNCCD,
            id.id_taxpyr_idnt_se AS IDTAXPYRIDNTSE,
            id.id_taxpyr_idnt_no AS IDTAXPYRIDNTNO,
            id.id_taxpyr_zip AS IDTAXPYRZIP,
            id.id_taxpyr_addr AS IDTAXPYRADDR,
            id.id_taxpyr_dtl_addr AS IDTAXPYRDTLADDR,
            id.id_ovrss_nm AS IDOVRSSNM,
            id.id_ovrss_cd AS IDOVRSSCD,
            id.id_ovrss_cntry_cd AS IDOVRSSCNTRYCD,
            id.id_tot_pkg_cnt AS IDTOTPKGCNT,
            id.id_tot_wt AS IDTOTWT,
            id.id_stlm_amt AS IDSTLMAMT,
            id.id_tot_tax_amt AS IDTOTTAXAMT,
            TO_CHAR(id.id_dclr_dt, 'YYYY-MM-DD HH24:MI') AS IDDCLRDTSTR,
            ir.ir_no AS IRNO,
            ir.ir_owr_id AS IROWRID,
            ir.ir_broker_id AS IRBROKERID,
            ir.ir_bl_awb_no AS IRBLAWBNO,
            ir.ir_arrv_port_cd AS IRARRVPORTCD,
            NVL(p.port_nm, ir.ir_arrv_port_cd) AS ARRVPORTNM
        FROM imp_dclr id
             JOIN imp_rqst ir
               ON ir.ir_no = id.id_ir_no
             LEFT JOIN port p
               ON p.port_cd = ir.ir_arrv_port_cd
              AND p.port_use_yn = 'Y'
        WHERE id.id_ir_no = #{idIrNo}
          AND ir.ir_broker_id = #{brokerId}
    </select>


            <select id="selectImportDeclareItemList" resultType="map">
        SELECT
            idi_sn AS IDISN,
            idi_ir_no AS IDIIRNO,
            idi_status_cd AS IDISTATUSCD,
            CASE idi_status_cd
                WHEN 'ITEM_DCLR' THEN '품목 신고'
                WHEN 'ITEM_REVIEW' THEN '심사중'
                WHEN 'ITEM_SUPP_REQ' THEN '보완요청'
                WHEN 'ITEM_SUPP_SUB' THEN '보완제출'
                WHEN 'ITEM_ACPT' THEN '수리'
                WHEN 'ITEM_REJ' THEN '반려'
                ELSE idi_status_cd
            END AS IDISTATUSNM,
            idi_hs_cd AS IDIHSCD,
            idi_dclr_gdsnm AS IDIDCLRGDSNM,
            idi_trdmk_nm AS IDITRDMKNM,
            idi_trdng_gdsnm AS IDITRDNGGDSNM,
            idi_qty AS IDIQTY,
            idi_qty_unit_cd AS IDIQTYUNITCD,
            idi_net_wt AS IDINETWT,
            idi_taxt_prc_krw AS IDITAXTPRCKRW,
            idi_orgn_cntry_cd AS IDIORGNCNTRYCD
        FROM imp_dclr_item
        WHERE idi_ir_no = #{idIrNo}
        ORDER BY idi_sn
    </select>

            <select id="selectImportDeclareMdlspecList" resultType="map">
        SELECT
            idim_sn AS IDIMSN,
            idim_ir_no AS IDIMIRNO,
            idim_mdlspec_sn AS IDIMMDLSPECSN,
            idim_mdlspec_no AS IDIMMDLSPECNO,
            idim_mdlspec_nm AS IDIMMDLSPECNM,
            idim_qty1 AS IDIMQTY1,
            idim_qty1_unit_cd AS IDIMQTY1UNITCD,
            idim_qty2 AS IDIMQTY2,
            idim_qty2_unit_cd AS IDIMQTY2UNITCD,
            idim_unit_prc AS IDIMUNITPRC,
            idim_amt AS IDIMAMT
        FROM imp_dclr_item_mdlspec
        WHERE idim_ir_no = #{idIrNo}
        ORDER BY idim_sn, idim_mdlspec_sn
    </select>
    
    
		        <select id="selectSupplementItem" resultType="map">
        SELECT
            item.idi_sn AS IDISN,
            item.idi_ir_no AS IDIIRNO,
            item.idi_status_cd AS IDISTATUSCD,
            CASE item.idi_status_cd
                WHEN 'ITEM_DCLR' THEN '품목 신고'
                WHEN 'ITEM_REVIEW' THEN '심사중'
                WHEN 'ITEM_SUPP_REQ' THEN '보완요청'
                WHEN 'ITEM_SUPP_SUB' THEN '보완제출'
                WHEN 'ITEM_ACPT' THEN '수리'
                WHEN 'ITEM_REJ' THEN '반려'
                ELSE item.idi_status_cd
            END AS IDISTATUSNM,
            item.idi_hs_cd AS IDIHSCD,
            item.idi_dclr_gdsnm AS IDIDCLRGDSNM,
            item.idi_trdmk_nm AS IDITRDMKNM,
            item.idi_trdng_gdsnm AS IDITRDNGGDSNM,
            item.idi_taxt_prc_krw AS IDITAXTPRCKRW,
            item.idi_net_wt AS IDINETWT,
            item.idi_qty AS IDIQTY,
            item.idi_qty_unit_cd AS IDIQTYUNITCD,
            item.idi_orgn_cntry_cd AS IDIORGNCNTRYCD
        FROM imp_dclr_item item
             JOIN imp_rqst ir
               ON ir.ir_no = item.idi_ir_no
        WHERE item.idi_ir_no = #{idIrNo}
          AND item.idi_sn = #{idiSn}
          AND ir.ir_broker_id = #{brokerId}
    </select>
	
	
	        <select id="selectSupplementMdlspecList" resultType="map">
        SELECT
            idim_sn AS IDIMSN,
            idim_ir_no AS IDIMIRNO,
            idim_mdlspec_sn AS IDIMMDLSPECSN,
            idim_mdlspec_no AS IDIMMDLSPECNO,
            idim_mdlspec_nm AS IDIMMDLSPECNM,
            idim_qty1 AS IDIMQTY1,
            idim_qty1_unit_cd AS IDIMQTY1UNITCD,
            idim_unit_prc AS IDIMUNITPRC,
            idim_amt AS IDIMAMT
        FROM imp_dclr_item_mdlspec
        WHERE idim_ir_no = #{idIrNo}
          AND idim_sn = #{idiSn}
        ORDER BY idim_mdlspec_sn
    </select>
	
	
	<update id="updateSupplementItem" parameterType="map">
	    UPDATE imp_dclr_item
	       SET idi_hs_cd          = #{idiHsCd},
	           idi_dclr_gdsnm     = #{idiDclrGdsnm},
	           idi_trdng_gdsnm    = #{idiTrdngGdsnm},
	           idi_trdmk_nm       = #{idiTrdmkNm},
	           idi_qty            = #{idiQty},
	           idi_qty_unit_cd    = #{idiQtyUnitCd},
	           idi_net_wt         = #{idiNetWt},
	           idi_taxt_prc_krw   = #{idiTaxtPrcKrw},
	           idi_orgn_cntry_cd  = #{idiOrgnCntryCd},
	           idi_updt_dt        = SYSDATE
	     WHERE idi_ir_no = #{idIrNo}
	       AND idi_sn = #{idiSn}
	       AND idi_status_cd = 'ITEM_SUPP_REQ'
	</update>
	
	
	<delete id="deleteSupplementMdlspecByItem">
	    DELETE FROM imp_dclr_item_mdlspec
	     WHERE idim_ir_no = #{idIrNo}
	       AND idim_sn = #{idiSn}
	</delete>
	
	
	<insert id="insertSupplementMdlspec" parameterType="map">
    INSERT INTO imp_dclr_item_mdlspec (
        idim_sn,
        idim_mdlspec_sn,
        idim_ir_no,
        idim_mdlspec_no,
        idim_mdlspec_nm,
        idim_qty1,
        idim_qty1_unit_cd,
        idim_unit_prc,
        idim_amt
    ) VALUES (
        #{idimSn},
        (
            SELECT NVL(MAX(m.idim_mdlspec_sn), 0) + 1
              FROM imp_dclr_item_mdlspec m
             WHERE m.idim_ir_no = #{idimIrNo}
               AND m.idim_sn = #{idimSn}
        ),
        #{idimIrNo},
        #{idimMdlspecNo},
        #{idimMdlspecNm},
        #{idimQty1},
        #{idimQty1UnitCd},
        #{idimUnitPrc},
        #{idimAmt}
    )
</insert>
	
	
	
	<!-- 수수료 청구 관리 목록 -->
<select id="selectTaxList" resultType="map">
    SELECT
        id.id_ir_no AS IDIRNO,
        id.id_impr_nm AS IDIMPRNM,
        ir.ir_owr_id AS IROWRID,
        NVL(item.main_item_nm, '-') AS MAINITEMNM,

        id.id_status_cd AS IDSTATUSCD,
        CASE id.id_status_cd
            WHEN 'CSTM_ACPT' THEN '수리완료'
            WHEN 'CSTM_INPRG' THEN '세관심사중'
            WHEN 'CSTM_REJ' THEN '반려'
            ELSE id.id_status_cd
        END AS IDSTATUSNM,

        TO_CHAR(id.id_aprv_dt, 'YYYY-MM-DD') AS IDAPRVDTSTR,
        id.id_tot_tax_amt AS IDTOTTAXAMT,
        id.id_stlm_amt AS IDSTLMAMT,

        /* 관세사 수수료 예시 계산
           - 기본수수료 30,000원
           - 신고 결제금액의 0.15%
           - 최소 30,000원 보장
           추후 실제 요율 정책 생기면 여기만 변경
        */
        GREATEST(
            30000,
            ROUND(NVL(id.id_stlm_amt, 0) * 0.0015)
        ) AS BROKERFEEAMT,

        ROUND(
            GREATEST(30000, ROUND(NVL(id.id_stlm_amt, 0) * 0.0015)) * 0.1
        ) AS BROKERFEEVATAMT,

        GREATEST(
            30000,
            ROUND(NVL(id.id_stlm_amt, 0) * 0.0015)
        )
        +
        ROUND(
            GREATEST(30000, ROUND(NVL(id.id_stlm_amt, 0) * 0.0015)) * 0.1
        ) AS BROKERFEETOTALAMT,

        '청구대기' AS FEECHARGESTATUSNM

    FROM imp_dclr id
         JOIN imp_rqst ir
           ON ir.ir_no = id.id_ir_no
         LEFT JOIN (
            SELECT
                idi_ir_no,
                MIN(idi_dclr_gdsnm) KEEP (DENSE_RANK FIRST ORDER BY idi_sn) AS main_item_nm
            FROM imp_dclr_item
            GROUP BY idi_ir_no
         ) item
           ON item.idi_ir_no = id.id_ir_no
    WHERE ir.ir_broker_id = #{brokerId}
      AND id.id_status_cd = 'CSTM_ACPT'
    ORDER BY id.id_aprv_dt DESC NULLS LAST, id.id_ir_no DESC
</select>


<!-- 신고필증 관리 목록 -->
<select id="selectCertList" resultType="map">
    SELECT
        ci.ci_no AS CINO,
        ci.ci_dclr_type_cd AS CIDCLRTYPECD,
        CASE ci.ci_dclr_type_cd
            WHEN 'IMPORT' THEN '수입'
            WHEN 'EXPORT' THEN '수출'
            ELSE ci.ci_dclr_type_cd
        END AS CIDCLRTYPENM,
        ci.ci_dclr_no AS CIDCLRNO,
        ci.tfg_no AS TFGNO,
        ci.ci_status_cd AS CISTATUSCD,
        CASE ci.ci_status_cd
            WHEN 'CERT_ISSUED' THEN '발급완료'
			WHEN 'CERT_REISSUED' THEN '재발급'
			WHEN 'CERT_CANCELLED' THEN '취소'
            ELSE ci.ci_status_cd
        END AS CISTATUSNM,
        TO_CHAR(ci.ci_issue_dt, 'YYYY-MM-DD') AS CIISSUEDTSTR,

        id.id_ir_no AS IDIRNO,
        id.id_impr_nm AS IDIMPRNM,
        ir.ir_owr_id AS IROWRID,
        ir.ir_broker_id AS IRBROKERID,
        NVL(item.main_item_nm, '-') AS MAINITEMNM,
        NVL(item.main_hs_cd, '-') AS MAINHSCD,
        NVL(id.id_mbl_no, ir.ir_bl_awb_no) AS BLNO,

        id.id_tot_tax_amt AS IDTOTTAXAMT,
        CASE
            WHEN id.id_tot_tax_amt IS NULL THEN '-'
            ELSE TO_CHAR(id.id_tot_tax_amt, 'FM999,999,999,999,999') || '원'
        END AS IDTOTTAXAMTSTR,

        NVL(ct.ct_pay_status_cd, 'NONE') AS CTPAYSTATUSCD,
        CASE
            WHEN ct.ct_no IS NULL THEN '확인필요'
            WHEN ct.ct_pay_done_yn = 'Y' THEN '납부완료'
            WHEN ct.ct_pay_status_cd = 'PAID' THEN '납부완료'
            WHEN ct.ct_pay_status_cd = 'PARTIAL' THEN '분납중'
            ELSE '미납'
        END AS CTPAYSTATUSNM,

        '미전달' AS SENDSTATUSNM
    FROM cert_insurance ci
         JOIN imp_dclr id
           ON id.id_ir_no = ci.ci_dclr_no
         JOIN imp_rqst ir
           ON ir.ir_no = id.id_ir_no
         LEFT JOIN (
            SELECT
                idi_ir_no,
                MIN(idi_dclr_gdsnm) KEEP (DENSE_RANK FIRST ORDER BY idi_sn) AS main_item_nm,
                MIN(idi_hs_cd) KEEP (DENSE_RANK FIRST ORDER BY idi_sn) AS main_hs_cd
            FROM imp_dclr_item
            GROUP BY idi_ir_no
         ) item
           ON item.idi_ir_no = id.id_ir_no
         LEFT JOIN customs_tax ct
           ON ct.ct_sttemnt_id = id.id_ir_no
          AND ct.ct_type_cd = 'IMPORT'
    WHERE ci.ci_dclr_type_cd = 'IMPORT'
      AND ir.ir_broker_id = #{brokerId}

      <if test="pageDTO.keyword != null and pageDTO.keyword != ''">
        AND (
            ci.ci_no LIKE '%' || #{pageDTO.keyword} || '%'
            OR ci.ci_dclr_no LIKE '%' || #{pageDTO.keyword} || '%'
            OR id.id_impr_nm LIKE '%' || #{pageDTO.keyword} || '%'
            OR ir.ir_owr_id LIKE '%' || #{pageDTO.keyword} || '%'
            OR item.main_item_nm LIKE '%' || #{pageDTO.keyword} || '%'
        )
      </if>

      <if test="pageDTO.statusCd != null and pageDTO.statusCd != '' and pageDTO.statusCd != 'ALL'">
        AND ci.ci_status_cd = #{pageDTO.statusCd}
      </if>

    ORDER BY ci.ci_issue_dt DESC NULLS LAST, ci.ci_no DESC
</select>

<update id="updateItemStatusToSuppSub">
    UPDATE imp_dclr_item
       SET idi_status_cd = 'ITEM_SUPP_SUB',
           idi_updt_dt = SYSDATE
     WHERE idi_ir_no = #{idIrNo}
       AND idi_sn = #{idiSn}
</update>


<!-- ============================================================
     세금납부 · 화주청구 관리
     ============================================================ -->

<select id="selectTaxChargeList" resultType="map">
    SELECT
        ct.ct_no AS CTNO,
        ir.ir_no AS IRNO,
        ir.ir_owr_id AS OWRID,
        ow.owr_nm AS OWRNM,
        ir.ir_broker_id AS BROKERID,

        ir.ir_status_cd AS IRSTATUSCD,
        CASE ir.ir_status_cd
            WHEN 'CSTM_TAX_REQ' THEN '결제요청'
            WHEN 'CSTM_TAX_PAID' THEN '결제완료'
            WHEN 'CSTM_DONE' THEN '완료'
            WHEN 'CSTM_ACPT' THEN '수리완료'
            ELSE ir.ir_status_cd
        END AS IRSTATUSNM,

        CASE
            WHEN ir.ir_status_cd = 'CSTM_TAX_REQ' THEN '청구완료'
            WHEN ir.ir_status_cd = 'CSTM_TAX_PAID' THEN '결제완료'
            WHEN ir.ir_status_cd = 'CSTM_DONE' THEN '완료'
            WHEN bc.bc_no IS NULL THEN '미청구'
            ELSE '청구완료'
        END AS CHARGESTATUSNM,

        NVL(item.repr_item_nm, '-') AS REPRITEMNM,

        NVL(d.id_tot_taxt_prc_krw, NVL(d.id_stlm_amt, ct.ct_total_tax_amt)) AS DCLRAMT,

        ct.ct_duty_amt AS DUTYAMT,
        ct.ct_vat_amt AS VATAMT,
        ct.ct_total_tax_amt AS TAXAMT,
        ct.ct_pay_ddline_dt AS PAYDDLINEDT,
        ct.ct_pay_status_cd AS TAXPAYSTATUSCD,
        ct.ct_pay_done_yn AS TAXPAYDONEYN,

        bc.bc_no AS BCNO,
        bc.bc_status_cd AS BCSTATUSCD,
        bc.bc_broker_fee_amt AS BROKERFEEAMT,
        bc.bc_fee_vat_amt AS FEEVATAMT,
        bc.bc_total_amt AS TOTALAMT,
        bc.bc_charge_dt AS CHARGEDT,

        bfp.bfp_no AS BFPNO,
        bfp.bfp_policy_nm AS BFPPOLICYNM,
        bfp.bfp_base_fee_amt AS BFPBASEFEEAMT,
        bfp.bfp_rate AS BFPRATE,
        bfp.bfp_min_fee_amt AS BFPMINFEEAMT,
        bfp.bfp_max_fee_amt AS BFPMAXFEEAMT,
        bfp.bfp_vat_rate AS BFPVATRATE,
        bfp.bfp_min_dclr_amt AS BFPMINDCLRAMT,
        bfp.bfp_max_dclr_amt AS BFPMAXDCLRAMT

    FROM customs_tax ct
    JOIN imp_rqst ir
      ON ir.ir_no = ct.ct_sttemnt_id
    LEFT JOIN imp_dclr d
      ON d.id_ir_no = ir.ir_no
    LEFT JOIN owner ow
      ON ow.owr_id = ir.ir_owr_id
    LEFT JOIN (
        SELECT
            idi_ir_no,
            MIN(idi_dclr_gdsnm) KEEP (DENSE_RANK FIRST ORDER BY idi_sn) AS repr_item_nm
        FROM imp_dclr_item
        GROUP BY idi_ir_no
    ) item
      ON item.idi_ir_no = ir.ir_no
    LEFT JOIN broker_charge bc
      ON bc.bc_ir_no = ir.ir_no
     AND bc.bc_ct_no = ct.ct_no
    LEFT JOIN broker_fee_policy bfp
      ON bfp.bfp_no = bc.bc_bfp_no
    WHERE ir.ir_broker_id = #{brokerId}

      <choose>
        <when test="pageDTO != null and pageDTO.statusCd == 'CSTM_DONE'">
          AND ir.ir_status_cd = 'CSTM_DONE'
        </when>

        <when test="pageDTO != null and pageDTO.statusCd == 'CSTM_TAX_REQ'">
          AND ir.ir_status_cd = 'CSTM_TAX_REQ'
        </when>

        <when test="pageDTO != null and pageDTO.statusCd == 'CSTM_TAX_PAID'">
          AND ir.ir_status_cd = 'CSTM_TAX_PAID'
        </when>

        <when test="pageDTO != null and pageDTO.statusCd == 'UNBILLED'">
          AND bc.bc_no IS NULL
          AND NVL(ir.ir_status_cd, 'NONE') != 'CSTM_DONE'
        </when>

        <otherwise>
          AND NVL(ir.ir_status_cd, 'NONE') != 'CSTM_DONE'
        </otherwise>
      </choose>

    ORDER BY ct.ct_crt_dt DESC NULLS LAST, ir.ir_no DESC
</select>







<select id="countBrokerChargeByTax" resultType="int">
    SELECT COUNT(*)
      FROM broker_charge
     WHERE bc_ir_no = #{irNo}
       AND bc_ct_no = #{ctNo}
</select>



<update id="updateImpRqstStatus">
    UPDATE imp_rqst
       SET ir_status_cd = #{statusCd}
     WHERE ir_no = #{irNo}
       AND ir_broker_id = #{brokerId}
</update>

<update id="updateImpRqstStatusToDone">
    UPDATE imp_rqst
       SET ir_status_cd = 'CSTM_DONE'
     WHERE ir_no = #{irNo}
       AND ir_broker_id = #{brokerId}
       AND ir_status_cd = 'CSTM_TAX_PAID'
</update>

<select id="selectChargeSourceForCreate" resultType="map">
    SELECT
        ct.ct_no AS CTNO,
        ir.ir_no AS IRNO,
        ir.ir_owr_id AS OWRID,
        ir.ir_broker_id AS BROKERID,
        NVL(d.id_tot_taxt_prc_krw, NVL(d.id_stlm_amt, ct.ct_total_tax_amt)) AS DCLRAMT,
        ct.ct_total_tax_amt AS TAXAMT
    FROM customs_tax ct
    JOIN imp_rqst ir
      ON ir.ir_no = ct.ct_sttemnt_id
    LEFT JOIN imp_dclr d
      ON d.id_ir_no = ir.ir_no
    WHERE ir.ir_no = #{irNo}
      AND ct.ct_no = #{ctNo}
      AND ir.ir_broker_id = #{brokerId}
</select>


<select id="selectBrokerFeePolicyByAmount" resultType="map">
    SELECT
        bfp_no AS BFPNO,
        bfp_biz_type_cd AS BFPBIZTYPECD,
        bfp_policy_nm AS BFPPOLICYNM,
        bfp_base_fee_amt AS BFPBASEFEEAMT,
        bfp_rate AS BFPRATE,
        bfp_min_fee_amt AS BFPMINFEEAMT,
        bfp_max_fee_amt AS BFPMAXFEEAMT,
        bfp_vat_rate AS BFPVATRATE,
        bfp_min_dclr_amt AS BFPMINDCLRAMT,
        bfp_max_dclr_amt AS BFPMAXDCLRAMT
    FROM broker_fee_policy
    WHERE bfp_biz_type_cd = 'IMPORT'
      AND bfp_use_yn = 'Y'
      AND #{dclrAmt} <![CDATA[>=]]> NVL(bfp_min_dclr_amt, 0)
      AND (
            bfp_max_dclr_amt IS NULL
            OR #{dclrAmt} <![CDATA[<=]]> bfp_max_dclr_amt
          )
    ORDER BY bfp_min_dclr_amt DESC
    FETCH FIRST 1 ROW ONLY
</select>


<insert id="insertBrokerCharge" parameterType="map">
    INSERT INTO broker_charge (
        bc_no,
        bc_ct_no,
        bc_ir_no,
        bc_owr_id,
        bc_broker_id,
        bc_bfp_no,
        bc_tax_amt,
        bc_broker_fee_amt,
        bc_fee_vat_amt,
        bc_total_amt,
        bc_status_cd,
        bc_order_nm,
        bc_payment_id,
        bc_charge_dt,
        bc_regist_dt
    ) VALUES (
        #{bcNo},
        #{ctNo},
        #{irNo},
        #{owrId},
        #{brokerId},
        #{bfpNo},
        #{taxAmt},
        #{brokerFeeAmt},
        #{feeVatAmt},
        #{totalAmt},
        'BC_CHARGED',
        #{orderNm},
        #{paymentId},
        SYSDATE,
        SYSDATE
    )
</insert>






   

    <select id="selectCertDetail" resultType="kr.or.tacs.vo.broker.status.StatusCertVO">
        SELECT *
        FROM (
            SELECT
                ci.CI_NO AS ciNo,
                ci.CI_DCLR_TYPE_CD AS ciDclrTypeCd,
                CASE ci.CI_DCLR_TYPE_CD
                    WHEN 'IMPORT' THEN '수입'
                    WHEN 'EXPORT' THEN '수출'
                    ELSE ci.CI_DCLR_TYPE_CD
                END AS ciDclrTypeNm,
                ci.CI_DCLR_NO AS ciDclrNo,
                ci.TFG_NO AS tfgNo,
                ci.CI_STATUS_CD AS ciStatusCd,
                CASE ci.CI_STATUS_CD
                    WHEN 'ISSUED' THEN '발급완료'
                    WHEN 'REISSUED' THEN '재발급'
                    WHEN 'CANCELLED' THEN '취소'
                    ELSE ci.CI_STATUS_CD
                END AS ciStatusNm,
                TO_CHAR(ci.CI_ISSUE_DT, 'YYYY-MM-DD HH24:MI') AS ciIssueDtText,

                ir.IR_OWR_ID AS ownerId,
                NVL(ow.OWR_NM, id.ID_IMPR_NM) AS ownerNm,
                ow.OWR_BIZRNO AS ownerBizrno,
                NVL(ow.OWR_CSTM_IDF_NO, ir.IR_CSTM_IDF_NO) AS ownerCstmIdfNo,

                ir.IR_BROKER_ID AS brokerId,
                br.BROKER_NM AS brokerNm,

                NVL(MIN(item.IDI_DCLR_GDSNM), '-') AS itemNm,
                NVL(MIN(item.IDI_HS_CD), '-') AS hsCd,
                NVL(id.ID_MBL_NO, ir.IR_BL_AWB_NO) AS blNo,
                id.ID_TOT_TAX_AMT AS totalTaxAmt,
                CASE
                    WHEN id.ID_TOT_TAX_AMT IS NULL THEN '-'
                    ELSE TO_CHAR(id.ID_TOT_TAX_AMT, 'FM999,999,999,999,999') || '원'
                END AS totalTaxAmtText,

                CASE
                    WHEN tax.CT_PAY_STATUS_CD = 'PAID' THEN '납부완료'
                    WHEN tax.CT_PAY_STATUS_CD = 'PARTIAL' THEN '분납중'
                    WHEN tax.CT_PAY_STATUS_CD = 'UNPAID' THEN '미납'
                    ELSE '확인필요'
                END AS payStatusNm,

                '-' AS payDateText,
                NVL(offi.OFFICER_NM, id.ID_OFFICER_ID) AS officerNm,
                NVL(offi.OFFICER_NAME, '-') AS customsNm
            FROM CERT_INSURANCE ci
            JOIN IMP_DCLR id
              ON id.ID_IR_NO = ci.CI_DCLR_NO
            JOIN IMP_RQST ir
              ON ir.IR_NO = id.ID_IR_NO
            LEFT JOIN OWNER ow
              ON ow.OWR_ID = ir.IR_OWR_ID
            LEFT JOIN BROKER br
              ON br.BROKER_ID = ir.IR_BROKER_ID
            LEFT JOIN OFFICER offi
              ON offi.OFFICER_ID = id.ID_OFFICER_ID
            LEFT JOIN IMP_DCLR_ITEM item
              ON item.IDI_IR_NO = id.ID_IR_NO
            LEFT JOIN CUSTOMS_TAX tax
              ON tax.CT_STTEMNT_ID = id.ID_IR_NO
            WHERE ci.CI_DCLR_TYPE_CD = 'IMPORT'
              AND ir.IR_BROKER_ID = #{brokerId}
              AND ci.CI_NO = #{ciNo}
            GROUP BY
                ci.CI_NO,
                ci.CI_DCLR_TYPE_CD,
                ci.CI_DCLR_NO,
                ci.TFG_NO,
                ci.CI_STATUS_CD,
                ci.CI_ISSUE_DT,
                ir.IR_OWR_ID,
                ow.OWR_NM,
                id.ID_IMPR_NM,
                ow.OWR_BIZRNO,
                ow.OWR_CSTM_IDF_NO,
                ir.IR_CSTM_IDF_NO,
                ir.IR_BROKER_ID,
                br.BROKER_NM,
                id.ID_MBL_NO,
                ir.IR_BL_AWB_NO,
                id.ID_TOT_TAX_AMT,
                tax.CT_PAY_STATUS_CD,
                offi.OFFICER_NM,
                offi.OFFICER_NAME,
                id.ID_OFFICER_ID
        )
    </select>

    <select id="selectCertFile" resultType="kr.or.tacs.vo.broker.status.StatusCertVO">
    SELECT
        ci.CI_NO AS ciNo,
        ci.CI_DCLR_NO AS ciDclrNo,
        ci.TFG_NO AS tfgNo,
        fd.DFI_FILE_NO AS dfiFileNo,
        fd.DFI_ORG_NM AS dfiOrgNm,
        fd.DFI_STR_NM AS dfiStrNm,
        fd.DFI_PATH AS dfiPath,
        fd.DFI_MIME_TY AS dfiMimeTy
    FROM CERT_INSURANCE ci
    JOIN IMP_DCLR id
      ON id.ID_IR_NO = ci.CI_DCLR_NO
    JOIN IMP_RQST ir
      ON ir.IR_NO = id.ID_IR_NO
    JOIN TACS_FILE_MAP fm
      ON fm.TFM_TFG_NO = ci.TFG_NO
    JOIN DOCS_FILE_DATA fd
      ON fd.DFI_FILE_NO = fm.TFM_DFI_NO
    WHERE ci.CI_DCLR_TYPE_CD = 'IMPORT'
      AND ir.IR_BROKER_ID = #{brokerId}
      AND ci.CI_NO = #{ciNo}
      AND ci.CI_STATUS_CD IN ('CERT_ISSUED', 'CERT_REISSUED')
      AND NVL(fd.DFI_DEL_YN, 'N') = 'N'
      AND ROWNUM = 1
</select>

</mapper>
