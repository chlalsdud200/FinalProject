package kr.or.tacs.dto;

import lombok.Data;

/**
 * 파일 다운로드 권한 검증용 컨텍스트.
 *
 * 파일(dfiFileNo)이 속한 파일그룹(tfgNo)을 기준으로
 * 수입/수출 신고건과 운송접수건의 참여자를 역으로 조회한 결과를 담는다.
 *
 * ownerId / brokerId / transportManagerId 가 모두 없으면 아직 업무객체 매핑이 적용되지 않은
 * 파일유형(자료실/문서함/검역 등)으로 본다.
 */
@Data
public class FileAccessContextDTO {

    private Long tfgNo;
    private String ownerId;
    private String brokerId;
    private String transportManagerId;

    /**
     * 수입/수출 신고건과 연결된 파일인지 여부.
     */
    public boolean isBusinessMapped() {
        return (ownerId != null && !ownerId.isBlank())
                || (brokerId != null && !brokerId.isBlank())
                || (transportManagerId != null && !transportManagerId.isBlank());
    }
}
