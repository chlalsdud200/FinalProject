    /**
     * HS AI추천 기능 상태 확인
     * - 설정 OFF이면 false
     * - 설정 ON이어도 Milvus health check 실패하면 false
     * - Milvus가 꺼져 있어도 프로젝트 전체에는 영향 없음
     */
    @GetMapping("/declare/hsAiStatus.do")
    @ResponseBody
    public Map<String, Object> hsAiStatus() {
        Map<String, Object> result = new HashMap<>();

        boolean alive = false;

        if (hsAiRecommendEnabled) {
            alive = checkMilvusHealth();
        }

        boolean enabled = hsAiRecommendEnabled && alive;

        result.put("success", true);
        result.put("enabled", enabled);
        result.put("configured", hsAiRecommendEnabled);
        result.put("alive", alive);
        result.put("healthUrl", hsAiRecommendHealthUrl);
        result.put("attuUrl", hsAiRecommendAttuUrl);

        if (!hsAiRecommendEnabled) {
            result.put("message", "HS AI추천 기능이 설정에서 비활성화되어 있습니다.");
        } else if (!alive) {
            result.put("message", "Milvus가 실행 중이 아니거나 health check에 실패했습니다.");
        } else {
            result.put("message", "HS AI추천 기능을 사용할 수 있습니다.");
        }

        return result;
    }

    /**
     * Milvus standalone health check
     * docker-compose-milvus.yml 기준 9091 포트의 /healthz 확인
     */
    private boolean checkMilvusHealth() {
        HttpURLConnection conn = null;

        try {
            URL url = new URL(hsAiRecommendHealthUrl);
            conn = (HttpURLConnection) url.openConnection();
            conn.setConnectTimeout(hsAiRecommendTimeoutMs);
            conn.setReadTimeout(hsAiRecommendTimeoutMs);
            conn.setRequestMethod("GET");

            int code = conn.getResponseCode();
            if (code != 200) {
                return false;
            }

            try (BufferedReader br = new BufferedReader(
                    new InputStreamReader(conn.getInputStream(), StandardCharsets.UTF_8))) {

                String body = br.readLine();

                /*
                 * Milvus /healthz 응답은 환경에 따라 "OK" 또는 기타 정상 문자열일 수 있으므로
                 * 200 응답 + 본문 존재를 정상으로 본다.
                 */
                return body != null && !body.trim().isEmpty();
            }

        } catch (IOException e) {
            return false;
        } finally {
            if (conn != null) {
                conn.disconnect();
            }
        }
    }
    
    
  
    
    
    // ==========================================================
    // 8D-ATTACH — 수입신고서 첨부파일 관리
    // ==========================================================

    /**
     * 8D-ATTACH
     * URL  : GET /broker/declare/impDocs.do?irNo=IMP-...
     * Resp : { success, list: [...] }
     *
     * 현재 수입의뢰번호(IR_NO)에 연결된 IMP_RQST.IR_TFG_NO 기준으로
     * 공통 파일 목록을 조회한다.
     */
    @GetMapping("/declare/impDocs.do")
    @ResponseBody
    public Map<String, Object> getImpDocs(@RequestParam("irNo") String irNo,
                                          Principal principal) {
        Map<String, Object> result = new HashMap<>();

        try {
            String brokerId = (principal != null) ? principal.getName() : null;
            if (brokerId == null) {
                result.put("success", false);
                result.put("message", "로그인이 필요합니다.");
                return result;
            }

            List<FileInfoDTO> list = brokerDeclareService.getImpDocList(irNo, brokerId);

            result.put("success", true);
            result.put("list", list);
            return result;

        } catch (Exception e) {
            e.printStackTrace();
            result.put("success", false);
            result.put("message", "첨부파일 조회 실패: " + e.getMessage());
            return result;
        }
    }

    /**
     * 8D-ATTACH
     * URL  : POST /broker/declare/uploadImpDocs.do
     * Form : irNo, files
     *
     * IR_TFG_NO가 있으면 기존 파일그룹에 추가,
     * 없으면 새 파일그룹 생성 후 IMP_RQST.IR_TFG_NO 업데이트.
     */
    @PostMapping("/declare/uploadImpDocs.do")
    @ResponseBody
    public Map<String, Object> uploadImpDocs(@RequestParam("irNo") String irNo,
                                             @RequestParam("files") List<MultipartFile> files,
                                             Principal principal) {
        Map<String, Object> result = new HashMap<>();

        try {
            String brokerId = (principal != null) ? principal.getName() : null;
            if (brokerId == null) {
                result.put("success", false);
                result.put("message", "로그인이 필요합니다.");
                return result;
            }

            Long tfgNo = brokerDeclareService.uploadImpDocs(irNo, files, brokerId);

            result.put("success", true);
            result.put("message", "첨부서류가 업로드되었습니다.");
            result.put("tfgNo", tfgNo);
            return result;

        } catch (Exception e) {
            e.printStackTrace();
            result.put("success", false);
            result.put("message", "첨부파일 업로드 실패: " + e.getMessage());
            return result;
        }
    }

    /**
     * 8D-ATTACH
     * URL  : POST /broker/declare/deleteImpDoc.do
     * Form : irNo, fileNo
     *
     * 현재 MVP에서는 fileNo 기준 공통 파일 삭제.
     */
    @PostMapping("/declare/deleteImpDoc.do")
    @ResponseBody
    public Map<String, Object> deleteImpDoc(@RequestParam("irNo") String irNo,
                                            @RequestParam("fileNo") Long fileNo,
                                            Principal principal) {
        Map<String, Object> result = new HashMap<>();

        try {
            String brokerId = (principal != null) ? principal.getName() : null;
            if (brokerId == null) {
                result.put("success", false);
                result.put("message", "로그인이 필요합니다.");
                return result;
            }

            brokerDeclareService.deleteImpDoc(irNo, fileNo, brokerId);

            result.put("success", true);
            result.put("message", "첨부파일이 삭제되었습니다.");
            return result;

        } catch (Exception e) {
            e.printStackTrace();
            result.put("success", false);
            result.put("message", "첨부파일 삭제 실패: " + e.getMessage());
            return result;
        }
    }
    
    
    /*
     * 8E-DELETE
     * 수입신고서 임시저장 삭제
     *
     * URL  : POST /broker/declare/deleteImpDraft.do
     * Param: idIrNo
     */
    @PostMapping("/declare/deleteImpDraft.do")
    @ResponseBody
    public Map<String, Object> deleteImpDraft(@RequestParam("idIrNo") String idIrNo,
                                              Principal principal) {
        Map<String, Object> result = new HashMap<>();

        try {
            String brokerId = (principal != null) ? principal.getName() : null;

            if (brokerId == null) {
                result.put("success", false);
                result.put("message", "로그인이 필요합니다.");
                return result;
            }

            brokerDeclareService.deleteImpDraft(idIrNo, brokerId);

            result.put("success", true);
            result.put("message", "임시저장 신고서가 삭제되었습니다.");
            return result;

        } catch (Exception e) {
            e.printStackTrace();
            result.put("success", false);
            result.put("message", e.getMessage());
            return result;
        }
    }
}
