package kr.or.tacs.vo.common.notification;

import lombok.Data;

/**
 * 마이페이지 알림 수신 설정 한 줄(이벤트 1종).
 */
@Data
public class NotificationPrefVO {

    private String eventCd;   // np_event_cd
    private String bizNm;     // np_biz_nm (표시용 알림 이름)
    private String useYn;     // 'Y'(수신) / 'N'(거부). 설정 없으면 기본 'Y'
}
