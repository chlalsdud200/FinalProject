/* import-ui.js
 * 수입 운송의뢰 상세 인라인 탭 UI.
 */
(function () {
    'use strict';

    if (window.__TACS_IMPORT_UI_LOADED) return;
    window.__TACS_IMPORT_UI_LOADED = true;

    const GROUP = 'import';
    const REQUEST_LIST_ID = 'TACS-FW-015';
    const REQUEST_DETAIL_ID = 'TACS-FW-016';
    const IMPORT_ROUTE_STORAGE_KEY = 'tacs.import.currentRoute.v2';
    const IMPORT_ROUTE_BOOT_RESTORE_MS = 12000;
    let importBootRestoreRoute;
    let importBootRestoreDeadline = 0;

    const WORK_ITEMS = [
        {id: 'request', title: '수입운송의뢰상세', itemId: REQUEST_DETAIL_ID},
        {id: 'arrival', title: '도착통지서 발송', itemId: 'TACS-FW-020'},
        {id: 'inbound', title: '입고관리', itemId: 'TACS-FW-025'},
        {id: 'do', title: 'D/O', itemId: 'TACS-FW-030'},
        {id: 'release', title: '반출관리', itemId: 'TACS-FW-033'},
        {id: 'inland', title: '내륙배차', itemId: 'TACS-FW-035'}
    ];

    const doFileState = new Map();

    /*
     * 화면 분리 가드
     * - 왼쪽 사이드바 화면(각 리스트)과 운송의뢰 상세 내부 탭은 같은 detail-body를 공유한다.
     * - 이전 상세 탭의 비동기 setTimeout/search/render가 사이드바 리스트 화면 위에 다시 그려지는 문제를 막기 위해
     *   수입 상세 탭 전용 render token을 둔다.
     */
    let importInlineRenderToken = 0;

    function isImportInlineDetailActive(root) {
        const body = document.getElementById('detail-body');
        if (!root || !root.isConnected || !body || !body.contains(root)) return false;
        return body.dataset.currentGroup === GROUP && body.dataset.currentItem === REQUEST_DETAIL_ID;
    }

    function bumpImportInlineRenderToken() {
        importInlineRenderToken += 1;
        return importInlineRenderToken;
    }

    function cleanupImportInlineDetail() {
        bumpImportInlineRenderToken();
        const body = document.getElementById('detail-body');
        if (!body) return;

        // 운송의뢰 상세 탭 화면에서만 비운다. 이미 다른 리스트가 렌더된 상태라면 건드리지 않는다.
        if (body.querySelector('.import-inline-tabs-0513') || body.querySelector('.import-ui-main-request-detail')) {
            body.innerHTML = '';
        }
        doFileState.clear();
    }

    function esc(value) {
        return String(value == null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function pick(row, keys, fallback) {
        row = row || {};
        for (let i = 0; i < keys.length; i += 1) {
            const value = row[keys[i]];
            if (value !== undefined && value !== null && String(value).trim() !== '' && String(value).trim() !== '-') return value;
        }
        return fallback == null ? '' : fallback;
    }

    function normalizeText(value) {
        return String(value == null ? '' : value).trim();
    }

    function contextPath() {
        if (typeof window.getContextPath === 'function') return window.getContextPath();
        if (typeof window.getTransportContextPath === 'function') return window.getTransportContextPath();
        return (window.contextPath || document.body?.dataset?.contextPath || '').replace(/\/$/, '');
    }

    function withContext(url) {
        if (/^https?:\/\//i.test(url)) return url;
        return contextPath() + url;
    }

    function csrfHeaders(isMultipart) {
        const csrf = window.TRANSPORT_CSRF || {};
        const token = csrf.token
            || document.querySelector('meta[name="_csrf"]')?.getAttribute('content')
            || document.querySelector('meta[name="csrf-token"]')?.getAttribute('content')
            || document.querySelector('input[name="_csrf"]')?.value
            || '';
        const header = csrf.header
            || document.querySelector('meta[name="_csrf_header"]')?.getAttribute('content')
            || 'X-CSRF-TOKEN';
        const headers = {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        };
        if (!isMultipart) headers['Content-Type'] = 'application/x-www-form-urlencoded; charset=UTF-8';
        if (token) headers[header] = token;
        return headers;
    }

    function postJson(url, data) {
        const isMultipart = data instanceof FormData;
        let body = data;
        if (!isMultipart) {
            body = new URLSearchParams();
            Object.keys(data || {}).forEach(function (key) {
                if (data[key] !== undefined && data[key] !== null) body.append(key, data[key]);
            });
        }
        return fetch(withContext(url), {
            method: 'POST',
            headers: csrfHeaders(isMultipart),
            credentials: 'same-origin',
            body: isMultipart ? body : body.toString()
        }).then(function (response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.json();
        }).then(function (json) {
            if (!json || json.success !== true) {
                throw new Error((json && json.message) ? json.message : '처리에 실패했습니다.');
            }
            return json;
        });
    }

    function getJson(url) {
        const controller = (typeof AbortController !== 'undefined') ? new AbortController() : null;
        const timeoutId = controller ? window.setTimeout(function () {
            try { controller.abort(); } catch (e) { /* noop */ }
        }, 8000) : null;

        return fetch(withContext(url), {
            method: 'GET',
            headers: {'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
            credentials: 'same-origin',
            cache: 'no-store',
            signal: controller ? controller.signal : undefined
        }).then(function (response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.json();
        }).finally(function () {
            if (timeoutId) window.clearTimeout(timeoutId);
        });
    }

    function jsonRows(json) {
        if (Array.isArray(json)) return json;
        if (!json || typeof json !== 'object') return [];

        const candidates = [
            json.data, json.list, json.rows, json.result, json.items,
            json.resultList, json.dataList, json.body, json.payload
        ];

        for (let i = 0; i < candidates.length; i += 1) {
            const candidate = candidates[i];
            if (Array.isArray(candidate)) return candidate;
        }

        /*
         * Spring 응답이 {success:true, data:{list:[...]}} 또는
         * {result:{rows:[...]}} 처럼 한 번 더 감싸져 오는 경우까지 처리한다.
         * 기존에는 이 형태를 빈 배열로 보고 D/O 상세 탭이 계속 0원/빈 설명으로 렌더링됐다.
         */
        for (let i = 0; i < candidates.length; i += 1) {
            const candidate = candidates[i];
            if (candidate && typeof candidate === 'object') {
                const nested = [
                    candidate.data, candidate.list, candidate.rows, candidate.result, candidate.items,
                    candidate.resultList, candidate.dataList, candidate.body, candidate.payload
                ];
                for (let j = 0; j < nested.length; j += 1) {
                    if (Array.isArray(nested[j])) return nested[j];
                }
            }
        }

        return [];
    }

    function getJsonFlexible(urls) {
        const list = Array.isArray(urls) ? urls : [urls];
        let index = 0;
        function tryNext(lastError) {
            if (index >= list.length) return Promise.reject(lastError || new Error('조회 가능한 API를 찾지 못했습니다.'));
            const url = list[index++];
            return getJson(url + (url.indexOf('?') >= 0 ? '&' : '?') + '_=' + Date.now())
                .catch(function (error) {
                    if (/HTTP 404/.test(error.message || '')) return tryNext(error);
                    throw error;
                });
        }
        return tryNext();
    }

    const TAB_DATA_CONFIG = {
        arrival: {
            loadedFlag: '__TACS_IMPORT_ARRIVAL_LOADED',
            loadingFlag: '__TACS_IMPORT_ARRIVAL_LOADING',
            storeKeys: ['TRANSPORT_IMPORT_ARRIVAL_TRACKING', 'TRANSPORT_IMPORT_ARRIVAL_LIST', '__TACS_IMPORT_ARRIVAL_TRACKING_ROWS'],
            urls: [
                '/transport/import/arrival-notice/list.do',
                '/transport/import/arrival-tracking/list.do',
                '/transport/import/manifest/arrival-list.do',
                '/transport/import/manifest/list.do'
            ]
        },
        inbound: {
            loadedFlag: '__TACS_IMPORT_INBOUND_LOADED',
            loadingFlag: '__TACS_IMPORT_INBOUND_LOADING',
            storeKeys: ['__TACS_IMPORT_INBOUND_REGISTERED_ROWS', 'TRANSPORT_IMPORT_WAREHOUSE_IN_LIST', 'TRANSPORT_IMPORT_INBOUND_LIST'],
            urls: [
                '/transport/import/unloading-in/list.do'
            ]
        },
        do: {
            loadedFlag: '__TACS_IMPORT_DO_LOADED',
            loadingFlag: '__TACS_IMPORT_DO_LOADING',
            storeKeys: ['TRANSPORT_IMPORT_DO_LIST', '__TACS_IMPORT_DO_ROWS'],
            urls: [
                '/transport/import/do/list.do'
            ]
        },
        release: {
            loadedFlag: '__TACS_IMPORT_RELEASE_LOADED',
            loadingFlag: '__TACS_IMPORT_RELEASE_LOADING',
            storeKeys: ['__TACS_IMPORT_RELEASE_ROWS', 'TRANSPORT_IMPORT_RELEASE_LIST', 'IMPORT_RELEASE_LIST'],
            urls: [
                '/transport/import/release-request/list.do'
            ]
        },
        inland: {
            loadedFlag: '__TACS_IMPORT_INLAND_LOADED',
            loadingFlag: '__TACS_IMPORT_INLAND_LOADING',
            storeKeys: ['TRANSPORT_IMPORT_INLAND_DISPATCH_LIST', '__TACS_IMPORT_INLAND_ROWS'],
            urls: [
                '/transport/import/inland-dispatch/list.do'
            ]
        }
    };

    function storeRows(keys, rows) {
        if (!Array.isArray(rows)) rows = [];
        (keys || []).forEach(function (key) {
            window[key] = rows;
        });
        return rows;
    }

    function tabRows(type) {
        if (type === 'arrival') {
            return mergeArrivalNoticeSentPatches(rowsOf(window.TRANSPORT_IMPORT_ARRIVAL_TRACKING, window.TRANSPORT_IMPORT_ARRIVAL_LIST, window.__TACS_IMPORT_ARRIVAL_TRACKING_ROWS));
        }
        if (type === 'inbound') {
            return rowsOf(window.__TACS_IMPORT_INBOUND_DETAIL_ROWS, window.__TACS_IMPORT_INBOUND_REGISTERED_ROWS, window.TRANSPORT_IMPORT_WAREHOUSE_IN_LIST, window.TRANSPORT_IMPORT_INBOUND_LIST);
        }
        if (type === 'do') {
            return rowsOf(window.TRANSPORT_IMPORT_DO_LIST, window.__TACS_IMPORT_DO_ROWS);
        }
        if (type === 'release') {
            return rowsOf(window.__TACS_IMPORT_RELEASE_ROWS, window.TRANSPORT_IMPORT_RELEASE_LIST, window.IMPORT_RELEASE_LIST);
        }
        if (type === 'inland') {
            const rows = window.importInlandDispatchState && window.importInlandDispatchState.rows;
            return rowsOf(rows, window.TRANSPORT_IMPORT_INLAND_DISPATCH_LIST, window.__TACS_IMPORT_INLAND_ROWS);
        }
        return [];
    }

    function tabHasDataForRequest(type, trcNo) {
        return !!findRowByRequestNo(tabRows(type), trcNo);
    }

    function loadWarehouseOptions() {
        if (window.__TACS_WAREHOUSE_LOADED || window.__TACS_WAREHOUSE_LOADING) {
            return Promise.resolve(window.TRANSPORT_WAREHOUSE_LIST || []);
        }
        window.__TACS_WAREHOUSE_LOADING = true;
        return getJsonFlexible([
            '/transport/import/warehouse-manager/list.do',
            '/transport/import/warehouse/manager/list.do',
            '/transport/import/inbound/warehouse-manager/list.do',
            '/transport/import/warehouseManager/list.do'
        ]).then(function (json) {
            const rows = jsonRows(json);
            window.TRANSPORT_WAREHOUSE_LIST = rows;
            window.WAREHOUSE_LIST = rows;
            window.TRANSPORT_WAREHOUSE_ZONE_LIST = rows;
            window.WAREHOUSE_ZONE_LIST = rows;
            window.__TACS_WAREHOUSE_LOADED = true;
            window.__TACS_WAREHOUSE_ZONE_LOADED = true;
            return rows;
        }).catch(function (error) {
            console.warn('[창고 목록 조회 실패]', error);
            return [];
        }).finally(function () {
            window.__TACS_WAREHOUSE_LOADING = false;
        });
    }

    function loadWarehouseZoneOptions() {
        return Promise.resolve(window.TRANSPORT_WAREHOUSE_ZONE_LIST || []);
    }

    function loadWarehouseManagerOptions() {
        if (window.__TACS_WAREHOUSE_MANAGER_LOADED || window.__TACS_WAREHOUSE_MANAGER_LOADING) {
            return Promise.resolve(window.TRANSPORT_WAREHOUSE_MANAGER_LIST || []);
        }
        window.__TACS_WAREHOUSE_MANAGER_LOADING = true;
        return getJsonFlexible([
            '/transport/import/warehouse-manager/list.do',
            '/transport/import/warehouse/manager/list.do',
            '/transport/import/inbound/warehouse-manager/list.do',
            '/transport/import/warehouseManager/list.do'
        ]).then(function (json) {
            const rows = jsonRows(json);
            window.TRANSPORT_WAREHOUSE_MANAGER_LIST = rows;
            window.WAREHOUSE_MANAGER_LIST = rows;
            window.__TACS_WAREHOUSE_MANAGER_LOADED = true;
            return rows;
        }).catch(function (error) {
            console.warn('[창고담당자 목록 조회 실패]', error);
            return [];
        }).finally(function () {
            window.__TACS_WAREHOUSE_MANAGER_LOADING = false;
        });
    }

    function loadCarOptions() {
        if (window.__TACS_IMPORT_CAR_LOADED) {
            return Promise.resolve(window.TRANSPORT_CAR_LIST || window.CAR_LIST || window.__TACS_CAR_LIST || []);
        }
        if (window.__TACS_IMPORT_CAR_LOADING) {
            return Promise.resolve(window.TRANSPORT_CAR_LIST || window.CAR_LIST || window.__TACS_CAR_LIST || []);
        }
        window.__TACS_IMPORT_CAR_LOADING = true;
        return getJsonFlexible([
            '/transport/import/inland-dispatch/cars.do'
        ]).then(function (json) {
            const rows = jsonRows(json);
            window.TRANSPORT_CAR_LIST = rows;
            window.CAR_LIST = rows;
            window.__TACS_CAR_LIST = rows;
            window.__TACS_IMPORT_CAR_LOADED = true;
            return rows;
        }).catch(function (error) {
            console.warn('[차량 목록 조회 실패]', error);
            return [];
        }).finally(function () {
            window.__TACS_IMPORT_CAR_LOADING = false;
        });
    }

    function loadDoListForLookup() {
        if (window.__TACS_IMPORT_DO_LOADING) return Promise.resolve(window.TRANSPORT_IMPORT_DO_LIST || []);
        if (window.__TACS_IMPORT_DO_LOADED && Array.isArray(window.TRANSPORT_IMPORT_DO_LIST) && window.TRANSPORT_IMPORT_DO_LIST.length > 0) {
            return Promise.resolve(window.TRANSPORT_IMPORT_DO_LIST);
        }
        window.__TACS_IMPORT_DO_LOADING = true;
        return getJsonFlexible(['/transport/import/do/list.do']).then(function (json) {
            const rows = mergeDoSettlementPatches(jsonRows(json));
            storeRows(['TRANSPORT_IMPORT_DO_LIST', '__TACS_IMPORT_DO_ROWS'], rows);
            window.__TACS_IMPORT_DO_LOADED = true;
            return rows;
        }).catch(function (error) {
            console.warn('[D/O 목록 조회 실패]', error);
            window.__TACS_IMPORT_DO_LOADED = false;
            return [];
        }).finally(function () {
            window.__TACS_IMPORT_DO_LOADING = false;
        });
    }

    function ensureTabData(type, trcNo, root) {
        const cfg = TAB_DATA_CONFIG[type];
        if (!cfg) return Promise.resolve(false);
        if (window[cfg.loadingFlag]) return Promise.resolve(true);
        /*
         * 현재 의뢰번호 데이터가 없으면 이미 한 번 목록을 불러왔더라도 다시 조회한다.
         * 이전 의뢰(예: 00027) 상태 캐시만 남아 있으면 신규 의뢰(예: 00028)의
         * 입고관리 탭이 빈 값으로 렌더링되는 고질 오류가 발생한다.
         */
        if (window[cfg.loadedFlag] && tabHasDataForRequest(type, trcNo)) return Promise.resolve(false);
        if (window[cfg.loadedFlag] && !trcNo && tabRows(type).length > 0) return Promise.resolve(false);

        window[cfg.loadingFlag] = true;
        return getJsonFlexible(cfg.urls).then(function (json) {
            const rows = jsonRows(json);
            storeRows(cfg.storeKeys, rows);
            if (type === 'inland') {
                window.importInlandDispatchState = window.importInlandDispatchState || {};
                window.importInlandDispatchState.rows = rows;
            }
            window[cfg.loadedFlag] = true;
            const extraLoads = [];
            if (type === 'release' || type === 'inland') {
                extraLoads.push(loadDoListForLookup());
            }
            if (type === 'inbound' || type === 'release') {
                extraLoads.push(loadWarehouseOptions());
                extraLoads.push(loadWarehouseZoneOptions());
                extraLoads.push(loadWarehouseManagerOptions());
            }
            if (type === 'inland') extraLoads.push(loadCarOptions());
            return Promise.all(extraLoads).then(function () { return true; });
        }).catch(function (error) {
            console.warn('[수입 상세 탭 데이터 조회 실패]', type, error);
            window[cfg.loadedFlag] = true;
            return false;
        }).finally(function () {
            window[cfg.loadingFlag] = false;
            if (isImportInlineDetailActive(root) && root.dataset.activeWorkId === type) {
                renderInlineTab(root, type);
            }
        });
    }

    function rowsOf() {
        const rows = [];
        Array.prototype.slice.call(arguments).forEach(function (list) {
            if (Array.isArray(list)) rows.push.apply(rows, list);
        });
        return rows;
    }

    function requestRows() {
        return rowsOf(
            window.TRANSPORT_IMPORT_REQUESTS,
            window.__TACS_IMPORT_REQUEST_LIST,
            window.__IMPORT_REQUEST_LIST,
            window.importTransportRequests,
            window.importRequestRows,
            window.importRequests
        );
    }

    function currentRequest() {
        try {
            return window.selectedImportRequest || selectedImportRequest || {};
        } catch (e) {
            return window.selectedImportRequest || {};
        }
    }

    function currentRequestNo(row) {
        return pick(row, ['trcNo', 'TRC_NO', 'requestNo', 'tcsTrcNo', 'reqNo'], '');
    }

    function setCurrentRequest(req) {
        window.selectedImportRequest = req || {};
        try {
            selectedImportRequest = req || {};
        } catch (e) {
            // 전역 let 접근이 불가능한 환경이면 window 값만 사용한다.
        }
    }


    const __requestGoodsHydrateRunning = Object.create(null);
    const __requestRouteHydrateRunning = Object.create(null);
    const REQUEST_DOC_HYDRATE_MAX_ATTEMPTS = 8;
    const REQUEST_DOC_HYDRATE_DELAY_MS = 700;

    function hasRequestDocValue(row, keys) {
        return keys.some(function (key) {
            return isUsableValue(pick(row, [key], ''));
        });
    }

    function hasAllRequestDocs(row) {
        row = row || {};
        return hasRequestDocValue(row, ['blPdfFileNo', 'blFileNo', 'mblFileNo', 'blPdfFile', 'blFile', 'mblFile'])
            && hasRequestDocValue(row, ['invoiceFileNo', 'invFileNo', 'invoiceFile', 'invoiceFileNm', 'invoiceUrl', 'invoiceFileUrl'])
            && hasRequestDocValue(row, ['packingListFileNo', 'pkgFileNo', 'packingListFile', 'pkgListFile', 'packingListUrl', 'packingListFileUrl']);
    }

    /*
     * 새로고침 직후에는 sessionStorage/history에 저장된 최소 스냅샷으로 먼저 상세가 복원된다.
     * 이 상태를 그대로 두면 저장된 최신 DB 값이 아니라 예전 스냅샷/빈 객체가 화면에 남아서
     * 사용자가 입력했던 값이 사라진 것처럼 보인다. 복원 직후 의뢰 목록 API를 한 번 더 조회해
     * 현재 의뢰번호의 최신 row로 상세 탭을 다시 그린다.
     */
    function refreshRestoredRequestRoute(no, workId, attemptsLeft) {
        no = normalizeText(no);
        if (!no || __requestRouteHydrateRunning[no]) return;
        if (attemptsLeft === undefined || attemptsLeft === null) {
            attemptsLeft = REQUEST_DOC_HYDRATE_MAX_ATTEMPTS;
        }
        __requestRouteHydrateRunning[no] = true;

        getJsonFlexible([
            '/transport/import/request/list.do',
            '/transport/import/list.do'
        ]).then(function (json) {
            const rows = firstRows(json);
            if (rows.length) {
                storeRows(['TRANSPORT_IMPORT_REQUESTS', '__TACS_IMPORT_REQUEST_LIST', '__IMPORT_REQUEST_LIST'], rows);
            }
            const latest = rows.find(function (row) { return rowMatchesRequestNo(row, no); }) || null;
            if (!latest) return null;

            const current = currentRequest();
            const base = rowMatchesRequestNo(current, no) ? current : {};
            const next = mergeUsableRows(base, latest);
            setCurrentRequest(next);
            return next;
        }).then(function (latest) {
            if (!latest) return;
            const root = document.querySelector('.import-inline-tabs-0513');
            if (!root || !isImportInlineDetailActive(root)) return;
            if (!rowMatchesRequestNo({trcNo: root.dataset.requestNo || root.dataset.trcNo || ''}, no)) return;
            if (isRequestGoodsSummaryEditorActive(no)) return;
            const active = validImportWorkId(workId || root.dataset.activeWorkId || 'request');
            renderRequestDetail(latest, active);
            if (active === 'request' && attemptsLeft > 0 && !hasAllRequestDocs(latest)) {
                window.setTimeout(function () {
                    refreshRestoredRequestRoute(no, active, attemptsLeft - 1);
                }, REQUEST_DOC_HYDRATE_DELAY_MS);
            }
        }).catch(function (error) {
            console.warn('[수입운송의뢰 상세 복원 데이터 재조회 실패]', error);
        }).finally(function () {
            __requestRouteHydrateRunning[no] = false;
        });
    }


    function firstRows(json) {
        if (Array.isArray(json)) return json;
        if (!json || typeof json !== 'object') return [];
        const keys = ['data', 'rows', 'list', 'result', 'resultList', 'items'];
        for (let i = 0; i < keys.length; i += 1) {
            if (Array.isArray(json[keys[i]])) return json[keys[i]];
        }
        return [];
    }

    function isRequestGoodsSummaryFieldName(name) {
        return ['goodsName', 'itemNm', 'qty', 'goodsQty', 'weight', 'goodsWeight'].includes(normalizeText(name));
    }

    function isRequestGoodsSummaryEditorActive(trcNo) {
        const active = document.activeElement;
        if (!active || !active.matches || !active.matches('[name="goodsName"], [name="qty"], [name="weight"]')) return false;
        const root = active.closest('.import-ui-main-request-detail');
        if (!root) return false;
        return !trcNo || rowMatchesRequestNo({trcNo: root.dataset.requestNo || root.dataset.trcNo || ''}, trcNo);
    }

    function patchGoodsFields(target, source, opts) {
        if (!target || !source) return false;
        opts = opts || {};
        let changed = false;
        const pairs = [
            ['ggNo', ['ggNo', 'GG_NO', 'tfgNo', 'trcTfgNo', 'TRC_TFG_NO']],
            ['goodsName', ['goodsName', 'itemNm', 'GOODS_NAME', 'goodsNm']],
            ['itemNm', ['itemNm', 'goodsName', 'GOODS_NAME', 'goodsNm']],
            ['goodsHsCode', ['goodsHsCode', 'hsCode', 'GOODS_HS_CODE']],
            ['hsCode', ['hsCode', 'goodsHsCode', 'GOODS_HS_CODE']],
            ['qty', ['qty', 'goodsQty', 'CG_QTY', 'quantity', 'totalQty']],
            ['weight', ['weight', 'goodsWeight', 'CG_WEIGHT', 'totalWeight']],
            ['price', ['price', 'CG_PRICE']],
            ['goodsTotalPrice', ['goodsTotalPrice', 'CG_TOTAL_PRICE', 'totalPrice']],
            ['origin', ['origin', 'originCountryCd', 'cgOrigin', 'CG_ORIGIN']]
        ];
        pairs.forEach(function (pair) {
            const key = pair[0];
            if (opts.skipRequestSummary === true && isRequestGoodsSummaryFieldName(key)) return;
            const val = pick(source, pair[1], '');
            if (!isUsableValue(target[key]) && isUsableValue(val)) {
                target[key] = val;
                changed = true;
            }
        });
        if (Array.isArray(source.goodsList) && source.goodsList.length && (!Array.isArray(target.goodsList) || !target.goodsList.length)) {
            target.goodsList = source.goodsList;
            changed = true;
        }
        return changed;
    }

    function hydrateRequestGoodsIfNeeded(req) {
        const no = currentRequestNo(req);
        if (!no || __requestGoodsHydrateRunning[no]) return;
        // 품목 단가(USD)/총금액/원산지는 요약 조회(goodsName/qty/weight)에는 없고
        // 품목 상세(goods.do = CUSTOMS_GOODS)에만 있다. 따라서 요약값만 있고 상세 품목목록(goodsList)이
        // 아직 없으면, 입고관리 4.품목사항에 단가/총금액/원산지까지 자동으로 채우기 위해 한 번 더 조회한다.
        const hasDetailedGoods = Array.isArray(req.goodsList) && req.goodsList.length > 0;
        if (hasDetailedGoods) return;
        __requestGoodsHydrateRunning[no] = true;
        getJsonFlexible([
            '/transport/import/request/list.do',
            '/transport/import/list.do'
        ]).then(function (json) {
            const rows = firstRows(json);
            const reqRow = rows.find(function (row) { return rowMatchesRequestNo(row, no); }) || null;
            const current = currentRequest();
            if (!rowMatchesRequestNo(current, no)) return false;
            let changed = false;
            if (reqRow) {
                changed = patchGoodsFields(current, reqRow, {skipRequestSummary: true}) || changed;
                storeRows(['TRANSPORT_IMPORT_REQUESTS', '__TACS_IMPORT_REQUEST_LIST', '__IMPORT_REQUEST_LIST'], rows);
            }
            const ggNo = pick(current, ['ggNo', 'GG_NO', 'tfgNo', 'trcTfgNo', 'TRC_TFG_NO'], '');
            if (!ggNo) return changed;
            return getJsonFlexible([
                '/transport/import/manifest/goods.do?ggNo=' + encodeURIComponent(ggNo),
                '/transport/import/inbound/goods.do?ggNo=' + encodeURIComponent(ggNo),
                '/transport/import/unloading-in/goods.do?ggNo=' + encodeURIComponent(ggNo)
            ]).then(function (goodsJson) {
                const goodsRows = firstRows(goodsJson).filter(Boolean);
                if (goodsRows.length) {
                    current.goodsList = goodsRows;
                    patchGoodsFields(current, goodsRows[0], {skipRequestSummary: true});
                    // 품목 상세 목록(품목별 단가/총금액/원산지)이 새로 채워졌으므로 반드시 재렌더한다.
                    // (patchGoodsFields가 false를 반환해도 goodsList 자체가 바뀐 것이므로 changed로 본다)
                    changed = true;
                }
                /*
                 * CUSTOMS_GOODS는 "대표품명 외 N건" 1행으로만 집계 저장되고 단가/원산지가 없다.
                 * 포장명세서 PDF에는 품목별(2건)로 수량/중량/금액(US$)/원산지가 있으므로,
                 * 포장명세서 첨부가 있으면 거기서 품목별로 끌어와 4.품목사항을 우선 채운다.
                 */
                const pkgFileNo = pick(current, ['packingListFileNo', 'pkgFileNo', 'PACKING_LIST_FILE_NO'], '')
                    || pick(reqRow || {}, ['packingListFileNo', 'pkgFileNo', 'PACKING_LIST_FILE_NO'], '');
                if (!pkgFileNo) return changed;
                return getJson('/transport/import/manifest/packing-goods.do?fileNo=' + encodeURIComponent(pkgFileNo) + '&_=' + Date.now())
                    .then(function (pkgJson) {
                        const pkgRows = firstRows(pkgJson).filter(function (it) {
                            return it && (isUsableValue(it.goodsName) || isUsableValue(it.weight) || isUsableValue(it.qty));
                        });
                        if (pkgRows.length) {
                            current.goodsList = pkgRows.map(function (row) {
                                return Object.assign({}, row, {
                                    __packingPrefill: true
                                });
                            });
                            rememberInboundPackingGoods(current, reqRow || current, no, pkgRows);
                            patchGoodsFields(current, current.goodsList[0], {skipRequestSummary: true});
                            changed = true;
                        }
                        return changed;
                    }).catch(function () { return changed; });
            }).catch(function () { return changed; });
        }).then(function (changed) {
            // 1회 조회 완료를 'done'으로 표시해 재조회 루프를 막는다(품목이 없어 goodsList가 비어도 동일).
            __requestGoodsHydrateRunning[no] = 'done';
            const current = currentRequest();
            if (!rowMatchesRequestNo(current, no)) return;
            setCurrentRequest(current);
            if (changed && !isRequestGoodsSummaryEditorActive(no)) renderRequestDetail(current);
        }).catch(function (error) {
            // 네트워크 오류 등 실패 시에는 다음 진입에서 재시도할 수 있도록 플래그를 해제한다.
            __requestGoodsHydrateRunning[no] = false;
            console.warn('[수입운송의뢰 품목 재조회 실패]', error);
        });
    }

    function validImportWorkId(workId) {
        const value = String(workId || '').trim();
        return WORK_ITEMS.some(function (work) { return work.id === value; }) ? value : 'request';
    }

    function readStoredImportRoute() {
        try {
            const raw = window.sessionStorage && window.sessionStorage.getItem(IMPORT_ROUTE_STORAGE_KEY);
            return raw ? JSON.parse(raw) : null;
        } catch (e) {
            return null;
        }
    }

    function importRouteRequestSnapshot(req) {
        if (!req || typeof req !== 'object') return null;
        const snap = {};
        Object.keys(req).forEach(function (key) {
            const value = req[key];
            if (value == null) {
                snap[key] = value;
                return;
            }
            const valueType = typeof value;
            if (valueType === 'string' || valueType === 'number' || valueType === 'boolean') {
                snap[key] = value;
            }
        });
        const no = currentRequestNo(req) || req.trcNo || req.requestNo || req.irNo || req.TRC_NO;
        if (no) {
            snap.trcNo = snap.trcNo || no;
            snap.requestNo = snap.requestNo || no;
            snap.irNo = snap.irNo || no;
            snap.TRC_NO = snap.TRC_NO || no;
        }
        return snap;
    }

    function requestFromImportRoute(route) {
        if (!route || typeof route !== 'object') return null;
        const req = route.request || route.req || route.row || null;
        if (!req || typeof req !== 'object') return null;
        const no = route.trcNo || currentRequestNo(req);
        const snap = Object.assign({}, req);
        if (no) {
            snap.trcNo = snap.trcNo || no;
            snap.requestNo = snap.requestNo || no;
            snap.irNo = snap.irNo || no;
            snap.TRC_NO = snap.TRC_NO || no;
        }
        return snap;
    }

    function rememberImportRoute(route) {
        if (!route || !route.type) return;
        if (!allowMenuRouteOverwrite(route)) return;
        const nextRoute = Object.assign({}, route, { ts: Date.now() });
        try {
            if (window.sessionStorage) {
                window.sessionStorage.setItem(IMPORT_ROUTE_STORAGE_KEY, JSON.stringify(nextRoute));
            }
        } catch (e) {
            // 저장소 사용 불가 시에도 화면 렌더링은 그대로 진행한다.
        }
        try {
            if (window.history && window.history.replaceState) {
                const url = new URL(window.location.href);
                url.pathname = (typeof getContextPath === 'function' ? getContextPath() : '') + '/transport/import.do';
                url.searchParams.delete('page');
                url.searchParams.delete('trcNo');
                url.searchParams.delete('requestNo');
                url.searchParams.delete('reqNo');
                url.searchParams.delete('no');
                const state = Object.assign({}, window.history.state || {});
                state.group = GROUP;
                state.item = route.type === 'request-detail' ? REQUEST_DETAIL_ID : route.itemId;
                state.tacsImportRoute = nextRoute;
                window.history.replaceState(state, '', url.pathname + url.search + url.hash);
            }
        } catch (e) {
            // URL/히스토리 동기화 실패는 화면 렌더링에 영향 주지 않는다.
        }
    }

    function routeFromHistoryState() {
        try {
            const state = window.history && window.history.state ? window.history.state : null;
            if (!state) return null;
            if (state.tacsImportRoute) return state.tacsImportRoute;
            if (state.group === GROUP && state.item === REQUEST_DETAIL_ID && state.trcNo) {
                return { type: 'request-detail', trcNo: state.trcNo, workId: state.workId || 'request' };
            }
            if (state.group === GROUP && state.item) {
                return { type: 'menu', itemId: state.item };
            }
        } catch (e) {}
        return null;
    }

    function isRefreshNavigation() {
        try {
            const nav = window.performance && window.performance.getEntriesByType
                ? window.performance.getEntriesByType('navigation')[0]
                : null;
            if (nav && nav.type) return nav.type === 'reload';
            if (window.performance && window.performance.navigation) return window.performance.navigation.type === 1;
        } catch (e) {
            return false;
        }
        return false;
    }

    function isImportDetailRoute(route) {
        return !!(route && route.type === 'request-detail' && route.trcNo);
    }

    function bootImportDetailRoute() {
        if (typeof importBootRestoreRoute !== 'undefined') return importBootRestoreRoute;
        const storedRoute = routeFromHistoryState() || readStoredImportRoute();
        importBootRestoreRoute = (isRefreshNavigation() && isImportDetailRoute(storedRoute)) ? storedRoute : null;
        if (importBootRestoreRoute) importBootRestoreDeadline = Date.now() + IMPORT_ROUTE_BOOT_RESTORE_MS;
        return importBootRestoreRoute;
    }

    function isBootDetailRestoreActive() {
        return !!(bootImportDetailRoute() && importBootRestoreDeadline && Date.now() <= importBootRestoreDeadline);
    }

    function clearImportBootRestore() {
        importBootRestoreDeadline = 0;
        importBootRestoreRoute = null;
    }

    function isRecentUserImportNav(groupKey, itemId) {
        const nav = window.__TACS_TRANSPORT_USER_NAV || null;
        return !!(nav
            && nav.group === groupKey
            && String(nav.item || '') === String(itemId || '')
            && Date.now() - Number(nav.ts || 0) < 1500);
    }

    function allowMenuRouteOverwrite(route) {
        if (!isBootDetailRestoreActive()) return true;
        return isImportDetailRoute(route);
    }

    function shouldSuppressBootMenuOpen(groupKey, itemId) {
        if (groupKey !== GROUP || itemId === REQUEST_DETAIL_ID || !isBootDetailRestoreActive()) return false;
        const evt = window.event;
        if (isRecentUserImportNav(groupKey, itemId) || (evt && evt.isTrusted)) {
            clearImportBootRestore();
            return false;
        }
        return true;
    }

    function activeImportRouteForRestore() {
        const bootRoute = bootImportDetailRoute();
        if (bootRoute) return bootRoute;
        return routeFromHistoryState() || (isRefreshNavigation() ? readStoredImportRoute() : null);
    }

    function importRouteRequestNo() {
        const route = activeImportRouteForRestore();
        if (route && route.type === 'request-detail' && route.trcNo) return route.trcNo;
        try {
            const params = new URLSearchParams(window.location.search || '');
            return params.get('trcNo') || params.get('requestNo') || params.get('reqNo') || params.get('no') || '';
        } catch (e) {
            return '';
        }
    }

    function importRouteWorkId(req) {
        const no = currentRequestNo(req);
        const route = activeImportRouteForRestore();
        if (route && route.type === 'request-detail' && String(route.trcNo || '') === String(no || '')) {
            return validImportWorkId(route.workId);
        }
        return 'request';
    }

    function updateImportDetailUrl(req, workId) {
        const no = currentRequestNo(req);
        if (!no) return;
        rememberImportRoute({
            type: 'request-detail',
            trcNo: no,
            workId: validImportWorkId(workId || importRouteWorkId(req)),
            request: importRouteRequestSnapshot(req)
        });
    }

    function routedRequest(route) {
        const activeRoute = route || activeImportRouteForRestore();
        const routeNo = (activeRoute && activeRoute.trcNo) ? String(activeRoute.trcNo) : importRouteRequestNo();
        if (routeNo) {
            const row = findRequestRow(routeNo);
            if (row && currentRequestNo(row) && rowMatchesRequestNo(row, routeNo)) return row;
            const routeReq = requestFromImportRoute(activeRoute);
            if (routeReq && currentRequestNo(routeReq)) return routeReq;
            const current = currentRequest();
            if (current && currentRequestNo(current) && rowMatchesRequestNo(current, routeNo)) return current;
            return { trcNo: routeNo, requestNo: routeNo, irNo: routeNo, TRC_NO: routeNo, __routeStub: true };
        }
        const current = currentRequest();
        if (current && currentRequestNo(current)) return current;
        return requestRows()[0] || {};
    }

    /*
     * 같은 건인데 화면/DB에서 번호 형태가 섞여 들어오는 경우가 있다.
     * 예)
     * - TRAN_RCP.TRC_NO : TRC-IMP-20260522-002
     * - IMP_RQST.IR_NO : IMP-20260522-002
     * 그래서 단순 문자열 비교만 하면 새로고침 후 도착통지 행을 못 찾아서
     * TRC_NTC_SENT가 있어도 화면이 다시 미발송처럼 보인다.
     */
    function requestNoKeys(value) {
        const raw = String(value || '').trim().toUpperCase();
        if (!raw) return [];

        const noTrc = raw.replace(/^TRC-/, '');
        const compact = noTrc.replace(/-/g, '');
        const compactNoPrefix = compact.replace(/^TRC/, '');

        /*
         * 도착통지/적하목록 쪽에서 같은 의뢰번호가 아래처럼 섞여 들어온다.
         * - TRC-IMP-20260522-002
         * - IMP-20260522-002
         * - IMP-20260522-00022
         * - IMP-2026-0522-002
         * 단순 문자열 비교만 하면 TRC_NTC_SENT가 있어도 행을 못 찾아서 화면이 미발송처럼 보인다.
         * 그래서 IMP + 8자리 날짜 + 마지막 순번 숫자 기준의 canonical key를 하나 더 만든다.
         */
        const nums = noTrc.match(/^(IMP|EXP)-?(\d{4})-?(\d{2})-?(\d{2})-?(\d+)$/);
        const canonical = nums ? (nums[1] + nums[2] + nums[3] + nums[4] + String(parseInt(nums[5], 10))) : '';

        return [raw, noTrc, compact, compactNoPrefix, canonical].filter(function (item, index, arr) {
            return item && arr.indexOf(item) === index;
        });
    }

    const REQUEST_NO_KEYS = [
        'trcNo', 'TRC_NO', 'requestNo', 'reqNo', 'tcsTrcNo', 'TCS_TRC_NO', 'TR_NO',
        'ianTrcNo', 'IAN_TRC_NO', 'arrivalTrcNo', 'arrivalNoticeTrcNo',
        'arrivalNoticeReqNo', 'arrivalNoticeNo', 'noticeNo', 'ntcNo',
        'diTrcNo', 'DI_TRC_NO',
        'wirNo', 'WIR_NO', 'wirTrcNo', 'WIR_TRC_NO', 'WIR_REF_NO',
        'ianIrNo', 'IAN_IR_NO', 'irNo', 'IR_NO',
        'crrTreId', 'CRR_TRE_ID', 'crrRefNo', 'CRR_REF_NO',
        'dispatchTrcNo', 'DISPATCH_TRC_NO', 'treId', 'TRE_ID',
        'relatedTrcNo'
    ];

    function requestNoValues(row) {
        if (!row) return [];
        return [
            row.trcNo, row.requestNo, row.reqNo, row.tcsTrcNo, row.TCS_TRC_NO, row.TRC_NO, row.TR_NO,
            row.ianTrcNo, row.IAN_TRC_NO, row.arrivalTrcNo, row.arrivalNoticeTrcNo,
            row.arrivalNoticeReqNo, row.arrivalNoticeNo, row.noticeNo, row.ntcNo,
            row.diTrcNo, row.DI_TRC_NO,
            row.wirNo, row.WIR_NO, row.wirTrcNo, row.WIR_TRC_NO, row.WIR_REF_NO,
            row.ianIrNo, row.IAN_IR_NO, row.irNo, row.IR_NO,
            row.crrTreId, row.CRR_TRE_ID, row.crrRefNo, row.CRR_REF_NO,
            row.dispatchTrcNo, row.DISPATCH_TRC_NO, row.treId, row.TRE_ID,
            row.relatedTrcNo
        ];
    }

    function rowMatchesRequestNo(row, no) {
        const targetKeys = requestNoKeys(no);
        if (!targetKeys.length || !row) return false;
        const rowKeys = [];
        requestNoValues(row).forEach(function (value) {
            rowKeys.push.apply(rowKeys, requestNoKeys(value));
        });
        return targetKeys.some(function (key) { return rowKeys.includes(key); });
    }

    function findRowByRequestNo(list, no) {
        if (!Array.isArray(list)) return null;
        return list.find(function (row) { return rowMatchesRequestNo(row, no); }) || null;
    }

    function doSettlementPatchRows() {
        window.__TACS_IMPORT_DO_SETTLEMENT_PATCH_ROWS = window.__TACS_IMPORT_DO_SETTLEMENT_PATCH_ROWS || [];
        return window.__TACS_IMPORT_DO_SETTLEMENT_PATCH_ROWS;
    }

    function arrivalNoticeSentPatchRows() {
        window.__TACS_IMPORT_ARRIVAL_SENT_PATCH_ROWS = window.__TACS_IMPORT_ARRIVAL_SENT_PATCH_ROWS || [];
        return window.__TACS_IMPORT_ARRIVAL_SENT_PATCH_ROWS;
    }

    function arrivalNoticeSentPatch(trcNo, noticeNo) {
        return {
            trcNo: trcNo,
            TRC_NO: trcNo,
            transportRequestNo: trcNo,
            requestNo: trcNo,
            reqNo: noticeNo || trcNo,
            arrivalNoticeReqNo: noticeNo || trcNo,
            arrivalNoticeNo: noticeNo || trcNo,
            noticeNo: noticeNo || trcNo,
            ianNo: noticeNo || trcNo,
            IAN_NO: noticeNo || trcNo,
            noticeStatus: 'TRC_NTC_SENT',
            noticeStatusCd: 'TRC_NTC_SENT',
            noticeStatusNm: '발송완료',
            arrivalNoticeStatus: 'TRC_NTC_SENT',
            arrivalNoticeStatusCd: 'TRC_NTC_SENT',
            arrivalNoticeStatusNm: '발송완료',
            arrivalNoticeSendStatusCd: 'TRC_NTC_SENT',
            sendStatusCd: 'TRC_NTC_SENT',
            sendSttsCd: 'TRC_NTC_SENT',
            sendStatusNm: '발송완료',
            ianSendSttsCd: 'TRC_NTC_SENT',
            ianSendSttsNm: '발송완료',
            IAN_SEND_STTS_CD: 'TRC_NTC_SENT',
            IAN_SEND_STTS_NM: '발송완료'
        };
    }

    function rememberArrivalNoticeSentPatch(trcNo, noticeNo) {
        trcNo = normalizeText(trcNo);
        if (!trcNo) return null;
        const patches = arrivalNoticeSentPatchRows().filter(function (row) {
            return !rowMatchesRequestNo(row, trcNo);
        });
        const patch = arrivalNoticeSentPatch(trcNo, normalizeText(noticeNo));
        patches.unshift(patch);
        window.__TACS_IMPORT_ARRIVAL_SENT_PATCH_ROWS = patches;
        return patch;
    }

    function mergeArrivalNoticeSentPatchValue(baseRow, patchRow) {
        const merged = Object.assign({}, baseRow || {});
        Object.keys(patchRow || {}).forEach(function (key) {
            const value = patchRow[key];
            if (isUsableValue(value)) merged[key] = value;
        });
        return merged;
    }

    function mergeArrivalNoticeSentPatches(rows) {
        rows = Array.isArray(rows) ? rows : [];
        const patches = arrivalNoticeSentPatchRows();
        if (!patches.length) return rows;
        const mergedRows = rows.map(function (row) {
            const patch = patches.find(function (item) { return rowMatchesRequestNo(row, currentRequestNo(item)); });
            return patch ? mergeArrivalNoticeSentPatchValue(row, patch) : row;
        });
        patches.forEach(function (patch) {
            if (!findRowByRequestNo(mergedRows, currentRequestNo(patch))) mergedRows.unshift(patch);
        });
        return mergedRows;
    }

    function rememberDoSettlementPatch(trcNo, patchRow) {
        if (!trcNo || !patchRow) return;
        const patches = doSettlementPatchRows().filter(function (row) {
            return !rowMatchesRequestNo(row, trcNo);
        });
        patches.unshift(Object.assign({}, patchRow, {trcNo: trcNo, requestNo: trcNo}));
        window.__TACS_IMPORT_DO_SETTLEMENT_PATCH_ROWS = patches.slice(0, 20);
    }

    function mergeDoSettlementPatchValue(baseRow, patchRow) {
        const merged = Object.assign({}, baseRow || {});
        const amountKeys = [
            'freightAmt', 'tcsFrgtAmt', 'tcsFrghtAmt', 'tcsFreightAmt', 'freight', 'TCS_FRGT_AMT', 'TCS_FRGHT_AMT', 'TCS_FREIGHT_AMT',
            'warehouseAmt', 'tcsWhAmt', 'warehouse', 'whAmt', 'TCS_WH_AMT',
            'totalBillAmt', 'tcsTotBillAmt', 'totalAmt', 'billAmt', 'TCS_TOT_BILL_AMT'
        ];
        Object.keys(patchRow || {}).forEach(function (key) {
            const patchValue = patchRow[key];
            if (!isUsableValue(patchValue)) return;
            if (amountKeys.includes(key)) {
                if (numberOnly(merged[key]) <= 0 && numberOnly(patchValue) > 0) merged[key] = patchValue;
                return;
            }
            if (/settlement|tcsStl|TCS_STL/.test(key) && normalizeSettlementStatus(merged[key]) === '미정산') {
                merged[key] = patchValue;
                return;
            }
            if (!isUsableValue(merged[key])) merged[key] = patchValue;
        });
        return merged;
    }

    function mergeDoSettlementPatches(rows) {
        const patches = doSettlementPatchRows();
        if (!patches.length) return Array.isArray(rows) ? rows : [];
        const mergedRows = (Array.isArray(rows) ? rows : []).map(function (row) {
            const patch = patches.find(function (item) { return rowMatchesRequestNo(row, currentRequestNo(item)); });
            return patch ? mergeDoSettlementPatchValue(row, patch) : row;
        });
        patches.forEach(function (patch) {
            if (!findRowByRequestNo(mergedRows, currentRequestNo(patch))) mergedRows.unshift(patch);
        });
        return mergedRows;
    }

    function isUsableValue(value) {
        return value !== undefined && value !== null && String(value).trim() !== '' && String(value).trim() !== '-';
    }

    function mergeUsableRows() {
        const merged = {};
        Array.prototype.slice.call(arguments).forEach(function (row) {
            Object.keys(row || {}).forEach(function (key) {
                if (isUsableValue(row[key])) {
                    merged[key] = row[key];
                }
            });
        });
        return merged;
    }

    function mergeRowsForRequest(list, no) {
        const merged = {};
        (Array.isArray(list) ? list : []).forEach(function (row) {
            if (!rowMatchesRequestNo(row, no)) return;
            Object.keys(row).forEach(function (key) {
                if (!isUsableValue(merged[key]) && isUsableValue(row[key])) {
                    merged[key] = row[key];
                }
            });
        });
        return Object.keys(merged).length ? merged : null;
    }

    function workRow(type, no) {
        return mergeRowsForRequest(tabRows(type), no) || findRowByRequestNo(tabRows(type), no) || {};
    }

    function findRequestRow(no) {
        return findRowByRequestNo(requestRows(), no) || {};
    }

    function mergedRequestContext(no) {
        const merged = {};
        [
            findRequestRow(no),
            workRow('arrival', no),
            workRow('inbound', no),
            workRow('do', no),
            workRow('release', no),
            workRow('inland', no)
        ].forEach(function (row) {
            if (!row) return;
            Object.keys(row).forEach(function (key) {
                if (!isUsableValue(merged[key]) && isUsableValue(row[key])) {
                    merged[key] = row[key];
                }
            });
        });
        return merged;
    }

    function requestMblValue(no, req, fallbackRow) {
        const source = mergeUsableRows(mergedRequestContext(no), fallbackRow || {}, req || {});
        return cleanFileName(pick(source, [
            'mblNo', 'masterBlNo', 'masterBl', 'blNo', 'icmMblNo', 'ICM_MBL_NO',
            'biMblNo', 'BI_MBL_NO', 'irBlAwbNo', 'IR_BL_AWB_NO', 'mblFile', 'hblFile'
        ], ''));
    }

    function requestCargoGoodsName(no, req, fallbackRow) {
        const source = mergeUsableRows(mergedRequestContext(no), fallbackRow || {}, req || {});
        return pick(source, [
            'goodsName', 'itemNm', 'goodsNm', 'GOODS_NAME', 'ITEM_NM',
            'TRC_GOODS_NM', 'TRC_GOODS_NAME', 'TRC_ITEM_NM',
            'frghtIemNm', 'cargoName'
        ], '');
    }

    // Master B/L에서 House B/L 번호를 파생한다(백엔드 updateImpTransportReqMasterBl와 동일 규칙).
    // 'MBL-...' 접두면 'HBL-'로 치환, 그 외에는 영숫자 코어 앞에 'HBL-'를 붙여 하우스비엘번호답게 만든다.
    function deriveHouseBlFromMaster(mbl) {
        const raw = String(mbl == null ? '' : mbl).trim();
        if (!raw) return '';
        const upper = raw.toUpperCase();
        if (/^TACS[\s\-_]MBL[\s\-_]/.test(upper)) return 'TACS-HBL-' + raw.replace(/^TACS[\s\-_]MBL[\s\-_]+/i, '');
        if (/^MBL[\s\-_]/.test(upper)) return 'HBL-' + raw.replace(/^MBL[\s\-_]+/i, '');
        return 'HBL-' + upper.replace(/[^0-9A-Z]/g, '');
    }

    function selectedFromButton(button) {
        const no = button.dataset.trcNo || button.dataset.requestNo || button.dataset.no || '';
        const row = mergeUsableRows(mergedRequestContext(no), findRequestRow(no));
        const req = {
            requestNo: no || currentRequestNo(row),
            receiptDate: button.dataset.receiptDate || pick(row, ['receiptDate', 'requestDt', 'trcRceptDt', 'registDt'], ''),
            receiptStatus: button.dataset.receiptStatus || pick(row, ['receiptStatus', 'statusNm', 'statusCd', 'trcStatusCd', 'TRC_STATUS_CD'], ''),
            displayStatus: button.dataset.displayStatus || pick(row, ['displayStatus', 'requestDisplayStatusNm', 'releaseStatusNm'], ''),
            statusCd: button.dataset.statusCd || pick(row, ['statusCd', 'trcStatusCd', 'TRC_STATUS_CD'], ''),
            statusNm: button.dataset.statusNm || pick(row, ['statusNm', 'trcStatusNm', 'TRC_STATUS_NM'], ''),
            rejectReason: button.dataset.rejectReason || pick(row, ['rejectReason', 'rejectCn'], ''),
            shipperName: button.dataset.shipperName || pick(row, ['shipperName', 'ownerNm', 'owrNm', 'trcOwrNm'], ''),
            shipperContact: button.dataset.shipperContact || pick(row, ['shipperContact', 'ownerPicNm', 'owrPicNm'], ''),
            shipperPhone: button.dataset.shipperPhone || pick(row, ['shipperPhone', 'ownerTelno', 'owrTelno'], ''),
            shipperEmail: button.dataset.shipperEmail || pick(row, ['shipperEmail', 'ownerEmail', 'owrEmail'], ''),
            consignorName: button.dataset.consignorName || button.dataset.buyerName || pick(row, ['consignorName', 'buyerNm', 'buyerName', 'traderNm', 'trcTrdrNm'], ''),
            consignorCountry: button.dataset.consignorCountry || button.dataset.buyerCountry || pick(row, ['consignorCountry', 'buyerCountryCd', 'buyerCountryNm', 'traderCountryCd', 'trcTrdrCountryCd'], ''),
            carrierName: button.dataset.carrierName || pick(row, ['carrierName', 'carrierNm'], ''),
            originPort: button.dataset.originPort || pick(row, ['originPort', 'deptPortCd', 'deptPortNm'], ''),
            destinationPort: button.dataset.destinationPort || pick(row, ['destinationPort', 'arvlPortCd', 'arvlPortNm'], ''),
            transportMode: button.dataset.transportMode || pick(row, ['transportMode', 'transportMeanNm', 'transportMeanCd'], ''),
            transportType: button.dataset.transportType || pick(row, ['transportType', 'transportTypeCd'], ''),
            transshipYn: button.dataset.transshipYn || pick(row, ['transshipYn'], ''),
            requestNote: button.dataset.requestNote || pick(row, ['requestNote', 'requestCn', 'trcRequestCn'], ''),
            blType: button.dataset.blType || pick(row, ['blType'], ''),
            bondedWarehouse: button.dataset.bondedWarehouse || pick(row, ['bondedWarehouse', 'warehouseNm', 'wzNm'], ''),
            importDeclNo: button.dataset.importDeclNo || pick(row, ['importDeclNo'], ''),
            containerSpec: button.dataset.containerSpec || pick(row, ['containerSpec'], ''),
            itemCategory: button.dataset.itemCategory || pick(row, ['itemCategory', 'frghtIemNm', 'TRC_ITEM_CTGRY_NM', 'CRR_FRGHT_IEM_NM'], ''),
            goodsName: button.dataset.goodsName || pick(row, ['goodsName', 'itemNm', 'GOODS_NAME'], ''),
            itemNm: button.dataset.goodsName || pick(row, ['itemNm', 'goodsName', 'GOODS_NAME'], ''),
            qty: button.dataset.qty || pick(row, ['qty', 'goodsQty', 'CG_QTY'], ''),
            weight: button.dataset.weight || pick(row, ['weight', 'goodsWeight', 'netWeight', 'CG_WEIGHT'], ''),
            mblNo: button.dataset.mblNo || button.dataset.blNo || requestMblValue(no, null, row),
            hblNo: button.dataset.hblNo || pick(row, ['hblNo', 'houseBlNo', 'icmHblNo', 'ICM_HBL_NO', 'biHblNo', 'BI_HBL_NO'], ''),
            blNo: button.dataset.blNo || button.dataset.mblNo || requestMblValue(no, null, row),
            mblFile: button.dataset.mblFile || requestMblValue(no, null, row),
            blPdfFile: button.dataset.blPdfFile || pick(row, ['blPdfFile', 'blFile', 'mblFile'], ''),
            blPdfFileNo: button.dataset.blPdfFileNo || pick(row, ['blPdfFileNo', 'blFileNo', 'mblFileNo'], ''),
            hblFile: button.dataset.hblFile || pick(row, ['hblFile', 'hblNo'], ''),
            eta: button.dataset.eta || pick(row, ['eta', 'arrivalEta', 'arrivalExpectedDate', 'arrivalExpectedDt', 'arrivalScheduledDate', 'arrvDt', 'arrvSchdYmd', 'ianArrvDt', 'ianArrvSchdYmd', 'irArrvSchdYmd', 'IAN_ARRV_DT', 'IAN_ARRV_SCHD_YMD'], ''),
            cargoMgmtNo: autoImpCargoMgmtNoForDisplay(button.dataset.cargoMgmtNo || pick(row, ['cargoMgmtNo', 'cargoManagementNo', 'wirCargoMgmtNo', 'WIR_CARGO_MGMT_NO'], '')),
            invoiceNo: button.dataset.invoiceNo || pick(row, ['invoiceNo', 'wirInvoiceNo', 'invcNo'], ''),
            invoiceFile: button.dataset.invoiceFile || pick(row, ['invoiceFile', 'invoiceNo', 'invcNo'], ''),
            invoiceFileNo: button.dataset.invoiceFileNo || pick(row, ['invoiceFileNo', 'invFileNo'], ''),
            invoiceUrl: button.dataset.invoiceUrl || pick(row, ['invoiceUrl', 'invoiceFileUrl', 'invFileUrl'], ''),
            packingListFile: button.dataset.packingListFile || pick(row, ['packingListFile', 'pkgListFile'], ''),
            packingListFileNo: button.dataset.packingListFileNo || pick(row, ['packingListFileNo', 'pkgFileNo'], ''),
            packingListUrl: button.dataset.packingListUrl || pick(row, ['packingListUrl', 'packingListFileUrl', 'pkgFileUrl'], '')
        };
        setCurrentRequest(req);
        return req;
    }

    function normalizeReceiptStatus(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        if (['TRC_DONE', 'ACCEPTED', 'ACC'].includes(upper) || raw === '접수완료') return '접수완료';
        if (['REQ_FIX', 'FIX_REQ', 'SUPPLEMENT', 'SUPPLEMENT_REQUESTED'].includes(upper) || raw === '보완요청') return '접수완료';
        if (['IN_DONE'].includes(upper) || raw === '입고완료') return '접수완료';
        if (['REL_DONE', 'DONE', 'RELEASED'].includes(upper) || raw === '반출완료') return '접수완료';
        if (['TRC_REJECT', 'REJECTED', 'REJ'].includes(upper) || raw === '접수반려') return '접수반려';
        if (['TRC_WAIT', 'REQUESTED', 'REQ'].includes(upper) || raw === '접수대기') return '접수대기';
        return raw || '접수대기';
    }

    function normalizeDoStatus(value, hasDoNo) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        if (['TRC_DO_REQ', 'DELIVERED', 'DLVR'].includes(upper) || raw === '전달완료' || raw === 'D/O전달완료') return '전달완료';
        if (['TRC_DO_ISSUED', 'ISSUED'].includes(upper) || raw === '발급완료' || raw === 'D/O발급완료') return '발급완료';
        if (['TRC_DO_READY', 'READY', 'REQUESTED', 'WAIT', 'DRAFT', 'ISSUABLE'].includes(upper) || raw === '발급가능' || raw === '발급대기' || raw === 'D/O발급대기') return '발급대기';
        return raw || (hasDoNo ? '발급완료' : '발급대기');
    }

    function normalizeSettlementStatus(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        if (upper === 'TRC_STL_PAID' || upper === 'PAID' || upper === 'DONE' || upper === 'COMPLETE' || upper === 'COMPLETED' || raw === '정산완료') return '정산완료';
        if (upper === 'TRC_STL_REQ' || upper === 'REQUEST' || upper === 'REQUESTED' || raw === '정산요청' || raw === '정산요청완료') return '정산요청';
        if (upper === 'TRC_STL_UNPAID' || upper === 'UNPAID' || raw === '미정산') return '미정산';
        return raw || '미정산';
    }

    function cleanFileName(value) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '';
        return raw.replace(/\.pdf$/i, '');
    }

    function pdfName(value) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '';
        return /\.pdf$/i.test(raw) ? raw : raw + '.pdf';
    }

    function numberOnly(value) {
        return Number(String(value || '0').replace(/[^0-9.-]/g, '')) || 0;
    }

    function money(value) {
        return numberOnly(value).toLocaleString('ko-KR') + '원';
    }

    function today() {
        const now = new Date();
        return now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
    }

    function dateOnly(value) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '';
        const match = raw.replace(/[./]/g, '-').match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
        if (!match) return '';
        return match[1] + '-' + match[2].padStart(2, '0') + '-' + match[3].padStart(2, '0');
    }

    function dateTimeMinute(value) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '';
        const normalized = raw.replace('T', ' ');
        return normalized.length >= 16 ? normalized.substring(0, 16) : normalized;
    }

    function formatLocalDateTimeMinute(date) {
        const d = date instanceof Date ? date : new Date();
        const pad = function (num) { return String(num).padStart(2, '0'); };
        return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
    }

    function releaseRequestDisplayNo(row, actualNo) {
        const display = pick(row, [
            'releaseReqDisplayNo', 'releaseReqDispNo', 'releaseRequestDisplayNo', 'releaseRequestNoDisplay',
            'crrDisplayNo', 'CRR_DISPLAY_NO'
        ], '');
        if (display) return display;
        const rawNo = normalizeText(actualNo);
        if (!rawNo || rawNo === '-') return '';
        // DB 기준키(CRR_NO)는 숫자로 유지하고, 화면 표시용 번호만 입고관리번호(WIR_NO)와 분리한다.
        if (!/^\d+$/.test(rawNo)) return rawNo;
        const dateSource = pick(row, ['crrCrDt', 'crrReqDt', 'releaseReqDt', 'releasePlanDt', 'requestDt'], '');
        const trcSource = pick(row, ['trcNo', 'requestNo', 'CRR_TRE_ID', 'crrTreId'], '');
        let ymd = '';
        let m = normalizeText(dateSource).replace(/[./]/g, '-').match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
        if (m) {
            ymd = m[1] + m[2].padStart(2, '0') + m[3].padStart(2, '0');
        } else {
            m = normalizeText(dateSource).replace(/[.]/g, '/').match(/^(\d{2})[/-](\d{1,2})[/-](\d{1,2})/);
            if (m) ymd = (Number(m[1]) < 50 ? '20' : '19') + m[1] + m[2].padStart(2, '0') + m[3].padStart(2, '0');
        }
        if (!ymd) {
            const trcDate = normalizeText(trcSource).match(/(20\d{6})/);
            if (trcDate) ymd = trcDate[1];
        }
        if (!ymd) ymd = today().replace(/-/g, '');
        return 'REL-IMP-' + ymd + '-' + (rawNo.length < 4 ? rawNo.padStart(4, '0') : rawNo);
    }



    function currentImportRequestNoForCargo() {
        const root = document.querySelector('.import-ui-main-request-detail');
        const datasetNo = root ? normalizeText(root.dataset.trcNo || root.dataset.requestNo || '') : '';
        if (datasetNo) return datasetNo;
        const active = state.currentRequest || state.selectedRequest || state.activeRequest || {};
        return normalizeText(pick(active, ['trcNo', 'requestNo', 'transportReqNo', 'reqNo'], ''));
    }

    function autoImpCargoMgmtNoForDisplay(value) {
        const display = normalizeText(value);
        // WIR_NO/입고상태가 아직 없는 '입고대기 전' 화면에서는 의뢰번호만으로
        // CARGO-IMP-...를 화면에서 미리 만들지 않는다.
        // 화물관리번호는 WH_IN_RPT row가 생성될 때 DB의 WIR_CARGO_MGMT_NO 값으로만 표시한다.
        if (!display || display === '-' || display === '발송 시 자동생성') return '-';
        return display
            .replace(/^CARGO-TRC-/i, 'CARGO-')
            .replace(/^TRC-/i, 'CARGO-');
    }

    function downloadUrl(fileNo, directUrl) {
        if (fileNo) return withContext('/common/file/download.do?fileNo=' + encodeURIComponent(fileNo));
        return directUrl || '';
    }

    function fileDownloadField(label, name, fileNo, directUrl) {
        const displayName = pdfName(name) || (fileNo || directUrl ? label + '.pdf' : '첨부파일 없음');
        const url = downloadUrl(fileNo, directUrl);
        return ''
            + '<div class="import-ui-field">'
            + '<label>' + esc(label) + '</label>'
            + '<div class="import-ui-file-cell">'
            + '<input value="' + esc(displayName) + '" readonly>'
            + (url ? '<a href="' + esc(url) + '" class="import-ui-file-download">다운로드</a>' : '')
            + '</div>'
            + '</div>';
    }

    function field(label, value, opts) {
        opts = opts || {};
        const name = opts.name ? ' name="' + esc(opts.name) + '"' : '';
        const editableClass = opts.editable ? ' import-ui-editable' : '';
        const readonly = opts.editable ? '' : ' readonly';
        const type = opts.type || 'text';
        let displayValue = type === 'date' ? dateOnly(value) : normalizeText(value);

        // 품목/화물명은 Mapper 쪽에서 이미 "외 n건"이 붙어서 내려오는 경우가 있어서
        // 화면에서 다시 붙거나 "외 0건"이 중복 노출되지 않도록 최종 렌더링 직전에 정리한다.
        if (opts.goodsName === true || /품목|화물/.test(normalizeText(label))) {
            displayValue = sanitizeGoodsDisplayName(displayValue);
        }
        if (/화물관리번호/.test(normalizeText(label))) {
            displayValue = autoImpCargoMgmtNoForDisplay(displayValue);
        }

        if (opts.textarea) {
            return ''
                + '<div class="import-ui-field">'
                + '<label>' + esc(label) + '</label>'
                + '<textarea' + name + readonly + ' class="' + editableClass.trim() + '">' + esc(displayValue) + '</textarea>'
                + '</div>';
        }
        return ''
            + '<div class="import-ui-field">'
            + '<label>' + esc(label) + '</label>'
            + '<input type="' + esc(type) + '"' + name + readonly + ' value="' + esc(displayValue) + '" class="' + editableClass.trim() + '">'
            + '</div>';
    }

    const importOptionModalConfig = {
        buyerCountry: {
            title: '거래자 국가',
            url: '/transport/import/request/country/list.do'
        },
        transportMode: {
            title: '운송수단',
            url: '/transport/import/request/common-option/list.do?type=TRANSPORT_MEAN'
        },
        transportType: {
            title: '운송형태',
            url: '/transport/import/request/common-option/list.do?type=TRANSPORT_TYPE'
        },
        originPort: {
            title: '출발항',
            url: '/transport/import/request/port/list.do'
        },
        destinationPort: {
            title: '도착항',
            url: '/transport/import/request/port/list.do'
        },
        blType: {
            title: 'B/L 구분',
            rows: [
                {value: 'Master B/L', label: 'Master B/L'},
                {value: 'House B/L', label: 'House B/L'}
            ]
        },
        itemCategory: {
            title: '화물품목구분',
            url: '/transport/import/request/common-option/list.do?type=ITEM_CATEGORY'
        }
    };

    let importOptionModalTarget = null;
    const importRequestDetailBusy = new Set();
    const savedImportRequestDetails = new Set();
    const IMPORT_REQUEST_DETAIL_DRAFT_PREFIX = 'tacs.import.requestDetailDraft.';

    function requestDetailDraftKey(trcNo) {
        return IMPORT_REQUEST_DETAIL_DRAFT_PREFIX + normalizeText(trcNo);
    }

    function readRequestDetailDraft(trcNo) {
        trcNo = normalizeText(trcNo);
        if (!trcNo || !window.sessionStorage) return null;
        try {
            const raw = sessionStorage.getItem(requestDetailDraftKey(trcNo));
            return raw ? JSON.parse(raw) : null;
        } catch (e) {
            return null;
        }
    }

    function removeRequestDetailDraft(trcNo) {
        trcNo = normalizeText(trcNo);
        if (!trcNo || !window.sessionStorage) return;
        try {
            sessionStorage.removeItem(requestDetailDraftKey(trcNo));
        } catch (e) {}
    }

    function mergeRequestDetailDraft(row) {
        row = Object.assign({}, row || {});
        const draft = readRequestDetailDraft(currentRequestNo(row));
        if (!draft || !draft.trcNo) return row;
        const display = draft._display || {};

        const touched = Array.isArray(draft._touched) ? draft._touched : [];
        const isTouched = function (name) {
            return touched.indexOf(name) >= 0;
        };
        const assignDraft = function (keys, value, allowBlank) {
            if (!allowBlank && !isUsableValue(value)) return;
            if (allowBlank && (value === undefined || value === null)) return;
            keys.forEach(function (key) {
                row[key] = value;
            });
        };

        assignDraft(['receiptDate'], draft.receiptDate);
        assignDraft(['shipperName'], draft.shipperName);
        assignDraft(['shipperPhone'], draft.shipperPhone);
        assignDraft(['shipperEmail'], draft.shipperEmail);
        assignDraft(['consignorName', 'buyerName', 'buyerNm'], draft.buyerNm);
        assignDraft(['consignorCountry', 'buyerCountry'], display.buyerCountry || draft.buyerCountryCd);
        assignDraft(['buyerCountryCd'], draft.buyerCountryCd);
        assignDraft(['transportMode', 'transportMeanNm'], display.transportMean || draft.transportMeanCd);
        assignDraft(['transportMeanCd'], draft.transportMeanCd);
        assignDraft(['transportType'], display.transportType || draft.transportTypeCd);
        assignDraft(['transportTypeCd'], draft.transportTypeCd);
        assignDraft(['originPort', 'deptPortNm'], draft.deptPortCd || display.deptPort);
        assignDraft(['deptPortCd'], draft.deptPortCd);
        assignDraft(['destinationPort', 'arvlPortNm'], draft.arvlPortCd || display.arvlPort);
        assignDraft(['arvlPortCd'], draft.arvlPortCd);
        assignDraft(['blType'], display.blType);
        assignDraft(['itemCategory'], draft.itemCategory);
        assignDraft(['goodsName', 'itemNm'], draft.goodsName, isTouched('goodsName'));
        assignDraft(['qty', 'goodsQty'], draft.qty, isTouched('qty'));
        assignDraft(['weight', 'goodsWeight'], draft.weight, isTouched('weight'));
        assignDraft(['mblNo', 'blNo'], draft.mblNo);
        assignDraft(['requestNote', 'requestCn'], draft.requestCn);
        return row;
    }

    function saveRequestDetailDraft(root) {
        if (!root || !root.classList || !root.classList.contains('import-ui-main-request-detail')) return;
        const payload = readRequestDetailPayload(root);
        if (!payload || !payload.trcNo || !window.sessionStorage) return;
        try {
            sessionStorage.setItem(requestDetailDraftKey(payload.trcNo), JSON.stringify(payload));
        } catch (e) {}
    }

    function optionSaveValue(type, value) {
        const text = normalizeText(value);
        if (!text) return '';
        const first = text.split('/')[0].trim();
        if (type === 'transportMode') {
            if (text === '해상') return 'SEA';
            if (text === '항공') return 'AIR';
        }
        if (type === 'transportType') {
            if (text === 'Less than Container Load') return 'LCL';
            if (text === 'Full Container Load') return 'FCL';
        }
        return first || text;
    }

    function optionField(label, value, opts) {
        opts = opts || {};
        if (!opts.editable) return field(label, value, opts);
        const type = opts.optionType || opts.name;
        const name = opts.name || type;
        const displayValue = normalizeText(value);
        const saveValue = optionSaveValue(type, displayValue);
        return ''
            + '<div class="import-ui-field import-ui-option-field">'
            + '<label>' + esc(label) + '</label>'
            + '<div class="import-ui-option-cell" data-option-type="' + esc(type) + '">'
            + '<input type="hidden" name="' + esc(name) + '" value="' + esc(saveValue) + '">'
            + '<input type="text" readonly value="' + esc(displayValue) + '" class="import-ui-editable import-ui-option-display" data-option-name="' + esc(name) + '">'
            + '<button type="button" class="import-ui-option-btn" data-option-type="' + esc(type) + '">검색</button>'
            + '</div>'
            + '</div>';
    }

    function ensureImportOptionModal() {
        let modal = document.getElementById('importOptionModal');
        if (modal) return modal;
        modal = document.createElement('div');
        modal.id = 'importOptionModal';
        modal.className = 'import-option-modal';
        modal.style.display = 'none';
        modal.innerHTML = ''
            + '<div class="import-option-backdrop"></div>'
            + '<div class="import-option-panel">'
            + '<div class="import-option-head">'
            + '<h4 id="importOptionModalTitle">선택</h4>'
            + '<button type="button" class="import-option-close">×</button>'
            + '</div>'
            + '<div class="import-option-search">'
            + '<input id="importOptionKeyword" type="text" placeholder="코드 또는 명칭 검색">'
            + '<button type="button" class="import-option-search-btn">조회</button>'
            + '</div>'
            + '<div class="import-option-list-wrap">'
            + '<table class="import-option-table">'
            + '<thead><tr><th>코드</th><th>명칭</th></tr></thead>'
            + '<tbody id="importOptionTbody"></tbody>'
            + '</table>'
            + '</div>'
            + '</div>';
        document.body.appendChild(modal);

        const keyword = modal.querySelector('#importOptionKeyword');
        if (keyword) {
            keyword.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    loadImportOptionRows();
                }
            });
        }
        return modal;
    }

    function normalizeImportOptionRows(rows) {
        return (Array.isArray(rows) ? rows : []).map(function (row) {
            row = row || {};
            const value = normalizeText(row.value || row.VALUE || row.code || row.CODE || row.countryCd || row.COUNTRYCD || row.COUNTRY_CD || row.portCd || row.PORTCD || row.PORT_CD || row.name || row.NAME || row.label || row.LABEL);
            const label = normalizeText(row.portNm || row.PORTNM || row.PORT_NM || row.label || row.LABEL || row.name || row.NAME || row.countryNmKr || row.COUNTRYNMKR || row.COUNTRY_NM_KR || row.countryNmEn || row.COUNTRYNMEN || row.COUNTRY_NM_EN || value);
            return {value: value, label: label};
        }).filter(function (row) {
            return row.value || row.label;
        });
    }

    function renderImportOptionRows(rows) {
        const tbody = document.getElementById('importOptionTbody');
        if (!tbody) return;
        const list = normalizeImportOptionRows(rows);
        if (!list.length) {
            tbody.innerHTML = '<tr><td colspan="2" class="import-option-empty">조회 결과가 없습니다.</td></tr>';
            return;
        }
        tbody.innerHTML = list.map(function (row) {
            return '<tr class="import-option-row" data-value="' + esc(row.value) + '" data-label="' + esc(row.label || row.value) + '">'
                + '<td>' + esc(row.value || '-') + '</td>'
                + '<td>' + esc(row.label || row.value || '-') + '</td>'
                + '</tr>';
        }).join('');
    }

    function loadImportOptionRows() {
        if (!importOptionModalTarget) return;
        const cfg = importOptionModalConfig[importOptionModalTarget.type] || {};
        const keywordEl = document.getElementById('importOptionKeyword');
        const keyword = normalizeText(keywordEl ? keywordEl.value : '');
        const tbody = document.getElementById('importOptionTbody');
        if (tbody) tbody.innerHTML = '<tr><td colspan="2" class="import-option-empty">조회 중입니다.</td></tr>';

        if (cfg.rows) {
            const lowered = keyword.toLowerCase();
            renderImportOptionRows(cfg.rows.filter(function (row) {
                const text = normalizeText((row.value || '') + ' ' + (row.label || '')).toLowerCase();
                return !lowered || text.indexOf(lowered) > -1;
            }));
            return;
        }

        const sep = cfg.url && cfg.url.indexOf('?') > -1 ? '&' : '?';
        const url = cfg.url + sep + 'keyword=' + encodeURIComponent(keyword);
        getJson(url)
            .then(renderImportOptionRows)
            .catch(function (error) {
                console.error('[수입운송 옵션 조회 실패]', error);
                if (tbody) tbody.innerHTML = '<tr><td colspan="2" class="import-option-empty">목록을 불러오지 못했습니다.</td></tr>';
            });
    }

    function openImportOptionModal(trigger) {
        const cell = trigger ? trigger.closest('.import-ui-option-cell') : null;
        if (!cell) return;
        const type = cell.dataset.optionType || '';
        const cfg = importOptionModalConfig[type];
        if (!cfg) return;

        const modal = ensureImportOptionModal();
        importOptionModalTarget = {
            type: type,
            hidden: cell.querySelector('input[type="hidden"]'),
            display: cell.querySelector('.import-ui-option-display')
        };

        const title = modal.querySelector('#importOptionModalTitle');
        const keyword = modal.querySelector('#importOptionKeyword');
        if (title) title.textContent = cfg.title || '선택';
        if (keyword) keyword.value = '';
        modal.style.display = 'flex';
        loadImportOptionRows();
        if (keyword) keyword.focus();
    }

    function closeImportOptionModal() {
        const modal = document.getElementById('importOptionModal');
        if (modal) modal.style.display = 'none';
        importOptionModalTarget = null;
    }

    function selectImportOption(row) {
        if (!row || !importOptionModalTarget) return;
        const value = row.dataset.value || '';
        const label = row.dataset.label || value;
        if (importOptionModalTarget.hidden) importOptionModalTarget.hidden.value = value;
        if (importOptionModalTarget.display) importOptionModalTarget.display.value = label;
        const detailRoot = (importOptionModalTarget.display || importOptionModalTarget.hidden || {}).closest
            ? (importOptionModalTarget.display || importOptionModalTarget.hidden).closest('.import-ui-main-request-detail')
            : null;
        [importOptionModalTarget.hidden, importOptionModalTarget.display].forEach(function (el) {
            if (!el) return;
            el.dispatchEvent(new Event('input', {bubbles: true}));
            el.dispatchEvent(new Event('change', {bubbles: true}));
        });
        saveRequestDetailDraft(detailRoot);
        closeImportOptionModal();
    }

    function selectField(label, name, options, selectedValue) {
        const selected = normalizeText(selectedValue);
        const rows = Array.isArray(options) ? options : [];
        return ''
            + '<div class="import-ui-field">'
            + '<label>' + esc(label) + '</label>'
            + '<select name="' + esc(name) + '" class="import-ui-editable">'
            + rows.map(function (opt) {
                const value = normalizeText(opt.value);
                const labelText = normalizeText(opt.label || opt.value);
                return '<option value="' + esc(value) + '"' + (value === selected ? ' selected' : '') + '>' + esc(labelText || value) + '</option>';
            }).join('')
            + '</select>'
            + '</div>';
    }

    function hiddenField(name, value) {
        return '<input type="hidden" name="' + esc(name) + '" value="' + esc(normalizeText(value)) + '">';
    }

    function warehouseAutoHiddenFields(row) {
        row = row || {};
        const source = selectedWarehouseRow(row) || row;
        return hiddenField('wzNo', warehouseZoneValue(source) || warehouseZoneValue(row))
            + hiddenField('wmId', warehouseManagerValue(source) || warehouseManagerValue(row));
    }

    function selectedWarehouseRow(row) {
        row = row || {};
        const selected = selectedWarehouseValue(row) || pick(row, WAREHOUSE_VALUE_KEYS, '') || warehouseOptionValue(row);
        return selected ? findWarehouseRowByWarehouseSelect(selected, resolveWarehouseName(row)) : null;
    }

    function warehouseManagerReadonlyField(row) {
        const source = selectedWarehouseRow(row) || row || {};
        const managerName = resolveWarehouseManagerName(source) || resolveWarehouseManagerName(row);
        return '<div class="import-ui-field"><label>창고담당자</label><input type="text" readonly data-warehouse-manager-display="true" value="' + esc(managerName || '-') + '"></div>';
    }

    function carFieldValue(row, keys, fallback) {
        return normalizeText(pick(row || {}, keys, fallback || ''));
    }

    function inlandCarRows() {
        const source = Array.isArray(window.TRANSPORT_CAR_LIST) ? window.TRANSPORT_CAR_LIST
            : (Array.isArray(window.CAR_LIST) ? window.CAR_LIST
                : (Array.isArray(window.__TACS_CAR_LIST) ? window.__TACS_CAR_LIST : []));
        const seen = {};
        const rows = [];
        source.forEach(function (car) {
            const no = inlandCarNo(car);
            if (!no || seen[no]) return;
            seen[no] = true;
            rows.push(car);
        });
        return rows;
    }

    function inlandCarNo(car) {
        return carFieldValue(car, ['carNo', 'vehicleNo', 'CAR_NO', 'D_CAR_NO'], '');
    }

    function inlandCarName(car) {
        return carFieldValue(car, ['carNm', 'vehicleNm', 'CAR_NM', 'D_CAR_NM'], '');
    }

    function inlandDriverName(car) {
        return carFieldValue(car, ['driverNm', 'carDriverNm', 'drvNm', 'CAR_DRIVER_NM', 'D_DRIVER_NM'], '');
    }

    function inlandDriverTel(car) {
        return carFieldValue(car, ['driverTelno', 'driverTel', 'driverPhone', 'carDriverTelno', 'CAR_DRIVER_TELNO', 'D_DRIVER_TELNO', 'CAR_DRIVER_TEL'], '');
    }

    function inlandCarSelectField(selectedCarNo) {
        const selected = normalizeText(selectedCarNo);
        const rows = inlandCarRows();
        const hasSelected = selected && rows.some(function (car) { return inlandCarNo(car) === selected; });
        let html = '<div class="import-ui-field"><label>차량번호</label><select name="carNo" class="import-ui-editable import-ui-inland-car-select">';
        html += '<option value="">차량 선택</option>';
        if (selected && !hasSelected) {
            html += '<option value="' + esc(selected) + '" selected>' + esc(selected) + '</option>';
        }
        html += rows.map(function (car) {
            const no = inlandCarNo(car);
            if (!no) return '';
            return '<option value="' + esc(no) + '"'
                + (no === selected ? ' selected' : '')
                + ' data-car-nm="' + esc(inlandCarName(car)) + '"'
                + ' data-driver-nm="' + esc(inlandDriverName(car)) + '"'
                + ' data-driver-telno="' + esc(inlandDriverTel(car)) + '">'
                + esc(no) + '</option>';
        }).join('');
        html += '</select></div>';
        return html;
    }

    function globalRows() {
        return rowsOf.apply(null, Array.prototype.slice.call(arguments).map(function (name) {
            return window[name];
        }));
    }


    function isMeaningfulOptionValue(value) {
        const raw = normalizeText(value);
        return raw && raw !== '-' && raw !== 'null' && raw !== 'undefined';
    }

    const WAREHOUSE_MANAGER_TO_WAREHOUSE_NM = {
        '장창고': '인천',
        '이수인': '대전',
        '임경호': '부산',
        '오수빈': '평택',
        '이예인': '광양'
    };

    const WAREHOUSE_VALUE_KEYS = ['whNo', 'warehouseNo', 'warehouseId', 'whId', 'WH_NO', 'WRHS_NO'];
    const WAREHOUSE_LABEL_KEYS = ['whNm', 'warehouseNm', 'warehouseName', 'WH_NM', 'WRHS_NM'];
    const WAREHOUSE_ZONE_VALUE_KEYS = ['wzNo', 'warehouseZoneNo', 'bondedZoneNo', 'wirWzNo', 'WIR_WZ_NO', 'WZ_NO'];
    const WAREHOUSE_ZONE_LABEL_KEYS = ['wzNm', 'warehouseZoneNm', 'zoneNm', 'bondedZoneNm', 'WZ_NM'];
    const WAREHOUSE_MANAGER_VALUE_KEYS = ['wmId', 'warehouseManagerId', 'bondedManagerId', 'wirWmId', 'WIR_WM_ID', 'WM_ID'];
    const WAREHOUSE_MANAGER_LABEL_KEYS = ['bondedManagerNm', 'warehouseManagerNm', 'wmNm', 'managerNm', 'WM_NM'];

    function warehouseManagerNameFromRow(row) {
        return pick(row || {}, WAREHOUSE_MANAGER_LABEL_KEYS, '');
    }

    function inferWarehouseNameFromManager(managerName) {
        const raw = normalizeText(managerName);
        if (!raw) return '';
        const compact = raw.replace(/\s+/g, '');
        const foundKey = Object.keys(WAREHOUSE_MANAGER_TO_WAREHOUSE_NM).find(function (name) {
            return compact.indexOf(name) >= 0;
        });
        return foundKey ? WAREHOUSE_MANAGER_TO_WAREHOUSE_NM[foundKey] : '';
    }

    function warehouseNameFromRow(row) {
        row = row || {};
        const direct = pick(row, WAREHOUSE_LABEL_KEYS, '');
        if (isMeaningfulOptionValue(direct)) return direct;

        const inferredByManager = inferWarehouseNameFromManager(warehouseManagerNameFromRow(row));
        if (isMeaningfulOptionValue(inferredByManager)) return inferredByManager;

        const targetLabel = pick(row, ['targetWarehouseNm', 'targetWarehouse'], '');
        if (isMeaningfulOptionValue(targetLabel) && targetLabel.indexOf('/') >= 0) {
            const labelWarehouse = targetLabel.split('/')[0].trim();
            if (isMeaningfulOptionValue(labelWarehouse)) return labelWarehouse;
        }

        return '';
    }

    function warehouseOptionValue(row) {
        row = row || {};
        return pick(row, WAREHOUSE_VALUE_KEYS, '')
            || pick(row, WAREHOUSE_ZONE_VALUE_KEYS, '')
            || pick(row, WAREHOUSE_MANAGER_VALUE_KEYS, '');
    }

    function warehouseZoneValue(row) {
        return pick(row || {}, WAREHOUSE_ZONE_VALUE_KEYS, '');
    }

    function warehouseManagerValue(row) {
        return pick(row || {}, WAREHOUSE_MANAGER_VALUE_KEYS, '');
    }

    function selectOptionText(select) {
        const option = select && select.options ? select.options[select.selectedIndex] : null;
        return normalizeText(option ? option.textContent : '');
    }

    function setSelectValueIfPossible(root, name, value) {
        const fields = root ? Array.from(root.querySelectorAll('[name="' + name + '"]')) : [];
        const select = fields.find(function (fieldEl) { return fieldEl.tagName === 'SELECT'; });
        const val = normalizeText(value);
        if (!fields.length || !isMeaningfulOptionValue(val)) return;

        let selectedValue = val;
        if (select) {
            const options = Array.from(select.options || []);
            const exact = options.find(function (opt) { return normalizeText(opt.value) === val; });
            if (exact) {
                selectedValue = exact.value;
            } else {
                const byText = options.find(function (opt) { return normalizeText(opt.textContent) === val; });
                if (byText) selectedValue = byText.value;
            }
        }

        fields.forEach(function (fieldEl) {
            fieldEl.value = selectedValue;
        });
    }

    function warehouseRowMatchesWarehouseSelect(row, value, label) {
        const v = normalizeText(value);
        const l = normalizeText(label);
        return normalizeText(warehouseOptionValue(row)) === v
            || normalizeText(pick(row || {}, WAREHOUSE_VALUE_KEYS, '')) === v
            || normalizeText(warehouseZoneValue(row)) === v
            || normalizeText(warehouseManagerValue(row)) === v
            || (l && normalizeText(warehouseNameFromRow(row)) === l);
    }

    function findWarehouseRowByWarehouseSelect(value, label) {
        const rows = warehouseSourceRows();
        return rows.find(function (row) {
            return warehouseRowMatchesWarehouseSelect(row, value, label);
        }) || null;
    }

    function findWarehouseRowByZone(value) {
        const target = normalizeText(value);
        return warehouseSourceRows().find(function (row) {
            return normalizeText(warehouseZoneValue(row)) === target;
        }) || null;
    }

    function findWarehouseRowByManager(value) {
        const target = normalizeText(value);
        return warehouseSourceRows().find(function (row) {
            return normalizeText(warehouseManagerValue(row)) === target;
        }) || null;
    }

    function syncWarehouseBondedSelects(changedSelect) {
        if (!changedSelect) return;
        const name = changedSelect.name;
        if (name !== 'warehouseId' && name !== 'wzNo' && name !== 'wmId') return;

        const root = changedSelect.closest('.import-ui-request-detail')
            || changedSelect.closest('.import-inline-tabs-0513')
            || changedSelect.closest('#detail-body')
            || document;
        let matched = null;

        if (name === 'warehouseId') {
            matched = findWarehouseRowByWarehouseSelect(changedSelect.value, selectOptionText(changedSelect));
        } else if (name === 'wzNo') {
            matched = findWarehouseRowByZone(changedSelect.value);
        } else if (name === 'wmId') {
            matched = findWarehouseRowByManager(changedSelect.value);
        }

        if (!matched) return;

        if (name !== 'warehouseId') {
            setSelectValueIfPossible(root, 'warehouseId', warehouseOptionValue(matched) || warehouseNameFromRow(matched));
        }
        if (name !== 'wzNo') {
            setSelectValueIfPossible(root, 'wzNo', warehouseZoneValue(matched));
        }
        if (name !== 'wmId') {
            setSelectValueIfPossible(root, 'wmId', warehouseManagerValue(matched));
        }
        const managerDisplay = root.querySelector('[data-warehouse-manager-display="true"]');
        if (managerDisplay) {
            managerDisplay.value = resolveWarehouseManagerName(matched) || '-';
        }
    }


    function warehouseSourceRows() {
        return globalRows(
            'TRANSPORT_WAREHOUSE_LIST',
            'WAREHOUSE_LIST',
            '__TACS_WAREHOUSE_LIST',
            'warehouseList',
            'windowWarehouseList',
            'transportWarehouseList',
            'TRANSPORT_IMPORT_WAREHOUSE_LIST',
            'IMPORT_WAREHOUSE_LIST',
            '__TACS_IMPORT_WAREHOUSE_LIST'
        );
    }

    function selectedWarehouseValue(selectedRow) {
        selectedRow = selectedRow || {};

        const selectedWzNo = pick(selectedRow, WAREHOUSE_ZONE_VALUE_KEYS, '');

        if (!selectedWzNo) return '';

        const matched = warehouseSourceRows().find(function (row) {
            return warehouseZoneValue(row) === selectedWzNo;
        });

        if (!matched) return '';

        return warehouseOptionValue(matched);
    }

    function uniqueOptions(rows, valueKeys, labelKeys, fallbackOption) {
        const map = new Map();
        if (fallbackOption && fallbackOption.value) {
            map.set(String(fallbackOption.value), fallbackOption);
        }
        (Array.isArray(rows) ? rows : []).forEach(function (row) {
            const value = pick(row, valueKeys, '');
            if (!isMeaningfulOptionValue(value)) return;
            const label = pick(row, labelKeys, value);
            if (!map.has(String(value))) {
                map.set(String(value), {value: value, label: label || value});
            }
        });
        return Array.from(map.values());
    }

    function inboundWarehouseManagerOptions(row) {
        const selectedValue = pick(row, WAREHOUSE_MANAGER_VALUE_KEYS, '');
        const selectedLabel = resolveWarehouseManagerName(row);
        return uniqueOptions(
            globalRows('TRANSPORT_WAREHOUSE_MANAGER_LIST', 'WAREHOUSE_MANAGER_LIST', 'TRANSPORT_WAREHOUSE_LIST', 'WAREHOUSE_LIST'),
            WAREHOUSE_MANAGER_VALUE_KEYS,
            WAREHOUSE_MANAGER_LABEL_KEYS,
            isMeaningfulOptionValue(selectedValue) ? {value: selectedValue, label: selectedLabel || selectedValue} : null
        );
    }

    function inboundWarehouseZoneOptions(row) {
        const selectedValue = pick(row, WAREHOUSE_ZONE_VALUE_KEYS, '');
        const selectedLabel = resolveWarehouseZoneName(row);
        return uniqueOptions(
            globalRows('TRANSPORT_WAREHOUSE_ZONE_LIST', 'WAREHOUSE_ZONE_LIST', 'TRANSPORT_WAREHOUSE_LIST', 'WAREHOUSE_LIST'),
            WAREHOUSE_ZONE_VALUE_KEYS,
            WAREHOUSE_ZONE_LABEL_KEYS,
            isMeaningfulOptionValue(selectedValue) ? {value: selectedValue, label: selectedLabel || selectedValue} : null
        );
    }

    function uniqueWarehouseNameOptions(rows, selectedValue, selectedLabel) {
        const map = new Map();
        if (isMeaningfulOptionValue(selectedValue)) {
            const fallbackLabel = selectedLabel || selectedValue;
            const fallbackKey = isMeaningfulOptionValue(selectedLabel) ? normalizeText(selectedLabel) : 'selected:' + normalizeText(selectedValue);
            map.set(fallbackKey, {value: selectedValue, label: fallbackLabel});
        }

        (Array.isArray(rows) ? rows : []).forEach(function (row) {
            const label = warehouseNameFromRow(row);
            if (!isMeaningfulOptionValue(label)) return;
            const value = warehouseOptionValue(row);
            if (!isMeaningfulOptionValue(value)) return;

            // 같은 창고명이 여러 보세구역/담당자 row 로 중복 내려와도 화면에는 한 번만 표시한다.
            const key = normalizeText(label);
            if (!map.has(key)) {
                map.set(key, {value: value, label: label});
            }
        });
        return Array.from(map.values());
    }

    function inboundWarehouseOptions(row) {
        const selectedValue = selectedWarehouseValue(row);
        const selectedLabel = resolveWarehouseName(row);
        return uniqueWarehouseNameOptions(warehouseSourceRows(), selectedValue, selectedLabel);
    }

    function formValues(root) {
        const data = {};
        if (!root) return data;
        root.querySelectorAll('input[name], select[name], textarea[name]').forEach(function (el) {
            data[el.name] = el.value;
        });
        return data;
    }

    function noticeStatusText(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        if (upper === 'TRC_NTC_SENT' || upper === 'SENT' || raw === '발송완료' || raw === '통지완료' || raw === '발급완료') return '발송완료';
        if (upper === 'TRC_NTC_NSENT' || upper === 'NSENT' || raw === '발송대기' || raw === '미발급') return '발송대기';
        return raw || '발송대기';
    }


    function requestStatusOf(req) {
        req = req || currentRequest();
        const no = currentRequestNo(req);
        const receiptLike = function (value) {
            const normalized = normalizeReceiptStatus(value);
            return ['접수완료', '접수대기', '접수반려'].includes(normalized) ? normalized : '';
        };
        const rawReceiptStatus = function (row) {
            row = row || {};
            // 접수상태 판정에는 TRC_* 접수 컬럼을 먼저 보고,
            // statusNm/statusCd에 도착통지/입고/반출 진행상태가 섞이면 접수상태로 쓰지 않는다.
            let raw = pick(row, ['receiptStatus', 'trcStatusCd', 'TRC_STATUS_CD', 'trcStatusNm', 'TRC_STATUS_NM', 'trcStatus'], '');
            let normalized = receiptLike(raw);
            if (normalized) return normalized;
            raw = pick(row, ['statusCd', 'statusNm', 'status'], '');
            normalized = receiptLike(raw);
            return normalized || '';
        };
        const visibleReceiptStatus = function () {
            const body = document.getElementById('detail-body');
            const statusInput = body ? Array.from(body.querySelectorAll('.import-ui-field')).find(function (fieldEl) {
                const label = fieldEl.querySelector('label');
                return label && normalizeText(label.textContent) === '접수상태';
            }) : null;
            const raw = statusInput ? (statusInput.querySelector('input,textarea,select') || {}).value : '';
            return receiptLike(raw);
        };

        // 1) 상세 버튼에서 세팅된 현재 의뢰값 우선 확인
        let status = rawReceiptStatus(req);
        const visibleStatus = visibleReceiptStatus();
        if (visibleStatus && (!status || status === '접수대기')) return visibleStatus;
        if (status) return status;

        // 2) 현재 의뢰값에 상태가 빠진 경우, 원본 운송의뢰 목록에서 다시 찾기
        const row = findRequestRow(no);
        status = rawReceiptStatus(row);
        if (visibleStatus && (!status || status === '접수대기')) return visibleStatus;
        if (status) return status;

        // 3) 화면에 이미 렌더된 접수상태 input이 있으면 마지막으로 확인
        if (visibleStatus) return visibleStatus;

        return '';
    }

    function requestFlowStatusValues(req) {
        req = req || currentRequest();
        const no = currentRequestNo(req);
        const rows = [
            req,
            findRequestRow(no),
            mergedRequestContext(no)
        ].filter(Boolean);
        const keys = [
            'displayStatus', 'displayStatusNm', 'displayStatusCd',
            'requestDisplayStatusNm', 'REQUEST_DISPLAY_STATUS_NM',
            'requestDisplayStatusCd', 'REQUEST_DISPLAY_STATUS_CD',
            'flowStatus', 'flowStatusNm', 'flowStatusCd',
            'arrivalStatus', 'arrivalStatusNm', 'arrivalStatusCd', 'ianArrvStatusCd', 'IAN_ARRV_STATUS_CD',
            'statusNm', 'statusCd', 'status',
            'receiptStatusNm', 'receiptStatusCd', 'receiptStatus',
            'trcStatusNm', 'TRC_STATUS_NM', 'trcStatusCd', 'TRC_STATUS_CD'
        ];
        const values = [];
        rows.forEach(function (row) {
            keys.forEach(function (key) {
                const raw = normalizeText(row && row[key]);
                if (raw && values.indexOf(raw) < 0) values.push(raw);
            });
        });
        return values;
    }

    function flowStatusMatches(req, codeList, nameList) {
        const codes = (codeList || []).map(function (v) { return normalizeText(v).toUpperCase(); });
        const names = (nameList || []).map(normalizeText);
        return requestFlowStatusValues(req).some(function (value) {
            const raw = normalizeText(value);
            const upper = raw.toUpperCase();
            return codes.indexOf(upper) >= 0 || names.indexOf(raw) >= 0;
        });
    }

    const INBOUND_SUPPLEMENT_CODES = ['REQ_FIX', 'IN_FIX', 'FIX_REQ', 'REQ_SENT', 'SUPPLEMENT', 'SUPPLEMENT_REQUESTED', 'SUPPLEMENT_SUBMITTED', 'REJECT', 'REJECTED'];
    const INBOUND_SUPPLEMENT_NAMES = ['보완요청', '입고 보완요청', '입고보완요청', '보완제출', '보완제출완료', '입고 보완제출완료', '입고보완제출완료', '입고반려', '반려'];

    function isInboundSupplementStatusValue(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        return INBOUND_SUPPLEMENT_CODES.indexOf(upper) >= 0 || INBOUND_SUPPLEMENT_NAMES.indexOf(raw) >= 0;
    }

    function requestShowsInboundSupplement(req) {
        return flowStatusMatches(req, INBOUND_SUPPLEMENT_CODES, INBOUND_SUPPLEMENT_NAMES);
    }

    function hasInboundSupplementState(trcNo) {
        const keys = [
            'inStatusNm', 'warehouseInStatusNm', 'warehouseReplyStatusNm', 'wirStatusNm', 'whInStatusNm', 'statusNm',
            'statusCd', 'inStatusCd', 'warehouseInStatusCd', 'warehouseReplyStatusCd', 'whReplyStatusCd',
            'wirStatusCd', 'wirWhReplyStatusCd', 'WIR_STATUS_CD', 'WIR_WH_REPLY_STATUS_CD'
        ];
        return flowRowsForRequest('inbound', trcNo).some(function (row) {
            return keys.some(function (key) { return isInboundSupplementStatusValue(row && row[key]); });
        });
    }

    function shouldOpenInboundForSupplement(req, trcNo) {
        return requestShowsInboundSupplement(req) || hasInboundSupplementState(trcNo || currentRequestNo(req));
    }

    const RELEASE_STAGE_CODES = [
        'REL_WAIT', 'REL_SENT', 'REL_FIX', 'REL_REJECT', 'REL_DONE',
        'OUT_WAIT', 'OUT_REQ', 'OUT_SENT', 'OUT_FIX', 'OUT_REJECT', 'OUT_DONE',
        'RELEASE_WAIT', 'RELEASE_REQ', 'RELEASE_SENT', 'RELEASE_FIX', 'RELEASE_REJECT', 'RELEASE_DONE',
        'CRR_WAIT', 'CRR_REQ', 'CRR_FIX', 'CRR_REJECT', 'CRR_DONE'
    ];
    const RELEASE_STAGE_NAMES = [
        '반출대기', '반출요청', '반출요청완료',
        '반출보완요청', '반출 보완요청', '반출수정요청', '반출 수정요청',
        '반출반려', '반출 반려', '반출완료'
    ];
    const RELEASE_GENERIC_NAMES = ['보완요청', '수정요청', '반려'];

    function requestShowsReleaseStage(req) {
        return flowStatusMatches(req, RELEASE_STAGE_CODES, RELEASE_STAGE_NAMES);
    }

    function hasReleaseStageState(trcNo) {
        const no = trcNo || currentRequestNo(currentRequest());
        const releaseKeys = [
            'releaseStatusCd', 'releaseRequestStatusCd', 'crrStatusCd', 'crStatusCd', 'whOutStatusCd',
            'CRR_STATUS_CD', 'CR_STATUS_CD', 'WH_OUT_STATUS_CD',
            'releaseStatusNm', 'releaseRequestStatusNm', 'crrStatusNm', 'crStatusNm', 'whOutStatusNm',
            'CRR_STATUS_NM', 'CR_STATUS_NM', 'WH_OUT_STATUS_NM'
        ];
        const displayKeys = [
            'releaseDisplayStatusCd', 'releaseDisplayStatusNm',
            'workStatusCd', 'workStatusNm', 'progressStatusCd', 'progressStatusNm',
            'displayStatusCd', 'displayStatusNm', 'displayStatus', 'statusLabel', 'statusText'
        ];
        return flowRowsForRequest('release', no).some(function (row) {
            if (rowHasAnyStatus(row, releaseKeys, RELEASE_STAGE_CODES, RELEASE_STAGE_NAMES.concat(RELEASE_GENERIC_NAMES))) return true;
            return rowHasAnyStatus(row, displayKeys, RELEASE_STAGE_CODES, RELEASE_STAGE_NAMES);
        }) || requestShowsReleaseStage(currentRequest()) || requestShowsReleaseStage(findRequestRow(no));
    }

    function isAllTabsOpenStatus(req) {
        // 도착대기(TRC_ARR_PENDING)는 더 이상 모든 탭을 한 번에 열지 않는다.
        // 도착통지서 발송완료 후에는 입고관리만 열리고, 입고완료→D/O→반출완료→내륙 순서로
        // 단계별로 잠금이 풀려야 한다. (도착대기에서 전체개방하면 입고완료 없이 D/O·반출이 열려버림)
        // 완료대기/최종완료 등 최종 단계만 전체개방으로 둔다.
        return flowStatusMatches(req, [
            'COMPLETE_WAIT', 'DONE_WAIT', 'TRC_COMPLETE_WAIT', 'TRC_DONE_WAIT',
            'FINAL_DONE', 'TRC_FINAL_DONE', 'TRC_FIN_DONE', 'TRC_END_DONE', 'TRC_ALL_DONE'
        ], ['완료대기', '최종완료']);
    }

    function isReceiptCompleteOnlyStatus(req, trcNo) {
        if (isAllTabsOpenStatus(req)) return false;
        const no = trcNo || currentRequestNo(req);
        // 보완요청/보완제출완료처럼 이미 입고 단계로 들어간 건은
        // TRAN_RCP가 아직 접수완료(TRC_DONE)로 남아 있어도 입고관리 탭을 닫으면 안 된다.
        if (hasInboundSupplementState(no)) return false;
        // 이미 반출 단계(반출대기/반출요청/반출보완요청/반출반려/반출완료)에 들어간 건은
        // TRAN_RCP가 아직 접수완료(TRC_DONE)로 남아 있어도 도착통지서까지만 잠그면 안 된다.
        if (hasReleaseStageState(no)) return false;
        // 도착통지서 발송완료(TRC_NTC_SENT) 이후에는 입고관리 탭을 열어야 한다.
        if (isArrivalNoticeSent(no)) return false;
        const status = requestStatusOf(req);
        if (status !== '접수완료') return false;
        if (requestShowsInboundSupplement(req)) return false;
        return !flowStatusMatches(req, ['REQ_FIX', 'IN_FIX', 'FIX_REQ', 'REQ_SENT', 'SUPPLEMENT_SUBMITTED', 'REJECT', 'REJECTED'], [
            '도착통지서 발송완료', '도착통지 발송완료', '발송완료',
            '입고대기', '입고요청', '입고요청완료', '입고완료', '입고 보완요청', '입고보완요청', '보완요청', '보완제출', '보완제출완료', '입고 보완제출완료', '입고보완제출완료', '입고반려', '반려',
            '정산요청', '정산완료',
            'D/O발급대기', 'D/O발급완료', 'D/O전달완료',
            '반출대기', '반출요청', '반출요청완료', '반출보완요청', '반출 보완요청', '반출수정요청', '반출 수정요청', '반출반려', '반출 반려', '반출완료',
            '배차대기', '배차완료'
        ]);
    }

    function isRequestAccepted(req) {
        const status = requestStatusOf(req);
        if (!status) return true;
        return status === '접수완료' || isAllTabsOpenStatus(req);
    }

    function arrivalRowForRequest(trcNo) {
        return findRowByRequestNo(tabRows('arrival'), trcNo) || {};
    }

    function isArrivalNoticeSent(trcNo) {
        const no = trcNo || currentRequestNo(currentRequest());
        const rows = [
            arrivalRowForRequest(no),
            currentRequest(),
            findRequestRow(no),
            mergeRowsForRequest(tabRows('arrival'), no)
        ];
        const statusKeys = [
            'noticeStatusCd', 'arrivalNoticeStatusCd', 'arrivalNoticeSendStatusCd',
            'ianSendSttsCd', 'IAN_SEND_STTS_CD', 'sendSttsCd',
            'noticeStatus', 'noticeStatusNm', 'sendStatusNm',
            'ianSendSttsNm', 'IAN_SEND_STTS_NM', 'sendSttsNm',
            'arrivalNoticeStatus', 'arrivalNoticeStatusNm', 'ianSendStatusCd'
        ];
        const requestKeys = ['trcNo', 'requestNo', 'reqNo', 'TRC_NO', 'IAN_TRC_NO', 'ianTrcNo'];

        /*
         * 입고관리 게이트의 기준은 DOM 글자나 임시 표시명이 아니라 DB 상태값이다.
         * IMP_ARRV_NTC.IAN_SEND_STTS_CD = TRC_NTC_SENT 이거나,
         * 같은 값을 매핑한 arrivalNoticeStatusCd/noticeStatusCd 등이 있으면 다음 단계 진행 가능으로 본다.
         * SENT/NSENT 구버전 코드는 더 이상 인정하지 않는다.
         */
        return rows.some(function (row) {
            if (!row) return false;
            const rowNo = requestKeys.map(function (key) { return row[key]; }).find(isUsableValue);
            if (rowNo && no && !rowMatchesRequestNo(row, no)) return false;
            return statusKeys.some(function (key) {
                const raw = normalizeText(row[key]);
                const upper = raw.toUpperCase();
                return upper === 'TRC_NTC_SENT'
                    || raw === '발송완료'
                    || raw === '통지완료';
            });
        });
    }


    function flowRowsForRequest(type, trcNo) {
        const no = trcNo || currentRequestNo(currentRequest());
        return [
            workRow(type, no),
            mergeRowsForRequest(tabRows(type), no),
            currentRequest(),
            findRequestRow(no),
            mergedRequestContext(no)
        ].filter(Boolean);
    }

    function rowHasAnyStatus(row, keys, exactCodes, exactNames) {
        const codes = (exactCodes || []).map(function (v) { return normalizeText(v).toUpperCase(); });
        const names = (exactNames || []).map(normalizeText);
        return (keys || []).some(function (key) {
            const raw = normalizeText(row && row[key]);
            const upper = raw.toUpperCase();
            return raw && (codes.includes(upper) || names.includes(raw));
        });
    }

    function isInboundCompleted(trcNo) {
        const keys = [
            'warehouseInStatusCd', 'warehouseReplyStatusCd', 'wirWhReplyStatusCd',
            'inStatusCd', 'whInStatusCd', 'wirStatusCd', 'WIR_STATUS_CD', 'WIR_WH_REPLY_STATUS_CD',
            'warehouseInStatusNm', 'warehouseReplyStatusNm', 'inStatusNm', 'whInStatusNm', 'statusNm'
        ];
        return flowRowsForRequest('inbound', trcNo).some(function (row) {
            return rowHasAnyStatus(row, keys, ['IN_DONE', 'APR'], ['입고완료']);
        });
    }

    function isDoDeliveredForGate(trcNo) {
        const keys = [
            'doStatusCd', 'diStatusCd', 'DI_STATUS_CD', 'doStatus',
            'requestDisplayStatusCd', 'REQUEST_DISPLAY_STATUS_CD', 'displayStatusCd', 'statusCd',
            'doStatusNm', 'diStatusNm', 'DI_STATUS_NM', 'statusNm',
            'requestDisplayStatusNm', 'REQUEST_DISPLAY_STATUS_NM', 'displayStatus', 'displayStatusNm'
        ];
        return flowRowsForRequest('do', trcNo).some(function (row) {
            return normalizeDoFilter(row) === 'TRC_DO_REQ'
                || rowHasAnyStatus(row, keys, ['TRC_DO_REQ', 'DELIVERED', 'DO_DELIVERED'], ['D/O전달완료', '전달완료']);
        });
    }

    function isReleaseCompleted(trcNo) {
        const keys = [
            'releaseStatusCd', 'crrStatusCd', 'crStatusCd', 'whOutStatusCd', 'CR_STATUS_CD',
            'releaseStatusNm', 'crrStatusNm', 'crStatusNm', 'whOutStatusNm', 'statusNm'
        ];
        return flowRowsForRequest('release', trcNo).some(function (row) {
            return rowHasAnyStatus(row, keys, ['REL_DONE', 'OUT_DONE', 'RELEASE_DONE', 'DONE'], ['반출완료']);
        });
    }

    function tabGateState(id, trcNo, req) {
        const accepted = isRequestAccepted(req);
        const allTabsOpen = isAllTabsOpenStatus(req);
        const releaseStageOpen = hasReleaseStageState(trcNo);
        if (id === 'request') return {open: true, title: '', message: ''};
        if (allTabsOpen && id !== 'release' && id !== 'inland') return {open: true, title: '', message: ''};
        if (!accepted) return {open: false, title: '접수완료 후 진행 가능', message: '운송의뢰가 접수완료 상태가 아니면 다음 단계를 진행할 수 없습니다.'};
        if (id === 'arrival') return {open: true, title: '', message: ''};
        if (releaseStageOpen && (id === 'inbound' || id === 'do')) return {open: true, title: '', message: ''};
        if (releaseStageOpen && id === 'inland' && isReleaseCompleted(trcNo)) return {open: true, title: '', message: ''};
        if (releaseStageOpen && id === 'inland') return {open: false, title: '반출완료 후 진행 가능', message: '반출 보완요청/반출요청 상태에서는 반출관리까지만 열립니다. 창고 승인 후 반출완료가 되면 내륙배차가 열립니다.'};
        if (id === 'release' && !isDoDeliveredForGate(trcNo)) return {open: false, title: 'D/O 전달완료 후 진행 가능', message: '반출관리는 D/O가 전달완료(TRC_DO_REQ)된 뒤 열립니다.'};
        if (id === 'release') return {open: true, title: '', message: ''};
        if (id === 'inbound' && shouldOpenInboundForSupplement(req, trcNo)) return {open: true, title: '', message: ''};
        if (isReceiptCompleteOnlyStatus(req, trcNo)) {
            return {open: false, title: '도착대기 후 진행 가능', message: '접수완료 상태에서는 도착통지서 탭만 열립니다. 도착대기 또는 최종완료 상태가 되면 모든 상세탭이 열립니다.'};
        }
        if (!isArrivalNoticeSent(trcNo)) return {open: false, title: '도착통지 발송 후 진행 가능', message: '도착통지서 발송완료 후 입고관리만 열립니다.'};
        if (id === 'inbound') return {open: true, title: '', message: ''};
        if (!isInboundCompleted(trcNo)) return {open: false, title: '입고완료 후 진행 가능', message: '입고관리 상태가 입고완료(IN_DONE)일 때 D/O, 반출관리, 내륙배차가 열립니다.'};
        if (id === 'do') return {open: true, title: '', message: ''};
        if (!isDoDeliveredForGate(trcNo)) return {open: false, title: 'D/O 전달완료 후 진행 가능', message: 'D/O가 전달완료(TRC_DO_REQ)된 뒤 반출관리를 진행할 수 있습니다.'};
        if (!isReleaseCompleted(trcNo)) return {open: false, title: '반출완료 후 진행 가능', message: '반출관리 상태가 반출완료(REL_DONE)일 때 내륙배차가 열립니다.'};
        return {open: true, title: '', message: ''};
    }

    function lockPanelHtml(title, message) {
        return ''
            + '<div class="import-ui-request-detail">'
            + '<div class="import-ui-section" style="margin:16px;">'
            + '<h5>' + esc(title || '진행 불가') + '</h5>'
            + '<p class="text-sm text-slate-600" style="margin:0;">' + esc(message || '이전 단계를 먼저 처리해주세요.') + '</p>'
            + '</div>'
            + '</div>';
    }

    function setTabDisabledState(root, req) {
        if (!root) return;
        req = req || currentRequest();
        const no = currentRequestNo(req);
        root.querySelectorAll('.import-ui-tab').forEach(function (button) {
            const id = button.dataset.workId || '';
            const gate = tabGateState(id, no, req);
            const disabled = !gate.open;
            button.classList.toggle('is-disabled', disabled);
            button.setAttribute('aria-disabled', disabled ? 'true' : 'false');
            if (disabled) {
                const tip = gate.message || gate.title || '이전 단계를 먼저 완료하면 열립니다.';
                button.setAttribute('title', tip);
                button.setAttribute('data-lock-title', gate.title || '이전 단계 완료 후 진행 가능');
                button.setAttribute('data-lock-message', tip);
            } else {
                button.removeAttribute('title');
                button.removeAttribute('data-lock-title');
                button.removeAttribute('data-lock-message');
            }
        });
    }

    function markArrivalSentForRequest(trcNo, noticeNo) {
        const sentPatch = rememberArrivalNoticeSentPatch(trcNo, noticeNo);
        const rows = tabRows('arrival');
        let row = findRowByRequestNo(rows, trcNo);
        if (!row) {
            row = {trcNo: trcNo, requestNo: trcNo, reqNo: noticeNo || '', arrivalNoticeReqNo: noticeNo || '', arrivalNoticeNo: noticeNo || ''};
            window.TRANSPORT_IMPORT_ARRIVAL_TRACKING = window.TRANSPORT_IMPORT_ARRIVAL_TRACKING || [];
            window.TRANSPORT_IMPORT_ARRIVAL_TRACKING.push(row);
        }
        if (sentPatch) Object.assign(row, sentPatch);
        if (noticeNo && noticeNo !== '-') {
            if (!isUsableValue(row.reqNo)) row.reqNo = noticeNo;
            if (!isUsableValue(row.arrivalNoticeReqNo)) row.arrivalNoticeReqNo = noticeNo;
            if (!isUsableValue(row.arrivalNoticeNo)) row.arrivalNoticeNo = noticeNo;
            row.ianNo = noticeNo;
            row.IAN_NO = noticeNo;
        }
        row.trcNo = row.trcNo || trcNo;
        row.TRC_NO = row.TRC_NO || trcNo;
        row.transportRequestNo = row.transportRequestNo || trcNo;
        row.requestNo = row.requestNo || trcNo;
        row.noticeStatus = 'TRC_NTC_SENT';
        row.noticeStatusCd = 'TRC_NTC_SENT';
        row.noticeStatusNm = '발송완료';
        row.sendStatusNm = '발송완료';
        row.arrivalNoticeStatusCd = 'TRC_NTC_SENT';
        row.arrivalNoticeSendStatusCd = 'TRC_NTC_SENT';
        row.ianSendSttsCd = 'TRC_NTC_SENT';
        row.ianSendSttsNm = '발송완료';
        row.IAN_SEND_STTS_CD = 'TRC_NTC_SENT';
        row.IAN_SEND_STTS_NM = '발송완료';
        row.statusCd = 'TRC_NTC_SENT';
        row.statusNm = '발송완료';
        window.__TACS_IMPORT_ARRIVAL_LOADED = true;

        if (typeof window.syncManifestArrivalNoticeStatus === 'function') {
            window.syncManifestArrivalNoticeStatus(trcNo);
        }
    }

    function refreshArrivalNoticeSentState(detail) {
        detail = detail || {};
        const trcNo = detail.trcNo || detail.transportRequestNo || detail.reqNo || currentRequestNo(currentRequest());
        if (!trcNo) return;

        const noticeNo = detail.noticeNo || detail.arrivalNoticeNo || detail.arrivalNoticeReqNo || detail.ianNo || '';
        markArrivalSentForRequest(trcNo, noticeNo);
        if (typeof window.patchImportArrivalNoticeSentDom === 'function') {
            window.patchImportArrivalNoticeSentDom(trcNo, noticeNo);
            setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, noticeNo); }, 0);
            setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, noticeNo); }, 120);
        }

        [currentRequest(), findRequestRow(trcNo)].forEach(function (row) {
            if (!row || (currentRequestNo(row) && !rowMatchesRequestNo(row, trcNo))) return;
            row.noticeStatus = 'TRC_NTC_SENT';
            row.noticeStatusCd = 'TRC_NTC_SENT';
            row.noticeStatusNm = '발송완료';
            row.arrivalNoticeStatus = 'TRC_NTC_SENT';
            row.arrivalNoticeStatusCd = 'TRC_NTC_SENT';
            row.arrivalNoticeSendStatusCd = 'TRC_NTC_SENT';
            row.ianSendSttsCd = 'TRC_NTC_SENT';
            row.ianSendSttsNm = '발송완료';
            row.IAN_SEND_STTS_CD = 'TRC_NTC_SENT';
            row.IAN_SEND_STTS_NM = '발송완료';
            row.sendStatusCd = 'TRC_NTC_SENT';
            row.sendSttsCd = 'TRC_NTC_SENT';
            row.sendStatusNm = '발송완료';
            // generic statusCd/statusNm은 접수상태 판정에 쓰이므로
            // 도착통지서 상태를 덮어쓰지 않는다.
            if (noticeNo && noticeNo !== '-') {
                row.reqNo = row.reqNo || noticeNo;
                row.arrivalNoticeNo = row.arrivalNoticeNo || noticeNo;
                row.arrivalNoticeReqNo = row.arrivalNoticeReqNo || noticeNo;
                row.ianNo = noticeNo;
                row.IAN_NO = noticeNo;
            }
        });

        document.querySelectorAll('.import-inline-tabs-0513').forEach(function (root) {
            if (!isImportInlineDetailActive(root)) return;
            const req = currentRequest();
            if (currentRequestNo(req) && !rowMatchesRequestNo(req, trcNo)) return;
            if ((root.dataset.activeWorkId || '') === 'arrival') {
            renderInlineTab(root, 'arrival');
                if (typeof window.patchImportArrivalNoticeSentDom === 'function') {
                    setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, noticeNo); }, 0);
                    setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, noticeNo); }, 120);
                    setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, noticeNo); }, 300);
                    setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, noticeNo); }, 700);
                }
            }
            setTabDisabledState(root, req);
        });
    }

    function isDoneStatus(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        return ['DONE', 'IN_DONE', 'OUT_DONE', 'RELEASE_DONE', 'TRC_DISPATCH_DONE', 'TRC_NTC_SENT', 'DELIVERED'].includes(upper)
            || raw.indexOf('완료') >= 0 || raw.indexOf('통지완료') >= 0 || raw.indexOf('반출완료') >= 0;
    }

    function statusText(value, fallback) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        if (!raw || raw === '-') return fallback || '';
        if (upper === 'WAIT' || upper === 'IN_WAIT') return '입고대기';
        if (upper === 'SENT') return '입고요청';
        if (upper === 'IN_DONE') return '입고완료';
        if (upper === 'REQ_FIX' || upper === 'FIX_REQ' || upper === 'SUPPLEMENT' || upper === 'SUPPLEMENT_REQUESTED') return '보완요청';
        if (upper === 'SUB') return '보완완료';
        if (upper === 'REQ_SENT' || upper === 'REL_SENT') return '보완제출완료';
        if (upper === 'APR') return '입고완료';
        if (upper === 'OUT_WAIT' || upper === 'RELEASE_WAIT' || upper === 'REL_WAIT' || upper === 'REQ') return fallback === '반출대기' ? '반출대기' : '대기';
        if (upper === 'REL_FIX' || upper === 'REL_REJECT') return '보완요청';
        if (upper === 'REL_DONE' || upper === 'OUT_DONE' || upper === 'RELEASE_DONE') return '반출완료';
        if (upper === 'TRC_DISPATCH_WAIT' || upper === 'DISPATCH_WAIT') return '배차대기';
        if (upper === 'TRC_DISPATCH_DONE') return '배차완료';
        if (upper === 'TRC_END' || upper === 'COMPLETE_WAIT' || upper === 'DONE_WAIT') return '완료대기';
        if (upper === 'TRC_COMPLETE' || upper === 'FINAL_DONE') return '최종완료';
        if (upper === 'TRC_NTC_SENT') return '입고요청';
        if (upper === 'REQUESTED') return fallback === '반출대기' ? '반출대기' : '발송완료';
        return raw;
    }

    function section(title, content) {
        return '<section class="import-ui-section"><h5>' + esc(title) + '</h5>' + content + '</section>';
    }

    const inboundDetailMessageCache = new Map();
    const inboundDetailGoodsCache = new Map();
    const inboundPackingGoodsCache = new Map();

    function inboundSupplementMessage(row) {
        return pick(row, [
            'suppReqCn',
            'rejectReason',
            'supplementReason',
            'rejectMemo',
            'sriReqCn',
            'SRI_REQ_CN'
        ], '');
    }

    function inboundSupplementNoticeHtml(row) {
        const message = normalizeText(inboundSupplementMessage(row));
        if (!message) return '';
        return ''
            + '<div class="import-ui-field import-ui-inbound-supp-notice-wrap">'
            + '<label style="color:#92400e;">창고 보완요청 메시지</label>'
            + '<textarea readonly style="min-height:58px;background:#fffbeb!important;border-color:#f59e0b!important;color:#78350f!important;-webkit-text-fill-color:#78350f!important;font-weight:900;line-height:1.55;">' + esc(message) + '</textarea>'
            + '</div>';
    }

    function mergeInboundDetailIntoStores(trcNo, detail) {
        if (!detail || typeof detail !== 'object') return;
        const keys = [
            '__TACS_IMPORT_INBOUND_DETAIL_ROWS',
            '__TACS_IMPORT_INBOUND_REGISTERED_ROWS',
            'TRANSPORT_IMPORT_WAREHOUSE_IN_LIST',
            'TRANSPORT_IMPORT_INBOUND_LIST'
        ];
        keys.forEach(function (key) {
            const rows = window[key];
            if (!Array.isArray(rows)) return;
            let matched = false;
            rows.forEach(function (row) {
                if (!rowMatchesRequestNo(row, trcNo)
                    && normalizeText(pick(row, ['wirNo', 'WIR_NO', 'inboundRequestNo'], '')) !== normalizeText(pick(detail, ['wirNo', 'WIR_NO', 'inboundRequestNo'], ''))) {
                    return;
                }
                Object.keys(detail).forEach(function (key) {
                    // 상세조회 값이 null/빈값이면 기존 목록의 실제 값(품목/금액/메시지)을 덮어쓰지 않는다.
                    // 단, 상태값은 상세조회가 더 정확할 수 있으므로 값이 있을 때만 갱신한다.
                    if (isUsableValue(detail[key])) row[key] = detail[key];
                });
                matched = true;
            });
            if (!matched && rowMatchesRequestNo(detail, trcNo)) rows.push(detail);
        });
    }

    function goodsListOf(row) {
        const list = row && (row.goodsList || row.itemList || row.customsGoodsList || row.goodsRows || row.goods || row.__packingGoodsList);
        return Array.isArray(list) ? list.filter(Boolean) : [];
    }

    function representativeGoodsBaseName(value) {
        return cleanPackingGoodsName(normalizeText(value).replace(/\s*외\s*\d+\s*건\s*$/g, '')).trim();
    }

    function cleanPackingGoodsName(value) {
        return normalizeText(value)
            .replace(/\s+P\.?\s*O\.?\s*NO\.?\s*[:#-]?.*$/i, '')
            .replace(/\s+PO\s*NO\.?\s*[:#-]?.*$/i, '')
            .replace(/\s+\d[\d,]*(?:\.\d+)?\s*(?:BAGS?|PCS|PIECES|CTNS?|CARTONS?|BOX(?:ES)?|PKGS?|PACKAGES?)\b.*$/i, '')
            .replace(/\s+\d[\d,]*(?:\.\d+)?\s*(?:KG|KGS|KILOGRAMS?|TONS?|T|CBM)\b.*$/i, '')
            .replace(/\s+US\$\s*[\d,]+(?:\.\d+)?.*$/i, '')
            .replace(/\(\s+/g, '(')
            .replace(/\s+\)/g, ')')
            .replace(/[\s,;:.-]+$/g, '')
            .trim();
    }

    function runtimePackingGoodsList(row, req) {
        const detailMap = window.__TACS_IMPORT_PACKING_GOODS_DETAIL_BY_KEY || {};
        const map = window.__TACS_IMPORT_PACKING_GOODS_BY_KEY || {};
        const keys = [
            currentRequestNo(row),
            currentRequestNo(req),
            pick(row || {}, ['ggNo', 'GG_NO', 'tfgNo', 'trcTfgNo', 'TRC_TFG_NO'], ''),
            pick(req || {}, ['ggNo', 'GG_NO', 'tfgNo', 'trcTfgNo', 'TRC_TFG_NO'], '')
        ].map(normalizeText).filter(Boolean);

        for (let i = 0; i < keys.length; i += 1) {
            if (Array.isArray(detailMap[keys[i]]) && detailMap[keys[i]].length) {
                return detailMap[keys[i]].map(function (item) {
                    return Object.assign({__packingPrefill: true}, item);
                });
            }
        }
        for (let i = 0; i < keys.length; i += 1) {
            if (Array.isArray(map[keys[i]]) && map[keys[i]].length) {
                return map[keys[i]].map(function (item) {
                    return Object.assign({__packingPrefill: true}, item);
                });
            }
        }
        return [];
    }

    function packingGoodsCacheKeys(row, req, trcNo) {
        const keys = [
            trcNo,
            currentRequestNo(row),
            currentRequestNo(req),
            pick(row || {}, ['ggNo', 'GG_NO', 'tfgNo', 'trcTfgNo', 'TRC_TFG_NO'], ''),
            pick(req || {}, ['ggNo', 'GG_NO', 'tfgNo', 'trcTfgNo', 'TRC_TFG_NO'], '')
        ].map(normalizeText).filter(Boolean);
        return keys.filter(function (key, index) { return keys.indexOf(key) === index; });
    }

    function rememberInboundPackingGoods(row, req, trcNo, rows) {
        if (!Array.isArray(rows) || !rows.length) return;
        window.__TACS_IMPORT_PACKING_GOODS_DETAIL_BY_KEY = window.__TACS_IMPORT_PACKING_GOODS_DETAIL_BY_KEY || {};
        const normalizedRows = rows.map(function (item) {
            return Object.assign({}, item, {__packingPrefill: true});
        });
        packingGoodsCacheKeys(row, req, trcNo).forEach(function (key) {
            window.__TACS_IMPORT_PACKING_GOODS_DETAIL_BY_KEY[key] = normalizedRows;
        });
    }

    function hasGoodsCommercialFields(rows) {
        return (Array.isArray(rows) ? rows : []).some(function (item) {
            return item && (
                isUsableValue(pick(item, ['price', 'goodsPrice', 'unitPrice', 'CG_PRICE', 'PRICE'], ''))
                || isUsableValue(pick(item, ['goodsTotalPrice', 'summaryTotalPrice', 'totalPrice', 'CG_TOTAL_PRICE', 'SUMMARY_TOTAL_PRICE', 'TOTAL_PRICE'], ''))
                || isUsableValue(pick(item, ['origin', 'originCountryCd', 'cgOrigin', 'CG_ORIGIN', 'ORIGIN_COUNTRY_CD'], ''))
            );
        });
    }

    function ensureInboundPackingGoodsPrefill(root, trcNo) {
        const no = normalizeText(trcNo);
        const req = currentRequest();
        const requestRow = workRow('request', no) || {};
        const inboundRow = workRow('inbound', no) || {};
        const source = Object.assign({}, req || {}, requestRow, inboundRow);
        const detailRows = runtimePackingGoodsList(source, req);
        if (hasGoodsCommercialFields(detailRows)) return;

        const fileNo = pick(source, ['packingListFileNo', 'pkgFileNo', 'PACKING_LIST_FILE_NO'], '');
        if (!fileNo) return;
        const cacheKey = String(fileNo);
        if (inboundPackingGoodsCache.get(cacheKey) === 'loading' || inboundPackingGoodsCache.get(cacheKey) === 'done') return;
        inboundPackingGoodsCache.set(cacheKey, 'loading');

        getJson('/transport/import/manifest/packing-goods.do?fileNo=' + encodeURIComponent(fileNo) + '&_=' + Date.now())
            .then(function (json) {
                const rows = firstRows(json).filter(function (item) {
                    return item && (isUsableValue(item.goodsName) || isUsableValue(item.qty) || isUsableValue(item.weight));
                });
                if (!rows.length) {
                    inboundPackingGoodsCache.delete(cacheKey);
                    return;
                }
                inboundPackingGoodsCache.set(cacheKey, 'done');
                rememberInboundPackingGoods(source, req, no, rows);

                const current = currentRequest();
                if (current && rowMatchesRequestNo(current, no)) {
                    setCurrentRequest(Object.assign({}, current, {
                        goodsList: rows.map(function (item) { return Object.assign({}, item, {__packingPrefill: true}); })
                    }));
                }
                if (root && root.isConnected && root.dataset.activeWorkId === 'inbound') {
                    renderInlineTab(root, 'inbound');
                }
            })
            .catch(function (error) {
                inboundPackingGoodsCache.delete(cacheKey);
                console.warn('[입고 포장명세서 품목 상세 조회 실패]', error);
            });
    }

    function hasInboundGoodsList(row) {
        return goodsListOf(row).length > 0;
    }

    function ensureInboundGoodsDetail(root, trcNo) {
        const row = workRow('inbound', trcNo) || workRow('release', trcNo);
        if (hasInboundGoodsList(row)) return;

        const wirNo = pick(row, ['wirNo', 'WIR_NO', 'inboundRequestNo'], '');
        if (!wirNo) return;

        const cacheKey = String(wirNo);
        if (inboundDetailGoodsCache.get(cacheKey) === 'loading' || inboundDetailGoodsCache.get(cacheKey) === 'done') return;
        inboundDetailGoodsCache.set(cacheKey, 'loading');

        getJson('/transport/import/unloading-in/detail.do?wirNo=' + encodeURIComponent(wirNo) + '&_=' + Date.now())
            .then(function (detail) {
                inboundDetailGoodsCache.set(cacheKey, 'done');
                if (!window.__TACS_IMPORT_INBOUND_DETAIL_ROWS) window.__TACS_IMPORT_INBOUND_DETAIL_ROWS = [];
                mergeInboundDetailIntoStores(trcNo, detail);
                if (root && root.isConnected && (root.dataset.activeWorkId === 'inbound' || root.dataset.activeWorkId === 'release')) {
                    renderInlineTab(root, root.dataset.activeWorkId);
                }
            })
            .catch(function (error) {
                inboundDetailGoodsCache.delete(cacheKey);
                console.warn('[입고 품목 상세 조회 실패]', error);
            });
    }

    function ensureInboundSupplementMessage(root, trcNo) {
        const row = workRow('inbound', trcNo);
        const rawStatus = pick(row, [
            'inStatusNm', 'warehouseInStatusNm', 'wirStatusNm', 'statusNm', 'statusCd',
            'warehouseInStatusCd', 'warehouseReplyStatusCd', 'wirStatusCd', 'whInStatusNm',
            'whReplyStatusCd', 'wirWhReplyStatusCd', 'WIR_STATUS_CD', 'WIR_WH_REPLY_STATUS_CD'
        ], '');
        const status = statusText(rawStatus, '입고대기');
        const hasMessage = normalizeText(inboundSupplementMessage(row));
        if (hasMessage || status !== '보완요청') return;

        const wirNo = pick(row, ['wirNo', 'WIR_NO', 'inboundRequestNo'], trcNo);
        if (!wirNo) return;

        const cacheKey = String(wirNo);
        if (inboundDetailMessageCache.get(cacheKey) === 'loading' || inboundDetailMessageCache.get(cacheKey) === 'done') return;
        inboundDetailMessageCache.set(cacheKey, 'loading');

        getJson('/transport/import/unloading-in/detail.do?wirNo=' + encodeURIComponent(wirNo) + '&_=' + Date.now())
            .then(function (detail) {
                inboundDetailMessageCache.set(cacheKey, 'done');
                mergeInboundDetailIntoStores(trcNo, detail);
                if (root && root.isConnected && root.dataset.activeWorkId === 'inbound') {
                    renderInlineTab(root, 'inbound');
                }
            })
            .catch(function (error) {
                inboundDetailMessageCache.delete(cacheKey);
                console.warn('[입고 보완요청 메시지 상세 조회 실패]', error);
            });
    }

    function goImportRequestListFromDetail(event) {
        if (event && typeof event.preventDefault === 'function') event.preventDefault();
        if (event && typeof event.stopPropagation === 'function') event.stopPropagation();
        if (event && typeof event.stopImmediatePropagation === 'function') event.stopImmediatePropagation();

        rememberImportRoute({ type: 'menu', itemId: REQUEST_LIST_ID });
        importBootRestoreDeadline = 0;
        importBootRestoreRoute = null;

        if (typeof window.renderCurrentImportRequestList === 'function') {
            window.renderCurrentImportRequestList(event);
        } else if (typeof window.openDetail === 'function') {
            window.openDetail(GROUP, REQUEST_LIST_ID);
        }

        const body = document.getElementById('detail-body');
        if (body) {
            body.dataset.currentGroup = GROUP;
            body.dataset.currentItem = REQUEST_LIST_ID;
            body.dataset.importViewMode = 'left-list';
        }

        return false;
    }

    function isImportRequestDetailBodyActive() {
        const body = document.getElementById('detail-body');
        return !!(body && body.dataset.currentGroup === GROUP && body.dataset.currentItem === REQUEST_DETAIL_ID);
    }

    function pinImportDetailBackButton(reschedule) {
        const back = document.getElementById('backBtn');
        if (!back) return;
        back.classList.remove('hidden');
        back.setAttribute('data-import-detail-back', 'request-list');
        back.setAttribute('aria-label', '운송의뢰 목록으로 돌아가기');
        if (back.tagName && back.tagName.toLowerCase() === 'a') {
            back.setAttribute('href', withContext('/transport/import.do?tab=request'));
            back.removeAttribute('target');
        }
        back.innerHTML = '<span class="material-symbols-outlined text-lg">arrow_back</span><span>운송의뢰</span>';
        back.onclick = goImportRequestListFromDetail;
        installImportDetailBackCapture();

        // 상세 탭 렌더 직후 다른 공통 라우터가 backBtn을 다시 "대시보드로"로 덮는 경우를 방어한다.
        if (reschedule === false) return;
        [0, 80, 250, 600].forEach(function (delay) {
            setTimeout(function () {
                if (isImportRequestDetailBodyActive()) pinImportDetailBackButton(false);
            }, delay);
        });
    }

    function installImportDetailBackCapture() {
        if (window.__TACS_IMPORT_DETAIL_BACK_CAPTURE) return;
        window.__TACS_IMPORT_DETAIL_BACK_CAPTURE = true;
        document.addEventListener('click', function (event) {
            const target = event.target && event.target.closest ? event.target.closest('#backBtn,[data-import-detail-back="request-list"]') : null;
            if (!target) return;
            const body = document.getElementById('detail-body');
            const isDetail = !!(body && body.dataset.currentGroup === GROUP && body.dataset.currentItem === REQUEST_DETAIL_ID);
            const isPinned = target.getAttribute('data-import-detail-back') === 'request-list';
            const labelText = normalizeText(target.textContent || '');
            if (!isDetail && !isPinned && labelText !== '운송의뢰') return;
            goImportRequestListFromDetail(event);
        }, true);
    }

    function renderShell(title, itemId, bodyHtml, options) {
        options = options || {};
        const dashboard = document.getElementById('dashboard-view');
        const detail = document.getElementById('detail-view');
        const body = document.getElementById('detail-body');
        const pageTitle = document.getElementById('page-title');
        const breadcrumb = document.getElementById('breadcrumb');
        const back = document.getElementById('backBtn');

        try { currentGroupKey = GROUP; currentItemId = itemId; } catch (e) {}
        if (typeof window.toggleMenuGroup === 'function') window.toggleMenuGroup(GROUP, true);
        if (typeof window.setActiveNav === 'function') window.setActiveNav(GROUP, itemId === REQUEST_DETAIL_ID ? REQUEST_LIST_ID : itemId);
        if (typeof window.setSavedLastItemId === 'function') window.setSavedLastItemId(GROUP, itemId);

        if (dashboard) dashboard.classList.add('hidden');
        if (detail) detail.classList.remove('hidden');
        if (pageTitle) pageTitle.textContent = title;
        if (breadcrumb) breadcrumb.innerHTML = '수입운송 &gt; <span class="font-semibold text-slate-900">' + esc(title) + '</span>';
        if (body) {
            window.detailBody = body;
            body.dataset.currentGroup = GROUP;
            body.dataset.currentItem = itemId;
            if (itemId === REQUEST_DETAIL_ID) bumpImportInlineRenderToken();
            body.innerHTML = bodyHtml;
        }
        if (back) {
            if (options.backHandler) {
                back.classList.remove('hidden');
                back.innerHTML = options.backLabelHtml || '<span class="material-symbols-outlined text-lg">arrow_back</span><span>운송의뢰</span>';
                back.onclick = options.backHandler;
            } else {
                pinImportDetailBackButton();
            }
        }
        if (typeof window.normalizeDetailActionButtons === 'function') window.normalizeDetailActionButtons();
        return body;
    }

    function ensureStyle() {
        if (document.getElementById('tacs-import-ui-clean-style')) return;
        const style = document.createElement('style');
        style.id = 'tacs-import-ui-clean-style';
        style.textContent = `
            #detail-body .import-ui-tabs{margin:0 0 0;border:1px solid #cbd5e1;background:#fff;}
            #detail-body .import-ui-tab-bar{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));border-bottom:1px solid #cbd5e1;background:#fff;}
            #detail-body .import-ui-tab{position:relative;height:56px;border:0;border-right:1px solid #d7e1ef;background:#fff;font-size:13px;font-weight:900;color:#0f172a;cursor:pointer;}
            #detail-body .import-ui-tab:last-child{border-right:0;}
            #detail-body .import-ui-tab:hover{background:#f3f7ff;color:#1d4ed8;}
            #detail-body .import-ui-tab.is-disabled{opacity:.72;cursor:help;background:#f8fafc;color:#94a3b8;}
            #detail-body .import-ui-tab.is-disabled:hover{background:#eef2f7;color:#64748b;}
            #detail-body .import-ui-tab.is-disabled::after{content:attr(data-lock-message);display:none;position:absolute;left:50%;top:calc(100% + 8px);transform:translateX(-50%);z-index:9999;width:max-content;max-width:340px;padding:9px 11px;border:1px solid #cbd5e1;border-radius:10px;background:#0f172a;color:#fff;font-size:12px;font-weight:800;line-height:1.45;text-align:left;white-space:normal;box-shadow:0 10px 25px rgba(15,23,42,.18);pointer-events:none;}
            #detail-body .import-ui-tab.is-disabled::before{content:'';display:none;position:absolute;left:50%;top:100%;transform:translateX(-50%);z-index:10000;border:7px solid transparent;border-bottom-color:#0f172a;pointer-events:none;}
            #detail-body .import-ui-tab.is-disabled:hover::after,#detail-body .import-ui-tab.is-disabled:hover::before{display:block;}
            #detail-body .import-ui-tab.is-active{background:#eaf2ff;color:#0f3f8c;box-shadow:none;}
            #detail-body .import-ui-panel{display:none;padding:16px;background:#fff;border-bottom:1px solid #dbe4f0;}
            #detail-body .import-ui-panel.is-active{display:block;}
            #detail-body .import-ui-request-detail{border:1px solid #cbd5e1;border-top:1px solid #cbd5e1;background:#fff;}
            #detail-body .import-ui-grid3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px;padding:16px;}
            #detail-body .import-ui-extra-section{padding:0 16px 16px;}
            #detail-body .import-ui-goods-table-wrap{border:1px solid #cbd5e1;background:#fff;overflow-x:auto;}
            #detail-body .import-ui-goods-table{width:100%;border-collapse:collapse;font-size:12px;}
            #detail-body .import-ui-goods-table th{background:#eaf2ff;border-bottom:1px solid #94a3b8;padding:10px 12px;text-align:center;font-weight:900;color:#0f172a;}
            #detail-body .import-ui-goods-table td{border-bottom:1px solid #e2e8f0;padding:10px 12px;text-align:center;color:#0f172a;font-weight:700;vertical-align:middle;}
            #detail-body .import-ui-goods-table tr:last-child td{border-bottom:0;}
            #detail-body .import-ui-goods-table .left{text-align:left;}
            #detail-body .import-ui-goods-edit{width:100%;height:34px;min-height:34px;border:1px solid #cbd5e1;background:#fff;padding:0 8px;box-sizing:border-box;font-size:12px;font-weight:700;line-height:1.2;color:#0f172a;}
            #detail-body .import-ui-goods-edit[readonly]{background:#e5e7eb;color:#334155;-webkit-text-fill-color:#334155;cursor:default;}
            #detail-body .import-ui-goods-empty{text-align:center!important;color:#64748b!important;background:#f8fafc!important;font-weight:800;}
            #detail-body .import-ui-section{border:1px solid #cbd5e1;background:#fff;padding:14px 16px;}
            #detail-body .import-ui-section h5,.import-ui-card h4{margin:0 0 12px;padding-left:9px;border-left:4px solid #334155;font-size:12px;font-weight:900;color:#0f172a;}
            #detail-body .import-ui-field{margin-bottom:10px;}
            #detail-body .import-ui-field label{display:block;margin:0 0 6px;font-size:11px;font-weight:900;color:#475569;}
            #detail-body .import-ui-field input,#detail-body .import-ui-field select,#detail-body .import-ui-field textarea{width:100%;min-height:40px;border:1px solid #cbd5e1;background:#e5e7eb;padding:0 10px;font-size:12px;font-weight:700;color:#334155;outline:0;box-sizing:border-box;}
            #detail-body .import-ui-field textarea{min-height:76px;padding:10px;resize:vertical;}
            #detail-body .import-ui-field input.import-ui-editable,#detail-body .import-ui-field select.import-ui-editable,#detail-body .import-ui-field textarea.import-ui-editable{background:#fff;color:#0f172a;}
            #detail-body .import-ui-option-cell{display:flex;align-items:center;gap:6px;}
            #detail-body .import-ui-option-cell .import-ui-option-display{min-width:0;cursor:pointer;}
            #detail-body .import-ui-option-btn{display:inline-flex;align-items:center;justify-content:center;flex:0 0 52px;width:52px;height:40px;min-height:40px;border:1px solid #334155;background:#334155;color:#fff;-webkit-text-fill-color:#fff;font-size:12px;font-weight:900;line-height:1;cursor:pointer;}
            #detail-body .import-ui-field input.import-ui-editable:disabled,#detail-body .import-ui-field select.import-ui-editable:disabled,#detail-body .import-ui-field textarea.import-ui-editable:disabled{background:#e5e7eb!important;color:#334155!important;-webkit-text-fill-color:#334155!important;opacity:1!important;cursor:not-allowed;}
            #detail-body .import-ui-field select.import-ui-editable:disabled option{color:#334155!important;background:#e5e7eb!important;}
            #detail-body .import-ui-file-cell{display:flex;gap:8px;align-items:center;}
            #detail-body .import-ui-file-cell input{min-width:0;}
            #detail-body .import-ui-file-download{display:inline-flex!important;align-items:center!important;justify-content:center!important;flex:0 0 auto!important;min-width:72px!important;min-height:38px!important;border:1px solid #334155!important;background:#1e293b!important;color:#fff!important;-webkit-text-fill-color:#fff!important;padding:9px 11px!important;font-size:12px!important;font-weight:900!important;text-decoration:none!important;}
            #detail-body .import-ui-actions{display:flex;justify-content:flex-end;align-items:center;gap:8px;padding:14px 16px;border-top:1px solid #e2e8f0;}
            #detail-body .import-ui-btn{display:inline-flex;align-items:center;justify-content:center;box-sizing:border-box;min-height:34px;padding:0 14px;border:1px solid #1e293b;background:#1e293b;color:#fff;-webkit-text-fill-color:#fff;font-size:12px;font-weight:900;line-height:1;white-space:nowrap;cursor:pointer;vertical-align:middle;}
            #detail-body .import-ui-btn.secondary{background:#fff;color:#1e293b;-webkit-text-fill-color:#1e293b;border-color:#cbd5e1;}
            #detail-body .import-ui-btn.danger{background:#b91c1c;border-color:#b91c1c;color:#fff;-webkit-text-fill-color:#fff;}
            #detail-body .import-ui-btn:disabled{cursor:not-allowed!important;}
            #detail-body .import-ui-do-flow-btn,.import-ui-do-flow-btn{display:inline-flex!important;align-items:center!important;justify-content:center!important;box-sizing:border-box!important;width:112px!important;min-width:112px!important;max-width:112px!important;height:34px!important;min-height:34px!important;max-height:34px!important;margin:0!important;padding:0 12px!important;border:1px solid #1e293b!important;border-radius:0!important;opacity:1!important;font-size:12px!important;font-weight:900!important;line-height:1!important;text-align:center!important;white-space:nowrap!important;vertical-align:middle!important;box-shadow:none!important;appearance:none!important;-webkit-appearance:none!important;}
            #detail-body .import-ui-do-flow-btn.is-active,.import-ui-do-flow-btn.is-active{background:#1e293b!important;border-color:#1e293b!important;color:#fff!important;-webkit-text-fill-color:#fff!important;cursor:pointer!important;}
            #detail-body .import-ui-do-flow-btn.is-locked,#detail-body .import-ui-do-flow-btn.is-done,#detail-body .import-ui-do-flow-btn:disabled,.import-ui-do-flow-btn.is-locked,.import-ui-do-flow-btn.is-done,.import-ui-do-flow-btn:disabled{pointer-events:none!important;box-shadow:none!important;background:#e5e7eb!important;border-color:#cbd5e1!important;color:#64748b!important;-webkit-text-fill-color:#64748b!important;opacity:1!important;filter:none!important;cursor:not-allowed!important;}
            #detail-body .import-ui-field input[readonly],#detail-body .import-ui-field textarea[readonly]{cursor:default!important;}
            #detail-body .import-ui-two-col{display:grid;grid-template-columns:minmax(0,1.25fr) minmax(320px,.75fr);gap:16px;}
            #detail-body .import-ui-form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;}
            #detail-body .import-ui-doc-field{grid-column:1/-1;}
            #detail-body .import-ui-doc-toolbar{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
            #detail-body .import-ui-doc-select,#detail-body .import-ui-doc-upload-btn{display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:7px 12px;border:1px solid #334155;background:#475569;color:#fff;-webkit-text-fill-color:#fff;font-size:12px;font-weight:900;cursor:pointer;}
            #detail-body .import-ui-doc-upload-btn{background:#1e293b;color:#fff;-webkit-text-fill-color:#fff;}
            #detail-body .import-ui-doc-help{font-size:12px;color:#64748b;font-weight:700;}
            #detail-body .import-ui-doc-drop{min-height:94px;border:1px dashed #94a3b8;background:#f8fafc;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;font-size:12px;color:#475569;cursor:pointer;margin-bottom:10px;text-align:center;}
            #detail-body .import-ui-doc-drop:hover,#detail-body .import-ui-doc-drop.is-dragover{background:#eff6ff;border-color:#2563eb;color:#1d4ed8;}
            #detail-body .import-ui-doc-summary{font-size:11px;color:#64748b;max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding:0 10px;}
            #detail-body .import-ui-doc-table-wrap{border:1px solid #cbd5e1;background:#fff;overflow-x:auto;}
            #detail-body .import-ui-doc-table{width:100%;border-collapse:collapse;font-size:12px;}
            #detail-body .import-ui-doc-table th{background:#eaf2ff;border-bottom:1px solid #cbd5e1;padding:8px 10px;text-align:left;font-weight:900;color:#334155;}
            #detail-body .import-ui-doc-table td{border-bottom:1px solid #e2e8f0;padding:8px 10px;color:#0f172a;vertical-align:middle;}
            #detail-body .import-ui-doc-table tr:last-child td{border-bottom:0;}
            #detail-body .import-ui-doc-empty{text-align:center!important;color:#64748b!important;background:#f1f5f9!important;font-weight:800;}
            #detail-body .import-ui-doc-name{font-weight:900;word-break:break-all;}\n            #detail-body .import-ui-doc-status{text-align:center!important;white-space:nowrap!important;}\n
            #detail-body .import-ui-doc-chip{display:inline-flex;align-items:center;justify-content:center;min-height:20px;padding:2px 8px;border-radius:999px;background:#e2e8f0;color:#334155;font-size:11px;font-weight:900;line-height:1;white-space:nowrap;}
            #detail-body .import-ui-doc-chip.pending{background:#fff7ed;color:#c2410c;border:1px solid #fed7aa;}
            #detail-body .import-ui-doc-chip.done{background:#dcfce7;color:#166534;border:1px solid #bbf7d0;}
            #detail-body .import-ui-doc-action{text-align:center!important;white-space:nowrap;}
            #detail-body .import-ui-doc-action a,#detail-body .import-ui-doc-remove{display:inline-flex;align-items:center;justify-content:center;min-height:26px;padding:5px 9px;border:1px solid #334155;background:#fff;color:#0f172a;font-size:11px;font-weight:900;text-decoration:none;cursor:pointer;}
            #detail-body .import-ui-doc-remove{border-color:#fecaca;background:#fee2e2;color:#991b1b;}
            #detail-body .import-ui-summary-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;}
            #detail-body .import-ui-summary-cell{border:1px solid #cbd5e1;background:#fff;padding:12px;}
            #detail-body .import-ui-summary-cell span{display:block;font-size:11px;font-weight:800;color:#64748b;}
            #detail-body .import-ui-summary-cell strong{display:block;margin-top:4px;font-size:13px;font-weight:900;color:#0f172a;word-break:break-word;}
            #detail-body td:has(.import-request-detail-btn){display:table-cell!important;text-align:center!important;vertical-align:middle!important;white-space:nowrap;}
            #detail-body td:has(.import-request-detail-btn) .btn,#detail-body td:has(.import-request-detail-btn) button,#detail-body td:has(.import-request-detail-btn) a{margin:0!important;vertical-align:middle;}
            #detail-body .import-request-action-cell{display:table-cell!important;text-align:center!important;vertical-align:middle!important;white-space:nowrap!important;}
            #detail-body .import-request-action-cell button,#detail-body .import-request-action-cell a{display:inline-flex!important;align-items:center!important;justify-content:center!important;margin:0 3px!important;vertical-align:middle!important;}
            #detail-body .import-request-status-col,#detail-body .import-request-status-cell{width:96px!important;min-width:96px!important;max-width:96px!important;text-align:center!important;vertical-align:middle!important;white-space:nowrap!important;box-sizing:border-box!important;}
            #detail-body .import-request-status-badge{display:inline-flex!important;align-items:center!important;justify-content:center!important;width:70px!important;min-width:70px!important;max-width:70px!important;height:22px!important;min-height:22px!important;max-height:22px!important;padding:0 4px!important;border-radius:3px!important;box-sizing:border-box!important;font-size:11px!important;font-weight:900!important;line-height:1!important;text-align:center!important;white-space:nowrap!important;overflow:hidden!important;text-overflow:ellipsis!important;animation:none!important;transition:none!important;transform:none!important;box-shadow:none!important;}
            #detail-body .import-request-status-badge.import-tone-wait{background:#dbeafe!important;border:1px solid #93c5fd!important;color:#1d4ed8!important;-webkit-text-fill-color:#1d4ed8!important;}
            #detail-body .import-request-status-badge.import-tone-done{background:#dcfce7!important;border:1px solid #86efac!important;color:#15803d!important;-webkit-text-fill-color:#15803d!important;}
            #detail-body .import-request-status-badge.import-tone-danger{background:#fee2e2!important;border:1px solid #fecaca!important;color:#b91c1c!important;-webkit-text-fill-color:#b91c1c!important;}
            #detail-body .import-request-status-badge.import-tone-neutral{background:#f1f5f9!important;border:1px solid #cbd5e1!important;color:#475569!important;-webkit-text-fill-color:#475569!important;}
            .import-option-modal{position:fixed;inset:0;z-index:3000;align-items:center;justify-content:center;padding:24px;font-family:Pretendard,"Noto Sans KR","Malgun Gothic",Arial,sans-serif;}
            .import-option-backdrop{position:absolute;inset:0;background:rgba(15,23,42,.42);}
            .import-option-panel{position:relative;z-index:1;width:min(680px,100%);max-height:82vh;background:#fff;border:1px solid #334155;box-shadow:0 18px 50px rgba(15,23,42,.22);display:flex;flex-direction:column;}
            .import-option-head{height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 16px;border-bottom:1px solid #cbd5e1;background:#f8fafc;}
            .import-option-head h4{margin:0;font-size:14px;font-weight:900;color:#0f172a;}
            .import-option-close{width:34px;height:34px;border:0;background:transparent;color:#334155;font-size:24px;line-height:1;cursor:pointer;}
            .import-option-search{display:flex;gap:8px;padding:14px 16px;border-bottom:1px solid #e2e8f0;}
            .import-option-search input{flex:1;min-width:0;height:38px;border:1px solid #cbd5e1;padding:0 10px;font-size:12px;font-weight:700;color:#0f172a;outline:0;}
            .import-option-search-btn{width:64px;height:38px;border:1px solid #334155;background:#334155;color:#fff;font-size:12px;font-weight:900;cursor:pointer;}
            .import-option-list-wrap{overflow:auto;}
            .import-option-table{width:100%;border-collapse:collapse;font-size:12px;}
            .import-option-table th{height:38px;padding:9px 12px;background:#f8fafc;border-bottom:1px solid #cbd5e1;color:#334155;font-weight:900;text-align:left;}
            .import-option-table td{height:40px;padding:9px 12px;border-bottom:1px solid #e2e8f0;color:#0f172a;font-weight:700;}
            .import-option-row{cursor:pointer;}
            .import-option-row:hover{background:#eaf2ff;}
            .import-option-empty{text-align:center!important;color:#64748b!important;background:#f8fafc!important;font-weight:800!important;}
            @media(max-width:1200px){#detail-body .import-ui-grid3,#detail-body .import-ui-two-col{grid-template-columns:1fr;}#detail-body .import-ui-summary-grid{grid-template-columns:repeat(2,minmax(0,1fr));}}
            @media(max-width:760px){#detail-body .import-ui-tab-bar{grid-template-columns:1fr;}#detail-body .import-ui-form-grid,#detail-body .import-ui-summary-grid{grid-template-columns:1fr;}#detail-body .import-ui-file-cell{align-items:stretch;flex-direction:column;}#detail-body .import-ui-file-download{text-align:center;}}
        `;
        document.head.appendChild(style);
    }

    function requestDetailHtml(req) {
        req = mergeRequestDetailDraft(req || {});
        const no = currentRequestNo(req);
        const originalRow = findRequestRow(no) || {};
        const receiptStatusRaw = pick(req, [
            'receiptStatus', 'receiptStatusNm', 'receiptStatusCd',
            'trcStatusNm', 'trcStatusCd', 'TRC_STATUS_NM', 'TRC_STATUS_CD',
            'status', 'statusNm', 'statusCd'
        ], pick(originalRow, [
            'receiptStatus', 'receiptStatusNm', 'receiptStatusCd',
            'trcStatusNm', 'trcStatusCd', 'TRC_STATUS_NM', 'TRC_STATUS_CD',
            'status', 'statusNm', 'statusCd'
        ], ''));
        const status = normalizeText(receiptStatusRaw) ? normalizeReceiptStatus(receiptStatusRaw) : '확인중';
        const displayStatus = normalizeText(req.displayStatus) || status;
        let invoiceFileName = pick(req, [
            'invoiceFile', 'invoiceFileNm', 'invoiceFileName', 'invoiceOrgNm',
            'invFile', 'invFileNm', 'invOrgNm', 'INVOICE_FILE', 'INVOICE_FILE_NM', 'INV_FILE_NM'
        ], pick(originalRow, [
            'invoiceFile', 'invoiceFileNm', 'invoiceFileName', 'invoiceOrgNm',
            'invFile', 'invFileNm', 'invOrgNm', 'INVOICE_FILE', 'INVOICE_FILE_NM', 'INV_FILE_NM'
        ], ''));
        let invoiceFileNo = pick(req, [
            'invoiceFileNo', 'invoiceDfiNo', 'invoiceDfiFileNo',
            'invFileNo', 'invDfiNo', 'dfiInvoiceNo', 'INVOICE_FILE_NO', 'INV_FILE_NO'
        ], pick(originalRow, [
            'invoiceFileNo', 'invoiceDfiNo', 'invoiceDfiFileNo',
            'invFileNo', 'invDfiNo', 'dfiInvoiceNo', 'INVOICE_FILE_NO', 'INV_FILE_NO'
        ], ''));
        const invoiceUrl = pick(req, ['invoiceUrl', 'invoiceFileUrl', 'invFileUrl'], pick(originalRow, ['invoiceUrl', 'invoiceFileUrl', 'invFileUrl'], ''));
        const packingFileName = pick(req, ['packingListFile', 'pkgListFile'], pick(originalRow, ['packingListFile', 'pkgListFile', 'PACKING_LIST_FILE'], ''));
        const packingFileNo = pick(req, ['packingListFileNo', 'pkgFileNo'], pick(originalRow, ['packingListFileNo', 'pkgFileNo', 'PACKING_LIST_FILE_NO'], ''));
        const packingUrl = pick(req, ['packingListUrl', 'packingListFileUrl', 'pkgFileUrl'], pick(originalRow, ['packingListUrl', 'packingListFileUrl', 'pkgFileUrl'], ''));
        const blPdfFileName = pick(req, ['blPdfFile', 'blFile', 'mblFile'], pick(originalRow, ['blPdfFile', 'blFile', 'mblFile', 'BL_PDF_FILE'], ''));
        const blPdfFileNo = pick(req, ['blPdfFileNo', 'blFileNo', 'mblFileNo'], pick(originalRow, ['blPdfFileNo', 'blFileNo', 'mblFileNo', 'BL_PDF_FILE_NO'], ''));
        // Master B/L 칸은 실제 B/L 번호만 표시한다. 번호가 아직 없으면 빈칸으로 두고
        // 운송담당자가 선하증권 PDF를 보고 직접 입력한다. (mblFile/hblFile 등 첨부파일명은 폴백에서 제외)
        const masterBl = pick(
            mergeUsableRows(mergedRequestContext(no), originalRow || {}, req || {}),
            ['mblNo', 'masterBlNo', 'masterBl', 'blNo', 'icmMblNo', 'ICM_MBL_NO', 'biMblNo', 'BI_MBL_NO', 'irBlAwbNo', 'IR_BL_AWB_NO'],
            ''
        );
        const buyerName = pick(req, ['consignorName', 'buyerName', 'buyerNm'], '');
        const buyerCountry = pick(req, ['consignorCountry', 'buyerCountry', 'buyerCountryCd'], '');
        const cargoCtx = mergeUsableRows(mergedRequestContext(no), originalRow || {}, req || {});
        const requestGoodsName = requestCargoGoodsName(no, req, originalRow);
        const requestQty = pick(cargoCtx, ['qty', 'goodsQty', 'totalQty', 'CG_QTY', 'TOTAL_QTY', 'QTY'], '');
        const requestWeight = pick(cargoCtx, ['weight', 'goodsWeight', 'totalWeight', 'netWeight', 'CG_WEIGHT', 'TOTAL_WEIGHT', 'NET_WEIGHT', 'WEIGHT'], '');
        /*
         * 운송의뢰는 접수대기 상태에서만 수정 가능하다.
         * 접수완료/반려 이후에는 승인된 의뢰 원본으로 보고 전부 readonly 처리한다.
         */
        const canEditRequest = !req.__routeStub && normalizeText(receiptStatusRaw) && status === '접수대기';
        const noticeSent = isArrivalNoticeSent(no)
            || displayStatus === '도착통지서 발송완료'
            || displayStatus === '발송완료'
            || normalizeText(req.arrivalNoticeStatus) === 'TRC_NTC_SENT'
            || normalizeText(req.arrivalNoticeStatusCd) === 'TRC_NTC_SENT'
            || normalizeText(req.arrivalNoticeSendStatusCd) === 'TRC_NTC_SENT';
        const detailSaved = savedImportRequestDetails.has(no);
        const actionHtml = canEditRequest
            ? '<div class="import-ui-actions"><button type="button" class="import-ui-btn danger request-reject-btn" data-request-type="수입" data-request-no="' + esc(no) + '">반려</button><button type="button" class="import-ui-btn import-request-save-btn" data-request-no="' + esc(no) + '"' + (detailSaved ? ' disabled aria-disabled="true"' : '') + '>' + (detailSaved ? '저장완료' : '저장') + '</button><button type="button" class="import-ui-btn import-request-submit-btn" data-request-no="' + esc(no) + '">수락</button></div>'
            : status === '접수반려'
                ? '<div class="import-ui-actions"><span class="info-chip">접수반려</span></div>'
                : '<div class="import-ui-actions"><span class="info-chip">' + esc(noticeSent ? '발송완료' : status) + '</span></div>';

        return ''
            + '<div class="import-ui-request-detail import-ui-main-request-detail" data-request-no="' + esc(no) + '">'
            + '<div class="import-ui-grid3">'
            + '<div class="import-ui-section"><h5>1. 의뢰/화주 정보</h5>'
            + field('의뢰번호', no)
            + field('접수일자', req.receiptDate, {name: 'receiptDate'})
            + field('접수상태', status)
            + field('화주명', req.shipperName, {name: 'shipperName'})
            + field('화주 연락처', req.shipperPhone, {name: 'shipperPhone'})
            + field('화주 이메일', req.shipperEmail, {name: 'shipperEmail'})
            + '</div>'
            + '<div class="import-ui-section"><h5>2. 운송/B/L 정보</h5>'
            + field('바이어명', buyerName, {editable: canEditRequest, name: 'buyerName'})
            + optionField('거래자 국가', buyerCountry, {editable: canEditRequest, name: 'buyerCountry'})
            + optionField('운송수단', req.transportMode, {editable: canEditRequest, name: 'transportMode'})
            + optionField('운송형태', req.transportType, {editable: canEditRequest, name: 'transportType'})
            + optionField('출발항', req.originPort, {editable: canEditRequest, name: 'originPort'})
            + optionField('도착항', req.destinationPort, {editable: canEditRequest, name: 'destinationPort'})
            + optionField('B/L 구분', req.blType, {editable: canEditRequest, name: 'blType'})
            + '</div>'
            + '<div class="import-ui-section"><h5>3. 화물/첨부/요청</h5>'
            + field('품명', requestGoodsName, {editable: canEditRequest, name: 'goodsName'})
            + field('수량', requestQty, {editable: canEditRequest, name: 'qty', type: 'number'})
            + field('중량(KG)', requestWeight, {editable: canEditRequest, name: 'weight', type: 'number'})
            + field('Master B/L', masterBl, {editable: canEditRequest, name: 'mblNo'})
            + fileDownloadField('선하증권(B/L)', blPdfFileName, blPdfFileNo, '')
            + fileDownloadField('송장', invoiceFileName, invoiceFileNo, invoiceUrl)
            + fileDownloadField('포장명세서', packingFileName, packingFileNo, packingUrl)
            + field('요청사항', req.requestNote, {textarea: true, name: 'requestNote'})
            + '</div>'
            + '</div>'
            + actionHtml
            + '</div>';
    }

    function tabsHtml(active) {
        active = active || 'request';
        return ''
            + '<div class="import-ui-tabs import-inline-tabs-0513" data-active-work-id="' + esc(active) + '">'
            + '<div class="import-ui-tab-bar">'
            + WORK_ITEMS.map(function (item) {
                return '<button type="button" class="import-ui-tab import-inline-tab' + (item.id === active ? ' is-active' : '') + '" data-work-id="' + esc(item.id) + '">' + esc(item.title) + '</button>';
            }).join('')
            + '</div>'
            + '<div class="import-ui-panel import-inline-panel"></div>'
            + '</div>';
    }

    /*
     * 딥링크(알림/대시보드)로 들어온 raw 목록행은 ownerNm/requestCn/requestDt 같은 원본 키를 쓰는데
     * 상세 렌더(requestDetailHtml)는 shipperName/requestNote/receiptDate 같은 정규화 키만 읽는다.
     * 버튼 클릭(selectedFromButton)과 달리 딥링크는 이 정규화를 안 거쳐 의뢰/화주 정보가 비어 보였다.
     * 빠진 정규화 키만 원본 키에서 채워 두 경로의 표시를 일치시킨다. (빈 값일 때만 채우므로 draft/입력값은 보존)
     */
    function normalizeRequestRowShape(req) {
        if (!req || typeof req !== 'object') return req;
        const fill = function (target, sources) {
            if (isUsableValue(req[target])) return;
            const value = pick(req, sources, '');
            if (isUsableValue(value)) req[target] = value;
        };
        fill('receiptDate', ['requestDt', 'trcRceptDt', 'registDt']);
        fill('shipperName', ['ownerNm', 'owrNm', 'trcOwrNm']);
        fill('shipperContact', ['ownerPicNm', 'owrPicNm']);
        fill('shipperPhone', ['ownerTelno', 'owrTelno']);
        fill('shipperEmail', ['ownerEmail', 'owrEmail']);
        fill('requestNote', ['requestCn', 'trcRequestCn']);
        fill('consignorName', ['buyerNm', 'buyerName', 'traderNm', 'trcTrdrNm']);
        fill('consignorCountry', ['buyerCountryCd', 'buyerCountryNm', 'traderCountryCd', 'trcTrdrCountryCd']);
        fill('carrierName', ['carrierNm']);
        fill('originPort', ['deptPortCd', 'deptPortNm']);
        fill('destinationPort', ['arvlPortCd', 'arvlPortNm']);
        fill('transportMode', ['transportMeanNm', 'transportMeanCd']);
        fill('transportType', ['transportTypeCd']);
        return req;
    }

    function renderRequestDetail(req, forcedWorkId) {
        ensureStyle();
        req = req || currentRequest();
        if (!currentRequestNo(req)) {
            const firstRow = requestRows()[0] || {};
            req = Object.assign({}, firstRow, req);
        }
        req = mergeRequestDetailDraft(req);
        normalizeRequestRowShape(req);
        setCurrentRequest(req);
        hydrateRequestGoodsIfNeeded(req);
        const initialWorkId = validImportWorkId(forcedWorkId || importRouteWorkId(req));
        updateImportDetailUrl(req, initialWorkId);
        const body = renderShell('운송의뢰', REQUEST_DETAIL_ID, '<div class="space-y-0">' + tabsHtml(initialWorkId) + requestDetailHtml(req) + '</div>');
        if (body) {
            const root = body.querySelector('.import-inline-tabs-0513');
            if (root) {
                root.dataset.requestNo = currentRequestNo(req);
                setTabDisabledState(root, req);
                renderInlineTab(root, initialWorkId);
            }
        }
        if (typeof window.bindImportRequestReceiptActions === 'function') {
            setTimeout(function () { window.bindImportRequestReceiptActions(GROUP, REQUEST_DETAIL_ID); }, 0);
        }
    }

    function isInboundReadonlyStatus(value) {
        const raw = normalizeText(value);
        const upper = raw.toUpperCase();
        return raw === '입고대기'
            || raw === '입고요청'
            || raw === '입고요청완료'
            || raw === '입고완료'
            || raw === '보완완료'
            || raw === '보완제출완료'
            || raw === '보완승인'
            || upper === 'WAIT'
            || upper === 'IN_WAIT'
            || upper === 'SENT'
            || upper === 'REQ_SENT'
            || upper === 'IN_DONE'
            || upper === 'SUB'
            || upper === 'APR';
    }

    function applyReadonlyToInboundHtml(html, readonly) {
        if (!readonly) return html;
        return html
            .replace(/<select name="(warehouseId|wzNo|wmId|incoTermsCd)" class="import-ui-editable">/g,
                '<select name="$1" class="import-ui-editable" disabled aria-readonly="true">')
            .replace(/<input([^>]*class="import-ui-editable"[^>]*)(?<!readonly)>/g,
                function (match, attrs) {
                    return match.indexOf(' readonly') >= 0 || match.indexOf(' disabled') >= 0
                        ? match
                        : '<input' + attrs + ' readonly aria-readonly="true">';
                })
            .replace(/<textarea([^>]*class="import-ui-editable"[^>]*)(?<!readonly)>/g,
                function (match, attrs) {
                    return match.indexOf(' readonly') >= 0 || match.indexOf(' disabled') >= 0
                        ? match
                        : '<textarea' + attrs + ' readonly aria-readonly="true">';
                })
            .replace(/<button type="button" class="import-ui-btn secondary import-ui-inbound-supp-btn"([^>]*)>보완<\/button>/g,
                '<button type="button" class="import-ui-btn secondary import-ui-inbound-supp-btn"$1 disabled>보완</button>')
            .replace(/<button type="button" class="import-ui-btn import-ui-inbound-send-btn"([^>]*)>발송<\/button>/g,
                '<button type="button" class="import-ui-btn import-ui-inbound-send-btn"$1 disabled>발송</button>')
            .replace(/<button type="button" class="import-ui-btn import-ui-inbound-send-btn"([^>]*)>보완제출<\/button>/g,
                '<button type="button" class="import-ui-btn import-ui-inbound-send-btn"$1 disabled>보완제출</button>');
    }

    function resolveWarehouseName(row) {
        row = row || {};
        const directOrMapped = warehouseNameFromRow(row);
        if (isMeaningfulOptionValue(directOrMapped)) return directOrMapped;

        const whValue = selectedWarehouseValue(row);
        if (isMeaningfulOptionValue(whValue)) {
            const matched = warehouseSourceRows().find(function (w) {
                return normalizeText(warehouseOptionValue(w)) === normalizeText(whValue)
                    || normalizeText(pick(w, WAREHOUSE_VALUE_KEYS, '')) === normalizeText(whValue);
            });
            const label = matched ? warehouseNameFromRow(matched) : '';
            if (isMeaningfulOptionValue(label)) return label;
        }

        const selectedWzNo = pick(row, WAREHOUSE_ZONE_VALUE_KEYS, '');
        if (isMeaningfulOptionValue(selectedWzNo)) {
            const matchedByZone = findWarehouseRowByZone(selectedWzNo);
            const labelByZone = matchedByZone ? warehouseNameFromRow(matchedByZone) : '';
            if (isMeaningfulOptionValue(labelByZone)) return labelByZone;
        }

        const selectedWmId = pick(row, WAREHOUSE_MANAGER_VALUE_KEYS, '');
        if (isMeaningfulOptionValue(selectedWmId)) {
            const matchedByManager = findWarehouseRowByManager(selectedWmId);
            const labelByManager = matchedByManager ? warehouseNameFromRow(matchedByManager) : '';
            if (isMeaningfulOptionValue(labelByManager)) return labelByManager;
        }

        return '-';
    }

    function resolveWarehouseZoneName(row) {
        row = row || {};
        const direct = pick(row, WAREHOUSE_ZONE_LABEL_KEYS, '');
        if (isMeaningfulOptionValue(direct)) return direct;

        const selectedWzNo = pick(row, WAREHOUSE_ZONE_VALUE_KEYS, '');
        if (isMeaningfulOptionValue(selectedWzNo)) {
            const matched = globalRows('TRANSPORT_WAREHOUSE_ZONE_LIST', 'WAREHOUSE_ZONE_LIST', 'TRANSPORT_WAREHOUSE_LIST', 'WAREHOUSE_LIST').find(function (z) {
                return normalizeText(warehouseZoneValue(z)) === normalizeText(selectedWzNo);
            });
            const label = matched ? pick(matched, WAREHOUSE_ZONE_LABEL_KEYS, '') : '';
            if (isMeaningfulOptionValue(label)) return label;
            return selectedWzNo;
        }

        return '-';
    }

    function resolveWarehouseManagerName(row) {
        row = row || {};
        const direct = pick(row, WAREHOUSE_MANAGER_LABEL_KEYS, '');
        if (isMeaningfulOptionValue(direct)) return direct;

        const selectedWmId = pick(row, WAREHOUSE_MANAGER_VALUE_KEYS, '');
        if (isMeaningfulOptionValue(selectedWmId)) {
            const matched = globalRows('TRANSPORT_WAREHOUSE_MANAGER_LIST', 'WAREHOUSE_MANAGER_LIST', 'TRANSPORT_WAREHOUSE_LIST', 'WAREHOUSE_LIST').find(function (m) {
                return normalizeText(warehouseManagerValue(m)) === normalizeText(selectedWmId);
            });
            const label = matched ? pick(matched, WAREHOUSE_MANAGER_LABEL_KEYS, '') : '';
            if (isMeaningfulOptionValue(label)) return label;
            return selectedWmId;
        }

        return '-';
    }


    function formatGoodsNumber(value, moneyYn) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '-';
        const n = numberOnly(raw);
        if (!n && !/^0([.]0+)?$/.test(raw.replace(/,/g, ''))) return raw;
        const formatted = n.toLocaleString('ko-KR', moneyYn ? {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        } : {});
        return moneyYn ? formatted + ' USD' : formatted;
    }

    function formatGoodsWeight(value) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '-';
        const n = numberOnly(raw);
        if (!n && !/^0([.]0+)?$/.test(raw.replace(/,/g, ''))) return raw;
        return n.toLocaleString('ko-KR') + ' KG';
    }

    function editableGoodsNumber(value, moneyYn) {
        const raw = normalizeText(value);
        if (!raw || raw === '-') return '';
        const cleaned = raw.replace(/,/g, '').replace(/[^0-9.-]/g, '');
        if (!moneyYn) return cleaned;
        const number = Number(cleaned);
        return Number.isFinite(number) ? number.toFixed(2) : cleaned;
    }

    function sanitizeGoodsDisplayName(value) {
        let raw = normalizeText(value);
        if (!raw || raw === '-') return raw;

        // 예: "전자기기 외 0건", "전자기기 외 0건 외 0건" => "전자기기"
        // 예: "전자기기 외 2건 외 0건" => "전자기기 외 2건"
        let prev;
        do {
            prev = raw;
            raw = raw
                .replace(/\s*외\s*0\s*건\s*$/g, '')
                .replace(/(\s*외\s*[1-9][0-9]*\s*건)\s*외\s*0\s*건\s*$/g, '$1')
                .replace(/(\s*외\s*[1-9][0-9]*\s*건)(?:\s*\1)+\s*$/g, '$1')
                .trim();
        } while (raw !== prev);

        return raw || '-';
    }

    function goodsSummaryNameFromList(source) {
        const list = goodsListOf(source);
        if (!list.length) return '';

        const names = [];
        list.forEach(function (item) {
            const name = sanitizeGoodsDisplayName(pick(item, [
                'goodsName', 'itemNm', 'goodsNm', 'name', 'itemName',
                'GOODS_NAME', 'ITEM_NM', 'CG_GOODS_NM', 'CG_GOODS_NAME', 'GDS_NM',
                'frghtIemNm', 'WIR_FRGHT_IEM_NM', 'CRR_FRGHT_IEM_NM'
            ], ''));
            if (!isUsableValue(name)) return;
            if (names.indexOf(name) < 0) names.push(name);
        });

        if (!names.length) return '';
        return names[0] + (names.length > 1 ? ' 외 ' + (names.length - 1) + '건' : '');
    }

    function displayGoodsName(row, req) {
        row = row || {};
        req = req || {};

        const trcNo = pick(row, REQUEST_NO_KEYS, '') || pick(req, REQUEST_NO_KEYS, '');
        const requestRow = trcNo ? workRow('request', trcNo) : null;
        const inboundRow = trcNo ? workRow('inbound', trcNo) : null;
        const releaseRow = trcNo ? workRow('release', trcNo) : null;
        const inlandRow = trcNo ? workRow('inland', trcNo) : null;
        const sources = [req, requestRow, inboundRow, releaseRow, inlandRow, row].filter(Boolean);

        // 반출관리/내륙배차 화면의 "품명"은 반출요청/배차 테이블의 임시 화물명보다
        // 운송의뢰/입고 품목 요약(CUSTOMS_GOODS/GOODS 기준, 예: THAI MILLED RICE 외 1건)을 우선 표시한다.
        const directGoodsKeys = [
            'goodsName', 'itemNm', 'goodsNm', 'summaryGoodsName', 'GOODS_NAME',
            'TRC_GOODS_NM', 'TRC_ITEM_NM', 'WIR_GOODS_NM', 'WIR_ITEM_NM'
        ];
        const requestGoodsValue = pick(requestRow, directGoodsKeys, '') || pick(req, directGoodsKeys, '');
        if (isUsableValue(requestGoodsValue)) return cleanPackingGoodsName(sanitizeGoodsDisplayName(requestGoodsValue));

        for (let i = 0; i < sources.length; i += 1) {
            const value = pick(sources[i], directGoodsKeys, '');
            if (isUsableValue(value)) return cleanPackingGoodsName(sanitizeGoodsDisplayName(value));
        }

        for (let i = 0; i < sources.length; i += 1) {
            const value = goodsSummaryNameFromList(sources[i]);
            if (isUsableValue(value)) return cleanPackingGoodsName(sanitizeGoodsDisplayName(value));
        }

        const fallbackCargoKeys = [
            'frghtIemNm', 'crrFrghtIemNm', 'cargoName', 'cargoNm',
            'CRR_FRGHT_IEM_NM', 'WIR_FRGHT_IEM_NM', 'DISPATCH_CARGO_NM'
        ];
        for (let i = 0; i < sources.length; i += 1) {
            const value = pick(sources[i], fallbackCargoKeys, '');
            if (isUsableValue(value)) return cleanPackingGoodsName(sanitizeGoodsDisplayName(value));
        }

        return cleanPackingGoodsName(sanitizeGoodsDisplayName(pick(req, ['itemCategory', 'itemCategoryNm', 'TRC_ITEM_CTGRY_NM'], '-')));
    }


    function goodsSectionHtml(row, req, editable) {
        row = row || {};
        req = req || {};
        editable = editable === true;

        const editableCell = function (key, value, type, readonly) {
            const inputType = type || 'text';
            const step = inputType === 'number'
                ? (key === 'price' || key === 'goodsTotalPrice' ? ' step="0.01"' : ' step="0.001"')
                : '';
            return '<input class="import-ui-editable import-ui-goods-edit" data-goods-field="' + esc(key) + '" type="' + esc(inputType) + '"' + step + ' value="' + esc(normalizeText(value)) + '"' + (readonly ? ' readonly tabindex="-1"' : '') + '>';
        };
        const calcTotalPrice = function (price, weight, totalPrice) {
            const priceNum = numberOnly(price);
            const weightNum = numberOnly(weight);
            return (priceNum && weightNum) ? (priceNum * weightNum).toFixed(2) : editableGoodsNumber(totalPrice, true);
        };
        const rowHtml = function (source) {
            source = source || {};
            const cgNo = pick(source, ['cgNo', 'CG_NO'], '');
            const goodsNo = pick(source, ['goodsNo', 'GOODS_NO'], '');
            const goodsName = cleanPackingGoodsName(sanitizeGoodsDisplayName(pick(source, [
                'goodsName', 'itemNm', 'GOODS_NAME', 'goodsNm', 'summaryGoodsName',
                'frghtIemNm', 'cargoName', 'CRR_FRGHT_IEM_NM', 'WIR_FRGHT_IEM_NM',
                'itemCategory', 'TRC_ITEM_CTGRY_NM'
            ], pick(req, ['goodsName', 'itemNm', 'GOODS_NAME', 'itemCategory'], ''))));
            const goodsHsCode = pick(source, ['goodsHsCode', 'hsCode', 'itemHsCode', 'GOODS_HS_CODE', 'goodsHsCd', 'HS_CODE'], '');
            const price = pick(source, ['price', 'goodsPrice', 'unitPrice', 'CG_PRICE', 'PRICE'], '');
            const qty = pick(source, ['qty', 'totalQty', 'goodsQty', 'CG_QTY', 'TOTAL_QTY', 'QTY'], '');
            const totalPrice = pick(source, ['goodsTotalPrice', 'summaryTotalPrice', 'totalPrice', 'CG_TOTAL_PRICE', 'SUMMARY_TOTAL_PRICE', 'TOTAL_PRICE'], '');
            const weight = pick(source, ['weight', 'totalWeight', 'netWeight', 'CG_WEIGHT', 'TOTAL_WEIGHT', 'WEIGHT'], '');
            const origin = pick(source, ['origin', 'originCountryCd', 'cgOrigin', 'CG_ORIGIN', 'ORIGIN_COUNTRY_CD'], '');
            const goodsCnt = pick(source, ['goodsCnt', 'GOODS_CNT'], '');
            const goodsCntNum = numberOnly(goodsCnt);
            const baseGoodsName = representativeGoodsBaseName(goodsName) || goodsName;
            const displayName = goodsCntNum > 1 && baseGoodsName && !/\s외\s*[0-9]+건$/.test(baseGoodsName)
                ? baseGoodsName + ' 외 ' + (goodsCntNum - 1) + '건'
                : baseGoodsName;

            return '<tr>'
              + '<td class="left" data-cg-no="' + esc(cgNo) + '" data-goods-no="' + esc(goodsNo) + '" data-goods-hs-code="' + esc(goodsHsCode || '') + '">'
              + (editable ? editableCell('goodsName', displayName || '', 'text') : esc(displayName || '-'))
              + '</td>'
              + '<td>' + (editable ? editableCell('price', editableGoodsNumber(price, true), 'number') : esc(formatGoodsNumber(price, true))) + '</td>' + '<td>' + (editable ? editableCell('qty', editableGoodsNumber(qty), 'number') : esc(formatGoodsNumber(qty, false) && formatGoodsNumber(qty, false) !== '-' ? formatGoodsNumber(qty, false) + ' Bags' : '-')) + '</td>'
              + '<td>' + (editable ? editableCell('goodsTotalPrice', calcTotalPrice(price, weight, totalPrice), 'number') : esc(formatGoodsNumber(totalPrice, true))) + '</td>'
              + '<td>' + (editable ? editableCell('weight', editableGoodsNumber(weight), 'number') : esc(formatGoodsWeight(weight))) + '</td>'
              + '<td>' + (editable ? editableCell('origin', origin || 'KR', 'text') : esc(origin || '-')) + '</td>'
              + (editable ? '<td><button type="button" class="import-ui-btn import-ui-goods-remove-btn">삭제</button></td>' : '')
              + '</tr>';
        };

        const detailRows = goodsListOf(row);
        const runtimeRows = runtimePackingGoodsList(row, req);
        let rows = hasGoodsCommercialFields(detailRows)
            ? detailRows
            : (hasGoodsCommercialFields(runtimeRows) ? runtimeRows : (detailRows.length ? detailRows : runtimeRows));
        if (!editable && rows.length) {
            const seen = {};
            rows = rows.filter(function (item) {
                item = item || {};
                const cgNo = normalizeText(pick(item, ['cgNo', 'CG_NO'], ''));
                const goodsNo = normalizeText(pick(item, ['goodsNo', 'GOODS_NO'], ''));
                const nm = normalizeText(pick(item, ['goodsName', 'itemNm', 'itemCategory', 'frghtIemNm', 'cargoName', 'GOODS_NAME'], ''));
                const qty = normalizeText(pick(item, ['qty', 'totalQty', 'goodsQty', 'CG_QTY', 'TOTAL_QTY', 'QTY'], ''));
                const price = normalizeText(pick(item, ['price', 'goodsPrice', 'unitPrice', 'CG_PRICE', 'PRICE'], ''));
                const totalPrice = normalizeText(pick(item, ['goodsTotalPrice', 'summaryTotalPrice', 'totalPrice', 'CG_TOTAL_PRICE', 'SUMMARY_TOTAL_PRICE', 'TOTAL_PRICE'], ''));
                const weight = normalizeText(pick(item, ['weight', 'totalWeight', 'netWeight', 'CG_WEIGHT', 'TOTAL_WEIGHT', 'WEIGHT'], ''));
                const origin = normalizeText(pick(item, ['origin', 'originCountryCd', 'cgOrigin', 'CG_ORIGIN', 'ORIGIN_COUNTRY_CD'], ''));
                const key = cgNo ? ('CG_NO:' + cgNo) : [goodsNo, nm, qty, price, totalPrice, weight, origin].join('|');
                if (!key || seen[key]) return false;
                seen[key] = true;
                return true;
            });
        }
        if (!rows.length) {
            const hasGoods = normalizeText(pick(row, ['goodsName', 'itemNm', 'itemCategory', 'frghtIemNm', 'cargoName', 'GOODS_NAME'], ''))
                || normalizeText(pick(row, ['goodsHsCode', 'hsCode', 'GOODS_HS_CODE'], ''))
                || normalizeText(pick(row, ['price', 'qty', 'goodsTotalPrice', 'weight'], ''));
            rows = hasGoods ? [row] : [];
        }

        const sourceJson = editable && rows.length > 1 ? esc(JSON.stringify(rows)) : '';
        const bodyHtml = rows.length
            ? rows.map(rowHtml).join('')
            : (editable ? rowHtml({origin: 'KR'}) : '<tr><td colspan="' + (editable ? '7' : '6') + '" class="import-ui-goods-empty">등록된 품목사항이 없습니다.</td></tr>');

        return ''
            + '<div class="import-ui-extra-section">'
            + '<section class="import-ui-section"><h5>4. 품목사항</h5>'
            + (editable ? '<div class="import-ui-actions" style="justify-content:flex-end;margin:0 0 8px;"><button type="button" class="import-ui-btn import-ui-goods-add-btn">+ 행추가</button></div>' : '')
            + '<div class="import-ui-goods-table-wrap"><table class="import-ui-goods-table">'
            + '<thead><tr><th>품명</th><th style="width:14%">단가(USD)</th><th style="width:12%">수량(Bags)</th><th style="width:16%">총금액(USD)</th><th style="width:12%">중량(KG)</th><th style="width:13%">원산지</th>' + (editable ? '<th style="width:80px">관리</th>' : '') + '</tr></thead>'
            + '<tbody data-goods-source="' + sourceJson + '">' + bodyHtml + '</tbody>'
            + '</table></div>'
            + '</section>'
            + '</div>';
    }




    function recalcInboundGoodsTotalPrice(input) {
        const row = input && input.closest ? input.closest('tr') : null;
        if (!row) return;
        const priceInput = row.querySelector('[data-goods-field="price"]');
        const weightInput = row.querySelector('[data-goods-field="weight"]');
        const totalInput = row.querySelector('[data-goods-field="goodsTotalPrice"]');
        if (!priceInput || !weightInput || !totalInput) return;
        const price = numberOnly(priceInput.value);
        const weight = numberOnly(weightInput.value);
        totalInput.value = (price && weight) ? (price * weight).toFixed(2) : '';
    }

    function createEditableGoodsRow(source) {
        source = source || {};
        const goodsName = cleanPackingGoodsName(representativeGoodsBaseName(pick(source, ['goodsName', 'itemNm', 'GOODS_NAME', 'goodsNm', 'frghtIemNm'], '')));
        const price = editableGoodsNumber(pick(source, ['price', 'goodsPrice', 'unitPrice', 'CG_PRICE', 'PRICE'], ''), true);
        const qty = editableGoodsNumber(pick(source, ['qty', 'totalQty', 'goodsQty', 'CG_QTY', 'TOTAL_QTY', 'QTY'], ''));
        const weight = editableGoodsNumber(pick(source, ['weight', 'totalWeight', 'netWeight', 'CG_WEIGHT', 'TOTAL_WEIGHT', 'WEIGHT'], ''));
        const totalPrice = editableGoodsNumber(pick(source, ['goodsTotalPrice', 'summaryTotalPrice', 'totalPrice', 'CG_TOTAL_PRICE', 'SUMMARY_TOTAL_PRICE', 'TOTAL_PRICE'], ''), true)
            || ((numberOnly(price) && numberOnly(weight)) ? (numberOnly(price) * numberOnly(weight)).toFixed(2) : '');
        const origin = pick(source, ['origin', 'originCountryCd', 'cgOrigin', 'CG_ORIGIN', 'ORIGIN_COUNTRY_CD'], 'KR');
        const tr = document.createElement('tr');
        tr.innerHTML = ''
            + '<td class="left" data-cg-no="" data-goods-no="" data-goods-hs-code=""><input class="import-ui-editable import-ui-goods-edit" data-goods-field="goodsName" type="text" value="' + esc(goodsName) + '"></td>'
            + '<td><input class="import-ui-editable import-ui-goods-edit" data-goods-field="price" type="number" step="0.01" value="' + esc(price) + '"></td>'
            + '<td><input class="import-ui-editable import-ui-goods-edit" data-goods-field="qty" type="number" step="0.001" value="' + esc(qty) + '"></td>'
            + '<td><input class="import-ui-editable import-ui-goods-edit" data-goods-field="goodsTotalPrice" type="number" step="0.01" value="' + esc(totalPrice) + '"></td>'
            + '<td><input class="import-ui-editable import-ui-goods-edit" data-goods-field="weight" type="number" step="0.001" value="' + esc(weight) + '"></td>'
            + '<td><input class="import-ui-editable import-ui-goods-edit" data-goods-field="origin" type="text" value="' + esc(origin || 'KR') + '"></td>'
            + '<td><button type="button" class="import-ui-btn import-ui-goods-remove-btn">삭제</button></td>';
        return tr;
    }

    function handleGoodsAdd(button) {
        const section = button ? button.closest('.import-ui-extra-section') : null;
        const tbody = section ? section.querySelector('.import-ui-goods-table tbody') : null;
        if (!tbody) return;
        const emptyRow = tbody.querySelector('.import-ui-goods-empty');
        if (emptyRow && emptyRow.closest('tr')) emptyRow.closest('tr').remove();
        let source = {};
        try {
            const rows = JSON.parse(tbody.dataset.goodsSource || '[]');
            source = rows[tbody.querySelectorAll('tr').length] || {};
        } catch (e) {
            source = {};
        }
        const tr = createEditableGoodsRow(source);
        tbody.appendChild(tr);
        const firstInput = tr.querySelector('[data-goods-field="goodsName"]');
        if (firstInput) firstInput.focus();
    }

    function handleGoodsRemove(button) {
        const tbody = button && button.closest('tbody');
        const tr = button && button.closest('tr');
        if (!tbody || !tr) return;
        tr.remove();
        if (!tbody.querySelector('tr')) {
            tbody.appendChild(createEditableGoodsRow());
        }
    }

    function importInlineHelpers() {
        return {
            esc: esc,
            pick: pick,
            normalizeText: normalizeText,
            statusText: statusText,
            isInboundReadonlyStatus: isInboundReadonlyStatus,
            selectedWarehouseValue: selectedWarehouseValue,
            today: today,
            dateOnly: dateOnly,
            section: section,
            field: field,
            selectField: selectField,
            warehouseAutoHiddenFields: warehouseAutoHiddenFields,
            warehouseManagerReadonlyField: warehouseManagerReadonlyField,
            inboundWarehouseOptions: inboundWarehouseOptions,
            resolveWarehouseName: resolveWarehouseName,
            inboundWarehouseZoneOptions: inboundWarehouseZoneOptions,
            resolveWarehouseZoneName: resolveWarehouseZoneName,
            inboundWarehouseManagerOptions: inboundWarehouseManagerOptions,
            resolveWarehouseManagerName: resolveWarehouseManagerName,
            goodsSectionHtml: goodsSectionHtml,
            cleanPackingGoodsName: cleanPackingGoodsName,
            applyReadonlyToInboundHtml: applyReadonlyToInboundHtml,
            currentRequestNo: currentRequestNo,
            workRow: workRow,
            requestCargoGoodsName: requestCargoGoodsName,
            inboundSupplementNoticeHtml: inboundSupplementNoticeHtml
        };
    }

    window.__TACS_IMPORT_INLINE_HELPERS = importInlineHelpers;
    window.goImportRequestListFromDetail = goImportRequestListFromDetail;
    window.pinImportDetailBackButton = pinImportDetailBackButton;
    window.installImportDetailBackCapture = installImportDetailBackCapture;

    function releaseGoodsCarrier(row, req) {
        const no = currentRequestNo(req) || currentRequestNo(row);
        const inboundRow = workRow('inbound', no);
        if (hasInboundGoodsList(inboundRow)) return inboundRow;

        // 반출관리 품목은 직접 수정/신규 등록하지 않고 입고관리 품목을 그대로 보여준다.
        // 입고 상세 품목 로딩 전에는 반출 쪽 요약/중복 품목을 보여주지 않는다.
        return {goodsList: []};
    }

    function renderSimpleWorkPanel(type, req) {
        const no = currentRequestNo(req);
        let col1 = '';
        let col2 = '';
        let col3 = '';
        let actions = '';
        let goodsHtml = '';
        let inboundReadonly = false;

        if (type === 'arrival') {
            const row = workRow('arrival', no);
            const noticeNo = pick(row, ['reqNo', 'REQ_NO', 'arrivalNoticeReqNo', 'arrivalNoticeNo', 'ianNo', 'IAN_NO', 'ian_no', 'IAN_NO_STR', 'noticeNo', 'arrvNtcNo', 'ntcNo'], '-');
            const noticeStatus = noticeStatusText(pick(row, ['noticeStatusCd', 'arrivalNoticeStatusCd', 'arrivalNoticeSendStatusCd', 'ianSendSttsCd', 'IAN_SEND_STTS_CD', 'sendSttsCd', 'statusCd', 'noticeStatus', 'noticeStatusNm', 'sendStatusNm', 'ianSendSttsNm', 'IAN_SEND_STTS_NM', 'sendSttsNm', 'statusNm'], ''));
            const mbl = cleanFileName(pick(row, ['mblNo', 'masterBlNo', 'icmMblNo', 'blNo', 'ICM_MBL_NO', 'BI_MBL_NO', 'TCS_MBL_NO', 'IR_BL_AWB_NO'], pick(req, ['mblNo', 'masterBlNo', 'blNo', 'mblFile'], '')));
            const hbl = cleanFileName(pick(row, ['hblNo', 'houseBlNo', 'icmHblNo', 'ICM_HBL_NO', 'BI_HBL_NO', 'TCS_HBL_NO'], pick(req, ['hblNo', 'houseBlNo', 'hblFile'], ''))) || deriveHouseBlFromMaster(mbl);
            col1 = section('1. 도착통지 정보',
                field('도착통지서 번호', noticeNo)
                + field('의뢰번호', no)
                + field('화주명', pick(row, ['ownerNm', 'owrNm', 'OWR_NM', 'IAN_RCV_ACTR_NM'], req.shipperName || '-'))
            );
            col2 = section('2. B/L 및 화물 정보',
                field('MASTER B/L', mbl)
                + field('HOUSE B/L', hbl)
                + field('품목구분', pick(row, ['itemCategory', 'frghtIemNm', 'TRC_ITEM_CTGRY_NM', 'CRR_FRGHT_IEM_NM'], req.itemCategory || '-'))
            );
            col3 = section('3. 도착/입항 정보',
                field('현재 위치', pick(row, ['currentLoc', 'currentLocation', 'currLoc', 'ianCurrLoc', 'IAN_CURR_LOC', 'currLocation'], req.destinationPort || '-'))
                + field('도착예정일', pick(row, ['eta', 'arrivalScheduledDate', 'arrvDt', 'arrvSchdYmd', 'ianArrvDt', 'ianArrvSchdYmd', 'IAN_ARRV_DT', 'IAN_ARRV_SCHD_YMD'], req.eta || '-'), {type: 'date'})
            );
            const arrivalNoticeSent = /^(TRC_NTC_SENT|SENT|발송완료|통지완료)$/.test(normalizeText(noticeStatus));
            actions = '<button type="button" class="import-ui-btn import-ui-arrival-send-btn import-arrival-issue-modal-btn"'
                + ' data-auto-issue-button="Y"'
                + ' data-trc-no="' + esc(no) + '"'
                + ' data-request-no="' + esc(no) + '"'
                + ' data-notice-no="' + esc(noticeNo) + '"'
                + ' data-notice-status="' + esc(arrivalNoticeSent ? '발송완료' : '발송대기') + '"'
                + '>도착통지서 발급</button>';
        } else if (type === 'inbound') {
            if (typeof window.buildImportInboundInlinePanel === 'function') {
                return window.buildImportInboundInlinePanel(importInlineHelpers(), req);
            }
            return '<div class="import-ui-request-detail" data-work-type="inbound"><div class="empty-card">입고관리 모듈을 불러오지 못했습니다. import-inbound.js 로딩 순서를 확인하세요.</div></div>';
        } else if (type === 'release') {
            const row = workRow('release', no);
            const doRow = findDoRow(no);
            const releaseDoSource = Object.assign({}, row || {}, doRow || {});

            // 반출 상태는 반출 전용 컬럼만 본다. statusNm/statusCd는 D/O 상태가 섞여 들어와
            // “전달완료”를 반출완료처럼 오인해서 버튼이 사라지고 전체 readonly가 되는 원인이었다.
            const releaseRawCd = normalizeText(pick(row, [
                // 원본 반출요청 상태를 파생 표시상태보다 우선한다.
                'crrStatusCd', 'crStatusCd', 'whOutStatusCd', 'releaseStatusCd',
                'CRR_STATUS_CD', 'CR_STATUS_CD', 'WH_OUT_STATUS_CD'
            ], '')).toUpperCase();
            const releaseNmFromDb = pick(row, [
                'crrStatusNm', 'crStatusNm', 'whOutStatusNm', 'releaseStatusNm',
                'CRR_STATUS_NM', 'CR_STATUS_NM', 'WH_OUT_STATUS_NM'
            ], '');
            const releaseReqActualNo = pick(row, ['crrNo', 'CRR_NO', 'releaseReqNo', 'releaseRequestNo'], '');
            const hasReleaseRequest = isUsableValue(releaseReqActualNo) && releaseReqActualNo !== '-';
            const releaseRemarkForState = pick(row, ['remark', 'releaseRemark', 'crrRmrk', 'requestCn', 'CRR_REQ_CN'], '');
            /*
             * D/O 전달완료 시 서버가 CARGO_RELEASE_REQ 기본 row를 미리 만들어 둔다.
             * 이 자동 생성 row(REL_WAIT + 기본 remark)는 아직 운송담당자가 반출요청을 발송한 상태가 아니므로,
             * 화면에서는 반출대기가 아니라 "-" 상태로 보여주고 발송 버튼을 열어둔다.
             */
            const releaseAutoBaseRow = releaseRawCd === 'REL_WAIT'
                && normalizeText(releaseRemarkForState).indexOf('D/O 전달완료 자동 반출요청 생성') >= 0;
            const releaseReqNo = releaseAutoBaseRow ? '-' : (releaseRequestDisplayNo(row, releaseReqActualNo) || '-');
            const doNoForRelease = pick(releaseDoSource, ['doNo', 'diDoNo', 'DI_DO_NO'], '-');
            const doStatusForRelease = normalizeDoStatus(pick(releaseDoSource, ['doStatusNm', 'doStatusCd', 'DI_STATUS_CD', 'diStatusCd', 'statusNm'], ''), !!pick(releaseDoSource, ['doNo', 'diDoNo', 'DI_DO_NO'], ''));
            const releaseIsZeroStep = (!hasReleaseRequest && !releaseRawCd) || releaseAutoBaseRow;
            const releaseStatus = releaseIsZeroStep
                ? '-'
                // 코드가 있으면 코드 기준으로 표시한다. 파생 상태명이 반출완료여도
                // 원본 CRR_STATUS_CD가 REL_WAIT이면 반출대기로 보여야 한다.
                : (releaseRawCd ? statusText(releaseRawCd, '반출대기') : statusText(releaseNmFromDb || 'REL_WAIT', '반출대기'));
            const releaseSupplementStatus = normalizeText(pick(row, [
                'supplementStatusCd', 'srStatusCd', 'SR_STATUS_CD'
            ], '')).toUpperCase();

            const releaseIsSupplement = ['REQ', 'REQ_FIX', 'REL_FIX', 'FIX', 'REJECT', 'REL_REJECT'].includes(releaseSupplementStatus)
                || ['REL_FIX', 'REQ_FIX', 'REJECT', 'REL_REJECT'].includes(releaseRawCd)
                || releaseStatus === '보완요청'
                || releaseStatus === '반려';
            const releaseCanSend = releaseIsZeroStep || ['REQ_READY', 'READY'].includes(releaseRawCd);
            const releaseIsRequested = hasReleaseRequest && (['REQUESTED', 'REL_SENT', 'SENT'].includes(releaseRawCd)
                || releaseStatus === '발송완료'
                || releaseStatus === '반출요청완료');
            const releaseIsDone = ['REL_DONE', 'DONE', 'RELEASED'].includes(releaseRawCd)
                || releaseStatus === '반출완료';
            const releaseIsWaiting = !releaseAutoBaseRow && (hasReleaseRequest || !!releaseRawCd) && (['REL_WAIT', 'WAIT', 'OUT_WAIT', 'RELEASE_WAIT'].includes(releaseRawCd)
                || (!releaseCanSend && !releaseIsDone && !releaseIsRequested && !releaseIsSupplement));
            const releaseReadonly = releaseIsDone || releaseIsRequested || releaseIsWaiting || (!releaseCanSend && !releaseIsSupplement);
            const releaseEditable = !releaseReadonly && (releaseIsZeroStep || releaseCanSend || releaseIsSupplement);
            const releaseRequestDate = releaseAutoBaseRow ? '-' : (hasReleaseRequest ? (pick(row, ['crrReqDt', 'releaseReqDt', 'releasePlanDt', 'CR_REQ_DT', 'CRR_REQ_DT', 'crReqDt'], '') || today()) : '-');
            const releaseDoneDate = pick(row, ['releaseDt', 'crrReleaseDt', 'CRR_RELEASE_DT'], '');
            const releaseDoneDateOpts = releaseEditable
                ? {type: 'date', editable: true, name: 'releaseDt'}
                : (dateOnly(releaseDoneDate) ? {type: 'date'} : {});
            const releaseRemark = releaseAutoBaseRow ? '' : releaseRemarkForState;
            col1 = section('1. 반출요청 정보',
                field('반출요청번호', releaseReqNo)
                + field('의뢰번호', no)
                + field('반출상태', releaseStatus)
                + field('반출요청일', releaseRequestDate, {type: 'date'})
            );
            const releaseWarehouseZoneName = pick(row, [
                'warehouseZoneNm', 'wzNm', 'zoneNm', 'bondedAreaNm', 'bondedZoneNm',
                'WZ_NM', 'WAREHOUSE_ZONE_NM', 'BONDED_AREA_NM', 'BONDED_ZONE_NM'
            ], '') || resolveWarehouseZoneName(row);

            col2 = section('2. D/O 및 창고 정보',
                field('D/O 번호', doNoForRelease)
                + field('D/O 상태', doStatusForRelease)
                + field('창고명', resolveWarehouseName(row))
                + field('보세구역 위치', releaseWarehouseZoneName || '-')
                + field('창고담당자', resolveWarehouseManagerName(row))
            );
            col3 = section('3. 화물/반출 정보',
                field('품명', displayGoodsName(row, req), {editable: false})
                + field('반출완료일', releaseDoneDate || '-', releaseDoneDateOpts)
                + field('요청사항', releaseRemark, {textarea: true, editable: releaseEditable, name: 'remark'})
                + inboundSupplementNoticeHtml(row)
            );
            goodsHtml = goodsSectionHtml(releaseGoodsCarrier(row, req), req, false);
            actions = isDoneStatus(releaseStatus)
                ? '<button type="button" class="import-ui-btn import-ui-release-send-btn" disabled data-trc-no="' + esc(no) + '" data-release-req-no="' + esc(releaseReqActualNo || '') + '">반출완료</button>'
                : releaseIsSupplement
                    ? '<button type="button" class="import-ui-btn import-ui-release-send-btn" data-supplement-submit="true" data-trc-no="' + esc(no) + '" data-release-req-no="' + esc(releaseReqActualNo || '') + '">보완제출</button>'
                    : releaseCanSend
                        ? '<button type="button" class="import-ui-btn import-ui-release-send-btn" data-trc-no="' + esc(no) + '" data-release-req-no="' + esc(releaseReqActualNo || '') + '">발송</button>'
                        : releaseIsWaiting
                            ? '<button type="button" class="import-ui-btn import-ui-release-send-btn" disabled data-trc-no="' + esc(no) + '" data-release-req-no="' + esc(releaseReqActualNo || '') + '">반출대기</button>'
                            : releaseIsZeroStep
                                ? '<span class="info-chip">-</span>'
                                : '';
        } else {
            const row = workRow('inland', no);
            const dispatchStatus = statusText(pick(row, ['dispatchStatusNm', 'dispatchStatusCd', 'statusNm', 'DISPATCH_STATUS_CD', 'D_STATUS_CD'], ''), '배차대기');
            const rawDispatchStatusCd = normalizeText(pick(row, ['dispatchStatusCd', 'DISPATCH_STATUS_CD', 'D_STATUS_CD'], '')).toUpperCase();
            const carNo = pick(row, ['carNo', 'vehicleNo', 'CAR_NO', 'D_CAR_NO'], '');
            const carNm = pick(row, ['carNm', 'vehicleNm', 'CAR_NM', 'D_CAR_NM'], '');
            const driverNm = pick(row, ['driverNm', 'CAR_DRIVER_NM', 'D_DRIVER_NM'], '');
            const driverTelno = pick(row, ['driverTelno', 'driverTel', 'driverPhone', 'CAR_DRIVER_TELNO', 'D_DRIVER_TELNO', 'CAR_DRIVER_TEL'], '');
            const isDispatchDone = isDoneStatus(dispatchStatus) || rawDispatchStatusCd === 'TRC_DISPATCH_DONE';
            const isDispatchWaiting = !isDispatchDone;
            col1 = section('1. 배차 정보',
                field('배차번호', pick(row, ['dispatchNo', 'dpNo', 'DISPATCH_NO', 'D_NO'], '-'))
                + field('의뢰번호', no)
                + field('배차상태', dispatchStatus)
                + field('배차일자', pick(row, ['pickupDt', 'releaseReqDt', 'dispatchDt', 'dpDt', 'DISPATCH_PICKUP_DT', 'DISPATCH_DT', 'D_DISPATCH_DT'], '-'), {type: 'date'})
            );
            col2 = section('2. 차량/기사 정보',
                (isDispatchWaiting ? inlandCarSelectField(carNo) : field('차량번호', carNo || '-'))
                + field('차량명', carNm || '-', {name: 'carNm'})
                + field('기사명', driverNm || '-', {name: 'driverNm'})
                + field('기사 연락처', driverTelno || '-', {name: 'driverTelno'})
            );
            col3 = section('3. 운송지 정보',
                field('상차지', pick(row, ['loadgAdres', 'releasePlace', 'warehouseZoneNm', 'loadingAddress', 'pickupAddress', 'loadAddr', 'DISPATCH_LOADG_ADRES', 'DISPATCH_LOAD_ADDR', 'D_LOAD_ADDR', 'DP_LOAD_ADDR'], '-'))
                + field('도착지', pick(row, ['destinationAdres', 'dstnAdres', 'destinationAddress', 'deliveryAddress', 'arrivalAddr', 'destAddr', 'DISPATCH_DEST_ADRES', 'DISPATCH_DEST_ADDR', 'D_DEST_ADDR', 'DP_DEST_ADDR'], '-'))
                + field('품명', displayGoodsName(row, req), {goodsName: true})
            );
            const pickupDtValue = pick(row, ['pickupDt', 'releaseReqDt', 'dispatchDt', 'dpDt', 'DISPATCH_PICKUP_DT', 'DISPATCH_DT', 'D_DISPATCH_DT'], '');
            actions = isDispatchDone
                ? '<button type="button" class="import-ui-btn import-ui-inland-process-btn" disabled data-trc-no="' + esc(no) + '">' + esc(dispatchStatus || '배차완료') + '</button>'
                : '<button type="button" class="import-ui-btn import-ui-inland-process-btn" data-trc-no="' + esc(no) + '" data-pickup-dt="' + esc(dateOnly(pickupDtValue) || pickupDtValue) + '">배차완료 처리</button>';
        }

        let html = ''
            + '<div class="import-ui-request-detail" data-work-type="' + esc(type) + '">'
            + '<div class="import-ui-grid3">' + col1 + col2 + col3 + '</div>'
            + goodsHtml
            + (actions ? '<div class="import-ui-actions">' + actions + '</div>' : '')
            + '</div>';

        if (type === 'inbound') {
            html = applyReadonlyToInboundHtml(html, inboundReadonly);
        }

        return html;
    }

    function findDoRow(no) {
        const list = rowsOf(window.TRANSPORT_IMPORT_DO_LIST, window.__TACS_IMPORT_DO_ROWS);
        const sourceList = Array.isArray(list) ? list : [];
        let matched = sourceList.filter(function (row) { return rowMatchesRequestNo(row, no); });

        /*
         * D/O 전용 목록 API가 느리거나 응답이 끊기면 기존 코드는 계속
         * "D/O 데이터를 불러오는 중입니다" 화면에 갇혔다.
         * 운송의뢰 목록 row에도 정산상태/TCS/D/O상태가 같이 내려오므로,
         * 전용 D/O row가 없을 때는 현재 선택된 운송의뢰 row를 안전한 폴백으로 사용한다.
         */
        if (!matched.length) {
            const req = currentRequest();
            if (req && rowMatchesRequestNo(req, no)) matched = [req];
        }
        if (!matched.length) return {};

        /*
         * /transport/import/do/list.do 는 원본 mapper row 와 import-do.js 가 정규화한 row 가
         * 섞여 들어올 수 있다. 정규화 row 는 freight/warehouse/owner/doStatus 같은 이름을 쓰고,
         * mapper row 는 freightAmt/warehouseAmt/ownerNm/doStatusNm 같은 이름을 쓴다.
         * 첫 번째로 매칭된 행에 0원/빈값이 있으면 뒤에 있는 실제 TRAN_COST_STL 값이 화면에
         * 못 올라오므로, 같은 의뢰번호 행은 전부 합치고 금액은 0보다 큰 값을 우선한다.
         */
        const merged = {};
        const amountKeys = new Set([
            'freightAmt', 'tcsFrgtAmt', 'tcsFrghtAmt', 'tcsFreightAmt', 'freight', 'TCS_FRGT_AMT', 'TCS_FRGHT_AMT', 'TCS_FREIGHT_AMT',
            'warehouseAmt', 'tcsWhAmt', 'warehouse', 'whAmt', 'TCS_WH_AMT',
            'totalBillAmt', 'tcsTotBillAmt', 'totalAmt', 'billAmt', 'TCS_TOT_BILL_AMT'
        ]);

        matched.forEach(function (row) {
            Object.keys(row || {}).forEach(function (key) {
                const value = row[key];
                if (!isUsableValue(value)) return;

                if (amountKeys.has(key)) {
                    const currentNum = numberOnly(merged[key]);
                    const nextNum = numberOnly(value);
                    if (!isUsableValue(merged[key]) || (currentNum <= 0 && nextNum > 0)) {
                        merged[key] = value;
                    }
                    return;
                }

                if (!isUsableValue(merged[key])) {
                    merged[key] = value;
                }
            });
        });

        return Object.keys(merged).length ? merged : (matched[0] || {});
    }

    function patchImportDoDeliveredState(trcNo, doNo) {
        const deliveredPatch = {
            trcNo: trcNo,
            requestNo: trcNo,
            doNo: doNo,
            diDoNo: doNo,
            DI_DO_NO: doNo,
            doStatusCd: 'TRC_DO_REQ',
            diStatusCd: 'TRC_DO_REQ',
            DI_STATUS_CD: 'TRC_DO_REQ',
            doStatus: 'TRC_DO_REQ',
            doStatusNm: 'D/O전달완료',
            diStatusNm: 'D/O전달완료',
            DI_STATUS_NM: 'D/O전달완료'
        };

        const patchRows = function (rows) {
            const source = Array.isArray(rows) ? rows.slice() : [];
            let patched = false;
            const next = source.map(function (row) {
                if (!rowMatchesRequestNo(row, trcNo)) return row;
                patched = true;
                return Object.assign({}, row, deliveredPatch);
            });
            if (!patched) next.unshift(deliveredPatch);
            return next;
        };

        storeRows(['TRANSPORT_IMPORT_DO_LIST', '__TACS_IMPORT_DO_ROWS'], patchRows(rowsOf(window.TRANSPORT_IMPORT_DO_LIST, window.__TACS_IMPORT_DO_ROWS)));
        storeRows(['TRANSPORT_IMPORT_RELEASE_LIST', 'IMPORT_RELEASE_LIST', '__TACS_IMPORT_RELEASE_ROWS'], patchRows(rowsOf(window.TRANSPORT_IMPORT_RELEASE_LIST, window.IMPORT_RELEASE_LIST, window.__TACS_IMPORT_RELEASE_ROWS)));

        [currentRequest(), findRequestRow(trcNo)].forEach(function (row) {
            if (!row || !rowMatchesRequestNo(row, trcNo)) return;
            Object.assign(row, deliveredPatch, {
                requestDisplayStatusCd: 'TRC_DO_REQ',
                requestDisplayStatusNm: 'D/O전달완료'
            });
        });
    }

    function doStateKey(root) {
        return String((root && root.dataset && root.dataset.requestNo) || currentRequestNo(currentRequest()) || 'default');
    }

    function fileKey(file) {
        return [file && file.name, file && file.size, file && file.lastModified].join('|');
    }

    function normalizeDocName(name) {
        return String(name || '').trim().toLowerCase();
    }

    function getSelectedFiles(root) {
        return doFileState.get(doStateKey(root)) || [];
    }

    function saveSelectedFiles(root, files) {
        const unique = [];
        const seen = new Set();
        Array.from(files || []).forEach(function (file) {
            const key = fileKey(file);
            if (!file || seen.has(key)) return;
            seen.add(key);
            unique.push(file);
        });
        doFileState.set(doStateKey(root), unique);
        return unique;
    }

    function appendSelectedFiles(root, files) {
        return saveSelectedFiles(root, getSelectedFiles(root).concat(Array.from(files || [])));
    }

    function clearSelectedFiles(root) {
        doFileState.delete(doStateKey(root));
    }

    function syncInputFiles(input, files) {
        if (!input || typeof DataTransfer === 'undefined') return;
        const dataTransfer = new DataTransfer();
        Array.from(files || []).forEach(function (file) { dataTransfer.items.add(file); });
        input.files = dataTransfer.files;
    }

    function isPdf(file) {
        return file && (/\.pdf$/i.test(file.name || '') || file.type === 'application/pdf');
    }

    function doDocKind(fileName) {
        const raw = String(fileName || '');
        const name = raw.toLowerCase();
        if (raw.includes('선하증권') || name.includes('bill_of_lading') || name.includes('bill-of-lading') || name.includes('bl_') || name.includes('b/l')) return '선하증권';
        if (raw.includes('포장명세서') || raw.includes('패킹리스트') || name.includes('packing') || name.includes('packing_list') || name.includes('packing-list')) return '포장명세서';
        if (raw.includes('송장') || name.includes('invoice')) return '송장';
        if (name.includes('cert') || name.includes('declaration') || raw.includes('신고') || raw.includes('필증')) return '수입신고필증';
        if (name.includes('do') || name.includes('d/o') || name.includes('delivery')) return 'D/O';
        return '첨부문서';
    }

    function renderSelectedDocRows(root) {
        const input = root.querySelector('input[type="file"][name="docFiles"]');
        const files = getSelectedFiles(root);
        const tbody = root.querySelector('.import-ui-do-selected-docs');
        const summary = root.querySelector('.import-ui-doc-summary');
        if (input) syncInputFiles(input, files);
        if (summary) {
            summary.textContent = files.length
                ? files.length + '개 파일 선택됨: ' + files.map(function (file) { return file.name; }).join(', ')
                : '선택된 파일 없음';
        }
        if (!tbody) return;
        const existingDocs = existingDoDocs(root);
        const fallbackExistingRows = existingDoRowsHtmlFromTable(tbody);
        if (!files.length) {
            tbody.innerHTML = existingDocs.length
                ? existingDoDocsHtml(existingDocs)
                : (fallbackExistingRows || '<tr><td colspan="3" class="import-ui-doc-empty">선택된 첨부문서가 없습니다.</td></tr>');
            return;
        }
        const existingRows = existingDocs.length ? existingDoDocsHtml(existingDocs) : fallbackExistingRows;
        const existingNames = new Set(existingDocs.map(function (doc) { return normalizeDocName(doc.name); }));
        const selectedRows = files.filter(function (file) {
            return !existingNames.has(normalizeDocName(file && file.name));
        }).map(function (file, index) {
            return ''
                + '<tr>'
                + '<td class="import-ui-doc-name">' + esc(file.name) + '</td>'
                + '<td><span class="import-ui-doc-chip pending">추가예정</span></td>'
                + '<td class="import-ui-doc-action"><button type="button" class="import-ui-doc-remove" data-index="' + index + '">삭제</button></td>'
                + '</tr>';
        }).join('');
        tbody.innerHTML = existingRows + selectedRows;
    }

    function existingDoRowsHtmlFromTable(tbody) {
        if (!tbody) return '';
        return Array.from(tbody.querySelectorAll('tr')).filter(function (row) {
            return row.querySelector('.import-ui-doc-chip.done');
        }).map(function (row) {
            return row.outerHTML;
        }).join('');
    }

    function existingDoDocs(root) {
        const field = root ? root.querySelector('.import-ui-doc-field[data-existing-do-docs-json]') : null;
        if (!field) return [];
        try {
            const docs = JSON.parse(field.dataset.existingDoDocsJson || '[]');
            return Array.isArray(docs) ? docs.filter(function (doc) { return doc && doc.name; }) : [];
        } catch (e) {
            return [];
        }
    }

    function existingDoDocsHtml(docs) {
        if (!docs.length) return '<tr><td colspan="3" class="import-ui-doc-empty">등록된 첨부문서가 없습니다.</td></tr>';
        return docs.map(function (doc) {
            const url = downloadUrl(doc.fileNo, '');
            return ''
                + '<tr>'
                + '<td class="import-ui-doc-name">' + esc(doc.name) + '</td>'
                + '<td><span class="import-ui-doc-chip done">기존첨부</span></td>'
                + '<td class="import-ui-doc-action">' + (url ? '<a class="import-ui-file-download" href="' + esc(url) + '">다운로드</a>' : '-') + '</td>'
                + '</tr>';
        }).join('');
    }

    function registeredDocs(row) {
        const docs = [];
        const seen = new Set();

        function push(fileText, fileNoText, kind) {
            const names = String(fileText || '').split(',').map(function (name) { return name.trim(); }).filter(Boolean);
            const nos = String(fileNoText || '').split(',').map(function (fileNo) { return fileNo.trim(); });

            names.forEach(function (name, index) {
                const fileNo = nos[index] || nos[0] || '';
                const docKind = kind || doDocKind(name);
                const key = fileNo ? ('NO:' + fileNo) : ('NM:' + name.toLowerCase() + ':' + docKind);

                if (seen.has(key)) return;
                seen.add(key);

                docs.push({
                    name: name,
                    fileNo: fileNo,
                    kind: docKind
                });
            });
        }

        /*
         * mapper의 doPdfFile은 DI_TFG_NO 기준 전체 첨부문서 LISTAGG라서
         * D/O + 수입신고필증이 같이 들어올 수 있다.
         * 여기서 문서종류를 파일명으로 다시 판별하고, 아래 doCertFile과 중복되는 fileNo는 제거한다.
         */
        push(
            pick(row, ['doPdfFile', 'doFile', 'impDoFile', 'doPdfFileNm', 'doOrgNm'], ''),
            pick(row, ['doPdfFileNo', 'doFileNo', 'impDoFileNo', 'doPdfDfiNo', 'doDfiNo'], ''),
            ''
        );
        push(
            pick(row, ['doCertFile', 'customsCertFile', 'importDeclCertFile', 'importDeclarationCertFile', 'declCertFile', 'certFileNm', 'certOrgNm', 'CUSTOMS_CERT_FILE'], ''),
            pick(row, ['doCertFileNo', 'customsCertFileNo', 'importDeclCertFileNo', 'dfiFileNo', 'certDfiNo', 'CUSTOMS_CERT_FILE_NO'], ''),
            ''
        );

        return docs;
    }

    function isImportCertDoc(doc) {
        const kind = normalizeText(doc && doc.kind);
        const name = normalizeText(doc && doc.name);
        return kind === '수입신고필증'
            || name.indexOf('수입신고필증') >= 0
            || name.indexOf('수입신고') >= 0
            || name.indexOf('신고필증') >= 0
            || name.toLowerCase().indexOf('customs_cert') >= 0
            || name.toLowerCase().indexOf('declaration') >= 0
            || name.toLowerCase().indexOf('certificate') >= 0;
    }

    function importCertDocs(row) {
        return registeredDocs(row).filter(isImportCertDoc);
    }

    function importCertReceivedHtml(row, settlementPaid, trcNo) {
        if (!settlementPaid) return '';
        const docs = importCertDocs(row);
        const certYn = normalizeText(pick(row, ['certYn', 'trcCertYn', 'TRC_CERT_YN'], ''));
        const received = docs.length > 0 || certYn === 'Y';
        const rows = docs.length ? docs.map(function (doc) {
            const url = downloadUrl(doc.fileNo, '');
            return ''
                + '<tr>'
                + '<td class="import-ui-doc-name">' + esc(doc.name) + '</td>'
                + '<td class="import-ui-doc-status"><span class="import-ui-doc-chip done">수신완료</span></td>'
                + '<td class="import-ui-doc-action">' + (url ? '<a class="import-ui-file-download" href="' + esc(url) + '">다운로드</a>' : '-') + '</td>'
                + '</tr>';
        }).join('') : ''
            + '<tr>'
            + '<td class="import-ui-doc-empty">' + (certYn === 'Y'
                ? '필증 전달 상태는 있으나 연결된 PDF가 없습니다.'
                : '연결된 수입신고필증 PDF가 없습니다.') + '</td>'
            + '<td class="import-ui-doc-status"><span class="import-ui-doc-chip pending">미수신</span></td>'
            + '<td class="import-ui-doc-action">'
            + '<button type="button" class="import-ui-btn import-ui-customs-cert-connect-btn" data-trc-no="' + esc(trcNo || currentRequestNo(row)) + '">필증 연결</button>'
            + '</td>'
            + '</tr>'
            + '<tr><td colspan="3" class="import-ui-doc-help">화주 업로드 파일을 찾지 못하면 첨부문서에 수입신고필증 PDF를 추가하세요.</td></tr>';

        return ''
            + '<div class="import-ui-field import-ui-doc-field import-ui-cert-received-field">'
            + '<label>화주 수입신고필증</label>'
            + '<div class="import-ui-doc-table-wrap">'
            + '<table class="import-ui-doc-table">'
            + '<thead><tr><th>파일명</th><th style="width:16%">수신상태</th><th style="width:18%">관리</th></tr></thead>'
            + '<tbody>'
            + rows
            + '</tbody></table></div></div>';
    }

    function registeredDocsHtml(row) {
        const docs = registeredDocs(row);
        return existingDoDocsHtml(docs);
    }

    function buildDoPanel(req) {
        const no = currentRequestNo(req);
        /*
         * D/O 목록 row가 아직 없거나 /do/list.do 재조회가 늦어져도,
         * 정산요청 직후 현재 상세 row에 패치된 운임비/창고비/정산설명을 먼저 살린다.
         */
        const row = Object.assign({}, req || {}, findDoRow(no) || {});
        const doNo = pick(row, ['doNo', 'diDoNo', 'DI_DO_NO'], '');
        const settlementStatus = normalizeSettlementStatus(pick(row, ['settlementStatusNm', 'settlementStatusCd', 'settlementStatus', 'stlStatus', 'stlStatusCd', 'tcsStlStatusNm', 'tcsStlStatusCd', 'tcsStlStatus', 'TCS_STL_STATUS_CD', 'TCS_STL_STATUS'], '미정산'));
        const tcsDt = dateTimeMinute(pick(row, [
            'tcsDt', 'TCS_DT', 'tcsDtText', 'tcsDtStr', 'tcsDtFmt', 'tcsBillDt', 'TCS_BILL_DT',
            'settlementReqDt', 'settlementRequestDt', 'settlementDt', 'billDt', 'chargeDt', 'requestDt'
        ], ''));
        const doStatus = normalizeDoStatus(pick(row, ['doStatusNm', 'doStatusCd', 'doStatus', 'statusNm', 'diStatusCd', 'DI_STATUS_CD'], ''), !!doNo);
        const mbl = cleanFileName(pick(row, ['mblNo', 'masterBlNo', 'mbl', 'masterBlnNo', 'tcsMblNo', 'icmMblNo', 'blNo', 'TCS_MBL_NO', 'ICM_MBL_NO', 'IR_BL_AWB_NO'], pick(req, ['mblNo', 'masterBlNo', 'blNo', 'mblFile'], '')));
        const hbl = cleanFileName(pick(row, ['hblNo', 'houseBlNo', 'hbl', 'houseBlnNo', 'tcsHblNo', 'icmHblNo', 'TCS_HBL_NO', 'ICM_HBL_NO'], pick(req, ['hblNo', 'houseBlNo', 'hblFile'], '')));
        const freightAmt = pick(row, ['freightAmt', 'tcsFrgtAmt', 'tcsFrghtAmt', 'tcsFreightAmt', 'freight', 'TCS_FRGT_AMT', 'TCS_FRGHT_AMT', 'TCS_FREIGHT_AMT'], '0');
        const warehouseAmt = pick(row, ['warehouseAmt', 'tcsWhAmt', 'tcsWarehouseAmt', 'warehouse', 'whAmt', 'TCS_WH_AMT', 'TCS_WAREHOUSE_AMT'], '0');
        const totalAmt = pick(row, ['totalBillAmt', 'tcsTotBillAmt', 'tcsTotalBillAmt', 'totalAmt', 'billAmt', 'TCS_TOT_BILL_AMT', 'TCS_TOTAL_BILL_AMT'], numberOnly(freightAmt) + numberOnly(warehouseAmt));
        const owner = pick(row, ['ownerNm', 'owrNm', 'owner', 'ownerId', 'tcsOwrId', 'owrId', 'TCS_OWR_ID', 'TRC_OWR_ID'], req.shipperName || '');
        const registeredDocList = registeredDocs(row);
        const registeredNames = registeredDocList.map(function (doc) { return doc.name; }).join(', ');
        const registeredDocsJson = JSON.stringify(registeredDocList);
        const settlementPaid = settlementStatus === '정산완료';
        const settlementRequested = settlementStatus === '정산요청';
        const settlementEditable = settlementStatus === '미정산';
        const doIssued = doStatus === '발급완료' || doStatus === 'D/O발급완료';
        const doDelivered = doStatus === '전달완료' || doStatus === 'D/O전달완료';
        const issueDisabled = !settlementPaid || doIssued || doDelivered;
        const deliverDisabled = !doIssued || doDelivered;
        const doBtnStateClass = function (enabled, done) {
            return done ? ' is-done' : (enabled ? ' is-active' : ' is-locked');
        };
        const settleBtnText = settlementPaid ? '정산완료' : (settlementRequested ? '정산요청완료' : '정산요청');
        const issueBtnText = (doIssued || doDelivered) ? '발급완료' : 'D/O 발급';
        const deliverBtnText = doDelivered ? '전달완료' : 'D/O 및 필증 전달';
        const uploadDocHtml = doDelivered
            ? ''
                + '<div class="import-ui-field import-ui-doc-field" data-existing-do-docs="' + esc(registeredNames) + '" data-existing-do-docs-json="' + esc(registeredDocsJson) + '">'
                + '<label>첨부문서</label>'
                + '<div class="import-ui-doc-drop is-locked" style="cursor:not-allowed;opacity:.75;">D/O 전달완료 상태라 첨부문서를 추가할 수 없습니다.</div>'
                + '</div>'
            : ''
                + '<div class="import-ui-field import-ui-doc-field" data-existing-do-docs="' + esc(registeredNames) + '" data-existing-do-docs-json="' + esc(registeredDocsJson) + '">'
                + '<label>첨부문서 *</label>'
                + '<div class="import-ui-doc-toolbar"><button type="button" class="import-ui-doc-select">파일 선택</button><span class="import-ui-doc-help">PDF 여러 개 첨부 가능</span></div>'
                + '<input type="file" name="docFiles" accept="application/pdf,.pdf" multiple class="import-ui-doc-input" style="display:none">'
                + '<div class="import-ui-doc-drop" data-do-doc-drop="true"><div style="font-size:22px;font-weight:900;line-height:24px;">⇧</div><div>파일을 이곳에 드래그하거나 <b>파일 선택</b>을 누르세요</div><div class="import-ui-doc-summary">선택된 파일 없음</div></div>'
                + '<div class="import-ui-doc-table-wrap"><table class="import-ui-doc-table"><thead><tr><th>파일명</th><th style="width:14%">상태</th><th style="width:14%">관리</th></tr></thead><tbody class="import-ui-do-selected-docs">' + registeredDocsHtml(row) + '</tbody></table></div>'
                + '</div>';

        return ''
            + '<div class="import-ui-two-col">'
            + '<section class="import-ui-card import-ui-section"><h4>D/O 발급 정보</h4><div class="import-ui-form-grid">'
            + field('D/O 번호', doNo, {name: 'doNo'})
            + field('MASTER B/L', mbl)
            + field('HOUSE B/L', hbl)
            + field('D/O 상태', doStatus)
            + uploadDocHtml
            + '</div></section>'
            + '<section class="import-ui-card import-ui-section"><h4>수입 비용 정산</h4>'
            + field('의뢰번호', no)
            + field('화주명', owner)
            + field('정산상태', settlementStatus)
            + field('청구일시', tcsDt)
            + field('수입 운임비', money(freightAmt), {editable: settlementEditable, name: 'freightAmt'})
            + field('창고비', money(warehouseAmt), {editable: settlementEditable, name: 'warehouseAmt'})
            + field('총 청구금액', money(totalAmt), {name: 'totalBillAmt'})
            + field('정산 설명', pick(row, ['tcsStlExpln', 'settlementExpln', 'settlementMemo', 'settlementDesc', 'stlExpln', 'tcsStlDesc', 'tcsStlMemo', 'TCS_STL_EXPLN'], ''), {textarea: true, editable: settlementEditable, name: 'settlementMemo'})
            + importCertReceivedHtml(row, settlementPaid, no)
            + '</section>'
            + '</div>'
            + '<div class="import-ui-actions">'
            + '<button type="button" class="import-ui-btn import-ui-do-flow-btn import-ui-do-settle-btn' + doBtnStateClass(!settlementPaid && !settlementRequested, settlementPaid || settlementRequested) + '" data-trc-no="' + esc(no) + '" data-settlement-status="' + esc(settlementStatus) + '" data-do-status="' + esc(doStatus) + '"' + ((settlementPaid || settlementRequested) ? ' disabled aria-disabled="true"' : '') + '>' + settleBtnText + '</button>'
            + '<button type="button" class="import-ui-btn import-ui-do-flow-btn import-ui-do-issue-btn' + doBtnStateClass(!issueDisabled, doIssued || doDelivered) + '" data-trc-no="' + esc(no) + '" data-do-status="' + esc(doStatus) + '"' + (issueDisabled ? ' disabled aria-disabled="true"' : '') + '>' + issueBtnText + '</button>'
            + '<button type="button" class="import-ui-btn import-ui-do-flow-btn import-ui-do-deliver-btn' + doBtnStateClass(!deliverDisabled, doDelivered) + '" data-trc-no="' + esc(no) + '" data-do-status="' + esc(doStatus) + '"' + (deliverDisabled ? ' disabled aria-disabled="true"' : '') + '>' + deliverBtnText + '</button>'
            + '</div>';
    }

    function refreshDoList(root, activeType) {
        if (window.__TACS_IMPORT_DO_LOADING) {
            return Promise.resolve(window.TRANSPORT_IMPORT_DO_LIST || []);
        }

        window.__TACS_IMPORT_DO_LOADING = true;
        if (root && root.dataset) {
            root.dataset.doLookupRequestedAt = String(Date.now());
            root.dataset.doLookupTargetReqNo = normalizeText(root.dataset.requestNo || root.dataset.trcNo || '');
        }
        return getJson('/transport/import/do/list.do?_=' + Date.now())
            .then(function (json) {
                /*
                 * /transport/import/do/list.do 응답이 배열일 수도 있고
                 * {data/list/rows/result...} 래퍼일 수도 있다.
                 * 기존 코드는 배열 응답만 인정해서 래퍼 응답이면 항상 빈 배열로 저장했고,
                 * D/O 탭 렌더링 조건이 빈 배열이면 다시 조회하도록 되어 있어서
                 * 콘솔에 /do/list.do가 무한 반복되는 문제가 발생했다.
                 */
                const rows = mergeDoSettlementPatches(jsonRows(json));
                storeRows(['TRANSPORT_IMPORT_DO_LIST', '__TACS_IMPORT_DO_ROWS'], rows);
                window.__TACS_IMPORT_DO_LOADED = true;
                window.__TACS_IMPORT_DO_LAST_LOADED_AT = Date.now();
                return rows;
            })
            .catch(function (error) {
                window.__TACS_IMPORT_DO_LOADED = true;
                console.error('[D/O 목록 조회 실패]', error);
                return [];
            })
            .finally(function () {
                window.__TACS_IMPORT_DO_LOADING = false;
                if (root && root.dataset) {
                    root.dataset.doLookupCompletedFor = root.dataset.doLookupTargetReqNo || normalizeText(root.dataset.requestNo || root.dataset.trcNo || '');
                }
                if (isImportInlineDetailActive(root) && activeType) renderInlineTab(root, activeType);
            });
    }

    function hasDoPdfFileForRequest(trcNo) {
        const row = findDoRow(trcNo);
        if (!row) return false;
        return registeredDocs(row).some(function (doc) {
            return doc && doc.fileNo && !isImportCertDoc(doc);
        });
    }

    function refreshDoListUntilDoPdfReady(root, trcNo, attemptsLeft) {
        return refreshDoList(root, 'do').then(function (rows) {
            if (hasDoPdfFileForRequest(trcNo) || attemptsLeft <= 0) return rows;
            return new Promise(function (resolve) {
                setTimeout(resolve, 800);
            }).then(function () {
                window.__TACS_IMPORT_DO_LOADED = false;
                return refreshDoListUntilDoPdfReady(root, trcNo, attemptsLeft - 1);
            });
        });
    }


    function applyDoPaidReadonlyGuard(root) {
        if (!root) return;
        const fields = Array.from(root.querySelectorAll('.import-ui-field'));
        const valueByLabel = function (labelText) {
            const fieldEl = fields.find(function (el) {
                const label = el.querySelector('label');
                return label && normalizeText(label.textContent) === labelText;
            });
            const input = fieldEl ? fieldEl.querySelector('input, textarea, select') : null;
            return input ? normalizeText(input.value || input.textContent || '') : '';
        };
        const settlementStatus = valueByLabel('정산상태');
        const doStatus = valueByLabel('D/O 상태');
        const normalizedSettlementStatus = normalizeSettlementStatus(settlementStatus);
        const paid = normalizedSettlementStatus === '정산완료';
        const requested = normalizedSettlementStatus === '정산요청';
        const doIssued = doStatus === '발급완료' || doStatus === '전달완료' || doStatus === 'D/O발급완료' || doStatus === 'D/O전달완료';
        const delivered = doStatus === '전달완료' || doStatus === 'D/O전달완료';

        ['freightAmt', 'warehouseAmt', 'totalBillAmt'].forEach(function (name) {
            const input = root.querySelector('[name="' + name + '"]');
            if (!input) return;
            if (paid || requested || name === 'totalBillAmt') {
                input.readOnly = true;
                input.setAttribute('readonly', 'readonly');
                if (name !== 'totalBillAmt') input.classList.remove('import-ui-editable');
                input.setAttribute('aria-readonly', 'true');
                return;
            }
            input.readOnly = false;
            input.removeAttribute('readonly');
            input.classList.add('import-ui-editable');
            input.removeAttribute('aria-readonly');
        });

        const settlementMemo = root.querySelector('[name="settlementMemo"]');
        if (settlementMemo) {
            if (paid || requested) {
                settlementMemo.readOnly = true;
                settlementMemo.setAttribute('readonly', 'readonly');
                settlementMemo.classList.remove('import-ui-editable');
            } else {
                settlementMemo.readOnly = false;
                settlementMemo.removeAttribute('readonly');
                settlementMemo.classList.add('import-ui-editable');
            }
        }

        const recalcTotalBill = function () {
            const freight = readMoneyInput(root, 'freightAmt');
            const warehouse = readMoneyInput(root, 'warehouseAmt');
            const total = root.querySelector('[name="totalBillAmt"]');
            if (total) total.value = money(freight + warehouse);
        };
        ['freightAmt', 'warehouseAmt'].forEach(function (name) {
            const input = root.querySelector('[name="' + name + '"]');
            if (input && !input.dataset.totalRecalcBound) {
                input.dataset.totalRecalcBound = 'Y';
                input.addEventListener('input', recalcTotalBill);
                input.addEventListener('change', recalcTotalBill);
            }
        });

        const setFlowButtonState = function (button, enabled, done, text) {
            if (!button) return;
            button.classList.add('import-ui-do-flow-btn');
            button.classList.toggle('is-active', !!enabled);
            button.classList.toggle('is-locked', !enabled && !done);
            button.classList.toggle('is-done', !!done);
            if (text) button.textContent = text;
            if (enabled) {
                button.disabled = false;
                button.removeAttribute('disabled');
                button.removeAttribute('aria-disabled');
            } else {
                button.disabled = true;
                button.setAttribute('disabled', 'disabled');
                button.setAttribute('aria-disabled', 'true');
            }
        };

        const settleBtn = root.querySelector('.import-ui-do-settle-btn');
        if (settleBtn) {
            settleBtn.dataset.settlementStatus = paid ? '정산완료' : (requested ? '정산요청' : '미정산');
            setFlowButtonState(settleBtn, !paid && !requested, paid || requested, paid ? '정산완료' : (requested ? '정산요청완료' : '정산요청'));
        }

        const issueBtn = root.querySelector('.import-ui-do-issue-btn');
        if (issueBtn) {
            setFlowButtonState(issueBtn, paid && !doIssued && !delivered, doIssued || delivered, (doIssued || delivered) ? '발급완료' : 'D/O 발급');
        }

        const deliverBtn = root.querySelector('.import-ui-do-deliver-btn');
        if (deliverBtn) {
            setFlowButtonState(deliverBtn, doIssued && !delivered, delivered, delivered ? '전달완료' : 'D/O 및 필증 전달');
        }
    }


    function textFromGoodsEditable(el) {
        if (!el) return '';
        if (el.tagName === 'SELECT') {
            const opt = el.options && el.selectedIndex >= 0 ? el.options[el.selectedIndex] : null;
            return normalizeText(opt ? opt.textContent : el.value);
        }
        return normalizeText(el.value || el.textContent || '');
    }

    function releaseReadonlyGoodsText(field, value) {
        const raw = normalizeText(value);
        if (!raw) return '-';
        if (field === 'price' || field === 'goodsTotalPrice') return formatGoodsNumber(raw, true);
        if (field === 'weight') return formatGoodsWeight(raw);
        if (field === 'qty') return formatGoodsNumber(raw, false);
        return raw;
    }

    function lockReleaseGoodsReadonly(root) {
        if (!root || root.dataset.activeWorkId !== 'release') return;
        const panel = root.querySelector('.import-ui-panel');
        if (!panel) return;
        const table = panel.querySelector('.import-ui-goods-table');
        if (!table) return;

        panel.querySelectorAll('.import-ui-goods-add-btn').forEach(function (button) {
            const actions = button.closest('.import-ui-actions');
            if (actions) actions.remove();
            else button.remove();
        });

        const headers = Array.from(table.querySelectorAll('thead th'));
        const manageIndex = headers.findIndex(function (th) { return normalizeText(th.textContent) === '관리'; });
        if (manageIndex >= 0) {
            headers[manageIndex].remove();
        }

        Array.from(table.querySelectorAll('tbody tr')).forEach(function (tr) {
            const cells = Array.from(tr.children || []);
            const removeButtonCellIndex = cells.findIndex(function (td) { return !!td.querySelector('.import-ui-goods-remove-btn'); });
            const removeIndex = manageIndex >= 0 ? manageIndex : removeButtonCellIndex;
            if (removeIndex >= 0 && cells[removeIndex]) cells[removeIndex].remove();

            Array.from(tr.querySelectorAll('.import-ui-goods-remove-btn')).forEach(function (button) { button.remove(); });
            Array.from(tr.querySelectorAll('input, select, textarea')).forEach(function (input) {
                const field = input.dataset ? input.dataset.goodsField : '';
                const td = input.closest('td');
                if (!td) return;
                const text = releaseReadonlyGoodsText(field, textFromGoodsEditable(input));
                td.textContent = text;
                if (field === 'goodsName') td.classList.add('left');
            });
        });
    }

    function renderInlineTab(root, type) {
        ensureStyle();
        const active = type || root.dataset.activeWorkId || 'request';
        const req = currentRequest();
        const no = currentRequestNo(req);
        if (no) root.dataset.requestNo = no;
        root.dataset.activeWorkId = active;
        updateImportDetailUrl(req, active);
        pinImportDetailBackButton();

        root.querySelectorAll('.import-ui-tab').forEach(function (button) {
            button.classList.toggle('is-active', button.dataset.workId === active);
        });
        setTabDisabledState(root, req);

        const detailSection = root.parentElement ? root.parentElement.querySelector('.import-ui-main-request-detail') : null;
        const panel = root.querySelector('.import-ui-panel');
        if (detailSection) detailSection.style.display = active === 'request' ? 'block' : 'none';
        if (!panel) return;

        const allTabsOpen = isAllTabsOpenStatus(req);
        const releaseStageOpen = hasReleaseStageState(no);
        const inboundSupplementOpen = active === 'inbound' && shouldOpenInboundForSupplement(req, no);
        if (active !== 'request' && !isRequestAccepted(req)) {
            panel.classList.add('is-active');
            panel.innerHTML = lockPanelHtml('접수완료 후 진행 가능', '운송의뢰가 접수완료 상태가 아니면 도착통지서 발송, 입고관리, D/O, 반출요청, 내륙배차를 진행할 수 없습니다.');
            return;
        }

        if (active === 'inbound' && (requestShowsInboundSupplement(req) || isReceiptCompleteOnlyStatus(req, no)) && !hasInboundSupplementState(no) && !window.__TACS_IMPORT_INBOUND_LOADING && !tabHasDataForRequest('inbound', no)) {
            panel.classList.add('is-active');
            panel.innerHTML = '<div class="import-ui-section"><h5>입고 보완요청 확인</h5><p class="text-sm text-slate-500">창고 보완요청 정보를 불러오는 중입니다.</p></div>';
            ensureTabData('inbound', no, root).then(function () {
                if (root && root.isConnected && root.dataset.activeWorkId === active) renderInlineTab(root, active);
            });
            return;
        }

        if (active !== 'request' && active !== 'arrival' && active !== 'release' && !inboundSupplementOpen && !releaseStageOpen && isReceiptCompleteOnlyStatus(req, no)) {
            panel.classList.add('is-active');
            panel.innerHTML = lockPanelHtml('도착대기 후 진행 가능', '접수완료 상태에서는 도착통지서 탭만 열립니다. 도착대기 또는 최종완료 상태가 되면 모든 상세탭이 열립니다.');
            setTabDisabledState(root, req);
            return;
        }

        if (!allTabsOpen && ['inbound', 'do', 'inland'].includes(active)) {
            if (!(active === 'inbound' && shouldOpenInboundForSupplement(req, no))
                && !(releaseStageOpen && (active === 'inbound' || active === 'do'))
                && !(active === 'inland' && isReleaseCompleted(no))) {
                if (!window.__TACS_IMPORT_ARRIVAL_LOADING && !window.__TACS_IMPORT_ARRIVAL_LOADED) {
                    panel.classList.add('is-active');
                    panel.innerHTML = '<div class="import-ui-section"><h5>도착통지 상태 확인</h5><p class="text-sm text-slate-500">도착통지서 발송 여부를 확인하는 중입니다.</p></div>';
                    ensureTabData('arrival', no, root).then(function () {
                        if (root && root.isConnected && root.dataset.activeWorkId === active) renderInlineTab(root, active);
                    });
                    return;
                }
                if (!isArrivalNoticeSent(no)) {
                    panel.classList.add('is-active');
                    panel.innerHTML = lockPanelHtml('도착통지 발송 후 진행 가능', '도착통지서 발송 탭에서 도착통지서를 발송완료 처리해야 이 단계가 열립니다.');
                    setTabDisabledState(root, req);
                    return;
                }
            }
        }

        if (!allTabsOpen && ['do', 'inland'].includes(active)
            && !(releaseStageOpen && active === 'do')
            && !(active === 'inland' && isReleaseCompleted(no))) {
            if (!window.__TACS_IMPORT_INBOUND_LOADING && !window.__TACS_IMPORT_INBOUND_LOADED && !tabHasDataForRequest('inbound', no)) {
                panel.classList.add('is-active');
                panel.innerHTML = '<div class="import-ui-section"><h5>입고 상태 확인</h5><p class="text-sm text-slate-500">입고완료 여부를 확인하는 중입니다.</p></div>';
                ensureTabData('inbound', no, root).then(function () {
                    if (root && root.isConnected && root.dataset.activeWorkId === active) renderInlineTab(root, active);
                });
                return;
            }
            if (!isInboundCompleted(no)) {
                panel.classList.add('is-active');
                panel.innerHTML = lockPanelHtml('입고완료 후 진행 가능', '도착통지서 발송완료 상태에서는 입고관리까지만 열립니다. 창고 승인 후 입고완료(IN_DONE)가 되어야 D/O, 반출관리, 내륙배차가 열립니다.');
                setTabDisabledState(root, req);
                return;
            }
        }

        if (((active === 'release')
                || (!allTabsOpen && active === 'inland' && !isReleaseCompleted(no)))) {
            if (!window.__TACS_IMPORT_DO_LOADING && !isDoDeliveredForGate(no) && !tabHasDataForRequest('do', no)) {
                panel.classList.add('is-active');
                panel.innerHTML = '<div class="import-ui-section"><h5>D/O 상태 확인</h5><p class="text-sm text-slate-500">D/O 전달완료 여부를 확인하는 중입니다.</p></div>';
                refreshDoList(root, active);
                return;
            }
            if (window.__TACS_IMPORT_DO_LOADING) {
                panel.classList.add('is-active');
                panel.innerHTML = '<div class="import-ui-section"><h5>D/O 상태 확인</h5><p class="text-sm text-slate-500">D/O 전달완료 여부를 확인하는 중입니다.</p></div>';
                return;
            }
            if (!isDoDeliveredForGate(no)) {
                panel.classList.add('is-active');
                panel.innerHTML = lockPanelHtml('D/O 전달완료 후 진행 가능', '반출관리는 D/O가 전달완료(TRC_DO_REQ)된 뒤 열립니다.');
                setTabDisabledState(root, req);
                return;
            }
        }

        if (!allTabsOpen && active === 'inland') {
            if (!window.__TACS_IMPORT_RELEASE_LOADING && !window.__TACS_IMPORT_RELEASE_LOADED && !tabHasDataForRequest('release', no)) {
                panel.classList.add('is-active');
                panel.innerHTML = '<div class="import-ui-section"><h5>반출 상태 확인</h5><p class="text-sm text-slate-500">반출완료 여부를 확인하는 중입니다.</p></div>';
                ensureTabData('release', no, root).then(function () {
                    if (root && root.isConnected && root.dataset.activeWorkId === active) renderInlineTab(root, active);
                });
                return;
            }
            if (!isReleaseCompleted(no)) {
                panel.classList.add('is-active');
                panel.innerHTML = lockPanelHtml('반출완료 후 진행 가능', '내륙배차는 반출관리 상태가 반출완료(REL_DONE)된 뒤 열립니다.');
                setTabDisabledState(root, req);
                return;
            }
        }

        if (active === 'request') {
            panel.classList.remove('is-active');
            panel.innerHTML = '';
            if (detailSection) {
                detailSection.style.display = 'block';
            } else {
                renderRequestDetail(req);
            }
            return;
        }

        panel.classList.add('is-active');
        /*
         * 도착통지서 발송 탭은 단순 도착정보 폼이 아니라
         * 적하목록 DB값과 포장명세서 PDF를 대조한 뒤 도착통지서를 발송하는 화면이다.
         * 그래서 TACS-FW-020에서는 import-request.js의 적하목록 비교 패널을 재사용한다.
         */
        const arrivalLookupKey = no || '__none__';
        const arrivalLookupCompleted = root.dataset.arrivalLookupCompletedFor === arrivalLookupKey;
        if (active === 'arrival'
            && !arrivalLookupCompleted
            && !window.__TACS_IMPORT_ARRIVAL_LOADING
            && (!window.__TACS_IMPORT_ARRIVAL_LOADED || !tabHasDataForRequest('arrival', no))) {
            panel.classList.add('is-active');
            panel.innerHTML = '<div class="import-ui-section"><h5>도착통지서 정보 조회</h5><p class="text-sm text-slate-500">도착예정일을 불러오는 중입니다.</p></div>';
            ensureTabData('arrival', no, root).then(function () {
                if (root && root.isConnected) root.dataset.arrivalLookupCompletedFor = arrivalLookupKey;
                if (root && root.isConnected && root.dataset.activeWorkId === active) renderInlineTab(root, active);
            });
            return;
        }

        if (active === 'arrival') {
            if (typeof buildImportManifestWorkflowPanel === 'function') {
                /*
                 * 도착통지서 탭은 적하목록 비교 패널을 재사용하므로 기존에는 req(운송의뢰 row)만
                 * __TACS_IMPORT_MANIFEST_PENDING_SEARCH에 넣었다. 그런데 도착예정일은
                 * IMP_ARRV_NTC.IAN_ARRV_DT 기준으로 arrival row에 내려오므로, arrival row를 먼저 섞어야
                 * 모달/대조화면의 도착예정일이 '-'로 빠지지 않는다.
                 */
                const arrivalRow = workRow('arrival', no);
                const arrivalCtx = mergeUsableRows(arrivalRow || {}, req || {});
                const etaForArrival = pick(arrivalCtx, [
                    'eta', 'arrivalEta', 'arrivalExpectedDate', 'arrivalExpectedDt',
                    'arrivalScheduledDate', 'arrvDt', 'arrvSchdYmd',
                    'ianArrvDt', 'ianArrvSchdYmd', 'irArrvSchdYmd',
                    'IAN_ARRV_DT', 'IAN_ARRV_SCHD_YMD'
                ], '');
                window.__TACS_IMPORT_MANIFEST_PENDING_SEARCH = {
                    trcNo: no,
                    requestNo: no,
                    manifestNo: no,
                    noticeNo: pick(arrivalCtx, ['reqNo', 'arrivalNoticeReqNo', 'arrivalNoticeNo', 'ianNo', 'IAN_NO', 'noticeNo'], ''),
                    mblNo: pick(arrivalCtx, ['mblNo', 'blNo', 'masterBl', 'masterBlNo', 'icmMblNo', 'ICM_MBL_NO', 'BI_MBL_NO']),
                    hblNo: pick(arrivalCtx, ['hblNo', 'houseBl', 'houseBlNo', 'icmHblNo', 'ICM_HBL_NO', 'BI_HBL_NO']),
                    ownerNm: pick(arrivalCtx, ['ownerNm', 'owrNm', 'shipperName']),
                    noticeStatus: pick(arrivalCtx, ['noticeStatusCd', 'arrivalNoticeStatusCd', 'arrivalNoticeSendStatusCd', 'ianSendSttsCd', 'IAN_SEND_STTS_CD', 'noticeStatusNm'], ''),
                    // 도착통지서 발급 모달에서 도착예정일/항구값을 그대로 쓸 수 있게 전달
                    eta: etaForArrival,
                    arrivalEta: etaForArrival,
                    arrivalExpectedDate: etaForArrival,
                    arrivalScheduledDate: etaForArrival,
                    arrvDt: etaForArrival,
                    ianArrvDt: etaForArrival,
                    deptPort: pick(arrivalCtx, ['deptPortRouteNm', 'deptPortNm', 'deptPortCd', 'departurePort', 'startPort']),
                    deptPortNm: pick(arrivalCtx, ['deptPortRouteNm', 'deptPortNm', 'deptPortCd', 'departurePort', 'startPort']),
                    arvlPort: pick(arrivalCtx, ['arvlPortRouteNm', 'arvlPortNm', 'arvlPortCd', 'arrivalPort', 'destinationPort']),
                    arvlPortNm: pick(arrivalCtx, ['arvlPortRouteNm', 'arvlPortNm', 'arvlPortCd', 'arrivalPort', 'destinationPort']),
                    currentLoc: pick(arrivalCtx, ['currentLoc', 'currentLocNm', 'currentLocCd', 'currLoc', 'ianCurrLoc', 'arvlPortRouteNm', 'arvlPortNm', 'arvlPortCd'])
                };
                panel.innerHTML = buildImportManifestWorkflowPanel({detailMode: true});
                if (typeof bindImportManifestWorkflowActions === 'function') {
                    bindImportManifestWorkflowActions('import', 'TACS-FW-020');
                }
                const renderToken = importInlineRenderToken;
                [80, 250, 600].forEach(function (delay) {
                    setTimeout(function () {
                        if (renderToken !== importInlineRenderToken) return;
                        if (!isImportInlineDetailActive(root) || root.dataset.activeWorkId !== 'arrival') return;
                        if (typeof setImportManifestSearchCriteria === 'function') {
                            setImportManifestSearchCriteria(window.__TACS_IMPORT_MANIFEST_PENDING_SEARCH || {trcNo: no, requestNo: no});
                        }
                        if (typeof searchImportManifestList === 'function') searchImportManifestList();
                    }, delay);
                });
                return;
            }

            panel.innerHTML = renderSimpleWorkPanel(active, req);
            return;
        }

        if (['inbound', 'release', 'inland'].includes(active)) {
            const cfg = TAB_DATA_CONFIG[active];
            if (cfg && !window[cfg.loadingFlag] && !window[cfg.loadedFlag]) {
                panel.innerHTML = '<div class="import-ui-section"><h5>데이터 조회</h5><p class="text-sm text-slate-500">상세 데이터를 불러오는 중입니다.</p></div>';
                ensureTabData(active, no, root).then(function () {
                    if (root && root.isConnected && root.dataset.activeWorkId === active) renderInlineTab(root, active);
                });
                return;
            }
            if ((active === 'inbound' || active === 'release')
                && !root.dataset.warehouseOptionsRequested
                && (!window.TRANSPORT_WAREHOUSE_LIST || window.TRANSPORT_WAREHOUSE_LIST.length === 0)) {
                root.dataset.warehouseOptionsRequested = 'true';
                panel.innerHTML = '<div class="import-ui-section"><h5>창고 목록 조회</h5><p class="text-sm text-slate-500">창고 목록을 불러오는 중입니다.</p></div>';
                Promise.all([
                    loadWarehouseOptions(),
                    loadWarehouseManagerOptions()
                ]).then(function () {
                    if (root && root.isConnected && root.dataset.activeWorkId === active) renderInlineTab(root, active);
                });
                return;
            }
            if (active === 'inbound' || active === 'release' || active === 'inland') {
                const goodsRow = workRow('inbound', no) || workRow('release', no) || workRow('inland', no);
                const wirNoForGoods = pick(goodsRow, ['wirNo', 'WIR_NO', 'inboundRequestNo'], '');
                const goodsCacheKey = normalizeText(wirNoForGoods);
                if (goodsCacheKey
                    && !hasInboundGoodsList(goodsRow)
                    && inboundDetailGoodsCache.get(goodsCacheKey) !== 'done') {
                    /*
                     * 반출관리/내륙배차 화면은 품목 상세 조회가 늦거나 실패해도
                     * 화면 전체가 "품목사항 상세를 불러오는 중입니다"에 갇히면 안 된다.
                     * 상세 품목은 백그라운드로 가져오고, 우선 현재 row의 품명 요약값으로 화면을 띄운다.
                     */
                    ensureInboundGoodsDetail(root, no);
                }
            }
            panel.innerHTML = renderSimpleWorkPanel(active, req);
            if (active === 'release') {
                lockReleaseGoodsReadonly(root);
            }
            if (active === 'inbound') {
                ensureInboundPackingGoodsPrefill(root, no);
                ensureInboundGoodsDetail(root, no);
                ensureInboundSupplementMessage(root, no);
            }
            if (active === 'release' || active === 'inland') {
                ensureInboundGoodsDetail(root, no);
            }
            return;
        }

        if (active === 'do') {
            const doLookupKey = no || 'default';
            const doRows = rowsOf(window.TRANSPORT_IMPORT_DO_LIST, window.__TACS_IMPORT_DO_ROWS);
            const hasDoRowForCurrentRequest = !!findRowByRequestNo(doRows, doLookupKey);

            /*
             * 이전 의뢰번호/빈 목록을 이미 로딩 완료로 들고 있으면 D/O 상세 탭이
             * 다시 조회하지 않고 0원/빈 설명을 그린다. 현재 의뢰번호 row가 없으면
             * 의뢰번호별로 한 번은 반드시 /do/list.do를 새로 조회한다.
             */
            const doLastLoadedAt = Number(window.__TACS_IMPORT_DO_LAST_LOADED_AT || 0);
            const doCacheStale = !doLastLoadedAt || (Date.now() - doLastLoadedAt > 1500);
            const doLookupRequestedAt = Number(root.dataset.doLookupRequestedAt || 0);
            const doLookupCooling = root.dataset.doLookupRequestedFor === doLookupKey && (Date.now() - doLookupRequestedAt < 1500);

            /*
             * 화주가 정산 납부를 끝내도 같은 상세화면 안의 기존 메모리 row(TRC_STL_REQ)가
             * 남아 있으면 정산완료(TRC_STL_PAID)가 화면에 안 올라온다. D/O 탭 진입 시
             * 짧은 쿨타임만 두고 /do/list.do를 다시 조회해서 TRAN_COST_STL 최신 상태를 반영한다.
             */
            const doLookupCompletedForCurrent = root.dataset.doLookupCompletedFor === doLookupKey;
            const shouldBlockForInitialDoLoad = (!window.__TACS_IMPORT_DO_LOADED || (!hasDoRowForCurrentRequest && !doLookupCompletedForCurrent))
                && !window.__TACS_IMPORT_DO_LOADING
                && !doLookupCooling;

            if (shouldBlockForInitialDoLoad) {
                root.dataset.doLookupRequestedFor = doLookupKey;
                root.dataset.doLookupRequestedAt = String(Date.now());
                panel.innerHTML = '<div class="import-ui-section"><h5>D/O 관리</h5><p class="text-sm text-slate-500">D/O 데이터를 불러오는 중입니다.</p></div>';
                refreshDoList(root, 'do');
                return;
            }

            if (window.__TACS_IMPORT_DO_LOADED
                && hasDoRowForCurrentRequest
                && doCacheStale
                && !window.__TACS_IMPORT_DO_LOADING
                && !doLookupCooling) {
                root.dataset.doLookupRequestedFor = doLookupKey;
                root.dataset.doLookupRequestedAt = String(Date.now());
                refreshDoList(root, 'do');
            }

            if (window.__TACS_IMPORT_DO_LOADING && !window.__TACS_IMPORT_DO_LOADED) {
                panel.innerHTML = '<div class="import-ui-section"><h5>D/O 관리</h5><p class="text-sm text-slate-500">D/O 데이터를 불러오는 중입니다.</p></div>';
                return;
            }
            panel.innerHTML = buildDoPanel(req);
            applyDoPaidReadonlyGuard(root);
            renderSelectedDocRows(root);
            return;
        }
        panel.innerHTML = renderSimpleWorkPanel(active, req);
        if (active === 'release') lockReleaseGoodsReadonly(root);
    }

    function openFilePicker(root) {
        const input = root ? root.querySelector('input[type="file"][name="docFiles"]') : null;
        if (!input) return;
        input.disabled = false;
        input.removeAttribute('disabled');
        input.multiple = true;
        input.accept = 'application/pdf,.pdf';
        input.click();
    }

    function handlePickedFiles(root, files) {
        const list = Array.from(files || []);
        const invalid = list.find(function (file) { return !isPdf(file); });
        if (invalid) {
            alert('첨부문서는 PDF 파일만 업로드할 수 있습니다.');
            const input = root.querySelector('input[type="file"][name="docFiles"]');
            if (input) input.value = '';
            renderSelectedDocRows(root);
            return;
        }
        appendSelectedFiles(root, list);
        renderSelectedDocRows(root);
    }

    function readMoneyInput(root, name) {
        const input = root.querySelector('[name="' + name + '"]');
        return numberOnly(input ? input.value : 0);
    }

    function setButtonBusy(button, busyText) {
        if (!button) return function () {};
        const oldText = button.textContent;
        const oldDisabled = button.disabled;
        button.disabled = true;
        button.textContent = busyText;
        return function () {
            button.disabled = oldDisabled;
            button.textContent = oldText;
        };
    }

    function handleConnectCustomsCert(button) {
        const trcNo = normalizeText(button.dataset.trcNo || currentRequestNo(currentRequest()));
        if (!trcNo) {
            alert('운송의뢰번호를 찾을 수 없습니다.');
            return;
        }
        if (button.disabled) return;
        button.disabled = true;
        button.setAttribute('disabled', 'disabled');
        const originalText = button.textContent;
        button.textContent = '연결 중...';

        postJson('/transport/import/do/connect-customs-cert.do', {trcNo: trcNo})
            .then(function (json) {
                alert((json && json.message) ? json.message : '수입신고필증을 연결했습니다.');
                window.__TACS_IMPORT_DO_LOADED = false;
                const root = button.closest('.import-inline-tabs-0513');
                return refreshDoList(root, 'do');
            })
            .catch(function (error) {
                alert(error && error.message ? error.message : '수입신고필증 연결 중 오류가 발생했습니다.');
            })
            .finally(function () {
                button.disabled = false;
                button.removeAttribute('disabled');
                button.textContent = originalText || '화주 업로드 필증 연결';
            });
    }

    function handleSettle(button) {
        const root = button.closest('.import-inline-tabs-0513');
        applyDoPaidReadonlyGuard(root);
        const settlementStatus = normalizeSettlementStatus(button.dataset.settlementStatus || '');
        const rootStatus = normalizeSettlementStatus((button.closest('.import-inline-tabs-0513') || document).querySelector('.import-ui-do-settle-btn')?.dataset?.settlementStatus || '');
        if (button.disabled || settlementStatus === '정산완료' || settlementStatus === '정산요청' || rootStatus === '정산완료' || rootStatus === '정산요청' || normalizeText(button.textContent) === '정산완료' || normalizeText(button.textContent) === '정산요청완료') {
            const isPaid = settlementStatus === '정산완료' || rootStatus === '정산완료' || normalizeText(button.textContent) === '정산완료';
            button.disabled = true;
            button.setAttribute('disabled', 'disabled');
            button.setAttribute('aria-disabled', 'true');
            button.textContent = isPaid ? '정산완료' : '정산요청완료';
            return;
        }
        const trcNo = button.dataset.trcNo || currentRequestNo(currentRequest());
        if (!trcNo) {
            alert('정산 대상 의뢰번호를 찾을 수 없습니다.');
            return;
        }
        const freightAmt = readMoneyInput(root, 'freightAmt');
        const warehouseAmt = readMoneyInput(root, 'warehouseAmt');
        const totalBillAmt = freightAmt + warehouseAmt;
        const settlementMemo = normalizeText(root.querySelector('[name="settlementMemo"]')?.value || '');
        if (freightAmt <= 0 && warehouseAmt <= 0 && !settlementMemo) {
            alert('운임비, 창고비 또는 정산 설명 중 하나 이상을 입력하세요.');
            return;
        }
        const restore = setButtonBusy(button, '정산요청중');
        postJson('/transport/import/do/settle.do', {
            trcNo: trcNo,
            freightAmt: freightAmt,
            warehouseAmt: warehouseAmt,
            totalBillAmt: totalBillAmt,
            settlementMemo: settlementMemo,
            settlementExpln: settlementMemo,
            tcsStlExpln: settlementMemo
        }).then(function (json) {
            alert((json && json.message) ? json.message : '정산요청을 화주에게 보냈습니다.');

            /*
             * 저장은 성공했는데 목록 재조회 응답이 캐시/래퍼 형태 때문에 늦게 반영되면
             * 현재 D/O 상세 탭이 그대로 0원/빈 설명처럼 보인다.
             * 방금 보낸 값은 즉시 메모리 row에 반영하고, 그 다음 서버값으로 다시 덮어쓴다.
             */
            const requestedAt = formatLocalDateTimeMinute(new Date());
            const patchRow = {
                trcNo: trcNo,
                requestNo: trcNo,
                freightAmt: freightAmt,
                tcsFrgtAmt: freightAmt,
                freight: freightAmt,
                warehouseAmt: warehouseAmt,
                tcsWhAmt: warehouseAmt,
                warehouse: warehouseAmt,
                totalBillAmt: totalBillAmt,
                tcsTotBillAmt: totalBillAmt,
                settlementStatusCd: 'TRC_STL_REQ',
                tcsStlStatusCd: 'TRC_STL_REQ',
                settlementStatusNm: 'TRC_STL_REQ',
                tcsStlStatusNm: 'TRC_STL_REQ',
                settlementStatus: '정산요청',
                tcsDt: requestedAt,
                TCS_DT: requestedAt,
                settlementReqDt: requestedAt,
                settlementExpln: settlementMemo,
                tcsStlExpln: settlementMemo,
                settlementMemo: settlementMemo
            };
            rememberDoSettlementPatch(trcNo, patchRow);

            const currentRows = rowsOf(window.TRANSPORT_IMPORT_DO_LIST, window.__TACS_IMPORT_DO_ROWS).slice();
            let patched = false;
            const patch = function (row) {
                if (!rowMatchesRequestNo(row, trcNo)) return row;
                patched = true;
                return mergeDoSettlementPatchValue(row, patchRow);
            };
            const patchedRows = currentRows.map(patch);
            if (!patched) {
                patchedRows.unshift(patchRow);
            }
            storeRows(['TRANSPORT_IMPORT_DO_LIST', '__TACS_IMPORT_DO_ROWS'], patchedRows);
            renderInlineTab(root, 'do');

            window.__TACS_IMPORT_DO_LOADED = false;
            return refreshDoList(root, 'do');
        }).catch(function (error) {
            console.error('[D/O 정산 실패]', error);
            alert(error.message || '정산요청 처리 중 오류가 발생했습니다.');
        }).finally(restore);
    }



    function handleIssue(button) {
        const root = button.closest('.import-inline-tabs-0513');
        const trcNo = button.dataset.trcNo || currentRequestNo(currentRequest());
        if (!root || !trcNo) {
            alert('D/O 발급 대상 의뢰번호를 찾을 수 없습니다.');
            return;
        }

        const files = getSelectedFiles(root);
        const doNo = normalizeText(root.querySelector('[name="doNo"]')?.value || '');

        const invalid = files.find(function (file) { return !isPdf(file); });
        if (invalid) {
            alert('첨부문서는 PDF 파일만 선택할 수 있습니다.');
            return;
        }

        const formData = new FormData();
        formData.append('trcNo', trcNo);
        formData.append('doNo', doNo);
        formData.append('receiveDt', today());
        files.forEach(function (file) {
            formData.append('docFiles', file);
        });

        const restore = setButtonBusy(button, '발급중');
        postJson('/transport/import/do/issue.do', formData)
            .then(function () {
                alert('D/O가 발급되었습니다.');
                clearSelectedFiles(root);
                const input = root.querySelector('input[type="file"][name="docFiles"]');
                if (input) input.value = '';
                window.__TACS_IMPORT_DO_LOADED = false;
                return refreshDoListUntilDoPdfReady(root, trcNo, 8);
            })
            .catch(function (error) {
                console.error('[D/O 발급 실패]', error);
                alert(error.message || 'D/O 발급 중 오류가 발생했습니다.');
            })
            .finally(restore);
    }

    function handleDeliver(button) {
        const root = button.closest('.import-inline-tabs-0513');
        const trcNo = button.dataset.trcNo || currentRequestNo(currentRequest());
        const row = findDoRow(trcNo);
        const doNo = pick(row, ['doNo', 'diDoNo', 'DI_DO_NO'], '');
        if (!trcNo || !doNo) {
            alert('전달할 D/O 번호를 찾을 수 없습니다.');
            return;
        }

        const files = getSelectedFiles(root);
        const invalid = files.find(function (file) { return !isPdf(file); });
        if (invalid) {
            alert('첨부문서는 PDF 파일만 선택할 수 있습니다.');
            return;
        }

        const deliveryTargetNm = root.querySelector('[name="deliveryTargetNm"]')?.value || '';
        const deliveryMethodCd = root.querySelector('[name="deliveryMethodCd"]')?.value || '온라인';
        const restore = setButtonBusy(button, '전달중');

        /*
         * 전달완료 단계에서는 /upload-files.do를 다시 호출하지 않는다.
         * D/O 발급 API가 이미 PDF를 저장하고 DI_TFG_NO에 연결하므로,
         * 여기서 재업로드를 하면 같은 파일을 한 번 더 저장하다가 500이 날 수 있다.
         * 선택 목록은 화면 표시용으로만 유지하고, 전달 성공 후에만 비운다.
         */
        postJson('/transport/import/do/deliver.do', {
            trcNo: trcNo,
            doNo: doNo,
            deliveryDt: today(),
            deliveryTargetNm: deliveryTargetNm,
            deliveryMethodCd: deliveryMethodCd
        }).then(function () {
            alert('D/O와 수입신고필증이 창고담당자에게 전달되었습니다.');
            patchImportDoDeliveredState(trcNo, doNo);
            setTabDisabledState(root, currentRequest());
            window.__TACS_IMPORT_DO_LOADED = false;
            return refreshDoList(root, 'do');
        }).catch(function (error) {
            console.error('[D/O 전달 실패]', error);
            alert(error.message || 'D/O 전달 중 오류가 발생했습니다.');
        }).finally(restore);
    }

    function postFlexible(urls, data) {
        const list = Array.isArray(urls) ? urls : [urls];
        let index = 0;
        function tryNext(lastError) {
            if (index >= list.length) return Promise.reject(lastError || new Error('처리 가능한 API를 찾지 못했습니다.'));
            const url = list[index++];
            const body = new URLSearchParams();
            Object.keys(data || {}).forEach(function (key) {
                if (data[key] !== undefined && data[key] !== null) body.append(key, data[key]);
            });
            return fetch(withContext(url), {
                method: 'POST',
                headers: csrfHeaders(false),
                credentials: 'same-origin',
                body: body.toString()
            }).then(function (res) {
                if (!res.ok) throw new Error('HTTP ' + res.status);
                return res.text().then(function (text) {
                    if (!text) return {success: true};
                    try { return JSON.parse(text); } catch (e) { return {success: true, raw: text}; }
                });
            }).then(function (json) {
                if (json && (json.success === false || json.성공 === false)) throw new Error(json.message || json.메시지 || '처리에 실패했습니다.');
                return json || {success: true};
            }).catch(function (err) {
                if (/HTTP 404/.test(err.message || '')) return tryNext(err);
                throw err;
            });
        }
        return tryNext();
    }

    function markActionDone(button, message) {
        const actions = button && button.closest('.import-ui-actions');
        if (actions) actions.innerHTML = '<span class="info-chip">' + esc(message || '처리완료') + '</span>';
    }


    function sendArrivalNotice(payload) {
        return postFlexible([
            '/transport/import/arrival-notice/send.do',
            '/transport/import/arrival-tracking/notice/send.do',
            '/transport/import/arrival/send.do'
        ], payload).catch(function (error) {
            if (!/HTTP 404/.test(error.message || '')) throw error;
            const reqNo = encodeURIComponent(payload.reqNo || payload.trcNo || '');
            return getJsonFlexible([
                '/transport/import/arrival-notice/send-get.do?reqNo=' + reqNo,
                '/transport/import/arrival-tracking/notice/send-get.do?reqNo=' + reqNo,
                '/transport/import/arrival/send-get.do?reqNo=' + reqNo
            ]);
        });
    }

    function handleArrivalSend(button) {
        const root = button.closest('.import-inline-tabs-0513');
        const trcNo = button.dataset.trcNo || currentRequestNo(currentRequest());
        const noticeNo = button.dataset.noticeNo || '';
        const reqNo = trcNo;
        const payload = Object.assign({
            reqNo: reqNo,
            trcNo: trcNo,
            noticeNo: noticeNo
        }, formValues(root));
        delete payload.cargoMgmtNo;
        const restore = setButtonBusy(button, '발송중');
        sendArrivalNotice(payload)
            .then(function (json) {
                const savedNoticeNo = pick(json, ['noticeNo', 'arrivalNoticeNo', 'arrivalNoticeReqNo', 'ianNo'], noticeNo || '');
                const requestRow = findRequestRow(trcNo) || currentRequest() || {};
                const masterBlNo = pick(payload, ['mblNo', 'masterBlNo', 'masterBl', 'mblHbl', 'blNo'], pick(requestRow, ['mblNo', 'masterBlNo', 'masterBl', 'mblHbl', 'blNo', 'icmMblNo', 'ICM_MBL_NO', 'BI_MBL_NO', 'TCS_MBL_NO', 'IR_BL_AWB_NO'], ''));
                const sentDetail = {
                    trcNo: trcNo,
                    reqNo: reqNo,
                    noticeNo: savedNoticeNo || noticeNo || payload.reqNo || '',
                    arrivalNoticeNo: savedNoticeNo || noticeNo || payload.reqNo || '',
                    arrivalNoticeReqNo: savedNoticeNo || noticeNo || payload.reqNo || '',
                    mblNo: masterBlNo,
                    masterBlNo: masterBlNo,
                    blNo: masterBlNo
                };
                refreshArrivalNoticeSentState(sentDetail);
                window.dispatchEvent(new CustomEvent('tacs:import-arrival-notice-sent', { detail: sentDetail }));
                if (typeof window.patchImportArrivalNoticeSentDom === 'function') {
                    window.patchImportArrivalNoticeSentDom(trcNo, sentDetail.noticeNo);
                }
                alert('도착통지서가 발송되었습니다.');
                if (root && root.dataset.activeWorkId === 'arrival') {
                    renderInlineTab(root, 'arrival');
                    if (typeof window.patchImportArrivalNoticeSentDom === 'function') {
                        setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, savedNoticeNo || noticeNo || payload.reqNo || ''); }, 0);
                        setTimeout(function () { window.patchImportArrivalNoticeSentDom(trcNo, savedNoticeNo || noticeNo || payload.reqNo || ''); }, 120);
                    }
                } else {
                    markActionDone(button, '발송완료');
                }
                if (root) setTabDisabledState(root, currentRequest());
            })
            .catch(function (error) {
                console.error('[도착통지 발송 실패]', error);
                const message = String(error && error.message || '');
                if (message.includes('입고관리 대상') || message.includes('WH_IN_RPT')) {
                    alert('도착통지서 발송 중 문제가 발생했습니다. 입고관리 대상 정보를 확인해주세요.');
                    return;
                }
                alert(message || '도착통지 발송 중 오류가 발생했습니다.');
            })
            .finally(restore);
    }

    function collectInboundGoodsJson(root) {
        const rows = root ? Array.from(root.querySelectorAll('.import-ui-goods-table tbody tr')) : [];
        if (!rows.length) return '[]';
        const toNumberOrNull = function (value) {
            const text = normalizeText(value).replace(/,/g, '');
            if (!text) return null;
            const num = Number(text);
            if (Number.isFinite(num)) return num;
            if (!/[0-9]/.test(text)) return null;
            const cleaned = numberOnly(text);
            return Number.isFinite(cleaned) ? cleaned : null;
        };
        const goods = rows.map(function (rowEl) {
            const firstCell = rowEl.querySelector('td[data-cg-no]');
            const cells = Array.from(rowEl.querySelectorAll('td'));
            const value = function (key, index) {
                const input = rowEl.querySelector('[data-goods-field="' + key + '"]');
                if (input) return normalizeText(input.value || '');
                return normalizeText(cells[index] ? cells[index].textContent : '');
            };
            const cgNo = toNumberOrNull(firstCell?.dataset?.cgNo || '');
            const goodsNo = toNumberOrNull(firstCell?.dataset?.goodsNo || '');
            const goodsName = sanitizeGoodsDisplayName(value('goodsName', 0));
            const goodsHsCodeRaw = normalizeText(firstCell?.dataset?.goodsHsCode || value('goodsHsCode', -1));
            // 화면에서는 HS코드를 완전히 입력받지 않는다.
            // GOODS.GOODS_HS_CODE가 NOT NULL인 현재 DB 구조 때문에 서버 저장용으로만 기본값을 숨겨서 보낸다.
            const goodsHsCode = goodsHsCodeRaw || '0101211000';
            const price = toNumberOrNull(value('price', 1));
            const qty = toNumberOrNull(value('qty', 2));
            const goodsTotalPrice = toNumberOrNull(value('goodsTotalPrice', 3));
            const weight = toNumberOrNull(value('weight', 4));
            const origin = value('origin', 5);
            if (!cgNo && !goodsNo && !goodsName && !goodsHsCodeRaw && price == null && qty == null && goodsTotalPrice == null && weight == null) {
                return null;
            }
            return {
                cgNo: cgNo,
                goodsNo: goodsNo,
                goodsName: goodsName,
                goodsHsCode: goodsHsCode,
                hsCode: goodsHsCode,
                itemNm: goodsName,
                price: price,
                qty: qty,
                goodsTotalPrice: goodsTotalPrice,
                weight: weight,
                origin: origin
            };
        }).filter(Boolean);
        return JSON.stringify(goods);
    }

    function inboundSummaryGoodsNameFromPayload(formPayload) {
        try {
            const goods = JSON.parse(formPayload && formPayload.goodsJson ? formPayload.goodsJson : '[]')
                .filter(function (item) {
                    return item && normalizeText(item.goodsName || item.itemNm);
                });
            if (!goods.length) return '';
            const firstName = sanitizeGoodsDisplayName(goods[0].goodsName || goods[0].itemNm);
            return goods.length > 1 && firstName && !/\s외\s*[0-9]+건$/.test(firstName)
                ? firstName + ' 외 ' + (goods.length - 1) + '건'
                : firstName;
        } catch (e) {
            return '';
        }
    }

    function inboundGoodsCountFromPayload(formPayload) {
        try {
            return JSON.parse(formPayload && formPayload.goodsJson ? formPayload.goodsJson : '[]').length || '';
        } catch (e) {
            return '';
        }
    }

    function inboundGoodsListFromPayload(formPayload) {
        try {
            return JSON.parse(formPayload && formPayload.goodsJson ? formPayload.goodsJson : '[]')
                .filter(function (item) {
                    return item && normalizeText(item.goodsName || item.itemNm);
                })
                .map(function (item) {
                    return Object.assign({}, item, {
                        itemNm: item.itemNm || item.goodsName || '',
                        __packingPrefill: item.__packingPrefill === true
                    });
                });
        } catch (e) {
            return [];
        }
    }

    function patchInboundRowAfterSubmit(trcNo, formPayload, supplementSubmit) {
        const no = normalizeText(trcNo);
        if (!no) return;
        const submittedStatusCd = supplementSubmit ? 'REQ_SENT' : 'WAIT';
        const submittedStatusNm = supplementSubmit ? '보완제출완료' : '입고대기';
        const summaryGoodsName = inboundSummaryGoodsNameFromPayload(formPayload) || formPayload.itemNm || '';
        const goodsList = inboundGoodsListFromPayload(formPayload);
        const aliases = {
            trcNo: no,
            requestNo: no,
            wirNo: formPayload.wirNo || '',
            inPlanDt: formPayload.inPlanDt || '',
            wirInPlanDt: formPayload.inPlanDt || '',
            warehouseId: formPayload.warehouseId || '',
            whNo: formPayload.warehouseId || '',
            wzNo: formPayload.wzNo || '',
            warehouseZoneNo: formPayload.wzNo || '',
            wmId: formPayload.wmId || '',
            warehouseManagerId: formPayload.wmId || '',
            cargoMgmtNo: autoImpCargoMgmtNoForDisplay(formPayload.cargoMgmtNo || ''),
            wirCargoMgmtNo: autoImpCargoMgmtNoForDisplay(formPayload.cargoMgmtNo || ''),
            incoTermsCd: formPayload.incoTermsCd || '',
            wirIncoTermsCd: formPayload.incoTermsCd || '',
            invoiceNo: formPayload.invoiceNo || '',
            wirInvoiceNo: formPayload.invoiceNo || '',
            itemNm: summaryGoodsName,
            goodsName: summaryGoodsName,
            goodsCnt: summaryGoodsName ? String(inboundGoodsCountFromPayload(formPayload)) : '',
            remark: formPayload.remark || '',
            requestCn: formPayload.remark || '',
            WIR_RQST_CN: formPayload.remark || '',
            statusCd: submittedStatusCd,
            whReplyStatusCd: submittedStatusCd,
            warehouseReplyStatusCd: submittedStatusCd,
            wirWhReplyStatusCd: submittedStatusCd,
            warehouseInStatusCd: submittedStatusCd,
            wirStatusCd: submittedStatusCd,
            statusNm: submittedStatusNm,
            inStatusNm: submittedStatusNm,
            warehouseInStatusNm: submittedStatusNm,
            whInStatusNm: submittedStatusNm,
            wirStatusNm: submittedStatusNm
        };
        if (goodsList.length) {
            aliases.goodsList = goodsList;
            aliases.itemList = goodsList;
            rememberInboundPackingGoods(aliases, currentRequest() || {}, no, goodsList);
        }
        TAB_DATA_CONFIG.inbound.storeKeys.forEach(function (key) {
            const list = Array.isArray(window[key]) ? window[key] : [];
            let patched = false;
            const next = list.map(function (row) {
                if (rowMatchesRequestNo(row, no)) {
                    patched = true;
                    return Object.assign({}, row, aliases);
                }
                return row;
            });
            if (!patched) next.unshift(aliases);
            window[key] = next;
        });

        const requestAliases = {
            requestDisplayStatusCd: submittedStatusCd,
            requestDisplayStatusNm: submittedStatusNm,
            displayStatusCd: submittedStatusCd,
            displayStatusNm: submittedStatusNm,
            displayStatus: submittedStatusNm,
            warehouseInStatusCd: submittedStatusCd,
            warehouseInStatusNm: submittedStatusNm,
            inboundOutboundStatusCd: submittedStatusCd,
            inboundOutboundStatusNm: submittedStatusNm,
            whReplyStatusCd: submittedStatusCd,
            warehouseReplyStatusCd: submittedStatusCd,
            wirStatusCd: submittedStatusCd,
            wirStatusNm: submittedStatusNm
        };
        if (formPayload.wirNo) requestAliases.wirNo = formPayload.wirNo;
        if (goodsList.length) {
            requestAliases.goodsList = goodsList;
            requestAliases.itemList = goodsList;
        }
        ['TRANSPORT_IMPORT_REQUESTS', '__TACS_IMPORT_REQUEST_LIST', '__IMPORT_REQUEST_LIST'].forEach(function (key) {
            const list = Array.isArray(window[key]) ? window[key] : [];
            window[key] = list.map(function (row) {
                return rowMatchesRequestNo(row, no) ? Object.assign({}, row, requestAliases) : row;
            });
        });
        const req = currentRequest();
        if (req && rowMatchesRequestNo(req, no)) {
            setCurrentRequest(Object.assign({}, req, requestAliases));
        }
    }

    function handleInboundSend(button, supplement) {
        const root = button.closest('.import-inline-tabs-0513');
        const trcNo = button.dataset.trcNo || currentRequestNo(currentRequest());
        const supplementSubmit = button.dataset.supplementSubmit === 'true';
        const row = workRow('inbound', trcNo);
        const payload = Object.assign({
            trcNo: trcNo,
            wirNo: button.dataset.wirNo || pick(row, ['wirNo', 'WIR_NO', 'inboundRequestNo'], ''),
            supplementYn: (supplementSubmit || supplement) ? 'Y' : 'N'
        }, formValues(root));
        payload.wmId = payload.wmId || pick(row, WAREHOUSE_MANAGER_VALUE_KEYS, '');
        payload.wzNo = payload.wzNo || pick(row, WAREHOUSE_ZONE_VALUE_KEYS, '');
        payload.receiverId = payload.receiverId || payload.wmId;
        payload.goodsJson = collectInboundGoodsJson(root);
        if (!payload.wzNo || !payload.wmId) {
            alert('창고명을 선택해주세요.');
            return;
        }
        const goodsSaveOnly = button.dataset.goodsSave === 'true';
        const restore = setButtonBusy(button, goodsSaveOnly ? '저장중' : (supplementSubmit ? '보완제출중' : (supplement ? '보완중' : '발송중')));
        const urls = (supplementSubmit || supplement)
            ? ['/transport/import/unloading-in/supplement.do']
            : ['/transport/import/unloading-in/deliver.do'];
        postFlexible(urls, payload)
            .then(function (res) {
                alert(goodsSaveOnly ? '품목사항이 저장되었습니다.' : (supplementSubmit ? '입고 보완사항이 제출되었습니다.' : (supplement ? '입고 보완요청이 처리되었습니다.' : '입고신청이 발송되었습니다.')));
                if (res && res.wirNo) {
                    button.dataset.wirNo = res.wirNo;
                    payload.wirNo = res.wirNo;
                }
                patchInboundRowAfterSubmit(trcNo, payload, supplementSubmit);
                markActionDone(button, goodsSaveOnly ? '저장완료' : (supplementSubmit ? '보완제출완료' : (supplement ? '보완요청완료' : '발송완료')));
                if (root && root.isConnected) renderInlineTab(root, 'inbound');

                // 발송/보완제출 직후 서버 목록을 다시 읽되, 캐시가 붙지 않게 timestamp를 붙인다.
                window.__TACS_IMPORT_INBOUND_LOADED = false;
                return getJsonFlexible(['/transport/import/unloading-in/list.do?_=' + Date.now(), '/transport/import/unloading-in/list.do']).then(function (json) {
                    const rows = jsonRows(json);
                    storeRows(TAB_DATA_CONFIG.inbound.storeKeys, rows);
                    window.__TACS_IMPORT_INBOUND_LOADED = true;
                    if (root && root.isConnected) renderInlineTab(root, 'inbound');
                });
            })
            .catch(function (error) { console.error('[입고 처리 실패]', error); alert(error.message || '입고 처리 중 오류가 발생했습니다.'); })
            .finally(restore);
    }

    function handleReleaseSend(button, supplement) {
        const root = button.closest('.import-inline-tabs-0513');
        const trcNo = button.dataset.trcNo || currentRequestNo(currentRequest());
        const supplementSubmit = button.dataset.supplementSubmit === 'true';
        const row = workRow('release', trcNo);
        const payload = Object.assign({
            trcNo: trcNo,
            releaseReqNo: button.dataset.releaseReqNo || pick(row, ['crrNo', 'CRR_NO', 'releaseReqNo', 'releaseRequestNo'], ''),
            supplementYn: (supplementSubmit || supplement) ? 'Y' : 'N'
        }, formValues(root));
        payload.wmId = payload.wmId || pick(row, ['wmId', 'warehouseManagerId', 'bondedManagerId', 'crrWmId', 'CRR_WM_ID', 'WM_ID'], '');
        payload.wzNo = payload.wzNo || pick(row, ['wzNo', 'warehouseZoneNo', 'bondedZoneNo', 'crrWzNo', 'CRR_WZ_NO', 'WZ_NO'], '');
        payload.receiverId = payload.receiverId || payload.wmId;
        // 반출관리 품목사항은 입고관리 입력값을 그대로 보여주는 읽기전용 영역이다.
        // 여기서 goodsJson을 보내면 기존 CUSTOMS_GOODS에 중복 품목이 추가될 수 있으므로 전송하지 않는다.
        if (!payload.wzNo || !payload.wmId) {
            alert('창고명을 선택해주세요.');
            return;
        }
        const restore = setButtonBusy(button, supplementSubmit ? '보완제출중' : (supplement ? '보완중' : '발송중'));
        const urls = (supplementSubmit || supplement)
            ? ['/transport/import/release-request/supplement.do']
            : ['/transport/import/release-request/request.do'];
        postFlexible(urls, payload)
            .then(function () {
                alert(supplementSubmit ? '반출 보완사항이 제출되었습니다.' : (supplement ? '반출 보완요청이 처리되었습니다.' : '반출요청이 발송되었습니다.'));
                window.__TACS_IMPORT_RELEASE_LOADED = false;
                return getJsonFlexible(['/transport/import/release-request/list.do']).then(function (json) {
                    const rows = jsonRows(json);
                    window.__TACS_IMPORT_RELEASE_ROWS = rows;
                    window.TRANSPORT_IMPORT_RELEASE_LIST = rows;
                    window.IMPORT_RELEASE_LIST = rows;
                    window.__TACS_IMPORT_RELEASE_LOADED = true;
                    if (root && root.isConnected) renderInlineTab(root, 'release');
                });
            })
            .catch(function (error) { console.error('[반출 처리 실패]', error); alert(error.message || '반출 처리 중 오류가 발생했습니다.'); })
            .finally(restore);
    }

    function normalizeImportRequestActionCells(scope) {
        const root = scope || document;
        const buttons = Array.from(root.querySelectorAll('button, a')).filter(function (el) {
            const text = normalizeText(el.textContent);
            return el.classList.contains('import-request-detail-btn')
                || text === '상세'
                || text === '반려사유';
        });
        buttons.forEach(function (button) {
            const cell = button.closest('td');
            if (!cell) return;
            const hasRequestAction = Array.from(cell.querySelectorAll('button, a')).some(function (el) {
                const text = normalizeText(el.textContent);
                return el.classList.contains('import-request-detail-btn')
                    || text === '상세'
                    || text === '반려사유';
            });
            if (hasRequestAction) cell.classList.add('import-request-action-cell');
        });
    }

    function installRequestActionCellObserver() {
        normalizeImportRequestActionCells(document);
        const target = document.getElementById('detail-body') || document.body;
        if (!target || window.__TACS_IMPORT_REQUEST_ACTION_OBSERVER) return;
        window.__TACS_IMPORT_REQUEST_ACTION_OBSERVER = true;
        const observer = new MutationObserver(function () {
            normalizeImportRequestActionCells(target);
        });
        observer.observe(target, {childList: true, subtree: true});
    }

    function readRequestDetailPayload(root) {
        const current = currentRequest();
        const rootRequestNo = root ? normalizeText(root.dataset.requestNo || root.dataset.trcNo || '') : '';
        const value = function (name) {
            const el = root ? root.querySelector('[name="' + name + '"]') : null;
            return el ? normalizeText(el.value) : '';
        };
        const displayValue = function (name) {
            const el = root ? root.querySelector('.import-ui-option-display[data-option-name="' + name + '"]') : null;
            return el ? normalizeText(el.value) : value(name);
        };
        const touched = root ? Array.from(root.querySelectorAll('[data-user-edited="true"][name]')).map(function (el) {
            return el.name;
        }) : [];
        return {
            trcNo: rootRequestNo || currentRequestNo(current),
            receiptDate: value('receiptDate'),
            shipperName: value('shipperName'),
            shipperPhone: value('shipperPhone'),
            shipperEmail: value('shipperEmail'),
            buyerNm: value('buyerName'),
            buyerCountryCd: value('buyerCountry'),
            transportMeanCd: value('transportMode'),
            transportTypeCd: value('transportType'),
            deptPortCd: value('originPort'),
            arvlPortCd: value('destinationPort'),
            itemCategory: value('itemCategory'),
            goodsName: value('goodsName'),
            qty: value('qty'),
            weight: value('weight'),
            mblNo: value('mblNo'),
            requestCn: value('requestNote'),
            _touched: touched,
            _display: {
                buyerCountry: displayValue('buyerCountry'),
                transportMean: displayValue('transportMode'),
                transportType: displayValue('transportType'),
                deptPort: displayValue('originPort'),
                arvlPort: displayValue('destinationPort'),
                blType: displayValue('blType')
            }
        };
    }

    function applyRequestDetailPayloadToCurrent(payload) {
        if (!payload || !payload.trcNo) return;
        const assign = function (row, keys, value) {
            const next = normalizeText(value);
            if (!next) return;
            keys.forEach(function (key) {
                row[key] = next;
            });
        };
        [window.selectedImportRequest].concat(requestRows()).forEach(function (row) {
            if (!row || !rowMatchesRequestNo(row, payload.trcNo)) return;
            const display = payload._display || {};
            assign(row, ['receiptDate'], payload.receiptDate);
            assign(row, ['shipperName'], payload.shipperName);
            assign(row, ['shipperPhone'], payload.shipperPhone);
            assign(row, ['shipperEmail'], payload.shipperEmail);
            assign(row, ['consignorName', 'buyerName', 'buyerNm'], payload.buyerNm);
            assign(row, ['consignorCountry', 'buyerCountry'], display.buyerCountry || payload.buyerCountryCd);
            assign(row, ['buyerCountryCd'], payload.buyerCountryCd);
            assign(row, ['transportMode', 'transportMeanNm'], display.transportMean || payload.transportMeanCd);
            assign(row, ['transportMeanCd'], payload.transportMeanCd);
            assign(row, ['transportType'], display.transportType || payload.transportTypeCd);
            assign(row, ['transportTypeCd'], payload.transportTypeCd);
            assign(row, ['originPort', 'deptPortNm'], display.deptPort || payload.deptPortCd);
            assign(row, ['deptPortCd'], payload.deptPortCd);
            assign(row, ['destinationPort', 'arvlPortNm'], display.arvlPort || payload.arvlPortCd);
            assign(row, ['arvlPortCd'], payload.arvlPortCd);
            assign(row, ['blType'], display.blType);
            assign(row, ['itemCategory'], payload.itemCategory);
            assign(row, ['goodsName', 'itemNm'], payload.goodsName);
            assign(row, ['qty', 'goodsQty'], payload.qty);
            assign(row, ['weight', 'goodsWeight'], payload.weight);
            assign(row, ['mblNo', 'blNo'], payload.mblNo);
            assign(row, ['hblNo', 'houseBlNo'], deriveHouseBlFromMaster(payload.mblNo));
            assign(row, ['requestNote', 'requestCn'], payload.requestCn);
        });
        syncRequestDetailPayloadToWorkflowRows(payload);
    }

    function syncRequestDetailPayloadToWorkflowRows(payload) {
        if (!payload || !payload.trcNo) return;
        const hblNo = deriveHouseBlFromMaster(payload.mblNo);
        const display = payload._display || {};
        const patch = {
            trcNo: payload.trcNo,
            requestNo: payload.trcNo,
            manifestNo: payload.trcNo,
            mblNo: payload.mblNo,
            masterBlNo: payload.mblNo,
            masterBl: payload.mblNo,
            blNo: payload.mblNo,
            hblNo: hblNo,
            houseBlNo: hblNo,
            houseBl: hblNo,
            ownerNm: payload.shipperName,
            shipperName: payload.shipperName,
            deptPortCd: payload.deptPortCd,
            deptPortNm: display.deptPort || payload.deptPortCd,
            arvlPortCd: payload.arvlPortCd,
            arvlPortNm: display.arvlPort || payload.arvlPortCd,
            itemCategory: payload.itemCategory,
            goodsName: payload.goodsName,
            itemNm: payload.goodsName,
            qty: payload.qty,
            weight: payload.weight
        };
        ['arrival'].forEach(function (type) {
            const cfg = TAB_DATA_CONFIG[type];
            if (!cfg) return;
            cfg.storeKeys.forEach(function (key) {
                const list = Array.isArray(window[key]) ? window[key] : [];
                let matched = false;
                const next = list.map(function (row) {
                    if (!rowMatchesRequestNo(row, payload.trcNo)) return row;
                    matched = true;
                    return mergeUsableRows(row, patch);
                });
                if (!matched) next.unshift(patch);
                window[key] = next;
            });
            window[cfg.loadedFlag] = true;
            window[cfg.loadingFlag] = false;
        });
        window.__TACS_IMPORT_MANIFEST_PENDING_SEARCH = mergeUsableRows(window.__TACS_IMPORT_MANIFEST_PENDING_SEARCH || {}, {
            trcNo: payload.trcNo,
            requestNo: payload.trcNo,
            manifestNo: payload.trcNo,
            mblNo: payload.mblNo,
            hblNo: hblNo,
            blNo: payload.mblNo,
            ownerNm: payload.shipperName
        });
    }

    function requestDetailPersistPayload(payload) {
        const clean = Object.assign({}, payload || {});
        delete clean._display;
        delete clean.receiptDate;
        delete clean.shipperName;
        delete clean.shipperPhone;
        delete clean.shipperEmail;
        return clean;
    }

    function setRequestDetailButtonsBusy(root, activeButton, busyText) {
        const buttons = root ? root.querySelectorAll('.import-request-save-btn, .import-request-submit-btn') : [];
        buttons.forEach(function (btn) {
            btn.dataset.oldText = btn.textContent;
            btn.dataset.oldDisabled = btn.disabled ? 'Y' : 'N';
            btn.disabled = true;
            if (btn === activeButton) btn.textContent = busyText;
        });
        return function () {
            buttons.forEach(function (btn) {
                if (!btn.isConnected) return;
                btn.disabled = btn.dataset.oldDisabled === 'Y';
                btn.textContent = btn.dataset.oldText || btn.textContent;
                delete btn.dataset.oldText;
                delete btn.dataset.oldDisabled;
            });
        };
    }

    function handleRequestDetailSave(button) {
        const root = button.closest('.import-ui-request-detail');
        const payload = readRequestDetailPayload(root);
        if (!payload.trcNo) {
            alert('저장할 의뢰번호를 찾을 수 없습니다.');
            return;
        }
        if (importRequestDetailBusy.has(payload.trcNo)) return;
        importRequestDetailBusy.add(payload.trcNo);
        const restore = setRequestDetailButtonsBusy(root, button, '저장중');
        postJson('/transport/import/request/detail/save.do', requestDetailPersistPayload(payload))
            .then(function () {
                savedImportRequestDetails.add(payload.trcNo);
                removeRequestDetailDraft(payload.trcNo);
                applyRequestDetailPayloadToCurrent(payload);
                renderRequestDetail(currentRequest());
                alert('운송의뢰 상세정보가 저장되었습니다.');
            })
            .catch(function (error) {
                console.error('[운송의뢰 상세 저장 실패]', error);
                alert(error.message || '운송의뢰 상세정보 저장 중 오류가 발생했습니다.');
            })
            .finally(function () {
                importRequestDetailBusy.delete(payload.trcNo);
                restore();
            });
    }

    function handleInlandProcess(button) {
        const root = button.closest('.import-inline-tabs-0513');
        const trcNo = button.dataset.trcNo || currentRequestNo(currentRequest());
        const row = findRowByRequestNo(tabRows('inland'), trcNo) || {};
        const detailRoot = button.closest('.import-ui-request-detail');
        const carSelect = detailRoot ? detailRoot.querySelector('select.import-ui-inland-car-select[name="carNo"]') : null;
        const carNo = normalizeText(carSelect ? carSelect.value : pick({buttonCarNo: button.dataset.carNo}, ['buttonCarNo'], pick(row, ['carNo', 'vehicleNo', 'CAR_NO', 'D_CAR_NO'], '')));
        const pickupDt = dateOnly(pick({buttonPickupDt: button.dataset.pickupDt}, ['buttonPickupDt'], pick(row, ['pickupDt', 'releaseReqDt', 'dispatchDt', 'dpDt', 'DISPATCH_PICKUP_DT', 'DISPATCH_DT', 'D_DISPATCH_DT'], today()))) || today();

        if (!trcNo) {
            alert('배차 처리할 의뢰번호를 찾을 수 없습니다.');
            return;
        }
        if (!carNo || carNo === '-') {
            alert('차량번호를 선택해주세요.');
            if (carSelect) carSelect.focus();
            return;
        }
        const payload = {
            trcNo: trcNo,
            carNo: carNo,
            pickupDt: pickupDt
        };
        const restore = setButtonBusy(button, '처리중');
        postFlexible(['/transport/import/inland-dispatch/assign.do'], payload)
            .then(function () {
                alert('내륙배차가 처리되었습니다.');
                window.__TACS_IMPORT_INLAND_LOADED = false;
                window.TRANSPORT_IMPORT_INLAND_DISPATCH_LIST = [];
                window.__TACS_IMPORT_INLAND_ROWS = [];
                if (window.importInlandDispatchState) window.importInlandDispatchState.rows = [];
                return ensureTabData('inland', trcNo, root).then(function () {
                    if (root && root.isConnected) renderInlineTab(root, 'inland');
                });
            })
            .catch(function (error) { console.error('[내륙배차 처리 실패]', error); alert(error.message || '내륙배차 처리 중 오류가 발생했습니다.'); })
            .finally(restore);
    }


    function clearImportArrivalRuntimeCache() {
        window.__TACS_IMPORT_ARRIVAL_LOADING = false;
        window.__TACS_IMPORT_ARRIVAL_LOADED = false;
        window.TRANSPORT_IMPORT_ARRIVAL_TRACKING = [];
        window.TRANSPORT_IMPORT_ARRIVAL_LIST = [];
        window.__TACS_IMPORT_ARRIVAL_TRACKING_ROWS = [];
        window.IMPORT_MANIFEST_LIST = [];
        window.SELECTED_IMPORT_MANIFEST = null;
    }

    function postImportRequestAcceptStatus(trcNo) {
        const params = new URLSearchParams();
        params.set('trcNo', trcNo || '');
        params.set('statusCd', 'TRC_DONE');
        const headers = {'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8'};
        const csrf = window.TRANSPORT_CSRF || {};
        if (csrf.header && csrf.token) headers[csrf.header] = csrf.token;
        return fetch((window.contextPath || '') + '/transport/import/request/status.do', {
            method: 'POST',
            headers: headers,
            body: params.toString(),
            cache: 'no-store'
        }).then(function (res) {
            if (!res.ok) throw new Error('HTTP ' + res.status);
            return res.json();
        }).then(function (json) {
            if (json && json.success === false) throw new Error(json.message || '수입 운송의뢰 접수 처리에 실패했습니다.');
            return json || {};
        });
    }

    function updateAcceptedRequestInMemory(trcNo) {
        const markAccepted = function (row) {
            row.status = '접수완료';
            row.statusCd = 'TRC_DONE';
            row.statusNm = '접수완료';
            row.trcStatusCd = 'TRC_DONE';
            row.trcStatusNm = '접수완료';
            row.receiptStatusCd = 'TRC_DONE';
            row.receiptStatus = '접수완료';
            row.receiptStatusNm = '접수완료';
            row.displayStatus = '접수완료';
            row.displayStatusNm = '접수완료';
            row.requestDisplayStatusCd = 'TRC_DONE';
            row.requestDisplayStatusNm = '접수완료';
            row.TRC_STATUS_CD = 'TRC_DONE';
            row.TRC_STATUS_NM = '접수완료';
        };
        [window.TRANSPORT_IMPORT_REQUESTS, window.__TACS_IMPORT_REQUEST_LIST, window.__IMPORT_REQUEST_LIST].forEach(function (list) {
            if (!Array.isArray(list)) return;
            list.forEach(function (row) {
                if (sameRequestNo(currentRequestNo(row), trcNo)) {
                    markAccepted(row);
                }
            });
        });
        const req = currentRequest();
        if (sameRequestNo(currentRequestNo(req), trcNo)) {
            markAccepted(req);
            setCurrentRequest(req);
        }
    }

    function handleRequestAccept(button) {
        const trcNo = button.dataset.requestNo || currentRequestNo(currentRequest());
        if (!trcNo) {
            alert('접수 처리할 의뢰번호가 없습니다.');
            return;
        }
        if (importRequestDetailBusy.has(trcNo)) return;
        importRequestDetailBusy.add(trcNo);

        const detailRoot = button.closest('.import-ui-request-detail');
        const restore = setRequestDetailButtonsBusy(detailRoot, button, '저장/수락중');
        const payload = readRequestDetailPayload(detailRoot);
        const savePromise = payload && payload.trcNo
            ? postJson('/transport/import/request/detail/save.do', requestDetailPersistPayload(payload)).then(function () {
                removeRequestDetailDraft(payload.trcNo);
                applyRequestDetailPayloadToCurrent(payload);
            })
            : Promise.resolve();

        savePromise.then(function () {
            return postImportRequestAcceptStatus(trcNo);
        }).then(function () {
            removeRequestDetailDraft(trcNo);
            updateAcceptedRequestInMemory(trcNo);
            clearImportArrivalRuntimeCache();
            alert('입력값 저장 후 수입 운송의뢰가 접수완료 처리되었습니다. 도착통지서 탭으로 이동합니다.');
            const root = button.closest('.import-inline-tabs-0513');
            if (root) {
                root.dataset.activeWorkId = 'arrival';
                renderInlineTab(root, 'arrival');
                return;
            }
            if (typeof openDetail === 'function') openDetail(GROUP, 'TACS-FW-020');
        }).catch(function (error) {
            console.error('[수입 운송의뢰 수락 실패]', error);
            alert(error.message || '수입 운송의뢰 수락 중 오류가 발생했습니다.');
        }).finally(function () {
            importRequestDetailBusy.delete(trcNo);
            restore();
        });
    }

    function bindGlobalEvents() {

        document.addEventListener('input', function (event) {
            const target = event.target;
            if (!target || !target.matches) return;
            const draftRoot = target.closest('.import-ui-main-request-detail');
            if (draftRoot && target.matches('input[name], textarea[name], select[name], .import-ui-option-display[data-option-name]')) {
                if (target.name) target.dataset.userEdited = 'true';
                saveRequestDetailDraft(draftRoot);
            }
            if (target.matches('[data-goods-field="price"], [data-goods-field="weight"]')) {
                recalcInboundGoodsTotalPrice(target);
                return;
            }
        }, true);

        document.addEventListener('click', function (event) {
            const target = event.target instanceof Element ? event.target : null;
            if (!target) return;

            const optionClose = target.closest('.import-option-close, .import-option-backdrop');
            if (optionClose) {
                event.preventDefault();
                closeImportOptionModal();
                return;
            }

            const optionSearch = target.closest('.import-option-search-btn');
            if (optionSearch) {
                event.preventDefault();
                loadImportOptionRows();
                return;
            }

            const optionRow = target.closest('.import-option-row');
            if (optionRow) {
                event.preventDefault();
                selectImportOption(optionRow);
                return;
            }

            const optionTrigger = target.closest('.import-ui-option-btn, .import-ui-option-display');
            if (optionTrigger && optionTrigger.closest('.import-ui-request-detail')) {
                event.preventDefault();
                openImportOptionModal(optionTrigger);
                return;
            }

            const goodsAddButton = target.closest('.import-ui-goods-add-btn');
            if (goodsAddButton) {
                event.preventDefault();
                const root = goodsAddButton.closest('.import-inline-tabs-0513');
                if (root && root.dataset.activeWorkId === 'release') {
                    lockReleaseGoodsReadonly(root);
                    return;
                }
                handleGoodsAdd(goodsAddButton);
                return;
            }

            const goodsRemoveButton = target.closest('.import-ui-goods-remove-btn');
            if (goodsRemoveButton) {
                event.preventDefault();
                const root = goodsRemoveButton.closest('.import-inline-tabs-0513');
                if (root && root.dataset.activeWorkId === 'release') {
                    lockReleaseGoodsReadonly(root);
                    return;
                }
                handleGoodsRemove(goodsRemoveButton);
                return;
            }

            const manifestButton = target.closest('.import-manifest-link-btn');
            if (manifestButton) {
                event.preventDefault();
                event.stopPropagation();
                if (typeof event.stopImmediatePropagation === 'function') event.stopImmediatePropagation();
                if (typeof openImportManifestCompareFromRequest === 'function') {
                    openImportManifestCompareFromRequest({
                        requestNo: manifestButton.dataset.requestNo,
                        mblNo: manifestButton.dataset.mblNo,
                        hblNo: manifestButton.dataset.hblNo,
                        ownerNm: manifestButton.dataset.ownerNm
                    });
                }
                return;
            }

            const detailButton = target.closest('.import-request-detail-btn');
            if (detailButton) {
                event.preventDefault();
                event.stopPropagation();
                if (typeof event.stopImmediatePropagation === 'function') event.stopImmediatePropagation();
                renderRequestDetail(selectedFromButton(detailButton));
                // 인메모리 목록 행에는 화주 첨부파일(송장/포장명세서/선하증권) 정보가 빠져 있을 수 있다.
                // 상세 진입 직후 서버에서 해당 의뢰 행을 다시 받아 첨부 다운로드가 처음부터 보이게 한다.
                // (저장/접수 후에야 첨부가 뜨던 문제 보정)
                refreshRestoredRequestRoute(currentRequestNo(currentRequest()), 'request');
                return;
            }

            const tab = target.closest('.import-ui-tab, .import-inline-tab');
            if (tab && tab.closest('.import-inline-tabs-0513')) {
                event.preventDefault();
                event.stopPropagation();
                if (typeof event.stopImmediatePropagation === 'function') event.stopImmediatePropagation();
                renderInlineTab(tab.closest('.import-inline-tabs-0513'), tab.dataset.workId || 'request');
                return;
            }

            const docSelect = target.closest('.import-ui-doc-select, [data-do-doc-drop="true"]');
            if (docSelect && docSelect.closest('.import-inline-tabs-0513')) {
                event.preventDefault();
                event.stopPropagation();
                if (typeof event.stopImmediatePropagation === 'function') event.stopImmediatePropagation();
                openFilePicker(docSelect.closest('.import-inline-tabs-0513'));
                return;
            }

            const removeDoc = target.closest('.import-ui-doc-remove');
            if (removeDoc && removeDoc.closest('.import-inline-tabs-0513')) {
                event.preventDefault();
                event.stopPropagation();
                if (typeof event.stopImmediatePropagation === 'function') event.stopImmediatePropagation();
                const root = removeDoc.closest('.import-inline-tabs-0513');
                const index = Number(removeDoc.dataset.index || -1);
                saveSelectedFiles(root, getSelectedFiles(root).filter(function (_, idx) { return idx !== index; }));
                renderSelectedDocRows(root);
                return;
            }

            const requestSubmitButton = target.closest('.import-request-submit-btn');
            if (requestSubmitButton) {
                event.preventDefault();
                if (!requestSubmitButton.disabled) handleRequestAccept(requestSubmitButton);
                return;
            }

            const requestDetailSaveButton = target.closest('.import-request-save-btn');
            if (requestDetailSaveButton) {
                event.preventDefault();
                if (!requestDetailSaveButton.disabled) handleRequestDetailSave(requestDetailSaveButton);
                return;
            }

            const arrivalSendButton = target.closest('.import-ui-arrival-send-btn');
            if (arrivalSendButton) {
                event.preventDefault();
                if (arrivalSendButton.disabled) return;

                // 2026-06-03 긴급수정:
                // '도착통지서 발급' 버튼은 발송 API를 바로 타면 안 된다.
                // 모달 안의 전송/발송완료 버튼만 실제 handleArrivalSend()를 호출한다.
                const confirmedSend = arrivalSendButton.dataset && arrivalSendButton.dataset.confirmSend === 'Y';
                if (!confirmedSend) {
                    if (typeof window.openImportArrivalNoticeIssueModalFromButton === 'function') {
                        window.openImportArrivalNoticeIssueModalFromButton(arrivalSendButton);
                    } else if (typeof window.openImportArrivalNoticeSendModalFromButton === 'function') {
                        window.openImportArrivalNoticeSendModalFromButton(arrivalSendButton);
                    } else {
                        alert('도착통지서 발급 모달 스크립트를 먼저 확인해주세요.');
                    }
                    return;
                }
                delete arrivalSendButton.dataset.confirmSend;
                handleArrivalSend(arrivalSendButton);
                return;
            }

            const inboundSendButton = target.closest('.import-ui-inbound-send-btn');
            if (inboundSendButton) {
                event.preventDefault();
                if (!inboundSendButton.disabled) handleInboundSend(inboundSendButton, false);
                return;
            }

            const inboundSuppButton = target.closest('.import-ui-inbound-supp-btn');
            if (inboundSuppButton) {
                event.preventDefault();
                if (!inboundSuppButton.disabled) handleInboundSend(inboundSuppButton, true);
                return;
            }

            const releaseSendButton = target.closest('.import-ui-release-send-btn');
            if (releaseSendButton) {
                event.preventDefault();
                if (!releaseSendButton.disabled) handleReleaseSend(releaseSendButton, false);
                return;
            }

            const releaseSuppButton = target.closest('.import-ui-release-supp-btn');
            if (releaseSuppButton) {
                event.preventDefault();
                if (!releaseSuppButton.disabled) handleReleaseSend(releaseSuppButton, true);
                return;
            }

            const inlandProcessButton = target.closest('.import-ui-inland-process-btn');
            if (inlandProcessButton) {
                event.preventDefault();
                if (!inlandProcessButton.disabled) handleInlandProcess(inlandProcessButton);
                return;
            }

            const certConnectButton = target.closest('.import-ui-customs-cert-connect-btn');
            if (certConnectButton) {
                event.preventDefault();
                if (!certConnectButton.disabled) handleConnectCustomsCert(certConnectButton);
                return;
            }

            const settleButton = target.closest('.import-ui-do-settle-btn');
            if (settleButton) {
                event.preventDefault();
                const root = settleButton.closest('.import-inline-tabs-0513');
                applyDoPaidReadonlyGuard(root);
                if (!settleButton.disabled) handleSettle(settleButton);
                return;
            }

            const issueButton = target.closest('.import-ui-do-issue-btn');
            if (issueButton) {
                event.preventDefault();
                if (!issueButton.disabled) handleIssue(issueButton);
                return;
            }

            const deliverButton = target.closest('.import-ui-do-deliver-btn');
            if (deliverButton) {
                event.preventDefault();
                if (!deliverButton.disabled) handleDeliver(deliverButton);
                return;
            }

        }, true);

        document.addEventListener('change', function (event) {
            const target = event.target instanceof Element ? event.target : null;
            if (!target) return;
            const draftRoot = target.closest('.import-ui-main-request-detail');
            if (draftRoot && target.matches('input[name], textarea[name], select[name], .import-ui-option-display[data-option-name]')) {
                if (target.name) target.dataset.userEdited = 'true';
                saveRequestDetailDraft(draftRoot);
            }
            if (target.matches('select.import-ui-editable[name="warehouseId"], select.import-ui-editable[name="wzNo"], select.import-ui-editable[name="wmId"]')) {
                syncWarehouseBondedSelects(target);
                const rootForSave = target.closest('.import-ui-main-request-detail');
                if (rootForSave) saveRequestDetailDraft(rootForSave);
                return;
            }
            if (target.matches('select.import-ui-inland-car-select[name="carNo"]')) {
                const root = target.closest('.import-ui-request-detail');
                const option = target.options[target.selectedIndex];
                const setValue = function (name, value) {
                    const input = root ? root.querySelector('[name="' + name + '"]') : null;
                    if (input) input.value = normalizeText(value) || '-';
                };
                setValue('carNm', option ? option.dataset.carNm : '');
                setValue('driverNm', option ? option.dataset.driverNm : '');
                setValue('driverTelno', option ? option.dataset.driverTelno : '');
                return;
            }
            if (!target.matches('input[type="file"][name="docFiles"]')) return;
            const root = target.closest('.import-inline-tabs-0513');
            if (!root) return;
            handlePickedFiles(root, target.files || []);
        }, true);

        window.addEventListener('beforeunload', function () {
            const detailRoot = document.querySelector('.import-ui-main-request-detail');
            if (detailRoot) saveRequestDetailDraft(detailRoot);
        });

        ['dragenter', 'dragover'].forEach(function (type) {
            document.addEventListener(type, function (event) {
                const target = event.target instanceof Element ? event.target : null;
                const drop = target ? target.closest('[data-do-doc-drop="true"]') : null;
                if (!drop || !drop.closest('.import-inline-tabs-0513')) return;
                event.preventDefault();
                drop.classList.add('is-dragover');
            }, true);
        }, true);

        document.addEventListener('dragleave', function (event) {
            const target = event.target instanceof Element ? event.target : null;
            const drop = target ? target.closest('[data-do-doc-drop="true"]') : null;
            if (drop) drop.classList.remove('is-dragover');
        }, true);

        document.addEventListener('drop', function (event) {
            const target = event.target instanceof Element ? event.target : null;
            const drop = target ? target.closest('[data-do-doc-drop="true"]') : null;
            if (!drop || !drop.closest('.import-inline-tabs-0513')) return;
            event.preventDefault();
            event.stopPropagation();
            if (typeof event.stopImmediatePropagation === 'function') event.stopImmediatePropagation();
            drop.classList.remove('is-dragover');
            if (drop.classList.contains('is-locked')) return;
            handlePickedFiles(drop.closest('.import-inline-tabs-0513'), event.dataTransfer ? event.dataTransfer.files : []);
        }, true);
    }


    let __requestListStatusRows = null;
    let __requestListStatusRowsPromise = null;

    function normalizeTextStatus(value) {
        return String(value || '').replace(/\s+/g, '').trim();
    }

    function normalizeReceiptFilter(row) {
        const code = pick(row, ['receiptStatusCd', 'trcStatusCd', 'statusCd', 'TRC_STATUS_CD'], '');
        if (code === 'TRC_WAIT' || code === 'TRC_DONE' || code === 'TRC_REJECT') return code;
        const nm = normalizeTextStatus(pick(row, ['receiptStatusNm', 'trcStatusNm', 'statusNm'], ''));
        if (nm === '접수대기') return 'TRC_WAIT';
        if (nm === '접수완료') return 'TRC_DONE';
        if (nm === '접수반려') return 'TRC_REJECT';
        return code || '';
    }

    function normalizeNoticeFilter(row) {
        const code = pick(row, ['arrivalNoticeStatusCd', 'sendStatusCd', 'noticeStatus'], '');
        if (code === 'TRC_NTC_SENT' || code === 'SENT') return 'TRC_NTC_SENT';
        if (code === 'TRC_NTC_NSENT' || code === 'NSENT') return 'TRC_NTC_NSENT';
        const receipt = normalizeReceiptFilter(row);
        const nm = normalizeTextStatus(pick(row, ['arrivalNoticeStatusNm', 'noticeStatusNm'], ''));
        if (nm === '발송완료' || nm === '발급완료' || nm === '통지완료') return 'TRC_NTC_SENT';
        if (nm === '발송대기' || nm === '미발급') return 'TRC_NTC_NSENT';
        if (receipt === 'TRC_DONE') return 'TRC_NTC_NSENT';
        return '';
    }

    function normalizeInoutFilter(row) {
        const code = pick(row, ['inboundOutboundStatusCd', 'releaseStatusCd', 'warehouseInStatusCd', 'wirStatusCd'], '');
        if (code === 'IN_DONE') return 'IN_DONE';
        if (code === 'WAIT') return 'WAIT';
        if (code === 'REQ_FIX' || code === 'REJECT') return 'REQ_FIX';
        if (code === 'REL_DONE') return 'REL_DONE';
        if (code === 'REL_WAIT') return 'REL_WAIT';
        if (code === 'REL_FIX' || code === 'REL_REJECT') return 'REL_FIX';
        const nm = normalizeTextStatus(pick(row, ['inboundOutboundStatusNm', 'releaseStatusNm', 'warehouseInStatusNm', 'requestDisplayStatusNm'], ''));
        if (nm.indexOf('반출완료') >= 0) return 'REL_DONE';
        if (nm.indexOf('반출대기') >= 0 || nm.indexOf('반출요청') >= 0) return 'REL_WAIT';
        if (nm.indexOf('반출보완') >= 0) return 'REL_FIX';
        if (nm.indexOf('입고완료') >= 0) return 'IN_DONE';
        if (nm.indexOf('입고대기') >= 0) return 'WAIT';
        if (nm.indexOf('입고보완') >= 0) return 'IN_FIX';
        return '';
    }

    function normalizeSettlementFilter(row) {
        const code = pick(row, ['tcsStlStatusCd', 'settlementStatusCd', 'TCS_STL_STATUS_CD'], '');
        if (code === 'TRC_STL_PAID' || code === 'TCS_STL_PAID' || code === 'PAID') return 'TRC_STL_PAID';
        if (code === 'TRC_STL_REQ' || code === 'TCS_STL_REQ' || code === 'REQ') return 'TRC_STL_REQ';
        if (code === 'TRC_STL_UNPAID' || code === 'UNPAID') return 'TRC_STL_UNPAID';
        const nm = normalizeTextStatus(pick(row, ['tcsStlStatusNm', 'settlementStatusNm', 'requestDisplayStatusNm'], ''));
        if (nm.indexOf('정산완료') >= 0) return 'TRC_STL_PAID';
        if (nm.indexOf('정산요청') >= 0) return 'TRC_STL_REQ';
        return 'TRC_STL_UNPAID';
    }

    function normalizeDoFilter(row) {
        const code = pick(row, ['doStatusCd', 'DI_STATUS_CD'], '');
        if (code === 'TRC_DO_READY' || code === 'READY') return 'TRC_DO_READY';
        if (code === 'TRC_DO_ISSUED' || code === 'ISSUED') return 'TRC_DO_ISSUED';
        if (code === 'TRC_DO_REQ' || code === 'DELIVERED') return 'TRC_DO_REQ';
        const nm = normalizeTextStatus(pick(row, ['doStatusNm', 'requestDisplayStatusNm'], ''));
        if (nm.indexOf('D/O발급대기') >= 0) return 'TRC_DO_READY';
        if (nm.indexOf('D/O발급완료') >= 0) return 'TRC_DO_ISSUED';
        if (nm.indexOf('D/O전달완료') >= 0) return 'TRC_DO_REQ';
        return '';
    }

    function requestListRowNo(row) {
        return String(pick(row, ['trcNo', 'requestNo', 'importRequestNo', 'reqNo', 'TRC_NO'], '') || '').trim();
    }

    function getRequestListRowsForStatusFilter() {
        if (Array.isArray(__requestListStatusRows)) return Promise.resolve(__requestListStatusRows);
        const cached = firstRows(window.TRANSPORT_IMPORT_REQUESTS || window.__TACS_IMPORT_REQUEST_LIST || window.__IMPORT_REQUEST_LIST || []);
        if (cached.length) {
            __requestListStatusRows = cached;
            return Promise.resolve(cached);
        }
        if (__requestListStatusRowsPromise) return __requestListStatusRowsPromise;
        __requestListStatusRowsPromise = getJsonFlexible([
            '/transport/import/request/list.do?_=' + Date.now(),
            '/transport/import/list.do?_=' + Date.now()
        ]).then(function (json) {
            const rows = firstRows(json);
            __requestListStatusRows = rows;
            storeRows(['TRANSPORT_IMPORT_REQUESTS', '__TACS_IMPORT_REQUEST_LIST', '__IMPORT_REQUEST_LIST'], rows);
            return rows;
        }).catch(function () {
            __requestListStatusRows = [];
            return [];
        }).finally(function () {
            __requestListStatusRowsPromise = null;
        });
        return __requestListStatusRowsPromise;
    }

    function getRequestListStatusRowMap(rows) {
        const map = Object.create(null);
        (rows || []).forEach(function (row) {
            const no = requestListRowNo(row);
            if (no) map[no] = row;
        });
        return map;
    }

    function getTableHeaderTexts(table) {
        return Array.from(table.querySelectorAll('thead th')).map(function (th) {
            return normalizeTextStatus(th.textContent || '');
        });
    }

    function findTableHeaderIndex(table, keyword) {
        const headers = getTableHeaderTexts(table);
        const key = normalizeTextStatus(keyword);
        return headers.findIndex(function (text) { return text.indexOf(key) >= 0; });
    }

    function findTableHeaderIndexAny(table, keywords) {
        const headers = getTableHeaderTexts(table);
        const keys = (keywords || []).map(function (keyword) { return normalizeTextStatus(keyword); }).filter(Boolean);
        for (let i = 0; i < headers.length; i += 1) {
            for (let j = 0; j < keys.length; j += 1) {
                if (headers[i].indexOf(keys[j]) >= 0) return i;
            }
        }
        return -1;
    }

    function isImportRequestMainListTable(table) {
        if (!table || table.dataset.importRequestStatusEnhancedTable === 'Y') return false;
        const headers = getTableHeaderTexts(table).join('|');
        const statusHeaderExists = headers.indexOf('접수상태') >= 0 || headers.indexOf('진행상태') >= 0;
        return headers.indexOf('의뢰번호') >= 0
            && headers.indexOf('MASTERB/L') >= 0
            && statusHeaderExists
            && headers.indexOf('등록일시') >= 0;
    }

    function requestStatusLabelClass(label, code) {
        const text = normalizeTextStatus(label);
        const cd = String(code || '');
        if (cd.indexOf('REJECT') >= 0 || text.indexOf('반려') >= 0 || text.indexOf('보완') >= 0) return 'import-request-status-badge import-tone-danger';
        if (cd.indexOf('READY') >= 0 || cd.indexOf('WAIT') >= 0 || text.indexOf('대기') >= 0 || text.indexOf('요청') >= 0) return 'import-request-status-badge import-tone-wait';
        if (cd.indexOf('DONE') >= 0 || cd.indexOf('SENT') >= 0 || cd.indexOf('PAID') >= 0 || cd.indexOf('REQ') >= 0 || text.indexOf('완료') >= 0) return 'import-request-status-badge import-tone-done';
        return 'import-request-status-badge import-tone-neutral';
    }

    function setRequestListStatusCell(cell, label, code) {
        if (!cell || !label) return;
        const text = normalizeText(label) || '-';
        const cd = code || '';
        const key = cd + '|' + text;
        cell.dataset.flowStatusCd = cd;
        cell.classList.add('import-request-status-cell');
        // 같은 값이면 DOM을 다시 갈아끼우지 않는다. 리스트가 재조회될 때 상태칩이 흔들리는 현상을 막는다.
        if (cell.dataset.importRequestStatusKey === key && cell.querySelector('.import-request-status-badge')) return;
        cell.dataset.importRequestStatusKey = key;
        // 예전 6단계 진행상태(접수/통지/입고/D/O/반출/배차)를 남겨두지 말고 상태명 1개만 렌더링한다.
        cell.innerHTML = '<span class="' + requestStatusLabelClass(text, cd) + '" title="' + esc(text) + '">' + esc(text) + '</span>';
    }

    function stabilizeRequestListStatusColumn(table, statusIdx) {
        if (!table || statusIdx < 0) return;
        const head = table.querySelector('thead tr');
        if (head && head.children[statusIdx]) head.children[statusIdx].classList.add('import-request-status-col');
        Array.from(table.querySelectorAll('tbody tr')).forEach(function (tr) {
            if (tr.children[statusIdx]) tr.children[statusIdx].classList.add('import-request-status-cell');
        });
    }

    function refreshRequestListStatusCells(table, rowMap) {
        const statusIdx = findTableHeaderIndexAny(table, ['접수상태', '진행상태']);
        if (statusIdx < 0) return;
        stabilizeRequestListStatusColumn(table, statusIdx);
        Array.from(table.querySelectorAll('tbody tr')).forEach(function (tr) {
            const no = String((tr.children[0] && tr.children[0].textContent) || '').trim();
            const row = rowMap[no];
            if (!row) return;
            const label = pick(row, ['requestDisplayStatusNm', 'REQUEST_DISPLAY_STATUS_NM'], '');
            const code = pick(row, ['requestDisplayStatusCd', 'REQUEST_DISPLAY_STATUS_CD'], '');
            setRequestListStatusCell(tr.children[statusIdx], label, code);
            tr.dataset.receiptStatus = normalizeReceiptFilter(row);
            tr.dataset.noticeStatus = normalizeNoticeFilter(row);
            tr.dataset.inoutStatus = normalizeInoutFilter(row);
            tr.dataset.settlementStatus = normalizeSettlementFilter(row);
            tr.dataset.doStatus = normalizeDoFilter(row);
        });
    }

    function requestListFallbackMatches(tr, type, wanted) {
        const text = normalizeTextStatus(tr.textContent || '');
        if (!wanted) return true;
        if (type === 'receipt') {
            if (wanted === 'TRC_WAIT') return text.indexOf('접수대기') >= 0;
            if (wanted === 'TRC_DONE') return text.indexOf('접수완료') >= 0 || text.indexOf('발송완료') >= 0 || text.indexOf('발급완료') >= 0 || text.indexOf('입고') >= 0 || text.indexOf('정산') >= 0 || text.indexOf('D/O') >= 0 || text.indexOf('반출') >= 0 || text.indexOf('배차') >= 0;
            if (wanted === 'TRC_REJECT') return text.indexOf('접수반려') >= 0;
        }
        if (type === 'notice') {
            if (wanted === 'TRC_NTC_SENT') return text.indexOf('발송완료') >= 0 || text.indexOf('발급완료') >= 0;
            if (wanted === 'TRC_NTC_NSENT') return text.indexOf('발송대기') >= 0 || text.indexOf('접수완료') >= 0;
        }
        if (type === 'inout') {
            if (wanted === 'WAIT') return text.indexOf('입고대기') >= 0;
            if (wanted === 'IN_DONE') return text.indexOf('입고완료') >= 0;
            if (wanted === 'IN_FIX') return text.indexOf('입고보완') >= 0;
            if (wanted === 'REL_WAIT') return text.indexOf('반출대기') >= 0;
            if (wanted === 'REL_DONE') return text.indexOf('반출완료') >= 0;
            if (wanted === 'REL_FIX') return text.indexOf('반출보완') >= 0;
        }
        if (type === 'settlement') {
            if (wanted === 'TRC_STL_REQ') return text.indexOf('정산요청') >= 0;
            if (wanted === 'TRC_STL_PAID') return text.indexOf('정산완료') >= 0;
            if (wanted === 'TRC_STL_UNPAID') return text.indexOf('정산') < 0;
        }
        if (type === 'do') {
            if (wanted === 'TRC_DO_READY') return text.indexOf('D/O발급대기') >= 0;
            if (wanted === 'TRC_DO_ISSUED') return text.indexOf('D/O발급완료') >= 0;
            if (wanted === 'TRC_DO_REQ') return text.indexOf('D/O전달완료') >= 0;
        }
        return true;
    }

    function applyRequestListStatusFilters(filterBox) {
        const table = filterBox && filterBox.__targetTable;
        if (!table) return;
        const valueOf = function (name) {
            const el = filterBox.querySelector('[data-status-filter="' + name + '"]');
            return el ? el.value : '';
        };
        const values = {
            // 접수상태/입고·반출상태/도착통지서 필터는 위 검색영역과 중복이라 제거했다.
            // 값이 없으면 해당 조건은 통과 처리된다.
            receipt: valueOf('receipt'),
            notice: valueOf('notice'),
            inout: valueOf('inout'),
            settlement: valueOf('settlement'),
            do: valueOf('do')
        };
        Array.from(table.querySelectorAll('tbody tr')).forEach(function (tr) {
            const checks = [
                ['receipt', values.receipt, tr.dataset.receiptStatus],
                ['notice', values.notice, tr.dataset.noticeStatus],
                ['inout', values.inout, tr.dataset.inoutStatus],
                ['settlement', values.settlement, tr.dataset.settlementStatus],
                ['do', values.do, tr.dataset.doStatus]
            ];
            const pass = checks.every(function (item) {
                const type = item[0];
                const wanted = item[1];
                const actual = item[2];
                if (!wanted) return true;
                if (actual) return actual === wanted;
                return requestListFallbackMatches(tr, type, wanted);
            });
            tr.style.display = pass ? '' : 'none';
        });
    }

    function createRequestListStatusFilterBox(table) {
        const box = document.createElement('div');
        box.dataset.importRequestAdvancedStatusFilter = 'Y';
        box.className = 'grid grid-cols-1 md:grid-cols-2 gap-2 mb-3';
        // 위 기본 검색영역에 이미 있는 접수상태/입고·반출상태/도착통지서 셀렉트박스는 여기서 다시 만들지 않는다.
        // 여기에는 운송의뢰 목록에서 추가로 필요한 정산/D/O 필터만 남긴다.
        box.innerHTML = ''
            + '<label class="block text-xs font-semibold text-slate-700">수입비용정산상태'
            + '  <select data-status-filter="settlement" class="mt-1 w-full border border-slate-300 rounded px-2 py-2 text-sm">'
            + '    <option value="">전체</option><option value="TRC_STL_UNPAID">미정산</option><option value="TRC_STL_REQ">정산요청</option><option value="TRC_STL_PAID">정산완료</option>'
            + '  </select>'
            + '</label>'
            + '<label class="block text-xs font-semibold text-slate-700">D/O발급상태'
            + '  <select data-status-filter="do" class="mt-1 w-full border border-slate-300 rounded px-2 py-2 text-sm">'
            + '    <option value="">전체</option><option value="TRC_DO_READY">D/O발급대기</option><option value="TRC_DO_ISSUED">D/O발급완료</option><option value="TRC_DO_REQ">D/O전달완료</option>'
            + '  </select>'
            + '</label>';
        box.__targetTable = table;
        box.addEventListener('change', function () { applyRequestListStatusFilters(box); });
        return box;
    }

    function enhanceImportRequestListTable(table) {
        if (!isImportRequestMainListTable(table)) return;
        table.dataset.importRequestStatusEnhancedTable = 'Y';
        const wrapper = table.closest('.overflow-x-auto') || table.parentElement;
        const parent = wrapper && wrapper.parentElement;
        if (parent && !parent.querySelector('[data-import-request-advanced-status-filter="Y"]')) {
            const box = createRequestListStatusFilterBox(table);
            parent.insertBefore(box, wrapper);
            getRequestListRowsForStatusFilter().then(function (rows) {
                refreshRequestListStatusCells(table, getRequestListStatusRowMap(rows));
                applyRequestListStatusFilters(box);
            });
        } else {
            getRequestListRowsForStatusFilter().then(function (rows) {
                refreshRequestListStatusCells(table, getRequestListStatusRowMap(rows));
            });
        }
    }

    function installRequestListStatusSearchEnhancer() {
        const scan = function () {
            document.querySelectorAll('table').forEach(enhanceImportRequestListTable);
        };
        scan();
        const observer = new MutationObserver(function () { scan(); });
        observer.observe(document.body, { childList: true, subtree: true });
    }

    function restoreStoredImportRoute(previousOpenDetail, forcedRoute, force) {
        const route = forcedRoute || activeImportRouteForRestore();
        if (!route) return;
        if (route.type === 'request-detail') {
            const no = route.trcNo;
            if (!no) return;
            const row = routedRequest(route) || requestFromImportRoute(route) || { trcNo: no, requestNo: no, irNo: no, TRC_NO: no, __routeStub: true };
            setCurrentRequest(row);
            const workId = validImportWorkId(route.workId || 'request');
            const root = document.querySelector('.import-inline-tabs-0513');
            const sameDetail = root && root.isConnected
                && rowMatchesRequestNo({trcNo: root.dataset.requestNo || root.dataset.trcNo || ''}, no)
                && String(root.dataset.activeWorkId || 'request') === String(workId);
            if (sameDetail && !force) {
                setTabDisabledState(root, row);
                return;
            }
            renderRequestDetail(row, workId);
            refreshRestoredRequestRoute(no, workId);
            return;
        }
        if (route.type === 'menu' && route.itemId && route.itemId !== REQUEST_DETAIL_ID && typeof previousOpenDetail === 'function') {
            cleanupImportInlineDetail();
            previousOpenDetail(GROUP, route.itemId);
        }
    }

    function scheduleStoredImportRouteRestore(previousOpenDetail) {
        const route = activeImportRouteForRestore();
        if (!route) return;
        if (isImportDetailRoute(route)) {
            [0, 80, 220, 520, 1000, 1800, 3200].forEach(function (delay, index) {
                setTimeout(function () { restoreStoredImportRoute(previousOpenDetail, route, index === 0); }, delay);
            });
            setTimeout(function () { importBootRestoreDeadline = 0; }, IMPORT_ROUTE_BOOT_RESTORE_MS + 200);
            return;
        }
        setTimeout(function () { restoreStoredImportRoute(previousOpenDetail, route); }, 0);
    }

    function installOpenDetailRouter() {
        const previousOpenDetail = window.openDetail;
        bootImportDetailRoute();
        window.openDetail = function (groupKey, itemId) {
            if (groupKey === GROUP && itemId !== REQUEST_DETAIL_ID && isRecentUserImportNav(groupKey, itemId)) {
                clearImportBootRestore();
            }
            if (shouldSuppressBootMenuOpen(groupKey, itemId)) {
                scheduleStoredImportRouteRestore(previousOpenDetail);
                return false;
            }
            if (groupKey === GROUP && itemId === REQUEST_DETAIL_ID) {
                const route = activeImportRouteForRestore();
                const detailRoute = isImportDetailRoute(route) ? route : null;
                const row = detailRoute ? routedRequest(detailRoute) : currentRequest();
                const workId = detailRoute ? validImportWorkId(detailRoute.workId || 'request') : importRouteWorkId(row);
                rememberImportRoute({
                    type: 'request-detail',
                    trcNo: currentRequestNo(row),
                    workId: workId
                });
                renderRequestDetail(row, workId);
                return false;
            }

            // 사이드바의 독립 리스트 화면으로 이동할 때는 상세 탭 DOM/예약 렌더를 먼저 끊는다.
            // 그래야 적하목록/D/O/입고/반출/내륙 리스트 위로 이전 상세 탭 화면이 다시 튀어나오지 않는다.
            if (groupKey === GROUP) {
                rememberImportRoute({ type: 'menu', itemId: itemId });
                cleanupImportInlineDetail();
            }

            if (typeof previousOpenDetail === 'function') return previousOpenDetail.apply(this, arguments);
            return undefined;
        };
        try { openDetail = window.openDetail; } catch (e) {}
        scheduleStoredImportRouteRestore(previousOpenDetail);
    }


    window.__TACS_IMPORT_GET_RESTORE_ROUTE = function () {
        return activeImportRouteForRestore();
    };
    window.__TACS_IMPORT_BOOT_DETAIL_RESTORE_ACTIVE = function () {
        return isBootDetailRestoreActive();
    };
    window.__TACS_IMPORT_CLEAR_BOOT_DETAIL_RESTORE = clearImportBootRestore;
    window.__TACS_IMPORT_RESTORE_ROUTE = function (route, force) {
        restoreStoredImportRoute(null, route || activeImportRouteForRestore(), force !== false);
    };
    window.renderImportRequestDetailPage = function (forcedRoute) {
        const route = forcedRoute || activeImportRouteForRestore();
        if (isImportDetailRoute(route)) {
            restoreStoredImportRoute(null, route, true);
            return;
        }
        renderRequestDetail(routedRequest(route));
    };
    window.refreshImportInlineDoPanel = function () {
        const root = document.querySelector('.import-inline-tabs-0513');
        if (root) refreshDoList(root, root.dataset.activeWorkId || 'do');
    };
    window.refreshImportArrivalNoticeSentState = refreshArrivalNoticeSentState;
    window.markImportArrivalNoticeSent = refreshArrivalNoticeSentState;
    window.addEventListener('tacs:import-arrival-notice-sent', function (event) {
        refreshArrivalNoticeSentState(event && event.detail ? event.detail : {});
    });
    if (typeof window.buildImportInlandTransportPanel !== 'function') {
        window.buildImportInlandTransportPanel = function (row) {
            const req = row || currentRequest();
            if (req && currentRequestNo(req)) setCurrentRequest(req);
            return renderSimpleWorkPanel('inland', req);
        };
    }

    ensureStyle();
    bindGlobalEvents();
    installOpenDetailRouter();
    installRequestActionCellObserver();
    installRequestListStatusSearchEnhancer();
})();
