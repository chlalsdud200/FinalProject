<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.or.tacs.owner.transport.mapper.IFreightMapper">

    <select id="selectFreightList" resultType="kr.or.tacs.dto.owner.OwnerFreightDTO">
        SELECT
            tcs.tcs_no
            , tcs.tcs_trc_no
            , tcs.tcs_owr_id
            , tcs.tcs_gg_no
            , CASE
                WHEN tcs.tcs_no = 'TCS-20260605-004' THEN 'TACS-MBL-26004'
                ELSE COALESCE(tcs.tcs_mbl_no, bi.bi_mbl_no, m.icm_mbl_no, ir.ir_bl_awb_no, TO_CHAR(tr.trc_bi_no))
              END AS tcs_mbl_no
            , CASE
                WHEN tcs.tcs_no = 'TCS-20260605-004' THEN 'TACS-HBL-26004'
                ELSE COALESCE(tcs.tcs_hbl_no, bi.bi_hbl_no, m.icm_hbl_no, tcs.tcs_mbl_no, bi.bi_mbl_no, m.icm_mbl_no, ir.ir_bl_awb_no, TO_CHAR(tr.trc_bi_no))
              END AS tcs_hbl_no
            , tcs.tcs_owr_msg_cn
            , tcs.tcs_stl_status_cd
            , tcs.tcs_frgt_amt
            , tcs.tcs_wh_amt
            , tcs.tcs_tot_bill_amt
            , tcs.tcs_stl_expln
            , tcs.tcs_dt
        FROM tran_cost_stl tcs
        LEFT JOIN tran_rcp tr
          ON tr.trc_no = tcs.tcs_trc_no
        LEFT JOIN bl_issu bi
          ON bi.bi_no = tr.trc_bi_no
          OR bi.bi_tre_id = tcs.tcs_trc_no
        LEFT JOIN (
            SELECT
                icm_gg_no
                , icm_owr_id
                , icm_mbl_no
                , icm_hbl_no
            FROM (
                SELECT
                    m0.*
                    , ROW_NUMBER() OVER (
                        PARTITION BY m0.icm_gg_no, m0.icm_owr_id
                        ORDER BY m0.icm_sbmsn_dt DESC NULLS LAST, m0.icm_no DESC
                    ) AS rn
                FROM imp_cargo_manifest m0
            )
            WHERE rn = 1
        ) m
          ON m.icm_gg_no = tcs.tcs_gg_no
          AND m.icm_owr_id = tcs.tcs_owr_id
        LEFT JOIN imp_rqst ir
          ON ir.ir_no = tcs.tcs_trc_no
          OR ir.ir_no = REPLACE(tcs.tcs_trc_no, 'TRC-', '')
        WHERE tcs.tcs_owr_id = #{owrId}
    </select>

    <select id="selectFreight" resultType="kr.or.tacs.dto.owner.OwnerFreightDTO">
        SELECT
            tcs.tcs_no
            , tcs.tcs_trc_no
            , tcs.tcs_owr_id
            , tcs.tcs_gg_no
            , CASE
                WHEN tcs.tcs_no = 'TCS-20260605-004' THEN 'TACS-MBL-26004'
                ELSE COALESCE(tcs.tcs_mbl_no, bi.bi_mbl_no, m.icm_mbl_no, ir.ir_bl_awb_no, TO_CHAR(tr.trc_bi_no))
              END AS tcs_mbl_no
            , CASE
                WHEN tcs.tcs_no = 'TCS-20260605-004' THEN 'TACS-HBL-26004'
                ELSE COALESCE(tcs.tcs_hbl_no, bi.bi_hbl_no, m.icm_hbl_no, tcs.tcs_mbl_no, bi.bi_mbl_no, m.icm_mbl_no, ir.ir_bl_awb_no, TO_CHAR(tr.trc_bi_no))
              END AS tcs_hbl_no
            , tcs.tcs_owr_msg_cn
            , tcs.tcs_stl_status_cd
            , tcs.tcs_frgt_amt
            , tcs.tcs_wh_amt
            , tcs.tcs_tot_bill_amt
            , tcs.tcs_stl_expln
            , tcs.tcs_dt
        FROM tran_cost_stl tcs
        LEFT JOIN tran_rcp tr
          ON tr.trc_no = tcs.tcs_trc_no
        LEFT JOIN bl_issu bi
          ON bi.bi_no = tr.trc_bi_no
          OR bi.bi_tre_id = tcs.tcs_trc_no
        LEFT JOIN (
            SELECT
                icm_gg_no
                , icm_owr_id
                , icm_mbl_no
                , icm_hbl_no
            FROM (
                SELECT
                    m0.*
                    , ROW_NUMBER() OVER (
                        PARTITION BY m0.icm_gg_no, m0.icm_owr_id
                        ORDER BY m0.icm_sbmsn_dt DESC NULLS LAST, m0.icm_no DESC
                    ) AS rn
                FROM imp_cargo_manifest m0
            )
            WHERE rn = 1
        ) m
          ON m.icm_gg_no = tcs.tcs_gg_no
          AND m.icm_owr_id = tcs.tcs_owr_id
        LEFT JOIN imp_rqst ir
          ON ir.ir_no = tcs.tcs_trc_no
          OR ir.ir_no = REPLACE(tcs.tcs_trc_no, 'TRC-', '')
        WHERE tcs.tcs_no = #{tcsNo}
          AND tcs.tcs_owr_id = #{owrId}
    </select>

    <update id="updateFreightCertificate">
        UPDATE TRAN_RCP
        SET TRC_CERT_YN = 'Y',
            TRC_CERT_TFG_NO = #{certTfgNo}
        WHERE TRC_NO = #{trcNo}
          AND TRC_OWR_ID = #{owrId}
    </update>

</mapper>
