package kr.or.tacs.fieldofficer.mypage.mapper;

import java.util.List;

import org.apache.ibatis.annotations.Mapper;
import org.apache.ibatis.annotations.Param;

import kr.or.tacs.vo.OfficerVO;

@Mapper
public interface IMypageMapper {

	//마이페이지 공무원 정보 조회
	public OfficerVO selectOfficer(@Param("officerId") String officerId);
	
	// 마이페이지 개인정보 수정
	public int updateOfficer(OfficerVO officerVO);
	
	// 기존 알림 설정 삭제
    public int deleteAlarmSettingByOfficerId(@Param("officerId") String officerId);

    // 알림유형 코드로 알림 설정 등록
    public int insertAlarmSettingByTyCd(
            @Param("officerId") String officerId,
            @Param("alarmRuleTyCd") String alarmRuleTyCd,
            @Param("webAlarmYn") String webAlarmYn
    );

    // 저장된 알림유형코드 목록 조회
    public List<String> selectAlarmRuleTyCdList(@Param("officerId") String officerId);

    // 시스템 알림 사용 여부 조회
    public String selectWebAlarmYn(@Param("officerId") String officerId);
}
