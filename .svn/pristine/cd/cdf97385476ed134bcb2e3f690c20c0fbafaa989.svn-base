      '#detail-body table td,#detail-body .tbl td,#detail-body .import-ui-goods-table td,#detail-body .import-ui-doc-table td{height:44px!important;padding:10px 12px!important;background:#fff!important;color:#0f172a!important;font-weight:700!important;text-align:center!important;}',
      '#detail-body table td:first-child,#detail-body .tbl td:first-child{font-weight:900!important;}',
      '#detail-body .overflow-x-auto,#detail-body .import-ui-doc-table-wrap,#detail-body .import-ui-goods-table-wrap{border:1px solid #cbd5e1!important;border-radius:0!important;background:#fff!important;}',
      '#detail-body .section-card-action-footer,#detail-body .import-ui-actions{display:flex!important;justify-content:flex-end!important;align-items:center!important;gap:8px!important;min-height:56px!important;padding:10px 16px!important;border-top:1px solid #cbd5e1!important;background:#fff!important;}',
      '#detail-body .import-ui-tab{height:48px!important;border-radius:0!important;border-right:1px solid #cbd5e1!important;background:#fff!important;color:#334155!important;font-size:12px!important;font-weight:900!important;}',
      '#detail-body .import-ui-tab:hover{background:#f8fafc!important;color:#0f172a!important;}',
      '#detail-body .import-ui-tab.is-active{background:#e8eef7!important;color:#0f172a!important;box-shadow:none!important;}',
      '#detail-body .import-inline-tabs-0513,#detail-body .import-ui-tabs{width:100%!important;min-width:0!important;background:#fff!important;}',
      '#detail-body .import-ui-tab-bar{display:grid!important;grid-template-columns:repeat(6,minmax(0,1fr))!important;border-bottom:1px solid #cbd5e1!important;background:#fff!important;}',
      '#detail-body .import-ui-panel{display:none!important;min-height:0!important;height:0!important;padding:0!important;background:#fff!important;border:0!important;}',
