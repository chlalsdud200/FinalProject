<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<c:set var="mp" value="${requestScope.menuPermissions}" />
<c:if test="${menuPermissionEnabled eq true}">
<style>
<c:if test="${mp['/owner/dashboard/list.do'].readYn ne 'Y'}">.aside a[href$="/owner/dashboard/list.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/export/list.do'].readYn ne 'Y'}">.aside a[href$="/owner/export/list.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/import/list.do'].readYn ne 'Y'}">.aside a[href$="/owner/import/list.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/transport/forwarder/list.do'].readYn ne 'Y'}">.aside a[href$="/owner/transport/forwarder/list.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/transport/freight/list.do'].readYn ne 'Y'}">.aside a[href$="/owner/transport/freight/list.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/transport/forwarder/list.do'].readYn ne 'Y' and mp['/owner/transport/freight/list.do'].readYn ne 'Y'}">#ng-transport{display:none!important;}</c:if>
<c:if test="${mp['/owner/arrival-notice/list.do'].readYn ne 'Y'}">.aside a[href$="/owner/arrival-notice/list.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/tariff/duty/list.do'].readYn ne 'Y'}">#ng-refund{display:none!important;}</c:if>
<c:if test="${mp['/orders/customs/form.do'].readYn ne 'Y'}">.aside a[href$="/orders/customs/form.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/certs/list.do'].readYn ne 'Y'}">.aside a[href$="/owner/certs/list.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/docs/list.do'].readYn ne 'Y'}">.aside a[href$="/owner/docs/list.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/docs/trash.do'].readYn ne 'Y'}">.aside a[href$="/owner/docs/trash.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/docs/list.do'].readYn ne 'Y' and mp['/owner/docs/trash.do'].readYn ne 'Y'}">#ng-docs{display:none!important;}</c:if>
<c:if test="${mp['/owner/community/notice/list.do'].readYn ne 'Y'}">.aside a[href$="/owner/community/notice/list.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/community/archive/list.do'].readYn ne 'Y'}">.aside a[href$="/owner/community/archive/list.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/community/support/list.do'].readYn ne 'Y'}">.aside a[href$="/owner/community/support/list.do"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/community/notice/list.do'].readYn ne 'Y' and mp['/owner/community/archive/list.do'].readYn ne 'Y' and mp['/owner/community/support/list.do'].readYn ne 'Y'}">#ng-community{display:none!important;}</c:if>
<c:if test="${mp['/owner/mypage.do?tab=profile'].readYn ne 'Y'}">.aside a[href*="/owner/mypage.do?tab=profile"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/mypage.do?tab=alarm'].readYn ne 'Y'}">.aside a[href*="/owner/mypage.do?tab=alarm"]{display:none!important;}</c:if>
<c:if test="${mp['/owner/mypage.do?tab=profile'].readYn ne 'Y' and mp['/owner/mypage.do?tab=alarm'].readYn ne 'Y'}">#ng-mypage{display:none!important;}</c:if>
<c:if test="${mp['/owner/export/form.do'].readYn ne 'Y'}">.aside a[href$="/owner/export/form.do"]{display:none!important;}</c:if>
</style>
</c:if>

<aside class="aside">
    <div class="logo-area">
        <div class="logo-row">
            <div class="logo-icon"><span class="material-symbols-outlined">inventory_2</span></div>
            <div class="logo-text">
                <h1>TACS</h1>
                <p>Shipper Portal</p>
            </div>
        </div>
    </div>

    <nav>
        <div class="nav-section-label">메인</div>
        <a class="nav-link ${activeMenu eq 'dashboard' ? 'active' : ''}" data-p="dash"
           href="${pageContext.request.contextPath}/owner/dashboard/list.do">
            <span class="material-symbols-outlined">dashboard</span>대시보드
        </a>

        <div class="nav-section-label">통관 · 운송</div>
        <a class="nav-link ${activeMenu eq 'export' ? 'active' : ''}" data-p="export"
           href="${pageContext.request.contextPath}/owner/export/list.do">
            <span class="material-symbols-outlined">upload_file</span>수출통관 의뢰
        </a>
        <a class="nav-link ${activeMenu eq 'import' ? 'active' : ''}" data-p="import"
           href="${pageContext.request.contextPath}/owner/import/list.do">
            <span class="material-symbols-outlined">download</span>수입통관 의뢰
        </a>

        <div class="nav-group" id="ng-transport">
            <button type="button" class="nav-group-btn ${activeGroup eq 'transport' ? 'active' : ''}" id="ngb-transport"
                    onclick="toggleNav('transport')">
                <span class="material-symbols-outlined">local_shipping</span>운송
                <span class="nav-arrow" id="na-transport"
                      style="${activeGroup eq 'transport' ? 'transform:rotate(90deg);' : ''}">▸</span>
            </button>
            <div class="nav-sub ${activeGroup eq 'transport' ? 'open' : ''}" id="ns-transport">
                <a class="nav-sub-link ${activeSub eq 'forwarder' ? 'active' : ''}"
                   href="${pageContext.request.contextPath}/owner/transport/forwarder/list.do">운송업체계약 관리</a>

                <a class="nav-sub-link ${activeSub eq 'freight' ? 'active' : ''}"
                   href="${pageContext.request.contextPath}/owner/transport/freight/list.do">운임 정산</a>
            </div>
        </div>

        <a class="nav-link ${activeMenu eq 'arrivalNotice' ? 'active' : ''}" data-p="arrival-notice"
           href="${pageContext.request.contextPath}/owner/arrival-notice/list.do">
            <span class="material-symbols-outlined">mark_email_unread</span>도착통지서
        </a>

        <div class="nav-group" id="ng-refund">
            <button type="button" class="nav-group-btn ${activeGroup eq 'refund' ? 'active' : ''}" id="ngb-refund"
                    onclick="toggleNav('refund')">
                <span class="material-symbols-outlined">payments</span>관세
                <span class="nav-arrow" id="na-refund"
                      style="${activeGroup eq 'refund' ? 'transform:rotate(90deg);' : ''}">▸</span>
            </button>
            <div class="nav-sub ${activeGroup eq 'refund' ? 'open' : ''}" id="ns-refund">
                <a class="nav-sub-link ${activeSub eq 'duty' ? 'active' : ''}"
                   href="${pageContext.request.contextPath}/owner/tariff/duty/list.do">관세 납부</a>
            </div>
        </div>

        <div class="nav-section-label">현황 · 관리</div>
        <a class="nav-link ${activeMenu eq 'certs' ? 'active' : ''}" data-p="certs"
           href="${pageContext.request.contextPath}/owner/certs/list.do">
            <span class="material-symbols-outlined">description</span>수출입신고필증 조회
        </a>
        <div class="nav-group" id="ng-docs">
            <button type="button" class="nav-group-btn ${activeMenu eq 'docs' ? 'active' : ''}" id="ngb-docs"
                    onclick="toggleNav('docs')">
                <span class="material-symbols-outlined">folder</span>문서함
                <span class="nav-arrow" id="na-docs"
                      style="${activeMenu eq 'docs' ? 'transform:rotate(90deg);' : ''}">▸</span>
            </button>
            <div class="nav-sub ${activeMenu eq 'docs' ? 'open' : ''}" id="ns-docs">
                <a class="nav-sub-link ${(activeMenu eq 'docs' and empty activeSub) or activeSub eq 'myDocs' ? 'active' : ''}"
                   href="${pageContext.request.contextPath}/owner/docs/list.do">내문서</a>
                <a class="nav-sub-link ${activeSub eq 'trash' ? 'active' : ''}"
                   href="${pageContext.request.contextPath}/owner/docs/trash.do">휴지통</a>
            </div>
        </div>

        <div class="nav-section-label">커뮤니티 · 계정</div>
        <div class="nav-group" id="ng-community">
            <button type="button" class="nav-group-btn ${activeGroup eq 'community' ? 'active' : ''}" id="ngb-community"
                    onclick="toggleNav('community')">
                <span class="material-symbols-outlined">forum</span>커뮤니티
                <span class="nav-arrow" id="na-community"
                      style="${activeGroup eq 'community' ? 'transform:rotate(90deg);' : ''}">▸</span>
            </button>
            <div class="nav-sub ${activeGroup eq 'community' ? 'open' : ''}" id="ns-community">
                <a class="nav-sub-link ${activeSub eq 'notice' ? 'active' : ''}" data-community-tab="notice"
                   href="${pageContext.request.contextPath}/owner/community/notice/list.do"
                   onclick="event.preventDefault(); goSub('community', 'notice');">공지사항</a>
                <a class="nav-sub-link ${activeSub eq 'archive' ? 'active' : ''}" data-community-tab="archive"
                   href="${pageContext.request.contextPath}/owner/community/archive/list.do"
                   onclick="event.preventDefault(); goSub('community', 'archive');">자료실</a>
                <a class="nav-sub-link ${activeSub eq 'support' ? 'active' : ''}" data-community-tab="support"
                   href="${pageContext.request.contextPath}/owner/community/support/list.do"
                   onclick="event.preventDefault(); goSub('community', 'support');">고객센터</a>
            </div>
        </div>

        <div class="nav-group" id="ng-mypage">
            <button type="button" class="nav-group-btn ${activeGroup eq 'mypage' ? 'active' : ''}" id="ngb-mypage"
                    onclick="toggleNav('mypage')">
                <span class="material-symbols-outlined">manage_accounts</span>마이페이지
                <span class="nav-arrow" id="na-mypage"
                      style="${activeGroup eq 'mypage' ? 'transform:rotate(90deg);' : ''}">▸</span>
            </button>
            <div class="nav-sub ${activeGroup eq 'mypage' ? 'open' : ''}" id="ns-mypage">
                <a class="nav-sub-link ${activeSub eq 'profile' ? 'active' : ''}"
                   href="${pageContext.request.contextPath}/owner/mypage.do?tab=profile">회원정보 수정</a>
                <a class="nav-sub-link ${activeSub eq 'alarm' ? 'active' : ''}"
                   href="${pageContext.request.contextPath}/owner/mypage.do?tab=alarm">알림 수신 설정</a>
            </div>
        </div>

        <div class="nav-bottom">
            <a class="nav-cta" href="${pageContext.request.contextPath}/owner/export/form.do">
                <span class="material-symbols-outlined">add</span>신규 의뢰 등록
            </a>
            <form action="${pageContext.request.contextPath}/logout" method="post" id="logoutForm"
                  style="display:none;">
                <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}"/>
            </form>
            <a class="nav-link" href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit();">
                <span class="material-symbols-outlined">logout</span>로그아웃
            </a>
        </div>
    </nav>
</aside>
