package kr.or.tacs.officer.basicscreen.service;

import java.nio.charset.StandardCharsets;
import java.util.List;

import org.apache.pdfbox.Loader;
import org.apache.pdfbox.pdmodel.PDDocument;
import org.apache.pdfbox.text.PDFTextStripper;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import kr.or.tacs.common.file.service.GoogleDriveService;
import kr.or.tacs.common.file.service.IFileService;
import kr.or.tacs.dto.FileInfoDTO;
import kr.or.tacs.dto.officer.AIRiskDTO;
import kr.or.tacs.dto.officer.BasicScreenDetailDTO;
import kr.or.tacs.officer.basicscreen.mapper.AIRiskMapper;
import kr.or.tacs.officer.basicscreen.mapper.IScreenDetailMapper;
import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class AiRiskServiceImpl implements IAiRiskService {

    @Autowired
    private AIRiskMapper aiMapper;

    @Autowired
    private IScreenDetailMapper detailMapper;

    @Autowired
    private IFileService fileService;

    @Autowired
    private GoogleDriveService googleDriveService;

    @Override
    public AIRiskDTO getAiRiskResult(String bizTypeCd, String refNo) {
        AIRiskDTO dto = new AIRiskDTO();
        dto.setArrBizTypeCd(bizTypeCd);
        dto.setArrRefNo(refNo);
        return aiMapper.selectAiRiskResult(dto);
    }

    @Override
    public int saveAiRiskResult(AIRiskDTO dto) {
        return aiMapper.insertAiRiskResult(dto);
    }

    @Override
    public void aiResultSave(String bizTypeCd, String refNo) {

        AIRiskDTO search = new AIRiskDTO();
        search.setArrBizTypeCd(bizTypeCd);
        search.setArrRefNo(refNo);

        AIRiskDTO exist = aiMapper.selectAiRiskResult(search);
        if (exist != null) {
            return;
        }

        BasicScreenDetailDTO detail = null;

        if ("IMPORT".equals(bizTypeCd)) {
            detail = detailMapper.selectImportDetail(refNo);
        } else if ("EXPORT".equals(bizTypeCd)) {
            detail = detailMapper.selectExportDetail(refNo);
        }

        int score = 0;
        StringBuilder detailCn = new StringBuilder();
        String fileText = "";

        try {
            if (detail != null && detail.getTfgNo() != null) {
                List<FileInfoDTO> files = fileService.getFileList(detail.getTfgNo());

                if (files == null || files.isEmpty()) {
                    score += 50;
                    detailCn.append("첨부파일 없음; ");
                } else {
                    for (FileInfoDTO file : files) {

                        if (file.getDfiDriveFileId() == null || file.getDfiDriveFileId().isBlank()) {
                            score += 20;
                            detailCn.append("Google Drive 파일 ID 없음; ");
                            continue;
                        }

                        if (!"DONE".equals(file.getDfiUploadSttsCd())) {
                            score += 20;
                            detailCn.append("파일 업로드 미완료; ");
                            continue;
                        }

                        byte[] bytes = googleDriveService.downloadFile(file.getDfiDriveFileId());

                        String mime = file.getDfiMimeTy();
                        String orgName = file.getDfiOrgNm();

                        if ((mime != null && mime.contains("text"))
                                || (orgName != null && orgName.toLowerCase().endsWith(".txt"))) {
                            fileText += "\n" + new String(bytes, StandardCharsets.UTF_8);
                        } else if ((mime != null && mime.contains("pdf"))
                                || (orgName != null && orgName.toLowerCase().endsWith(".pdf"))) {
                            try (PDDocument document = Loader.loadPDF(bytes)) {
                                PDFTextStripper stripper = new PDFTextStripper();
                                fileText += "\n" + stripper.getText(document);
                            }
                        }
                    }
                }
            } else {
                score += 50;
                detailCn.append("신고 상세정보 또는 파일그룹번호 없음; ");
            }
        } catch (Exception e) {
            score += 50;
            detailCn.append("첨부파일 내용 읽기 실패; ");
        }

        System.out.println("===== AI PDF/TXT 추출 내용 시작 =====");
        System.out.println(fileText);
        System.out.println("===== AI PDF/TXT 추출 내용 끝 =====");

        String normalizedFileText = normalize(fileText);

        System.out.println("===== AI 비교 디버그 시작 =====");
        System.out.println("신고번호 = " + refNo);
        System.out.println("업무구분 = " + bizTypeCd);

        if (detail != null) {
            System.out.println("DB 품명 = " + detail.getItemName());
            System.out.println("DB HS코드 = " + detail.getHsCode());
            System.out.println("DB 수량 = " + detail.getQty());
            System.out.println("DB 금액 = " + detail.getAmount());
            System.out.println("DB 원산지 = " + detail.getOrigin());
        }

        System.out.println("PDF/TXT 추출내용 = ");
        System.out.println(fileText);
        System.out.println("정규화된 파일내용 = " + normalizedFileText);
        System.out.println("===== AI 비교 디버그 끝 =====");

        if (normalizedFileText.isBlank()) {
            score += 70;
            detailCn.append("첨부파일 내부 텍스트 확인 불가; ");
        } else if (detail != null) {

            if (hasValue(detail.getItemName()) && isMissing(normalizedFileText, detail.getItemName())) {
                score += 35;
                detailCn.append("품명 불일치 또는 미확인; ");
            }

            if (hasValue(detail.getHsCode()) && isMissing(normalizedFileText, detail.getHsCode())) {
                score += 30;
                detailCn.append("HS코드 불일치 또는 미확인; ");
            }

            if (hasValue(detail.getQty()) && isMissing(normalizedFileText, detail.getQty())) {
                score += 15;
                detailCn.append("수량 불일치 또는 미확인; ");
            }

            if (hasValue(detail.getAmount()) && isMissing(normalizedFileText, detail.getAmount())) {
                score += 25;
                detailCn.append("금액 불일치 또는 미확인; ");
            }

            if (hasValue(detail.getOrigin()) && isMissing(normalizedFileText, detail.getOrigin())) {
                score += 15;
                detailCn.append("원산지 불일치 또는 미확인; ");
            }
        }

        int validDbCount = 0;

        if (detail != null) {
            if (hasValue(detail.getItemName())) validDbCount++;
            if (hasValue(detail.getHsCode())) validDbCount++;
            if (hasValue(detail.getQty())) validDbCount++;
            if (hasValue(detail.getAmount())) validDbCount++;
            if (hasValue(detail.getOrigin())) validDbCount++;
        }

        if (validDbCount <= 2) {
            score += 30;
            detailCn.append("신고정보 비교 항목 부족; ");
        }

        if (score == 35 && detailCn.toString().contains("품명 불일치")) {
            score += 25;
            detailCn.append("품명 단독 불일치로 추가 검토 필요; ");
        }

        if (score > 100) {
            score = 100;
        }

        String gradeCd;
        String resultCn;

        if (score >= 70) {
            gradeCd = "HIGH";
            resultCn = "첨부서류와 신고정보 비교 결과 고위험 항목이 확인되었습니다.";
        } else if (score >= 40) {
            gradeCd = "MIDDLE";
            resultCn = "첨부서류와 신고정보 비교 결과 일부 항목 재확인이 필요합니다.";
        } else {
            gradeCd = "LOW";
            resultCn = "첨부서류와 신고정보 비교 결과 주요 불일치 항목이 적습니다.";
        }

        System.out.println("AI 최종 점수 = " + score);
        System.out.println("AI 상세 사유 = " + detailCn.toString());

        AIRiskDTO dto = new AIRiskDTO();
        dto.setArrNo(aiMapper.selectArrNo());
        dto.setArrBizTypeCd(bizTypeCd);
        dto.setArrRefNo(refNo);
        dto.setArrScore(score);
        dto.setArrGradeCd(gradeCd);
        dto.setArrResultCn(resultCn);
        dto.setArrDetailCn(detailCn.toString());
        dto.setArrStatusCd("DONE");
        dto.setArrOfficerId(null);

        aiMapper.insertAiRiskResult(dto);
    }

    private String normalize(String value) {
        if (value == null) {
            return "";
        }

        return value
                .replace(",", "")
                .replace(" ", "")
                .replace("\n", "")
                .replace("\r", "")
                .toLowerCase();
    }

    private boolean isMissing(String normalizedFileText, String dbValue) {
        if (!hasValue(dbValue)) {
            return false;
        }

        String normalizedDbValue = normalize(dbValue);

        if (normalizedDbValue.isBlank()) {
            return false;
        }

        return !normalizedFileText.contains(normalizedDbValue);
    }

    private boolean hasValue(String value) {
        return value != null
                && !value.trim().isEmpty()
                && !"-".equals(value.trim());
    }
}