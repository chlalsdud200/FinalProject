/* ==========================================================
   2026-05-25 수입운송 최종 CSS 정리
   - PDF 업로드 버튼 중복 텍스트 제거
   - 반출관리 품목사항을 입고관리와 동일한 크기/간격으로 보정
   - 적하목록 조회 아코디언 상세영역 간격 보정
   ========================================================== */

/* PDF 버튼은 실제 버튼 텍스트만 사용한다. 이전 ::after 강제 문구 때문에
   "PDF 텍스트PDF 업로드"처럼 겹쳐 보이던 문제 방지 */
#manifestPackingUploadBtn,
.manifest-packing-upload-label{
  min-width:120px!important;
  height:34px!important;
  padding:0 16px!important;
  font-size:12px!important;
  font-weight:800!important;
  line-height:34px!important;
  color:#fff!important;
  -webkit-text-fill-color:#fff!important;
  background:#334155!important;
  border:1px solid #334155!important;
  border-radius:4px!important;
  text-indent:0!important;
}
#manifestPackingUploadBtn::after,
.manifest-packing-upload-label::after{
  content:none!important;
  display:none!important;
}
#manifestPackingUploadBtn *,
.manifest-packing-upload-label *{
  font-size:12px!important;
  color:#fff!important;
  -webkit-text-fill-color:#fff!important;
}
#manifestPackingUploadBtn input,
.manifest-packing-upload-label input{
  display:none!important;
}

/* 상세 탭 공통: 품목사항 표가 반출관리에서만 커지는 현상 보정 */
#detail-body .import-ui-goods-edit-wrap,
#detail-body .import-ui-goods-wrap,
#detail-body .import-ui-items-wrap{
  margin-top:10px!important;
  border:1px solid #cbd5e1!important;
  background:#fff!important;
  overflow-x:auto!important;
}
#detail-body table.import-ui-goods-edit,
#detail-body .import-ui-goods-edit-wrap table,
#detail-body .import-ui-goods-wrap table,
#detail-body .import-ui-items-wrap table{
  width:100%!important;
  min-width:1120px!important;
  border-collapse:collapse!important;
  table-layout:fixed!important;
  font-size:12px!important;
  line-height:1.25!important;
}
#detail-body table.import-ui-goods-edit th,
#detail-body table.import-ui-goods-edit td,
#detail-body .import-ui-goods-edit-wrap th,
#detail-body .import-ui-goods-edit-wrap td,
#detail-body .import-ui-goods-wrap th,
#detail-body .import-ui-goods-wrap td,
#detail-body .import-ui-items-wrap th,
#detail-body .import-ui-items-wrap td{
  height:34px!important;
  padding:6px 8px!important;
  border:1px solid #cbd5e1!important;
  vertical-align:middle!important;
  text-align:center!important;
  font-size:12px!important;
  font-weight:700!important;
  color:#0f172a!important;
  background:#fff!important;
  white-space:nowrap!important;
}
#detail-body table.import-ui-goods-edit th,
#detail-body .import-ui-goods-edit-wrap th,
#detail-body .import-ui-goods-wrap th,
#detail-body .import-ui-items-wrap th{
  background:#e8f1ff!important;
  color:#0f172a!important;
  font-weight:800!important;
}
#detail-body table.import-ui-goods-edit input,
#detail-body table.import-ui-goods-edit select,
#detail-body .import-ui-goods-edit-wrap input,
#detail-body .import-ui-goods-edit-wrap select,
#detail-body .import-ui-goods-wrap input,
#detail-body .import-ui-goods-wrap select,
#detail-body .import-ui-items-wrap input,
#detail-body .import-ui-items-wrap select{
  width:100%!important;
  height:30px!important;
  min-height:30px!important;
  padding:0 8px!important;
  border:1px solid #94a3b8!important;
  border-radius:0!important;
  background:#fff!important;
  color:#0f172a!important;
  font-size:12px!important;
  font-weight:700!important;
  line-height:30px!important;
  box-sizing:border-box!important;
}

/* 적하목록 조회 아코디언 상세: 다닥다닥 붙는 것 방지 */
#importManifestListPanel tr.manifest-row-detail > td,
#importManifestListPanel tr.manifest-detail-row > td,
#importManifestListPanel .manifest-detail-cell{
  padding:18px 24px 22px!important;
  background:#fff!important;
  border-top:1px solid #cbd5e1!important;
  border-bottom:1px solid #cbd5e1!important;
}
#importManifestListPanel .manifest-detail-box,
#importManifestListPanel .manifest-detail-section,
#importManifestListPanel .manifest-accordion-detail,
#importManifestListPanel .manifest-detail-content{
  display:block!important;
  padding:14px 16px!important;
  margin:0 0 14px 0!important;
  border:1px solid #d7e2f2!important;
  background:#fff!important;
}
#importManifestListPanel .manifest-detail-box:last-child,
#importManifestListPanel .manifest-detail-section:last-child{
  margin-bottom:0!important;
}
#importManifestListPanel .manifest-detail-title,
#importManifestListPanel .manifest-section-title,
#importManifestListPanel h3,
#importManifestListPanel h4{
  margin:0 0 10px 0!important;
  padding:0 0 6px 8px!important;
  border-left:4px solid #334155!important;
  color:#0f172a!important;
  font-size:13px!important;
  font-weight:900!important;
  line-height:1.3!important;
}
#importManifestListPanel .manifest-detail-grid,
#importManifestListPanel .manifest-info-grid,
#importManifestListPanel .manifest-detail-fields{
  display:grid!important;
  grid-template-columns:repeat(3,minmax(0,1fr))!important;
  gap:12px 14px!important;
  align-items:start!important;
}
#importManifestListPanel .manifest-detail-field,
#importManifestListPanel .manifest-info-item,
#importManifestListPanel .manifest-field{
  min-width:0!important;
  padding:0!important;
}
#importManifestListPanel .manifest-detail-field label,
#importManifestListPanel .manifest-info-item label,
#importManifestListPanel .manifest-field label{
  display:block!important;
  margin:0 0 5px 0!important;
  color:#0f172a!important;
  font-size:12px!important;
  font-weight:800!important;
  line-height:1.25!important;
}
#importManifestListPanel .manifest-detail-value,
#importManifestListPanel .manifest-info-value,
#importManifestListPanel .manifest-field-value{
  display:flex!important;
  align-items:center!important;
  min-height:32px!important;
  padding:7px 10px!important;
  border:1px solid #d7e2f2!important;
  background:#eef4ff!important;
  color:#334155!important;
  font-size:12px!important;
  font-weight:800!important;
  line-height:1.25!important;
  word-break:break-all!important;
}


/* 20260525 final import CSS cleanup: keep manifest screen stable after refresh and remove duplicate hotfix artifacts */
#detail-body .search-panel,
#detail-body .filter-area,
#detail-body .list-search-panel,
#detail-body .import-list-search-panel,
#detail-body .import-request-search-panel{
  display:grid!important;
  grid-template-columns:repeat(5,minmax(0,1fr))!important;
  gap:12px!important;
  align-items:end!important;
}
#detail-body .search-panel > *,
#detail-body .filter-area > *,
#detail-body .list-search-panel > *,
#detail-body .import-list-search-panel > *,
#detail-body .import-request-search-panel > *{
  min-width:0!important;
}
#detail-body .search-panel button,
#detail-body .filter-area button,
#detail-body .list-search-panel button,
#detail-body .import-list-search-panel button,
#detail-body .import-request-search-panel button{
  height:36px!important;
  padding:0 18px!important;
  font-size:12px!important;
  font-weight:800!important;
  color:#fff!important;
  white-space:nowrap!important;
}

/* manifest-packing-upload-btn 스타일은 상단 공통 정의를 따름 */
#detail-body .manifest-packing-upload-btn input{display:none!important;}

#detail-body .import-ui-section{border:1px solid #cbd5e1!important;background:#fff!important;padding:14px!important;margin-bottom:14px!important;}
#detail-body .import-ui-section h3,
#detail-body .import-ui-section-title{font-size:14px!important;font-weight:900!important;margin:0 0 10px!important;color:#0f172a!important;}
#detail-body .import-ui-detail-grid{display:grid!important;grid-template-columns:repeat(3,minmax(0,1fr))!important;gap:12px!important;align-items:start!important;}
#detail-body .import-ui-field label{font-size:11px!important;font-weight:800!important;color:#334155!important;margin-bottom:5px!important;display:block!important;}
#detail-body .import-ui-field input,
#detail-body .import-ui-field select,
#detail-body .import-ui-field textarea{width:100%!important;min-height:36px!important;font-size:12px!important;font-weight:700!important;border:1px solid #cbd5e1!important;border-radius:0!important;padding:8px 10px!important;background:#fff!important;color:#1e293b!important;}
#detail-body .import-ui-field input[readonly],
#detail-body .import-ui-field textarea[readonly],
#detail-body .import-ui-field .readonly{background:#e5e7eb!important;color:#334155!important;}

#detail-body .import-ui-goods-wrap{margin-top:8px!important;overflow-x:auto!important;border:1px solid #cbd5e1!important;background:#fff!important;}
#detail-body .import-ui-goods-table{width:100%!important;border-collapse:collapse!important;table-layout:fixed!important;margin:0!important;}
#detail-body .import-ui-goods-table th{height:32px!important;background:#eaf2ff!important;border:1px solid #cbd5e1!important;font-size:12px!important;font-weight:900!important;color:#1e293b!important;text-align:center!important;padding:6px 8px!important;}
#detail-body .import-ui-goods-table td{border:1px solid #cbd5e1!important;padding:6px 8px!important;background:#fff!important;vertical-align:middle!important;}
#detail-body .import-ui-goods-table input,
#detail-body .import-ui-goods-table select{height:34px!important;min-height:34px!important;width:100%!important;font-size:12px!important;font-weight:700!important;padding:6px 8px!important;border:1px solid #94a3b8!important;background:#fff!important;color:#0f172a!important;box-sizing:border-box!important;}

#detail-body .import-manifest-accordion-row > td{padding:0!important;background:#f8fafc!important;}
#detail-body .import-manifest-accordion-row td > div{margin:14px!important;padding:16px!important;border:1px solid #cbd5e1!important;background:#fff!important;}
#detail-body .import-manifest-accordion-row .grid{display:grid!important;grid-template-columns:repeat(3,minmax(0,1fr))!important;gap:14px!important;align-items:start!important;}
#detail-body .import-manifest-accordion-row .grid > div{min-width:0!important;}
#detail-body .import-manifest-accordion-row .grid > div > div:first-child{font-size:11px!important;font-weight:900!important;color:#475569!important;margin-bottom:5px!important;}
#detail-body .import-manifest-accordion-row .grid > div > div:last-child{min-height:36px!important;padding:9px 10px!important;border:1px solid #cbd5e1!important;background:#eef4ff!important;font-size:12px!important;font-weight:800!important;color:#1e293b!important;display:flex!important;align-items:center!important;}
#detail-body .import-manifest-accordion-close{height:30px!important;padding:0 12px!important;border:1px solid #64748b!important;background:#fff!important;color:#334155!important;font-size:12px!important;font-weight:900!important;}

@media (max-width:1200px){
  #detail-body .search-panel,
  #detail-body .filter-area,
  #detail-body .list-search-panel,
  #detail-body .import-list-search-panel,
  #detail-body .import-request-search-panel{grid-template-columns:repeat(3,minmax(0,1fr))!important;}
  #detail-body .import-ui-detail-grid,
  #detail-body .import-manifest-accordion-row .grid{grid-template-columns:repeat(2,minmax(0,1fr))!important;}
}

/* === 2026-05-27 D/O 버튼 상태 통일 ===
   미정산: 정산요청만 활성화
   정산요청/정산완료: 정산 버튼은 완료/대기 표시로 잠금
   정산완료 후 D/O 발급 활성화, 발급 후 전달요청 활성화
*/
#detail-body .import-ui-do-flow-btn,
.import-ui-do-flow-btn{
  display:inline-flex!important;
  align-items:center!important;
  justify-content:center!important;
  box-sizing:border-box!important;
  width:112px!important;
  min-width:112px!important;
  max-width:112px!important;
  height:34px!important;
  min-height:34px!important;
  max-height:34px!important;
  padding:0 12px!important;
  border:1px solid #1e293b!important;
  border-radius:0!important;
  font-size:12px!important;
  font-weight:900!important;
  line-height:1!important;
  text-align:center!important;
  white-space:nowrap!important;
  box-shadow:none!important;
  opacity:1!important;
}
#detail-body .import-ui-do-flow-btn.is-active,
.import-ui-do-flow-btn.is-active{
  background:#1e293b!important;
  border-color:#1e293b!important;
  color:#fff!important;
  -webkit-text-fill-color:#fff!important;
  cursor:pointer!important;
  pointer-events:auto!important;
}
#detail-body .import-ui-do-flow-btn.is-locked,
#detail-body .import-ui-do-flow-btn.is-done,
#detail-body .import-ui-do-flow-btn:disabled,
.import-ui-do-flow-btn.is-locked,
.import-ui-do-flow-btn.is-done,
.import-ui-do-flow-btn:disabled{
  background:#e5e7eb!important;
  border-color:#cbd5e1!important;
  color:#64748b!important;
  -webkit-text-fill-color:#64748b!important;
  cursor:not-allowed!important;
  pointer-events:none!important;
  opacity:1!important;
  box-shadow:none!important;
}
