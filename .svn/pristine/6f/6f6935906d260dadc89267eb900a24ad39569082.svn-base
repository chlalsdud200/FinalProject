@charset "UTF-8";

/* =========================================================
   수입운송 좌측 목록 화면 공통 CSS  (최종 통일본)
   기준 화면 : 내륙운송 배차처리 조회버튼 (검정 배경 #334155 · 흰 글씨)
   정리일    : 2026-05-25
   ========================================================= */

/* ----------------------------------------------------------
   1. 특수 모달 / 공통 테이블 행 동작
   ---------------------------------------------------------- */
#pickupDispatchListPanel .tbl td,
#pickupDispatchListPanel .tbl th,
#pickupDispatchModal .tbl td,
#pickupDispatchModal .tbl th{white-space:normal!important;word-break:keep-all;vertical-align:middle}
#pickupDispatchModal tbody tr{cursor:pointer}
#pickupDispatchModal tbody tr:hover td{background:#eef4fb!important}

#bondedReleaseRequestModal .field-select,
#bondedReleaseRequestModal .field-input,
#bondedReleaseRequestModal .field-textarea{font-size:13px!important}
#bondedReleaseRequestModal textarea,
#bondedReleaseRejectModal textarea{resize:none}

.import-manifest-row td{white-space:normal!important;word-break:keep-all;vertical-align:middle}
.import-manifest-row:hover td{background:#eef4fb!important}
#manifestCustomsModal textarea{resize:none}

.do-row{cursor:pointer}
.do-row:hover td{background:#eef4fb!important}
.do-row td{white-space:normal!important;word-break:keep-all;vertical-align:middle}
.do-settlement-cell .info-chip,
.do-status-cell .info-chip{min-width:64px!important;height:28px!important;padding:0 10px!important;justify-content:center!important}

#detail-body .import-manifest-arrival-status-btn{
  display:inline-flex!important;
  align-items:center!important;
  justify-content:center!important;
  width:74px!important;
  min-width:74px!important;
  max-width:74px!important;
  height:30px!important;
  min-height:30px!important;
  padding:0!important;
  border-radius:0!important;
  font-family:Pretendard,"Noto Sans KR","Malgun Gothic",Arial,sans-serif!important;
  font-size:11px!important;
  font-weight:900!important;
  line-height:30px!important;
  letter-spacing:0!important;
  text-align:center!important;
  text-decoration:none!important;
  text-indent:0!important;
  white-space:nowrap!important;
  box-sizing:border-box!important;
  vertical-align:middle!important;
  cursor:pointer!important;
  user-select:none!important;
  box-shadow:none!important;
  transition:none!important;
}

#detail-body .import-manifest-arrival-status-btn.is-issued{
  border-color:#86efac!important;
  background:#ecfdf5!important;
  color:#047857!important;
  -webkit-text-fill-color:#047857!important;
}

#detail-body .import-manifest-arrival-status-btn.is-pending{
  border-color:#cbd5e1!important;
  background:#f8fafc!important;
  color:#334155!important;
  -webkit-text-fill-color:#334155!important;
}

#detail-body .import-manifest-arrival-action-btn{
  display:inline-flex!important;
  align-items:center!important;
  justify-content:center!important;
  min-width:74px!important;
  height:30px!important;
  min-height:30px!important;
  padding:0 10px!important;
  border:1px solid #334155!important;
  border-radius:0!important;
  background:#334155!important;
  color:#fff!important;
  -webkit-text-fill-color:#fff!important;
  font-family:Pretendard,"Noto Sans KR","Malgun Gothic",Arial,sans-serif!important;
  font-size:11px!important;
  font-weight:900!important;
  line-height:30px!important;
  letter-spacing:0!important;
  white-space:nowrap!important;
  box-sizing:border-box!important;
  box-shadow:none!important;
  transition:none!important;
}

/* ----------------------------------------------------------
   2. 적하목록 비교 화면
   ---------------------------------------------------------- */
#manifestPackingDownloadBtn,
#manifestPackingViewBtn,
#manifestManualConfirmArea{display:none!important}

.manifest-pdf-value-input{background:#fff!important;color:#0f172a!important}
.manifest-compare-result span{white-space:nowrap}

#manifestPackingUploadInput{display:none!important}

#manifestPackingUploadBtn,
.manifest-packing-upload-btn{
  display:inline-flex!important;align-items:center!important;justify-content:center!important;
  min-width:92px!important;height:34px!important;padding:0 16px!important;
  background:#64748b!important;border:1px solid #64748b!important;border-radius:4px!important;
  color:#fff!important;-webkit-text-fill-color:#fff!important;
  font-size:12px!important;font-weight:800!important;line-height:1!important;
  white-space:nowrap!important;cursor:pointer!important;
  transition:all 0.2s!important;
  opacity:1!important;visibility:visible!important;text-indent:0!important;box-shadow:none!important;
}
.manifest-packing-upload-btn:hover{
  background:#334155!important;border-color:#334155!important;
}
#manifestPackingUploadBtn::before,
#manifestPackingUploadBtn::after,
.manifest-packing-upload-btn::before,
.manifest-packing-upload-btn::after{
  content:none!important;display:none!important;
}
#manifestPackingUploadBtn input,
.manifest-packing-upload-btn input{display:none!important}

/* ----------------------------------------------------------
   3. D/O 정산 처리 버튼
   ---------------------------------------------------------- */
.import-ui-do-settle-btn,
button.import-ui-do-settle-btn{
  display:inline-flex!important;align-items:center!important;justify-content:center!important;
  min-width:92px!important;height:36px!important;padding:0 14px!important;
  background:#334155!important;border:1px solid #334155!important;border-radius:0!important;
  color:#fff!important;-webkit-text-fill-color:#fff!important;
  font-size:13px!important;font-weight:800!important;line-height:36px!important;
  text-align:center!important;opacity:1!important;visibility:visible!important;box-shadow:none!important;cursor:pointer!important;
}
.import-ui-do-settle-btn:hover,
button.import-ui-do-settle-btn:hover{
  background:#1e293b!important;border-color:#1e293b!important;color:#fff!important;
}

/* ----------------------------------------------------------
   4. 상세 패널 내 일반 액션 버튼 (공통 흰색 버튼)
   ---------------------------------------------------------- */
#detail-body .import-ui-actions .import-ui-btn,
#detail-body .import-ui-btn,
#detail-body .import-ui-do-issue-btn,
#detail-body .import-ui-do-deliver-btn,
#detail-body .import-ui-inbound-send-btn,
#detail-body .import-ui-inbound-supp-btn,
#detail-body .import-ui-release-send-btn,
#detail-body .import-ui-release-supp-btn,
#detail-body .import-ui-arrival-send-btn,
#detail-body .import-ui-inland-process-btn,
#detail-body .import-request-save-btn,
#detail-body .import-request-submit-btn,
#detail-body .request-reject-btn,
#detail-body .import-ui-doc-select,
#detail-body .import-ui-doc-upload-btn,
#detail-body .import-ui-doc-action a,
#detail-body .import-ui-doc-remove,
#detail-body .do-select-btn,
#detail-body a.import-ui-file-download{
  display:inline-flex!important;align-items:center!important;justify-content:center!important;
  width:auto!important;min-width:58px!important;max-width:none!important;
  height:30px!important;min-height:30px!important;padding:0 12px!important;
  border:1px solid #b7c7d9!important;border-radius:0!important;
  background:#fff!important;color:#0f172a!important;-webkit-text-fill-color:#0f172a!important;
  font-size:12px!important;font-weight:900!important;line-height:1!important;
  text-align:center!important;text-decoration:none!important;
  box-shadow:none!important;opacity:1!important;cursor:pointer!important;
}
#detail-body .import-ui-actions .import-ui-btn:hover,
#detail-body .import-ui-btn:hover,
#detail-body .import-ui-do-issue-btn:hover,
#detail-body .import-ui-do-deliver-btn:hover,
#detail-body .import-ui-inbound-send-btn:hover,
#detail-body .import-ui-inbound-supp-btn:hover,
#detail-body .import-ui-release-send-btn:hover,
#detail-body .import-ui-release-supp-btn:hover,
#detail-body .import-ui-arrival-send-btn:hover,
#detail-body .import-ui-inland-process-btn:hover,
#detail-body .import-request-save-btn:hover,
#detail-body .import-request-submit-btn:hover,
#detail-body .request-reject-btn:hover,
#detail-body .import-ui-doc-select:hover,
#detail-body .import-ui-doc-upload-btn:hover,
#detail-body .import-ui-doc-action a:hover,
#detail-body .import-ui-doc-remove:hover,
#detail-body .do-select-btn:hover,
#detail-body a.import-ui-file-download:hover{
  background:#f8fafc!important;border-color:#9fb4cc!important;
  color:#0f172a!important;-webkit-text-fill-color:#0f172a!important;
}
#detail-body .import-ui-btn:disabled,
#detail-body .import-ui-do-settle-btn:disabled,
#detail-body .import-ui-do-issue-btn:disabled,
#detail-body .import-ui-do-deliver-btn:disabled,
#detail-body button:disabled{
  background:#fff!important;border-color:#b7c7d9!important;
  color:#0f172a!important;-webkit-text-fill-color:#0f172a!important;
  opacity:1!important;cursor:not-allowed!important;box-shadow:none!important;
}

/* ----------------------------------------------------------
   5. 좌측 목록 카드 공통 레이아웃
   ---------------------------------------------------------- */
#detail-body .import-left-list-card{
  width:100%!important;border:1px solid #cbd5e1!important;border-radius:0!important;
  background:#fff!important;box-shadow:none!important;overflow:hidden!important;
}

/* 카드 헤더 */
#detail-body .import-left-list-card > .bg-slate-50,
#detail-body .import-left-list-card > div:first-child[class*="border-b"],
#detail-body .import-left-list-card > div:first-child[class*="bg-slate-50"]{
  height:48px!important;min-height:48px!important;
  display:flex!important;align-items:center!important;
  padding:0 24px!important;background:#f8fafc!important;
  border-bottom:1px solid #cbd5e1!important;
}
#detail-body .import-left-list-card h4{
  margin:0!important;font-size:13px!important;font-weight:900!important;
  line-height:1!important;color:#0f172a!important;
}
#detail-body .import-left-list-card > .bg-slate-50:first-child p,
#detail-body .import-left-list-card > div:first-child[class*="bg-slate-50"] p{
  display:none!important;
}

/* 카드 바디 패딩 */
#detail-body .import-left-list-card > .p-5,
#detail-body .import-left-list-card > .p-6,
#detail-body .import-left-list-card > div[class*="p-5"],
#detail-body .import-left-list-card > div[class*="p-6"]{padding:24px!important;}

/* ----------------------------------------------------------
   6. 검색 그리드
   ---------------------------------------------------------- */
#detail-body .import-left-list-card .list-search-grid,
#detail-body .import-left-list-card .do-list-search-grid,
#detail-body .import-left-list-card .release-search-grid,
#detail-body .import-left-list-card .inland-search-grid,
#detail-body .import-left-list-card .import-list-search-grid,
#detail-body #importManifestListOnlyPanel .grid{
  display:grid!important;
  grid-template-columns:repeat(auto-fit,minmax(170px,1fr)) 52px!important;
  gap:10px!important;align-items:end!important;margin-bottom:14px!important;
}
#detail-body .import-left-list-card .list-search-grid > div,
#detail-body .import-left-list-card .do-list-search-grid > div,
#detail-body .import-left-list-card .release-search-grid > div,
#detail-body .import-left-list-card .inland-search-grid > div,
#detail-body .import-left-list-card .import-list-search-grid > div{
  min-width:0!important;display:flex!important;flex-direction:column!important;gap:6px!important;
}

/* flex column 구조(gap 쓰는 화면) 간격 보정 */
#detail-body .section-card .p-6[style*="flex-direction:column"] > .overflow-x-auto,
#detail-body .section-card .p-6[style*="flex-direction: column"] > .overflow-x-auto,
#detail-body .section-card .p-6[style*="flex-direction:column"] > div,
#detail-body .section-card .p-6[style*="flex-direction: column"] > div{margin-top:0!important;}

/* 검색 라벨 */
#detail-body .import-left-list-card .field-label,
#detail-body .import-left-list-card label{
  display:block!important;margin:0 0 6px 0!important;
  font-size:12px!important;font-weight:900!important;
  line-height:1!important;color:#0f172a!important;letter-spacing:-0.01em!important;
}

/* 검색 입력칸 / 셀렉트 */
#detail-body .import-left-list-card .field-input,
#detail-body .import-left-list-card .field-select,
#detail-body .import-left-list-card input[type="text"],
#detail-body .import-left-list-card input[type="date"],
#detail-body .import-left-list-card select{
  width:100%!important;height:40px!important;min-height:40px!important;
  padding:0 12px!important;margin:0!important;
  border:1px solid #cbd5e1!important;border-radius:0!important;
  background:#fff!important;color:#0f172a!important;-webkit-text-fill-color:#0f172a!important;
  font-size:12px!important;font-weight:800!important;line-height:40px!important;
  box-shadow:none!important;outline:none!important;
}
#detail-body .import-left-list-card .field-input::placeholder,
#detail-body .import-left-list-card input[type="text"]::placeholder{
  color:#0f172a!important;opacity:1!important;font-weight:800!important;
}

/* ----------------------------------------------------------
   7. ★ 조회 버튼 통일 (기준: 내륙운송 배차처리 — 검정 배경 · 흰 글씨)
      모든 탭의 조회버튼을 이 규칙 하나로 동일하게 적용
   ---------------------------------------------------------- */
/* 검색 그리드 안 버튼 (각 탭 조회 버튼) */
#detail-body .import-left-list-card .list-search-grid > button,
#detail-body .import-left-list-card .do-list-search-grid > button,
#detail-body .import-left-list-card .release-search-grid > button,
#detail-body .import-left-list-card .inland-search-grid > button,
#detail-body .import-left-list-card .import-list-search-grid > button,
  /* ID로 직접 지정된 각 탭 조회 버튼 */
#importInboundSearchBtn,
#importReleaseSearchBtn,
#importInlandDispatchSearchBtn,
#doListSearchBtn,
#manifestSearchBtn,
#importManifestSearchBtn,
  /* js-refresh 버튼 (운송의뢰 등) */
#detail-body .import-left-list-card .js-import-request-refresh{
  display:inline-flex!important;align-items:center!important;justify-content:center!important;
  justify-self:start!important;align-self:end!important;
  width:52px!important;min-width:52px!important;max-width:52px!important;
  height:40px!important;min-height:40px!important;
  padding:0!important;margin:0!important;
  border:1px solid #334155!important;border-radius:0!important;
  background:#334155!important;
  color:#fff!important;-webkit-text-fill-color:#fff!important;
  font-size:12px!important;font-weight:900!important;line-height:1!important;
  text-align:center!important;box-shadow:none!important;opacity:1!important;cursor:pointer!important;
}
#detail-body .import-left-list-card .list-search-grid > button:hover,
#detail-body .import-left-list-card .do-list-search-grid > button:hover,
#detail-body .import-left-list-card .release-search-grid > button:hover,
#detail-body .import-left-list-card .inland-search-grid > button:hover,
#detail-body .import-left-list-card .import-list-search-grid > button:hover,
#importInboundSearchBtn:hover,
#importReleaseSearchBtn:hover,
#importInlandDispatchSearchBtn:hover,
#doListSearchBtn:hover,
#manifestSearchBtn:hover,
#importManifestSearchBtn:hover,
#detail-body .import-left-list-card .js-import-request-refresh:hover{
  background:#1e293b!important;border-color:#1e293b!important;
  color:#fff!important;-webkit-text-fill-color:#fff!important;
}

/* ----------------------------------------------------------
   8. 테이블 래퍼
   ---------------------------------------------------------- */
#detail-body .import-left-list-card .overflow-x-auto,
#detail-body .import-left-list-card .overflow-hidden,
#detail-body .import-left-list-card .inland-table-wrap{
  width:100%!important;margin:0!important;
  border:1px solid #cbd5e1!important;border-radius:0!important;
  overflow-x:auto!important;background:#fff!important;box-shadow:none!important;
}

/* 검색 그리드 → 테이블 래퍼 상단 간격 */
#detail-body .import-left-list-card .list-search-grid + .overflow-x-auto,
#detail-body .import-left-list-card .do-list-search-grid + .overflow-x-auto,
#detail-body .import-left-list-card .do-list-search-grid + .overflow-hidden,
#detail-body .import-left-list-card .release-search-grid + .overflow-x-auto,
#detail-body .import-left-list-card .inland-search-grid + .overflow-x-auto,
#detail-body .import-left-list-card .import-list-search-grid + .overflow-x-auto,
#detail-body .import-left-list-card .p-5 > .overflow-x-auto,
#detail-body .import-left-list-card .p-6 > .overflow-x-auto,
#detail-body .import-left-list-card .p-5 > .overflow-hidden,
#detail-body .import-left-list-card .p-6 > .overflow-hidden{margin-top:16px!important;}

/* ----------------------------------------------------------
   9. 테이블 (thead / tbody)
   ---------------------------------------------------------- */
#detail-body .import-left-list-card table,
#detail-body .import-left-list-card .tbl,
#detail-body .import-left-list-card .inland-table{
  width:100%!important;border-collapse:collapse!important;
  table-layout:fixed!important;margin:0!important;
  background:#fff!important;font-size:12px!important;
}
#detail-body .import-left-list-card table thead th,
#detail-body .import-left-list-card .tbl thead th,
#detail-body .import-left-list-card .inland-table thead th{
  height:40px!important;padding:0 12px!important;
  background:#f8fafc!important;border-bottom:1px solid #cbd5e1!important;
  color:#0f172a!important;font-size:12px!important;font-weight:900!important;
  line-height:1.25!important;text-align:center!important;
  vertical-align:middle!important;white-space:nowrap!important;
}
#detail-body .import-left-list-card table tbody td,
#detail-body .import-left-list-card .tbl tbody td,
#detail-body .import-left-list-card .inland-table tbody td{
  height:46px!important;padding:0 12px!important;
  border-bottom:1px solid #e2e8f0!important;
  color:#0f172a!important;font-size:12px!important;font-weight:800!important;
  line-height:1.25!important;text-align:center!important;
  vertical-align:middle!important;white-space:normal!important;word-break:keep-all!important;
}
#detail-body .import-left-list-card table tbody tr:last-child td,
#detail-body .import-left-list-card .tbl tbody tr:last-child td,
#detail-body .import-left-list-card .inland-table tbody tr:last-child td{border-bottom:0!important;}

/* ----------------------------------------------------------
   10. 상태 칩 (공통 기본)
   ---------------------------------------------------------- */
#detail-body .import-left-list-card .tacs-status-chip,
#detail-body .import-left-list-card .info-chip,
#detail-body .import-left-list-card .inland-chip,
#detail-body .import-left-list-card .status-chip,
#detail-body .import-left-list-card span[class*="bg-green"],
#detail-body .import-left-list-card span[class*="bg-yellow"],
#detail-body .import-left-list-card span[class*="bg-red"],
#detail-body .import-left-list-card span[class*="bg-blue"]{
  display:inline-flex!important;align-items:center!important;justify-content:center!important;
  min-width:58px!important;height:30px!important;min-height:30px!important;padding:0 12px!important;
  border:1px solid #b7c7d9!important;border-radius:0!important;
  background:#fff!important;color:#0f172a!important;-webkit-text-fill-color:#0f172a!important;
  font-size:12px!important;font-weight:900!important;line-height:1!important;
  white-space:nowrap!important;box-shadow:none!important;
}

/* 상태 칩 색상 */
#detail-body .import-left-list-card .tacs-status-done,
#detail-body .import-left-list-card span.tacs-status-done,
#detail-body .import-left-list-card button.tacs-status-done{
  border:1px solid #86efac!important;background:#dcfce7!important;
  color:#166534!important;-webkit-text-fill-color:#166534!important;
}
#detail-body .import-left-list-card .tacs-status-reject,
#detail-body .import-left-list-card span.tacs-status-reject,
#detail-body .import-left-list-card button.tacs-status-reject{
  border:1px solid #fecaca!important;background:#fee2e2!important;
  color:#b91c1c!important;-webkit-text-fill-color:#b91c1c!important;
}
#detail-body .import-left-list-card .tacs-status-wait,
#detail-body .import-left-list-card span.tacs-status-wait,
#detail-body .import-left-list-card button.tacs-status-wait{
  border:1px solid #bfdbfe!important;background:#dbeafe!important;
  color:#1d4ed8!important;-webkit-text-fill-color:#1d4ed8!important;
}
#detail-body .import-left-list-card .tacs-status-neutral,
#detail-body .import-left-list-card span.tacs-status-neutral,
#detail-body .import-left-list-card button.tacs-status-neutral{
  border:1px solid #cbd5e1!important;background:#f8fafc!important;
  color:#334155!important;-webkit-text-fill-color:#334155!important;
}

/* ----------------------------------------------------------
   11. 처리 버튼 (상세·반려사유 등 테이블 안 버튼)
   ---------------------------------------------------------- */
#detail-body .import-left-list-card .do-select-btn,
#detail-body .import-left-list-card .import-list-action-btn{
  display:inline-flex!important;align-items:center!important;justify-content:center!important;
  min-width:58px!important;height:30px!important;padding:0 12px!important;
  border:1px solid #b7c7d9!important;border-radius:0!important;
  background:#fff!important;color:#0f172a!important;-webkit-text-fill-color:#0f172a!important;
  font-size:12px!important;font-weight:900!important;line-height:1!important;
}
/* ----------------------------------------------------------
   12. 내륙운송 배차처리 목록 보정
      - 운송의뢰 목록처럼 테이블 칸 세로선까지 동일하게 표시
      - 반출상태/배차상태 칩 모양을 다른 목록 상태칩과 동일하게 통일
   ---------------------------------------------------------- */
#detail-body .import-left-list-card table thead th,
#detail-body .import-left-list-card .tbl thead th,
#detail-body .import-left-list-card .inland-table thead th,
