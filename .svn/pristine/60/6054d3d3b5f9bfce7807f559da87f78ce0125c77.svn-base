(function installTacsImportReleaseCleanV1() {
    if (window.__TACS_IMPORT_RELEASE_CLEAN_V1_INSTALLED) return;
    window.__TACS_IMPORT_RELEASE_CLEAN_V1_INSTALLED = true;

    function escHtml(value) {
        return String(value == null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function cleanText(value) {
        const text = String(value == null ? '' : value).trim();
        return text === '-' ? '' : text;
    }

    function safeDisplay(value) {
        return escHtml(cleanText(value));
    }

    function pick(row, keys, fallback) {
        row = row || {};
        for (let i = 0; i < keys.length; i += 1) {
            const value = cleanText(row[keys[i]]);
            if (value) return value;
        }
        return fallback || '';
    }

    function releaseRequestDisplayNo(row, actualNo) {
        const display = pick(row, [
            'releaseReqDisplayNo', 'releaseReqDispNo', 'releaseRequestDisplayNo', 'releaseRequestNoDisplay',
            'crrDisplayNo', 'CRR_DISPLAY_NO'
        ], '');
        if (display) return display;
        const rawNo = cleanText(actualNo);
        if (!rawNo) return '';
        if (!/^\d+$/.test(rawNo)) return rawNo;
        const dateSource = pick(row, ['crrCrDt', 'crrReqDt', 'releaseReqDt', 'releasePlanDt', 'listAt', 'requestDt'], '');
        const trcSource = pick(row, ['trcNo', 'requestNo', 'CRR_TRE_ID', 'crrTreId'], '');
        let ymd = '';
        let m = cleanText(dateSource).replace(/[./]/g, '-').match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
        if (m) {
            ymd = m[1] + m[2].padStart(2, '0') + m[3].padStart(2, '0');
        } else {
            m = cleanText(dateSource).replace(/[.]/g, '/').match(/^(\d{2})[/-](\d{1,2})[/-](\d{1,2})/);
            if (m) ymd = (Number(m[1]) < 50 ? '20' : '19') + m[1] + m[2].padStart(2, '0') + m[3].padStart(2, '0');
        }
        if (!ymd) {
            const trcDate = cleanText(trcSource).match(/(20\d{6})/);
            if (trcDate) ymd = trcDate[1];
        }
        if (!ymd) ymd = new Date().toISOString().slice(0, 10).replace(/-/g, '');
        return 'REL-IMP-' + ymd + '-' + (rawNo.length < 4 ? rawNo.padStart(4, '0') : rawNo);
    }

    function normalizeReleaseStatus(row) {
        /*
         * 반출관리 목록은 반드시 "반출 전용 상태"만으로 표시한다.
         *
         * 기존에는 statusCd/statusNm까지 같이 보면서,
         * D/O/접수/입고 등 다른 단계의 DONE 값이 섞여 내려오면
         * 반출대기 건도 반출완료로 표시되는 문제가 있었다.
         */
        const releaseCd = pick(row, [
            // 원본 반출요청 상태를 파생 표시상태보다 우선한다.
            // 일부 건은 releaseStatusCd가 CRR_RELEASE_DT 등으로 REL_DONE 파생되지만
            // 실제 CRR_STATUS_CD는 REL_WAIT인 경우가 있다.
            'crrStatusCd', 'crStatusCd', 'whOutStatusCd', 'releaseStatusCd', 'releaseRequestStatusCd',
            'CRR_STATUS_CD', 'CR_STATUS_CD', 'WH_OUT_STATUS_CD', 'RELEASE_STATUS_CD', 'RELEASE_REQUEST_STATUS_CD'
        ], '').toUpperCase();
        const releaseNm = pick(row, [
            'crrStatusNm', 'crStatusNm', 'whOutStatusNm', 'releaseStatusNm', 'releaseRequestStatusNm',
            'CRR_STATUS_NM', 'CR_STATUS_NM', 'WH_OUT_STATUS_NM', 'RELEASE_STATUS_NM', 'RELEASE_REQUEST_STATUS_NM'
        ], '');

        const genericCd = pick(row, ['statusCd'], '').toUpperCase();
        const genericNm = pick(row, ['statusNm', 'listStatus', 'releaseStatus'], '');

        // statusCd는 범용 상태라서 REL/OUT/CRR 계열일 때만 반출 상태로 사용한다.
        const cd = releaseCd || (/^(REL|RELEASE|OUT|CRR|CR)_/.test(genericCd) ? genericCd : '');
        // statusNm도 반출 관련 문구일 때만 fallback으로 사용한다.
        const nm = releaseNm || (/반출|보완|반려/.test(genericNm) ? genericNm : '');
        const hasCd = !!cd;

        if (['REL_DONE', 'OUT_DONE', 'RELEASE_DONE', 'CRR_DONE', 'RELEASED'].includes(cd) || (!hasCd && nm === '반출완료')) {
            return '반출완료';
        }
        if ([
            'REL_WAIT', 'REQUESTED',
            'OUT_WAIT', 'OUT_REQ',
            'RELEASE_WAIT', 'RELEASE_REQ',
            'CRR_WAIT', 'CRR_REQ',
            'REQ_READY', 'READY'
        ].includes(cd) || (!hasCd && ['요청완료', '발송완료', '반출요청', '반출대기', '반출요청완료'].includes(nm))) {
            return '반출대기';
        }
        if (['REL_SENT', 'REQ_SENT', 'OUT_SENT', 'RELEASE_SENT', 'CRR_SENT'].includes(cd) || (!hasCd && nm === '보완제출완료')) {
            return '보완제출완료';
        }
        if ([
            'REL_FIX', 'REL_REJECT', 'REJECT', 'REJECTED',
            'OUT_FIX', 'OUT_REJECT',
            'RELEASE_FIX', 'RELEASE_REJECT',
            'CRR_FIX', 'CRR_REJECT'
        ].includes(cd) || (!hasCd && ['반려', '보완', '보완요청', '반출보완요청'].includes(nm))) {
            return '보완요청';
        }
        return nm || '';
    }

    function normalizeImportReleaseRow(row) {
        row = row || {};
        const requestNo = pick(row, ['trcNo', 'requestNo', 'reqNo'], '');
        const releaseReqActualNo = pick(row, ['crrNo', 'CRR_NO', 'releaseReqNo', 'releaseRequestNo'], '');
        const releaseReqNo = releaseRequestDisplayNo(row, releaseReqActualNo);
        const owner = pick(row, ['ownerNm', 'owner', 'owrNm'], '');
        const doNo = pick(row, ['doNo', 'diDoNo'], '');
        const cargoMgmtNo = pick(row, ['cargoMgmtNo', 'wirCargoMgmtNo'], '');
        const target = pick(row, ['bondedManagerNm', 'warehouseManagerNm', 'wmNm', 'doDlvrOwnerNm', 'targetWarehouse', 'warehouseZoneNm', 'bondedZoneNo', 'wzNo'], '');
        const requestDt = pick(row, ['releaseReqDt', 'crrReqDt', 'releasePlanDt', 'listAt', 'requestDt'], '');
        const warehouseNm = pick(row, ['warehouseNm', 'whNm'], '');
        const zoneNm = pick(row, ['warehouseZoneNm', 'wzNm'], '');

        return {
            raw: row,
            requestNo: requestNo,
            releaseReqNo: releaseReqNo,
            owner: owner,
            doNo: doNo,
            cargoMgmtNo: cargoMgmtNo,
            target: target,
            warehouseNm: warehouseNm,
            zoneNm: zoneNm,
            requestDt: requestDt,
            status: normalizeReleaseStatus(row),
            statusCd: pick(row, ['releaseStatusCd', 'statusCd'], '')
        };
    }

    function getInitialRows() {
        const source = Array.isArray(window.TRANSPORT_IMPORT_RELEASE_LIST)
            ? window.TRANSPORT_IMPORT_RELEASE_LIST
            : (Array.isArray(window.IMPORT_RELEASE_LIST) ? window.IMPORT_RELEASE_LIST : []);
        return source.map(normalizeImportReleaseRow);
    }

    function getRows() {
        const source = Array.isArray(window.__TACS_IMPORT_RELEASE_ROWS)
            ? window.__TACS_IMPORT_RELEASE_ROWS
            : getInitialRows().map(function (row) { return row.raw || row; });
        return source.map(normalizeImportReleaseRow);
    }
    function installStyle() {
        if (document.getElementById('tacs-import-release-clean-v1-style')) return;
        const style = document.createElement('style');
        style.id = 'tacs-import-release-clean-v1-style';
        style.textContent = '' +
            '#detail-body .import-release-request-panel .info-chip{display:inline-flex;align-items:center;justify-content:center;min-width:58px;min-height:30px;padding:0 12px;border:1px solid #b7c7d9;background:#ffffff;color:#0f172a;border-radius:0;font-size:12px;font-weight:900;white-space:nowrap;}';
        document.head.appendChild(style);
    }

    function readFilterState() {
        return {
            requestNo: cleanText(window.__TACS_IMPORT_RELEASE_REQ_FILTER),
            owner: cleanText(window.__TACS_IMPORT_RELEASE_OWNER_FILTER),
            doNo: cleanText(window.__TACS_IMPORT_RELEASE_DO_FILTER),
            cargoNo: cleanText(window.__TACS_IMPORT_RELEASE_CARGO_FILTER),
            status: cleanText(window.__TACS_IMPORT_RELEASE_STATUS_FILTER)
        };
    }

    function filterRows(rows) {
        const f = readFilterState();
        const req = f.requestNo.toLowerCase();
        const owner = f.owner.toLowerCase();
        const doNo = f.doNo.toLowerCase();
        const cargo = f.cargoNo.toLowerCase();
        const status = f.status;

        return (rows || []).filter(function (row) {
            return (!req || row.requestNo.toLowerCase().indexOf(req) >= 0)
                && (!owner || row.owner.toLowerCase().indexOf(owner) >= 0)
                && (!doNo || row.doNo.toLowerCase().indexOf(doNo) >= 0)
                && (!cargo || row.cargoMgmtNo.toLowerCase().indexOf(cargo) >= 0)
                && (!status || row.status === status);
        });
    }

    function buildStatusOptions(selected) {
        const statuses = ['', '반출대기', '반출완료', '보완요청', '보완제출완료'];
        return statuses.map(function (status) {
            const label = status || '전체';
            return '<option value="' + escHtml(status) + '"' + (selected === status ? ' selected' : '') + '>' + escHtml(label) + '</option>';
        }).join('');
    }

    function buildTableRows(rows, loading) {
        if (loading) {
            return '<tr><td colspan="8" class="text-center text-slate-500 py-6">보세구역 반출관리 목록을 불러오는 중입니다.</td></tr>';
        }
        if (!rows.length) {
            return '<tr><td colspan="8" class="text-center text-slate-500 py-6">조건에 맞는 보세구역 반출관리 목록이 없습니다.</td></tr>';
        }

        return rows.map(function (row) {
            return '' +
                '<tr class="release-list-row">' +
                '<td class="font-bold">' + safeDisplay(row.requestNo) + '</td>' +
                '<td>' + safeDisplay(row.releaseReqNo) + '</td>' +
                '<td>' + safeDisplay(row.owner) + '</td>' +
                '<td>' + safeDisplay(row.doNo) + '</td>' +
                '<td>' + safeDisplay(row.cargoMgmtNo) + '</td>' +
                '<td>' + safeDisplay(row.target || row.warehouseNm || row.zoneNm) + '</td>' +
                '<td class="text-center whitespace-nowrap">' + safeDisplay(row.requestDt) + '</td>' +
                '<td class="text-center"><span class="info-chip">' + safeDisplay(row.status) + '</span></td>' +
                '</tr>';
        }).join('');
    }

    function requestImportReleaseRows(force) {
        if (window.__TACS_IMPORT_RELEASE_LOADING) {
            return window.__TACS_IMPORT_RELEASE_PROMISE || Promise.resolve(window.__TACS_IMPORT_RELEASE_ROWS || []);
        }
        if (!force && window.__TACS_IMPORT_RELEASE_LOADED) {
            return Promise.resolve(window.__TACS_IMPORT_RELEASE_ROWS || window.TRANSPORT_IMPORT_RELEASE_LIST || []);
        }

        window.__TACS_IMPORT_RELEASE_LOADING = true;
        const contextPath = window.contextPath || document.body?.dataset?.contextPath || '';

        window.__TACS_IMPORT_RELEASE_PROMISE = fetch(contextPath + '/transport/import/release-request/list.do?_=' + Date.now(), {
            method: 'GET',
            headers: {'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json'},
            cache: 'no-store'
        })
            .then(function (res) {
                if (!res.ok) throw new Error('HTTP ' + res.status);
                return res.json();
            })
            .then(function (list) {
                const rawRows = Array.isArray(list) ? list : [];
                window.__TACS_IMPORT_RELEASE_ROWS = rawRows;
                window.TRANSPORT_IMPORT_RELEASE_LIST = rawRows;
                window.IMPORT_RELEASE_LIST = rawRows;
                window.__TACS_IMPORT_RELEASE_LOADED = true;
                return rawRows;
            })
            .catch(function (err) {
                console.error('[보세구역 반출관리 목록 조회 실패]', err);
                window.__TACS_IMPORT_RELEASE_ROWS = [];
                window.__TACS_IMPORT_RELEASE_LOADED = true;
                return [];
            })
            .finally(function () {
                window.__TACS_IMPORT_RELEASE_LOADING = false;
                refreshImportReleaseRequestPanel();
                if (typeof window.refreshImportWorkflowSummary === 'function') window.refreshImportWorkflowSummary();
            });

        return window.__TACS_IMPORT_RELEASE_PROMISE;
    }

    window.loadImportReleaseRequestRows = function () {
        return requestImportReleaseRows(true);
    };

    window.refreshImportReleaseRequestPanel = function () {
        const body = document.getElementById('detail-body');
        if (!body || body.dataset.currentItem !== 'TACS-FW-033') return;
        body.innerHTML = '<div class="space-y-6">' + window.buildInlandDispatchListPanel() + '</div>';
        window.bindImportReleaseRequestActions('import', 'TACS-FW-033');
        if (typeof normalizeDetailActionButtons === 'function') normalizeDetailActionButtons();
    };

    window.buildInlandDispatchListPanel = function () {
        installStyle();
        if (!window.__TACS_IMPORT_RELEASE_LOADED && !window.__TACS_IMPORT_RELEASE_LOADING) {
            requestImportReleaseRows(false);
        }

        const filters = readFilterState();
        const rows = filterRows(getRows());
        const loading = !!window.__TACS_IMPORT_RELEASE_LOADING;

        return '' +
            '<div class="space-y-4 import-release-request-panel" data-item-id="TACS-FW-033" data-view-mode="list">' +
            '  <div class="section-card import-left-list-card overflow-hidden">' +
            '    <div class="bg-slate-50 px-6 py-4 border-b border-slate-200"><h4 class="text-sm font-bold text-slate-900">보세구역 반출관리 목록</h4></div>' +
            '    <div class="p-6 space-y-4">' +
            '      <div class="list-search-grid">' +
            '        <div><label class="field-label">의뢰번호</label><input id="importReleaseReqFilter" class="field-input" type="text" value="' + escHtml(filters.requestNo) + '" placeholder="의뢰번호"></div>' +
            '        <div><label class="field-label">화주명</label><input id="importReleaseOwnerFilter" class="field-input" type="text" value="' + escHtml(filters.owner) + '" placeholder="화주명"></div>' +
            '        <div><label class="field-label">D/O 번호</label><input id="importReleaseDoFilter" class="field-input" type="text" value="' + escHtml(filters.doNo) + '" placeholder="D/O 번호"></div>' +
            '        <div><label class="field-label">화물관리번호</label><input id="importReleaseCargoFilter" class="field-input" type="text" value="' + escHtml(filters.cargoNo) + '" placeholder="화물관리번호"></div>' +
            '        <div><label class="field-label">상태</label><select id="importReleaseStatusFilter" class="field-select">' + buildStatusOptions(filters.status) + '</select></div>' +
            '        <button type="button" id="importReleaseSearchBtn" class="px-4 py-2 bg-slate-800 text-white text-xs font-bold hover:bg-slate-900">조회</button>' +
            '      </div>' +
            '      <div class="overflow-hidden border border-slate-200">' +
            '        <table class="w-full tbl table-fixed text-xs">' +
            '          <thead><tr><th>의뢰번호</th><th>반출요청번호</th><th>화주명</th><th>D/O 번호</th><th>화물관리번호</th><th>전달대상</th><th>요청일자</th><th>상태</th></tr></thead>' +
            '          <tbody>' + buildTableRows(rows, loading) + '</tbody>' +
            '        </table>' +
            '      </div>' +
            '    </div>' +
            '  </div>' +
            '</div>';
    };

    window.bindImportReleaseRequestActions = function (groupKey, itemId) {
        if (itemId !== 'TACS-FW-033') return;
        installStyle();
        const root = document.querySelector('.import-release-request-panel[data-item-id="TACS-FW-033"]');
        if (!root) return;

        function byId(id) { return document.getElementById(id); }

        function applyFilter() {
            window.__TACS_IMPORT_RELEASE_REQ_FILTER = cleanText(byId('importReleaseReqFilter')?.value || '');
            window.__TACS_IMPORT_RELEASE_OWNER_FILTER = cleanText(byId('importReleaseOwnerFilter')?.value || '');
            window.__TACS_IMPORT_RELEASE_DO_FILTER = cleanText(byId('importReleaseDoFilter')?.value || '');
            window.__TACS_IMPORT_RELEASE_CARGO_FILTER = cleanText(byId('importReleaseCargoFilter')?.value || '');
            window.__TACS_IMPORT_RELEASE_STATUS_FILTER = cleanText(byId('importReleaseStatusFilter')?.value || '');

            const body = document.getElementById('detail-body');
            if (body && body.dataset.currentItem === 'TACS-FW-033') {
                body.innerHTML = '<div class="space-y-6">' + window.buildInlandDispatchListPanel() + '</div>';
                window.bindImportReleaseRequestActions('import', 'TACS-FW-033');
                if (typeof normalizeDetailActionButtons === 'function') normalizeDetailActionButtons();
            }
        }

        const searchBtn = byId('importReleaseSearchBtn');
        if (searchBtn) searchBtn.addEventListener('click', applyFilter);

        ['importReleaseReqFilter', 'importReleaseOwnerFilter', 'importReleaseDoFilter', 'importReleaseCargoFilter'].forEach(function (id) {
            const el = byId(id);
            if (el) {
                el.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        applyFilter();
                    }
                });
            }
        });

        const statusFilter = byId('importReleaseStatusFilter');
        if (statusFilter) statusFilter.addEventListener('change', applyFilter);
    };

    // 구버전 코드에서 호출될 수 있는 이름 보존
    window.showImportReleaseRequestListView = function () {
        const body = document.getElementById('detail-body');
        if (body && body.dataset.currentItem === 'TACS-FW-033') {
            body.innerHTML = '<div class="space-y-6">' + window.buildInlandDispatchListPanel() + '</div>';
            window.bindImportReleaseRequestActions('import', 'TACS-FW-033');
        }
    };

    window.showImportReleaseRequestFormView = window.showImportReleaseRequestListView;

    document.addEventListener('DOMContentLoaded', installStyle);
    installStyle();
})();


/* === 2026-05-19 release button white text fix === */
(function(){
  function install(){
    if(document.getElementById('tacs-import-release-button-white-fix')) return;
    var st=document.createElement('style');
    st.id='tacs-import-release-button-white-fix';
    st.textContent='#detail-body .import-release-request-panel button,#detail-body .import-release-request-panel button *{color:#fff!important;}';
    document.head.appendChild(st);
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',install); else install();
})();

/* === 2026-05-21 반출요청 D/O 전달완료 가드 ===
 * 반출요청은 D/O + 수입신고필증 전달완료(TRC_DO_REQ) 이후에만 가능하다.
 */
(function installTacsImportReleaseDoDeliveredGuard(){
  if (window.__TACS_IMPORT_RELEASE_DO_DELIVERED_GUARD_20260521) return;
  window.__TACS_IMPORT_RELEASE_DO_DELIVERED_GUARD_20260521 = true;

  function txt(v){ return String(v == null ? '' : v).trim(); }
  function isDelivered(v){
    v = txt(v);
    return v === 'TRC_DO_REQ' || v === '전달완료' || v === 'D/O전달완료';
  }
  function findReleaseRow(root){
    var reqNoEl = root.querySelector('[data-request-no], [data-trc-no]');
    var reqNo = reqNoEl ? txt(reqNoEl.dataset.requestNo || reqNoEl.dataset.trcNo) : '';
    var rows = Array.isArray(window.__TACS_IMPORT_RELEASE_ROWS) ? window.__TACS_IMPORT_RELEASE_ROWS : (Array.isArray(window.TRANSPORT_IMPORT_RELEASE_LIST) ? window.TRANSPORT_IMPORT_RELEASE_LIST : []);
    if (reqNo) {
      for (var i=0; i<rows.length; i++) if (txt(rows[i].trcNo || rows[i].requestNo || rows[i].reqNo) === reqNo) return rows[i];
    }
    return rows.length === 1 ? rows[0] : null;
  }
  function allowRelease(root){
    var row = findReleaseRow(root);
    if (!row) return true;
    return isDelivered(row.doStatusCd) || isDelivered(row.doStatusNm) || isDelivered(row.doStatus);
  }
  document.addEventListener('click', function(e){
    var target = e.target instanceof Element ? e.target : null;
    if (!target) return;
    var btn = target.closest('button, a, input[type="button"], input[type="submit"]');
    if (!btn) return;
    var label = txt(btn.textContent || btn.value || btn.getAttribute('aria-label') || btn.title);
    var action = txt(btn.dataset && (btn.dataset.action || btn.dataset.role || '')).toLowerCase();
    var isReleaseRequest = action.indexOf('release') >= 0 || label.indexOf('반출요청') >= 0 || label.indexOf('발송') >= 0;
    if (!isReleaseRequest) return;
    var root = (btn.closest && btn.closest('#detail-body, .import-release-request-panel, .import-inline-tabs-0513, form')) || document;
    if (!allowRelease(root)) {
      alert('D/O와 수입신고필증 전달 완료 후 반출요청이 가능합니다.');
      e.preventDefault(); e.stopPropagation(); if (e.stopImmediatePropagation) e.stopImmediatePropagation();
    }
  }, true);
})();
