<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.or.tacs.transport.importp.mapper.ImportTransportMapper">
  <!-- ============================================================ -->
  <!-- 내륙운송 배차처리 -->
  <!-- namespace는 기존 ImportTransportMapper와 동일하게 유지한다. -->
  <!-- 발표 전 안전 분리를 위해 Java Mapper/Service/Controller는 변경하지 않는다. -->
  <!-- ============================================================ -->
  <select id="retriveImpInlandDispatchList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        T.TRC_NO AS trcNo,
        T.TRC_OWR_ID AS ownerId,
        NVL(O.OWR_NM, NVL(RQ.CRR_NM, T.TRC_OWR_ID)) AS ownerNm,
        NVL(RQ.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM) AS itemNm,
        NVL(GS.GOODS_NAME, NVL(RQ.CRR_FRGHT_IEM_NM, T.TRC_ITEM_CTGRY_NM)) AS goodsName,
        GS.GOODS_NO AS goodsNo,
        GS.QTY AS qty,
        GS.QTY AS totalQty,
        GS.PRICE AS price,
        GS.GOODS_TOTAL_PRICE AS goodsTotalPrice,
        GS.GOODS_TOTAL_PRICE AS summaryTotalPrice,
        GS.WEIGHT AS weight,
        GS.WEIGHT AS totalWeight,
        GS.ORIGIN AS origin,
        RQ.CRR_NO AS releaseReqNo,
        RQ.CRR_WZ_NO AS bondedZoneNo,
        RQ.CRR_WZ_NO AS warehouseZoneNo,
        RQ.CRR_WZ_NO AS wzNo,
        NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO)) AS warehouseZoneNm,
        RQ.CRR_WM_ID AS warehouseManagerId,
        RQ.CRR_WM_ID AS wmId,
        NVL(WM.WM_NM, RQ.CRR_WHM_NO) AS warehouseManagerNm,
        NULL AS releaseNo,
        TO_CHAR(RQ.CRR_CR_DT, 'YYYY-MM-DD') AS releaseReqDt,
        TO_CHAR(RQ.CRR_RELEASE_DT, 'YYYY-MM-DD') AS releaseDt,
        NVL(RQ.CRR_STATUS_CD, 'REL_WAIT') AS releaseStatusCd,
        CASE NVL(RQ.CRR_STATUS_CD, 'REL_WAIT')
        WHEN 'REL_REQ' THEN '반출대기'
        WHEN 'REL_WAIT' THEN '반출대기'
        WHEN 'REL_DONE' THEN '반출완료'
        WHEN 'REL_FIX' THEN '보완요청'
        WHEN 'REL_REJECT' THEN '보완요청'
        WHEN 'REL_SENT' THEN '보완제출완료'
        ELSE NVL(RQ.CRR_STATUS_CD, '반출대기')
        END AS releaseStatusNm,
        D.DISPATCH_NO AS dispatchNo,
        NVL(D.DISPATCH_STATUS_CD, 'TRC_DISPATCH_WAIT') AS dispatchStatusCd,
        CASE NVL(D.DISPATCH_STATUS_CD, 'TRC_DISPATCH_WAIT')
        WHEN 'TRC_DISPATCH_DONE' THEN '배차완료'
        WHEN 'DISPATCH_DONE' THEN '배차완료'
        ELSE '배차대기'
        END AS dispatchStatusNm,
        D.DISPATCH_CAR_NO AS carNo,
        NVL(C.CAR_NM, TO_CHAR(D.DISPATCH_CAR_NO)) AS carNm,
        NVL(D.DISPATCH_DRV_NM, C.CAR_DRIVER_NM) AS driverNm,
        D.DISPATCH_DRV_TELNO AS driverTelno,
        NVL(
        NULLIF(TRIM(NVL(O.OWR_ADRES, '') || ' ' || NVL(O.OWR_DETAIL_ADRES, '')), ''),
        NVL(D.DISPATCH_LOADG_ADRES, NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO)))
        ) AS destinationAdres,
        NVL(D.DISPATCH_LOADG_ADRES, NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO))) AS loadgAdres,
        NVL(D.DISPATCH_LOADG_ADRES, NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO))) AS releasePlace,
        TO_CHAR(D.DISPATCH_PICKUP_DT, 'YYYY-MM-DD') AS pickupDt
        FROM TRAN_RCP T
        LEFT JOIN CARGO_RELEASE_REQ RQ
        ON RQ.CRR_TRE_ID = T.TRC_NO
        LEFT JOIN OWNER O
        ON O.OWR_ID = T.TRC_OWR_ID
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = RQ.CRR_WZ_NO
        LEFT JOIN WAREHOUSE_MANAGER WM
        ON WM.WM_ID = RQ.CRR_WM_ID
        LEFT JOIN DISPATCH D
        ON D.DISPATCH_TRE_ID = T.TRC_NO
        LEFT JOIN CAR C
        ON C.CAR_NO = D.DISPATCH_CAR_NO
        LEFT JOIN (
        SELECT
        CG.GG_NO
        , MIN(CG.GOODS_NO) AS GOODS_NO
        , MIN(G.GOODS_NAME) AS GOODS_NAME
        , MIN(G.GOODS_HS_CODE) AS GOODS_HS_CODE
        , MIN(G.GOODS_HS_CODE) AS HS_CODE
        , NVL(SUM(CG.CG_QTY), 0) AS QTY
        , NVL(MAX(CG.CG_PRICE), 0) AS PRICE
        , NVL(SUM(CG.CG_TOTAL_PRICE), 0) AS GOODS_TOTAL_PRICE
        , NVL(SUM(CG.CG_WEIGHT), 0) AS WEIGHT
        , MIN(CG.CG_ORIGIN) AS ORIGIN
        FROM CUSTOMS_GOODS CG
        LEFT JOIN GOODS G
        ON G.GOODS_NO = CG.GOODS_NO
        GROUP BY CG.GG_NO
        ) GS
        ON GS.GG_NO = T.TRC_TFG_NO
        WHERE T.TRC_SE_CD = 'IMPORT'
        <if test="tmId != null and tmId != ''">
            AND T.TRC_TM_NO = (
            SELECT TM.TM_NO
            FROM TRANSPORT_MANAGER TM
            WHERE TM.TM_ID = #{tmId}
            )
        </if>
        AND T.TRC_STATUS_CD IN ('TRC_DONE', 'TRC_END', 'TRC_COMPLETE')
        AND (
        RQ.CRR_STATUS_CD IN ('REL_DONE', 'DONE', 'RELEASED', 'APPROVED')
        OR RQ.CRR_RELEASE_DT IS NOT NULL
        )
        ORDER BY RQ.CRR_CR_DT DESC, RQ.CRR_NO DESC
    </select>
  <select id="retriveImpAvailableCarList" resultType="kr.or.tacs.vo.transport.TransportRequestVO">
        SELECT
        C.CAR_NO AS carNo,
        C.CAR_NM AS carNm,
        C.CAR_DRIVER_NM AS driverNm,
        C.CAR_WORK_PSBL_PRD AS driverTelno,
        TM.TM_CP_NM AS transportCompanyNm
        FROM CAR C
        LEFT JOIN TRANSPORT_MANAGER TM
        ON TM.TM_NO = C.CAR_TM_NO
        WHERE UPPER(NVL(C.CAR_USE, 'Y')) = 'Y'
        <if test="tmId != null and tmId != ''">
            AND TM.TM_ID = #{tmId}
        </if>
        ORDER BY C.CAR_NO
    </select>
  <update id="updateImpInlandDispatch" parameterType="kr.or.tacs.vo.transport.TransportRequestVO">
        /*
        * 내륙운송 배차 저장/수정.
        * 기존 배차가 있으면 UPDATE, 없으면 INSERT 한다.
        */
        BEGIN
        UPDATE DISPATCH D
        SET
        D.DISPATCH_CAR_NO = COALESCE(
        #{carNo,jdbcType=NUMERIC},
        D.DISPATCH_CAR_NO,
        (SELECT MIN(C.CAR_NO) FROM CAR C WHERE UPPER(NVL(C.CAR_USE, 'Y')) = 'Y')
        ),
        D.DISPATCH_DRV_NM = (
        SELECT C.CAR_DRIVER_NM
        FROM CAR C
        WHERE C.CAR_NO = COALESCE(
        #{carNo,jdbcType=NUMERIC},
        D.DISPATCH_CAR_NO,
        (SELECT MIN(C2.CAR_NO) FROM CAR C2 WHERE UPPER(NVL(C2.CAR_USE, 'Y')) = 'Y')
        )
        ),
        D.DISPATCH_LOADG_ADRES = COALESCE(
        NULLIF(#{destinationAdres,jdbcType=VARCHAR}, ''),
        D.DISPATCH_LOADG_ADRES,
        (
        SELECT NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO))
        FROM CARGO_RELEASE_REQ RQ
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = RQ.CRR_WZ_NO
        WHERE RQ.CRR_TRE_ID = #{trcNo}
        ORDER BY RQ.CRR_NO DESC
        FETCH FIRST 1 ROW ONLY
        )
        ),
        D.DISPATCH_DRV_TELNO = (
        SELECT C.CAR_WORK_PSBL_PRD
        FROM CAR C
        WHERE C.CAR_NO = COALESCE(
        #{carNo,jdbcType=NUMERIC},
        D.DISPATCH_CAR_NO,
        (SELECT MIN(C2.CAR_NO) FROM CAR C2 WHERE UPPER(NVL(C2.CAR_USE, 'Y')) = 'Y')
        )
        ),
        D.DISPATCH_PICKUP_DT = CASE
        WHEN #{pickupDt} IS NULL OR TRIM(#{pickupDt}) IS NULL THEN SYSDATE
        ELSE TO_DATE(#{pickupDt}, 'YYYY-MM-DD')
        END,
        D.DISPATCH_STATUS_CD = 'TRC_DISPATCH_DONE'
        WHERE D.DISPATCH_TRE_ID = #{trcNo}
        AND EXISTS (
        SELECT 1
        FROM CARGO_RELEASE_REQ RQ
        WHERE RQ.CRR_TRE_ID = #{trcNo}
        AND (
        RQ.CRR_STATUS_CD IN ('REL_DONE', 'DONE', 'RELEASED', 'APPROVED')
        OR RQ.CRR_RELEASE_DT IS NOT NULL
        )
        );

        IF SQL%ROWCOUNT = 0 THEN
        INSERT INTO DISPATCH (
        DISPATCH_NO,
        DISPATCH_TRE_ID,
        DISPATCH_OWR_ID,
        DISPATCH_CAR_NO,
        DISPATCH_DRV_NM,
        DISPATCH_LOADG_ADRES,
        DISPATCH_DRV_TELNO,
        DISPATCH_PICKUP_DT,
        DISPATCH_STATUS_CD
        )
        SELECT
        (SELECT NVL(MAX(DISPATCH_NO), 0) + 1 FROM DISPATCH),
        T.TRC_NO,
        T.TRC_OWR_ID,
        CAR_PICK.CAR_NO,
        (SELECT C.CAR_DRIVER_NM FROM CAR C WHERE C.CAR_NO = CAR_PICK.CAR_NO),
        COALESCE(
        NULLIF(#{destinationAdres,jdbcType=VARCHAR}, ''),
        (
        SELECT NVL(WZ.WZ_NM, TO_CHAR(RQ.CRR_WZ_NO))
        FROM CARGO_RELEASE_REQ RQ
        LEFT JOIN WAREHOUSE_ZONE WZ
        ON WZ.WZ_NO = RQ.CRR_WZ_NO
        WHERE RQ.CRR_TRE_ID = #{trcNo}
        ORDER BY RQ.CRR_NO DESC
        FETCH FIRST 1 ROW ONLY
        )
        ),
        (SELECT C.CAR_WORK_PSBL_PRD FROM CAR C WHERE C.CAR_NO = CAR_PICK.CAR_NO),
        CASE
        WHEN #{pickupDt} IS NULL OR TRIM(#{pickupDt}) IS NULL THEN SYSDATE
        ELSE TO_DATE(#{pickupDt}, 'YYYY-MM-DD')
        END,
        'TRC_DISPATCH_DONE'
        FROM TRAN_RCP T
        CROSS JOIN (
        SELECT COALESCE(
        #{carNo,jdbcType=NUMERIC},
        (SELECT MIN(C.CAR_NO) FROM CAR C WHERE UPPER(NVL(C.CAR_USE, 'Y')) = 'Y')
        ) AS CAR_NO
        FROM DUAL
        ) CAR_PICK
        WHERE T.TRC_NO = #{trcNo}
        AND T.TRC_SE_CD = 'IMPORT'
        AND EXISTS (
        SELECT 1
        FROM CARGO_RELEASE_REQ RQ
        WHERE RQ.CRR_TRE_ID = T.TRC_NO
        AND (
        RQ.CRR_STATUS_CD IN ('REL_DONE', 'DONE', 'RELEASED', 'APPROVED')
        OR RQ.CRR_RELEASE_DT IS NOT NULL
        )
        )
        AND NOT EXISTS (
        SELECT 1
        FROM DISPATCH D
        WHERE D.DISPATCH_TRE_ID = T.TRC_NO
        );
        END IF;

        /*
        * 운송담당자 쪽 최종 처리 완료.
        * 반출완료 + 배차완료가 모두 끝난 경우에만 TRC_END(완료대기)로 올린다.
        * TRC_COMPLETE(최종완료)는 화주 최종완료 버튼 전용이므로 운송쪽에서는 건드리지 않는다.
        */
        UPDATE TRAN_RCP T
        SET T.TRC_STATUS_CD = 'TRC_END'
        WHERE T.TRC_NO = #{trcNo}
          AND T.TRC_SE_CD = 'IMPORT'
          AND T.TRC_STATUS_CD IN ('TRC_DONE', 'TRC_END')
          AND EXISTS (
              SELECT 1
              FROM CARGO_RELEASE_REQ RQ
              WHERE RQ.CRR_TRE_ID = T.TRC_NO
                AND (
                    RQ.CRR_STATUS_CD = 'REL_DONE'
                    OR RQ.CRR_RELEASE_DT IS NOT NULL
                )
          )
          AND EXISTS (
              SELECT 1
              FROM DISPATCH D
              WHERE D.DISPATCH_TRE_ID = T.TRC_NO
                AND D.DISPATCH_STATUS_CD IN ('TRC_DISPATCH_DONE', 'DISPATCH_DONE')
          );
        END;
    </update>
</mapper>
