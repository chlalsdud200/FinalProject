@charset "UTF-8";

.resource-archive-wrap {
  background: #fff;
  border: 1px solid #e2e8f0;
  padding: 18px;
}

.resource-archive-toolbar {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-bottom: 16px;
  border-left: 3px solid #565e74;
  padding-left: 10px;
}

.resource-archive-toolbar select,
.resource-archive-toolbar input {
  height: 34px;
  border: 1px solid #cbd5e1;
  padding: 0 10px;
  font-size: 12px;
  background: #fff;
}

.resource-archive-toolbar input[type="text"] {
  width: 450px;
}

.resource-archive-toolbar button,
.resource-archive-download {
  border: 0;
  background: #203444;
  color: #fff;
  padding: 8px 14px;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
}

.resource-archive-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}

.resource-archive-table th {
  background: #f8fafc;
  border-top: 1px solid #e2e8f0;
  border-bottom: 1px solid #e2e8f0;
  padding: 10px;
  text-align: left;
  color: #475569;
}

.resource-archive-table th:first-child,
.resource-archive-table td:first-child {
  text-align: center;
}

.resource-archive-table td {
  border-bottom: 1px solid #e2e8f0;
  padding: 10px;
  color: #203444;
  text-align: left;
}

.resource-archive-desc {
  margin-top: 4px;
  font-size: 11px;
  color: #64748b;
}

.resource-archive-empty {
  text-align: center;
  color: #94a3b8;
  padding: 32px !important;
}
