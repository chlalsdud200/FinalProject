<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<c:set var="mp" value="${requestScope.menuPermissions}" />
<c:if test="${menuPermissionEnabled eq true}">
<style>
<c:if test="${mp['/warehouse/dashboard.do'].readYn ne 'Y'}">.aside a[href$="/warehouse/dashboard.do"]{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/inbound.do'].readYn ne 'Y'}">.aside a[href$="/warehouse/inbound.do"]{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/inventory.do'].readYn ne 'Y'}">.aside a[href$="/warehouse/inventory.do"]{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/outbound.do'].readYn ne 'Y'}">.aside a[href$="/warehouse/outbound.do"]{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/docs.do'].readYn ne 'Y'}">.aside a[href$="/warehouse/docs.do"]{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/docs/trash.do'].readYn ne 'Y'}">.aside a[href$="/warehouse/docs/trash.do"]{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/docs.do'].readYn ne 'Y' and mp['/warehouse/docs/trash.do'].readYn ne 'Y'}">#ng-docs{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/community.do?tab=notice'].readYn ne 'Y'}">.aside a[href*="/warehouse/community.do?tab=notice"]{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/community.do?tab=archive'].readYn ne 'Y'}">.aside a[href*="/warehouse/community.do?tab=archive"]{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/community.do?tab=support'].readYn ne 'Y'}">.aside a[href*="/warehouse/community.do?tab=support"]{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/community.do?tab=notice'].readYn ne 'Y' and mp['/warehouse/community.do?tab=archive'].readYn ne 'Y' and mp['/warehouse/community.do?tab=support'].readYn ne 'Y'}">#ng-community{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/mypage.do?tab=profile'].readYn ne 'Y'}">.aside a[href*="/warehouse/mypage.do?tab=profile"]{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/mypage.do?tab=alarm'].readYn ne 'Y'}">.aside a[href*="/warehouse/mypage.do?tab=alarm"]{display:none!important;}</c:if>
<c:if test="${mp['/warehouse/mypage.do?tab=profile'].readYn ne 'Y' and mp['/warehouse/mypage.do?tab=alarm'].readYn ne 'Y'}">#ng-mypage{display:none!important;}</c:if>
</style>
</c:if>
<aside class="aside">
    <div class="logo-area">
        <div class="logo-row">
            <div class="logo-icon"><span class="material-symbols-outlined">shield</span></div>
            <div class="logo-text"><h1>TACS</h1><p>Warehouse Manager</p></div>
        </div>
    </div>

    <nav>
        <div class="nav-section-label">메인</div>
        <a href="${pageContext.request.contextPath}/warehouse/dashboard.do" class="nav-link" data-p="dashboard" onclick="event.preventDefault(); loadPage(this.href);">
            <span class="material-symbols-outlined">dashboard</span>대시보드
        </a>

        <div class="nav-section-label">화물관리</div>
        <a href="${pageContext.request.contextPath}/warehouse/inbound.do" class="nav-link" data-p="inbound" onclick="event.preventDefault(); loadPage(this.href);">
            <span class="material-symbols-outlined">archive</span>보세입고 처리
        </a>
        <a href="${pageContext.request.contextPath}/warehouse/inventory.do" class="nav-link" data-p="inventory" onclick="event.preventDefault(); loadPage(this.href);">
            <span class="material-symbols-outlined">inventory_2</span>보세재고 조회
        </a>
        <a href="${pageContext.request.contextPath}/warehouse/outbound.do" class="nav-link" data-p="outbound" onclick="event.preventDefault(); loadPage(this.href);">
            <span class="material-symbols-outlined">unarchive</span>보세반출 처리
        </a>
        <div class="nav-group" id="ng-docs">
            <a href="javascript:void(0)" class="nav-group-btn" id="ngb-docs" onclick="toggleNav('docs')">
                <span class="material-symbols-outlined">folder</span>문서함<span class="nav-arrow" id="na-docs">▸</span>
            </a>
            <div class="nav-sub" id="ns-docs">
                <a href="${pageContext.request.contextPath}/warehouse/docs.do" class="nav-sub-link" onclick="event.preventDefault(); loadPage(this.href);">내문서</a>
                <a href="${pageContext.request.contextPath}/warehouse/docs/trash.do" class="nav-sub-link" onclick="event.preventDefault(); loadPage(this.href);">휴지통</a>
            </div>
        </div>

        <div class="nav-section-label">커뮤니티 · 계정</div>

        <div class="nav-group" id="ng-community">
            <a href="javascript:void(0)" class="nav-group-btn" id="ngb-community" onclick="toggleNav('community')">
                <span class="material-symbols-outlined">forum</span>커뮤니티<span class="nav-arrow" id="na-community">▸</span>
            </a>
            <div class="nav-sub" id="ns-community">
                <a href="${pageContext.request.contextPath}/warehouse/community.do?tab=notice" class="nav-sub-link" data-community-tab="notice" onclick="event.preventDefault(); goSub('community', 'notice');">공지사항</a>
                <a href="${pageContext.request.contextPath}/warehouse/community.do?tab=archive" class="nav-sub-link" data-community-tab="archive" onclick="event.preventDefault(); goSub('community', 'archive');">자료실</a>
                <a href="${pageContext.request.contextPath}/warehouse/community.do?tab=support" class="nav-sub-link" data-community-tab="support" onclick="event.preventDefault(); goSub('community', 'support');">고객센터</a>
            </div>
        </div>

        <div class="nav-group" id="ng-mypage">
            <a href="javascript:void(0)" class="nav-group-btn" id="ngb-mypage" onclick="toggleNav('mypage')">
                <span class="material-symbols-outlined">manage_accounts</span>마이페이지<span class="nav-arrow" id="na-mypage">▸</span>
            </a>
            <div class="nav-sub" id="ns-mypage">
                <a href="${pageContext.request.contextPath}/warehouse/mypage.do?tab=profile" class="nav-sub-link" onclick="event.preventDefault(); goSub('mypage', 'profile');">회원정보 수정</a>
                <a href="${pageContext.request.contextPath}/warehouse/mypage.do?tab=alarm" class="nav-sub-link" onclick="event.preventDefault(); goSub('mypage', 'alarm');">알림 수신 설정</a>
            </div>
        </div>
    </nav>

    <div class="nav-bottom">
        <form action="${pageContext.request.contextPath}/logout" method="post" id="logoutForm" style="display:none;">
            <input type="hidden" name="${_csrf.parameterName}" value="${_csrf.token}" />
        </form>
        <a href="javascript:void(0)" class="nav-link" onclick="document.getElementById('logoutForm').submit();">
            <span class="material-symbols-outlined">logout</span>로그아웃
        </a>
    </div>
</aside>
