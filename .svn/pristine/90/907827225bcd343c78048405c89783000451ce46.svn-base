/* ── 관세사 선택 모달 ── */
.modal-overlay { display:none; position:fixed; inset:0; background:rgba(15,23,42,.45); z-index:200; align-items:center; justify-content:center; }
.modal-overlay.open { display:flex; }
.modal-box { background:#fff; width:580px; max-width:95vw; max-height:88vh; display:flex; flex-direction:column; box-shadow:0 20px 60px rgba(0,0,0,.18); }
.modal-head { display:flex; justify-content:space-between; align-items:flex-start; padding:20px 24px 16px; border-bottom:1px solid #e2e8f0; }
.modal-title { font-size:16px; font-weight:800; color:#0f172a; }
.modal-subtitle { font-size:11px; color:#64748b; margin-top:3px; }
.modal-close-btn { background:none; border:none; cursor:pointer; color:#94a3b8; padding:2px; }
.modal-close-btn:hover { color:#334155; }
.modal-close-btn .material-symbols-outlined { font-size:22px; }
.modal-search-wrap { display:flex; align-items:center; gap:10px; padding:14px 24px; border-bottom:1px solid #f1f5f9; }
.modal-search-wrap .material-symbols-outlined { font-size:18px; color:#94a3b8; flex-shrink:0; }
.modal-search-wrap input { flex:1; border:none; outline:none; font-size:13px; color:#203444; background:none; }
.modal-search-wrap input::placeholder { color:#94a3b8; }
.modal-tabs { display:flex; gap:0; padding:0 24px; border-bottom:1px solid #e2e8f0; }
.modal-tab { background:none; border:none; border-bottom:2px solid transparent; padding:10px 14px; font-size:12px; font-weight:600; color:#64748b; cursor:pointer; margin-bottom:-1px; transition:all .12s; }
.modal-tab:hover { color:#334155; }
.modal-tab.active { color:#565e74; border-bottom-color:#565e74; font-weight:700; }
.broker-list { flex:1; overflow-y:auto; padding:12px 16px; display:flex; flex-direction:column; gap:6px; }
.broker-card { display:flex; align-items:center; gap:14px; padding:14px 16px; border:1px solid #e2e8f0; cursor:pointer; transition:all .12s; position:relative; }
.broker-card:hover { border-color:#a0b4c8; background:#f8faff; }
.broker-card.selected { border-color:#565e74; background:#f0f4ff; }
.broker-card.hidden { display:none; }
.broker-avatar { width:40px; height:40px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:14px; font-weight:800; flex-shrink:0; }
.broker-info { flex:1; min-width:0; }
.broker-name { font-size:13px; font-weight:700; color:#0f172a; display:flex; align-items:center; gap:8px; }
.broker-badge { font-size:9px; font-weight:700; padding:2px 7px; background:#dae2fd; color:#373f54; }
.broker-badge.export { background:#fef3c7; color:#92400e; }
.broker-badge.import { background:#d1fae5; color:#065f46; }
.broker-person { font-size:11px; color:#475569; margin-top:3px; }
.broker-meta { font-size:10px; color:#94a3b8; margin-top:4px; }
.broker-check { font-size:20px; color:#e2e8f0; flex-shrink:0; transition:color .12s; }
.broker-card.selected .broker-check { color:#565e74; }
.modal-footer { display:flex; justify-content:space-between; align-items:center; padding:14px 24px; border-top:1px solid #e2e8f0; gap:12px; }
.broker-selected-preview { font-size:12px; color:#64748b; }
.broker-selected-preview strong { color:#0f172a; }


  .stats-grid, .metric-strip { grid-template-columns: 1fr 1fr; }
  .kanban-board { grid-template-columns: 1fr; }
  .two-col, .two-col-wide { grid-template-columns: 1fr; }
  .doc-flow-grid { grid-template-columns: 1fr; }
  .flow-arrow { display: none; }
  .form-grid { grid-template-columns: 1fr; }
  .ai-tax-grid { grid-template-columns: 1fr; }
  .dash-layout { grid-template-columns: 1fr; }
  .search-wrap input { width: 220px; }
  @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  input:focus { border-color: #4f46e5 !important; box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }
