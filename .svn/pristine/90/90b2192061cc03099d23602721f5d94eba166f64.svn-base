<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %>
<%@ taglib prefix="fn" uri="jakarta.tags.functions" %>
<c:set var="ctx" value="${pageContext.request.contextPath}" />

<!DOCTYPE html>
<html lang="ko">
<head>
    <%@ include file="/WEB-INF/views/broker/common/meta.jsp" %>
    <link rel="stylesheet" href="${ctx}/resources/css/broker/common.css">
    <link rel="stylesheet" href="${ctx}/resources/css/broker/pages/quarantine.css">
    <title>검역 결과 조회 | TACS</title>
</head>

<body>
<div class="app" id="app">

    <%@ include file="/WEB-INF/views/broker/common/sidebar.jsp" %>

    <div class="main-wrap">

        <%@ include file="/WEB-INF/views/broker/common/header.jsp" %>

        <div class="content">

            <div class="page active" id="pg-quarantine">

                <div class="sub-page">

                    <h2>
                        <span class="material-symbols-outlined">health_and_safety</span>
                        검역 관리
                    </h2>

                    <!-- 검역관리 탭 -->
                    <div class="sub-tabs" id="tabs-qu">
                        <a class="sub-tab ${activeSub eq 'result' ? 'active' : ''}"
                           href="${ctx}/broker/quarantine/result.do">검역결과조회</a>

                        <a class="sub-tab ${activeSub eq 'import' ? 'active' : ''}"
                           href="${ctx}/broker/quarantine/import.do">수입검역신청</a>

                        <a class="sub-tab ${activeSub eq 'export' ? 'active' : ''}"
                           href="${ctx}/broker/quarantine/export.do">수출검역신청</a>
                    </div>

                    <!-- ===== 검역결과조회 ===== -->
                    <div id="qu-result">

                        <div class="flex-between mb-4">
                            <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">
                                <span class="material-symbols-outlined">assignment_returned</span>
                                검역결과조회
                            </h3>

                            <div class="btn-group">
                                <button type="button"
                                        class="btn btn-outline"
                                        style="font-size:12px;"
                                        onclick="window.print()">
                                    <span class="material-symbols-outlined" style="font-size:16px;">download</span>
                                    다운로드
                                </button>
                            </div>
                        </div>

                        <div class="alert-bar success">
                            <span class="material-symbols-outlined" style="font-size:18px">check_circle</span>
                            검역신청 조회 및 검역 진행상황, 검역결과를 조회하실 수 있습니다.
                        </div>

                        <!-- 검색 영역 -->
                        <form id="quResultSearchForm"
                              action="${ctx}/broker/quarantine/result.do"
                              method="get"
                              style="background:#fff; padding:16px 20px; border:1px solid #e2e8f0; border-radius:4px; margin-bottom:16px;">

                            <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:12px 16px; align-items:end;">

                                <!-- 1행 -->
                                <div>
                                    <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">
                                        검역신청번호
                                    </label>
                                    <input type="text"
                                           id="quSearchApplyNo"
                                           name="searchApplyNo"
                                           value="${searchVO.searchApplyNo}"
                                           style="width:100%; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
                                </div>

                                <div>
                                    <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">
                                        수입자명
                                    </label>
                                    <input type="text"
                                           id="quSearchImporter"
                                           name="searchImporter"
                                           value="${searchVO.searchImporter}"
                                           style="width:100%; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
                                </div>

                                <div>
                                    <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">
                                        상품명
                                    </label>
                                    <input type="text"
                                           id="quSearchProductName"
                                           name="searchProductName"
                                           value="${searchVO.searchProductName}"
                                           style="width:100%; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
                                </div>

                                <div>
                                    <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">
                                        HS코드
                                    </label>
                                    <input type="text"
                                           id="quSearchHsCode"
                                           name="searchHsCode"
                                           value="${searchVO.searchHsCode}"
                                           style="width:100%; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
                                </div>

                                <!-- 2행 -->
                                <div style="grid-column: span 2;">
                                    <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">
                                        조회기간
                                    </label>

                                    <div style="display:flex; gap:8px; align-items:center;">
                                        <input type="date"
                                               id="quSearchFromDate"
                                               name="searchFromDate"
                                               value="${searchVO.searchFromDate}"
                                               style="flex:1; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">

                                        <span style="color:#697d8f; font-weight:600;">~</span>

                                        <input type="date"
                                               id="quSearchToDate"
                                               name="searchToDate"
                                               value="${searchVO.searchToDate}"
                                               style="flex:1; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
                                    </div>
                                </div>

                                <div>
                                    <label style="font-size:12px; font-weight:700; color:#4d6172; display:block; margin-bottom:4px;">
                                        검역결과
                                    </label>
                                    <input type="text"
                                           id="quSearchResult"
                                           name="searchResult"
                                           value="${searchVO.searchResult}"
                                           style="width:100%; padding:8px 10px; border:1px solid #cbd5e1; font-size:13px; background:#fff; color:#203444; outline:none; box-sizing:border-box;">
                                </div>

                                <div style="display:flex; gap:6px; justify-content:flex-end; align-items:flex-end;">
                                    <button type="submit"
                                            class="btn btn-primary"
                                            style="background:#565e74; padding:8px 16px; white-space:nowrap;">
                                        <span class="material-symbols-outlined" style="font-size:16px; vertical-align:middle;">search</span>
                                        조회
                                    </button>

                                    <button type="button"
                                            class="btn btn-secondary"
                                            style="padding:8px 16px; white-space:nowrap;"
                                            onclick="location.href='${ctx}/broker/quarantine/result.do'">
                                        초기화
                                    </button>
                                </div>

                            </div>
                        </form>

                        <!-- 목록 테이블 -->
                        <div style="overflow-x:auto; border:1px solid #e2e8f0; border-top:2px solid #334155;">
                            <table class="data-table" style="width:100%; margin-top:0;">
                                <thead style="background:#ecf4ff;">
                                <tr>
                                    <th style="width:50px;"><input type="checkbox"></th>
                                    <th style="width:130px;">검역신청번호 <span class="req">*</span></th>
                                    <th style="width:100px;">수입자명</th>
                                    <th style="width:120px;">상품명</th>
                                    <th style="width:100px;">HS코드</th>
                                    <th style="width:110px;">신청일</th>
                                    <th style="width:110px;">검역완료일</th>
                                    <th style="width:90px;">검역수량</th>
                                    <th style="width:100px;">검역결과</th>
                                    <th style="width:80px;">상세</th>
                                </tr>
                                </thead>

                                <tbody id="quResultTableBody">
                                <c:choose>
                                    <c:when test="${empty resultList}">
                                        <tr>
                                            <td colspan="10" style="text-align:center; color:#697d8f; padding:24px;">
                                                조회된 검역 신청 결과가 없습니다.
                                            </td>
                                        </tr>
                                    </c:when>

                                    <c:otherwise>
                                        <c:forEach var="row" items="${resultList}">
                                            <tr>
                                                <td>
                                                    <input type="checkbox" value="${row.iirReqNo}">
                                                </td>

                                                <td class="td-id">${row.iirReqNo}</td>
                                                <td>${row.idImprNm}</td>
                                                <td>${row.idiDclrGdsnm}</td>
                                                <td>${row.idiHsCd}</td>
                                                <td>${row.iirDt}</td>
                                                <td>${empty row.iirCmplDt ? '—' : row.iirCmplDt}</td>

                                                <td>
                                                    <span style="font-weight:700; color:#1d6b4f;">
                                                        ${row.idiQty} ${row.idiQtyUnitCd}
                                                    </span>
                                                </td>

                                                <td>
                                                    <c:choose>
                                                        <c:when test="${row.iirStatusCd eq 'REQ'}">
                                                            <span class="badge badge-wait">요청</span>
                                                        </c:when>

                                                        <c:when test="${row.iirStatusCd eq 'DONE' or row.iirStatusCd eq 'CMPL'}">
                                                            <span class="badge badge-ok">검역완료</span>
                                                        </c:when>

                                                        <c:otherwise>
                                                            <span class="badge badge-wait">
                                                                ${empty row.iirStatusNm ? row.iirStatusCd : row.iirStatusNm}
                                                            </span>
                                                        </c:otherwise>
                                                    </c:choose>
                                                </td>

                                                <td>
                                                    <a class="mini mini-view"
                                                       href="${ctx}/broker/quarantine/detail.do?iirReqNo=${row.iirReqNo}">
                                                        상세
                                                    </a>
                                                </td>
                                            </tr>
                                        </c:forEach>
                                    </c:otherwise>
                                </c:choose>
                                </tbody>
                            </table>
                        </div>

                        <!-- 목록 하단 -->
                        <div style="margin-top:16px; display:flex; justify-content:space-between; align-items:center;">
                            <div style="font-size:12px; color:#697d8f;">
                                <strong id="quTotalCount">
                                    <c:choose>
                                        <c:when test="${empty resultList}">0</c:when>
                                        <c:otherwise>${fn:length(resultList)}</c:otherwise>
                                    </c:choose>
                                </strong>
                                건의 검역신청이 조회되었습니다.
                            </div>

                            <div class="pagination">
                                <button type="button" class="page-btn" title="처음" disabled>«</button>
                                <button type="button" class="page-btn" title="이전" disabled>‹</button>
                                <button type="button" class="page-btn active">1</button>
                                <button type="button" class="page-btn">2</button>
                                <button type="button" class="page-btn">3</button>
                                <button type="button" class="page-btn">4</button>
                                <button type="button" class="page-btn">5</button>
                                <button type="button" class="page-btn" title="다음">›</button>
                                <button type="button" class="page-btn" title="마지막">»</button>
                            </div>
                        </div>

                    </div>
                    <!-- /#qu-result -->

                </div>
                <!-- /.sub-page -->

            </div>
            <!-- /.page -->

        </div>
        <!-- /.content -->

    </div>
    <!-- /.main-wrap -->

</div>
<!-- /.app -->


<!-- 검역결과 상세 모달 -->
<div class="modal-bg" id="quDetailModal">
    <div class="modal-box" style="width:620px;">

        <h3>
            <span class="material-symbols-outlined">assignment_turned_in</span>
            검역결과 상세조회
        </h3>

        <button type="button"
                class="modal-close"
                onclick="document.getElementById('quDetailModal').classList.remove('show')">
            ×
        </button>

        <div style="margin-top:20px;">

            <div style="background:#f8fafc; padding:16px; border-left:4px solid #565e74; margin-bottom:16px;">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; font-size:13px;">

                    <div>
                        <div style="color:#697d8f; font-size:11px; font-weight:700; margin-bottom:4px;">검역신청번호</div>
                        <div id="quDetailApplyNo" style="font-size:14px; font-weight:700; color:#203444;">-</div>
                    </div>

                    <div>
                        <div style="color:#697d8f; font-size:11px; font-weight:700; margin-bottom:4px;">검역진행상태</div>
                        <div id="quDetailStatus" style="font-size:14px; font-weight:700; color:#1d6b4f;">-</div>
                    </div>

                    <div>
                        <div style="color:#697d8f; font-size:11px; font-weight:700; margin-bottom:4px;">신청인</div>
                        <div id="quDetailApplicant" style="font-size:13px; color:#203444;">-</div>
                    </div>

                    <div>
                        <div style="color:#697d8f; font-size:11px; font-weight:700; margin-bottom:4px;">수입자</div>
                        <div id="quDetailImporter" style="font-size:13px; color:#203444;">-</div>
                    </div>

                </div>
            </div>

            <h4 style="font-size:12px; font-weight:700; margin-top:20px; margin-bottom:10px; border-bottom:1px solid #e2e8f0; padding-bottom:8px;">
                ■ 검역신청 정보
            </h4>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:16px; font-size:12px;">
                <div>
                    <div style="color:#697d8f; font-size:10px; margin-bottom:4px;">수출국</div>
                    <div id="quDetailExportCountry" style="color:#203444; font-weight:600;">
                        ${empty detailVO.idShipoutCntryCd ? '-' : detailVO.idShipoutCntryCd}
                    </div>
                </div>

                <div>
                    <div style="color:#697d8f; font-size:10px; margin-bottom:4px;">B/L번호</div>
                    <div id="quDetailBlNo" style="color:#203444; font-weight:600;">
                        ${empty detailVO.irBlAwbNo ? '-' : detailVO.irBlAwbNo}
                    </div>
                </div>

                <div>
                    <div style="color:#697d8f; font-size:10px; margin-bottom:4px;">도착항</div>
                    <div id="quDetailArrvPort" style="color:#203444; font-weight:600;">
                        ${empty detailVO.irArrvPortCd ? '-' : detailVO.irArrvPortCd}
                    </div>
                </div>

                <div>
                    <div style="color:#697d8f; font-size:10px; margin-bottom:4px;">접수검역소</div>
                    <div id="quDetailQrtnInst" style="color:#203444; font-weight:600;">
                        ${empty detailVO.iirQrtnInstCd ? '-' : detailVO.iirQrtnInstCd}
                    </div>
                </div>
            </div>

            <h4 style="font-size:12px; font-weight:700; margin-top:20px; margin-bottom:10px; border-bottom:1px solid #e2e8f0; padding-bottom:8px;">
                ■ 검역 대상 물품
            </h4>

            <div style="overflow-x:auto; border:1px solid #e2e8f0; margin-bottom:16px;">
                <table class="data-table" style="font-size:11px;">
                    <thead style="background:#f8fafc;">
                    <tr>
                        <th>HS코드</th>
                        <th>상품명</th>
                        <th>신청수량</th>
                        <th>검역장소</th>
                        <th>검역결과</th>
                    </tr>
                    </thead>

                    <tbody id="quDetailItems">
                    <tr>
                        <td colspan="5" style="text-align:center; color:#697d8f; padding:16px;">
                            상세 정보를 선택하세요.
                        </td>
                    </tr>
                    </tbody>
                </table>
            </div>

            <h4 style="font-size:12px; font-weight:700; margin-top:20px; margin-bottom:10px; border-bottom:1px solid #e2e8f0; padding-bottom:8px;">
                ■ 검역 결과 및 의견
            </h4>

            <div style="background:#f0fdf4; padding:12px; border-radius:4px; border-left:4px solid #1d6b4f; margin-bottom:16px;">
                <div style="font-size:12px; color:#065f46; line-height:1.6;">
                    <strong>검역결과:</strong>
                    <span id="quDetailResult">
                        ${empty detailVO.iirResultNm ? '-' : detailVO.iirResultNm}
                    </span>
                    <br>

                    <strong>검역일시:</strong>
                    <span id="quDetailResultDt">
                        ${empty detailVO.iirResultDt ? '-' : detailVO.iirResultDt}
                    </span>
                    <br>

                    <strong>담당자:</strong>
                    <span id="quDetailOfficer">
                        ${empty detailVO.iirRsltOfficerId ? '-' : detailVO.iirRsltOfficerId}
                    </span>
                    <br>

                    <strong>의견:</strong>
                    <span id="quDetailOpinion">
                        ${empty detailVO.iirResultCn ? '-' : detailVO.iirResultCn}
                    </span>
                </div>
            </div>

            <h4 style="font-size:12px; font-weight:700; margin-top:20px; margin-bottom:10px; border-bottom:1px solid #e2e8f0; padding-bottom:8px;">
                ■ 첨부문서
            </h4>

            <div style="background:#ecf4ff; padding:12px; border-radius:4px; margin-bottom:16px;">
                <div style="font-size:12px; color:#697d8f;">
                    등록된 첨부문서는 추후 공통 파일 모듈 연동 후 표시됩니다.
                </div>
            </div>

            <div class="btn-row" style="justify-content:flex-end; gap:8px; padding-top:16px; border-top:1px solid #e2e8f0;">
                <button type="button" class="btn btn-secondary" style="width:120px;" onclick="window.print()">인쇄</button>

                <button type="button"
                        class="btn btn-primary"
                        style="width:120px;"
                        onclick="document.getElementById('quDetailModal').classList.remove('show')">
                    닫기
                </button>
            </div>

        </div>
    </div>
</div>


<%@ include file="/WEB-INF/views/broker/common/modals.jsp" %>

<script>
    window.contextPath = '${ctx}';
</script>

<c:if test="${not empty detailVO}">
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('quDetailApplyNo').textContent =
                '${detailVO.iirReqNo}';

            document.getElementById('quDetailStatus').textContent =
                '${empty detailVO.iirStatusNm ? detailVO.iirStatusCd : detailVO.iirStatusNm}';

            document.getElementById('quDetailApplicant').textContent =
                '${detailVO.brokerOfficeNm}';

            document.getElementById('quDetailImporter').textContent =
                '${detailVO.idImprNm}';

            var tbody = document.getElementById('quDetailItems');

            if (tbody) {
                tbody.innerHTML =
                    '<tr>' +
                    '<td>${detailVO.idiHsCd}</td>' +
                    '<td>${detailVO.idiDclrGdsnm}</td>' +
                    '<td style="font-weight:700;">${detailVO.idiQty} ${detailVO.idiQtyUnitCd}</td>' +
                    '<td style="font-weight:700;">${detailVO.iilNm}</td>' +
                    '<td><span class="badge badge-ok" style="font-size:10px;">${empty detailVO.iirResultNm ? detailVO.iirStatusNm : detailVO.iirResultNm}</span></td>' +
                    '</tr>';
            }

            document.getElementById('quDetailModal').classList.add('show');
        });
    </script>
</c:if>

<script src="${ctx}/resources/js/broker/common.js"></script>
<script src="${ctx}/resources/js/broker/pages/quarantine.js"></script>

</body>
</html>